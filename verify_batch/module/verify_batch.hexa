#!hexa strict
// verify_batch/module/verify_batch.hexa — productized batch runner for verify_*.hexa
//
// @tool(slug="verify_batch", desc="Discover verify_*.hexa under a root, run each via `hexa <file>`, report pass/fail/unrunnable + slowest 5; mtime-based cache at state/verify_batch_cache.jsonl.")
// @usage(hexa run verify_batch/module/verify_batch.hexa [--root DIR] [--dry] [--full] [--json] [--self-test])
// @sentinel(__VERIFY_BATCH__ PASS|FAIL total=N passed=N failed=N unrunnable=N runtime_ms=N)
// @origin(~/core/n6-architecture/experiments/run_verify_batch.hexa, run_verify_batch_cached.py — productized to .hexa, HEXA-ONLY policy 2026-04-27)
// @api(fn run(targets: array, cache_strategy: string) -> map)
// @allow-bare-exec

// ─── path roots / helpers ─────────────────────────────────────

fn _home() -> string { return env_var("HOME") }

fn _core_root() -> string {
    let override = env_var("NEXUS_CORE_ROOT")
    if len(override) > 0 { return override }
    return _home() + "/core"
}

fn _default_root() -> string {
    return _home() + "/core/n6-architecture/experiments/"
}

fn _cache_path() -> string {
    return _core_root() + "/nexus/state/verify_batch_cache.jsonl"
}

fn dir_exists(p: string) -> bool {
    let out = to_string(exec("test -d '" + p + "' && echo y || echo n")).trim()
    if out == "y" { return true }
    return false
}

fn file_exists_safe(p: string) -> bool {
    let out = to_string(exec("test -f '" + p + "' && echo y || echo n")).trim()
    if out == "y" { return true }
    return false
}

fn _hexa_cli_present() -> bool {
    let h = to_string(exec("command -v hexa 2>/dev/null")).trim()
    if len(h) > 0 { return true }
    let alt = _home() + "/core/hexa-lang/hexa"
    if file_exists_safe(alt) { return true }
    return false
}

fn _hexa_cli_path() -> string {
    let h = to_string(exec("command -v hexa 2>/dev/null")).trim()
    if len(h) > 0 { return h }
    return _home() + "/core/hexa-lang/hexa"
}

fn _file_mtime(p: string) -> string {
    let r = to_string(exec("stat -f '%m' '" + p + "' 2>/dev/null || stat -c '%Y' '" + p + "' 2>/dev/null")).trim()
    if len(r) == 0 { return "0" }
    return r
}

fn _now_iso() -> string {
    return to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
}

// ─── target discovery ─────────────────────────────────────────
// Accepts an array of roots/files. For each entry:
//   - if a file ending in .hexa, include directly
//   - if a directory, glob `verify_*.hexa` recursively, skip .cache/ & __pycache__/
fn _collect_targets(targets: array) -> array {
    let mut out = []
    let mut i = 0
    while i < len(targets) {
        let t = targets[i]
        if dir_exists(t) {
            let cmd = "find '" + t + "' -type f -name 'verify_*.hexa' -not -path '*/.cache/*' -not -path '*/__pycache__/*' 2>/dev/null | sort"
            let raw = to_string(exec(cmd)).trim()
            if len(raw) > 0 {
                let lines = raw.split("\n")
                let mut j = 0
                while j < len(lines) {
                    if len(lines[j].trim()) > 0 { out.push(lines[j]) }
                    j = j + 1
                }
            }
        } else if file_exists_safe(t) {
            out.push(t)
        }
        i = i + 1
    }
    return out
}

// ─── cache I/O (JSONL, append-only, latest-wins) ──────────────
// Each record: {"path":"<abs>","mtime":"<ts>","verdict":"pass|fail|unrunnable","ms":<int>,"ts":"<iso>"}
// Read = scan whole file; later occurrences override earlier. Lightweight grep parse.

fn _cache_lookup(path: string, mtime: string) -> string {
    // Returns verdict ("pass"|"fail"|"unrunnable") if cached entry matches mtime, else "".
    let cache = _cache_path()
    if !file_exists_safe(cache) { return "" }
    // grep last occurrence by reverse-tac
    let needle = "\"path\":\"" + path + "\""
    let cmd = "grep -F '" + needle + "' '" + cache + "' 2>/dev/null | tail -1"
    let line = to_string(exec(cmd)).trim()
    if len(line) == 0 { return "" }
    // crude JSON field extraction
    let mt_key = "\"mtime\":\""
    let mt_idx = line.index_of(mt_key)
    if mt_idx < 0 { return "" }
    let after_mt = line.substring(mt_idx + len(mt_key), len(line))
    let mt_end = after_mt.index_of("\"")
    if mt_end < 0 { return "" }
    let cached_mt = after_mt.substring(0, mt_end)
    if cached_mt != mtime { return "" }
    let v_key = "\"verdict\":\""
    let v_idx = line.index_of(v_key)
    if v_idx < 0 { return "" }
    let after_v = line.substring(v_idx + len(v_key), len(line))
    let v_end = after_v.index_of("\"")
    if v_end < 0 { return "" }
    return after_v.substring(0, v_end)
}

fn _cache_append(path: string, mtime: string, verdict: string, ms: int) {
    let cache = _cache_path()
    let dir = _core_root() + "/nexus/state"
    exec("mkdir -p '" + dir + "' 2>/dev/null")
    let line = "{\"path\":\"" + path + "\",\"mtime\":\"" + mtime + "\",\"verdict\":\"" + verdict + "\",\"ms\":" + to_string(ms) + ",\"ts\":\"" + _now_iso() + "\"}\n"
    // append; use printf via exec to avoid race
    let escaped = line.replace("'", "'\\''")
    exec("printf '%s' '" + escaped + "' >> '" + cache + "' 2>/dev/null")
}

// ─── pass detection (mirrors original `[상태] pass` semantics) ─
// Return: "pass" | "fail" | "unrunnable"
fn _classify(exit_code: int, output: string) -> string {
    if exit_code == 127 { return "unrunnable" }  // no such command
    if output.index_of("[상태] pass") >= 0 { return "pass" }
    if output.index_of("[상태] PASS") >= 0 { return "pass" }
    if output.index_of("__SELFTEST__ PASS") >= 0 { return "pass" }
    if exit_code == 0 && len(output.trim()) == 0 { return "pass" }  // exit 0 + empty → unknown→pass per README
    if exit_code == 0 { return "pass" }  // exit 0 + output → pass_no_marker
    return "fail"
}

// ─── single run (with timing) ─────────────────────────────────
fn _run_one(path: string) -> array {
    // Returns [verdict, ms]
    if !_hexa_cli_present() { return ["unrunnable", 0] }
    let bin = _hexa_cli_path()
    let t0 = clock()
    // capture exit code and output; tee to /dev/null to combine streams
    let cmd = "'" + bin + "' run '" + path + "' 2>&1; echo __EXIT__=$?"
    let raw = to_string(exec(cmd))
    let t1 = clock()
    let ms = t1 - t0
    // parse exit code
    let mark = "__EXIT__="
    let mi = raw.index_of(mark)
    let mut ec = 0
    let mut output = raw
    if mi >= 0 {
        let after = raw.substring(mi + len(mark), len(raw))
        let nl = after.index_of("\n")
        let ec_str = if nl >= 0 { after.substring(0, nl).trim() } else { after.trim() }
        ec = to_int(ec_str)
        output = raw.substring(0, mi)
    }
    let verdict = _classify(ec, output)
    return [verdict, ms]
}

// ─── public API: run ──────────────────────────────────────────
// fn run(targets: array, cache_strategy: string) -> map
//   cache_strategy: "mtime" (default) | "full" (re-run all) | "dry" (no exec)
fn run(targets: array, cache_strategy: string) -> map {
    let strat = if len(cache_strategy) == 0 { "mtime" } else { cache_strategy }
    let files = _collect_targets(targets)
    let mut total = 0
    let mut passed = 0
    let mut failed = 0
    let mut unrunnable = 0
    let mut runtime_ms_total = 0
    // slowest_5: array of [path, ms] kept sorted desc by ms (size <= 5)
    let mut slowest = []

    let mut i = 0
    while i < len(files) {
        let abs = files[i]
        if len(abs.trim()) == 0 { i = i + 1; continue }
        total = total + 1
        let mt = _file_mtime(abs)
        let mut verdict = ""
        let mut ms = 0

        if strat == "dry" {
            verdict = "dry"
            ms = 0
        } else if strat == "mtime" {
            let cached = _cache_lookup(abs, mt)
            if len(cached) > 0 {
                verdict = cached
                ms = 0   // cached → no runtime contribution
            } else {
                let r = _run_one(abs)
                verdict = r[0]
                ms = r[1]
                _cache_append(abs, mt, verdict, ms)
            }
        } else {
            // full
            let r = _run_one(abs)
            verdict = r[0]
            ms = r[1]
            _cache_append(abs, mt, verdict, ms)
        }

        if verdict == "pass" { passed = passed + 1 }
        else if verdict == "fail" { failed = failed + 1 }
        else if verdict == "unrunnable" { unrunnable = unrunnable + 1 }
        runtime_ms_total = runtime_ms_total + ms

        // maintain top-5 slowest
        if ms > 0 {
            slowest.push([abs, ms])
            // simple bubble-sort + truncate
            let mut a = 0
            while a < len(slowest) {
                let mut b = a + 1
                while b < len(slowest) {
                    if slowest[a][1] < slowest[b][1] {
                        let tmp = slowest[a]
                        slowest[a] = slowest[b]
                        slowest[b] = tmp
                    }
                    b = b + 1
                }
                a = a + 1
            }
            while len(slowest) > 5 { slowest.pop() }
        }

        i = i + 1
    }

    let mut r = {}
    r["total"] = total
    r["passed"] = passed
    r["failed"] = failed
    r["unrunnable"] = unrunnable
    r["runtime_ms_total"] = runtime_ms_total
    r["slowest_5"] = slowest
    return r
}

// ─── CLI / self-test ──────────────────────────────────────────

fn _print_summary(r: map) {
    println("=== verify_batch summary ===")
    println("  total       : " + to_string(r["total"]))
    println("  passed      : " + to_string(r["passed"]))
    println("  failed      : " + to_string(r["failed"]))
    println("  unrunnable  : " + to_string(r["unrunnable"]))
    println("  runtime_ms  : " + to_string(r["runtime_ms_total"]))
    let s = r["slowest_5"]
    println("  slowest_5   :")
    let mut i = 0
    while i < len(s) {
        let row = s[i]
        println("    " + to_string(row[1]) + "ms  " + row[0])
        i = i + 1
    }
}

fn _print_json(r: map) {
    println("{")
    println("  \"total\": " + to_string(r["total"]) + ",")
    println("  \"passed\": " + to_string(r["passed"]) + ",")
    println("  \"failed\": " + to_string(r["failed"]) + ",")
    println("  \"unrunnable\": " + to_string(r["unrunnable"]) + ",")
    println("  \"runtime_ms_total\": " + to_string(r["runtime_ms_total"]) + ",")
    let s = r["slowest_5"]
    println("  \"slowest_5\": [")
    let mut i = 0
    while i < len(s) {
        let row = s[i]
        let comma = if i + 1 < len(s) { "," } else { "" }
        println("    {\"path\":\"" + row[0] + "\",\"ms\":" + to_string(row[1]) + "}" + comma)
        i = i + 1
    }
    println("  ]")
    println("}")
}

fn _self_test() {
    println("=== verify_batch --self-test ===")
    let tdir = "/tmp/empty_test_dir"
    exec("rm -rf '" + tdir + "'")
    exec("mkdir -p '" + tdir + "'")
    let r = run([tdir], "mtime")
    let ok_total = (r["total"] == 0)
    let ok_passed = (r["passed"] == 0)
    let ok_failed = (r["failed"] == 0)
    let ok_unrun = (r["unrunnable"] == 0)
    let ok_rt = (r["runtime_ms_total"] == 0)
    let s = r["slowest_5"]
    let ok_slow = (len(s) == 0)
    let ok_keys = ok_total && ok_passed && ok_failed && ok_unrun && ok_rt && ok_slow
    if ok_keys {
        println("  empty dir → all-zero summary: PASS")
    } else {
        println("  empty dir summary: FAIL " + to_string(r))
    }
    // also test that a nonexistent target is silently skipped
    let r2 = run(["/tmp/__definitely_nope_" + to_string(clock())], "mtime")
    let ok2 = (r2["total"] == 0)
    if ok2 { println("  nonexistent target → 0 total: PASS") }
    else { println("  nonexistent target → " + to_string(r2["total"]) + " : FAIL") }
    // ensure 'dry' mode doesn't crash
    let r3 = run([tdir], "dry")
    let ok3 = (r3["total"] == 0)
    if ok3 { println("  dry mode summary structure: PASS") }
    else { println("  dry mode FAIL") }
    exec("rm -rf '" + tdir + "'")
    if ok_keys && ok2 && ok3 {
        println("__VERIFY_BATCH__ PASS total=0 passed=0 failed=0 unrunnable=0 runtime_ms=0")
        exit(0)
    }
    println("__VERIFY_BATCH__ FAIL")
    exit(2)
}

fn main() -> void {
    let raw = args()
    let mut cli = []
    let mut a = 2
    while a < len(raw) { cli.push(raw[a]); a = a + 1 }

    let mut root = _default_root()
    let mut mode = "mtime"
    let mut dry = false
    let mut json = false
    let mut self_test = false

    let mut i = 0
    while i < len(cli) {
        let arg = cli[i]
        if arg == "--self-test" || arg == "--selftest" { self_test = true }
        else if arg == "--dry" { dry = true; mode = "dry" }
        else if arg == "--full" { mode = "full" }
        else if arg == "--json" { json = true }
        else if arg == "--root" {
            if i + 1 >= len(cli) { eprintln("--root requires PATH"); exit(1) }
            root = cli[i + 1]
            i = i + 1
        }
        else if arg == "--help" || arg == "-h" {
            println("usage: hexa run verify_batch/module/verify_batch.hexa [--root DIR] [--dry] [--full] [--json] [--self-test]")
            exit(0)
        }
        else if arg == "--cache" {
            if i + 1 >= len(cli) { eprintln("--cache requires mode"); exit(1) }
            mode = cli[i + 1]
            i = i + 1
        }
        else {
            eprintln("verify_batch: unknown arg `" + arg + "`")
            exit(1)
        }
        i = i + 1
    }

    if self_test { _self_test() }

    if dry {
        // print would-be runs
        let files = _collect_targets([root])
        println("[verify_batch --dry] would run " + to_string(len(files)) + " targets under " + root)
        let mut p = 0
        while p < len(files) && p < 20 {
            println("  " + files[p])
            p = p + 1
        }
        if len(files) > 20 { println("  ... (" + to_string(len(files) - 20) + " more)") }
        let r = run([root], "dry")
        if json { _print_json(r) } else { _print_summary(r) }
        println("__VERIFY_BATCH__ PASS total=" + to_string(r["total"]) + " mode=dry")
        exit(0)
    }

    let r = run([root], mode)
    if json { _print_json(r) } else { _print_summary(r) }
    let mut verdict = "PASS"
    if r["failed"] > 0 { verdict = "FAIL" }
    println("__VERIFY_BATCH__ " + verdict + " total=" + to_string(r["total"]) +
        " passed=" + to_string(r["passed"]) +
        " failed=" + to_string(r["failed"]) +
        " unrunnable=" + to_string(r["unrunnable"]) +
        " runtime_ms=" + to_string(r["runtime_ms_total"]))
    if r["failed"] > 0 { exit(2) }
    exit(0)
}
