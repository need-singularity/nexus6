// uprim_test.hexa — smoke test for u_log/u_env/u_floor1 shim.
use "shared/lib/uprim"

fn main() {
  let a = u_log(2.718281828)       // ~= 1.0
  let b = u_floor1(3.7)            // == 3
  let c = u_env("HOME")            // user $HOME
  print("u_log(e)    = " + to_string(a))
  print("u_floor1(3.7)= " + to_string(b))
  print("u_env(HOME) = " + c)
}
