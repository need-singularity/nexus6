#!hexa strict
// lib/n6_honesty/cli.hexa — n6_honesty CLI front-end (rewrite of lost cli.py)
//
// @tool(slug="n6_honesty_cli", desc="thin CLI dispatcher over honesty_triad.hexa. Mirrors the documented sub-commands (scan / scan-dir / --self-test). honesty_triad.hexa already exposes its own main() with --scan / --scan-dir flags; this CLI provides a stable subcommand surface so external callers can invoke `cli.hexa scan <file>` rather than reaching into the lint backend's flag layout.")
// @usage(hexa run lib/n6_honesty/cli.hexa --self-test)
// @usage(hexa run lib/n6_honesty/cli.hexa scan <file>)
// @usage(hexa run lib/n6_honesty/cli.hexa scan-dir <dir>)
// @exit_codes(0=PASS, 1=usage/io, 2=lint FAIL verdict propagated from backend)
// @sentinel(__N6_HONESTY_CLI__ PASS|FAIL [sub=<subcmd> reason=<slug>])
// @origin(lib/n6_honesty/cli.py — lost; orphan __pycache__/cli.cpython-314.pyc only forensic trace; semantics reconstructed from honesty_triad.hexa @usage banners. Rewritten as .hexa per AG10 HEXA-ONLY enforcement, ω-cycle 2026-04-27 py-module-restoration-as-hexa-rewrite.)

// ─── helpers ──────────────────────────────────────────────────

fn file_exists_safe(p: string) -> bool {
    let out = to_string(exec("test -f '" + p + "' && echo y || echo n")).trim()
    if out == "y" { return true }
    return false
}

fn dir_exists(p: string) -> bool {
    let out = to_string(exec("test -d '" + p + "' && echo y || echo n")).trim()
    if out == "y" { return true }
    return false
}

fn _backend_path() -> string {
    return "lib/n6_honesty/honesty_triad.hexa"
}

// ─── subcommand: scan ────────────────────────────────────────
fn _cmd_scan(rest: array) -> int {
    if len(rest) < 1 {
        eprintln("__N6_HONESTY_CLI__ FAIL sub=scan reason=usage fix='scan <file>'")
        return 1
    }
    let path = rest[0]
    if !file_exists_safe(path) {
        eprintln("__N6_HONESTY_CLI__ FAIL sub=scan reason=file_not_found path=" + path)
        return 1
    }
    let bp = _backend_path()
    if !file_exists_safe(bp) {
        eprintln("__N6_HONESTY_CLI__ FAIL sub=scan reason=missing_backend path=" + bp)
        return 1
    }
    let cmd = "hexa run " + bp + " --scan '" + path + "' 2>&1"
    let out = to_string(exec(cmd))
    print(out)
    if out.index_of("__N6_HONESTY__ FAIL") >= 0 {
        eprintln("__N6_HONESTY_CLI__ FAIL sub=scan reason=backend_verdict_fail file=" + path)
        return 2
    }
    println("__N6_HONESTY_CLI__ PASS sub=scan file=" + path)
    return 0
}

// ─── subcommand: scan-dir ────────────────────────────────────
fn _cmd_scan_dir(rest: array) -> int {
    if len(rest) < 1 {
        eprintln("__N6_HONESTY_CLI__ FAIL sub=scan-dir reason=usage fix='scan-dir <dir>'")
        return 1
    }
    let dir = rest[0]
    if !dir_exists(dir) {
        eprintln("__N6_HONESTY_CLI__ FAIL sub=scan-dir reason=dir_not_found path=" + dir)
        return 1
    }
    let bp = _backend_path()
    if !file_exists_safe(bp) {
        eprintln("__N6_HONESTY_CLI__ FAIL sub=scan-dir reason=missing_backend path=" + bp)
        return 1
    }
    let cmd = "hexa run " + bp + " --scan-dir '" + dir + "' 2>&1"
    let out = to_string(exec(cmd))
    print(out)
    // backend returns 2 if any FAIL verdict; surface its exit by re-checking sentinel
    if out.index_of("__N6_HONESTY__ FAIL") >= 0 {
        eprintln("__N6_HONESTY_CLI__ FAIL sub=scan-dir reason=backend_aggregate_fail dir=" + dir)
        return 2
    }
    println("__N6_HONESTY_CLI__ PASS sub=scan-dir dir=" + dir)
    return 0
}

// ─── self-test ───────────────────────────────────────────────
// Contract: sentinel-only. Backend semantic correctness is honesty_triad.hexa's
// responsibility (its own --self-test covers C1..C5 fixtures).
fn _run_self_test() -> int {
    println("=== n6_honesty_cli --self-test ===")
    let r1 = _cmd_scan([])
    if r1 == 0 { eprintln("__N6_HONESTY_CLI__ FAIL reason=usage_gate sub=scan"); return 2 }
    println("  usage-gate scan: OK (exit=" + to_string(r1) + ")")
    let r2 = _cmd_scan_dir([])
    if r2 == 0 { eprintln("__N6_HONESTY_CLI__ FAIL reason=usage_gate sub=scan-dir"); return 2 }
    println("  usage-gate scan-dir: OK (exit=" + to_string(r2) + ")")
    let r3 = _cmd_scan(["/nonexistent/__no_such_file__.n6"])
    if r3 == 0 { eprintln("__N6_HONESTY_CLI__ FAIL reason=missing_file_gate sub=scan"); return 2 }
    println("  file-not-found gate scan: OK (exit=" + to_string(r3) + ")")
    let r4 = _cmd_scan_dir(["/nonexistent/__no_such_dir__"])
    if r4 == 0 { eprintln("__N6_HONESTY_CLI__ FAIL reason=missing_dir_gate sub=scan-dir"); return 2 }
    println("  dir-not-found gate scan-dir: OK (exit=" + to_string(r4) + ")")
    println("__N6_HONESTY_CLI__ PASS sub=self-test")
    return 0
}

// ─── runner ──────────────────────────────────────────────────

fn main() -> int {
    let raw = args()
    let mut cli = []
    let mut ai = 2
    while ai < len(raw) {
        cli.push(raw[ai])
        ai = ai + 1
    }
    if len(cli) == 0 {
        println("usage: hexa run lib/n6_honesty/cli.hexa <subcmd> [args]")
        println("  scan <file>")
        println("  scan-dir <dir>")
        println("  --self-test")
        return 1
    }
    let sub = cli[0]
    let mut rest = []
    let mut i = 1
    while i < len(cli) {
        rest.push(cli[i])
        i = i + 1
    }
    if sub == "--self-test" || sub == "--selftest" || sub == "self-test" {
        return _run_self_test()
    }
    if sub == "scan" { return _cmd_scan(rest) }
    if sub == "scan-dir" { return _cmd_scan_dir(rest) }
    if sub == "--help" || sub == "-h" {
        println("usage: hexa run lib/n6_honesty/cli.hexa <subcmd> [args]")
        println("  scan <file>")
        println("  scan-dir <dir>")
        println("  --self-test")
        return 0
    }
    eprintln("__N6_HONESTY_CLI__ FAIL reason=unknown_subcmd sub=" + sub + " fix=--help")
    return 1
}
