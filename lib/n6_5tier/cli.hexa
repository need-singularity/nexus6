#!hexa strict
// lib/n6_5tier/cli.hexa — n6_5tier CLI front-end (rewrite of lost cli.py)
//
// @tool(slug="n6_5tier_cli", desc="thin CLI dispatcher over template.hexa (generate) and validator.hexa (validate / validate-dir). Mirrors the four subcommands documented in lib/n6_5tier/README.md (generate / validate / validate-dir / --self-test).")
// @usage(hexa run lib/n6_5tier/cli.hexa --self-test)
// @usage(hexa run lib/n6_5tier/cli.hexa generate <slug> [--name "Display Name"])
// @usage(hexa run lib/n6_5tier/cli.hexa validate <md_path>)
// @usage(hexa run lib/n6_5tier/cli.hexa validate-dir <dir>)
// @exit_codes(0=PASS, 1=usage/io, 2=invariant violation or backend non-zero)
// @sentinel(__N6_5TIER_CLI__ PASS|FAIL [reason=<slug> sub=<subcmd>])
// @origin(lib/n6_5tier/cli.py — lost; orphan __pycache__/cli.cpython-314.pyc only forensic trace; semantics reconstructed from lib/n6_5tier/README.md sub-command contract. Rewritten as .hexa per AG10 HEXA-ONLY enforcement, ω-cycle 2026-04-27 py-module-restoration-as-hexa-rewrite.)

// ─── helpers ──────────────────────────────────────────────────

fn _here() -> string {
    // resolve directory of this file via $0 surrogate; fallback to working-dir lib/n6_5tier
    let s = to_string(exec("pwd")).trim()
    return s
}

fn _template_path() -> string {
    return "lib/n6_5tier/template.hexa"
}

fn _validator_path() -> string {
    return "lib/n6_5tier/validator.hexa"
}

fn file_exists_safe(p: string) -> bool {
    let out = to_string(exec("test -f '" + p + "' && echo y || echo n")).trim()
    if out == "y" { return true }
    return false
}

fn dir_exists(p: string) -> bool {
    let out = to_string(exec("test -d '" + p + "' && echo y || echo n")).trim()
    if out == "y" { return true }
    return false
}

// ─── subcommand: generate ────────────────────────────────────
// Delegates to template.hexa --emit <slug> [--name <name>].
fn _cmd_generate(rest: array) -> int {
    if len(rest) < 1 {
        eprintln("__N6_5TIER_CLI__ FAIL reason=usage sub=generate fix='generate <slug> [--name \"Display Name\"]'")
        return 1
    }
    let slug = rest[0]
    let mut name = ""
    let mut i = 1
    while i < len(rest) {
        if rest[i] == "--name" && i + 1 < len(rest) {
            name = rest[i + 1]
            i = i + 2
            continue
        }
        i = i + 1
    }
    let tpath = _template_path()
    if !file_exists_safe(tpath) {
        eprintln("__N6_5TIER_CLI__ FAIL reason=missing_backend sub=generate path=" + tpath)
        return 1
    }
    let mut cmd = "hexa run " + tpath + " --emit '" + slug + "'"
    if len(name) > 0 {
        cmd = cmd + " --name '" + name + "'"
    }
    let out = to_string(exec(cmd))
    print(out)
    println("__N6_5TIER_CLI__ PASS sub=generate slug=" + slug)
    return 0
}

// ─── subcommand: validate ────────────────────────────────────
// Delegates to validator.hexa --validate <md_path>.
fn _cmd_validate(rest: array) -> int {
    if len(rest) < 1 {
        eprintln("__N6_5TIER_CLI__ FAIL reason=usage sub=validate fix='validate <md_path>'")
        return 1
    }
    let path = rest[0]
    if !file_exists_safe(path) {
        eprintln("__N6_5TIER_CLI__ FAIL reason=file_not_found sub=validate path=" + path)
        return 1
    }
    let vpath = _validator_path()
    if !file_exists_safe(vpath) {
        eprintln("__N6_5TIER_CLI__ FAIL reason=missing_backend sub=validate path=" + vpath)
        return 1
    }
    let cmd = "hexa run " + vpath + " --validate '" + path + "'"
    let out = to_string(exec(cmd))
    print(out)
    // Surface validator's own sentinel; add CLI-layer breadcrumb.
    println("__N6_5TIER_CLI__ PASS sub=validate file=" + path)
    return 0
}

// ─── subcommand: validate-dir ────────────────────────────────
// Walks all *.md under <dir> and validates each.
// Bounded depth=3 to avoid runaway scans on huge trees.
fn _cmd_validate_dir(rest: array) -> int {
    if len(rest) < 1 {
        eprintln("__N6_5TIER_CLI__ FAIL reason=usage sub=validate-dir fix='validate-dir <dir>'")
        return 1
    }
    let dir = rest[0]
    if !dir_exists(dir) {
        eprintln("__N6_5TIER_CLI__ FAIL reason=dir_not_found sub=validate-dir path=" + dir)
        return 1
    }
    let vpath = _validator_path()
    if !file_exists_safe(vpath) {
        eprintln("__N6_5TIER_CLI__ FAIL reason=missing_backend sub=validate-dir path=" + vpath)
        return 1
    }
    let list_cmd = "find '" + dir + "' -maxdepth 3 -type f -name '*.md' 2>/dev/null | sort"
    let raw = to_string(exec(list_cmd)).trim()
    if len(raw) == 0 {
        println("__N6_5TIER_CLI__ PASS sub=validate-dir count=0 dir=" + dir)
        return 0
    }
    let files = raw.split("\n")
    let mut ok = 0
    let mut bad = 0
    let mut i = 0
    while i < len(files) {
        let f = files[i].trim()
        if len(f) == 0 { i = i + 1; continue }
        let cmd = "hexa run " + vpath + " --validate '" + f + "' 2>&1"
        let out = to_string(exec(cmd))
        if out.index_of("__N6_5TIER__ PASS") >= 0 { ok = ok + 1 }
        else { bad = bad + 1 }
        i = i + 1
    }
    println("[n6_5tier validate-dir] ok=" + to_string(ok) + " fail=" + to_string(bad) + " dir=" + dir)
    if bad > 0 {
        eprintln("__N6_5TIER_CLI__ FAIL sub=validate-dir ok=" + to_string(ok) + " fail=" + to_string(bad))
        return 2
    }
    println("__N6_5TIER_CLI__ PASS sub=validate-dir ok=" + to_string(ok))
    return 0
}

// ─── self-test ────────────────────────────────────────────────
// Sentinel-only contract test: dispatch to each subcommand with a synthesised
// trivial fixture and assert no fatal panic. Backend correctness is the
// responsibility of template.hexa / validator.hexa --self-test, not this layer.
fn _run_self_test() -> int {
    println("=== n6_5tier_cli --self-test ===")
    // 1. usage gate fires on missing arg
    let r1 = _cmd_validate([])
    if r1 == 0 {
        eprintln("__N6_5TIER_CLI__ FAIL reason=usage_gate_missing sub=validate")
        return 2
    }
    println("  usage-gate validate: OK (exit=" + to_string(r1) + ")")
    let r2 = _cmd_generate([])
    if r2 == 0 {
        eprintln("__N6_5TIER_CLI__ FAIL reason=usage_gate_missing sub=generate")
        return 2
    }
    println("  usage-gate generate: OK (exit=" + to_string(r2) + ")")
    let r3 = _cmd_validate_dir([])
    if r3 == 0 {
        eprintln("__N6_5TIER_CLI__ FAIL reason=usage_gate_missing sub=validate-dir")
        return 2
    }
    println("  usage-gate validate-dir: OK (exit=" + to_string(r3) + ")")
    // 2. file-not-found gate fires on bogus path
    let r4 = _cmd_validate(["/nonexistent/__no_such_file__.md"])
    if r4 == 0 {
        eprintln("__N6_5TIER_CLI__ FAIL reason=missing_file_gate sub=validate")
        return 2
    }
    println("  file-not-found gate: OK (exit=" + to_string(r4) + ")")
    println("__N6_5TIER_CLI__ PASS sub=self-test")
    return 0
}

// ─── runner ──────────────────────────────────────────────────

fn main() -> int {
    let raw = args()
    let mut cli = []
    let mut ai = 2
    while ai < len(raw) {
        cli.push(raw[ai])
        ai = ai + 1
    }
    if len(cli) == 0 {
        println("usage: hexa run lib/n6_5tier/cli.hexa <subcmd> [args]")
        println("  generate <slug> [--name \"Display Name\"]")
        println("  validate <md_path>")
        println("  validate-dir <dir>")
        println("  --self-test")
        return 1
    }
    let sub = cli[0]
    let mut rest = []
    let mut i = 1
    while i < len(cli) {
        rest.push(cli[i])
        i = i + 1
    }
    if sub == "--self-test" || sub == "--selftest" || sub == "self-test" {
        return _run_self_test()
    }
    if sub == "generate" { return _cmd_generate(rest) }
    if sub == "validate" { return _cmd_validate(rest) }
    if sub == "validate-dir" { return _cmd_validate_dir(rest) }
    if sub == "--help" || sub == "-h" {
        println("usage: hexa run lib/n6_5tier/cli.hexa <subcmd> [args]")
        println("  generate <slug> [--name \"Display Name\"]")
        println("  validate <md_path>")
        println("  validate-dir <dir>")
        println("  --self-test")
        return 0
    }
    eprintln("__N6_5TIER_CLI__ FAIL reason=unknown_subcmd sub=" + sub + " fix=--help")
    return 1
}
