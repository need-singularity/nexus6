#!hexa strict
// lib/n6_5tier/validator.hexa — domain .md validator (rewrite of lost validator.py)
//
// @tool(slug="n6_5tier_validator", desc="validates an n=6 5-tier domain .md against the cosmology.md exemplar pattern. Checks §1..§7 sections, L0..L4 table, Python verify block, n6 anchors. Returns grade ∈ {A, B, C, F}.")
// @usage(hexa run lib/n6_5tier/validator.hexa --self-test)
// @usage(hexa run lib/n6_5tier/validator.hexa --validate <md_path>)
// @exit_codes(0=PASS, 1=usage/io, 2=validate FAIL/WARN below threshold)
// @sentinel(__N6_5TIER__ PASS|FAIL [grade=<A|B|C|F> file=<path>])
// @origin(lib/n6_5tier/validator.py — lost; rewritten as .hexa per AG10 HEXA-ONLY enforcement)

// ─── helpers ──────────────────────────────────────────────────

fn file_exists_safe(p: string) -> bool {
    let out = to_string(exec("test -f '" + p + "' && echo y || echo n")).trim()
    if out == "y" { return true }
    return false
}

fn _read(path: string) -> string {
    if !file_exists_safe(path) { return "" }
    return to_string(exec("cat '" + path + "' 2>/dev/null"))
}

// ─── section detection ───────────────────────────────────────

fn _required_sections() -> array {
    return [
        "## §1 WHY",
        "## §2 COMPARE",
        "## §3 REQUIRES",
        "## §4 STRUCT",
        "## §5 FLOW",
        "## §6 EVOLVE",
        "## §7 VERIFY"
    ]
}

fn _find_sections(body: string) -> array {
    let req = _required_sections()
    let mut found = []
    let mut i = 0
    while i < len(req) {
        let s = req[i]
        if body.index_of(s) >= 0 { found.push(s) }
        i = i + 1
    }
    return found
}

fn _missing_sections(body: string) -> array {
    let req = _required_sections()
    let mut missing = []
    let mut i = 0
    while i < len(req) {
        let s = req[i]
        if body.index_of(s) < 0 { missing.push(s) }
        i = i + 1
    }
    return missing
}

// ─── L0..L4 table ────────────────────────────────────────────

fn _has_l0_l4_table(body: string) -> bool {
    if body.index_of("L0") < 0 { return false }
    if body.index_of("L1") < 0 { return false }
    if body.index_of("L2") < 0 { return false }
    if body.index_of("L3") < 0 { return false }
    if body.index_of("L4") < 0 { return false }
    return true
}

// ─── Python verify block ─────────────────────────────────────

fn _has_verify_python(body: string) -> bool {
    if body.index_of("```python") < 0 { return false }
    // must be inside §7 VERIFY-ish region
    if body.index_of("§7 VERIFY") < 0 && body.index_of("VERIFY (Python check)") < 0 { return false }
    return true
}

// ─── n6 anchor count ─────────────────────────────────────────
// Counts literal occurrences of n=6 motif strings:
//   "sigma(6)" / "tau(6)" / "phi(6)" / "J_2(6)" / "n=6" / "A000203" / "A000005" / "A000010"

fn _count_substr(body: string, needle: string) -> int {
    if len(needle) == 0 { return 0 }
    let mut c = 0
    let mut idx = 0
    let n = len(body)
    let nl = len(needle)
    while idx < n {
        let pos = body.substring(idx, n).index_of(needle)
        if pos < 0 { return c }
        c = c + 1
        idx = idx + pos + nl
    }
    return c
}

fn _n6_anchor_count(body: string) -> int {
    let mut c = 0
    c = c + _count_substr(body, "sigma(6)")
    c = c + _count_substr(body, "tau(6)")
    c = c + _count_substr(body, "phi(6)")
    c = c + _count_substr(body, "J_2(6)")
    c = c + _count_substr(body, "n=6")
    c = c + _count_substr(body, "A000203")
    c = c + _count_substr(body, "A000005")
    c = c + _count_substr(body, "A000010")
    return c
}

// ─── grading ─────────────────────────────────────────────────
// A: 7/7 sections + L0..L4 + python verify + >=5 n6 anchors
// B: 6/7 sections + L0..L4 + python verify
// C: 5/7 sections (degraded but recognizable)
// F: <5/7 sections

fn _grade(found_count: int, has_l0l4: bool, has_py: bool, anchors: int) -> string {
    if found_count == 7 && has_l0l4 && has_py && anchors >= 5 { return "A" }
    if found_count >= 6 && has_l0l4 && has_py { return "B" }
    if found_count >= 5 { return "C" }
    return "F"
}

// ─── validate ────────────────────────────────────────────────

// fn validate(md_path: string) -> map
//   returns: { sections_found, sections_missing, has_l0_l4_table, has_verify_python,
//              n6_anchor_count, grade }
fn validate(md_path: string) -> map {
    let mut m: map = #{}
    m["path"] = md_path
    if !file_exists_safe(md_path) {
        m["sections_found_count"] = 0
        m["sections_missing_count"] = 7
        m["has_l0_l4_table"] = false
        m["has_verify_python"] = false
        m["n6_anchor_count"] = 0
        m["grade"] = "F"
        m["error"] = "file_not_found"
        return m
    }
    let body = _read(md_path)
    let found = _find_sections(body)
    let missing = _missing_sections(body)
    let l0l4 = _has_l0_l4_table(body)
    let py = _has_verify_python(body)
    let anchors = _n6_anchor_count(body)
    let g = _grade(len(found), l0l4, py, anchors)
    m["sections_found_count"] = len(found)
    m["sections_missing_count"] = len(missing)
    m["has_l0_l4_table"] = l0l4
    m["has_verify_python"] = py
    m["n6_anchor_count"] = anchors
    m["grade"] = g
    return m
}

fn _print_report(r: map) {
    println("  path                   : " + r["path"])
    println("  sections found         : " + to_string(r["sections_found_count"]) + "/7")
    println("  sections missing       : " + to_string(r["sections_missing_count"]))
    println("  has L0..L4 table       : " + to_string(r["has_l0_l4_table"]))
    println("  has python verify block: " + to_string(r["has_verify_python"]))
    println("  n6 anchor count        : " + to_string(r["n6_anchor_count"]))
    println("  grade                  : " + r["grade"])
}

// ─── self-test ────────────────────────────────────────────────
// Three checks:
//   1. generate→validate roundtrip via lib/n6_5tier/template.hexa
//      → must yield grade A or B
//   2. validate ~/core/n6-architecture/domains/physics/cosmology/cosmology.md
//      → must yield grade A or B (PASS-tier)
//   3. validate a deliberately-broken synthetic "cfd" .md
//      → must yield grade F or C (FAIL/WARN-tier)

fn _generate_via_template(slug: string) -> string {
    // Re-implement a minimal generator inline (avoid module-load coupling).
    // Mirrors the structure of template.hexa::generate but is small enough to
    // self-contain. The roundtrip verifies that the validator accepts our own
    // template output — a sanity check rather than a full regression.
    let mut s = ""
    s = s + "# " + slug + " (n=6 5-tier domain)\n\n"
    s = s + "## §1 WHY (how this technology changes your life)\n\nintro for n=6.\n\n"
    s = s + "## §2 COMPARE (current tech vs n=6)\n\n```\n  invariant-cov  |  0.20 |    1.00\n```\n\n"
    s = s + "## §3 REQUIRES\n\n- n6_arithmetic SSOT\n\n"
    s = s + "## §4 STRUCT\n\n```\n  L0 base | L1 core | L2 ctrl | L3 integ | L4 apply\n```\n\n"
    s = s + "| sigma(6) | tau(6) | phi(6) | J_2(6) |\n|---|---|---|---|\n| 12 | 4 | 2 | 24 |\n\n"
    s = s + "## §5 FLOW\n\n```\n  L0 -> L1 -> L2 -> L3 -> L4\n```\n\n"
    s = s + "## §6 EVOLVE\n\nDSE candidate pool sigma(6)=12.\n\n"
    s = s + "## §7 VERIFY (Python check)\n\n```python\nimport math\nassert 12 == 12  # sigma(6)\nprint('__SELFTEST__ PASS n=6 A000203')\n```\n\n"
    s = s + "OEIS A000005, A000010 cross-check.\n"
    return s
}

fn _broken_cfd_md() -> string {
    // intentionally missing §3, §5, §6, §7 and L0..L4 → must fail
    let mut s = ""
    s = s + "# CFD Domain (broken)\n\n"
    s = s + "## §1 WHY\n\nsome intro\n\n"
    s = s + "## §2 COMPARE\n\nbar chart\n\n"
    s = s + "## §4 STRUCT\n\nno tier table here\n\n"
    return s
}

fn _run_self_test() {
    println("=== n6_5tier validator --self-test ===")
    let tdir = "/tmp/n6_5tier_test"
    exec("rm -rf '" + tdir + "'")
    exec("mkdir -p '" + tdir + "'")

    // ── check 1: generate→validate roundtrip ──
    let synth = _generate_via_template("selftest-domain")
    let synth_path = tdir + "/synth.md"
    write_file(synth_path, synth)
    let r1 = validate(synth_path)
    println("\n[check 1] generate→validate roundtrip:")
    _print_report(r1)
    let g1 = r1["grade"]
    if g1 != "A" && g1 != "B" {
        eprintln("__N6_5TIER__ FAIL reason=roundtrip_grade got=" + g1 + " want=A_or_B")
        exec("rm -rf '" + tdir + "'")
        exit(2)
    }

    // ── check 2: cosmology.md must PASS ──
    let cos_path = env_var("HOME") + "/core/n6-architecture/domains/physics/cosmology/cosmology.md"
    println("\n[check 2] cosmology.md (must grade A or B):")
    if !file_exists_safe(cos_path) {
        println("  WARN: cosmology.md not found at " + cos_path + " — skipping check 2")
    } else {
        let r2 = validate(cos_path)
        _print_report(r2)
        let g2 = r2["grade"]
        if g2 != "A" && g2 != "B" {
            eprintln("__N6_5TIER__ FAIL reason=cosmology_grade got=" + g2 + " want=A_or_B path=" + cos_path)
            exec("rm -rf '" + tdir + "'")
            exit(2)
        }
    }

    // ── check 3: broken cfd-fixture must FAIL/WARN ──
    let cfd = _broken_cfd_md()
    let cfd_path = tdir + "/cfd_broken.md"
    write_file(cfd_path, cfd)
    let r3 = validate(cfd_path)
    println("\n[check 3] broken cfd fixture (must grade C or F):")
    _print_report(r3)
    let g3 = r3["grade"]
    if g3 != "C" && g3 != "F" {
        eprintln("__N6_5TIER__ FAIL reason=cfd_grade got=" + g3 + " want=C_or_F")
        exec("rm -rf '" + tdir + "'")
        exit(2)
    }

    exec("rm -rf '" + tdir + "'")
    println("\n__N6_5TIER__ PASS")
    exit(0)
}

// ─── runner ───────────────────────────────────────────────────

fn main() -> void {
    let raw_args = args()
    let mut cli = []
    let mut ai = 2
    while ai < len(raw_args) {
        cli.push(raw_args[ai])
        ai = ai + 1
    }

    if len(cli) == 0 {
        eprintln("__N6_5TIER__ FAIL reason=usage fix=--self-test|--validate <path>")
        exit(1)
    }

    let mut i = 0
    while i < len(cli) {
        let a = cli[i]
        if a == "--self-test" || a == "--selftest" {
            _run_self_test()
        }
        else if a == "--validate" {
            if i + 1 >= len(cli) {
                eprintln("__N6_5TIER__ FAIL reason=missing_path fix=--validate <md_path>")
                exit(1)
            }
            let path = cli[i + 1]
            let r = validate(path)
            _print_report(r)
            let g = r["grade"]
            if g == "F" {
                eprintln("__N6_5TIER__ FAIL grade=F file=" + path)
                exit(2)
            }
            println("__N6_5TIER__ PASS grade=" + g + " file=" + path)
            exit(0)
        }
        else if a == "--help" || a == "-h" {
            println("usage: hexa run lib/n6_5tier/validator.hexa [--self-test|--validate <md_path>]")
            println("grades: A (7/7+anchors) | B (6/7+L0..L4+py) | C (5/7) | F (<5/7)")
            exit(0)
        }
        else {
            eprintln("__N6_5TIER__ FAIL reason=unknown_arg arg=" + a)
            exit(1)
        }
        i = i + 1
    }
}
