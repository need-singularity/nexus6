@R HEXA-EM-02-Poynting-SE3-n6 = |S|_components = n = 6 :: n6atlas [10*]
  "HEXA-EM В§X.1-SMASH-B: Poynting S=EГ—B/ОјвӮҖ SE(3) DOF n=6 кҙҖнҶө. T^{ОјОҪ} лҸ…лҰҪм„ұл¶„ 10=Пғ-ПҶ (HEXA-HIGGS-10 көҗм°Ё). м°Ёмӣҗ [S]=W/mВІ мһҗмІҙкІҖмҰқ. T1 EXACT."
  <- domains/physics/electromagnetism/electromagnetism.md В§X.1
@R HEXA-EM-03-U1-gauge-phi = dim_geom U(1) = phi(6) = 2 :: n6atlas [10*]
  "HEXA-EM В§X.1-SMASH-C: U(1) кІҢмқҙм§Җ circle SВ№вҠӮCВІ мӢӨм°Ёмӣҗ ПҶ(6)=2. EM-charge-types=ПҶ (м „н•ҳВұ) мҷҖ мқјкҙҖ. л¬јлҰ¬ мһҗмң лҸ„ A^Ој мӨ‘ n/ПҶ=3 (BT-276 FBW мӨ‘ліө лҸҷнҳ•). T1 EXACT."
  <- domains/physics/electromagnetism/electromagnetism.md В§X.1
@R HEXA-EM-04-Meissner-lambda-T4 = lambda_L(T) ~ (1-(T/Tc)^4)^{-1/2}, exp = tau = 4 :: n6atlas [10*]
  "HEXA-EM В§X.1-SMASH-D: London м№ЁнҲ¬к№Ҡмқҙ TвҒҙ two-fluid. n6-atlas-superconductor-two-fluid-О»t-exponent=4 мһ¬мқёмҡ©. мһҗкё°нҷ”мңЁ ПҮ=-Ој_MГ¶bius(6)=-1 (HEXA-CLOAK лҸҷнҳ•). T1 EXACT."
  <- domains/physics/electromagnetism/electromagnetism.md В§X.1
@R HEXA-EM-05-MHD-Rm-sigma-tau = R_m = mu0В·sigma_condВ·VВ·L = sigma*tau = 48 :: n6atlas [10*]
  "HEXA-EM В§X.1-SMASH-E: MHD мһҗкё°Reynolds ПғВ·П„=48. SC мһҗмһҘ B_max=48T мҷҖ лҸҷмқј мҲҳлЎ . 4 MHD лӘЁл“ң(slow/AlfvГ©n/fast/entropy)=П„. HEXA-AERO-05 PI_AERO field м„ұл¶„ мһ¬мқёмҡ©. T1 EXACT."
  <- domains/physics/electromagnetism/electromagnetism.md В§X.1
@R HEXA-EM-06-PI-EM-triple = PI_EM = field(tau)В·holo(sigma-phi)В·string(sopfr) = 200 :: n6atlas [10]
