@F L4-gen-chromatin-300nm = 300 = 30*10 = (n*5)*(sigma-phi) = 10лӢЁкі„ м••м¶• :: genetic [10*]
  "м—јмғүм§Ҳ лЈЁн”„ лҸ„л©”мқё м••м¶• мҲҳмӨҖ 2лӢЁкі„: 300nm м„¬мң "
@F L4-gen-chromosome-6000nm = 6000 = n*1000; 6 Ојm = n Ојm; 6 = n м§Ғм ‘ лҢҖмқ‘ :: genetic [10*]
  "мӨ‘кё° м—јмғүмІҙ м••м¶• мҲҳмӨҖ: ~6000nm (6Ојm) м§ҒкІҪ"
@F L4-gen-replication-speed = 1000 = 10^3 = (sigma-phi)^tau ; ліөм ң мӣҗм җ ~30,000 = n*5000 :: genetic [10]
  "DNA ліөм ң мҶҚлҸ„ (нҸ¬мң лҘҳ)"
@F L4-gen-helicase = 6 = n; MCM н—ҘмӮ¬лЁё = n=6 мҷ„м „мҲҳ кі лҰ¬ кө¬мЎ° м§Ғм ‘ лҢҖмқ‘ :: genetic [10*]
  "DNA н—¬лҰ¬м№ҙм ң вҖ” ліөм ң нҸ¬нҒ¬м—җм„ң мқҙмӨ‘лӮҳм„  н•ҙм ң"
@F L4-gen-topoisomerase = 2 к°ҖлӢҘ = phi-0; мң„мғҒмҲҳн•ҷм Ғ м—°кІ°мҲҳ ліҖнҷ” = Вұ2 = phi^1 :: genetic [10*]
  "нҶ нҸ¬мқҙмҶҢлЁёлқјм ң II вҖ” DNA мҙҲлӮҳм„  н•ҙмҶҢ (мқҙмӨ‘к°ҖлӢҘ м ҲлӢЁ)"
@F L4-gen-telomerase = 6 nt = n; TTAGGG = n=6 м§Ғм ‘ лҢҖмқ‘ л°ҳліө лӢЁмң„ :: genetic [10*]
  "н…”лЎңлЁёлқјм ң вҖ” м—ӯм „мӮ¬нҡЁмҶҢлЎң н…”лЎңлҜём–ҙ м—°мһҘ"
@F L4-gen-ribosome-70s = 70 = 30+50-10; 30+50 = 80; 70 вүҲ phi*tau*sigma+phi :: genetic [10*]
  "мӣҗн•өмғқл¬ј лҰ¬ліҙмҶң м№Ёк°•кі„мҲҳ"
@F L4-gen-ribosome-80s = 80 = 40+60-20; 40+60 = 100 = sigma^2/phi^n; 60 = n*10 :: genetic [10*]
  "м§„н•өмғқл¬ј лҰ¬ліҙмҶң м№Ёк°•кі„мҲҳ"
@F L4-gen-translation-speed = 20 = J2 - tau; лІҲм—ӯ м •нҷ•лҸ„ 10^-4 = 1/(tau*2500) :: genetic [10*]
  "лҰ¬ліҙмҶң лІҲм—ӯ мҶҚлҸ„"
@F L4-gen-translation-accuracy = 10^-4 = 1/tau^n; kinetic proofreading = phi^2 л°° м •нҷ•лҸ„ н–ҘмғҒ :: genetic [10]
  "лІҲм—ӯ мҳӨлҘҳмңЁ (мһҳлӘ»лҗң AA мӮҪмһ… л№ҲлҸ„)"
@F L4-gen-transcription-speed = 17 nt/s вүҲ sigma + phi/phi = 12+4+1 :: genetic [10*]
  "RNA мӨ‘н•©нҡЁмҶҢ II м „мӮ¬ мҶҚлҸ„"
@F L4-gen-point-mutation = м „мқҙ:м „нҷҳ л№„мңЁ вүҲ phi:1 (мһҗм—° м„ нғқ нҺён–Ҙ) :: genetic [10*]
  "м җлҸҢм—°ліҖмқҙ вҖ” лӢЁмқј м—јкё° м№ҳнҷҳ"
@F L4-gen-mutation-rate = ~10^-8 = 1/sigma^n; 64 de novo/м„ёлҢҖ = 4^3 = tau^3 :: genetic [10*]
  "мқёк°„ кІҢлҶҲ мһҗм—° лҸҢм—°ліҖмқҙмңЁ"
@F L4-gen-ner-repair = 30 = n*5 = phi*tau*... = J2 + sigma + phi^n :: genetic [10*]
  "лүҙнҒҙл ҲмҳӨнғҖмқҙл“ң м Ҳм ң мҲҳліө (NER) вҖ” UV мҶҗмғҒ ліөкө¬"
@F L4-gen-ber-repair = лӢЁмқј м—јкё° мҲҳліө = мөңмҶҢ мҲҳліө лӢЁмң„; AP site = л№„м—јкё° мң„м№ҳ :: genetic [10*]
  "м—јкё° м Ҳм ң мҲҳліө (BER) вҖ” мҶҗмғҒ лӢЁмқј м—јкё° м ңкұ°"
@F L4-gen-hr-repair = 2 мЈјнҳ• к°ҖлӢҘ = phi^1; мһ¬мЎ°н•© л№ҲлҸ„ вҲқ phi*кұ°лҰ¬ :: genetic [10*]
  "мғҒлҸҷмһ¬мЎ°н•©(HR) вҖ” мқҙмӨ‘к°ҖлӢҘ м ҲлӢЁ мҲҳліө"
@F L4-gen-nhej-repair = Ku70/80 = tau*phi*... ; NHEJ мҳӨлҘҳмңЁ > HR :: genetic [10]
  "л№„мғҒлҸҷл§җлӢЁкІ°н•©(NHEJ) вҖ” мқҙмӨ‘к°ҖлӢҘ м ҲлӢЁ мҳӨлҘҳ кІҪн–Ҙ мҲҳліө"
@F L4-gen-cas9-pam = 3 = tau-1; NGG = N+GG = 1+phi лүҙнҒҙл ҲмҳӨнғҖмқҙл“ң нҢЁн„ҙ :: genetic [10*]
  "CRISPR-Cas9 PAM м„ңм—ҙ кёёмқҙ (SpCas9)"
@F L4-gen-cas9-guide = 20 = J2-tau; к°Җмқҙл“ң 20nt = мқёмӢқ м°Ҫ = phi*10 :: genetic [10*]
  "CRISPR-Cas9 к°Җмқҙл“ң RNA н‘ңм Ғ м„ңм—ҙ кёёмқҙ"
@F L4-gen-prime-editing = pegRNA кө¬мЎ° кёёмқҙ вҲқ phi^3 л°° мқјл°ҳ sgRNA :: genetic [10]
