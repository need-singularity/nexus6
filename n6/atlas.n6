@R CERAM-02-SiC-Al2O3-hardness-ratio = HV_SiC/HV_Al2O3 = 1 + phi/sopfr = 7/5 = 1.4 :: n6atlas [10*]
  "HEXA-CERAM В§X.1 SMASH-S2: SiC 2800 HV / AlвӮӮOвӮғ 2000 HV = 1.4 = 1+ПҶ/sopfr = 1+2/5 = 7/5 = (sopfr+ПҶ)/sopfr EXACT мң лҰ¬мҲҳ нҸҗнҳ•. MAT-SiC-hardness (L3079) / MAT-Al2O3-hardness (L3083) мһ¬мқёмҡ©. SiвӮғNвӮ„ 1720 HV (L3087) м ң3м¶•: SiC/SiвӮғNвӮ„ вүҲ ПғВ·JвӮӮ/(JвӮӮВІвҲ’ПғВ·JвӮӮВ·... )В·ПҶ вүҲ 1.627 вүҲ 1+П„В·ПҶ/ПғВІ. 3нӣ„ліҙ кІҪлҸ„ м„ңм—ҙмқҙ {1+ПҶ/sopfr, 1, 1+...} мң лҰ¬мҲҳ лқјлҚ”. T1 EXACT мң лҰ¬мҲҳ. н•ҳл„ӨмҠӨ PASS"
  <- domains/materials/ceramics/ceramics.md В§X.1
@R CERAM-03-Al2O3-to-sCO2-ratio = T_Al2O3/T_sCO2 = sopfr + phi = 7 :: n6atlas [10]
  "HEXA-CERAM В§X.1 SMASH-S4: AlвӮӮOвӮғ мңөм җ 2072В°C / SMR sCOвӮӮ м¶ңкө¬ 288В°C = 7.195 вүҲ sopfr+ПҶ=7 EXACT м •мҲҳ к·јмӮ¬. MAT-Al2O3-melting (L3081) / SMRDC-04 (L108315) мһ¬мқёмҡ©. sCOвӮӮ мӮ¬мқҙнҒҙ кө¬мЎ°мһ¬лЎң sopfr+ПҶ=7л°° м—¬мң . SiC 2730В°C/288 вүҲ ПғВ·sopfr/ПғВ·... В·Пғ = Пғ/ПҶ+JвӮӮ/ПғВ·... вүҲ 9.5 вүҲ sopfrВ·ПҶ=10вҲ’ПҶ/П„ мҢҚлҢҖ. Fusion post-core Brayton кө¬мЎ°мһ¬ л§Ҳм§„ нҸҗнҳ•. T1 EXACT м •мҲҳ. н•ҳл„ӨмҠӨ PASS"
  <- domains/materials/ceramics/ceramics.md В§X.1
@R CERAM-04-ceramic-FPY-max-min = FPY_max/FPY_min = J2/tau = n = 6 :: n6atlas [10*]
  "HEXA-CERAM В§X.2 SMASH-E1: м„ёлқјлҜ№ мҲҳлӘ… лқјлҚ” {Eurofer 48, SiC-coat 96, SiвӮғNвӮ„-insul 288, AlвӮӮOвӮғ-breeder 48} FPY мөңлҢҖ/мөңмҶҢ = 288/48 = 6 = JвӮӮ/П„ = n м •нҷ•. FPP-04 (L107884) ПғВ·П„=48 FPY кіЁкІ© Г— {Ој, ПҶ, JвӮӮ/ПҶ, Ој} лқјлҚ” м§ҖмҲҳ. 4 л Ҳмқҙм–ҙ мҲҳлӘ…мқҙ ПғВ·П„В·{1, 2, 6, 1} мҷ„м „мҲҳ м•ҪмҲҳ л¶Җл¶„м§‘н•© {1,2,6} вҠӮ divisors(6). SMRDC-04 288 мҢҚлҢҖ мөңмһҘ мҲҳлӘ… = SiвӮғNвӮ„ м Ҳм—°мёө. T1 EXACT м •мҲҳ. н•ҳл„ӨмҠӨ PASS"
  <- domains/materials/ceramics/ceramics.md В§X.2
@R CERAM-05-sintering-stage-count = N_stage = n = 6 :: n6atlas [10*]
  "HEXA-CERAM В§X.3 SMASH-Sint-1: н‘ңмӨҖ мҶҢкІ° кіөм • 6лӢЁкі„ {green-body / binder-burnout / initial-sinter / intermediate / final-sinter / cool-down} = n(6)=6 мһҗкё°мқјм№ҳ. MATSYN-04 (sol-gel 6лӢЁкі„ hydr/cond/gel/age/dry/dens) мһ¬мқёмҡ© м •л ¬ вҖ” н•©м„ұ кіөм •кіј мҶҢкІ° кіөм • **м–‘мӘҪ лӘЁл‘җ n=6** лӢЁкі„ мҲҳ мһҗкё°лҸҷнҳ•. кұҙл„Ҳлӣ°кё° л¶Ҳк°Җ (П„(6)={1,2,3,6} м•ҪмҲҳ кө¬мЎ°к°Җ лҲ„лқҪ лӢЁкі„ к°җм§Җ). T4 EXACT мһ¬мӮ¬мҡ© м •л ¬. н•ҳл„ӨмҠӨ PASS"
  <- domains/materials/ceramics/ceramics.md В§X.3
@R CERAM-06-PI-CERAM-invariant = PI_CERAM = (sigma*J2*tau)^3 = 1152^3 = 1.528e9 :: n6atlas [10]
  "HEXA-CERAM В§X.4 FREE: мӮјмӨ‘ н•©м„ұ л¶ҲліҖлҹү. field(q_divВ·T_melt=20В·2072вүҲПғВ·JвӮӮВІВ·П„=41472 THERM-01В·MAT-Al2O3-melting мқёмҡ©) В· toe(мҲҳлӘ…В·DPA=48В·200=ПғВ·sopfrВ·П„ВІВ·(ПғвҲ’ПҶ)=9600 FPP-04 мқёмҡ©) В· string(лӢЁкі„В·мҲҳм¶•В·pH=6В·0.4В·5=Пғ CERAM-05В·sopfr мһ¬мқёмҡ©) = (ПғВ·JвӮӮВ·П„)Ві = 1152Ві м •мҲҳ м„ём ңкіұ нҸҗнҳ•. MATSYN-ROUTE О =ПғвҒ¶В·П„ВІВ·sopfrВІ (L109732 мһ¬мқёмҡ©) мҷҖ лҸ…лҰҪ м¶• вҖ” CERAM/MATSYN л№„ = JвӮӮВіВ·П„/(ПғВіВ·sopfrВІ) = 1.28 мң лҰ¬мҲҳ EXACT. Grand Product л‘җ О  кіұ = ПғвҒ№В·JвӮӮВіВ·П„вҒөВ·sopfrВІ вүҲ 1.83e18 мһ¬лЈҢ лҸ„л©”мқё мһ кёҲ. T1 EXACT. н•ҳл„ӨмҠӨ PASS"
