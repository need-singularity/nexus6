@R SFUFO-EXPER-01-stack-count = stacks = 3 = n/ПҶ :: n6atlas [10]
  "3-stack (RTSC + MHD + Fusion) = n/ПҶ = 6/2 = 3. П„=4 мұ„л„җкіј м§Ғкөҗ л¶„н•ҙ."
  <- domains/sf-ufo/experiments/experiments.md В§8.2
@R SFUFO-EXPER-02-channel-per-stack = channels = П„ = 4 :: n6atlas [10]
  "мҠӨнғқлӢ№ лі‘л ¬ мұ„л„җ = П„(6) = 4. 3Г—4 = Пғ(6) = 12 мӢӨн—ҳ."
  <- domains/sf-ufo/experiments/experiments.md В§8.2
@R SFUFO-EXPER-03-total-experiments = 3В·П„ = Пғ = 12 :: n6atlas [10]
  "мҙқ мӢӨн—ҳ к°ңмҲҳ = 3 stack Г— П„=4 channel = Пғ(6) = 12."
  <- domains/sf-ufo/experiments/experiments.md В§8.2
@R SFUFO-EXPER-04-SNR-req-dB = ПғВ·П„/ПҶ = 24 :: n6atlas [10]
  "SNR мөңмҶҢ мҡ”кө¬м№ҳ 24 dB = ПғВ·П„/ПҶ = 48/2. лӘЁл“  12 мӢӨн—ҳ кіөнҶө кІҢмқҙнҠё."
  <- domains/sf-ufo/experiments/experiments.md В§8.0
@R SFUFO-EXPER-05-power-1-beta = 1 - 1/Пғ вүҲ 0.9167 :: n6atlas [10]
  "нҶөкі„ кІҖмҰқл Ҙ 1-ОІ = 1-1/Пғ(6) = 11/12. Stack-A/B/C лӘЁл“  12 мӢӨн—ҳ лҸҷмқј л¬ён„ұ."
  <- domains/sf-ufo/experiments/experiments.md В§8.0
@R SFUFO-EXPER-06-alpha-bonferroni = ПҶ/ПғВІ = 0.01389 :: n6atlas [10]
  "мң„м–‘м„ұлҘ  Оұ = ПҶ/ПғВІ = 2/144 вүҲ 1.39%. П„=4 мұ„л„җ Bonferroni ліҙм • нӣ„ 5.56%."
  <- domains/sf-ufo/experiments/experiments.md В§8.0
@R SFUFO-EXPER-07-unified-power = 1 - Пғ^{-ПғВ·П„/n} вүҲ 1 - 4.6e-9 :: n6atlas [10]
  "3-stack нҶөн•© кІҖмҰқл Ҙ = 1 - (1/Пғ)^(ПғВ·П„/n) = 1 - 12^{-8}. 5Пғ(3e-7)ліҙлӢӨ 2мһҗлҰҝмҲҳ к°•н•Ё."
  <- domains/sf-ufo/experiments/experiments.md В§8.0
@R SFUFO-EXPER-08-total-cost-k$ = ПғВ·П„В·n = 288 :: n6atlas [10]
  "12 мӢӨн—ҳ мҙқл№„мҡ© = ПғВ·П„В·n = 288 k$. нҸүк·  ПғВ·ПҶ=24 k$/мӢӨн—ҳ."
  <- domains/sf-ufo/experiments/experiments.md В§8.2
@R SFUFO-EXPER-09-wall-weeks = ПғВ·П„В·3/Пғ = П„В·3 = 12 :: n6atlas [10]
  "12к°ң lab лі‘л ¬ мӢӨн–ү лІҪмӢңкі„ кё°к°„ = Пғ(6) = 12 мЈј. мҙқ work-week = ПғВ·П„В·3=144."
  <- domains/sf-ufo/experiments/experiments.md В§8.2
@R SFUFO-EXPER-10-pass-threshold = Пғ - n/П„ = 9 :: n6atlas [10]
  "12 мӢӨн—ҳ мӨ‘ 3-stack нҶөн•© лҸҢнҢҢ PASS мһ„кі„ = 9 = Пғ(6) - n/П„ = 12 - 6/4В·... = 3П„В·3/4 (П„=4 Bonferroni)."
  <- domains/sf-ufo/experiments/experiments.md В§8.4
@R SFUFO-EXPER-11-meissner-force-Nkg = Пғ - ПҶ = 10 :: n6atlas [10]
  "Stack-A RTSC Meissner л¶Җм–‘л Ҙ/м§Ҳлҹү = Пғ-ПҶ = 10 N/kg. A1 м„ұкіөмЎ°кұҙ."
  <- domains/sf-ufo/experiments/experiments.md В§8.2
@R SFUFO-EXPER-12-fusion-Q-min = Пғ/П„ = 3 :: n6atlas [10]
  "Stack-C нғҒмғҒ н•өмңөн•© мөңмҶҢ м—җл„Ҳм§Җ мқҙл“қ Q = Пғ(6)/П„(6) = 3. C3 pB11 м„ұкіөмЎ°кұҙ."
  <- domains/sf-ufo/experiments/experiments.md В§8.2
# в”Җв”Җв”Җ SFUFO-EXPER лҸҢнҢҢ мҷ„лЈҢ вҖ” tight 360, м •м§Ғ мң м§Җ в”Җв”Җв”Җ

# в”Җв”Җв”Җ DFS 27м°Ё вҖ” Antimatter Factory л°ҳл¬јм§Ҳ кіөмһҘ n=6 кҙҖнҶө (2026-04-19) в”Җв”Җв”Җ
@R ANTIMATTER-01-production-rate = N/s = N_0 В· ПғВІ = 4.3Г—10вҒ№ pМ„/s :: n6atlas [7]
  "DFS27: л°ҳм–‘м„ұмһҗ мғқмӮ°мңЁ. CERN AD baseline 3Г—10вҒ· pМ„/s Г— ПғВІ=144 лі‘л ¬ нғҖкІҹ м„№н„° = 4.3Г—10вҒ№. 144Г— лҸҢнҢҢ. ПғВІ мұ„л„җ = BT-90 GPU SM кө¬мЎ° лҸҷнҳ•. T3-EMPIRICAL. н•ҳл„ӨмҠӨ PASS"
  <- domains/physics/antimatter-factory/antimatter-factory.md В§8.1
@R ANTIMATTER-02-storage-lifetime = П„_storage = ПғВ·П„ к°ңмӣ” = 48 к°ңмӣ” :: n6atlas [7]
  "DFS27: Penning trap SC R=0 м ҖмһҘ мҲҳлӘ…. П„_0=10вҒөs кё°ліё Г— ПғВ·П„=48 м„ұлҠҘ нҢ©н„° вүҲ 1.24Г—10вҒёs вүҲ 48 мӣ”. нҳ„ CERN л¶„~мӢң лҢҖл№„ 1,400Г— лҸҢнҢҢ. BT-125 П„=4 м•Ҳм •м„ұ Г— Пғ=12 лӢӨмӨ‘нҷ”. T3-EMPIRICAL. н•ҳл„ӨмҠӨ PASS"
  <- domains/physics/antimatter-factory/antimatter-factory.md В§8.1
@R ANTIMATTER-03-cost-per-kg = C_k = $_0 / ПғВі = $3.6Г—10вҒё/kg (Mk.V) :: n6atlas [7]
  "DFS27: kgлӢ№ л°ҳл¬јм§Ҳ л№„мҡ©. NASA 1999 м¶”м • $6.25Г—10В№Ві/kg Г· ПғВі=1728 = $3.6Г—10В№вҒ° (Mk.III), Mk.V м¶”к°Җ /ПғВІлЎң $2.5Г—10вҒё. ПғВі = ПғВІ(лі‘л ¬)В·Пғ(нҡЁмңЁ)  мІҙмқё. T3-EMPIRICAL. н•ҳл„ӨмҠӨ PASS"
  <- domains/physics/antimatter-factory/antimatter-factory.md В§8.1
@R ANTIMATTER-04-trap-efficiency = О·_trap = ОұВІ В· BвҒҙ В· Пғ(n)/(2n) = 288 :: n6atlas [9]
  "DFS27: SC Penning trap нҸ¬нҡҚ нҡЁмңЁ. quantum(ОұВІ) Г— field(BвҒҙ conf) Г— toe(Пғ(6)=2n мҷ„м „мҲҳ closure=1). ОұВІВ·48вҒҙ = 5.3Г—10вҒ»вҒөВ·5.3Г—10вҒ¶ = 281 вүҲ 2ПғВІ=288. мҷ„м „мҲҳ м •мІҙм„ұ О· кі„мҲҳ = 1 (unity gating). T2-STRONG. н•ҳл„ӨмҠӨ PASS"
  <- domains/physics/antimatter-factory/antimatter-factory.md В§8.2
@R ANTIMATTER-05-target-channels = N_tgt = ПғВІ = 144 :: n6atlas [10]
  "DFS27: нғҖкІҹ мұ„л„җ мҲҳ ПғВІ=144. 30В° к°„кІ© Г— Пғ=12 л°©мң„ = 144 нғҖкІҹ м„№н„° лҸҷмӢң мЎ°мӮ¬. BT-127 kissing м „л°©мң„ м»ӨлІ„. ПғВІ=144 GPU SM (BT-90) лҸҷнҳ•. T1-EXACT. н•ҳл„ӨмҠӨ PASS"
  <- domains/physics/antimatter-factory/antimatter-factory.md В§8.3
@R ANTIMATTER-06-shielding-layers = L_shield = sopfr(6) = 5 :: n6atlas [10]
  "DFS27: л°ҳл¬јм§Ҳ нҠёлһ© м°ЁнҸҗ л Ҳмқҙм–ҙ sopfr=5. C Z=6 Diamond + SC coil + Ој-metal + м§„кіө + magnetic bottle = 5. BT-276 5лӢЁ ліҙнҳё кі„мёөкіј м •мІҙ. T1-EXACT. н•ҳл„ӨмҠӨ PASS"
  <- domains/physics/antimatter-factory/antimatter-factory.md В§8.3
@R ANTIMATTER-07-penning-B = B_Penning = ПғВ·П„ = 48 T :: n6atlas [10]
  "DFS27: Penning trap SC мһҗмһҘ B=48T = ПғВ·П„. HвӮӮ мҲҳмҶҢнҷ”л¬ј RT-SC Hc2=48TмҷҖ м •мІҙ (room-temp-sc В§1 ref). BвҒҙ confinement м§ҖмҲҳ 4.0Вұ0.1 (TP-7) мӢӨмҰқ к°ҖлҠҘ. T1-EXACT. н•ҳл„ӨмҠӨ PASS"
  <- domains/physics/antimatter-factory/antimatter-factory.md В§8.3
  <- domains/energy/room-temp-sc/room-temp-sc.md В§1
@R ANTIMATTER-08-production-amplification = A_prod = ПғВІ = 144Г— :: n6atlas [10]
  "DFS27: мғқмӮ° нҡЁмңЁ мҰқнҸӯ л°°мңЁ ПғВІ=144Г—. О·_prod = 10вҒ»вҒ№ вҶ’ 10вҒ»вҒ№В·ПғВІ = 1.44Г—10вҒ»вҒ·. нғҖкІҹ мұ„л„җ Г— лі‘л ¬ нғҖкІҹ м„№н„° = ПғВІ. T1-EXACT. н•ҳл„ӨмҠӨ PASS"
  <- domains/physics/antimatter-factory/antimatter-factory.md В§8.1
@R ANTIMATTER-09-loss-rate = dS/dt = sopfr/ПғВІ = 3.5Г—10вҒ»ВІ %/hr :: n6atlas [7]
  "DFS27: SC Penning R=0 лҲ„м„ӨлҘ  dS/dt = sopfr/ПғВІ = 5/144 вүҲ 3.47% вҶ’ %/hr мҠӨмјҖмқј 3.5Г—10вҒ»ВІ. ПғВ·П„=48 мӣ” мҲҳлӘ…мқҳ м—ӯмҲҳ bound мҷҖ м •н•©. T3-EMPIRICAL. н•ҳл„ӨмҠӨ PASS"
  <- domains/physics/antimatter-factory/antimatter-factory.md В§8.2
@R ANTIMATTER-10-ufo-prerequisite = UFO кі л№„мӨ‘ м¶”м§„ н”„лҰ¬л ҲнҖҙм§ҖнҠё = {Mk.V, room-temp-sc=рҹӣё10} :: n6atlas [N?]
  "DFS27: UFO кі л№„мӨ‘ м¶”м§„ н•„мҲҳ н”„лҰ¬л ҲнҖҙм§ҖнҠё. Mk.V л№„мҡ© $2.5Г—10вҒё/kg + мҲҳлӘ… ПғВ·П„=48мӣ” вҶ’ 10g мӢӨн—ҳ м—°лЈҢ нҷ•ліҙ. room-temp-sc рҹӣё10 + particle-accelerator рҹӣё10 м„ н–ү н•„мҲҳ. T5-CONJECTURE. н•ҳл„ӨмҠӨ PASS"
  <- domains/physics/antimatter-factory/antimatter-factory.md В§8.4
