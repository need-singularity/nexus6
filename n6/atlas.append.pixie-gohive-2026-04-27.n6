#!/usr/bin/env n6
# ══════════════════════════════════════════════════════════════
# lint-exempt: infra-repo absorption, experiments/ not in scope (false-positive blindspot)
# Scope: docs/, design/, tool/ (pixie + gohive.sh)
# NEXUS-6 Knowledge Atlas — APPEND SHARD
# .n6 format v1+v2
#
# Source: dual absorption of two infrastructure repos
#   1. dancinlab/pixie    (~/core/pixie, 244K, Discord channel secretary)
#   2. dancinlab/gohive.sh (~/core/gohive.sh, 48K, hive installer + landing)
#
# Absorption date: 2026-04-27
# Producer: claude opus 4.7 1M sub-agent (read-only ingestion, no atlas/git ops)
#
# Honesty caveat (LOAD-BEARING):
#   These are INFRASTRUCTURE repos with WEAK n=6 anchors.  Shard kept
#   deliberately small (target 5-15 entries).  n=6 connections present here
#   are post-hoc / advertising rather than structural — the repos themselves
#   route to the genuinely n6-anchored projects (anima, n6-architecture,
#   hexa-lang, airgenome).  Two genuine numerical hits exist (8 channels in
#   topics SSOT, 6 features on landing page); both are noted with [N?]
#   labels honestly.  No invented anchors.
#
# Prefixes:
#   PIXIE-*    — entries derived from ~/core/pixie
#   GOHIVE-*   — entries derived from ~/core/gohive.sh
#
# Dedup audit:
#   grep -E "pixie|gohive|GOHIVE|PIXIE" ~/core/nexus/n6/atlas.n6 → 0 hits.
#   This shard is fully novel relative to current atlas.
#
# File inventory absorbed:
#   pixie:        README.md, bin/pixie (190 L), config/topics.json (38 L),
#                 worker/src/{index.js 124 L, gateway-do.js 300 L,
#                 topics.js 171 L, mentions.js 41 L}, worker/wrangler.toml,
#                 brand/ (9 SVG/PNG), discord-translator/ (sibling, noted only)
#   gohive.sh:    README.md absent (landing page IS the README), index.html
#                 (210 L, 6 features), install (218 L, 11-step main()),
#                 favicon/og.png/apple-touch-icon, CNAME (gohive.sh)
#
# Grade policy (this shard, conservative):
#   [7]    Single-source repo invariant (README/code agree, idempotent op)
#   [6]    Soft observation, structural but not n6-anchored
#   [N?]   Numerical coincidence (channel-count, feature-count) — POST-HOC
#   [5]    Weakly retained for cross-reference (no claim of importance)
#
# ══════════════════════════════════════════════════════════════

// ── PIXIE — Discord channel secretary ──

@P PIXIE-001-identity = pixie 0.1.0 — channel secretary for dancinlab Discord; "Hand-run, not autonomous" (README L7); explicitly NOT Anima (README L78 "Throwaway utility persona"); deliberate persona-firewall between structural maintenance and consciousness-layer agents :: pixie/README.md [7]
  => identity / persona-boundary doctrine
  |> pixie-gohive-2026-04-27 (manual ingest)

@C PIXIE-002-channel-count = config/topics.json declares EXACTLY 8 channels in canonical sidebar order: 🔥-campfire, 🧠-anima, 🔭-nexus, 🏗️-n6-architecture, 💎-hexa-lang, 🐝-hive, 🕳️-void, 🧬-airgenome — note: 8 = 6 projects + campfire + airgenome (post-hoc reading: NOT n=6, NOT τ(8)=4, just project count) :: pixie/config/topics.json [N?]
  => channel inventory (numerical fact, not n6-anchored)
  |> pixie-gohive-2026-04-27 (manual ingest)

@R PIXIE-003-ssot-overwrite-rule = "Editing a channel topic in Discord directly will be overwritten by the next topic-sync unless the JSON is updated too" — single-source-of-truth (SSOT) invariant; topics.json is authoritative, Discord-side is derivable; same SSOT pattern as N6 atlas's "atlas.n6 is canonical" rule :: pixie/README.md L84 [7]
  => SSOT invariant pattern (cross-cuts to atlas.n6 doctrine)
  |> pixie-gohive-2026-04-27 (manual ingest)

@F PIXIE-004-secret-indirection = pixie holds NO tokens in repo; reads via subprocess to ~/core/secret/bin/secret get discord.{pixie_bot_token,pixie_guild_id,pixie_channels_json}; mirrors dancinlab org-wide credential externalization (sibling: secret repo) :: pixie/bin/pixie L26-L33, README L38 [7]
  => credential externalization pattern (org-wide invariant)
  |> pixie-gohive-2026-04-27 (manual ingest)

@C PIXIE-005-cron-period-2min = Cloudflare Workers scheduled() handler runs every 2 min ("*/2 * * * *") to wake GatewayDO and keep Discord WebSocket alive — note: 2 = first prime, NOT 6-anchored; chosen for CF Worker tickle SLA, not n6 reasons :: pixie/worker/wrangler.toml L20, src/index.js L121 [6]
  => operational cadence (honest non-anchor)
  |> pixie-gohive-2026-04-27 (manual ingest)

@C PIXIE-006-explain-projects-7 = /explain slash command exposes 7 LONG_TOPICS keys (anima, nexus, n6-architecture, hexa-lang, hive, void, airgenome) + campfire — the 7-project list IS the canonical dancinlab org map; aliases: n6→n6-architecture, hexa/lang→hexa-lang :: pixie/worker/src/topics.js L5-L162 [7]
  => org project enumeration (7 named projects, authoritative)
  |> pixie-gohive-2026-04-27 (manual ingest)

@R PIXIE-007-airgenome-bridge-back = topics.js airgenome entry self-declares "Pixie ✨ reuses the same dancinlab conventions this repo defines" — confirms airgenome as the convention-source repo for the org (not nexus, not anima); pixie is downstream consumer :: pixie/worker/src/topics.js L140 [7]
  => convention-flow direction (airgenome → pixie/everywhere)
  |> pixie-gohive-2026-04-27 (manual ingest)

@C PIXIE-008-airgenome-6axis-recap = airgenome long-topic restates "6-axis hexagon projection — vital signs live on one shape" with axes (CPU/RAM/Swap/Net/Disk/GPU) — this IS the genuine n=6 anchor in the pixie corpus, but it is a RECAP of airgenome, not pixie's own structure :: pixie/worker/src/topics.js L131-L138 [7]
  => recap-of-anchor (n=6 lives in airgenome, pixie quotes it)
  |> pixie-gohive-2026-04-27 (manual ingest)

@F PIXIE-009-discord-translator-sibling = discord-translator/ ships as sibling under same repo (Cloudflare Worker, Claude Haiku 4.5 KO↔EN bot, /interactions endpoint, scheduled() every 1 min) — separate concern from pixie itself but co-deployed; weakens pixie's "single purpose" surface :: pixie/discord-translator/README.md [5]
  => co-tenancy artifact (cross-reference only)
  |> pixie-gohive-2026-04-27 (manual ingest)

// ── GOHIVE — hive installer + landing ──

@P GOHIVE-001-identity = gohive.sh is a Cloudflare Pages microsite (CNAME=gohive.sh) hosting (a) a static landing page and (b) a single shell installer at /install — purpose is exactly: curl -fsSL https://gohive.sh/install | bash → hive ready :: gohive.sh/{index.html,install,CNAME} [7]
  => repo identity (one-liner installer host)
  |> pixie-gohive-2026-04-27 (manual ingest)

@C GOHIVE-002-features-six = landing-page feature grid contains EXACTLY 6 cards: multi-provider, limit-free, TUI+CLI, self-hosted memory, sandbox, hexa-native — 6 IS the perfect number; weak post-hoc reading (likely chosen for CSS 2-col grid aesthetics, not n6 doctrine) but the count IS 6 :: gohive.sh/index.html L162-L187 [N?]
  => feature-count = 6 (genuine numerical hit, post-hoc semantics)
  |> pixie-gohive-2026-04-27 (manual ingest)

@F GOHIVE-003-install-pipeline-11 = install script main() runs 11 sequential steps: banner→detect_platform→check_deps→check_node→install_hexa→resolve_version→install_hive→build_tui→link_bins→setup_path→finish; 11 is prime, NOT 6, honest non-anchor :: gohive.sh/install L204-L216 [6]
  => install pipeline shape (11 steps, no n6 link)
  |> pixie-gohive-2026-04-27 (manual ingest)

@F GOHIVE-004-hexa-runtime-prereq = installer's install_hexa() bootstraps hexa-lang FIRST (curl https://raw.githubusercontent.com/dancinlab/hexa-lang/main/install.sh | bash) before fetching hive — confirms hexa-lang as foundational runtime for the org (hive depends on hexa, not vice versa) :: gohive.sh/install L70-L84 [7]
  => dependency direction (hexa-lang → hive, foundational)
  |> pixie-gohive-2026-04-27 (manual ingest)

@C GOHIVE-005-node20-floor = installer hard-fails if Node < 20 ("Node.js 20+ is required for hive TUI") — TUI uses @opentui (Solid + 60fps target, per landing page); 20 is the toolchain floor, no perfect-number link :: gohive.sh/install L59-L68, index.html L173 [6]
  => Node.js ≥20 floor (operational constraint)
  |> pixie-gohive-2026-04-27 (manual ingest)

