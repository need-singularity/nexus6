// atlas_health_export.hexa — atlas.n6 통계 JSON export (dashboard용)
// Usage: hexa atlas_health_export.hexa [path]
// Output: JSON to stdout (append to docs/atlas_health.json for time-series)

let a = args()
let mut atlas_path = "shared/n6/atlas.n6"
if a.len() > 1 { atlas_path = a[1] }

let content = read_file(atlas_path)
let lines = content.split("\n")

let mut total_nodes = 0
let mut total_edges = 0
let mut hub_count = 0
let mut breakthrough_count = 0
let mut text_nodes = 0
let mut json_nodes = 0

// domain counts — parallel arrays (hexa has no for-in-map)
let mut dom_keys = []
let mut dom_vals = []

// node type counts  // @allow-bare-interp
let mut type_keys = ["@P", "@C", "@L", "@F", "@R", "@S", "@X", "@?"]
let mut type_vals = [0, 0, 0, 0, 0, 0, 0, 0]

// grade counts
let mut grade_exact = 0
let mut grade_close = 0
let mut grade_hyp = 0

// degree tracking for hubs
let mut deg_keys = []
let mut deg_vals = []

fn bump_domain(d) {
  let mut found = false
  for i in range(dom_keys.len()) {
    if dom_keys[i] == d {
      dom_vals[i] = dom_vals[i] + 1
      found = true
    }
  }
  if !found {
    dom_keys.push(d)
    dom_vals.push(1)
  }
}

fn bump_degree(node_id) {
  let mut found = false
  for i in range(deg_keys.len()) {
    if deg_keys[i] == node_id {
      deg_vals[i] = deg_vals[i] + 1
      found = true
    }
  }
  if !found {
    deg_keys.push(node_id)
    deg_vals.push(1)
  }
}

for line in lines {
  let t = line.trim()
  if t == "" || t.starts_with("//") || t.starts_with("#") { continue }

  // text-format node: starts with @P, @C, etc.
  if t.starts_with("@") {
    text_nodes = text_nodes + 1
    total_nodes = total_nodes + 1

    // type
    for i in range(type_keys.len()) {
      if t.starts_with(type_keys[i]) {
        type_vals[i] = type_vals[i] + 1
      }
    }

    // domain from :: marker
    if t.contains("::") {
      let parts = t.split("::")
      if parts.len() > 1 {
        let dom = parts[1].trim().split(" ")[0].trim()
        if dom != "" { bump_domain(dom) }
      }
    }

    // grade
    if t.contains("grade=exact") { grade_exact = grade_exact + 1 }
    if t.contains("grade=close") { grade_close = grade_close + 1 }
    if t.contains("grade=hypothesis") { grade_hyp = grade_hyp + 1 }

    // breakthrough
    if t.contains("[BT]") || t.contains("breakthrough") {
      breakthrough_count = breakthrough_count + 1
    }
  }

  // JSON-format node
  if t.starts_with("{") && t.contains("\"type\"") && t.contains("\"node\"") {
    json_nodes = json_nodes + 1
    total_nodes = total_nodes + 1

    if t.contains("\"domain\"") {
      // extract domain value
      let idx = t.split("\"domain\"")
      if idx.len() > 1 {
        let rest = idx[1]
        let q1 = rest.split("\"")
        if q1.len() > 1 {
          let dom = q1[1].trim()
          if dom != "" && dom != ":" { bump_domain(dom) }
        }
      }
    }
  }

  // edge lines
  if t.starts_with("{") && t.contains("\"type\"") && t.contains("\"edge\"") {
    total_edges = total_edges + 1
    // bump degree for src/tgt
    if t.contains("\"src\"") {
      let parts = t.split("\"src\"")
      if parts.len() > 1 {
        let q = parts[1].split("\"")
        if q.len() > 1 { bump_degree(q[1]) }
      }
    }
    if t.contains("\"tgt\"") {
      let parts = t.split("\"tgt\"")
      if parts.len() > 1 {
        let q = parts[1].split("\"")
        if q.len() > 1 { bump_degree(q[1]) }
      }
    }
  }

  // text-format edge: contains -->
  if t.contains("-->") && !t.starts_with("{") {
    total_edges = total_edges + 1
  }
}

// count hubs (degree > 10)
for i in range(deg_keys.len()) {
  if deg_vals[i] > 10 { hub_count = hub_count + 1 }
}

// build JSON output
let now = exec("date -u '+%Y-%m-%dT%H:%M:%SZ'").trim()
let mut out = "{\n"
out = out + "  \"timestamp\": \"" + now + "\",\n"
out = out + "  \"nodes\": " + str(total_nodes) + ",\n"
out = out + "  \"text_nodes\": " + str(text_nodes) + ",\n"
out = out + "  \"json_nodes\": " + str(json_nodes) + ",\n"
out = out + "  \"edges\": " + str(total_edges) + ",\n"
out = out + "  \"lines\": " + str(lines.len()) + ",\n"
out = out + "  \"hubs\": " + str(hub_count) + ",\n"
out = out + "  \"breakthroughs\": " + str(breakthrough_count) + ",\n"
out = out + "  \"grades\": {\"exact\": " + str(grade_exact) + ", \"close\": " + str(grade_close) + ", \"hypothesis\": " + str(grade_hyp) + "},\n"

// domains
out = out + "  \"domains\": {"
for i in range(dom_keys.len()) {
  if i > 0 { out = out + ", " }
  out = out + "\"" + dom_keys[i] + "\": " + str(dom_vals[i])
}
out = out + "},\n"

// types
out = out + "  \"types\": {"
for i in range(type_keys.len()) {
  if i > 0 { out = out + ", " }
  out = out + "\"" + type_keys[i] + "\": " + str(type_vals[i])
}
out = out + "}\n"
out = out + "}"

println(out)
