// ═══════════════════════════════════════════════════════════
// miss_to_exact_tracker.hexa — MISS->EXACT 전환율 추적
// READ-ONLY analysis tool. Does NOT modify atlas.n6 (L0 protected).
//
// atlas.n6 grade 체계:
//   [N*]  = EXACT (verified, grade N)
//   [N!]  = BREAKTHROUGH (confirmed, grade N)
//   [N*!] = EXACT + BREAKTHROUGH
//   [N?]  = HYPOTHESIS (unverified, grade N)
//   [N]   = PARTIAL (graded but unverified)
//   (none) = MISS (no grade or JSON node without grade)  // @allow-bare-interp
//
// 전환 경로: MISS -> HYPOTHESIS -> PARTIAL -> EXACT -> BREAKTHROUGH
// 후보 선별: grade 기반 + domain + 연결 밀도 → 승격 가능성 점수
//
// Usage: hexa miss_to_exact_tracker.hexa [--verbose] [--top N]
// ═══════════════════════════════════════════════════════════

let a = args()
let mut verbose = false
let mut top_n: i64 = 30
let mut ai: i64 = 2
while ai < len(a) {
    let tok = a[ai]
    if tok == "--verbose" || tok == "-v" { verbose = true }
    else if tok == "--top" && ai + 1 < len(a) {
        ai = ai + 1
        try { top_n = to_int(a[ai]) } catch e {}  // @allow-silent-catch
    }
    ai = ai + 1
}

let _HOME = exec("printenv HOME").trim()
let _BASE = _HOME + "/Dev/nexus"
let _ATLAS = _BASE + "/shared/n6/atlas.n6"
let _DEG   = _ATLAS + ".deg"
let _STATS = _ATLAS + ".stats"

// ─── Utilities ────────────────────────────────────────────
fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(s.trim()) } catch e {}  // @allow-silent-catch
    return v
}

fn _grep_count(path: string, pattern: string) -> i64 {
    let mut r: i64 = 0
    try {
        let raw = exec("grep -c '" + pattern + "' '" + path + "' 2>/dev/null").trim()
        r = safe_int(raw)
    } catch e {}  // @allow-silent-catch
    return r
}

// ─── Validate inputs ─────────────────────────────────────
if !file_exists(_ATLAS) {
    println("error: atlas not found: " + _ATLAS)
    exit(1)  // @allow-silent-exit
}

println("═══════════════════════════════════════════════════════")
println("  MISS->EXACT Transition Tracker — atlas.n6 (read-only)")
println("═══════════════════════════════════════════════════════")
println("")

// ─── 1. Grade classification: count @-line nodes by grade type ───
// EXACT:       [N*] or [N*!] — verified
// BREAKTHROUGH:[N!] without * — breakthrough but not formally verified
// PARTIAL:     [N] alone — graded, not verified
// HYPOTHESIS:  [N?] — hypothesis
// Text-format @-lines have grades at end-of-line

let exact_count = safe_int(exec("grep -cE '^@.* \\[[0-9]+\\*[!]?\\]$' '" + _ATLAS + "' 2>/dev/null"))
let breakthrough_only = safe_int(exec("grep -cE '^@.* \\[[0-9]+!\\]$' '" + _ATLAS + "' 2>/dev/null"))
let partial_count = safe_int(exec("grep -cE '^@.* \\[[0-9]+\\]$' '" + _ATLAS + "' 2>/dev/null"))
let hypothesis_count = safe_int(exec("grep -cE '^@.* \\[[0-9]+\\?\\]$' '" + _ATLAS + "' 2>/dev/null"))
let text_nodes_total = safe_int(exec("grep -cE '^@[A-Z]+ ' '" + _ATLAS + "' 2>/dev/null"))

// JSON-format nodes (no inline grade; grade comes from confidence field)
let json_nodes = safe_int(exec("grep -c '\"type\":\"node\"' '" + _ATLAS + "' 2>/dev/null"))
let json_absorb = safe_int(exec("grep -c '\"type\":\"absorb\"' '" + _ATLAS + "' 2>/dev/null"))

// JSON nodes with high confidence (>=0.9) approximate EXACT
let json_high_conf = safe_int(exec("grep '\"type\":\"node\"' '" + _ATLAS + "' 2>/dev/null | grep -cE '\"confidence\":(0\\.9[0-9]*|1\\.0)' 2>/dev/null"))
// JSON nodes with medium confidence (0.5-0.89) approximate PARTIAL
let json_mid_conf = safe_int(exec("grep '\"type\":\"node\"' '" + _ATLAS + "' 2>/dev/null | grep -cE '\"confidence\":0\\.[5-8]' 2>/dev/null"))
// JSON nodes with low confidence (<0.5) approximate HYPOTHESIS
let json_low_conf = safe_int(exec("grep '\"type\":\"node\"' '" + _ATLAS + "' 2>/dev/null | grep -cE '\"confidence\":0\\.[0-4]' 2>/dev/null"))

let total_all = text_nodes_total + json_nodes + json_absorb

// Combined tallies
let total_exact = exact_count + json_high_conf
let total_partial = partial_count + breakthrough_only + json_mid_conf
let total_hypothesis = hypothesis_count + json_low_conf
let total_miss = total_all - total_exact - total_partial - total_hypothesis

println("── 1. Grade Distribution Summary ──")
println("  Total nodes (text + JSON):  " + to_string(total_all))
println("    text @-nodes:             " + to_string(text_nodes_total))
println("    JSON nodes:               " + to_string(json_nodes))
println("    JSON absorb:              " + to_string(json_absorb))
println("")
println("  EXACT    [N*] + high-conf:  " + to_string(total_exact))
println("    text [N*] / [N*!]:        " + to_string(exact_count))
println("    JSON conf>=0.9:           " + to_string(json_high_conf))
println("  PARTIAL  [N] + [N!] + mid:  " + to_string(total_partial))
println("    text [N]:                  " + to_string(partial_count))
println("    text [N!]:                 " + to_string(breakthrough_only))
println("    JSON conf 0.5-0.89:       " + to_string(json_mid_conf))
println("  HYPOTHESIS [N?] + low:      " + to_string(total_hypothesis))
println("    text [N?]:                 " + to_string(hypothesis_count))
println("    JSON conf<0.5:            " + to_string(json_low_conf))
println("  MISS (ungraded/unknown):    " + to_string(total_miss))
println("")

// ─── 2. Transition rates ─────────────────────────────────
let exact_rate = if total_all > 0 { to_float(total_exact) * 100.0 / to_float(total_all) } else { 0.0 }
let partial_rate = if total_all > 0 { to_float(total_partial) * 100.0 / to_float(total_all) } else { 0.0 }
let hypo_rate = if total_all > 0 { to_float(total_hypothesis) * 100.0 / to_float(total_all) } else { 0.0 }
let miss_rate = if total_all > 0 { to_float(total_miss) * 100.0 / to_float(total_all) } else { 0.0 }

println("── 2. Transition Rates ──")
println("  EXACT rate:      " + to_string(exact_rate) + "%")
println("  PARTIAL rate:    " + to_string(partial_rate) + "%")
println("  HYPOTHESIS rate: " + to_string(hypo_rate) + "%")
println("  MISS rate:       " + to_string(miss_rate) + "%")
println("")

// Transition pipeline visualization
println("  Pipeline: MISS -> HYPOTHESIS -> PARTIAL -> EXACT")
println("            " + to_string(total_miss) + "     " + to_string(total_hypothesis) + "          " + to_string(total_partial) + "       " + to_string(total_exact))
println("")

// ─── 3. Grade-level breakdown (text nodes only, [N*] detail) ───
println("── 3. Exact Grade Distribution ──")
let grade_dist_raw = exec("grep -oE ' \\[[0-9]+[?*!]*\\]$' '" + _ATLAS + "' 2>/dev/null | sort | uniq -c | sort -rn | head -20").trim()
let grade_lines = grade_dist_raw.split("\n")
for gl in grade_lines {
    let t = gl.trim()
    if t != "" { println("    " + t) }
}
println("")

// ─── 4. Domain-level transition analysis ─────────────────
println("── 4. Domain Transition Analysis ──")
println("  (text @-nodes by domain :: grade category)")
println("")

// Extract domain from @X ... :: domain [grade] lines
// Count EXACT per domain
let domain_exact_raw = exec("grep -E '^@.* \\[[0-9]+\\*[!]?\\]$' '" + _ATLAS + "' 2>/dev/null | grep -oE ':: [a-z_]+ ' | sed 's/:: //' | sed 's/ $//' | sort | uniq -c | sort -rn | head -15").trim()
println("  EXACT nodes by domain:")
let de_lines = domain_exact_raw.split("\n")
for del in de_lines {
    let t = del.trim()
    if t != "" { println("    " + t) }
}
println("")

// Count HYPOTHESIS per domain
let domain_hypo_raw = exec("grep -E '^@.* \\[[0-9]+\\?\\]$' '" + _ATLAS + "' 2>/dev/null | grep -oE ':: [a-z_]+ ' | sed 's/:: //' | sed 's/ $//' | sort | uniq -c | sort -rn | head -15").trim()
println("  HYPOTHESIS nodes by domain:")
let dh_lines = domain_hypo_raw.split("\n")
for dhl in dh_lines {
    let t = dhl.trim()
    if t != "" { println("    " + t) }
}
println("")

// Domain transition ratio: EXACT / (EXACT + non-EXACT) per domain
println("  Domain EXACT conversion rate:")
let domain_all_raw = exec("grep -E '^@[A-Z]+ ' '" + _ATLAS + "' 2>/dev/null | grep -oE ':: [a-z_]+ ' | sed 's/:: //' | sed 's/ $//' | sort | uniq -c | sort -rn | head -15").trim()
let da_lines = domain_all_raw.split("\n")
for dal in da_lines {
    let t = dal.trim()
    if t == "" { continue }
    let parts = t.split(" ")
    if len(parts) < 2 { continue }
    let domain_total = safe_int(parts[0])
    let domain_name = parts[1]
    // Count exact for this domain
    let d_exact = safe_int(exec("grep -E '^@.* :: " + domain_name + " \\[[0-9]+\\*[!]?\\]$' '" + _ATLAS + "' 2>/dev/null | wc -l"))
    let conv_rate = if domain_total > 0 { to_float(d_exact) * 100.0 / to_float(domain_total) } else { 0.0 }
    let status = if conv_rate >= 80.0 { " [STRONG]" } else if conv_rate >= 50.0 { " [MODERATE]" } else { " [WEAK - upgrade candidates here]" }
    println("    " + domain_name + ": " + to_string(d_exact) + "/" + to_string(domain_total) + " (" + to_string(conv_rate) + "%)" + status)
}
println("")

// ─── 5. Upgrade candidates: HYPOTHESIS -> EXACT promotion ─
println("── 5. Top Upgrade Candidates (HYPOTHESIS -> EXACT) ──")
println("  Criteria: [N?] nodes with high grade N and connections")
println("")

// 5a. High-grade hypotheses (grade >= 5, marked ?)
println("  [A] High-grade hypotheses (grade >= 5, unverified):")
let high_hypo_raw = exec("grep -E '^@.* \\[([5-9]|10)\\?\\]$' '" + _ATLAS + "' 2>/dev/null | head -" + to_string(top_n)).trim()
if high_hypo_raw != "" {
    let hh_lines = high_hypo_raw.split("\n")
    let mut hh_count: i64 = 0
    for hhl in hh_lines {
        let t = hhl.trim()
        if t != "" {
            // Extract id and grade
            let parts = t.split(" ")
            if len(parts) >= 2 {
                let node_type = parts[0]
                let node_id = parts[1]
                // Check degree from .deg sidecar
                let mut deg: i64 = 0
                if file_exists(_DEG) {
                    deg = safe_int(exec("awk -F'\\t' -v id='" + node_id + "' '$1==id{print $2}' '" + _DEG + "' 2>/dev/null"))
                }
                let deg_label = if deg >= 3 { " (HUB deg=" + to_string(deg) + ")" } else if deg >= 1 { " (deg=" + to_string(deg) + ")" } else { "" }
                println("    " + node_id + deg_label)
                hh_count = hh_count + 1
            }
        }
    }
    println("    --- " + to_string(hh_count) + " high-grade hypothesis candidates ---")
} else {
    println("    (none found)")
}
println("")

// 5b. PARTIAL nodes ([N] without * or ?) — closest to EXACT
println("  [B] PARTIAL nodes (graded, need verification):")
let partial_raw = exec("grep -E '^@.* \\[[0-9]+\\]$' '" + _ATLAS + "' 2>/dev/null | head -" + to_string(top_n)).trim()
if partial_raw != "" {
    let p_lines = partial_raw.split("\n")
    let mut p_count: i64 = 0
    for pl in p_lines {
        let t = pl.trim()
        if t != "" {
            let parts = t.split(" ")
            if len(parts) >= 2 {
                let node_id = parts[1]
                let mut deg: i64 = 0
                if file_exists(_DEG) {
                    deg = safe_int(exec("awk -F'\\t' -v id='" + node_id + "' '$1==id{print $2}' '" + _DEG + "' 2>/dev/null"))
                }
                let deg_label = if deg >= 3 { " (HUB deg=" + to_string(deg) + ")" } else if deg >= 1 { " (deg=" + to_string(deg) + ")" } else { "" }
                println("    " + node_id + deg_label)
                p_count = p_count + 1
            }
        }
    }
    println("    --- " + to_string(p_count) + " partial-grade candidates ---")
} else {
    println("    (none found)")
}
println("")

// 5c. Breakthrough-only [N!] — already validated but not * flagged
println("  [C] BREAKTHROUGH without EXACT flag (need * addition):")
let bt_only_raw = exec("grep -E '^@.* \\[[0-9]+!\\]$' '" + _ATLAS + "' 2>/dev/null | head -" + to_string(top_n)).trim()
if bt_only_raw != "" {
    let bt_lines = bt_only_raw.split("\n")
    let mut bt_count: i64 = 0
    for btl in bt_lines {
        let t = btl.trim()
        if t != "" {
            let parts = t.split(" ")
            if len(parts) >= 2 {
                println("    " + parts[1] + "  -> should become [N*!]")
                bt_count = bt_count + 1
            }
        }
    }
    println("    --- " + to_string(bt_count) + " breakthrough candidates for EXACT upgrade ---")
} else {
    println("    (none found)")
}
println("")

// ─── 6. JSON node confidence upgrade candidates ──────────  // @allow-bare-interp
println("── 6. JSON Node Confidence Upgrade Candidates ──")
println("  (confidence 0.5-0.89, could be promoted to >= 0.9)")
println("")

// JSON nodes with mid confidence, sorted by confidence descending
let json_candidates_raw = exec("grep '\"type\":\"node\"' '" + _ATLAS + "' 2>/dev/null | grep -oE '\"id\":\"[^\"]+\",.*\"confidence\":0\\.[5-8][0-9]*' | sed 's/\"id\":\"//' | sed 's/\",.*\"confidence\":/\tconf=/' | sort -t= -k2 -rn | head -" + to_string(top_n)).trim()
if json_candidates_raw != "" {
    let jc_lines = json_candidates_raw.split("\n")
    let mut jc_count: i64 = 0
    for jcl in jc_lines {
        let t = jcl.trim()
        if t != "" { println("    " + t); jc_count = jc_count + 1 }
    }
    println("    --- " + to_string(jc_count) + " JSON confidence upgrade candidates ---")
} else {
    println("    (none found)")
}
println("")

// ─── 7. Transition velocity estimation ───────────────────
println("── 7. Transition Velocity ──")
// Estimate: how many nodes would need to upgrade for each 1% improvement
let nodes_per_pct = if total_all > 0 { to_float(total_all) / 100.0 } else { 0.0 }
let gap_to_90 = 90.0 - exact_rate
let nodes_needed_90 = if gap_to_90 > 0.0 { gap_to_90 * nodes_per_pct } else { 0.0 }

println("  Current EXACT rate:         " + to_string(exact_rate) + "%")
println("  Nodes per 1% improvement:   " + to_string(nodes_per_pct))
if gap_to_90 > 0.0 {
    println("  Gap to 90% EXACT rate:      " + to_string(gap_to_90) + "% (" + to_string(nodes_needed_90) + " nodes)")
}
println("")

// Immediate actionable: breakthrough + high-grade hypothesis
let immediate_pool = breakthrough_only + hypothesis_count
println("  Immediate upgrade pool:")
println("    Breakthrough [N!] -> [N*!]: " + to_string(breakthrough_only))
println("    Hypothesis [N?] -> [N*]:    " + to_string(hypothesis_count))
println("    Total actionable:           " + to_string(immediate_pool))
println("")

// ─── 8. Summary ──────────────────────────────────────────
println("═══════════════════════════════════════════════════════")
println("  SUMMARY")
println("═══════════════════════════════════════════════════════")
println("  EXACT:      " + to_string(total_exact) + " (" + to_string(exact_rate) + "%)")
println("  non-EXACT:  " + to_string(total_all - total_exact) + " (" + to_string(100.0 - exact_rate) + "%)")
println("  Quickest wins:")
println("    1. Verify [N!] breakthroughs -> [N*!]  (" + to_string(breakthrough_only) + " nodes)")
println("    2. Verify [N?] hypotheses -> [N*]      (" + to_string(hypothesis_count) + " nodes)")
println("    3. Grade MISS nodes -> [N?] or [N*]    (" + to_string(total_miss) + " nodes)")
println("")
println("  IMPORTANT: atlas.n6 is L0 protected.")
println("  All writes MUST go through _guarded_append_atlas().")
println("  This tool is read-only analysis.")
println("═══════════════════════════════════════════════════════")

exit(0)
