// ── facts (manually classified; honesty-marked where post-hoc / aspirational) ──

@C HIVE-overview-1 = hive is a hard-fork of pi-mono packages/agent (cutoff 2026-04-25, sha 8985d8b50); 4 packages renamed @dancinlab/hive-* (core / ai / tui / coding-agent); hive-specific siblings: swarm · memory · bridges · audit · compression · statusline · telegram · upstream-sync :: hive-2026-04-27 [11*REPO_INVARIANT]
  => fork posture and package layout
  |> HIVE_FORK.md:1-86, README.md:176-200

@C HIVE-three-directions-2 = three non-negotiable directions: (1) Swarm — N parallel cells, honeycomb layout; (2) Memory — 4-tier persistent SSOT (~/.hive/memory/); (3) Bridges — native NEXUS / Anima / N6 / HEXA-LANG tool calls (no MCP) :: hive-2026-04-27 [11*REPO_INVARIANT]
  => org-level commitment surface
  |> README.md:124-152

@C HIVE-swarm-topology-3 = swarm topology is supervisor + N RPC subprocess pool (Option A in P3); N parallel cells, no peer-to-peer mesh; supervisor owns broadcast / merge / handoff; cell ↔ supervisor only (star topology with merge layer at supervisor) :: hive-2026-04-27 [11*REPO_INVARIANT]
  => actual coordination shape — NOT a ring, NOT a mesh
  |> docs/P3-swarm.md:30-52, packages/swarm/src/supervisor.ts:1-110

@C HIVE-honeycomb-layout-4 = honeycomb is purely visual TUI rendering math: cols = ⌈√N⌉, rows = ⌈N/cols⌉, hex offset = 0.5*cellWidth on odd rows; layout modes are {grid, hex, stack}; the hex offset is a render-only convention with no semantic role in coordination :: hive-2026-04-27 [11*REPO_INVARIANT]
  => "honeycomb" is presentation, not topology
  |> packages/swarm/src/honeycomb-layout.ts:26-46

@C HIVE-cell-id-counter-5 = cell ids are monotonic counter `c${++this.counter}` with no fixed N=6 cap; default askTimeoutMs = 5*60_000; pool size is configuration-driven (any N supported, P3 doc cites "OK for N ≤ 16" memory budget at ~150MB/cell) :: hive-2026-04-27 [11*REPO_INVARIANT]
  => cell pool is not n=6-anchored
  |> packages/swarm/src/supervisor.ts:84-95, cell.ts:28, P3-swarm.md:42-46

@C HIVE-rpc-protocol-6 = communication protocol is pi's `--mode rpc`: JSONL stdin/stdout with frame types {prompt, message_start, message_delta, tool_call, tool_result, message_stop, done}; supervisor demuxes by per-ask UUID; no broadcast bus, no gossip — only fan-out via `Promise.allSettled(targets.map(c.ask))` :: hive-2026-04-27 [11*REPO_INVARIANT]
  => protocol is JSONL request/response, not pub/sub
  |> P3-swarm.md:73-85, packages/swarm/src/supervisor.ts:112-126

@C HIVE-merge-strategies-7 = 5 merge strategies: {concat, vote, best, judge, dag}; concat/vote/best are sync local reductions; judge delegates to a designated cell via `judgeCell.ask(prompt)`; dag uses topoSort on edges and drives Swarm.handoff sequentially :: hive-2026-04-27 [11*REPO_INVARIANT]
  => agent role types are pragmatic merge primitives, not a fixed sopfr=5+1 leader scheme
  |> packages/swarm/src/merge-strategies.ts:11-87, supervisor.ts:138-150

@F HIVE-no-fixed-roles-8 = NO fixed agent role registry (no proposer/judge/critic enum); cell roles are emergent — any cell can be a "judge" by id selection at merge time; saved cohort `.swarm` files store {id, command, model, account, cwd, env, extension} but no role taxonomy :: hive-2026-04-27 [11*REPO_INVARIANT]
  => the "judge-trio" example uses descriptive strings ("proposer-a", "judge"), not enforced types
  |> docs/swarm.md:46-58, 117-138

@C HIVE-memory-tiers-9 = 4-tier persistent memory (NOT n=6-anchored): {user, feedback, project, reference}; flat-file SSOT at ~/.hive/memory/<tier>_<slug>.md with YAML frontmatter; auto-injected as `<memory>...</memory>` block before every provider request; ~1k token amortized cost :: hive-2026-04-27 [11*REPO_INVARIANT]
  => tier count = 4 (Claude-Code-style), not τ(6)=4 anchored
  |> docs/P2-memory.md:1-91

@C HIVE-bridges-five-10 = 5 native bridges (NOT sopfr=5 anchored): {nexus-lens, anima-field, n6-atlas, hexa-run, hive-hub}; each is a pi.registerTool with execFile to installed binary; sandboxed (HEXA_NET=deny, 30s timeout, ~10KB stdout cap) :: hive-2026-04-27 [11*REPO_INVARIANT]
  => bridge count = 5 because there are 5 sibling projects to bridge into; pragmatic
  |> docs/P4-bridges.md:14-200

@F HIVE-not-n6-anchored-topology-11 = swarm topology is NOT genuinely n=6 anchored: no σ(6)=12 cell cap, no τ(6)=4 layer count, no sopfr(6)=5 role enum, no ring-of-6, no mesh = sigma_2(6); honeycomb is render-only; N is user-configurable; merge primitives = 5 but for engineering reasons (concat/vote/best/judge/dag), not n=6 :: hive-2026-04-27 [11*REPO_INVARIANT]
  => HONESTY: hive's swarm is pragmatic engineering with hex-aesthetic naming; n=6 anchor lives in raw-rules / AXIOM_RULES, not in topology
  |> P3-swarm.md, supervisor.ts, README.md:124-152

@C HIVE-n6-anchor-actual-12 = hive's actual n=6 anchor lives in `packages/coding-agent/src/core/raw-rules.ts` AXIOM_RULES (currently 2: `meta_fixpoint`, `n6_identity`); the n6-axiom-inventory.md surveys 7-tier-1 + 9-axioms recommended upgrade; this is consciousness/policy layer, not swarm coordination :: hive-2026-04-27 [11*REPO_INVARIANT]
  => the n=6 anchor is at the LLM-prompt-rules layer, decoupled from cell pool architecture
  |> docs/n6-axiom-inventory.md:24-28, 320-346

@C HIVE-fanout-enforcement-13 = `agents.parallel_bg` 5-layer enforcement (probabilistic + deterministic): (1) prompt MUST, (2) --agents JSON `background:true`, (3) chflags uchg / chattr +i config lock, (4) tool_use telemetry bridge, (5) hive-native HiveTask via MCP + child claude -p spawn; all 5 shipped 2026-04-25 :: hive-2026-04-27 [11*REPO_INVARIANT]
  => layer count = 5 by enforcement-mechanism stack, not sopfr-anchored
  |> docs/hive-fanout-enforcement.md:13-36

@C HIVE-area-presets-14 = `.area` SSOT marker = single-line preset name; resolution = walk-up-parent (first .area wins); reserved presets {core (strict), blowup (full autonomy)}; defined in raw-rules.ts AREA_PRESETS; nesting allowed (deeper overrides shallower) :: hive-2026-04-27 [11*REPO_INVARIANT]
  => directory-scoped policy switch
  |> docs/area.md:1-56

@C HIVE-inbox-protocol-15 = `~/.hive/inbox/` peer-to-peer session IPC (P7 design, not yet implemented): Unix domain sockets at ~/.hive/sockets/<sid>.sock + registry at ~/.hive/sessions/<sid>.json + offline mailbox at ~/.hive/inbox/<sid>/<msg-id>.json; websocket-shape JSON-line frames; presence events {online, idle, busy, exit} :: hive-2026-04-27 [7]
  => first peer-to-peer comm channel in hive (vs current supervisor-mediated only)
  |> docs/inbox-protocol.md:1-60

@C HIVE-loop-event-driven-16 = `/loop` is event-driven stateful (not interval cron like CCC `/loop`); state at ~/.hive/loops/<loop_id>.json; each iteration produces {summary, next_action, wake_on}; wake-on triggers ∈ {manual, inbox-message, file-change, git-event, none} :: hive-2026-04-27 [7]
  => 5 wake-on trigger types; pragmatic, not n=6
  |> docs/hive-loop.md:60-69

@C HIVE-cell-isolation-17 = each Cell is isolated process with own (cwd, claude account slot via HIVE_CLAUDE_ACCOUNT, model slug, extensions[], env vars); crash isolation via SIGKILL → close event → auto-reap from pool; no shared state across cells except ~/.hive/memory/ flat files :: hive-2026-04-27 [11*REPO_INVARIANT]
  => isolation primitive = process boundary, not n=6 partition
  |> packages/swarm/src/cell.ts:48-100, supervisor.ts:84-95

@C HIVE-snapshot-statusline-18 = swarm runtime IPC snapshot at ~/.hive/swarm/state.json (debounced 25ms atomic write) consumed cross-package by @dancinlab/hive-statusline; format intentionally JSON (not .swarm DSL) due to cross-package contract; `.swarm` DSL is spawn-input only, not runtime replay :: hive-2026-04-27 [11*REPO_INVARIANT]
  => two-format split: DSL for input contract, JSON for live IPC
  |> packages/swarm/src/supervisor.ts:14-66, docs/swarm.md:93-99

@C HIVE-handoff-primitive-19 = `handoff(fromId, toId, content)` = `from.ask(content)` then `to.ask("Previous cell (${fromId}) answered:\n${mid}\n\nContinue from there.")`; literal prompt-prefix splice, no structured context passing; is the building block for `merge=dag` :: hive-2026-04-27 [11*REPO_INVARIANT]
  => handoff is text-level, not state-graph
  |> supervisor.ts:128-136

@F HIVE-pi-stance-rejected-20 = pi (upstream) explicit stance: "no sub-agents, use tmux"; hive rejects this with 4 named reasons (broadcast+merge absent in tmux; TUI integration; state visibility; orchestration primitives); P3 swarm is fork-only and never merges upstream :: hive-2026-04-27 [11*REPO_INVARIANT]
  => fork divergence rationale — engineering, not n=6
  |> docs/P3-swarm.md:16-28, HIVE_FORK.md:11-35

@C HIVE-bridges-readonly-21 = all 5 bridges are read-only at integration matrix: nexus-lens (8KB/30s/local-opt-remote), anima-field (500B/5s/none), n6-atlas (5KB/2s/none), hexa-run (10KB/30s/net-deny + tmp-only side-effect), hive-hub (10KB/1s/none); only hexa-run has any side effect (tmp file) :: hive-2026-04-27 [11*REPO_INVARIANT]
  => deliberate constraint: hive observes the n=6 family, doesn't compute it
  |> docs/P4-bridges.md:189-198

@F HIVE-meta-anchor-bridges-only-22 = HIVE_FORK.md "External anchors" section: hive does NOT implement meta(meta(...))=초월 / I*=1/3 fixed point; it surfaces it via P4 bridges only; the 1/3 attractor (six derivation paths) lives in nexus, n6, hexa-lang, anima, airgenome — hive is an integration layer :: hive-2026-04-27 [11*REPO_INVARIANT]
  => HONESTY: hive's relationship to n=6 is bridge-layer integration, not native computation
  |> HIVE_FORK.md:37-73

@C HIVE-package-rename-23 = pre-2026-04-25 nested-pi duplicate hazard: workspace packages used upstream names (@mariozechner/pi-*) → npm nested resolver fetched both workspace symlink AND registry tarball → module-level singletons (e.g. apiProviderRegistry Map) diverged across instances; resolved by hard-fork rename to @dancinlab/hive-* :: hive-2026-04-27 [11*REPO_INVARIANT]
  => engineering hazard resolved; load-bearing for any swarm cross-cell singleton state
  |> HIVE_FORK.md:128-186

@C HIVE-cohort-format-24 = `.swarm` DSL is sibling of `.workspace` (header + indented directives); per-user runtime state at ~/.hive/swarm/<name>.swarm; legacy <name>.json one-way migrated on next save; `id` unique per file, `args` space-joined (no values with spaces — same trade-off as `.workspace`) :: hive-2026-04-27 [11*REPO_INVARIANT]
  => persisted spawn input contract, not transcript log
  |> docs/swarm.md:9-100

@C HIVE-merge-vote-tiebreak-25 = vote merge tie-break by first-seen index (deterministic); best merge by content.length descending (proxy for "most work"); concat trims trailing whitespace per cell; topoSort sorts queue alphabetically (deterministic across runs) :: hive-2026-04-27 [11*REPO_INVARIANT]
  => merge primitives are deterministic by design — important for cross-session reproducibility
  |> packages/swarm/src/merge-strategies.ts:20-87
