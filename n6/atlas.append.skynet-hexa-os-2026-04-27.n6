# ── @C  Constants  (hexa-os numerical anchors) ──────────────

@C hexa_os_syscall_latency_target_ns = "20-80" :: hexa-os.perf.syscall [9!]
  => "Syscall latency target: ~300 ns (Linux int 0x80) → 20-80 ns (hexa fn call). 5-20× speedup."
  => "Mechanism: syscall = hexa fn call (not interrupt). Single address space, no ring transition."
  => "Status: TARGET, not measured. Bench POC scheduled as Phase 0/1, gated on hexa-lang P7-9 fixpoint."
  |> /Users/ghost/core/hexa-os/README.md L48-L60 perf table

@C hexa_os_p99_target_reduction_pct = "30-50" :: hexa-os.perf.p99 [9!]
  => "Headline target: serving latency p99 reduced 30-50% vs Linux+vLLM on identical HW."
  => "Concrete projected number: Linux p99 200ms → Hexa OS p99 130ms (-35%)."
  => "Mechanism: cooperative-only (no sched_tick jitter), arena-per-request (no kv-cache page fault), single addr space (fn call not syscall), unikernel (no daemon interference), per-core arena (no TLB shootdown), poll-mode I/O (no IRQ), pinned freq, pinned CPU."
  => "Honest: TARGET. No bench has run. Training gain capped at ~5% (compute-bound) — serving only."
  |> /Users/ghost/core/hexa-os/docs/PERF_P99.md §p99 table

@C hexa_os_cold_start_target_ms = 500 :: hexa-os.perf.coldstart [9!]
  => "Cold-start target: < 500 ms for 7B-model unikernel serving."
  => "Linux microVM baseline: 5-30 s (microVM 125-300ms + OS init 500-2000ms + app 100-500ms + model load 5-30s)."
  => "Unikernel projection: 120-500 ms (microVM 20-100ms + OS=0 + app=0 + lazy-mmap model 100-400ms). 10-60× improvement claimed."
  => "Status: design only. Firecracker guest packaging is Phase 4 (~4 months after prerequisites)."
  |> /Users/ghost/core/hexa-os/docs/HEXA_SERVE_V01.md §5 cold-start table

