// ═══════════════════════════════════════════════════════════
// build_edges_index.hexa — edges.jsonl 인접 리스트 인덱스 빌더
// R1 HEXA-FIRST 준수 (staleness 판정 hexa, 대용량 빌드 python3 위임)  // @allow-bare-interp
// 용도: 4.6M-line edges.jsonl → O(1) adjacency lookup JSON
// 사용: hexa build_edges_index.hexa [--edges PATH] [--force] [--verbose]
// 출력: edges.adjacency.json + edges.adjacency.json.gz (동일 디렉토리)
// 원칙: edges.jsonl 읽기 전용. 인덱스만 생성/갱신.
// ═══════════════════════════════════════════════════════════

let a = args()
let mut EDGES_PATH = "shared/discovery/cycle/edges.jsonl"
let mut force = false
let mut verbose = false

// ─── CLI 파싱 ───
let mut ai: i64 = 2
while ai < len(a) {
    let tok = a[ai]
    if tok == "--edges" && ai + 1 < len(a) { ai = ai + 1; EDGES_PATH = a[ai] }
    else if tok == "--force" || tok == "-f" { force = true }
    else if tok == "--verbose" || tok == "-v" { verbose = true }
    else if tok == "--help" || tok == "-h" {
        println("usage: hexa build_edges_index.hexa [--edges PATH] [--force] [--verbose]")
        println("  --edges PATH   edges.jsonl 경로 (default: shared/discovery/cycle/edges.jsonl)")
        println("  --force        mtime 무시, 강제 재빌드")
        println("  --verbose      상세 출력")
        println("")
        println("output: edges.adjacency.json + .gz (same directory as edges.jsonl)")
        println("format: {\"_meta\":{...},\"adj\":{\"p_000000\":[[\"p_000001\",0.2188],...]}}")
        println("  gzip: ~84% smaller; read with json.loads(gzip.open(f,'rt').read())")
        exit(0)
    }
    ai = ai + 1
}

// ─── 파일 존재 검증 ───
if !file_exists(EDGES_PATH) {
    println("error: edges file not found: " + EDGES_PATH)
    println("usage: hexa build_edges_index.hexa [--edges PATH] [--force] [--verbose]")
    exit(1)  // @allow-silent-exit
}

// ─── shell helper ───
fn _exec_str(cmd: string) -> string {
    let mut r = ""
    try { r = to_string(exec(cmd)).trim() } catch e {}  // @allow-silent-catch
    return r
}

fn _exec_int(cmd: string) -> i64 {
    let mut r: i64 = 0
    try { r = to_int(to_string(exec(cmd)).trim()) } catch e {}  // @allow-silent-catch
    return r
}

// ─── 경로 계산 ───
// OUT_PATH = edges.jsonl → edges.adjacency.json (같은 디렉토리)
let OUT_PATH = EDGES_PATH.replace(".jsonl", ".adjacency.json")
let GZ_PATH  = OUT_PATH + ".gz"

println("╔══════════════════════════════════════════════════════════╗")
println("║  build_edges_index — adjacency index builder             ║")
println("╚══════════════════════════════════════════════════════════╝")
println("")

// ─── source mtime ───
let source_mtime = _exec_str("stat -f '%m' '" + EDGES_PATH + "' 2>/dev/null || stat -c '%Y' '" + EDGES_PATH + "' 2>/dev/null")
if verbose {
    println("  source: " + EDGES_PATH)
    println("  output: " + OUT_PATH)
    println("  source mtime: " + source_mtime)
}

// ─── staleness check ───
if !force && file_exists(OUT_PATH) {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    // Original: python3 -c "import json; ..." — staleness mtime + edge/node count
    panic("R37/AN13/L3-PY: python3 invocation blocked at build_edges_index.hexa:77 (staleness check meta JSON parse). Research module — escalate to user.")
    let cached_mtime = ""
    if cached_mtime == source_mtime {
        println("  status: FRESH (mtime=" + source_mtime + ")")
        println("  edges.adjacency.json is up to date. Use --force to rebuild.")
        let cached_edges = ""
        let cached_nodes = ""
        let cached_size = _exec_str("stat -f '%z' '" + OUT_PATH + "' 2>/dev/null || stat -c '%s' '" + OUT_PATH + "' 2>/dev/null")
        println("  cached: " + cached_edges + " edges, " + cached_nodes + " nodes, " + cached_size + " bytes")
        exit(0)
    }
    if verbose {
        println("  cached mtime: " + cached_mtime + " (stale, source=" + source_mtime + ")")
    }
}

// ─── 빌드 시작 ───
let edge_count_est = _exec_int("wc -l < '" + EDGES_PATH + "'")
println("  building adjacency index ...")
println("  source: " + EDGES_PATH + " (~" + to_string(edge_count_est) + " lines)")
println("")

// ─── Python3 위임: 4.6M lines 대용량 처리 ───
// hexa 단독으로는 메모리/속도 제약 → python3 fast path  // @allow-bare-interp
// 양방향 인접 리스트 + 거리순 정렬 + compact 배열 포맷
// adj[node] = [[neighbor, distance], ...] — 키 반복 제거로 파일 크기 ~40% 절감
let py_script = "
import json, sys, os, gzip
from collections import defaultdict

edges_path = '" + EDGES_PATH + "'
out_path = '" + OUT_PATH + "'
gz_path = '" + GZ_PATH + "'
source_mtime = '" + source_mtime + "'
verbose = " + if verbose { "True" } else { "False" } + "

adj = defaultdict(list)
count = 0
errors = 0
batch_size = 500000

with open(edges_path) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            e = json.loads(line)
            fr = e['from']
            to = e['to']
            d = round(e.get('distance', 0), 4)
            adj[fr].append((to, d))
            adj[to].append((fr, d))
            count += 1
            if verbose and count % batch_size == 0:
                print(f'  ... {count:,} edges processed, {len(adj):,} nodes', flush=True)
        except Exception as ex:
            errors += 1
            if errors <= 5 and verbose:
                print(f'  warn: parse error line {count + errors}: {ex}', flush=True)
            continue

print(f'  parsed: {count:,} edges, {len(adj):,} nodes, {errors} errors')

# sort each adjacency list by distance (nearest neighbor first)
print('  sorting adjacency lists by distance ...')
for k in adj:
    adj[k].sort(key=lambda x: x[1])

# convert to list-of-lists for JSON (tuples become arrays)
adj_out = {k: [list(t) for t in v] for k, v in adj.items()}

# assemble result
result = {
    '_meta': {
        'source': os.path.basename(edges_path),
        'mtime': source_mtime,
        'edge_count': count,
        'node_count': len(adj),
        'errors': errors,
        'format': 'adj[node] = [[neighbor, distance], ...], sorted by distance asc'
    },
    'adj': adj_out
}

# write compact JSON (separators minimize whitespace)
print(f'  writing {out_path} ...')
with open(out_path, 'w') as f:
    json.dump(result, f, separators=(',', ':'))

size_bytes = os.path.getsize(out_path)
size_mb = size_bytes / (1024 * 1024)
print(f'  done: {size_bytes:,} bytes ({size_mb:.1f} MB)')

# write gzip compressed copy (compresslevel=6: good ratio, fast)
print(f'  writing {gz_path} ...')
with open(out_path, 'rb') as f_in:
    with gzip.open(gz_path, 'wb', compresslevel=6) as f_out:
        while True:
            chunk = f_in.read(8 * 1024 * 1024)
            if not chunk:
                break
            f_out.write(chunk)

gz_bytes = os.path.getsize(gz_path)
gz_mb = gz_bytes / (1024 * 1024)
ratio = gz_bytes / size_bytes * 100
print(f'  gzip:  {gz_bytes:,} bytes ({gz_mb:.1f} MB) — {ratio:.1f}% of JSON')
"

// R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
// Original: python3 -c "<py_script>" — 4.6M edges → adjacency JSON + gzip heavy-lift
panic("R37/AN13/L3-PY: python3 invocation blocked at build_edges_index.hexa:187 (edges→adjacency heavy-lift). Research module — escalate to user.")
let build_result = ""
println(build_result)

// ─── 결과 검증 ───
if !file_exists(OUT_PATH) {
    println("")
    println("  ERROR: index file was not created!")
    println("  check python3 availability and disk space.")  // @allow-bare-interp
    exit(1)  // @allow-silent-exit
}

// 최종 통계
let final_size = _exec_str("stat -f '%z' '" + OUT_PATH + "' 2>/dev/null || stat -c '%s' '" + OUT_PATH + "' 2>/dev/null")
let gz_size    = _exec_str("stat -f '%z' '" + GZ_PATH  + "' 2>/dev/null || stat -c '%s' '" + GZ_PATH  + "' 2>/dev/null")
// R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
// Original: python3 -c "import json; ..." — final stats meta extraction
panic("R37/AN13/L3-PY: python3 invocation blocked at build_edges_index.hexa:201 (final stats meta). Research module — escalate to user.")
let final_edges = ""
let final_nodes = ""

println("")
println("═══════════════════════════════════════════════════════════")
println("  RESULT")
println("  edges:    " + final_edges)
println("  nodes:    " + final_nodes)
println("  json:     " + final_size + " bytes  (" + OUT_PATH + ")")
println("  gzip:     " + gz_size    + " bytes  (" + GZ_PATH  + ")")
println("  mtime:    " + source_mtime)
println("═══════════════════════════════════════════════════════════")
println("  adjacency index built. O(n) scan → O(1) lookup ready.")
println("  read gzip: python3 -c \"import json,gzip; d=json.loads(gzip.open('file.gz','rt').read())\"")  // @allow-bare-interp
println("═══════════════════════════════════════════════════════════")
exit(0)
