@C BRAINWIRE-AR-THC-CB1-HILL = O(C) = C^n / (EC50^n + C^n), EC50=5-10 ng/mL, n=1.2 — O(5)=0.50, O(15)=0.82, O(50)=0.97 :: pharmacology [10]
  <- joywire_thc_variable_model_md
  => "CB1 receptor occupancy via Hill equation, n=1.2 cooperativity"
  => "Reference dose-response: 5 ng/mL light = half-occupancy; 50 ng/mL ≥ 95% saturation"

@C BRAINWIRE-AR-THC-NEUROCHEM-DELTAS = ΔDA +150-200%, ΔeCB +300-500%, Δ5HT +40-60%, ΔGABA +60-80%, ΔNE -50-70% :: pharmacology [10]
  <- joywire_thc_variable_model_md, bloomfield_2016, bossong_2009, pistis_2004
  => "Baseline→peak fold-changes from meta-analysis of 25+ papers"
  => "Note: ΔNE is NEGATIVE (locus coeruleus suppression — explains relaxation phenotype)"

@C BRAINWIRE-AR-THC-EEG-DELTAS = Δθ +80-150%, Δα -40-60%, Δγ +30-80%, Δδ +10-20%, Δβ -10-20% :: pharmacology [10]
  <- joywire_thc_variable_model_md, ilan_2004, zuurman_2008
  => "Hippocampal theta MASSIVE increase (+80-150%); frontal alpha suppression (-40-60%);"
  => "  gamma binding boost (+30-80%) — supports gamma-coupling subjective-binding hypothesis"

