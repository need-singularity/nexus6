  => "  BCI Bridge 10/10, N1 Hardware 10/10, Golden Zone Implant 10/10,"
  => "  N1 Epilepsy 10/10, N1 Depression 10/10, N1 Panic 10/10"
  |> python3 bench_hypotheses.py  (output captured 2026-04-27)

@F BRAINWIRE-AR-FALSIFIED-H005-40HZ-COHERENCE = "40Hz trimodal → Coherence" — Coherence +0% (expected 50-100%), score 0.00 :: hypothesis_falsified [F]
  <- bench_hypotheses_h_bw_005
  => "Hypothesis: 40Hz trimodal (TMS+tACS+entrainment) drives Coherence variable +50-100%"
  => "Observed: +0% — ZERO Coherence response in current transfer function model"
  => "Honest verdict: FALSIFIED at default coefficients. Either coefficients wrong or"
  => "  40Hz pathway → Coherence requires nonlinear coupling not in linear TF model."

@F BRAINWIRE-AR-FALSIFIED-H010-V1-NOISE-SENSORY = "tDCS V1 + noise → Sensory gain" — Sensory +30% (expected 50-100%), score 0.00 :: hypothesis_falsified [F]
