// ── Section A — Paper Verification Harness (cross-method PASS) ──
//   verify_paper.py and verify_paper_p002.py are independent
//   numerical re-derivations of every quantitative claim in two
//   peer-targeted manuscripts. 100% PASS at default tolerances.

@F BRAINWIRE-AR-VERIFY-PAPER-N1 = verify_paper.py 140/140 PASS @ tol=1e-4 :: paper_verification [10]
  <- archive_brainwire_root, paper_n1_deep_access_md
  => "Independent re-derivation of every numerical claim in docs/paper-n1-deep-access.md"
  => "Sections covered: 2.1 Brain-State, 2.2 Projections, 2.2.2 Temporal Interference (Thm 1),"
  => "  2.2.3 STDP (Prop 1), 2.3 G=D·P/I (Prop 2), 2.5 Optimization (Def 1, Thm 3),"
  => "  2.6 Perfect Number 6 (Thm 4), 2.7 PureField Tension (Prop 4), 2.8 Φ Scaling,"
  => "  2.9 Consciousness Criteria, 3.1/3.3/3.9 Deep Access + Vulnerability + Kuramoto,"
  => "  4.6 Shannon Safety (Thm 2), 4.7 Homeostasis, 5 N1-Only Full Coverage Thm"
  => "Tolerance: tol=1e-4 default; ordering checks via cmp=eq on lists"
  |> python3 verify_paper.py  (output captured 2026-04-27)

@F BRAINWIRE-AR-VERIFY-PAPER-P002-EPILEPSY = verify_paper_p002.py 173/173 PASS @ tol=1e-4 :: paper_verification [10]
  <- archive_brainwire_root, papers_brainwire_P002_n1_epilepsy_md
  => "Independent re-derivation of every numerical claim in P-002-n1-epilepsy-treatment.md"
  => "Sections covered: 1 Epidemiology (50M global, 30% drug-resistant ⇒ 15M target),"
  => "  2.5 N1 Specs (1024 electrodes, 20 kHz, 256× channel ratio vs RNS, 80× sample rate),"
  => "  2.6 Nyquist/HFO (Ripple ≥500 Hz Nyquist; RNS at 250 Hz cannot detect 80-250 Hz HFO),"
  => "  3.1 Detection (Eq 1, Eq 2 P_pre, Eq 3 prevention window),"
  => "  3.2 Anti-phase termination + Power reduction + Max treatable freq,"
  => "  3.3-3.7 GABA enhancement, Hippocampal-EC, STDP anti-kindling, 5HT pathway,"
  => "  4.1 Detection performance, 4.6 N1 vs RNS table, 5.4 Shannon safety"
  |> python3 verify_paper_p002.py  (output captured 2026-04-27)

