@F BRAINWIRE-AR-FALSIFIED-H040-TIER-ANIMA-LEVEL = "Tier→Anima level mapping" — T1:52%→L1, T2:55%→L1, T3:61%→L1, T4:77%→L1, score 0.22 :: hypothesis_falsified [F]
