# ── @F  Formulas  (CPGD, L_cell, L_IX, AN11) ──────────────────
@F P_S_projector = "V^T · V" :: anima.cpgd.algebra [11*]
  <- template_count
  => "orthogonal projector onto template subspace S; V rows = 16 eigenvecs"
  => "idempotent (P_S · P_S = P_S), symmetric (P_S^T = P_S)"
  => "init: W_0 = P_S · W_random ⇒ W_0 ∈ S"
  => "update: W_{k+1} = W_k − lr · (grad · P_S) ⇒ W_k ∈ S ∀k"
  |> edu/lora/cpgd_wrapper.hexa L281-L325 build_projector + verify_idempotent

@F W_init_closed_form = "W_0 = V (each row v_i)" :: anima.cpgd.init [11*]
  <- P_S_projector
  => "specifically chosen so AN11(b) cos = 1 exactly at step 0"
  => "P_S · V = V because v_i ∈ S"
  |> cpgd_wrapper.hexa L477-L493

@F cpgd_drift_bound = "cos(W_k[i,:], v_i) ≥ 1 − O(ε_lr · k)" :: anima.cpgd.theorem [11*]
  <- cpgd_lr_default, probe_steps_cpgd
  => "ε_lr = lr · ‖grad·P_S‖_row ≤ lr · ‖grad‖"
  => "for lr=0.001, 100 step, FP64: max_drift << 0.5 (1600/1600 above 0.5)"
