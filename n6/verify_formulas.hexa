// ═══════════════════════════════════════════════════════════
// verify_formulas.hexa — atlas.n6 수식 산술 검증 (readonly)
// R1 HEXA-FIRST. python eval shell-out 로 수식 평가.
// 용도: @X id = <값> ≈/= <수식> 형태 라인의 산술 정확성 검증
// 사용: hexa verify_formulas.hexa [path] [--verbose]
// ═══════════════════════════════════════════════════════════

let a = args()
let mut _ATLAS_PATH = "shared/n6/atlas.n6"
let mut verbose = false
let mut ai: i64 = 2
while ai < len(a) {
    let tok = a[ai]
    if tok == "--verbose" || tok == "-v" { verbose = true }
    else if !tok.starts_with("-") { _ATLAS_PATH = tok }
    ai = ai + 1
}

if !file_exists(_ATLAS_PATH) {
    println("error: atlas file not found: " + _ATLAS_PATH)
    println("usage: hexa verify_formulas.hexa [path] [--verbose]")
    exit(1)  // @allow-silent-exit
}

// Python 검증 스크립트 (eval 기반) 임베드 후 쉘아웃
// n6 상수: n=6, sigma=12, tau=4, phi=2, sopfr=5, M3=7, J2=24, P2=28, mu=1
let py_script = "import re,sys\n" +
    "ctx={'n':6,'sigma':12,'tau':4,'phi':2,'sopfr':5,'M3':7,'J2':24,'P2':28,'mu':1}\n" +
    "errs=[]; total=0\n" +
    "with open(sys.argv[1]) as f:\n" +
    "    for lno,line in enumerate(f,1):\n" +
    "        line=line.rstrip('\\n')\n" +
    "        if not line.startswith('@'): continue\n" +
    "        if '::' not in line: continue\n" +
    "        m=re.match(r'^@\\w+ (\\S+) =\\s*([^=≈]+?)\\s*([≈=])\\s*([^:]+?)\\s*::.*$',line)\n" +
    "        if not m: continue\n" +
    "        eid,lhs,sep,rhs=m.groups()\n" +
    "        lhs,rhs=lhs.strip(),rhs.strip()\n" +
    "        try: target=float(lhs)\n" +
    "        except: continue\n" +
    "        total+=1\n" +
    "        rhs_clean=rhs.split(';')[0].strip()\n" +
    "        rhs_clean=re.sub(r'\\s*\\([^)]*\\)\\s*$','',rhs_clean).strip()\n" +
    "        if not rhs_clean: continue\n" +
    "        if any(w in rhs_clean for w in ['근사','불가','misc','none','CONVENTION','EXACT','없음']): continue\n" +
    "        rhs_py=rhs_clean.replace('^','**').replace('²','**2').replace('³','**3')\n" +
    "        if re.search(r'[^\\x00-\\x7f]',rhs_py): continue\n" +
    "        try:\n" +
    "            v=eval(rhs_py,{'__builtins__':{}},ctx)\n" +
    "            if not isinstance(v,(int,float)): continue\n" +
    "            tol=max(0.05*abs(target),0.5)\n" +
    "            if abs(float(v)-target)>tol:\n" +
    "                errs.append((lno,eid,target,rhs_clean,v))\n" +
    "        except: pass\n" +
    "print(f'verifiable: {total}')\n" +
    "print(f'errors: {len(errs)}')\n" +
    "for e in errs:\n" +
    "    print(f'  L{e[0]:5d} {e[1]:45s} claim={e[2]:12.4f} expr={e[3]:30s} computed={e[4]}')\n"

// R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
// Original: python3 -c "<py_script>" <atlas_path> for formula verification
println("=== verify_formulas: " + _ATLAS_PATH + " ===")
let _ = py_script
eprintln("R37/AN13/L3-PY: python3 invocation blocked at verify_formulas.hexa:main. Escalate to user for hexa-native replacement.")
exit(1)
