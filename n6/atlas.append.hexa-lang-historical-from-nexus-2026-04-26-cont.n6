// ── @F formulas — load-balancer / scorer / reduction triad ─────

@F load_balancer_strategies = "{weighted-rr, least-loaded, sticky}" :: hexa_lang_lb [10*]
  => "tool/load_balancer.hexa picks 1 host slug from ranked candidate list."
  => "weighted-rr ─ BRACKET reduction (ternary pruning saturation cutoff). least-loaded ─ ATOMIZE (per-host running-count min). sticky ─ TABLE LOOKUP (fingerprint→last-pick within STICKY_WINDOW_SECONDS)."
  => "State at ~/.hive/resource-lb-state in raw-format DSL (matches .resource family invariant)."
  |> tool/load_balancer.hexa header REDUCTION + STATE FORMAT

@F resource_scorer_reduction = "BRACKET (capability-cut + linear sort)" :: hexa_lang_scorer [10*]
  => "tool/resource_scorer.hexa ranks hosts by capability-bracket pruning + (memory headroom + scoring weight) blend."
  => "Capability check is 'left wall' — fails outright drop. Survivors scored by unimodal blend; total order via linear sort, NOT iterative bracket narrowing."
  => "Future optimization: csv-string capability tokens → string-intern + bitset → bitwise AND (format unchanged)."
  |> tool/resource_scorer.hexa header REDUCTION + LAYOUT INVARIANT

@F spawn_lint_forbidden_idioms = "{nohup &, disown, >/dev/null 2>&1 &, bare &}" :: hexa_lang_orphan_prevention [10*]
  -> plan_b_phase_count
  => "spawn_lint scans .hexa/.sh/.bash for 4 orphan-prone shell idioms."
  => "ERROR: nohup &, disown, H-SILENT (>/dev/null 2>&1 &). WARN: bare trailing &."
  => "Allow per-line via `# spawn_lint: allow` (or `// spawn_lint: allow` for .hexa) with reason."
  => "Exit 1 only on ERROR; WARN does not break CI by default."
  |> tool/spawn_lint.hexa header POLICY

