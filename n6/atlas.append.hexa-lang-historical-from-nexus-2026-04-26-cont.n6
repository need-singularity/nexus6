// ── @P primitives — new architectural anchors ──────────────────

@P plan_b_phase_count = 4 :: hexa_lang_concurrency [11*]
  => "Plan B (structured concurrency + .resource process channel) split into 4 phases, ~1mo rollout."
  => "Phase 1: kind=process channel + lint + reaper. Phase 2: stdlib/proc supervised spawn. Phase 3: codegen defer/scope/spawn AOT emission. Phase 4: spawn_lint forbidden-idiom scanner."
  => "Replaces ad-hoc &-backgrounding which produced 18 vitest orphan workers + hexa_interp orphans + 11h coding-agent leak on 2026-04-25."
  |> stdlib/proc.hexa header + tool/spawn_lint.hexa header

@P resource_kind_taxonomy = "{host, process, channel}" :: hexa_lang_resource [11*]
  => "Three .resource kinds canonized — host (cross-host docker), process (kind=process supervised), channel (channel-prefix dispatch)."
  => "kind=host validates `image` field (resource_lint.hexa). kind=process registers pgid + lease-ttl (default 300s)."
  => "Persistent SSOT in raw-format DSL (NOT JSON) — invariant of .resource family."
  |> tool/resource_lint.hexa + tool/load_balancer.hexa STATE FORMAT

@P darwin_bypass_marker_path = "$HOME/.hx/.darwin-bypass-eligible" :: hexa_lang_resolver [10*]
  => "L1 lossless cycle marker (2026-04-25) — presence stamps Darwin host pre-cleared for direct Mach-O exec on safe argv (--version/--help/lsp)."
  => "Stamped at install time by tool/install_darwin_marker.sh; resolver self-heal at ~/.hx/bin/hexa lines 80-112 retries on first invocation."
  => "Override via $HEXA_DARWIN_MARKER env."
  |> tool/install_darwin_marker.sh L7-L33

@P hexa_runner_image_caps = "cpus=4, mem=4g, debian:12-slim, multi-arch arm64+amd64" :: hexa_lang_landing_pad [11*]
  => "hexa-runner Docker image — single landing pad after Mac jetsam SIGKILL (2026-04-25)."
  => "Hard cap cpus=4/mem=4g — darwin lacks cgroup-equivalent, so Linux container is ONLY safe execution surface."
  => "Built via tool/build_runner_image.hexa from pre-built static musl ELFs at build/hexa_linux_<arch>."
  |> docker/runner/Dockerfile L1-L21 + memory project_mac_hard_landing_policy

// ── @C constants — new tunables / counts ───────────────────────

@C resource_lease_ttl_default_s = 300 :: hexa_lang_resource_supervision [10*]
  <- resource_kind_taxonomy
  => "Default lease-ttl on supervised process spawn = 300s. Owner renews via proc_lease_renew while alive."
  => "Reaper SIGTERMs entries whose lease expired; killpg(pgid) wipes whole worker tree (vitest fanout-safe)."
  |> stdlib/proc.hexa header STRATEGY §

@C tool_attr_set_count = 4 :: hexa_lang_self_attrs [10*]
  => "@tool / @usage / @example / @exit_codes — 4-attr annotation set for tool/*.hexa self-description."
  => "manifest_scan.hexa regex-extracts these into tool/manifest.json; replaces hand-maintained HEXA_TOOLS list in packages/coding-agent/src/core/raw-rules.ts."
  => "First occurrence per script wins; parser does NOT enforce at parse-time (line-comment markers)."
  |> tool/manifest_scan.hexa header SCHEMA + self/attrs/{tool,usage,example,exitcodes}.hexa

@C n_gates_registered_l4_l11 = 8 :: hexa_lang_gate_ladder [10*]
  -> surge_l4, dream_l5, reign_l6, swarm_l7, wake_l8, molt_l9, forge_l10, canon_l11
  => "8 gate commands registered to nexus L_n SSOTs: L4 surge (super-orch) → L5 dream (self-seed) → L6 reign (autonomous) → L7 swarm (ecology) → L8 wake (reality-loop) → L9 molt (self-rewrite) → L10 forge (bootstrap) → L11 canon (transfinite seal)."
  => "Plus omega (L_ω apex). Each registers via cross-repo SSOT pointer to nexus@<sha>."
  |> commits 467c4ffb b36c3037 aba14f59 14fae5f9 7f1be002 15a94918 6e9ed57e aa2b51e7 432f2517

@C raw_omega_saturation_pair = "raw#37 (plan) + raw#38 (impl)" :: hexa_lang_omega_cycle [10*]
  => "Ω-saturation cycle paired enforcement — design doc 'simulation 한계 도달'/'ceiling=X'/'sensitivity 정량' commits MUST be followed by impl evidence (cli/, tool/, .hexa, .json SSOT) in same cycle."
  => "Last commit must include 'omega-saturation:fixpoint' marker. 3-strike: same finding design-only x3 → hard block."
  => "Bypass marker: @allow-design-only-cycle (self/attrs/, future) for guides/post-mortems."
  => "File globs — plan: design/*.md, docs/*.md, *handoff*.md, *_audit*.md / impl: cli/*.hexa, tool/*.{hexa,py}, *_state*.json, atlas/*.n6."
