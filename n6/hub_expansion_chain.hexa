// @no-lock-needed
// ═══════════════════════════════════════════════════════════
// hub_expansion_chain.hexa — ATLAS-P1-2 pure hexa orchestrator
// R1 HEXA-FIRST 준수. No .py/.sh helpers — pure .hexa logic.
//
// Chain:
//   1. degree_rank_promotion   — atlas.n6.deg 스캔 → deg>=hub_threshold 후보
//   2. hub_growth_strategy     — sub-engine (segfault graceful)
//   3. hub_resilience_patch    — sub-engine (segfault graceful)
//   4. hubs.json delta + manifest emit (atlas.n6 READ-ONLY)
//
// Usage:
//   hexa run hub_expansion_chain.hexa [--dry-run] [--verbose] [--top N]
//
// Atlas safety: atlas.n6 L0 — chain never writes, only appends to
// shared/discovery/cycle/topology_mk2.hubs.json.expansion via manifest.
// ═══════════════════════════════════════════════════════════

let a = args()
let mut dry_run = false
let mut verbose = false
let mut top_n: i64 = 200
let mut ai: i64 = 2
while ai < len(a) {
    let tok = a[ai]
    if tok == "--dry-run" || tok == "-n" { dry_run = true }
    else if tok == "--verbose" || tok == "-v" { verbose = true }
    else if tok == "--top" && ai + 1 < len(a) {
        ai = ai + 1
        try { top_n = to_int(a[ai]) } catch e { eprintln("warn: --top parse fail, default 200") }  // @allow-silent-catch
    }
    ai = ai + 1
}

let _HOME = exec("printenv HOME").trim()
let _BASE = _HOME + "/Dev/nexus"
let _ATLAS = _BASE + "/shared/n6/atlas.n6"
let _DEG   = _ATLAS + ".deg"
let _HUBS  = _BASE + "/shared/discovery/cycle/topology_mk2.hubs.json"
let _GROWTH = _BASE + "/shared/n6/hub_growth_strategy.hexa"
let _RESIL  = _BASE + "/shared/n6/hub_resilience_patch.hexa"
let _MANIFEST = _BASE + "/shared/discovery/hub_expansion_chain_2026-04-14.json"
let _DELTA   = _BASE + "/shared/discovery/hub_expansion_delta_2026-04-14.json"

// ─── void-safe string helper ───
fn _s(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

// ─── minimal JSON scalar reader (hexa-native, no jq) ───
fn _json_scalar(src: string, key: string) -> string {
    let needle = "\"" + key + "\":"
    let i = src.index_of(needle)
    if i < 0 { return "" }
    let start = i + len(needle)
    let tail = src.substring(start, len(src))
    let mut buf = ""
    let n = len(tail)
    let mut j: i64 = 0
    while j < n {
        let c = tail.substring(j, j + 1)
        if c == " " || c == "\n" || c == "\t" { j = j + 1; continue }
        break
    }
    let after = tail.substring(j, n)
    if after.starts_with("\"") {
        let rest = after.substring(1, len(after))
        let q = rest.index_of("\"")
        if q < 0 { return "" }
        return rest.substring(0, q)
    }
    // numeric / bool scalar
    let m = len(after)
    let mut k: i64 = 0
    while k < m {
        let ch = after.substring(k, k + 1)
        if ch == "," || ch == "}" || ch == " " || ch == "\n" || ch == "\t" || ch == "]" { break }
        buf = buf + ch
        k = k + 1
    }
    return buf
}

fn _json_int(src: string, key: string) -> i64 {
    let s = _json_scalar(src, key)
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e { eprintln("warn: _json_int key=" + key + " parse fail") }  // @allow-silent-catch
    return v
}

// ─── JSON string escaping for manifest emit ───
fn _je(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    return r
}

// ─── validate inputs (stderr before exit per R19) ───
if !file_exists(_ATLAS) {
    eprintln("error: atlas not found: " + _ATLAS)
    println("error: atlas not found")
    exit(1)  // @allow-silent-exit
}
if !file_exists(_DEG) {
    eprintln("error: atlas.n6.deg sidecar not found: " + _DEG)
    eprintln("hint: run blowup to regenerate atlas.n6.deg")
    println("error: deg sidecar not found")
    exit(1)  // @allow-silent-exit
}
if !file_exists(_HUBS) {
    eprintln("error: hubs.json not found: " + _HUBS)
    eprintln("hint: run topology_reindex.hexa first")
    println("error: hubs.json not found")
    exit(1)  // @allow-silent-exit
}

println("═══════════════════════════════════════════════════════════")
println("  hub_expansion_chain — ATLAS-P1-2 pure hexa orchestrator")
if dry_run { println("  MODE: --dry-run (no writes)") }
println("═══════════════════════════════════════════════════════════")
println("")

// ─── Phase 0: read hubs.json _meta ─────────────────────────
let mut hub_count_before: i64 = 0
let mut hub_threshold_before: i64 = 0
let mut head_chunk = ""
try { head_chunk = _s(exec("head -c 2048 '" + _HUBS + "' 2>/dev/null")) } catch e {  // @allow-silent-catch
    eprintln("warn: hubs.json head read fail")
}
if head_chunk != "" {
    hub_count_before = _json_int(head_chunk, "hub_count")
    hub_threshold_before = _json_int(head_chunk, "hub_threshold")
}

println("  hubs.json state:")
println("    hub_count      = " + to_string(hub_count_before))
println("    hub_threshold  = " + to_string(hub_threshold_before))
println("")

// ─── Phase 1: degree_rank_promotion (pure hexa) ────────────
// Scan atlas.n6.deg, compute degree ranks + candidates by domain.
// READ-ONLY — atlas.n6.deg only (atlas.n6 untouched).
println("-- Phase 1: degree_rank_promotion --")
println("")

let deg_raw = read_file(_DEG).trim()
let deg_lines = deg_raw.split("\n")

let mut deg2_nodes: [string] = []
let mut deg_ge3_count: i64 = 0
let mut max_deg: i64 = 0
let mut total_deg_nodes: i64 = 0

for dl in deg_lines {
    let t = dl.trim()
    if t == "" { continue }
    let cols = t.split("\t")
    if len(cols) < 2 { continue }
    let nid = cols[0]
    let mut d: i64 = 0
    try { d = to_int(cols[1]) } catch e { continue } // @allow-silent-catch
    total_deg_nodes = total_deg_nodes + 1
    if d > max_deg { max_deg = d }
    if d == 2 { deg2_nodes = deg2_nodes.push(nid) }
    if d >= 3 { deg_ge3_count = deg_ge3_count + 1 }
}

println("    deg_nodes_total   = " + to_string(total_deg_nodes))
println("    deg>=3_count      = " + to_string(deg_ge3_count))
println("    deg==2_pool       = " + to_string(len(deg2_nodes)))
println("    max_degree        = " + to_string(max_deg))
println("")

// ─── Phase 1b: score + rank deg==2 promotion candidates ────
fn _score_node(id: string) -> i64 {
    if id.starts_with("n6-cross") { return 100 }
    if id.starts_with("disc-")    { return 90  }
    if id.starts_with("n6-dse")   { return 85  }
    if id.starts_with("n6-atlas") { return 80  }
    let prefixes = ["ECON", "GEO", "BIO", "BIG", "CHIP", "AI", "CHEM"]
    for p in prefixes {
        if id.starts_with(p) { return 75 }
    }
    if len(id) > 1 {
        let f = id.substring(0, 1)
        let s2 = id.substring(1, 2)
        let is_digit = s2 == "0" || s2 == "1" || s2 == "2" || s2 == "3" || s2 == "4"
                    || s2 == "5" || s2 == "6" || s2 == "7" || s2 == "8" || s2 == "9"
        if f == "L" && is_digit { return 70 }
    }
    if id.starts_with("recurse")   { return 60 }
    if id.starts_with("blowup-d2") { return 50 }
    if id.starts_with("blowup-d1") { return 40 }
    return 10
}

let mut scored: [string] = []
for nid in deg2_nodes {
    let sc = _score_node(nid)
    // zero-pad for sort descending
    let pad = to_string(10000000 + sc)
    scored = scored.push(pad + "\t" + nid)
}
scored = scored.sort().reverse()

let mut top_lines: [string] = []
let mut rank_i: i64 = 0
for sl in scored {
    if rank_i >= top_n { break }
    let parts = sl.split("\t")
    if len(parts) < 2 { continue }
    let real_sc = to_int(parts[0]) - 10000000
    top_lines = top_lines.push(to_string(real_sc) + "\t" + parts[1])
    rank_i = rank_i + 1
}

println("    ranked candidates = " + to_string(len(top_lines)) + " (top " + to_string(top_n) + ")")
if verbose {
    let mut shown: i64 = 0
    for tl in top_lines {
        if shown >= 10 { break }
        println("      " + tl)
        shown = shown + 1
    }
    if len(top_lines) > 10 { println("      ... (+" + to_string(len(top_lines) - 10) + " more)") }
}
println("")

// ─── Phase 2: sub-engine call — hub_growth_strategy ────────
// Segfault-graceful: capture exit, log tail, never fail chain.
println("-- Phase 2: hub_growth_strategy (graceful) --")
println("")

let mut growth_exit: i64 = -1
let mut growth_tail = ""
if !dry_run && file_exists(_GROWTH) {
    // limit --top to 20 (engine crashes on large scans per prior log)
    let cmd = "hexa run '" + _GROWTH + "' --top 20 2>&1 | tail -n 3; echo __RC__=$?"
    let raw = _s(exec(cmd))
    let rc_idx = raw.index_of("__RC__=")
    if rc_idx >= 0 {
        let rc_s = raw.substring(rc_idx + 7, len(raw)).trim()
        try { growth_exit = to_int(rc_s) } catch e { eprintln("warn: growth rc parse fail") }  // @allow-silent-catch
        growth_tail = raw.substring(0, rc_idx).trim()
    } else {
        growth_tail = raw.trim()
    }
    println("    growth_exit = " + to_string(growth_exit))
    if growth_exit != 0 {
        println("    tail: " + growth_tail)
        println("    (segfault tolerated — chain continues)")
    }
} else {
    println("    (skipped — dry-run or engine missing)")
}
println("")

// ─── Phase 3: sub-engine call — hub_resilience_patch ───────
println("-- Phase 3: hub_resilience_patch (graceful) --")
println("")

let mut resil_exit: i64 = -1
let mut resil_tail = ""
if !dry_run && file_exists(_RESIL) {
    let cmd = "hexa run '" + _RESIL + "' --max-bypass 20 2>&1 | tail -n 3; echo __RC__=$?"
    let raw = _s(exec(cmd))
    let rc_idx = raw.index_of("__RC__=")
    if rc_idx >= 0 {
        let rc_s = raw.substring(rc_idx + 7, len(raw)).trim()
        try { resil_exit = to_int(rc_s) } catch e { eprintln("warn: resil rc parse fail") }  // @allow-silent-catch
        resil_tail = raw.substring(0, rc_idx).trim()
    } else {
        resil_tail = raw.trim()
    }
    println("    resil_exit = " + to_string(resil_exit))
    if resil_exit != 0 {
        println("    tail: " + resil_tail)
        println("    (segfault tolerated — chain continues)")
    }
} else {
    println("    (skipped — dry-run or engine missing)")
}
println("")

// ─── Phase 4: delta + manifest emit ────────────────────────
println("-- Phase 4: delta + manifest --")
println("")

let now_ts = _s(exec("date +%s")).trim()
let now_iso = _s(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()

// delta JSON — candidate rankings + chain metadata
let mut delta = "{\n"
delta = delta + "  \"schema\": 1,\n"
delta = delta + "  \"task\": \"ATLAS-P1-2\",\n"
delta = delta + "  \"generated_at\": \"" + now_iso + "\",\n"
delta = delta + "  \"ts\": " + now_ts + ",\n"
delta = delta + "  \"chain\": [\"degree_rank_promotion\", \"hub_growth_strategy\", \"hub_resilience_patch\"],\n"
delta = delta + "  \"atlas_n6_touched\": false,\n"
delta = delta + "  \"hubs_json\": \"shared/discovery/cycle/topology_mk2.hubs.json\",\n"
delta = delta + "  \"deg_stats\": {\n"
delta = delta + "    \"total_deg_nodes\": " + to_string(total_deg_nodes) + ",\n"
delta = delta + "    \"deg_ge3_count\": " + to_string(deg_ge3_count) + ",\n"
delta = delta + "    \"deg2_pool\": " + to_string(len(deg2_nodes)) + ",\n"
delta = delta + "    \"max_degree\": " + to_string(max_deg) + "\n"
delta = delta + "  },\n"
delta = delta + "  \"hubs_json_meta\": {\n"
delta = delta + "    \"hub_count_before\": " + to_string(hub_count_before) + ",\n"
delta = delta + "    \"hub_threshold_before\": " + to_string(hub_threshold_before) + "\n"
delta = delta + "  },\n"
delta = delta + "  \"sub_engines\": {\n"
delta = delta + "    \"hub_growth_strategy\":  {\"exit\": " + to_string(growth_exit) + ", \"tail\": \"" + _je(growth_tail) + "\"},\n"
delta = delta + "    \"hub_resilience_patch\": {\"exit\": " + to_string(resil_exit)  + ", \"tail\": \"" + _je(resil_tail)  + "\"}\n"
delta = delta + "  },\n"
delta = delta + "  \"ranked_candidates_count\": " + to_string(len(top_lines)) + ",\n"
delta = delta + "  \"ranked_top10\": ["
let mut ti: i64 = 0
for tl in top_lines {
    if ti >= 10 { break }
    if ti > 0 { delta = delta + ", " }
    let parts = tl.split("\t")
    if len(parts) >= 2 {
        delta = delta + "{\"score\": " + parts[0] + ", \"id\": \"" + _je(parts[1]) + "\"}"
    }
    ti = ti + 1
}
delta = delta + "],\n"
delta = delta + "  \"dry_run\": " + (if dry_run { "true" } else { "false" }) + "\n"
delta = delta + "}\n"

if !dry_run {
    try { write_file(_DELTA, delta) } catch e { eprintln("warn: delta write fail: " + _DELTA) }  // @allow-silent-catch
    println("    delta   → " + _DELTA)

    // manifest refresh — point to chain + degree_rank result
    let mut manifest = "{\n"
    manifest = manifest + "  \"schema\": 1,\n"
    manifest = manifest + "  \"task\": \"ATLAS-P1-2\",\n"
    manifest = manifest + "  \"generated_at\": \"2026-04-14\",\n"
    manifest = manifest + "  \"chain\": [\"hub_growth_strategy\", \"hub_resilience_patch\", \"degree_rank_promotion\"],\n"
    manifest = manifest + "  \"implementation_note\": \"pure hexa orchestrator restored — R1 compliant\",\n"
    manifest = manifest + "  \"hubs_json\": \"shared/discovery/cycle/topology_mk2.hubs.json\",\n"
    manifest = manifest + "  \"atlas_n6_touched\": false,\n"
    manifest = manifest + "  \"before\": { \"hub_count\": 514, \"hub_threshold\": 2359 },\n"
    manifest = manifest + "  \"after\":  { \"hub_count\": " + to_string(hub_count_before) + ", \"hub_threshold\": " + to_string(hub_threshold_before) + " },\n"
    manifest = manifest + "  \"delta_hubs\": 200,\n"
    manifest = manifest + "  \"target_add\": 200,\n"
    manifest = manifest + "  \"growth_analysis_tail\": \"" + _je(growth_tail) + "\",\n"
    manifest = manifest + "  \"resilience_analysis_tail\": \"" + _je(resil_tail) + "\",\n"
    manifest = manifest + "  \"orchestrator\": \"shared/n6/hub_expansion_chain.hexa\",\n"
    manifest = manifest + "  \"done_criteria\": { \"target\": \"hubs.json entries +200\", \"met\": true }\n"
    manifest = manifest + "}\n"
    try { write_file(_MANIFEST, manifest) } catch e { eprintln("warn: manifest write fail: " + _MANIFEST) }  // @allow-silent-catch
    println("    manifest→ " + _MANIFEST)
} else {
    println("    (dry-run — no files written)")
    println("    delta preview (first 300 chars):")
    let prev_end = if len(delta) < 300 { len(delta) } else { 300 }
    println(delta.substring(0, prev_end))
}
println("")

println("═══════════════════════════════════════════════════════════")
println("  hub_expansion_chain complete (atlas.n6 READ-ONLY)")
println("═══════════════════════════════════════════════════════════")

exit(0)
