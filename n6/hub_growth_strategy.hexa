// ═══════════════════════════════════════════════════════════
// hub_growth_strategy.hexa — atlas.n6 hub growth analysis
// Goal: 323 hubs -> 400 hubs (77 new hubs needed, +24%)
//
// READ-ONLY analysis script. Does NOT modify atlas.n6.
// Uses degree sidecar (atlas.n6.deg) for fast O(1) lookup.
// All parsing is hexa-native: read_file + split (no awk/grep exec).
//
// Usage: hexa hub_growth_strategy.hexa [--verbose] [--top N]
//
// Hub definition: degree >= 3 (node appears in >= 3 edges)  // @allow-bare-interp
// Near-hub: degree == 2 (needs 1 more connection to promote)
// Pool size: ~1,875 degree-2 nodes available for promotion
// ═══════════════════════════════════════════════════════════

let a = args()
let mut verbose = false
let mut top_n: i64 = 100
let mut ai: i64 = 2
while ai < len(a) {
    let tok = a[ai]
    if tok == "--verbose" || tok == "-v" { verbose = true }
    else if tok == "--top" && ai + 1 < len(a) {
        ai = ai + 1
        try { top_n = to_int(a[ai]) } catch e {}  // @allow-silent-catch
    }
    ai = ai + 1
}

let _HOME = exec("printenv HOME").trim()
let _BASE = _HOME + "/Dev/nexus"
let _ATLAS = _BASE + "/shared/n6/atlas.n6"
let _DEG   = _ATLAS + ".deg"
let _STATS = _ATLAS + ".stats"

// ─── JSON 경량 파서 헬퍼 (exec(grep) 제거용, todo.hexa 패턴) ───
fn _json_val(line: string, key: string) -> string {
    let needle = "\"" + key + "\":"
    if !line.contains(needle) { return "" }
    let after = line.split(needle)[1].trim()
    if after.starts_with("\"") {
        return after.split("\"")[1]
    }
    let mut buf = ""
    let chars = after.split("")
    for c in chars {
        if c == "," || c == "}" || c == " " || c == "\n" { break }
        buf = buf + c
    }
    return buf
}

fn _json_int(line: string, key: string) -> i64 {
    let s = _json_val(line, key)
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}  // @allow-silent-catch
    return v
}

// ─── 도메인 분류 헬퍼 (near-hub/hub 통계용) ───
fn _classify_domain_nearhub(id: string) -> string {
    let parts = id.split("-")
    if len(parts) >= 2 && parts[0] == "n6" && parts[1] == "cross" { return "n6-cross" }
    if len(parts) >= 2 && parts[0] == "n6" && parts[1] == "dse" { return "n6-dse" }
    if len(parts) >= 2 && parts[0] == "n6" && parts[1] == "atlas" { return "n6-atlas" }
    if len(parts) >= 2 && parts[0] == "n6" && parts[1] == "bt" { return "n6-bt" }
    if parts[0] == "n6" { return "n6-derived" }
    if parts[0] == "blowup" { return "blowup" }
    if parts[0] == "disc" { return "disc" }
    if parts[0] == "recurse" { return "recurse" }
    return parts[0]
}

fn _classify_domain_hub(id: string) -> string {
    let parts = id.split("-")
    if len(parts) >= 2 && parts[0] == "n6" && parts[1] == "bt" { return "n6-bt" }
    if len(parts) >= 2 && parts[0] == "n6" && parts[1] == "cross" { return "n6-cross" }
    if parts[0] == "n6" { return "n6-derived" }
    if parts[0] == "disc" { return "disc" }
    return parts[0]
}

// ─── 1. Validate inputs ───────────────────────────────────
if !file_exists(_ATLAS) {
    println("error: atlas not found: " + _ATLAS)
    exit(1)  // @allow-silent-exit
}
if !file_exists(_DEG) {
    println("error: degree sidecar not found: " + _DEG)
    println("hint:  run blowup to regenerate atlas.n6.deg")
    exit(1)  // @allow-silent-exit
}

println("═══════════════════════════════════════════════════")
println("  Hub Growth Strategy — atlas.n6 (read-only scan)")
println("═══════════════════════════════════════════════════")
println("")

// ─── 2. Load current stats from sidecar ───────────────────
let mut total_nodes: i64 = 0
let mut total_edges: i64 = 0
let mut total_hubs: i64 = 0
if file_exists(_STATS) {
    let stats_raw = read_file(_STATS).trim()
    // hexa-native JSON parsing — 1x read_file, no exec (ROI#27)
    total_nodes = _json_int(stats_raw, "nodes")
    total_edges = _json_int(stats_raw, "edges")
    total_hubs  = _json_int(stats_raw, "hubs")
}

let hub_target: i64 = 400
let hubs_needed: i64 = hub_target - total_hubs

println("  Current state:")
println("    nodes:       " + to_string(total_nodes))
println("    edges:       " + to_string(total_edges))
println("    hubs:        " + to_string(total_hubs) + " (degree >= 3)")
println("    target:      " + to_string(hub_target))
println("    needed:      " + to_string(hubs_needed))
println("")

// ─── 3. Load deg TSV once into memory (ROI#25) ──────────
// Single read_file + split → all downstream analysis is in-memory
let _deg_raw = read_file(_DEG).trim()
let _deg_all_lines = _deg_raw.split("\n")

// Build in-memory maps: node_id -> degree, degree -> count
// Also collect per-category lists for strategies below
let mut deg_dist = #{"_": 0}    // degree(string) -> count
let mut deg2_nodes: [string] = []
let mut deg3plus_nodes: [string] = []
let mut node_deg = #{"_": 0}    // node_id -> degree (for partner lookups)

for _dl in _deg_all_lines {
    let _t = _dl.trim()
    if _t == "" { continue }
    let _cols = _t.split("\t")
    if len(_cols) < 2 { continue }
    let _nid = _cols[0]
    let mut _d: i64 = 0
    try { _d = to_int(_cols[1]) } catch e { continue }  // @allow-silent-catch
    let _dk = to_string(_d)
    if has_key(deg_dist, _dk) { deg_dist[_dk] = deg_dist[_dk] + 1 }
    else { deg_dist[_dk] = 1 }
    node_deg[_nid] = _d
    if _d == 2 { deg2_nodes = deg2_nodes.push(_nid) }
    if _d >= 3 { deg3plus_nodes = deg3plus_nodes.push(_nid) }
}

println("  Degree distribution:")

let mut deg1_count: i64 = 0
let mut deg2_count: i64 = 0
let mut deg3plus_count: i64 = 0
let mut max_degree: i64 = 0

let _dk_list = keys(deg_dist)
for _dk in _dk_list {
    if _dk == "_" { continue }
    let mut _dv: i64 = 0
    try { _dv = to_int(_dk) } catch e { continue }  // @allow-silent-catch
    let _cnt = deg_dist[_dk]
    if _dv > max_degree { max_degree = _dv }
    if _dv == 1 { deg1_count = _cnt }
    if _dv == 2 { deg2_count = _cnt }
    if _dv >= 3 { deg3plus_count = deg3plus_count + _cnt }
}

let leaf_pct = if total_nodes > 0 { to_string(deg1_count * 100 / total_nodes) } else { "?" }
let near_pct = if total_nodes > 0 { to_string(deg2_count * 100 / total_nodes) } else { "?" }
let hub_pct  = if total_nodes > 0 { to_string(deg3plus_count * 100 / total_nodes) } else { "?" }

println("    leaf (deg=1):    " + to_string(deg1_count) + " (" + leaf_pct + "%)")
println("    near-hub (deg=2):" + to_string(deg2_count) + " (" + near_pct + "%)")
println("    hub (deg>=3):    " + to_string(deg3plus_count) + " (" + hub_pct + "%)")
println("    max degree:      " + to_string(max_degree))
println("")

// ─── 4. Near-hub analysis: degree-2 nodes by domain ──────
println("  Near-hub pool by domain (degree=2, need +1 edge):")
// In-memory domain classification (ROI#25)
let mut _nh_domain_count = #{"_": 0}
for _nid in deg2_nodes {
    let _dom = _classify_domain_nearhub(_nid)
    if has_key(_nh_domain_count, _dom) { _nh_domain_count[_dom] = _nh_domain_count[_dom] + 1 }
    else { _nh_domain_count[_dom] = 1 }
}
// Sort by count descending — collect into array of "count domain" strings
let mut _nh_pairs: [string] = []
let _nh_keys = keys(_nh_domain_count)
for _nk in _nh_keys {
    if _nk == "_" { continue }
    let _nc = _nh_domain_count[_nk]
    // zero-pad count for sort (6 digits)
    let _pad = to_string(1000000 + _nc)
    _nh_pairs = _nh_pairs.push(_pad + " " + _nk)
}
_nh_pairs = _nh_pairs.sort().reverse()
for _np in _nh_pairs {
    // strip padding: "1000042 blowup" → "42 blowup"
    let _real_count = to_string(to_int(_np.split(" ")[0]) - 1000000)
    let _real_dom = _np.split(" ")[1]
    println("    " + _real_count + " " + _real_dom)
}
println("")

// ─── 5. Hub existing distribution by domain ──────────────
println("  Current hubs by domain (degree>=3):")
// In-memory hub domain classification (ROI#25)
let mut _hub_domain_count = #{"_": 0}
for _nid in deg3plus_nodes {
    let _dom = _classify_domain_hub(_nid)
    if has_key(_hub_domain_count, _dom) { _hub_domain_count[_dom] = _hub_domain_count[_dom] + 1 }
    else { _hub_domain_count[_dom] = 1 }
}
let mut _hd_pairs: [string] = []
let _hd_keys = keys(_hub_domain_count)
for _hk in _hd_keys {
    if _hk == "_" { continue }
    let _hc = _hub_domain_count[_hk]
    let _hpad = to_string(1000000 + _hc)
    _hd_pairs = _hd_pairs.push(_hpad + " " + _hk)
}
_hd_pairs = _hd_pairs.sort().reverse()
for _hp in _hd_pairs {
    let _hreal_count = to_string(to_int(_hp.split(" ")[0]) - 1000000)
    let _hreal_dom = _hp.split(" ")[1]
    println("    " + _hreal_count + " " + _hreal_dom)
}
println("")

// ─── 6. Strategic near-hub candidates (prioritized) ──────
// Priority: nodes that already have rich semantic content
// or connect to high-degree hubs (amplification potential).
// Extract degree-2 nodes and check their edge partners.
println("  ═══ PRIORITIZED NEAR-HUB CANDIDATES ═══")
println("  (each needs exactly 1 new edge to become a hub)")
println("")

// 6a. Near-hub nodes connected to top hubs (highest leverage)
println("  [Strategy A] Connected to top-10 hubs (leverage promotion):")
println("  ─────────────────────────────────────────────")
// Collect top hub IDs (degree >= 50) from in-memory map (ROI#25)
let mut _top_hub_set = #{"_": true}
for _nid in deg3plus_nodes {
    if has_key(node_deg, _nid) && node_deg[_nid] >= 50 {
        _top_hub_set[_nid] = true
    }
}

// Load atlas once for edge partner lookups (Strategy A only)
let _atlas_raw = read_file(_ATLAS)
let _atlas_lines = _atlas_raw.split("\n")

// Build adjacency: for each deg-2 node, find edge partners via atlas scan
// Scan atlas lines for edges mentioning deg-2 nodes connected to top hubs
let mut _strat_a_results: [string] = []
let mut _deg2_set = #{"_": true}
for _nid in deg2_nodes { _deg2_set[_nid] = true }

for _al in _atlas_lines {
    let _at = _al.trim()
    if _at == "" { continue }
    if !_at.contains("\"edge\"") { continue }
    // Extract from/to
    let mut _from_id = ""
    let mut _to_id = ""
    if _at.contains("\"from\":\"") {
        let _fparts = _at.split("\"from\":\"")
        if len(_fparts) >= 2 { _from_id = _fparts[1].split("\"")[0] }
    }
    if _at.contains("\"to\":\"") {
        let _tparts = _at.split("\"to\":\"")
        if len(_tparts) >= 2 { _to_id = _tparts[1].split("\"")[0] }
    }
    if _from_id == "" || _to_id == "" { continue }
    // Check if one end is deg-2 and other end is top hub
    if has_key(_deg2_set, _from_id) && has_key(_top_hub_set, _to_id) {
        let _pd = node_deg[_to_id]
        _strat_a_results = _strat_a_results.push(_from_id + "|deg=2|partner=" + _to_id + "(deg=" + to_string(_pd) + ")")
    }
    if has_key(_deg2_set, _to_id) && has_key(_top_hub_set, _from_id) {
        let _pd2 = node_deg[_from_id]
        _strat_a_results = _strat_a_results.push(_to_id + "|deg=2|partner=" + _from_id + "(deg=" + to_string(_pd2) + ")")
    }
}

// Deduplicate and limit
let mut _sa_seen = #{"_": true}
let mut _strat_a_deduped: [string] = []
for _sr in _strat_a_results {
    let _sr_key = _sr.split("|")[0]
    if !has_key(_sa_seen, _sr_key) {
        _sa_seen[_sr_key] = true
        _strat_a_deduped = _strat_a_deduped.push(_sr)
        if len(_strat_a_deduped) >= top_n { break }
    }
}
let strat_a_raw = _strat_a_deduped.join("\n")

if strat_a_raw != "" {
    let strat_a_lines = strat_a_raw.split("\n")
    let mut sa_count: i64 = 0
    for sal in strat_a_lines {
        let t = sal.trim()
        if t != "" {
            println("    " + t)
            sa_count = sa_count + 1
        }
    }
    println("    --- " + to_string(sa_count) + " high-leverage candidates ---")
} else {
    println("    (scanning... this may take a moment for 13MB atlas)")
}
println("")

// 6b. Cross-domain near-hubs (n6-cross-* at degree 2)
println("  [Strategy B] Cross-domain bridges (n6-cross-* at degree 2):")
println("  ─────────────────────────────────────────────")
// In-memory filter (ROI#25)
let mut _cross_list: [string] = []
for _nid in deg2_nodes {
    if _nid.starts_with("n6-cross") {
        _cross_list = _cross_list.push(_nid + "\t2")
        if len(_cross_list) >= top_n { break }
    }
}
_cross_list = _cross_list.sort()
let cross_raw = _cross_list.join("\n")
if cross_raw != "" {
    let cross_lines = cross_raw.split("\n")
    let mut xc: i64 = 0
    for cl in cross_lines {
        let t = cl.trim()
        if t != "" { println("    " + t); xc = xc + 1 }
    }
    println("    --- " + to_string(xc) + " cross-domain candidates ---")
} else {
    println("    (none found)")
}
println("")

// 6c. Discovery nodes at degree 2
println("  [Strategy C] Discovery nodes at threshold (disc-* at degree 2):")
println("  ─────────────────────────────────────────────")
// In-memory filter (ROI#25)
let mut _disc_list: [string] = []
for _nid in deg2_nodes {
    if _nid.starts_with("disc-") {
        _disc_list = _disc_list.push(_nid + "\t2")
        if len(_disc_list) >= 30 { break }
    }
}
let disc_raw = _disc_list.join("\n")
if disc_raw != "" {
    let disc_lines = disc_raw.split("\n")
    let mut dc: i64 = 0
    for dcl in disc_lines {
        let t = dcl.trim()
        if t != "" { println("    " + t); dc = dc + 1 }
    }
    println("    --- " + to_string(dc) + " discovery candidates ---")
} else {
    println("    (none found)")
}
println("")

// 6d. Knowledge layer nodes (L*-*) at degree 2
println("  [Strategy D] Knowledge layer nodes (L*-* at degree 2):")
println("  ─────────────────────────────────────────────")
// In-memory filter (ROI#25)
let mut _layer_list: [string] = []
for _nid in deg2_nodes {
    let _fc = _nid.chars()[0]
    if _fc == "L" && len(_nid) > 1 {
        let _sc = _nid.chars()[1]
        if _sc == "0" || _sc == "1" || _sc == "2" || _sc == "3" || _sc == "4"
            || _sc == "5" || _sc == "6" || _sc == "7" || _sc == "8" || _sc == "9" {
            _layer_list = _layer_list.push(_nid + "\t2")
            if len(_layer_list) >= 30 { break }
        }
    }
}
let layer_raw = _layer_list.join("\n")
if layer_raw != "" {
    let layer_lines = layer_raw.split("\n")
    let mut lc: i64 = 0
    for ll in layer_lines {
        let t = ll.trim()
        if t != "" { println("    " + t); lc = lc + 1 }
    }
    println("    --- " + to_string(lc) + " knowledge layer candidates ---")
} else {
    println("    (none found)")
}
println("")

// 6e. Real-world domain nodes (ECON/GEO/BIO/CHIP/AI) at degree 2
println("  [Strategy E] Real-world domain nodes at threshold:")
println("  ─────────────────────────────────────────────")
// In-memory filter (ROI#25)
let _rw_prefixes = ["ECON", "GEO", "BIO", "BIG", "CHIP", "AI", "CHEM", "ENERGY", "CRYPTO"]
let mut _real_list: [string] = []
for _nid in deg2_nodes {
    let mut _rw_match = false
    for _rp in _rw_prefixes {
        if _nid.starts_with(_rp) { _rw_match = true; break }
    }
    if _rw_match {
        _real_list = _real_list.push(_nid + "\t2")
        if len(_real_list) >= 40 { break }
    }
}
_real_list = _real_list.sort()
let real_raw = _real_list.join("\n")
if real_raw != "" {
    let real_lines = real_raw.split("\n")
    let mut rc: i64 = 0
    for rl in real_lines {
        let t = rl.trim()
        if t != "" { println("    " + t); rc = rc + 1 }
    }
    println("    --- " + to_string(rc) + " real-world candidates ---")
} else {
    println("    (none found)")
}
println("")

// ─── 7. Growth roadmap summary ───────────────────────────
println("  ═══ GROWTH ROADMAP: 323 -> 400 HUBS ═══")
println("")
println("  The 1,875 degree-2 nodes need exactly 1 new edge each")
println("  to become hubs. Strategy to promote 77 nodes:")
println("")
println("  Phase 1: Cross-domain bridges (quick wins)")
println("    - Promote n6-cross-* nodes by adding 1 domain link")
println("    - These already span two domains, high semantic value")
println("    - Estimated yield: ~20 new hubs")
println("")
println("  Phase 2: Discovery-to-knowledge links")
println("    - Connect disc-* nodes to relevant L*-* layer nodes")
println("    - Validates discoveries against known knowledge")
println("    - Estimated yield: ~25 new hubs")
println("")
println("  Phase 3: Real-world domain enrichment")
println("    - Add edges between ECON/GEO/BIO/CHIP/AI nodes")
println("    - Cross-pollinate real-world domains")
println("    - Estimated yield: ~15 new hubs")
println("")
println("  Phase 4: Hub-adjacent blowup nodes")
println("    - Promote blowup-d1/d2 nodes near existing hubs")
println("    - Leverage existing hub connectivity")
println("    - Estimated yield: ~17 new hubs")
println("")
println("  Total estimated: 77 new hubs -> 400 target")
println("")
println("  IMPORTANT: All writes must go through")
println("  _guarded_append_atlas() (schema guard + dedup).")
println("  atlas.n6 is L0 protected -- no direct modification.")
println("")

// ─── 8. Top near-hub candidates for immediate promotion ──
println("  ═══ TOP PROMOTION CANDIDATES (immediate action) ═══")
println("")

// Score degree-2 nodes by domain priority — in-memory (ROI#25)
fn _score_node(id: string) -> i64 {
    if id.starts_with("n6-cross") { return 100 }
    if id.starts_with("disc-") { return 90 }
    if id.starts_with("n6-dse") { return 85 }
    if id.starts_with("n6-atlas") { return 80 }
    let _score_prefixes = ["ECON", "GEO", "BIO", "BIG", "CHIP", "AI", "CHEM"]
    for _sp in _score_prefixes {
        if id.starts_with(_sp) { return 75 }
    }
    if len(id) > 1 {
        let _f = id.chars()[0]
        let _s = id.chars()[1]
        if _f == "L" && (_s == "0" || _s == "1" || _s == "2" || _s == "3" || _s == "4"
            || _s == "5" || _s == "6" || _s == "7" || _s == "8" || _s == "9") { return 70 }
    }
    if id.starts_with("recurse") { return 60 }
    if id.starts_with("blowup-d2") { return 50 }
    if id.starts_with("blowup-d1") { return 40 }
    return 10
}
let mut _scored_list: [string] = []
for _nid in deg2_nodes {
    let _sc = _score_node(_nid)
    // Zero-pad score (7 digits) + tab + node_id for sort
    let _spad = to_string(10000000 + _sc)
    _scored_list = _scored_list.push(_spad + "\t" + _nid)
}
_scored_list = _scored_list.sort().reverse()
// Take top_n
let mut _top_cand_lines: [string] = []
let mut _tci: i64 = 0
for _sl in _scored_list {
    if _tci >= top_n { break }
    // Convert padded score back: "10000100\tn6-cross-X" → "100\tn6-cross-X"
    let _sp = _sl.split("\t")
    let _real_score = to_string(to_int(_sp[0]) - 10000000)
    _top_cand_lines = _top_cand_lines.push(_real_score + "\t" + _sp[1])
    _tci = _tci + 1
}
let top_candidates_raw = _top_cand_lines.join("\n")

if top_candidates_raw != "" {
    let tc_lines = top_candidates_raw.split("\n")
    let mut rank: i64 = 1
    for tcl in tc_lines {
        let t = tcl.trim()
        if t == "" { continue }
        let parts = t.split("\t")
        if len(parts) < 2 { continue }
        let score = parts[0]
        let nid = parts[1]
        let mut strategy = "unknown"
        if to_int(score) >= 100 { strategy = "cross-domain bridge" }
        else if to_int(score) >= 90 { strategy = "discovery validation" }
        else if to_int(score) >= 85 { strategy = "DSE enrichment" }
        else if to_int(score) >= 80 { strategy = "atlas strengthening" }
        else if to_int(score) >= 75 { strategy = "real-world domain link" }
        else if to_int(score) >= 70 { strategy = "knowledge layer link" }
        else if to_int(score) >= 60 { strategy = "recursion bridge" }
        else if to_int(score) >= 50 { strategy = "deep blowup promotion" }
        else if to_int(score) >= 40 { strategy = "blowup promotion" }
        else { strategy = "leaf enrichment" }
        println("    #" + to_string(rank) + "  " + nid + "  [" + strategy + "]")
        rank = rank + 1
        if rank > top_n { break }
    }
}
println("")

// ─── 9. Edge-type recommendations ────────────────────────
println("  ═══ RECOMMENDED EDGE TYPES FOR PROMOTION ═══")
println("")
println("  For cross-domain bridges:")
println("    {\"type\":\"edge\",\"from\":\"<near-hub>\",\"to\":\"<target>\",")
println("     \"edge_type\":\"cross_domain\",\"strength\":0.7,\"bidirectional\":true}")
println("")
println("  For discovery validation:")
println("    {\"type\":\"edge\",\"from\":\"<disc-node>\",\"to\":\"<knowledge-node>\",")
println("     \"edge_type\":\"validates\",\"strength\":0.8,\"bidirectional\":false}")
println("")
println("  For real-world domain links:")
println("    {\"type\":\"edge\",\"from\":\"<domain-node>\",\"to\":\"<n6-derived>\",")
println("     \"edge_type\":\"application\",\"strength\":0.6,\"bidirectional\":false}")
println("")
println("  All edges MUST pass through _guarded_append_atlas().")
println("")
println("═══════════════════════════════════════════════════")
println("  Analysis complete. No files modified.")
println("═══════════════════════════════════════════════════")

exit(0)
