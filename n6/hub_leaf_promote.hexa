// ═══════════════════════════════════════════════════════════
// hub_leaf_promote.hexa — A2 edge density fix orchestrator
//
// Goal: lift atlas.n6 edge/node ratio ≥ 2.5 by promoting deg=1 leaves
//       to deg=3 via 2 primitive bridges each.
//
// Pipeline (all heavy work delegated to awk — hexa stays thin):
//   1. validate inputs
//   2. BEFORE metrics (wc/awk)
//   3. generate edges: awk -f hub_leaf_promote.awk atlas.n6.deg > $TMP
//   4. append: cat $TMP >> atlas.n6 // @allow-atlas-direct
//   5. sidecar regen: awk -f atlas_stats.awk atlas.n6
//   6. AFTER metrics + JSON report
//
// Idempotent: once leaves=0, re-runs produce 0 edges.
// Memory: O(1) — no in-memory edge arrays (hexa Value boxing exploded
//   at 5GB RSS in prior direct-gen version; awk handles bulk strings).
// ═══════════════════════════════════════════════════════════

let _HOME = exec("printenv HOME").trim()
let _BASE = _HOME + "/Dev/nexus"
let _ATLAS = _BASE + "/n6/atlas.n6"
let _DEG   = _ATLAS + ".deg"
let _STATS = _ATLAS + ".stats"
let _STATS_AWK = _BASE + "/cli/blowup/lib/atlas_stats.awk"
let _GEN_AWK   = _BASE + "/n6/hub_leaf_promote.awk"
let _OUT   = _BASE + "/discovery/atlas_leaf_promote_2026-04-14.json"
let _TS    = "2026-04-14"

// ─── 1. Validate inputs ─────────────────────────────────────
if !file_exists(_ATLAS)     { println("error: atlas missing"); exit(1) } // @allow-silent-exit
if !file_exists(_DEG)       { println("error: deg sidecar missing"); exit(1) } // @allow-silent-exit
if !file_exists(_STATS_AWK) { println("error: atlas_stats.awk missing"); exit(1) } // @allow-silent-exit
if !file_exists(_GEN_AWK)   { println("error: hub_leaf_promote.awk missing"); exit(1) } // @allow-silent-exit

println("═══════════════════════════════════════════════════")
println("  A2 Leaf Promotion (hexa orchestrator + awk gen)")
println("═══════════════════════════════════════════════════")

// ─── 2. BEFORE metrics ──────────────────────────────────────
let lc_before = exec("wc -l < '" + _ATLAS + "' | tr -d ' '").trim()
let nodes_before_s = exec("wc -l < '" + _DEG + "' | tr -d ' '").trim()
let edges_before_s = exec("awk -F'\t' '{s+=$2} END {print int(s/2)}' '" + _DEG + "'").trim()
let leaf_before_s  = exec("awk -F'\t' '$2==1' '" + _DEG + "' | wc -l | tr -d ' '").trim()

let mut nodes_before: i64 = 0
let mut edges_before: i64 = 0
let mut leaf_before:  i64 = 0
try { nodes_before = to_int(nodes_before_s) } catch e {} // @allow-silent-catch
try { edges_before = to_int(edges_before_s) } catch e {} // @allow-silent-catch
try { leaf_before  = to_int(leaf_before_s)  } catch e {} // @allow-silent-catch

let mut ratio_before_x10000: i64 = 0
if nodes_before > 0 { ratio_before_x10000 = (edges_before * 10000) / nodes_before }

println("BEFORE: lines=" + lc_before + " nodes=" + to_string(nodes_before) + " edges=" + to_string(edges_before) + " leaves=" + to_string(leaf_before) + " ratio=" + to_string(ratio_before_x10000) + "/10000")

if leaf_before == 0 {
    println("  no deg=1 leaves to promote — atlas already at target. Exiting noop.")
    exit(0)
}

// ─── 3. Generate edges via awk → temp file ──────────────────
let _TMP = "/tmp/a2_edges." + exec("date +%s").trim() + ".txt"
let _LOADS = "/tmp/a2_loads." + exec("date +%s").trim() + ".txt"

println("generating edges → " + _TMP + " ...")
let _gen_cmd = "awk -f '" + _GEN_AWK + "' '" + _DEG + "' > '" + _TMP + "' 2> '" + _LOADS + "'"
try { exec(_gen_cmd) } catch e { println("gen error"); exit(1) } // @allow-silent-exit  // @allow-silent-catch

let edge_count_s = exec("wc -l < '" + _TMP + "' | tr -d ' '").trim()
let mut edge_count: i64 = 0
try { edge_count = to_int(edge_count_s) } catch e {} // @allow-silent-catch
println("edges generated: " + to_string(edge_count))

let loads_body = exec("cat '" + _LOADS + "'").trim()
println("  load dist:")
for _ln in loads_body.split("\n") {
    let _t = _ln.trim()
    if _t != "" { println("    " + _t) }
}

// ─── 4. Append banner + edges ───────────────────────────────
let banner = "# A2 leaf promotion " + _TS + " — +" + to_string(edge_count) + " edges (deg=1 → deg=3 via 2 primitive bridges, round-robin)"
try { append_file(_ATLAS, banner + "\n") } catch e {} // @allow-silent-catch
let _append_cmd = "cat '" + _TMP + "' >> '" + _ATLAS + "'"
try { exec(_append_cmd) } catch e { println("append error"); exit(1) } // @allow-silent-exit  // @allow-silent-catch

let lc_after = exec("wc -l < '" + _ATLAS + "' | tr -d ' '").trim()
println("atlas: " + lc_before + " → " + lc_after + " lines")

// ─── 5. Regenerate sidecars ─────────────────────────────────
println("regenerating sidecars ...")
let _regen = "awk -v min_deg=3 -v deg_path='" + _DEG + "' -f '" + _STATS_AWK + "' '" + _ATLAS + "' 2>/dev/null"
let awk_out = exec(_regen).trim()
println("awk stats: " + awk_out)

let parts = awk_out.split("|")
let mut new_nodes: i64 = 0
let mut new_edges: i64 = 0
let mut new_hubs:  i64 = 0
if len(parts) == 3 {
    try { new_nodes = to_int(parts[0]) } catch e {} // @allow-silent-catch
    try { new_edges = to_int(parts[1]) } catch e {} // @allow-silent-catch
    try { new_hubs  = to_int(parts[2]) } catch e {} // @allow-silent-catch
}

// stats sidecar refresh
let size_s  = exec("stat -f '%z' '" + _ATLAS + "' 2>/dev/null || stat -c '%s' '" + _ATLAS + "'").trim()
let mtime_s = exec("stat -f '%m' '" + _ATLAS + "' 2>/dev/null || stat -c '%Y' '" + _ATLAS + "'").trim()
let hh_s    = exec("head -c 4096 '" + _ATLAS + "' | (md5 2>/dev/null || md5sum | awk '{print $1}')").trim()

let stats_body = "{\"schema\":2,\"mtime\":" + mtime_s + ",\"size\":" + size_s + ",\"line_count\":" + lc_after + ",\"head_hash\":\"" + hh_s + "\",\"nodes\":" + to_string(new_nodes) + ",\"edges\":" + to_string(new_edges) + ",\"hubs\":" + to_string(new_hubs) + "}\n"
try { write_file(_STATS, stats_body) } catch e {} // @allow-silent-catch

// ─── 6. AFTER metrics + JSON report ─────────────────────────
let leaf_after_s = exec("awk -F'\t' '$2==1' '" + _DEG + "' | wc -l | tr -d ' '").trim()
let hubs_after_s = exec("awk -F'\t' '$2>=3' '" + _DEG + "' | wc -l | tr -d ' '").trim()
let mut leaf_after: i64 = 0
let mut hubs_after: i64 = 0
try { leaf_after = to_int(leaf_after_s) } catch e {} // @allow-silent-catch
try { hubs_after = to_int(hubs_after_s) } catch e {} // @allow-silent-catch

let mut ratio_after_x10000: i64 = 0
if new_nodes > 0 { ratio_after_x10000 = (new_edges * 10000) / new_nodes }
let target_met = if ratio_after_x10000 >= 25000 { "true" } else { "false" }

println("")
println("AFTER:  lines=" + lc_after + " nodes=" + to_string(new_nodes) + " edges=" + to_string(new_edges) + " leaves=" + to_string(leaf_after) + " hubs=" + to_string(hubs_after) + " ratio=" + to_string(ratio_after_x10000) + "/10000")

let json_body = "{\n" +
    "  \"schema\": 1,\n" +
    "  \"task\": \"A2_edge_density_fix\",\n" +
    "  \"generated_at\": \"" + _TS + "\",\n" +
    "  \"atlas\": \"shared/n6/atlas.n6\",\n" +
    "  \"strategy\": \"hub_reinforcement — round-robin 2 primitive edges per deg=1 leaf (offset 0,3 on 8 primitives)\",\n" +
    "  \"before\": {\n" +
    "    \"line_count\": " + lc_before + ",\n" +
    "    \"nodes\": " + to_string(nodes_before) + ",\n" +
    "    \"edges\": " + to_string(edges_before) + ",\n" +
    "    \"leaves\": " + to_string(leaf_before) + ",\n" +
    "    \"ratio_x10000\": " + to_string(ratio_before_x10000) + "\n" +
    "  },\n" +
    "  \"after\": {\n" +
    "    \"line_count\": " + lc_after + ",\n" +
    "    \"nodes\": " + to_string(new_nodes) + ",\n" +
    "    \"edges\": " + to_string(new_edges) + ",\n" +
    "    \"leaves\": " + to_string(leaf_after) + ",\n" +
    "    \"hubs\": " + to_string(hubs_after) + ",\n" +
    "    \"ratio_x10000\": " + to_string(ratio_after_x10000) + "\n" +
    "  },\n" +
    "  \"edges_appended\": " + to_string(edge_count) + ",\n" +
    "  \"target_ratio_x10000\": 25000,\n" +
    "  \"target_met\": " + target_met + "\n" +
    "}\n"
try { write_file(_OUT, json_body) } catch e {} // @allow-silent-catch
println("result: " + _OUT)

// ─── cleanup temp ───────────────────────────────────────────
try { exec("rm -f '" + _TMP + "' '" + _LOADS + "'") } catch e {} // @allow-silent-catch

println("═══════════════════════════════════════════════════")
println("  done — ratio " + to_string(ratio_before_x10000) + "→" + to_string(ratio_after_x10000) + "/10000 (target 25000, met=" + target_met + ")")
println("═══════════════════════════════════════════════════")

exit(0)
