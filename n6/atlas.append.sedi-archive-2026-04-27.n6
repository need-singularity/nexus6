@X SEDI-AR-verdict-bipolar = SIGNAL-claim and NULL-baseline coexist :: meta_verdict [10*NEGATIVE_VERDICT]
  -> SEDI-AR-bl-voyager-1-conscious-927-6
  -> SEDI-AR-no-consciousness-in-physical-data
  -> SEDI-AR-pdg-ratio-matching-null
  -> SEDI-AR-perfect-number-uniqueness-falsifier
