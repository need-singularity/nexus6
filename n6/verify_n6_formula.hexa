// ═══════════════════════════════════════════════════════════
// verify_n6_formula.hexa — n6 산술 공식 수치 검증 헬퍼 (R1 HEXA-FIRST)
// Agent/script 가 공식 제안 시 사전 검증 용도.
//
// usage:
//   hexa verify_n6_formula.hexa <target> <formula>
//   hexa verify_n6_formula.hexa 155 "n*J2+sigma-mu"
//   # exit 0 if within tolerance, 1 otherwise
//
// n6 constants: n=6, sigma=12, tau=4, phi=2, sopfr=5, M3=7, J2=24, P2=28, mu=1
// operators: + - * / ^ ( ) (^ is exponent, not XOR)
// tolerance: 5% of target or 0.01 absolute minimum
//
// Ported from verify_n6_formula.py (2026-04-14, harness-approved)
// 함수명에 'verify' 키워드 직접 사용 금지 — hexa parser 충돌
// ═══════════════════════════════════════════════════════════

let argv = args()

if len(argv) < 4 {
    eprintln("verify_n6_formula.hexa — n6 arithmetic formula numeric verifier")
    eprintln("")
    eprintln("usage:")
    eprintln("    hexa verify_n6_formula.hexa <target> <formula>")
    eprintln("    hexa verify_n6_formula.hexa 155 \"n*J2+sigma-mu\"")
    eprintln("")
    eprintln("n6 constants: n=6, sigma=12, tau=4, phi=2, sopfr=5, M3=7, J2=24, P2=28, mu=1")
    eprintln("tolerance: 5% of target or 0.01 absolute minimum")
    exit(2)
}

let target_str = argv[2]
let formula = argv[3]

// Python 원자 평가 — verify_formulas.hexa 와 동일 패턴 (eval + n6 ctx)
let py_script = "import re,sys\n" +
    "ctx={'n':6,'sigma':12,'tau':4,'phi':2,'sopfr':5,'M3':7,'J2':24,'P2':28,'mu':1}\n" +
    "target_str=sys.argv[1]; formula=sys.argv[2]\n" +
    "try: target=float(target_str)\n" +
    "except ValueError:\n" +
    "    print(f'FAIL: invalid target: {target_str!r}'); sys.exit(1)\n" +     // @allow-silent-exit (embedded python)
    "expr=formula.replace('^','**').replace('\u00b2','**2').replace('\u00b3','**3')\n" +
    "if re.search(r'[^\\x00-\\x7f]',expr):\n" +
    "    print(f'FAIL: non-ASCII in formula: {formula!r}'); sys.exit(1)\n" +   // @allow-silent-exit (embedded python)
    "try: computed=eval(expr,{'__builtins__':{}},ctx)\n" +
    "except Exception as e:\n" +
    "    print(f'FAIL: eval error: {e}'); sys.exit(1)\n" +                    // @allow-silent-exit (embedded python)
    "if not isinstance(computed,(int,float)):\n" +
    "    print(f'FAIL: non-numeric result: {type(computed).__name__}'); sys.exit(1)\n" +  // @allow-silent-exit (embedded python)
    "computed=float(computed)\n" +
    "tol=max(0.05*abs(target),0.01)\n" +
    "diff=abs(computed-target)\n" +
    "ok=diff<=tol\n" +
    "status='OK' if ok else 'FAIL'\n" +
    "print(f'{status}: {formula} = {computed} (target={target}, diff={diff:.4f}, tol={tol:.4f})')\n" +
    "sys.exit(0 if ok else 1)\n"

// R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
// Original: python3 -c "<py_script>" <target> <formula> for n6 formula verification
let _ = py_script
let _ = target_str
let _ = formula
eprintln("R37/AN13/L3-PY: python3 invocation blocked at verify_n6_formula.hexa:main. Escalate to user for hexa-native replacement.")
let mut out: string = ""
let mut ok = false
out = ""
ok = false

// out 에는 GATE 디버그 + python source echo + 결과 라인이 섞여있음.
// 결과 라인은 마지막 비어있지 않은 라인. OK:/FAIL: prefix 로 판정.
let lines = out.split("\n")
let mut last: string = ""
let mut li: i64 = len(lines) - 1
while li >= 0 {
    let ln = lines[li].trim()
    if ln != "" { last = ln; break }
    li = li - 1
}

println(last)

if last.starts_with("OK:") {
    exit(0)
} else {
    eprintln("[verify_n6_formula] FAIL — see stdout for details")
    exit(1)  // @allow-silent-exit (eprintln above is the loud failure signal)
}
