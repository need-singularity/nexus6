  => structural fact (classifier thresholds)
  |> airgenome/archive/v1/docs/gates.hexa lines 176-220

@C AIRGENOME_VITALS_SAMPLE_15 = sample() returns Vitals{cpu,ram,gpu,npu,power,io: float} via uname-branch shell exec: Mac=sysctl/vm_stat, Linux=/proc/meminfo+nproc. cpu = (Σ %cpu)/ncpu, ram = used_mb·100/total_mb, power = swap_mb·100/total_mb, gpu/npu/io = 0.0 in single-host path. :: omega_cycle_airgenome [10*]
  => structural fact (the sensor)
  |> airgenome/core/core.hexa lines 41-56

@C AIRGENOME_ASSESS_THRESHOLDS_16 = assess(v, cpu_ceil, ram_ceil, swap_ceil) → {SEV_OK=0, SEV_WARN=1, SEV_CRITICAL=2}. Default ceilings: cpu=75%, ram=70%, swap=30%. Float-arithmetic bug workaround: all comparisons int-cast (1% precision loss accepted). cpu_warn = 0.8·cpu_ceil. :: omega_cycle_airgenome [10*]
  => structural fact (severity gate)
  |> airgenome/core/core.hexa lines 58-73

@C AIRGENOME_ADAPTIVE_THROTTLE_17 = AdaptiveThrottle 3-level: NORMAL/WARN/CRITICAL by RSS. SoftLimits default: warn=384MB, critical=480MB, throttle_sleep_ms=100, batch_scale_factor=0.5. throttle_batch_scale: NORMAL=1.0, WARN=0.5, CRITICAL=0.25. throttle_sleep_ms: NORMAL=0, WARN=100ms, CRITICAL=300ms. NO process-kill. :: omega_cycle_airgenome [10*]
  => structural fact (self-guard)
  |> airgenome/core/core.hexa lines 175-247

@C AIRGENOME_HARDLIMITS_18 = HardLimits default: max_rss_mb=512, max_data_mb=1024, nice_level=10, max_cpu_seconds=0. Applied via ulimit -m/-d/-t + renice -p $$. _hard_limits_applied flag → idempotent. :: omega_cycle_airgenome [10*]
  => structural fact (OS-level guard)
  |> airgenome/core/core.hexa lines 124-169

@C AIRGENOME_MILESTONES_M0_M6_19 = M0 v1-freeze+core-split, M1 L0 parse-check, M2 probe(Mac+ubu+htz vitals→infra_state), M3 dispatch(best-host AG6/AG7), M4 harvest(60B per-process→genomes.ring+sigdiff+throttle), M5 label(5 SSOT rules→labeled_anomaly.jsonl), M6 forecast(Holt's double exponential smoothing, MAE=0% on held-out). All ✅ done 2026-04-14. :: omega_cycle_airgenome [10*]
  => structural fact (milestone status)
  |> airgenome/README.md lines 65-77

