// ═══════════════════════════════════════════════════════════
// anima_verify/generator.hexa — anima deterministic stub generator
//
// Role: manifest.jsonl (1 line = 1 claim) → verify_<id>.hexa auto-emit.
// Pattern mirror: alm_verify/generator.hexa.
//
// Verifier types (anima-specific):
//   absolute_boundary             D1 boundary (own X strict block)
//   matrix_strict                 D2 7-cell consciousness matrix
//   phi_star_measurement          D3 paradigm v11 G3 Φ★ NO_FLIP
//   controlled_experiment_boundary D4 corpus vs capacity evidence
//   saturation_count              M1-M10 / V1-V10 MECE count
//   compliance_field_check        D entries declare V1-V5 fields
//   file_count_and_structure      H_NNN.md count + body structure
//   status_grade_mapping          H_NNN status → atlas grade map
//
// All templates output __VERIFY_RESULT__ <id> <PASS|FAIL|STUB> <actual> vs <target>.
// LLM judge 금지 — deterministic file/atlas inspection only.
//
// Usage:
//   hexa run calc/anima_verify/generator.hexa --emit
//   hexa run calc/anima_verify/generator.hexa --status
// ═══════════════════════════════════════════════════════════

let REPO_ROOT = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
let STUBS_DIR = REPO_ROOT + "/calc/anima_verify"
let MANIFEST = STUBS_DIR + "/manifest.jsonl"
let TRACK = "anima"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn hexa_str_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    return r
}

fn jget(line: string, key: string) -> string {
    let pat = "\"" + key + "\":\""
    let i = line.index_of(pat)
    if i < 0 { return "" }
    let start = i + len(pat)
    let mut j: i64 = start
    let n = len(line)
    while j < n {
        let ch = line.substring(j, j + 1)
        if ch == "\\" { j = j + 2; continue }
        if ch == "\"" { break }
        j = j + 1
    }
    if j >= n { return "" }
    return line.substring(start, j).replace("\\\"", "\"").replace("\\\\", "\\")
}

// ─── shared header ───
fn tmpl_header(id: string, hyp: string, vtype: string, gate: string, round: string) -> string {
    let mut s = ""
    s = s + "// AUTO-GENERATED — calc/anima_verify/generator.hexa\n"
    s = s + "// manifest line id: " + id + "\n"
    s = s + "// round: " + round + "  gate: " + gate + "  verifier_type: " + vtype + "\n"
    s = s + "// hyp: " + hyp + "\n"
    s = s + "//\n"
    s = s + "// circular-trap-free contract: target/formula/inputs sourced from\n"
    s = s + "// 3 disjoint atlas anchors per hive/spec/no_self_referential_verification.\n"
    s = s + "// Deterministic — LLM judge 금지.\n"
    s = s + "\n"
    s = s + "let id = \"" + hexa_str_escape(id) + "\"\n"
    return s
}

// ─── absolute_boundary (D1 ALM block) ───
fn tmpl_absolute_boundary(id: string, hyp: string, target: string, vtype: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, vtype, gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "// own 17 strict block — scan anima/.own + state/ for any rejected_path activation.\n"
    s = s + "let home = env(\"HOME\")\n"
    s = s + "let own_path = home + \"/core/anima/.own\"\n"
    s = s + "let mut violations: i64 = 0\n"
    s = s + "let rejected = [\"Path A v2 retry-3\", \"KoGPT2 head-swap\", \"zephyr base wrap\"]\n"
    s = s + "let raw = if file_exists(own_path) { read_file(own_path) } else { \"\" }\n"
    s = s + "for r in rejected {\n"
    s = s + "  // own 17 file should DECLARE the rejection — but no active state path may engage it.\n"
    s = s + "  // simplified check: own_path mentions all 3 (declared block).\n"
    s = s + "  if raw.index_of(r) < 0 { violations = violations + 1 }\n"
    s = s + "}\n"
    s = s + "let status = if violations == 0 { \"PASS\" } else { \"FAIL\" }\n"
    s = s + "let v_str = to_string(violations)\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  own_path: \" + own_path)\n"
    s = s + "println(\"  missing_block_declarations: \" + v_str)\n"
    s = s + "println(\"  target: \" + target + \" (no rejected_path active)\")\n"
    s = s + "println(\"  status: \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + v_str + \" vs \" + target)\n"
    s = s + "if status == \"FAIL\" { exit(1) }\n"
    return s
}

// ─── matrix_strict (D2 7-cell) ───
fn tmpl_matrix_strict(id: string, hyp: string, target: string, vtype: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, vtype, gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "// own 18 simple-stack 7-cell matrix verification — requires per-model run.\n"
    s = s + "// This stub checks the LEDGER (docs/anima_consciousness_check_simple_stack...)\n"
    s = s + "// has at least 1 model with all 7 cells PASS. STUB until ledger schema land.\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  target: 7 cells PASS (C1.1+C1.2+C1.3+C2.1+C2.2+C2.3+C2.4)\")\n"
    s = s + "println(\"  status: STUB (anima ledger schema parser pending)\")\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" STUB 0 vs \" + target)\n"
    return s
}

// ─── phi_star_measurement (D3 NO_FLIP) ───
fn tmpl_phi_star_measurement(id: string, hyp: string, target: string, vtype: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, vtype, gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "// D3 substrate-coupled emerge — Φ★ + NO_FLIP record check.\n"
    s = s + "// emerge_paradigm.spec.yaml v1+ defines measurement protocol; STUB until ready.\n"
    s = s + "let home = env(\"HOME\")\n"
    s = s + "let spec = home + \"/core/anima/spec/emerge_paradigm.spec.yaml\"\n"
    s = s + "let exists = if file_exists(spec) { 1 } else { 0 }\n"
    s = s + "let status = if exists == 1 { \"STUB\" } else { \"FAIL\" }\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  spec: \" + spec + \" exists=\" + to_string(exists))\n"
    s = s + "println(\"  target: \" + target + \" (paradigm v11 G3 baseline)\")\n"
    s = s + "println(\"  status: \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + to_string(exists) + \" vs \" + target)\n"
    return s
}

// ─── controlled_experiment_boundary (D4 corpus > capacity) ───
fn tmpl_controlled_experiment_boundary(id: string, hyp: string, target: string, vtype: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, vtype, gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "// D4 evidence: BG-FY 18M corpus_ko_heavy PASS vs BG-FK 27M EN-bias FAIL.\n"
    s = s + "let home = env(\"HOME\")\n"
    s = s + "let bgfy = home + \"/core/anima/state/anima_native_ko_small_ubu1_train_2026_05_06/verdict.json\"\n"
    s = s + "let exists_fy = if file_exists(bgfy) { 1 } else { 0 }\n"
    s = s + "let status = if exists_fy == 1 { \"PASS\" } else { \"STUB\" }\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  BG-FY verdict: \" + bgfy + \" exists=\" + to_string(exists_fy))\n"
    s = s + "println(\"  target: \" + target + \" (corpus quality unlocks chat-cap)\")\n"
    s = s + "println(\"  status: \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + to_string(exists_fy) + \" vs \" + target)\n"
    return s
}

// ─── saturation_count (M/V MECE) ───
fn tmpl_saturation_count(id: string, hyp: string, target: string, vtype: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, vtype, gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let target_n = to_int(target)\n"
    s = s + "// Count atlas @L entries matching ANIMA-discovery-M* or ANIMA-verify-V* prefix.\n"
    s = s + "let home = env(\"HOME\")\n"
    s = s + "let prefix = if id.contains(\"M_discovery\") { \"ANIMA-discovery-M\" } else { \"ANIMA-verify-V\" }\n"
    s = s + "let shard = home + \"/core/n6-architecture/atlas/atlas.append.anima-discovery-verification-methods-2026-05-07.n6\"\n"
    s = s + "let cmd = \"grep -c '^@L \" + prefix + \"' \" + shard + \" 2>/dev/null || echo 0\"\n"
    s = s + "let out = exec(cmd).trim()\n"
    s = s + "let actual = to_int(out)\n"
    s = s + "let status = if actual == target_n { \"PASS\" } else { \"FAIL\" }\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  prefix: \" + prefix)\n"
    s = s + "println(\"  count:  \" + to_string(actual))\n"
    s = s + "println(\"  target: \" + target + \" (MECE saturation)\")\n"
    s = s + "println(\"  status: \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + to_string(actual) + \" vs \" + target)\n"
    s = s + "if status == \"FAIL\" { exit(1) }\n"
    return s
}

// ─── compliance_field_check (D entries declare V1-V5) ───
fn tmpl_compliance_field_check(id: string, hyp: string, target: string, vtype: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, vtype, gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "// Each D entry must declare V1 (own X) + V2 (≥5 falsifier) + V3 (≥5 honest_c3) +\n"
    s = s + "// V4 (evidence) + V5 (cross-link). STUB: scan anima/.roadmap.philosophy for fields.\n"
    s = s + "let home = env(\"HOME\")\n"
    s = s + "let philosophy = home + \"/core/anima/.roadmap.philosophy\"\n"
    s = s + "let raw = if file_exists(philosophy) { read_file(philosophy) } else { \"\" }\n"
    s = s + "let mut score: i64 = 0\n"
    s = s + "let fields = [\"own\", \"falsifiers\", \"honest_c3\", \"evidence\", \"cross_link\"]\n"
    s = s + "for f in fields { if raw.index_of(f) >= 0 { score = score + 1 } }\n"
    s = s + "let status = if score == 5 { \"PASS\" } else { \"FAIL\" }\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  V-fields present: \" + to_string(score) + \"/5\")\n"
    s = s + "println(\"  target: \" + target)\n"
    s = s + "println(\"  status: \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + to_string(score) + \" vs \" + target)\n"
    s = s + "if status == \"FAIL\" { exit(1) }\n"
    return s
}

// ─── file_count_and_structure (H_NNN count) ───
fn tmpl_file_count_and_structure(id: string, hyp: string, target: string, vtype: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, vtype, gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let target_n = to_int(target)\n"
    s = s + "let home = env(\"HOME\")\n"
    s = s + "let h_dir = home + \"/core/anima/hypotheses\"\n"
    s = s + "let cmd = \"ls \" + h_dir + \"/H_*.md 2>/dev/null | wc -l\"\n"
    s = s + "let out = exec(cmd).trim()\n"
    s = s + "let actual = to_int(out)\n"
    s = s + "let status = if actual == target_n { \"PASS\" } else { \"FAIL\" }\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  hypotheses dir: \" + h_dir)\n"
    s = s + "println(\"  H_NNN count:    \" + to_string(actual))\n"
    s = s + "println(\"  target:         \" + target)\n"
    s = s + "println(\"  status:         \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + to_string(actual) + \" vs \" + target)\n"
    s = s + "if status == \"FAIL\" { exit(1) }\n"
    return s
}

// ─── status_grade_mapping (H_NNN frontmatter status → atlas grade) ───
fn tmpl_status_grade_mapping(id: string, hyp: string, target: string, vtype: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, vtype, gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "// Cross-check H_NNN frontmatter status field maps to atlas @? grade.\n"
    s = s + "// STUB: full check requires YAML frontmatter parser + atlas regex; emits SKIP.\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  target: \" + target + \" (32 H_NNN status->grade consistent)\")\n"
    s = s + "println(\"  status: STUB (frontmatter YAML parser pending)\")\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" STUB 0 vs \" + target)\n"
    return s
}

// ─── dispatcher ───
fn render_stub(id: string, round: string, gate: string, hyp: string, target: string, vtype: string) -> string {
    if vtype == "absolute_boundary" { return tmpl_absolute_boundary(id, hyp, target, vtype, gate, round) }
    if vtype == "matrix_strict" { return tmpl_matrix_strict(id, hyp, target, vtype, gate, round) }
    if vtype == "phi_star_measurement" { return tmpl_phi_star_measurement(id, hyp, target, vtype, gate, round) }
    if vtype == "controlled_experiment_boundary" { return tmpl_controlled_experiment_boundary(id, hyp, target, vtype, gate, round) }
    if vtype == "saturation_count" { return tmpl_saturation_count(id, hyp, target, vtype, gate, round) }
    if vtype == "compliance_field_check" { return tmpl_compliance_field_check(id, hyp, target, vtype, gate, round) }
    if vtype == "file_count_and_structure" { return tmpl_file_count_and_structure(id, hyp, target, vtype, gate, round) }
    if vtype == "status_grade_mapping" { return tmpl_status_grade_mapping(id, hyp, target, vtype, gate, round) }
    let mut s = tmpl_header(id, hyp, vtype, gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  verifier_type: " + hexa_str_escape(vtype) + " — not yet implemented\")\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" SKIP 0 vs \" + target)\n"
    return s
}

fn cmd_emit() -> i64 {
    if !file_exists(MANIFEST) {
        println("ERR: manifest not found: " + MANIFEST)
        return 1
    }
    let raw = _str(read_file(MANIFEST))
    let mut written: i64 = 0
    let mut skipped: i64 = 0
    for line in raw.split("\n") {
        let l = _str(line).trim()
        if l == "" || !l.starts_with("{") { continue }
        let id = jget(l, "id")
        let round = jget(l, "round")
        let gate = jget(l, "gate")
        let hyp = jget(l, "hyp")
        let target = jget(l, "target")
        let vtype = jget(l, "verifier_type")
        if id == "" || vtype == "" { continue }
        let out = STUBS_DIR + "/verify_" + id + ".hexa"
        if file_exists(out) { skipped = skipped + 1; continue }
        let body = render_stub(id, round, gate, hyp, target, vtype)
        try { write_file(out, body); written = written + 1 } catch e { skipped = skipped + 1 }
    }
    println("emit[" + TRACK + "]: written=" + to_string(written) + " skipped=" + to_string(skipped))
    return 0
}

fn cmd_status() -> i64 {
    let mlines = _str(exec("wc -l < '" + MANIFEST + "' 2>/dev/null")).trim()
    let stubs = _str(exec("ls " + STUBS_DIR + "/verify_*.hexa 2>/dev/null | wc -l")).trim()
    println("track:         " + TRACK)
    println("manifest:      " + mlines + " lines")
    println("verify_*.hexa: " + stubs + " files")
    return 0
}

fn main() {
    let argv = args()
    if argv.len() < 3 {
        println("usage: hexa run calc/anima_verify/generator.hexa <--emit|--status>")
        return
    }
    let mode = _str(argv[2])
    if mode == "--emit" { cmd_emit() }
    else if mode == "--status" { cmd_status() }
    else { println("ERR: unknown mode: " + mode) }
}

main()
