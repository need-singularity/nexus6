let id = "alm_r12_validity_closed_loop"
let target = "true"
let path = "shared/consciousness/closed_loop_verify.hexa"

// Local-first; pod-fallback if path starts with /workspace
let pod = env("HEXA_VERIFY_POD")
let pod_host = if pod != "" { pod } else { "87xsc" }
let is_pod = path.starts_with("/workspace/") || path.starts_with("/root/")
let repo = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
let local_path = if path.starts_with("/") { path } else { repo + "/" + path }
let cmd = if is_pod { "ssh " + pod_host + " 'test -s " + path + " && wc -c < " + path + " || echo 0'" } else { "test -s " + local_path + " && wc -c < " + local_path + " || echo 0" }
let out = exec(cmd).trim()
let size = to_int(out)
let status = if size > 0 { "PASS" } else { "FAIL" }
let size_str = to_string(size)
println("verify: " + id)
println("  path:     " + path + (if is_pod { " (pod=" + pod_host + ")" } else { " (local)" }))
println("  size:     " + size_str + " bytes")
println("  target:   size > 0")
println("  status:   " + status)
println("__VERIFY_RESULT__ " + id + " " + status + " " + size_str + " vs " + target)
if status == "FAIL" { exit(1) }
