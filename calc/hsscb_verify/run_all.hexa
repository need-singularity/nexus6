// ═══════════════════════════════════════════════════════════
// nexus calc/hsscb_verify/run_all.hexa
//
// hexa-sscb mk1 (HEXA-SSCB) deterministic gate aggregator.
// Pattern: alm_verify/run_all.hexa + clm_verify/run_all.hexa.
// LLM judge 금지 — 모든 verify_*.hexa 가 결정적 비교.
//
// circular-trap-free 보장: 각 verifier 의 (target_value, target_unit, target_source)
// 3-tuple 이 atlas.n6 + atlas.append.* 의 axis-M anchor 에서 분리 추출.
// ═══════════════════════════════════════════════════════════

let manifest_path = "calc/hsscb_verify/manifest.jsonl"

// ─── 2026-05-07 akida wire-up: --akida-route OR NEXUS_AKIDA_ROUTE=1 시
//     scripts/akida/dispatch.hexa route check-loop 으로 시도, probe 실패 시
//     아래 default 10-verifier 흐름 그대로 (backward compatible). ───
let _hsscb_argv = args()
let mut _hsscb_want_akida = false
let mut _hsscb_i = 2
while _hsscb_i < _hsscb_argv.len() {
    if _hsscb_argv[_hsscb_i] == "--akida-route" { _hsscb_want_akida = true }
    _hsscb_i = _hsscb_i + 1
}
if _hsscb_want_akida || env("NEXUS_AKIDA_ROUTE") == "1" {
    let _hsscb_repo = exec("git rev-parse --show-toplevel 2>/dev/null").trim()  // @allow-bare-exec
    let _hsscb_dispatcher = _hsscb_repo + "/scripts/akida/dispatch.hexa"
    if file_exists(_hsscb_dispatcher) {
        let _hsscb_probe = to_string(exec("hexa run '" + _hsscb_dispatcher + "' probe 2>/dev/null; echo __RC=$?"))  // @allow-bare-exec
        let _hsscb_rc_at = _hsscb_probe.index_of("__RC=")
        let mut _hsscb_probe_rc: i64 = 1
        if _hsscb_rc_at > -1 {
            try { _hsscb_probe_rc = to_int(_hsscb_probe.substring(_hsscb_rc_at + 5, _hsscb_probe.len()).trim()) } catch _hsscb_e {}  // @allow-silent-catch
        }
        if _hsscb_probe_rc == 0 {
            let _hsscb_out = to_string(exec("hexa run '" + _hsscb_dispatcher + "' route check-loop 2>&1"))  // @allow-bare-exec
            print(_hsscb_out)
            eprintln("NEXUS_VERIFY_AKIDA {\"track\":\"hsscb\",\"action\":\"akida-route\"}")
            exit(0)  // @allow-silent-exit
        }
        eprintln("NEXUS_VERIFY_AKIDA {\"track\":\"hsscb\",\"action\":\"fallback-default\",\"reason\":\"probe_rc=" + to_string(_hsscb_probe_rc) + "\"}")
    }
}

// 10 verifier ids (manifest.jsonl 의 id 필드)
let verifier_ids = [
    "hsscb_mk1_physics_turnoff",
    "hsscb_mk1_physics_i2t",
    "hsscb_mk1_physics_overshoot",
    "hsscb_mk1_physics_current_share",
    "hsscb_mk1_thermal_tj",
    "hsscb_mk1_reliability_tddb",
    "hsscb_mk1_signal_adc_bw",
    "hsscb_mk1_timing_irq",
    "hsscb_mk1_economics_bom",
    "hsscb_mk1_economics_schedule"
]

let mut pass_count: i64 = 0
let mut fail_count: i64 = 0

for vid in verifier_ids {
    let cmd = "hexa run calc/hsscb_verify/verify_" + vid + ".hexa"
    let out = exec(cmd)
    if out.contains("__VERIFY_RESULT__") && out.contains(" PASS ") {
        pass_count = pass_count + 1
        println("  [PASS] " + vid)
    } else {
        fail_count = fail_count + 1
        println("  [FAIL] " + vid)
        println(out)
    }
}

println("─────────────────────────────────────────")
println("hsscb_verify aggregate: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(pass_count + fail_count) + " total")
if fail_count > 0 { exit(1) }
