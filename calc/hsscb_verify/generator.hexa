// ═══════════════════════════════════════════════════════════
// nexus calc/hsscb_verify/generator.hexa
//
// manifest.jsonl → 10 verify_<id>.hexa stubs
// pattern: shared/calc/auto_stubs_gen.hexa (140-stub generator)
//        + alm_verify/generator.hexa (round-tagged variant)
//
// invariant: stub 안에 atlas.n6 + atlas.append.* 의 anchor id 만 인용 — 값
// 자체는 stub 안에 절대 하드코딩하지 않음 (circular-trap 회피).
// ═══════════════════════════════════════════════════════════

let manifest = "calc/hsscb_verify/manifest.jsonl"
let out_dir  = "calc/hsscb_verify/"
let lines = read_file(manifest).split("\n")

for line in lines {
    let t = line.trim()
    if len(t) == 0 { continue }
    if t[0..1] == "#" { continue }
    let entry = json_parse(t)
    let id    = entry["id"]
    let gate  = entry["gate"]
    let hyp   = entry["hyp"]
    let tgt   = entry["target"]
    let unit  = entry["target_unit"]
    let expr  = entry["expr"]
    let close = entry["closure"]
    let aanc  = entry["atlas_anchor"]
    let vanc  = entry["value_anchors"]
    let ipath = entry["input_path"]
    let vtype = entry["verifier_type"]

    let path = out_dir + "verify_" + id + ".hexa"
    let mut body = "// AUTO-GENERATED — calc/hsscb_verify/generator.hexa\n"
    body = body + "// manifest entry: " + id + "\n"
    body = body + "// gate: " + gate + "\n"
    body = body + "// hyp: " + hyp + "\n"
    body = body + "//\n"
    body = body + "// circular-trap-free contract:\n"
    body = body + "//   target  = " + tgt + " " + unit + " (from atlas axis-M anchor)\n"
    body = body + "//   formula = " + expr + " (from atlas.n6 @L: " + json_stringify(aanc) + ")\n"
    body = body + "//   inputs  = " + json_stringify(vanc) + "\n"
    body = body + "//   closure = " + close + "\n"
    body = body + "//\n"
    body = body + "// 외부 입력 소스 (cite-and-anchor):\n"
    body = body + "//   " + json_stringify(ipath) + "\n"
    body = body + "//\n"
    body = body + "// LLM judge 금지 — deterministic compare only.\n"
    body = body + "\n"
    body = body + "let id     = \"" + id + "\"\n"
    body = body + "let target = \"" + tgt + "\"\n"
    body = body + "let unit   = \"" + unit + "\"\n"
    body = body + "\n"
    body = body + "// TODO: pull values from atlas.append.hsscb-mk1-vendor-anchors-2026-05-06.n6\n"
    body = body + "//       via verify/atlas_anchors.py (Stage D wire-up).\n"
    body = body + "// TODO: apply formula → measured value\n"
    body = body + "// TODO: compare measured vs target → PASS/FAIL\n"
    body = body + "\n"
    body = body + "println(\"verify: \" + id)\n"
    body = body + "println(\"  target:    \" + target + \" \" + unit)\n"
    body = body + "println(\"  status:    STUB (Stage D wire-up pending)\")\n"
    body = body + "println(\"__VERIFY_RESULT__ \" + id + \" STUB \" + target + \" vs measured\")\n"

    write_file(path, body)
}

println("generated " + to_string(len(lines) - 1) + " verify_*.hexa stubs in " + out_dir)
