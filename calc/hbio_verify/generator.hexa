// ═══════════════════════════════════════════════════════════
// hbio_verify/generator.hexa — hexa-bio deterministic stub generator
//
// Role: manifest.jsonl (1 line = 1 claim) → verify_<id>.hexa auto-emit.
// Pattern: anima_verify/generator.hexa + alm_verify (numeric_threshold + sum_match).
// LLM judge 금지 — deterministic atlas anchor lookup + numeric compare.
//
// Verifier types (hexa-bio):
//   numeric_threshold  — actual op threshold (>= / <= / == / < / >)
//   sum_match          — sum of N atlas values == target
//   formula_anchored   — formula evaluation (alias of numeric_threshold)
//
// Usage:
//   hexa run calc/hbio_verify/generator.hexa --emit
//   hexa run calc/hbio_verify/generator.hexa --status
// ═══════════════════════════════════════════════════════════

let REPO_ROOT = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
let STUBS_DIR = REPO_ROOT + "/calc/hbio_verify"
let MANIFEST = STUBS_DIR + "/manifest.jsonl"
let TRACK = "hbio"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn hexa_str_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    return r
}

fn jget(line: string, key: string) -> string {
    let pat = "\"" + key + "\":\""
    let i = line.index_of(pat)
    if i < 0 { return "" }
    let start = i + len(pat)
    let mut j: i64 = start
    let n = len(line)
    while j < n {
        let ch = line.substring(j, j + 1)
        if ch == "\\" { j = j + 2; continue }
        if ch == "\"" { break }
        j = j + 1
    }
    if j >= n { return "" }
    return line.substring(start, j).replace("\\\"", "\"").replace("\\\\", "\\")
}

fn tmpl_header(id: string, hyp: string, vtype: string, gate: string, round: string) -> string {
    let mut s = ""
    s = s + "// AUTO-GENERATED — calc/hbio_verify/generator.hexa\n"
    s = s + "// manifest line id: " + id + "\n"
    s = s + "// round: " + round + "  gate: " + gate + "  verifier_type: " + vtype + "\n"
    s = s + "// hyp: " + hyp + "\n"
    s = s + "//\n"
    s = s + "// circular-trap-free contract: target/formula/inputs from 3 disjoint\n"
    s = s + "// atlas anchors per hive/spec/no_self_referential_verification.\n"
    s = s + "// raw#91 honest C3: in-silico simulator+metadata consistency only.\n"
    s = s + "// Deterministic — LLM judge 금지.\n"
    s = s + "\n"
    s = s + "let id = \"" + hexa_str_escape(id) + "\"\n"
    return s
}

fn tmpl_numeric_threshold(id: string, hyp: string, target: string, vtype: string, gate: string, round: string, closure: string) -> string {
    let mut s = tmpl_header(id, hyp, vtype, gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let target_n = to_float(target)\n"
    let mut op = ">="
    if closure.index_of("<=") >= 0 { op = "<=" }
    else if closure.index_of(">=") >= 0 { op = ">=" }
    else if closure.index_of("==") >= 0 { op = "==" }
    else if closure.index_of("<") >= 0 { op = "<" }
    else if closure.index_of(">") >= 0 { op = ">" }
    s = s + "let op = \"" + op + "\"\n"
    s = s + "// TODO (Stage E hbio): pull `actual` from atlas anchor or hexa-bio _python_bridge\n"
    s = s + "// witness file. STUB defaults actual to target_n (PASS by construction —\n"
    s = s + "// flag for real wire-up at hbio interp ready).\n"
    s = s + "let actual = target_n\n"
    s = s + "let pass = if op == \">=\" { actual >= target_n }\n"
    s = s + "           else if op == \"<=\" { actual <= target_n }\n"
    s = s + "           else if op == \"==\" { actual == target_n }\n"
    s = s + "           else if op == \"<\"  { actual <  target_n }\n"
    s = s + "           else if op == \">\"  { actual >  target_n }\n"
    s = s + "           else { false }\n"
    s = s + "let status = if pass { \"STUB\" } else { \"FAIL\" }\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  target:  \" + op + \" \" + target)\n"
    s = s + "println(\"  status:  \" + status + \" (Stage E wire-up pending)\")\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + to_string(actual) + \" vs \" + target)\n"
    return s
}

fn tmpl_sum_match(id: string, hyp: string, target: string, vtype: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, vtype, gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let target_n = to_int(target)\n"
    s = s + "// TODO (Stage E hbio): sum value_anchors from atlas → compare target.\n"
    s = s + "// STUB defaults actual to target_n (PASS by construction).\n"
    s = s + "let actual = target_n\n"
    s = s + "let status = if actual == target_n { \"STUB\" } else { \"FAIL\" }\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  target:  == \" + target)\n"
    s = s + "println(\"  status:  \" + status + \" (Stage E wire-up pending)\")\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + to_string(actual) + \" vs \" + target)\n"
    return s
}

fn render_stub(id: string, round: string, gate: string, hyp: string, target: string, closure: string, vtype: string) -> string {
    if vtype == "numeric_threshold" || vtype == "formula_anchored" { return tmpl_numeric_threshold(id, hyp, target, vtype, gate, round, closure) }
    if vtype == "sum_match" { return tmpl_sum_match(id, hyp, target, vtype, gate, round) }
    let mut s = tmpl_header(id, hyp, vtype, gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  verifier_type: " + hexa_str_escape(vtype) + " not yet implemented\")\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" SKIP 0 vs \" + target)\n"
    return s
}

fn cmd_emit() -> i64 {
    if !file_exists(MANIFEST) {
        println("ERR: manifest not found: " + MANIFEST)
        return 1
    }
    let raw = _str(read_file(MANIFEST))
    let mut written: i64 = 0
    let mut skipped: i64 = 0
    for line in raw.split("\n") {
        let l = _str(line).trim()
        if l == "" || !l.starts_with("{") { continue }
        let id = jget(l, "id")
        let round = jget(l, "round")
        let gate = jget(l, "gate")
        let hyp = jget(l, "hyp")
        let target = jget(l, "target")
        let closure = jget(l, "closure")
        let vtype = jget(l, "verifier_type")
        if id == "" || vtype == "" { continue }
        let out = STUBS_DIR + "/verify_" + id + ".hexa"
        if file_exists(out) { skipped = skipped + 1; continue }
        let body = render_stub(id, round, gate, hyp, target, closure, vtype)
        try { write_file(out, body); written = written + 1 } catch e { skipped = skipped + 1 }
    }
    println("emit[" + TRACK + "]: written=" + to_string(written) + " skipped=" + to_string(skipped))
    return 0
}

fn cmd_status() -> i64 {
    let mlines = _str(exec("wc -l < '" + MANIFEST + "' 2>/dev/null")).trim()
    let stubs = _str(exec("ls " + STUBS_DIR + "/verify_*.hexa 2>/dev/null | wc -l")).trim()
    println("track:         " + TRACK)
    println("manifest:      " + mlines + " lines")
    println("verify_*.hexa: " + stubs + " files")
    return 0
}

fn main() {
    let argv = args()
    if argv.len() < 3 { println("usage: hexa run calc/hbio_verify/generator.hexa <--emit|--status>"); return }
    let mode = _str(argv[2])
    if mode == "--emit" { cmd_emit() }
    else if mode == "--status" { cmd_status() }
    else { println("ERR: unknown mode: " + mode) }
}
