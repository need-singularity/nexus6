// ═══════════════════════════════════════════════════════════
// run_all.hexa — hbio_verify deterministic orchestrator
//
// 역할: manifest.jsonl + verify_*.hexa 전수 실행, __VERIFY_RESULT__
//       sentinel 수집 → gate-level aggregate.
// 패턴: alm_verify/run_all.hexa + anima_verify/run_all.hexa.
// LLM judge 금지 — sentinel = 각 stub deterministic 계산.
// ═══════════════════════════════════════════════════════════

let TRACK = "hbio"
let REPO_ROOT = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
let VERIFY_DIR = REPO_ROOT + "/calc/" + TRACK + "_verify"
let MANIFEST = VERIFY_DIR + "/manifest.jsonl"

fn resolve_hexa_bin() -> string {
    let hl = env("HEXA_LANG")
    if hl != "" { let cand = hl + "/hexa"; if file_exists(cand) { return cand } }
    let home = env("HOME")
    if home != "" { let cand = home + "/.hx/bin/hexa"; if file_exists(cand) { return cand } }
    return "hexa"
}

let HEXA_BIN = resolve_hexa_bin()

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn jget(line: string, key: string) -> string {
    let pat = "\"" + key + "\":\""
    let i = line.index_of(pat)
    if i < 0 { return "" }
    let start = i + len(pat)
    let mut j: i64 = start
    let n = len(line)
    while j < n {
        let ch = line.substring(j, j + 1)
        if ch == "\\" { j = j + 2; continue }
        if ch == "\"" { break }
        j = j + 1
    }
    if j >= n { return "" }
    return line.substring(start, j).replace("\\\"", "\"").replace("\\\\", "\\")
}

fn parse_args() -> map {
    let mut filter_gate = ""
    let argv = args()
    let mut i: i64 = 2
    while i < argv.len() {
        let a = _str(argv[i])
        if a == "--gate" && i + 1 < argv.len() { filter_gate = _str(argv[i + 1]); i = i + 2; continue }
        i = i + 1
    }
    return #{ "gate": filter_gate }
}

fn _akida_route_or_default() -> bool {
    // 2026-05-07 — "use akida || fallback default verify" wire (sister of
    // anima_verify/run_all.hexa). --akida-route OR NEXUS_AKIDA_ROUTE=1 →
    // probe akida → route check-loop on success, default verify on failure.
    let argv = args()
    let mut want = false
    let mut i: i64 = 2
    while i < argv.len() {
        if _str(argv[i]) == "--akida-route" { want = true }
        i = i + 1
    }
    if !want && env("NEXUS_AKIDA_ROUTE") != "1" { return false }
    let dispatcher = REPO_ROOT + "/scripts/akida/dispatch.hexa"
    if !file_exists(dispatcher) { return false }
    let probe = to_string(exec(HEXA_BIN + " run '" + dispatcher + "' probe 2>/dev/null; echo __RC=$?"))  // @allow-bare-exec
    let rc_at = probe.index_of("__RC=")
    let mut probe_rc: i64 = 1
    if rc_at > -1 {
        try { probe_rc = to_int(probe.substring(rc_at + 5, len(probe)).trim()) } catch e {}  // @allow-silent-catch
    }
    if probe_rc != 0 {
        eprintln("NEXUS_VERIFY_AKIDA {\"track\":\"" + TRACK + "\",\"action\":\"fallback-default\",\"reason\":\"probe_rc=" + to_string(probe_rc) + "\"}")
        return false
    }
    let out = to_string(exec(HEXA_BIN + " run '" + dispatcher + "' route check-loop 2>&1; echo __RC=$?"))  // @allow-bare-exec
    print(out)
    eprintln("NEXUS_VERIFY_AKIDA {\"track\":\"" + TRACK + "\",\"action\":\"akida-route\"}")
    return true
}

fn main() {
    if _akida_route_or_default() { return }
    if !file_exists(MANIFEST) {
        println("ERR: manifest not found: " + MANIFEST)
        exit(2)
    }
    let opts = parse_args()
    let raw = _str(read_file(MANIFEST))
    let mut pass_count: i64 = 0
    let mut fail_count: i64 = 0
    let mut skip_count: i64 = 0
    let mut total: i64 = 0

    println("=" + "=".repeat(70))
    println("  " + TRACK + "_verify run_all (circular-trap-free atlas-anchored)")
    println("  raw#91 honest C3: in-silico simulator+metadata consistency only")
    println("=" + "=".repeat(70))

    for line in raw.split("\n") {
        let l = _str(line).trim()
        if l == "" || !l.starts_with("{") { continue }
        let id = jget(l, "id")
        let gate = jget(l, "gate")
        if id == "" { continue }
        if opts["gate"] != "" && gate != opts["gate"] { continue }
        total = total + 1

        let stub = VERIFY_DIR + "/verify_" + id + ".hexa"
        if !file_exists(stub) {
            println("  [SKIP-NOSTUB] " + id + "  " + gate)
            skip_count = skip_count + 1
            continue
        }
        let cmd = HEXA_BIN + " run " + stub
        let out = _str(exec(cmd))
        let mut status = "UNKNOWN"
        for ol in out.split("\n") {
            let t = ol.trim()
            if t.starts_with("__VERIFY_RESULT__") {
                let parts = t.split(" ")
                if parts.len() >= 3 { status = _str(parts[2]) }
            }
        }
        if status == "PASS" { pass_count = pass_count + 1; println("  [PASS] " + id + "  " + gate) }
        else if status == "SKIP" || status == "STUB" { skip_count = skip_count + 1; println("  [SKIP] " + id + "  " + gate) }
        else { fail_count = fail_count + 1; println("  [FAIL] " + id + "  " + gate + "  status=" + status) }
    }

    println("=" + "=".repeat(70))
    println("  " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(skip_count) + " SKIP / " + to_string(total) + " total")
    if fail_count > 0 { exit(1) }
}
