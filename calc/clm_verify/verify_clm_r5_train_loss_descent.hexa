// AUTO-GENERATED — shared/calc/clm_verify/generator.hexa
// manifest line id: clm_r5_train_loss_descent
// round: r5  gate: G_TRAIN  verifier_type: numeric_descent
// hyp: loss sliding window descent
//
// Deterministic — LLM judge 금지.

let id = "clm_r5_train_loss_descent"
let target = "monotone"
let log_path = "/tmp/clm_r5_*.log"
let window = 10

let pod = env("HEXA_VERIFY_POD")
let pod_host = if pod != "" { pod } else { "87xsc" }
let is_pod = log_path.starts_with("/workspace/") || log_path.starts_with("/root/")
// CLM log may be local (/tmp/clm_r5_*.log glob — first match).
let awk_script = "awk 'match(\\$0,/loss=([0-9.]+)/,m){v[++n]=m[1]} END{w=10; if(n<=w){print \\"INSUFFICIENT\\"; exit} inc=0; for(i=1;i<=n-w+1;i++){s=0; for(j=0;j<w;j++)s+=v[i+j]; mean[i]=s/w} for(i=1;i<length(mean);i++){if(mean[i+1]>mean[i]*1.02)inc++} print inc}'"
let cmd = if is_pod { "ssh " + pod_host + " \"" + awk_script + " " + log_path + "\"" } else { awk_script + " " + log_path }
let out = exec(cmd).trim()
let status = if out == "0" { "PASS" } else { "FAIL" }
println("verify: " + id)
println("  log:      " + log_path)
println("  window:   " + to_string(window))
println("  rises:    " + out)
println("  target:   0 rises (monotone non-increase, 2%% tolerance)")
println("  status:   " + status)
println("__VERIFY_RESULT__ " + id + " " + status + " " + out + " vs " + target)
if status == "FAIL" { exit(1) }
