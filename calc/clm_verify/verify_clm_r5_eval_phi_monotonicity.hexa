let ratio_str = to_string(ratio)

println("verify: " + id)
println("  summary:  " + sp)
println("  final:    " + final_out)
println("  best:     " + best_out)
println("  ratio:    " + ratio_str)
println("  target:   >= " + target)
println("  status:   " + status)
