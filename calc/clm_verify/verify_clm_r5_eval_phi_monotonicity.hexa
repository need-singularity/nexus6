let id = "clm_r5_eval_phi_monotonicity"
let target = "0.5"
let target_ratio = 0.5

let summary_path = env("CLM_SUMMARY_PATH")
let default_path = exec("git rev-parse --show-toplevel 2>/dev/null").trim() + "/state/clm_r3_training_summary.json"
let sp = if summary_path != "" { summary_path } else { default_path }

let final_cmd = "jq -r '.phi_holo_final // .phi_final // .phi_holo // 0' " + sp
let best_cmd = "jq -r '.phi_holo_best // .phi_best // .phi_peak // 0' " + sp

let final_out = exec(final_cmd).trim()
