{
  "id": "L0-core-pin",
  "kind": "core_integrity_sot",
  "schema": "v1",
  "role": "nexus 핵심 파일 무결성 PIN — SHA256 drift 감지 + runtime refuse",
  "updated": "2026-04-20",
  "policy": {
    "bypass_env":    "NEXUS_CORE_EDIT_OK",
    "on_drift":      "refuse_and_emit_json",
    "on_missing":    "warn_only",
    "check_on":      ["nexus_startup", "pre_commit_hook"],
    "refuse_exit":   1,
    "refuse_stderr": "NEXUS_CORE_TAMPERED",
    "recovery":      "git checkout HEAD -- <path> 또는 git stash"
  },
  "pinned": [
    {
      "path": "run.hexa",
      "sha256": "PENDING",
      "min_lines": 800,
      "max_lines": 1500,
      "owner": "nexus-cli",
      "notes": "drill orchestrator + CLI dispatcher. 변경 많음 → PIN 대신 shape check 위주"
    },
    {
      "path": "shared/blowup/core/blowup.hexa",
      "sha256": "PENDING",
      "min_lines": 5000,
      "max_lines": 6500,
      "owner": "blowup-engine",
      "notes": "9-phase Mk.II~VII discovery engine. hot-spot, 393 concat 포함"
    },
    {
      "path": "shared/blowup/compose.hexa",
      "sha256": "PENDING",
      "min_lines": 500,
      "max_lines": 2000,
      "owner": "blowup-engine",
      "notes": "compose DFS 6-core orchestrator"
    },
    {
      "path": "shared/blowup/modules/blowup_absolute.hexa",
      "sha256": "PENDING",
      "owner": "blowup-engine",
      "notes": "Mk.VIII Δ₀-absolute Π₀¹"
    },
    {
      "path": "shared/blowup/modules/blowup_meta_closure.hexa",
      "sha256": "PENDING",
      "owner": "blowup-engine",
      "notes": "Mk.IX Phase 10 self-ref"
    },
    {
      "path": "shared/blowup/modules/blowup_hyperarithmetic.hexa",
      "sha256": "PENDING",
      "owner": "blowup-engine",
      "notes": "Mk.IX Π₀² reverse-math"
    },
    {
      "path": "shared/config/drill.json",
      "sha256": "PENDING",
      "owner": "drill-config",
      "notes": "depth/adaptive/preset SSOT"
    },
    {
      "path": "shared/config/roi/nexus.json",
      "sha256": "PENDING",
      "owner": "roi-sot",
      "notes": "48 ROI 완료 상태"
    },
    {
      "path": "shared/lockdown/L0_core.json",
      "sha256": "SELF",
      "owner": "L0-pin",
      "notes": "self-pin — 자체 변경 감지 (sha 제외 field 만 pin)"
    }
  ],
  "verify_script": "shared/scripts/verify_L0_core.hexa",
  "emit_schema": {
    "drift_json": {
      "kind":  "core_drift",
      "path":  "<relative>",
      "expected_sha256": "<hex>",
      "actual_sha256":   "<hex>",
      "bytes_diff":      "<int>",
      "recovery_hint":   "git checkout HEAD -- <path>"
    },
    "missing_json": {
      "kind":  "core_missing",
      "path":  "<relative>",
      "last_known_sha256": "<hex>",
      "recovery_hint":     "git log --all -- <path> 후 restore"
    }
  },
  "refresh": {
    "command": "shared/scripts/refresh_L0_core.hexa",
    "trigger": "intentional_core_edit_after_review",
    "audit":   "commit message 에 L0-REFRESH: <reason> 포함 필수"
  }
}
