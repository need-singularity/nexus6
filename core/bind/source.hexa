#!hexa strict
// nexus/core/bind/source.hexa — BindAxis interface contract (T1 lower-core)
//
// @tool(slug="nexus_bind_source", desc="BindAxis schema contract for nexus side dispatch_framework_v1 conformant subscriber land. Defines BindPayload + BindResult + BindSubscription + BindIssue structs and constructors. Mirrors hive/spec/dispatch_framework_v1.spec.yaml Section 1 event_schema TypedPayload/HandlerResult/Subscription/Issue verbatim. Section 2 handler_contract signature: pub fn on_<axis>_axis_fire(payload: BindPayload) -> BindResult. nexus side downstream consumer per dispatch_framework_v1 consumers.nexus.")
// @sentinel(__NEXUS_BIND_SOURCE_SELFTEST__ <PASS|FAIL>)
// @usage(hexa run nexus/core/bind/source.hexa)
// @resolver-bypass(reason="lib-only-no-side-effect; no remote work")
// @exit_codes(0=ok, 1=selftest_fail)
// @claude-dependency(NONE)
//
// Purpose:
//   Single canonical contract that every nexus bind axis subscriber module
//   (modules/bind/<axis>.hexa) must satisfy. Enables router to dispatch any
//   axis fire event to the matching subscriber without consumer code change.
//   AI-native dogfooding of raw 270/271/272/273 quartet — bind axis schema
//   itself is a plug-in module pattern (sister of hive/closure_format/).
//
// raw#9 hexa-only strict. raw 270/272 conformant 4-canonical-file pattern
// (mirrors hive/core/closure_format/ + hive/core/raw_format/).
//
// CONTRACT (every nexus bind subscriber module must export):
//   pub fn on_<axis>_axis_fire(payload: BindPayload) -> BindResult
//
// We use *_<axis>_axis_fire prefixed function names (axis-name suffix) rather
// than trait dispatch because hexa stage0 has no first-class trait/dyn-call.
// Mirrors hive/core/closure_format/source.hexa convention.
//
// HIVE SPEC CONFORMANCE (hive/spec/dispatch_framework_v1.spec.yaml):
//   Section 1 event_schema:
//     BindPayload   ↔ TypedPayload    (event_type, ts_unix, payload_data, opts)
//     BindResult    ↔ HandlerResult   (success, data, message, exit_code, verdict)
//     BindSubscription ↔ Subscription (id, axis, handler_path, scope)
//     BindIssue     ↔ Issue           (code, severity, message)
//   Section 2 handler_contract:
//     fn(payload: TypedPayload) -> HandlerResult
//     - default timeout 30s, default cost_cap $0.01 USD
//     - return_normalization: empty stdout → success=true verdict=DRY-RUN
//   Section 3 subscription_lifecycle:
//     declarative SSOT: state/active_bindings.hxc
//     imperative CLI:   nexus/core/bind/bind_main.hexa add <axis> <handler>
//
// raw#10 caveats:
//   (1) struct field set is intentionally a SUPERSET of hive Section 1 minimum
//       to allow forward-compat (e.g. cycle_id, prev_score). Mandatory fields
//       (event_type, ts_unix, payload_data) are exact-match.
//   (2) BindResult.verdict free-form: PASS|FAIL|REJECT|DRY-RUN|STUB-FROM-SPEC
//       to align with outside_noise_clm_handler existing sentinel emit set.
//   (3) Stage0 has no first-class trait — registry/router dispatch by string
//       axis name (loose-coupled per raw 273).
//   (4) BindPayload.opts is flat [[k,v]] mirror of hive Subscription.opts —
//       schema-extension forward-compat.
//   (5) struct-only file — no exec, no state read, no remote call.

// ─── BindPayload — input to a subscriber ─────────────────────────────────────

struct BindPayload {
    // axis identifier (e.g. "outside_noise" / "Closure" / "raw_landed")
    event_type:     str,
    // event start timestamp (unix seconds)
    ts_unix:        int,
    // serialized blob (typically JSON or [[k,v]] flat)
    payload_data:   str,
    // optional cycle id (bind: cycle id; hook-bus: session_id)
    cycle_id:       str,
    // optional prev axis score (bind: last AxisScore.value; -1.0 if n/a)
    prev_score:     float,
    // forward-compat flat opts list
    opts:           [[str]]
}

// ─── BindResult — subscriber dispatch outcome ────────────────────────────────

struct BindResult {
    // convenience: verdict in {PASS, DRY-RUN, allow}
    success:        bool,
    // free-form result blob
    data:           str,
    // short human-readable diagnostic
    message:        str,
    // 0 ok | 1 fail | 2 block | 6 fatal_input
    exit_code:      int,
    // PASS | FAIL | REJECT | ERROR | WARN | DRY-RUN | STUB-FROM-SPEC
    verdict:        str,
    // optional duration milliseconds
    duration_ms:    int,
    // optional truncated 300 chars stdout/stderr tail
    tail_snippet:   str
}

// ─── BindSubscription — one axis → handler binding ───────────────────────────

struct BindSubscription {
    // subscription id (typically axis name)
    id:             str,
    // axis identifier
    axis:           str,
    // abs path or repo-rel path to .hexa handler file
    handler_path:   str,
    // one of {axis_loop, event_chain, manual}
    scope_kind:     str,
    // unix seconds of bind time (0 if unknown)
    bound_at:       int,
    // grade letter ("A+" / "A" / ... / "design")
    grade:          str,
    // composite score (0.0-10.0; -1.0 if unknown)
    score:          float,
    // forward-compat flat opts list
    opts:           [[str]],
    // auto-expire ts (0 = no ttl)
    ttl_unix:       int,
    // subscription condition expression ("always" if unset)
    predicate:      str
}

// ─── BindIssue — validation diagnostic ───────────────────────────────────────

struct BindIssue {
    // F-DISPATCH-N or impl-specific code
    code:           str,
    // info | warn | error | block
    severity:       str,
    message:        str,
    axis:           str,
    handler_path:   str
}

// ─── Constructors ────────────────────────────────────────────────────────────

fn bind_payload_make(
    event_type: str, ts_unix: int, payload_data: str,
    cycle_id: str, prev_score: float, opts: [[str]]
) -> BindPayload {
    return BindPayload {
        event_type:   event_type,
        ts_unix:      ts_unix,
        payload_data: payload_data,
        cycle_id:     cycle_id,
        prev_score:   prev_score,
        opts:         opts
    }
}

fn bind_result_make(
    success: bool, data: str, message: str, exit_code: int,
    verdict: str, duration_ms: int, tail_snippet: str
) -> BindResult {
    return BindResult {
        success:      success,
        data:         data,
        message:      message,
        exit_code:    exit_code,
        verdict:      verdict,
        duration_ms:  duration_ms,
        tail_snippet: tail_snippet
    }
}

fn bind_subscription_make(
    id: str, axis: str, handler_path: str, scope_kind: str, bound_at: int,
    grade: str, score: float, opts: [[str]], ttl_unix: int, predicate: str
) -> BindSubscription {
    return BindSubscription {
        id:           id,
        axis:         axis,
        handler_path: handler_path,
        scope_kind:   scope_kind,
        bound_at:     bound_at,
        grade:        grade,
        score:        score,
        opts:         opts,
        ttl_unix:     ttl_unix,
        predicate:    predicate
    }
}

fn bind_issue_make(
    code: str, severity: str, message: str, axis: str, handler_path: str
) -> BindIssue {
    return BindIssue {
        code:         code,
        severity:     severity,
        message:      message,
        axis:         axis,
        handler_path: handler_path
    }
}

// ─── Opts helpers (mirror closure_format conventions) ────────────────────────

fn bind_opts_first(opts: [[str]], key: str) -> str {
    let mut i = 0
    while i < len(opts) {
        let kv = opts[i]
        if len(kv) >= 2 {
            if kv[0] == key { return kv[1] }
        }
        i = i + 1
    }
    return ""
}

fn bind_opts_all(opts: [[str]], key: str) -> [str] {
    let mut out = []
    let mut i = 0
    while i < len(opts) {
        let kv = opts[i]
        if len(kv) >= 2 {
            if kv[0] == key { out.push(kv[1]) }
        }
        i = i + 1
    }
    return out
}

// ─── Selftest ────────────────────────────────────────────────────────────────

fn _selftest_source() -> int {
    let opts1 = [["timeout_sec", "30"], ["cost_cap_usd", "0.01"]]
    let p = bind_payload_make("outside_noise", 1777800000, "{\"cycle\":1}", "c1", -1.0, opts1)
    if p.event_type != "outside_noise" { return 0 }
    if p.ts_unix != 1777800000 { return 0 }
    if p.cycle_id != "c1" { return 0 }
    if bind_opts_first(opts1, "timeout_sec") != "30" { return 0 }
    if bind_opts_first(opts1, "missing") != "" { return 0 }

    let r = bind_result_make(true, "{\"primitive_id\":\"p_c1_concept\"}", "ok", 0, "PASS", 1234, "snippet")
    if r.verdict != "PASS" { return 0 }
    if r.exit_code != 0 { return 0 }
    if !r.success { return 0 }

    let s = bind_subscription_make("outside_noise", "outside_noise", "/abs/handler.hexa", "axis_loop", 1777800000, "A", 0.85, opts1, 0, "always")
    if s.scope_kind != "axis_loop" { return 0 }
    if s.predicate != "always" { return 0 }

    let i = bind_issue_make("F-DISPATCH-1", "error", "missing typed signature", "outside_noise", "/abs/handler.hexa")
    if i.code != "F-DISPATCH-1" { return 0 }
    if i.severity != "error" { return 0 }

    let all_opts = bind_opts_all(opts1, "timeout_sec")
    if len(all_opts) != 1 { return 0 }

    return 1
}

fn main() {
    let ok = _selftest_source()
    if ok == 1 {
        println("__NEXUS_BIND_SOURCE_SELFTEST__ PASS")
    } else {
        println("__NEXUS_BIND_SOURCE_SELFTEST__ FAIL")
        exit(1)
    }
}
