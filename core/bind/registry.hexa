#!hexa strict
// nexus/core/bind/registry.hexa — active bind axes registry (T1)
//
// @tool(slug="nexus_bind_registry", desc="BindAxis registry: priority-ordered list of active bind axes registered for nexus side dispatch_framework_v1 conformant subscribers. Reads state/active_bindings.hxc declarative SSOT (raw 270/272 conformant). Each entry is (axis_name, BindSubscription) pair built via bind_subscription_make from source. Loose-coupled — modules NOT imported here per raw 273 stage0 fn-pointer absence; router does the call dispatch.")
// @sentinel(__NEXUS_BIND_REGISTRY_SELFTEST__ <PASS|FAIL>)
// @usage(hexa run nexus/core/bind/registry.hexa [--selftest])
// @resolver-bypass(reason="lib-only-no-side-effect; reads state file in-memory only")
// @exit_codes(0=ok, 1=selftest_fail)
// @claude-dependency(NONE)
//
// raw#9 hexa-only strict. raw 270/272/273 conformant.
//
// State file (declarative SSOT, dispatch_framework_v1 Section 3):
//   nexus/state/active_bindings.hxc
//   format: line-based, one binding per line:
//     bind axis=<name> handler=<path> scope=<axis_loop|event_chain|manual> grade=<G> ttl=<unix> predicate=<expr>
//   comments start with #
//
// raw#10:
//   (1) Default registry built-in fallback ([outside_noise]) — if state file
//       missing, returns the canonical baseline binding for outside_noise axis.
//       File-driven SSOT activates when nexus/state/active_bindings.hxc exists.
//   (2) Each registry entry is a (axis, BindSubscription) pair built via
//       bind_subscription_make from source.hexa — NO module file is imported
//       here (loose-coupling per raw 273).
//   (3) Stage0 has no first-class trait — registry returns array of structs;
//       router does the actual call dispatch by string axis name.
//   (4) State file parsing is grep-style line scan (key=value space-separated).
//       Full nested parser deferred. Comments lines starting with # ignored.
//   (5) Read-only — registry NEVER writes state file. Subscribe/unsubscribe
//       writes via bind_main.hexa imperative CLI (not yet impl this BG).
//   (6) Optional `inprocess=true|false` field (additive, default false for
//       back-compat) — when true, router consults inproc_dispatch table first
//       for ~800ms hexa-init avoidance. Stored in BindSubscription.opts as
//       [["inprocess","true"]] (no struct field change → source.hexa untouched).

use "source"

// ─── State file path (canonical) ─────────────────────────────────────────────

fn _home() -> str {
    let h = env_var("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _state_path() -> str {
    return _home() + "/core/nexus/state/active_bindings.hxc"
}

fn _shq(s: str) -> str {
    let mut r = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "'" { r = r + "'\\''" } else { r = r + c }
        i = i + 1
    }
    return "'" + r + "'"
}

fn _file_exists(path: str) -> bool {
    let cmd = "test -f " + _shq(path) + " && echo Y || echo N"
    let r = to_string(exec(cmd)).trim()
    if r == "Y" { return true }
    return false
}

// ─── Parse one bind line: bind axis=X handler=Y scope=Z ... ──────────────────

fn _parse_kv(line: str, key: str) -> str {
    let needle = key + "="
    let kp = line.index_of(needle)
    if kp < 0 { return "" }
    let after = line.substring(kp + len(needle), len(line))
    // value terminates at first whitespace or end
    let mut i = 0
    let n = len(after)
    while i < n {
        let c = after.substring(i, i + 1)
        if c == " " || c == "\t" || c == "\n" { break }
        i = i + 1
    }
    return after.substring(0, i)
}

// ─── Built-in default baseline (no state file) ───────────────────────────────

fn _default_baseline() -> [BindSubscription] {
    let mut out = []
    // baseline: inprocess=false (back-compat — explicit opt-in only)
    let opts0 = [["timeout_sec", "30"], ["cost_cap_usd", "0.01"], ["inprocess", "false"]]
    out.push(bind_subscription_make(
        "outside_noise",                                                   // id
        "outside_noise",                                                   // axis
        "/Users/<user>/core/nexus/tool/handlers/outside_noise_clm_handler.hexa",  // handler
        "axis_loop",                                                       // scope_kind
        0,                                                                 // bound_at (unset)
        "design",                                                          // grade
        -1.0,                                                              // score
        opts0,                                                             // opts
        0,                                                                 // ttl_unix (no ttl)
        "always"                                                           // predicate
    ))
    return out
}

// helper — opts derived from `inprocess=` parse on a registry line
fn _opts_from_inprocess(inprocess_v: str) -> [[str]] {
    let mut o = []
    if len(inprocess_v) > 0 {
        if inprocess_v == "true" {
            o.push(["inprocess", "true"])
        } else {
            o.push(["inprocess", "false"])
        }
    } else {
        o.push(["inprocess", "false"])
    }
    return o
}

// ─── Load registry from state file (or fallback to baseline) ─────────────────

pub fn nexus_bind_registry_default() -> [BindSubscription] {
    let path = _state_path()
    if !_file_exists(path) {
        return _default_baseline()
    }
    let raw = to_string(exec("cat " + _shq(path) + " 2>/dev/null"))
    let mut out = []
    let mut start = 0
    let mut i = 0
    let n = len(raw)
    while i < n {
        let c = raw.substring(i, i + 1)
        if c == "\n" {
            let line = raw.substring(start, i).trim()
            if len(line) > 0 {
                let first = line.substring(0, 1)
                if first != "#" && line.index_of("bind ") == 0 {
                    let axis = _parse_kv(line, "axis")
                    let handler = _parse_kv(line, "handler")
                    let scope_v = _parse_kv(line, "scope")
                    let grade = _parse_kv(line, "grade")
                    let ttl_s = _parse_kv(line, "ttl")
                    let pred = _parse_kv(line, "predicate")
                    let inproc_v = _parse_kv(line, "inprocess")
                    let mut ttl_n = 0
                    if len(ttl_s) > 0 { ttl_n = to_int(ttl_s) }
                    let mut g = "design"
                    if len(grade) > 0 { g = grade }
                    let mut p = "always"
                    if len(pred) > 0 { p = pred }
                    let mut sk = "axis_loop"
                    if len(scope_v) > 0 { sk = scope_v }
                    let opts_line = _opts_from_inprocess(inproc_v)
                    if len(axis) > 0 && len(handler) > 0 {
                        out.push(bind_subscription_make(
                            axis, axis, handler, sk, 0, g, -1.0, opts_line, ttl_n, p
                        ))
                    }
                }
            }
            start = i + 1
        }
        i = i + 1
    }
    if start < n {
        let last = raw.substring(start, n).trim()
        if len(last) > 0 {
            let first = last.substring(0, 1)
            if first != "#" && last.index_of("bind ") == 0 {
                let axis = _parse_kv(last, "axis")
                let handler = _parse_kv(last, "handler")
                let scope_v = _parse_kv(last, "scope")
                let grade = _parse_kv(last, "grade")
                let ttl_s = _parse_kv(last, "ttl")
                let pred = _parse_kv(last, "predicate")
                let inproc_v = _parse_kv(last, "inprocess")
                let mut ttl_n = 0
                if len(ttl_s) > 0 { ttl_n = to_int(ttl_s) }
                let mut g = "design"
                if len(grade) > 0 { g = grade }
                let mut p = "always"
                if len(pred) > 0 { p = pred }
                let mut sk = "axis_loop"
                if len(scope_v) > 0 { sk = scope_v }
                let opts_line = _opts_from_inprocess(inproc_v)
                if len(axis) > 0 && len(handler) > 0 {
                    out.push(bind_subscription_make(
                        axis, axis, handler, sk, 0, g, -1.0, opts_line, ttl_n, p
                    ))
                }
            }
        }
    }
    if len(out) == 0 { return _default_baseline() }
    return out
}

// ─── Lookup: axis name → BindSubscription (empty axis "" if not registered) ──

pub fn nexus_bind_registry_lookup(axis: str) -> BindSubscription {
    let reg = nexus_bind_registry_default()
    let mut i = 0
    while i < len(reg) {
        let s = reg[i]
        if s.axis == axis { return s }
        i = i + 1
    }
    return bind_subscription_make("", "", "", "", 0, "missing", -1.0, [], 0, "")
}

// ─── Lookup: in-process flag for an axis (false if absent) ───────────────────

pub fn nexus_bind_registry_inprocess(axis: str) -> bool {
    let s = nexus_bind_registry_lookup(axis)
    if s.grade == "missing" { return false }
    let mut i = 0
    while i < len(s.opts) {
        let kv = s.opts[i]
        if len(kv) >= 2 {
            if kv[0] == "inprocess" {
                if kv[1] == "true" { return true }
                return false
            }
        }
        i = i + 1
    }
    return false
}

// ─── Lookup: which axes are currently registered ─────────────────────────────

pub fn nexus_bind_registry_active_axes() -> [str] {
    let reg = nexus_bind_registry_default()
    let mut out = []
    let mut i = 0
    while i < len(reg) {
        out.push(reg[i].axis)
        i = i + 1
    }
    return out
}

// ─── Selftest ────────────────────────────────────────────────────────────────

fn _selftest_registry() -> int {
    let reg = nexus_bind_registry_default()
    if len(reg) < 1 { return 0 }
    // baseline OR file MUST contain outside_noise as registered axis
    let s = nexus_bind_registry_lookup("outside_noise")
    if s.axis != "outside_noise" { return 0 }
    if s.scope_kind != "axis_loop" { return 0 }
    if s.predicate != "always" { return 0 }

    let s_missing = nexus_bind_registry_lookup("nonexistent_axis_xyz")
    if s_missing.grade != "missing" { return 0 }

    let active = nexus_bind_registry_active_axes()
    if len(active) < 1 { return 0 }
    // outside_noise MUST appear in active list
    let mut found = false
    let mut i = 0
    while i < len(active) {
        if active[i] == "outside_noise" { found = true; break }
        i = i + 1
    }
    if !found { return 0 }

    // inprocess flag default = false (back-compat baseline) OR true (state file
    // explicitly opts in). Both honest. Just verify the helper does NOT crash
    // and returns a bool for both registered + missing axes.
    let _ip_known = nexus_bind_registry_inprocess("outside_noise")
    let ip_unknown = nexus_bind_registry_inprocess("nonexistent_xyz")
    if ip_unknown { return 0 }

    return 1
}

fn main() {
    let ok = _selftest_registry()
    if ok == 1 {
        let active = nexus_bind_registry_active_axes()
        println("__NEXUS_BIND_REGISTRY_SELFTEST__ PASS active_axes=" + to_string(len(active)))
    } else {
        println("__NEXUS_BIND_REGISTRY_SELFTEST__ FAIL")
        exit(1)
    }
}
