#!hexa strict
// nexus/core/atlas_n6/source.hexa — atlas_n6 backend abstract interface
//
// @tool(slug="atlas_n6_source", desc="canonical contract every atlas_n6 backend must satisfy. Allows the router to swap backends via config without touching consumer code.")
// @usage(hexa run nexus/core/atlas_n6/source.hexa --selftest)
// @sentinel(__ATLAS_N6_SOURCE__ <PASS|FAIL>)
// @resolver-bypass(reason="stage0 self-contained — pure constructors + selftest.")
//
// Domain: n6 architecture atlas + paradigm convergence (.roadmap.atlas_n6).
// Backends wrap nexus/tool/{atlas_absorb_hook, lens_atlas_orchestrator, omega_cycle_atlas_ingest, atlas_quick}.hexa.
//
// CONTRACT:
//   fn atlas_n6_source_meta_<name>() -> AtlasN6SourceMeta
//   fn atlas_n6_source_dispatch_<name>(req: AtlasN6Request) -> AtlasN6Result
//
// PRESERVED FILES (audit at land time):
//   nexus/tool/atlas_absorb_hook.hexa        (raw 80 hook entrypoint, 206 LOC)
//   nexus/tool/lens_atlas_orchestrator.hexa  (orchestrator, 834 LOC)
//   nexus/tool/omega_cycle_atlas_ingest.hexa (ingest, 952 LOC)
//   nexus/tool/atlas_quick.hexa              (quick scan)
//
// raw#9 hexa-only strict. raw#10:
//   (1) Modules wrap, no port; deep impl is multi-week per backend.
//   (2) `op` field is dispatch verb: "absorb" | "audit" | "query" | "diff".
//   (3) Witness path semantics SSOT lives in omega_cycle_atlas_ingest.hexa.

struct AtlasN6Request {
    op:           str,    // "absorb" | "audit" | "query" | "diff"
    witness_path: str,    // input path for absorb; query target for audit/query
    source_slug:  str,    // emitter slug (kick_dispatch, hexa_sim, ...)
    dry_run:      int     // 1 → no exec, 0 → real
}

struct AtlasN6SourceMeta {
    name:           str,
    tier:           int,   // 0..3 (0=local-stub, 1=hook, 2=orchestrator, 3=ingest)
    cost_usd:       int,
    lead_days:      int,
    is_local:       int,
    is_canonical:   int,
    status:         str,
    vendor:         str
}

struct AtlasN6Result {
    ok:           int,
    sentinel:     str,    // raw 80 sentinel from wrapped tool
    op:           str,
    rows_written: int,    // ingest rows / audit rows
    message:      str
}

fn atlas_n6_meta_make(
    name: str, tier: int, cost_usd: int, lead_days: int,
    is_local: int, is_canonical: int, status: str, vendor: str
) -> AtlasN6SourceMeta {
    return AtlasN6SourceMeta {
        name: name, tier: tier, cost_usd: cost_usd, lead_days: lead_days,
        is_local: is_local, is_canonical: is_canonical, status: status, vendor: vendor
    }
}

fn atlas_n6_request_make(op: str, witness_path: str) -> AtlasN6Request {
    return AtlasN6Request {
        op: op, witness_path: witness_path,
        source_slug: "", dry_run: 0
    }
}

fn atlas_n6_result_fail(reason: str) -> AtlasN6Result {
    return AtlasN6Result { ok: 0, sentinel: "", op: "", rows_written: 0, message: reason }
}

fn atlas_n6_result_ok(sentinel: str, op: str, rows: int, msg: str) -> AtlasN6Result {
    return AtlasN6Result { ok: 1, sentinel: sentinel, op: op, rows_written: rows, message: msg }
}

fn _selftest_source() -> int {
    let m = atlas_n6_meta_make("atlas_absorb", 1, 0, 0, 1, 1, "WRAPPED", "atlas_absorb_hook")
    if m.name != "atlas_absorb" { return 0 }
    if m.tier != 1 { return 0 }
    let r = atlas_n6_request_make("absorb", "/tmp/witness.json")
    if r.op != "absorb" { return 0 }
    let f = atlas_n6_result_fail("test_fail")
    if f.ok != 0 { return 0 }
    let s = atlas_n6_result_ok("__ATLAS__ PASS", "absorb", 1, "ok")
    if s.ok != 1 { return 0 }
    return 1
}

fn main() {
    println("[atlas_n6/source] interface contract self-test")
    if _selftest_source() == 1 {
        println("[atlas_n6/source] SELFTEST PASS")
        println("__ATLAS_N6_SOURCE__ PASS")
    } else {
        println("[atlas_n6/source] SELFTEST FAIL")
        println("__ATLAS_N6_SOURCE__ FAIL")
    }
}
