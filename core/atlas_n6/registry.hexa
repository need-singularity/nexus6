#!hexa strict
// nexus/core/atlas_n6/registry.hexa — atlas_n6 backend registry
//
// @tool(slug="atlas_n6_registry", desc="switch dispatch over canonical atlas_n6 backend names.")
// @usage(hexa run nexus/core/atlas_n6/registry.hexa --selftest)
// @sentinel(__ATLAS_N6_REGISTRY__ <PASS|FAIL>)
// @resolver-bypass(reason="meta-only paths in selftest.")
//
// REGISTERED BACKENDS (4):
//   atlas_absorb     — atlas_absorb_hook.hexa wrapper        (WRAPPED, T1)
//   atlas_audit      — atlas_quick.hexa wrapper              (WRAPPED, T1)
//   atlas_query      — lens_atlas_orchestrator.hexa wrapper  (WRAPPED, T2)
//   atlas_diff       — omega_cycle_atlas_ingest.hexa wrapper (WRAPPED, T3)

struct AtlasN6Request {
    op:           str,
    witness_path: str,
    source_slug:  str,
    dry_run:      int
}

struct AtlasN6SourceMeta {
    name:           str,
    tier:           int,
    cost_usd:       int,
    lead_days:      int,
    is_local:       int,
    is_canonical:   int,
    status:         str,
    vendor:         str
}

struct AtlasN6Result {
    ok:           int,
    sentinel:     str,
    op:           str,
    rows_written: int,
    message:      str
}

fn atlas_n6_meta_make(
    name: str, tier: int, cost_usd: int, lead_days: int,
    is_local: int, is_canonical: int, status: str, vendor: str
) -> AtlasN6SourceMeta {
    return AtlasN6SourceMeta {
        name: name, tier: tier, cost_usd: cost_usd, lead_days: lead_days,
        is_local: is_local, is_canonical: is_canonical, status: status, vendor: vendor
    }
}

fn atlas_n6_result_fail(reason: str) -> AtlasN6Result {
    return AtlasN6Result { ok: 0, sentinel: "", op: "", rows_written: 0, message: reason }
}

fn atlas_n6_result_ok(sentinel: str, op: str, rows: int, msg: str) -> AtlasN6Result {
    return AtlasN6Result { ok: 1, sentinel: sentinel, op: op, rows_written: rows, message: msg }
}

fn atlas_n6_registry_names() -> [str] {
    let mut a = []
    a = a.push("atlas_absorb")
    a = a.push("atlas_audit")
    a = a.push("atlas_query")
    a = a.push("atlas_diff")
    return a
}

fn atlas_n6_registry_meta(name: str) -> AtlasN6SourceMeta {
    if name == "atlas_absorb" { return atlas_n6_meta_make("atlas_absorb", 1, 0, 0, 1, 1, "WRAPPED", "nexus/tool/atlas_absorb_hook.hexa_206LOC") }
    if name == "atlas_audit" { return atlas_n6_meta_make("atlas_audit", 1, 0, 0, 1, 1, "WRAPPED", "nexus/tool/atlas_quick.hexa") }
    if name == "atlas_query" { return atlas_n6_meta_make("atlas_query", 2, 0, 0, 1, 1, "WRAPPED", "nexus/tool/lens_atlas_orchestrator.hexa_834LOC") }
    if name == "atlas_diff" { return atlas_n6_meta_make("atlas_diff", 3, 0, 0, 1, 1, "WRAPPED", "nexus/tool/omega_cycle_atlas_ingest.hexa_952LOC") }
    return atlas_n6_meta_make(name, -1, 0, 0, 0, 0, "UNKNOWN", "")
}

fn atlas_n6_registry_dispatch(name: str, req: AtlasN6Request) -> AtlasN6Result {
    if name == "atlas_absorb" {
        if req.dry_run == 1 {
            return atlas_n6_result_ok("__ATLAS_ABSORB__ DRY witness=" + req.witness_path, "absorb", 0, "atlas_absorb: dry-run")
        }
        return atlas_n6_result_fail("atlas_absorb: live exec deferred to wrapper module (modules/atlas_n6/atlas_absorb.hexa)")
    }
    if name == "atlas_audit" {
        if req.dry_run == 1 {
            return atlas_n6_result_ok("__ATLAS_AUDIT__ DRY", "audit", 0, "atlas_audit: dry-run")
        }
        return atlas_n6_result_fail("atlas_audit: live exec deferred to wrapper module")
    }
    if name == "atlas_query" {
        if req.dry_run == 1 {
            return atlas_n6_result_ok("__ATLAS_QUERY__ DRY", "query", 0, "atlas_query: dry-run")
        }
        return atlas_n6_result_fail("atlas_query: live exec deferred to wrapper module")
    }
    if name == "atlas_diff" {
        if req.dry_run == 1 {
            return atlas_n6_result_ok("__ATLAS_DIFF__ DRY", "diff", 0, "atlas_diff: dry-run")
        }
        return atlas_n6_result_fail("atlas_diff: live exec deferred to wrapper module")
    }
    return atlas_n6_result_fail("unknown backend: " + name)
}

fn _selftest() -> int {
    let names = atlas_n6_registry_names()
    if len(names) != 4 { return 0 }
    let mut i = 0
    while i < len(names) {
        let m = atlas_n6_registry_meta(names[i])
        if m.name != names[i] { return 0 }
        if m.tier < 0 { return 0 }
        if len(m.status) < 1 { return 0 }
        i = i + 1
    }
    let m_x = atlas_n6_registry_meta("nonexistent")
    if m_x.tier != -1 { return 0 }
    let req = AtlasN6Request { op: "absorb", witness_path: "/tmp/w.json", source_slug: "smoke", dry_run: 1 }
    let r1 = atlas_n6_registry_dispatch("atlas_absorb", req)
    if r1.ok != 1 { return 0 }
    let req2 = AtlasN6Request { op: "absorb", witness_path: "/tmp/w.json", source_slug: "smoke", dry_run: 0 }
    let r2 = atlas_n6_registry_dispatch("atlas_absorb", req2)
    if r2.ok != 0 { return 0 }
    return 1
}

fn main() {
    println("[atlas_n6/registry] 4-backend dispatch table")
    if _selftest() == 1 {
        println("[atlas_n6/registry] SELFTEST PASS")
        println("__ATLAS_N6_REGISTRY__ PASS")
    } else {
        println("[atlas_n6/registry] SELFTEST FAIL")
        println("__ATLAS_N6_REGISTRY__ FAIL")
    }
}
