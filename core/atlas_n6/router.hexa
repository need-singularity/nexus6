#!hexa strict
// nexus/core/atlas_n6/router.hexa — config-driven atlas_n6 backend selection + fallback
//
// @tool(slug="atlas_n6_router", desc="config + env priority router for atlas_n6 backends. Reads NEXUS_ATLAS_N6_SOURCE / NEXUS_ATLAS_N6_FALLBACK_CHAIN.")
// @usage(hexa run nexus/core/atlas_n6/router.hexa --selftest)
// @sentinel(__ATLAS_N6_ROUTER__ <PASS|FAIL>)
// @resolver-bypass(reason="dry-run only in selftest.")
//
// Default chain: atlas_absorb → atlas_audit → atlas_query

struct AtlasN6Request {
    op:           str,
    witness_path: str,
    source_slug:  str,
    dry_run:      int
}

struct AtlasN6Result {
    ok:           int,
    sentinel:     str,
    op:           str,
    rows_written: int,
    message:      str
}

fn atlas_n6_result_fail(reason: str) -> AtlasN6Result {
    return AtlasN6Result { ok: 0, sentinel: "", op: "", rows_written: 0, message: reason }
}

fn atlas_n6_result_ok(sentinel: str, op: str, rows: int, msg: str) -> AtlasN6Result {
    return AtlasN6Result { ok: 1, sentinel: sentinel, op: op, rows_written: rows, message: msg }
}

fn _route_dispatch(name: str, req: AtlasN6Request) -> AtlasN6Result {
    if name == "atlas_absorb" {
        if req.dry_run == 1 { return atlas_n6_result_ok("__ATLAS_ABSORB__ DRY", "absorb", 0, "atlas_absorb: ok") }
        return atlas_n6_result_fail("atlas_absorb: live deferred to wrapper module")
    }
    if name == "atlas_audit" {
        if req.dry_run == 1 { return atlas_n6_result_ok("__ATLAS_AUDIT__ DRY", "audit", 0, "atlas_audit: ok") }
        return atlas_n6_result_fail("atlas_audit: live deferred to wrapper module")
    }
    if name == "atlas_query" {
        if req.dry_run == 1 { return atlas_n6_result_ok("__ATLAS_QUERY__ DRY", "query", 0, "atlas_query: ok") }
        return atlas_n6_result_fail("atlas_query: live deferred to wrapper module")
    }
    if name == "atlas_diff" {
        if req.dry_run == 1 { return atlas_n6_result_ok("__ATLAS_DIFF__ DRY", "diff", 0, "atlas_diff: ok") }
        return atlas_n6_result_fail("atlas_diff: live deferred to wrapper module")
    }
    return atlas_n6_result_fail("unknown backend: " + name)
}

fn atlas_n6_default_chain() -> [str] {
    let mut a = []
    a = a.push("atlas_absorb")
    a = a.push("atlas_audit")
    a = a.push("atlas_query")
    return a
}

fn atlas_n6_resolve_chain() -> [str] {
    let single = exec("printenv NEXUS_ATLAS_N6_SOURCE 2>/dev/null || true").trim()
    if len(single) > 0 {
        let mut a = []
        a = a.push(single)
        return a
    }
    let chain = exec("printenv NEXUS_ATLAS_N6_FALLBACK_CHAIN 2>/dev/null || true").trim()
    if len(chain) > 0 {
        let parts = chain.split(",")
        let mut a = []
        let mut i = 0
        while i < len(parts) {
            let p = parts[i].trim()
            if len(p) > 0 { a = a.push(p) }
            i = i + 1
        }
        if len(a) > 0 { return a }
    }
    return atlas_n6_default_chain()
}

struct AtlasN6RouteResult {
    final_backend: str,
    attempts:      [str],
    reasons:       [str],
    result:        AtlasN6Result
}

fn atlas_n6_route_dispatch(req: AtlasN6Request) -> AtlasN6RouteResult {
    let chain = atlas_n6_resolve_chain()
    let mut attempts = []
    let mut reasons = []
    let mut i = 0
    while i < len(chain) {
        let name = chain[i]
        attempts = attempts.push(name)
        let r = _route_dispatch(name, req)
        if r.ok == 1 {
            reasons = reasons.push("ok")
            return AtlasN6RouteResult { final_backend: name, attempts: attempts, reasons: reasons, result: r }
        }
        reasons = reasons.push(r.message)
        i = i + 1
    }
    return AtlasN6RouteResult { final_backend: "", attempts: attempts, reasons: reasons, result: atlas_n6_result_fail("router: all backends failed") }
}

fn _selftest() -> int {
    let dc = atlas_n6_default_chain()
    if len(dc) != 3 { return 0 }
    if dc[0] != "atlas_absorb" { return 0 }
    let req = AtlasN6Request { op: "absorb", witness_path: "/tmp/w.json", source_slug: "smoke", dry_run: 1 }
    let r1 = _route_dispatch("atlas_absorb", req)
    if r1.ok != 1 { return 0 }
    let r2 = _route_dispatch("not_a_backend", req)
    if r2.ok != 0 { return 0 }
    let route = atlas_n6_route_dispatch(req)
    if route.result.ok != 1 { return 0 }
    return 1
}

fn main() {
    println("[atlas_n6/router] config-driven backend selection + fallback chain")
    if _selftest() == 1 {
        println("[atlas_n6/router] SELFTEST PASS")
        println("__ATLAS_N6_ROUTER__ PASS")
    } else {
        println("[atlas_n6/router] SELFTEST FAIL")
        println("__ATLAS_N6_ROUTER__ FAIL")
    }
    let req = AtlasN6Request { op: "absorb", witness_path: "/tmp/demo.json", source_slug: "demo", dry_run: 1 }
    let route = atlas_n6_route_dispatch(req)
    println("[atlas_n6/router] route_dispatch demo")
    println("[atlas_n6/router]   attempts=" + str(len(route.attempts)) + " final_backend=" + route.final_backend)
}
