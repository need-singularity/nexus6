#!hexa strict
// nexus/core/kick/source.hexa — kick(ω-cycle) backend source abstract interface
//
// @tool(slug="kick_source", desc="canonical contract every kick backend module must satisfy. Allows the router to swap backends via config without touching consumer code.")
// @usage(hexa run nexus/core/kick/source.hexa --selftest)
// @sentinel(__KICK_SOURCE__ <PASS|FAIL>)
// @resolver-bypass(reason="stage0 self-contained — no exec to host; pure constructors + selftest.")
//
// Purpose:
//   SSOT struct + helper definitions. Per-module files (modules/kick/*.hexa)
//   inline these structs (no `use`/`import` in hexa stage0).
//
// CONTRACT (every backend module exports):
//   fn kick_source_meta_<name>() -> KickSourceMeta
//   fn kick_source_dispatch_<name>(req: KickRequest) -> KickResult
//
// PRESERVED FILES (audit at land time, MUST remain byte-identical):
//   nexus/tool/kick_dispatch.hexa     (canonical dispatcher; modules wrap, not migrate)
//   nexus/tool/kick_parallel.hexa     (parallel kick driver)
//   nexus/tool/kick_tree.hexa         (kick tree visitor)
//   nexus/tool/kick_bench.hexa        (kick benchmark)
//
// raw#9 hexa-only strict. raw#10 caveats:
//   (1) Modules that wrap existing dispatchers exec the dispatcher binary;
//       deep-impl ports are scheduled per-module separate cycle.
//   (2) Sentinel emission and witness JSON shape SSOT lives in kick_dispatch.hexa.
//   (3) `routes` field is informational; router.hexa owns the routing decision.
//
// ─── KickRequest ───────────────────────────────────────────

struct KickRequest {
    topic:        str,    // free-form goal text
    backend:      str,    // canonical short id (matches a module name)
    stratum:      str,    // optional stratum hint ("project" | "system" | "")
    axes:         [str],  // comma-separated axes the dispatcher should probe
    noise_modes:  [str],  // subset of {"alpha","beta","gamma"} or empty
    parent_sid:   str,    // raw 44 parent session id (or "")
    dry_run:      int     // 1 → no spawn, 0 → real spawn
}

// ─── KickSourceMeta ────────────────────────────────────────

struct KickSourceMeta {
    name:           str,   // canonical id, snake_case
    tier:           int,   // 0..3 (0=local-stub, 1=nexus-canonical, 2=mac-host, 3=remote-claude)
    cost_usd:       int,   // per-call cost upper bound (0 = free local)
    lead_days:      int,   // setup time before backend is live
    is_local:       int,   // 1 = no network, 0 = remote
    is_canonical:   int,   // 1 = SSOT dispatcher, 0 = wrapper variant
    status:         str,   // "IMPLEMENTED" | "WRAPPED" | "STUB"
    vendor:         str    // free-form provider label
}

// ─── KickResult ────────────────────────────────────────────

struct KickResult {
    ok:           int,   // 1 = success, 0 = failure
    witness_path: str,   // absolute path to witness JSON when ok=1
    sentinel:     str,   // raw 80 sentinel line (or "")
    tier1_count:  int,   // tier-1 candidates produced
    falsifier_pass: int, // falsifier pass count
    message:      str    // human-readable diagnostic
}

// ─── Helpers ───────────────────────────────────────────────

fn kick_meta_make(
    name: str, tier: int, cost_usd: int, lead_days: int,
    is_local: int, is_canonical: int, status: str, vendor: str
) -> KickSourceMeta {
    return KickSourceMeta {
        name:         name,
        tier:         tier,
        cost_usd:     cost_usd,
        lead_days:    lead_days,
        is_local:     is_local,
        is_canonical: is_canonical,
        status:       status,
        vendor:       vendor
    }
}

fn kick_request_make(topic: str, backend: str) -> KickRequest {
    return KickRequest {
        topic:       topic,
        backend:     backend,
        stratum:     "",
        axes:        [],
        noise_modes: [],
        parent_sid:  "",
        dry_run:     0
    }
}

fn kick_result_fail(reason: str) -> KickResult {
    return KickResult {
        ok:           0,
        witness_path: "",
        sentinel:     "",
        tier1_count:  0,
        falsifier_pass: 0,
        message:      reason
    }
}

fn kick_result_ok(witness_path: str, sentinel: str, t1: int, fp: int, msg: str) -> KickResult {
    return KickResult {
        ok:           1,
        witness_path: witness_path,
        sentinel:     sentinel,
        tier1_count:  t1,
        falsifier_pass: fp,
        message:      msg
    }
}

// ─── Selftest ──────────────────────────────────────────────

fn _selftest_source() -> int {
    let m = kick_meta_make("nexus_kick", 1, 0, 0, 1, 1, "IMPLEMENTED", "nexus_canonical")
    if m.name != "nexus_kick" { return 0 }
    if m.tier != 1 { return 0 }
    if m.is_canonical != 1 { return 0 }
    let r = kick_request_make("test topic", "nexus_kick")
    if r.topic != "test topic" { return 0 }
    if r.dry_run != 0 { return 0 }
    let f = kick_result_fail("test_fail")
    if f.ok != 0 { return 0 }
    let s = kick_result_ok("/tmp/w.json", "__KICK__ PASS", 3, 2, "ok")
    if s.ok != 1 { return 0 }
    if s.tier1_count != 3 { return 0 }
    return 1
}

fn main() {
    println("[kick/source] interface contract self-test")
    if _selftest_source() == 1 {
        println("[kick/source] SELFTEST PASS")
        println("__KICK_SOURCE__ PASS")
    } else {
        println("[kick/source] SELFTEST FAIL")
        println("__KICK_SOURCE__ FAIL")
    }
}
