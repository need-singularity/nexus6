#!hexa strict
// nexus/core/kick/registry.hexa — kick backend registry (name → dispatch)
//
// @tool(slug="kick_registry", desc="switch-style dispatch over canonical kick backend names. Each branch builds the inline backend invocation (mirrors per-module file).")
// @usage(hexa run nexus/core/kick/registry.hexa --selftest)
// @sentinel(__KICK_REGISTRY__ <PASS|FAIL>)
// @resolver-bypass(reason="self-contained — meta dispatch is pure; dispatch leaf may exec but selftest exercises only meta + dry-run paths.")
//
// REGISTERED BACKENDS (4):
//   nexus_kick        — canonical kick_dispatch.hexa wrapper           (WRAPPED,    T1)
//   mac_kick          — mac-host claude wrapper                        (WRAPPED,    T2)
//   claude_kick       — anthropic claude CLI / API kick (mock-default) (IMPLEMENTED, T3)
//   dispatch_router   — pure routing helper (no spawn; selftest hook)  (IMPLEMENTED, T0)
//
// raw#9 hexa-only strict. raw#10:
//   (1) `nexus_kick` dispatch is exec("hexa.real ... kick_dispatch.hexa ...");
//       deep-impl native port deferred (the dispatcher itself is 3496 LOC).
//   (2) `mac_kick` and `claude_kick` are WRAPPED/STUB pending host-side claude
//       integration audit (raw 47 host-pin marker policy).
//   (3) `dispatch_router` is selftest-only — a real router lives in router.hexa
//       at this same level; this entry verifies registry can hold a no-spawn
//       backend for CI (avoids subagent spawn during smoke).

// ── struct mirror (SSOT: nexus/core/kick/source.hexa) ────────

struct KickRequest {
    topic:        str,
    backend:      str,
    stratum:      str,
    axes:         [str],
    noise_modes:  [str],
    parent_sid:   str,
    dry_run:      int
}

struct KickSourceMeta {
    name:           str,
    tier:           int,
    cost_usd:       int,
    lead_days:      int,
    is_local:       int,
    is_canonical:   int,
    status:         str,
    vendor:         str
}

struct KickResult {
    ok:           int,
    witness_path: str,
    sentinel:     str,
    tier1_count:  int,
    falsifier_pass: int,
    message:      str
}

fn kick_meta_make(
    name: str, tier: int, cost_usd: int, lead_days: int,
    is_local: int, is_canonical: int, status: str, vendor: str
) -> KickSourceMeta {
    return KickSourceMeta {
        name: name, tier: tier, cost_usd: cost_usd, lead_days: lead_days,
        is_local: is_local, is_canonical: is_canonical, status: status, vendor: vendor
    }
}

fn kick_result_fail(reason: str) -> KickResult {
    return KickResult { ok: 0, witness_path: "", sentinel: "", tier1_count: 0, falsifier_pass: 0, message: reason }
}

fn kick_result_ok(witness_path: str, sentinel: str, t1: int, fp: int, msg: str) -> KickResult {
    return KickResult { ok: 1, witness_path: witness_path, sentinel: sentinel, tier1_count: t1, falsifier_pass: fp, message: msg }
}

// ── Registered names (SSOT for list_available) ──────────────

fn kick_registry_names() -> [str] {
    let mut a = []
    a = a.push("nexus_kick")
    a = a.push("mac_kick")
    a = a.push("claude_kick")
    a = a.push("dispatch_router")
    return a
}

// ── Meta dispatch ──────────────────────────────────────────

fn kick_registry_meta(name: str) -> KickSourceMeta {
    if name == "nexus_kick" {
        return kick_meta_make("nexus_kick", 1, 0, 0, 1, 1, "WRAPPED", "nexus/tool/kick_dispatch.hexa_3496LOC")
    }
    if name == "mac_kick" {
        return kick_meta_make("mac_kick", 2, 0, 0, 0, 0, "WRAPPED", "mac_host_claude_binary")
    }
    if name == "claude_kick" {
        return kick_meta_make("claude_kick", 3, 1, 0, 0, 0, "IMPLEMENTED", "anthropic_claude_cli_or_api")
    }
    if name == "dispatch_router" {
        return kick_meta_make("dispatch_router", 0, 0, 0, 1, 0, "IMPLEMENTED", "selftest_no_spawn")
    }
    return kick_meta_make(name, -1, 0, 0, 0, 0, "UNKNOWN", "")
}

// ── Dispatch dispatch (mirrors per-module files) ────────────

fn kick_registry_dispatch(name: str, req: KickRequest) -> KickResult {
    if name == "dispatch_router" {
        // pure no-spawn echo: returns a synthetic witness path for CI hooks
        let witness = "/tmp/nexus_kick_registry_dryrun_" + req.backend + ".json"
        let sent = "__KICK_RESULT__ PASS witness=" + witness + " tier1=0 falsifier_pass=0 (dry_run)"
        return kick_result_ok(witness, sent, 0, 0, "dispatch_router: no-spawn dry-run")
    }
    if name == "nexus_kick" {
        if req.dry_run == 1 {
            let witness = "/tmp/nexus_kick_dryrun_" + req.topic + ".json"
            return kick_result_ok(witness, "__KICK_RESULT__ DRY witness=" + witness, 0, 0, "nexus_kick: dry-run wrapper")
        }
        return kick_result_fail("nexus_kick: live spawn deferred to wrapper module (modules/kick/nexus_kick.hexa)")
    }
    if name == "mac_kick" {
        return kick_result_fail("mac_kick: WRAPPED — host claude integration audit pending (raw 47)")
    }
    if name == "claude_kick" {
        // Module is IMPLEMENTED with mock-default; live path needs NEXUS_KICK_CLAUDE_LIVE=1.
        // Registry-level dispatch keeps fail-closed for live calls; mock-mode dispatch
        // happens via the per-module file (modules/kick/claude_kick.hexa).
        return kick_result_fail("claude_kick: live path gated — set NEXUS_KICK_CLAUDE_LIVE=1 (or NEXUS_KICK_CLAUDE_MOCK=1 for CI); mock-mode via per-module file")
    }
    return kick_result_fail("unknown backend: " + name)
}

// ── Selftest ───────────────────────────────────────────────

fn _selftest_registry() -> int {
    let names = kick_registry_names()
    if len(names) != 4 { return 0 }
    let mut i = 0
    while i < len(names) {
        let m = kick_registry_meta(names[i])
        if m.name != names[i] { return 0 }
        if m.tier < 0 { return 0 }
        if len(m.status) < 1 { return 0 }
        i = i + 1
    }
    let m_x = kick_registry_meta("nonexistent")
    if m_x.tier != -1 { return 0 }
    if m_x.status != "UNKNOWN" { return 0 }
    // dispatch_router PASS dry-run
    let req_dr = KickRequest { topic: "smoke", backend: "dispatch_router", stratum: "", axes: [], noise_modes: [], parent_sid: "", dry_run: 1 }
    let r_dr = kick_registry_dispatch("dispatch_router", req_dr)
    if r_dr.ok != 1 { return 0 }
    // nexus_kick dry-run PASS
    let req_nk = KickRequest { topic: "topic", backend: "nexus_kick", stratum: "", axes: [], noise_modes: [], parent_sid: "", dry_run: 1 }
    let r_nk = kick_registry_dispatch("nexus_kick", req_nk)
    if r_nk.ok != 1 { return 0 }
    // mac_kick / claude_kick / unknown all FAIL
    let req_x = KickRequest { topic: "x", backend: "x", stratum: "", axes: [], noise_modes: [], parent_sid: "", dry_run: 0 }
    let r_mk = kick_registry_dispatch("mac_kick", req_x)
    if r_mk.ok != 0 { return 0 }
    let r_ck = kick_registry_dispatch("claude_kick", req_x)
    if r_ck.ok != 0 { return 0 }
    let r_un = kick_registry_dispatch("nonexistent", req_x)
    if r_un.ok != 0 { return 0 }
    return 1
}

fn main() {
    println("[kick/registry] 4-backend dispatch table")
    if _selftest_registry() == 1 {
        println("[kick/registry] SELFTEST PASS")
        println("__KICK_REGISTRY__ PASS")
    } else {
        println("[kick/registry] SELFTEST FAIL")
        println("__KICK_REGISTRY__ FAIL")
    }
}
