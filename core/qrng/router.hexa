#!hexa strict
// nexus/core/qrng/router.hexa — config-driven qrng backend selection + fallback
//
// @tool(slug="qrng_router", desc="config + env priority router for qrng backends. Reads NEXUS_QRNG_SOURCE / NEXUS_QRNG_FALLBACK_CHAIN.")
// @usage(hexa run nexus/core/qrng/router.hexa --selftest)
// @sentinel(__QRNG_ROUTER__ <PASS|FAIL>)
// @resolver-bypass(reason="dry-run / mock only in selftest.")
//
// Default chain: anu → hardware_qrng → mock_qrng
//   (T1 free quantum first, T3 commercial fallback, T0 deterministic safety net)

struct QrngBytes {
    ok:           int,
    n_bytes:      int,
    bytes_:       [int],
    sha256_hex:   str,
    nist_pass:    int,
    message:      str
}

fn qrng_bytes_fail(reason: str) -> QrngBytes {
    return QrngBytes { ok: 0, n_bytes: 0, bytes_: [], sha256_hex: "", nist_pass: 0, message: reason }
}

fn qrng_bytes_ok(bytes_: [int], sha256_hex: str, msg: str) -> QrngBytes {
    return QrngBytes { ok: 1, n_bytes: len(bytes_), bytes_: bytes_, sha256_hex: sha256_hex, nist_pass: 0, message: msg }
}

fn _mock_collect(n_bytes: int, seed: int) -> QrngBytes {
    let mut s = if seed > 0 { seed } else { 12345 }
    let mut bytes_ = []
    let mut i = 0
    while i < n_bytes {
        s = (1664525 * s + 1013904223) % 4294967296
        bytes_ = bytes_.push(s % 256)
        i = i + 1
    }
    return qrng_bytes_ok(bytes_, "", "mock_qrng: ok")
}

fn _route_collect(name: str, n_bytes: int, seed: int) -> QrngBytes {
    if name == "mock_qrng" { return _mock_collect(n_bytes, seed) }
    if name == "anu" { return qrng_bytes_fail("anu: live deferred to wrapper module") }
    if name == "hardware_qrng" { return qrng_bytes_fail("hardware_qrng: STUB") }
    return qrng_bytes_fail("unknown backend: " + name)
}

fn qrng_default_chain() -> [str] {
    let mut a = []
    a = a.push("anu")
    a = a.push("hardware_qrng")
    a = a.push("mock_qrng")
    return a
}

fn qrng_resolve_chain() -> [str] {
    let single = exec("printenv NEXUS_QRNG_SOURCE 2>/dev/null || true").trim()
    if len(single) > 0 {
        let mut a = []
        a = a.push(single)
        return a
    }
    let chain = exec("printenv NEXUS_QRNG_FALLBACK_CHAIN 2>/dev/null || true").trim()
    if len(chain) > 0 {
        let parts = chain.split(",")
        let mut a = []
        let mut i = 0
        while i < len(parts) {
            let p = parts[i].trim()
            if len(p) > 0 { a = a.push(p) }
            i = i + 1
        }
        if len(a) > 0 { return a }
    }
    return qrng_default_chain()
}

struct QrngRouteResult {
    final_backend: str,
    attempts:      [str],
    reasons:       [str],
    result:        QrngBytes
}

fn qrng_route_collect(n_bytes: int, seed: int) -> QrngRouteResult {
    let chain = qrng_resolve_chain()
    let mut attempts = []
    let mut reasons = []
    let mut i = 0
    while i < len(chain) {
        let name = chain[i]
        attempts = attempts.push(name)
        let r = _route_collect(name, n_bytes, seed)
        if r.ok == 1 {
            reasons = reasons.push("ok")
            return QrngRouteResult { final_backend: name, attempts: attempts, reasons: reasons, result: r }
        }
        reasons = reasons.push(r.message)
        i = i + 1
    }
    return QrngRouteResult { final_backend: "", attempts: attempts, reasons: reasons, result: qrng_bytes_fail("router: all backends failed") }
}

fn _selftest() -> int {
    let dc = qrng_default_chain()
    if len(dc) != 3 { return 0 }
    if dc[0] != "anu" { return 0 }
    if dc[2] != "mock_qrng" { return 0 }
    let r1 = _route_collect("mock_qrng", 8, 42)
    if r1.ok != 1 { return 0 }
    let r2 = _route_collect("not_a_backend", 8, 0)
    if r2.ok != 0 { return 0 }
    // route_collect: anu fails, hardware fails, mock_qrng PASS
    let route = qrng_route_collect(8, 42)
    if route.result.ok != 1 { return 0 }
    if route.final_backend != "mock_qrng" { return 0 }
    return 1
}

fn main() {
    println("[qrng/router] config-driven backend selection + fallback chain")
    if _selftest() == 1 {
        println("[qrng/router] SELFTEST PASS")
        println("__QRNG_ROUTER__ PASS")
    } else {
        println("[qrng/router] SELFTEST FAIL")
        println("__QRNG_ROUTER__ FAIL")
    }
    let route = qrng_route_collect(4, 99)
    println("[qrng/router] route_collect demo n=4 seed=99")
    println("[qrng/router]   attempts=" + str(len(route.attempts)) + " final_backend=" + route.final_backend)
    let mut i = 0
    while i < len(route.attempts) {
        println("[qrng/router]   try[" + str(i) + "] " + route.attempts[i] + " -> " + route.reasons[i])
        i = i + 1
    }
}
