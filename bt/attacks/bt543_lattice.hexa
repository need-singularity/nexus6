// ═══════════════════════════════════════════════════════════
// VERIFY / SCAN / STATUS dispatchers
// ═══════════════════════════════════════════════════════════
fn cmd_verify() {
    println("=== BT-543 LATTICE VERIFY ===")
    println("math primitives self-test:")
    let s2 = sqrt_(2.0)
    let dev_s = abs_(s2 - 1.4142135624)
    println("  sqrt(2) = " + fs(s2) + " dev=" + fs(dev_s))
    let e1 = exp_(1.0)
    let dev_e = abs_(e1 - 2.7182818285)
    println("  exp(1)  = " + fs(e1) + " dev=" + fs(dev_e))
    let l2 = ln_(2.0)
    let dev_l = abs_(l2 - 0.6931471806)
    println("  ln(2)   = " + fs(l2) + " dev=" + fs(dev_l))
    let t1 = tanh_(1.0)
    let dev_t = abs_(t1 - 0.7615941560)
    println("  tanh(1) = " + fs(t1) + " dev=" + fs(dev_t))
    let mut pass = 0
    if dev_s < 0.0001 { pass = pass + 1 }
    if dev_e < 0.0001 { pass = pass + 1 }
    if dev_l < 0.0001 { pass = pass + 1 }
    if dev_t < 0.0001 { pass = pass + 1 }
    println("  math PASS: " + is(pass) + "/4")
    emit("math_verify", "VERIFIED", "sqrt/exp/ln/tanh " + is(pass) + "/4", is(pass) + "/4")
}

fn cmd_scan() {
    println("=== BT-543 LATTICE SCAN (round 2, lattice angle) ===")
    println("")
    cmd_verify()
    cmd_wilson_scan()
    cmd_potential()
    cmd_mass_gap()
    cmd_beta_critical()
    cmd_honesty()
    println("")
    println("=== SUMMARY ===")
    println("All 2D Z_2 lattice checks reduce to exact closed forms (Wilson 1974,")
    println("Wegner 1971, Kramers-Wannier 1941). Hexa primitives validated.")
    println("4D SU(3) Clay mass gap remains UNRESOLVED.")
    emit("summary", "HONEST_MISS",
        "2D toy verified; 4D Clay untouched.", "0/1 MISS")
}

