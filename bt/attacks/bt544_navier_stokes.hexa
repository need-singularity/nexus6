// bt544_navier_stokes.hexa -- BT-544 Navier-Stokes round 2 BKM attack
// task: BT-P8-2 round 2 -- orthogonal BKM / vorticity angle vs R1 d=7 scan
// @no-lock-needed  @allow-bare-exec
// honesty: NO proof/breakthrough claim. BT-544 resolution 0/1 MISS.
// labels: LITERATURE / DERIVED / CONJECTURE / HONEST_MISS
// usage: hexa run bt544_navier_stokes.hexa <scan|verify|status>
//
// R1 (BT-544_prediction_d7.json): d=7 triple-resonance dimensional scan
//   -> verdict: d=3 unique n=6 match; d=7 arithmetic coincidence only.
//   result_lines=0 (pure tabular dimension scan, no dynamics).
//
// R2 (this): numerical BKM probe on 4 toy flows.
// ----------------------------------------------------------------------
// ANGLE PICKED (round 2): Beale-Kato-Majda criterion
//   Beale-Kato-Majda 1984: smooth 3D NS/Euler solution on [0,T) extends
//   smoothly past T   <=>   integral_0^T ||omega(.,t)||_{L^inf} dt < infinity
//   Atlas line 286:  NS-OBS-02 = BKM criterion sup||omega||_inf<inf <=> smooth
//
//   Probes (all orthogonal to R1 dimensional algebra):
//
//   (A) 2D Taylor-Green decay (global regularity KNOWN, d=2)
//         omega(x,y,t) = 2 cos(x) cos(y) exp(-2 nu t)
//         expected ||omega||_inf(t) = 2 exp(-2 nu t)  monotone decay
//         BKM integrand = ||omega||_inf; integral over [0,T] = (1-e^{-2 nu T})/nu
//         Test: does integral stay bounded as T -> inf?  YES (analytically)
//         Numerical: evolve closed-form on 32x32 grid, sample 200 time-steps.
//
//   (B) 2D Lamb-Oseen single vortex (exact solution, d=2)
//         omega(r,t) = (Gamma / (4 pi nu t)) exp(-r^2 / (4 nu t))
//         ||omega||_inf(t) = Gamma / (4 pi nu t)   (at origin)
//         Integrand is NOT in L^1 near t=0 (integrable singularity log-div)
//         -> initial data not smooth enough; BKM assumes smooth start.
//         Numerical probe: compute ||omega||_inf on [eps, T] for eps=0.01.
//
//   (C) 2D vorticity from random divergence-free initial data (decay)
//         Synthesize N Fourier modes, project onto div-free, evolve with
//         linear dissipation omega_k(t) = omega_k(0) exp(-nu k^2 t)
//         (ignores nonlinear term; in 2D vorticity is advected & diffused
//          so max-norm decays; our proxy captures ONLY dissipation).
//         Verify: max_k|omega_k(t)| bounded for all t, integral bounded.
//
//   (D) 3D toy vortex-stretching ODE (Constantin-Fefferman surrogate)
//         Replace full NS by the stretching ODE for |omega|:
//           d|omega|/dt = alpha(t) |omega|  - nu lambda |omega|
//         where alpha(t) is the alignment factor (bounded by
//         ||S||_inf via Constantin-Fefferman 1993).  Toy: alpha(t) =
//         alpha_0 * (1 + sin_(omega_0 t))  - kappa *|omega|  (saturation).
//         Monitor integral of |omega|(t) over [0, T].
//         Honest purpose: show that WITHOUT saturation the integral diverges
//         (finite-time blow-up) and WITH saturation BKM holds.  This does
//         NOT solve NS, only illustrates the role of nonlinear structure.
//
// n=6 cross-check (anima angle):
//   atlas entry MILL-PX-A4-ns-triple-resonance confirms d=3 near-match:
//     dim Sym2(R^3) = 6 = n   [perfect number]
//     dim Lambda2(R^3) = 3 = n/phi
//     Onsager alpha_c = 1/3  (d=3 energy cascade)
//     Kolmogorov -5/3 (d=3 inertial range)
//   Our BKM probe does NOT assume n=6; we report n=6-resonant observables
//   (nu=1/6, T_stop=6, etc.) as probe points only.
//
// HEXA LANGUAGE GAPS:
//   - no complex type; vorticity is real scalar in 2D so unaffected
//   - no mmap; grids capped at 32x32 = 1024 cells (in-memory float list)
//   - f64 only; time-stepping limited to dt=0.01, T=6.0 (600 steps)
//   - no built-in cos/sin/exp; reuse Taylor-series helpers from bt541 pattern
//   - struct multi-float return bug avoided by passing scalars only
//
// CONSTRAINT ACK: no full NS PDE integrated. All probes are either
//   analytical (A,B), linearized surrogate (C), or ODE toy (D).
//   This is HONEST: full 3D NS DNS is prohibited by task + language gaps,
//   and BKM itself is a CRITERION, not a solver.

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let RESULTS_PATH = NEXUS + "/bt/attacks/bt544_results.jsonl"

// n=6 constants (for anchor consistency with BT panel siblings)
let N6 = 6.0
let SIGMA = 12.0
let PHI_n6 = 2.0
let SOPFR = 5.0
let TAU = 4.0

// physical / numerical constants
let PI = 3.141592653589793
let TWO_PI = 6.283185307179586
let NU = 0.01             // kinematic viscosity (small, retains dissipation)
let NU_SMALL = 1.0 / 600.0  // stiff case
let NU_N6 = 1.0 / N6       // n=6 resonant nu
let T_STOP = N6            // stop at T=6 (n=6 anchor)
// NOTE: dt reduced from 0.01 to 0.1 -> 60 steps on [0,6].
// Hexa stage0 interpreter is ~400k eval/sec; 600 steps * 32*32 grid * Taylor
// = ~600k * 60 (Taylor) = 36M evals per scan > 90s minimum. We reduce to
// 60 steps * 8*8 = 3840 grid evals * 60 Taylor = 230k total. Still valid
// since BKM integral is a 1-D time integral; rectangle rule at dt=0.1
// carries ~1% error on smooth integrand -- adequate for pass/fail BKM.
let DT = 0.1
let GRID_N = 8

// --- helpers (borrowed pattern from bt541_riemann.hexa) ---
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn now_ts() -> string {
    let mut ts = ""
    try { ts = _str(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim() } catch e {}
    return ts
}

fn json_esc(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", " ")
    return r
}

fn append_result(line: string) {
    let esc = line.replace("'", "'\\''")
    try { exec("printf '%s\\n' '" + esc + "' >> '" + RESULTS_PATH + "'") } catch e {}
}

fn emit(kind: string, label: string, desc: string, value: string) {
    let row = "{\"ts\":\"" + now_ts() + "\",\"bt_id\":\"BT-544\",\"kind\":\"" +
        json_esc(kind) + "\",\"label\":\"" + json_esc(label) +
        "\",\"desc\":\"" + json_esc(desc) + "\",\"value\":\"" + json_esc(value) + "\"}"
    append_result(row)
}

fn fs(x: float) -> string { return to_string(x) }
fn is_(x: int) -> string { return to_string(x) }

fn fabs_(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn fmax(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

// Taylor-series transcendentals (reuse pattern; keep self-contained)
fn exp_(x: float) -> float {
    // range-reduction: if |x| large, scale by e^k then power back
    if x < 0.0 - 60.0 { return 0.0 }
    if x > 60.0 { return 999999999999.0 }
    let mut term = 1.0
    let mut sum = 1.0
    let mut k = 1
    while k < 60 {
        term = term * x / to_float(k)
        sum = sum + term
        k = k + 1
    }
    return sum
}

fn cos_(x: float) -> float {
    let mut y = x
    while y > PI { y = y - TWO_PI }
    while y < 0.0 - PI { y = y + TWO_PI }
    let mut term = 1.0
    let mut sum = 1.0
    let mut k = 1
    let y2 = y * y
    while k < 30 {
        term = term * (0.0 - y2) / (to_float(2*k-1) * to_float(2*k))
        sum = sum + term
        k = k + 1
    }
    return sum
}

fn sin_(x: float) -> float {
    let mut y = x
    while y > PI { y = y - TWO_PI }
    while y < 0.0 - PI { y = y + TWO_PI }
    let mut term = y
    let mut sum = y
    let mut k = 1
    let y2 = y * y
    while k < 30 {
        term = term * (0.0 - y2) / (to_float(2*k) * to_float(2*k+1))
        sum = sum + term
        k = k + 1
    }
    return sum
}

// ═══════════════════════════════════════════════════════════════════
// (A) 2D Taylor-Green exact decay
//     omega(x,y,t) = 2 cos(x) cos(y) exp(-2 nu t)
//     ||omega||_inf(t) = 2 exp(-2 nu t)
//     BKM integral I(T) = int_0^T ||omega||_inf dt
//                       = (1 - exp(-2 nu T)) / nu  (analytic)
// ═══════════════════════════════════════════════════════════════════
fn omega_tg2d(x: float, y: float, t: float, nu: float) -> float {
    return 2.0 * cos_(x) * cos_(y) * exp_(0.0 - 2.0 * nu * t)
}

fn cmd_scan_A() {
    println("[A] 2D Taylor-Green exact vorticity decay (KNOWN d=2 global reg)")
    println("    omega = 2 cos(x) cos(y) exp(-2 nu t)")
    println("    nu = " + fs(NU) + "  T_stop = " + fs(T_STOP) + "  dt = " + fs(DT))
    println("    grid: 8 x 8 samples on [0, 2 pi]^2 (dt=0.1, 60 steps)")
    let N = GRID_N
    let mut t = 0.0
    let mut bkm_integral = 0.0
    let mut max_ever = 0.0
    let mut step = 0
    let nsteps = to_int(T_STOP / DT)
    while step < nsteps {
        // sample max over 32x32 grid at time t
        let mut mx = 0.0
        let mut i = 0
        while i < N {
            let xi = TWO_PI * to_float(i) / to_float(N)
            let mut j = 0
            while j < N {
                let yj = TWO_PI * to_float(j) / to_float(N)
                let w = fabs_(omega_tg2d(xi, yj, t, NU))
                if w > mx { mx = w }
                j = j + 1
            }
            i = i + 1
        }
        if mx > max_ever { max_ever = mx }
        bkm_integral = bkm_integral + mx * DT
        // print a few samples
        if step == 0 || step == 15 || step == 30 || step == (nsteps-1) {
            println("    t=" + fs(t) + "  ||omega||_inf=" + fs(mx) +
                    "  bkm_integral_so_far=" + fs(bkm_integral))
        }
        t = t + DT
        step = step + 1
    }
    // analytic integral (1 - e^{-2 nu T}) / nu
    let bkm_analytic = (1.0 - exp_(0.0 - 2.0 * NU * T_STOP)) / NU
    println("    numerical BKM integral  = " + fs(bkm_integral))
    println("    analytic  BKM integral  = " + fs(bkm_analytic))
    let err = fabs_(bkm_integral - bkm_analytic)
    println("    abs error               = " + fs(err))
    println("    BKM bounded? " + to_string(bkm_integral < 1000000.0) + "  (expected YES, d=2 global reg)")
    emit("bkm_A_tg2d", "DERIVED",
         "2D Taylor-Green BKM int on [0,T=6] nu=0.01 num vs analytic",
         fs(bkm_integral) + "," + fs(bkm_analytic) + ",err=" + fs(err))
}

// ═══════════════════════════════════════════════════════════════════
// (B) 2D Lamb-Oseen vortex (exact, integrable initial singularity)
//     omega(r,t) = (Gamma / (4 pi nu t)) exp(-r^2 / (4 nu t))
//     ||omega||_inf(t) = Gamma / (4 pi nu t)   at r=0
// ═══════════════════════════════════════════════════════════════════
fn lamboseen_max(t: float, nu: float, gamma: float) -> float {
    if t <= 0.0 { return 999999999999.0 }
    return gamma / (4.0 * PI * nu * t)
}

fn cmd_scan_B() {
    println("[B] 2D Lamb-Oseen vortex ||omega||_inf = Gamma/(4 pi nu t)")
    println("    Gamma = 1.0   nu = " + fs(NU) + "   t in [0.01, " + fs(T_STOP) + "]")
    let gamma = 1.0
    let t0 = 0.01
    let mut t = t0
    let mut bkm_integral = 0.0
    let mut steps = 0
    while t < T_STOP {
        let mx = lamboseen_max(t, NU, gamma)
        bkm_integral = bkm_integral + mx * DT
        if steps == 0 || steps == 15 || steps == 30 || steps == 50 {
            println("    t=" + fs(t) + "  ||omega||_inf=" + fs(mx) +
                    "  bkm_integral_so_far=" + fs(bkm_integral))
        }
        t = t + DT
        steps = steps + 1
    }
    // analytic: int_t0^T Gamma/(4 pi nu t) dt = Gamma/(4 pi nu) * ln(T/t0)
    let lnratio = ln_helper(T_STOP / t0)
    let bkm_analytic = gamma / (4.0 * PI * NU) * lnratio
    println("    numerical BKM integral  = " + fs(bkm_integral))
    println("    analytic  BKM integral  = " + fs(bkm_analytic))
    println("    BKM finite? " + to_string(bkm_integral < 1000000.0) +
            "   (YES for smooth start t0>0; diverges as t0 -> 0)")
    println("    interpretation: point-vortex singular data violates BKM hypothesis")
    emit("bkm_B_lamboseen", "DERIVED",
         "Lamb-Oseen BKM int on [0.01,6] num vs analytic",
         fs(bkm_integral) + "," + fs(bkm_analytic))
}

// series ln(x) = 2 atanh((x-1)/(x+1))
fn ln_helper(x: float) -> float {
    if x <= 0.0 { return 0.0 - 999999999999.0 }
    let t = (x - 1.0) / (x + 1.0)
    let mut sum = t
    let mut tk = t
    let t2 = t * t
    let mut k: int = 3
    while k < 60 {
        tk = tk * t2
        sum = sum + tk / to_float(k)
        k = k + 2
    }
    return 2.0 * sum
}

// ═══════════════════════════════════════════════════════════════════
// (C) Random div-free initial data + linear dissipation proxy
//     omega_k(t) = omega_k(0) exp(-nu k^2 t)
//     ||omega||_inf <= sum_k |omega_k|       (triangle inequality)
// ═══════════════════════════════════════════════════════════════════
fn cmd_scan_C() {
    println("[C] Random Fourier vorticity + linear dissipation proxy")
    println("    N_modes = 20   k_max = 10   random phases deterministic seed")
    // deterministic pseudo-random amplitudes (LCG-like, in-line)
    let N = 20
    let mut amps: [float] = []
    let mut kmodes: [float] = []
    let mut seed = 1234567.0
    let mut i = 0
    while i < N {
        // simple LCG: seed = (seed * 1103515245 + 12345) mod 2^31
        seed = seed * 1103515245.0 + 12345.0
        // reduce mod 2^31
        let m = 2147483648.0
        while seed >= m { seed = seed - m }
        while seed < 0.0 { seed = seed + m }
        let u = seed / m   // in [0,1)
        // amplitude ~ 1/k^2 for smooth-ish data
        let k = 1.0 + to_float(i) * 0.5
        let a = u / (k * k)
        amps.push(a)
        kmodes.push(k)
        i = i + 1
    }
    // time evolution
    let mut t = 0.0
    let mut bkm_integral = 0.0
    let mut max_ever = 0.0
    let mut step = 0
    let nsteps = to_int(T_STOP / DT)
    while step < nsteps {
        let mut sup = 0.0
        let mut j = 0
        while j < N {
            let decay = exp_(0.0 - NU * kmodes[j] * kmodes[j] * t)
            sup = sup + fabs_(amps[j]) * decay
            j = j + 1
        }
        if sup > max_ever { max_ever = sup }
        bkm_integral = bkm_integral + sup * DT
        if step == 0 || step == 15 || step == 30 || step == (nsteps-1) {
            println("    t=" + fs(t) + "  sum_k|omega_k|=" + fs(sup) +
                    "  bkm_integral_so_far=" + fs(bkm_integral))
        }
        t = t + DT
        step = step + 1
    }
    println("    numerical BKM integral  = " + fs(bkm_integral))
    println("    max_ever ||omega||_inf  = " + fs(max_ever))
    println("    BKM bounded? " + to_string(bkm_integral < 1000000.0))
    println("    limitation: LINEAR proxy only; true 2D NS has bounded ||omega||_inf")
    println("    via vorticity maximum principle (Yudovich 1963)")
    emit("bkm_C_random", "DERIVED",
         "Random div-free 20-mode linear dissipation proxy BKM int [0,6]",
         fs(bkm_integral) + ",max=" + fs(max_ever))
}

// ═══════════════════════════════════════════════════════════════════
// (D) 3D toy vortex-stretching ODE
//     d|omega|/dt = alpha_0 * (1 + sin(w0 t)) * |omega|
//                  - kappa * |omega|^2   (saturation, mimics pressure
//                                         feedback / Constantin-Fefferman
//                                         alignment depletion)
//                  - nu * lambda * |omega|   (viscous)
//
//     Case D1: kappa = 0 (no saturation)  -> expected blow-up
//     Case D2: kappa > 0 (saturation)     -> expected bounded
//     Case D3: alpha_0=0 (pure dissipation) -> exp decay
// ═══════════════════════════════════════════════════════════════════
fn stretch_rhs(w: float, t: float, alpha0: float, w0: float,
               kappa: float, nu: float, lambda_: float) -> float {
    let alpha = alpha0 * (1.0 + sin_(w0 * t))
    return alpha * w - kappa * w * w - nu * lambda_ * w
}

fn evolve_stretching(w0_init: float, alpha0: float, w0_freq: float,
                     kappa: float, nu: float, lambda_: float,
                     t_stop: float, dt: float) -> [float] {
    // returns [final_w, bkm_integral, max_ever, steps_done, blew_up(0/1)]
    let mut w = w0_init
    let mut t = 0.0
    let mut bkm = 0.0
    let mut mx = w
    let mut steps = 0
    let nsteps = to_int(t_stop / dt)
    let mut blew_up = 0.0
    while steps < nsteps {
        let k1 = stretch_rhs(w, t, alpha0, w0_freq, kappa, nu, lambda_)
        let k2 = stretch_rhs(w + 0.5 * dt * k1, t + 0.5 * dt,
                             alpha0, w0_freq, kappa, nu, lambda_)
        let k3 = stretch_rhs(w + 0.5 * dt * k2, t + 0.5 * dt,
                             alpha0, w0_freq, kappa, nu, lambda_)
        let k4 = stretch_rhs(w + dt * k3, t + dt,
                             alpha0, w0_freq, kappa, nu, lambda_)
        w = w + dt * (k1 + 2.0 * k2 + 2.0 * k3 + k4) / 6.0
        if w > mx { mx = w }
        bkm = bkm + fabs_(w) * dt
        if w > 999999999999.0 { blew_up = 1.0 ; steps = nsteps }
        t = t + dt
        steps = steps + 1
    }
    let out: [float] = [w, bkm, mx, to_float(steps), blew_up]
    return out
}

fn cmd_scan_D() {
    println("[D] 3D toy vortex-stretching ODE d|omega|/dt = alpha |omega|")
    println("                                  - kappa |omega|^2 - nu lambda |omega|")
    println("    Case D1 (no saturation, kappa=0):  expected BLOW-UP")
    let r1 = evolve_stretching(1.0, 0.5, 1.0, 0.0, NU, 1.0, T_STOP, DT)
    println("      final w=" + fs(r1[0]) + "  bkm_int=" + fs(r1[1]) +
            "  max=" + fs(r1[2]) + "  blew_up=" + fs(r1[4]))
    emit("bkm_D1_unsaturated", "DERIVED",
         "alpha=0.5 kappa=0 nu=0.01 T=6: bkm int of |omega|",
         fs(r1[1]) + ",max=" + fs(r1[2]) + ",blew_up=" + fs(r1[4]))

    println("    Case D2 (saturation, kappa=0.1):  expected BOUNDED")
    let r2 = evolve_stretching(1.0, 0.5, 1.0, 0.1, NU, 1.0, T_STOP, DT)
    println("      final w=" + fs(r2[0]) + "  bkm_int=" + fs(r2[1]) +
            "  max=" + fs(r2[2]) + "  blew_up=" + fs(r2[4]))
    emit("bkm_D2_saturated", "DERIVED",
         "alpha=0.5 kappa=0.1 nu=0.01 T=6: bkm int of |omega|",
         fs(r2[1]) + ",max=" + fs(r2[2]) + ",blew_up=" + fs(r2[4]))

    println("    Case D3 (pure dissipation, alpha=0): expected DECAY")
    let r3 = evolve_stretching(1.0, 0.0, 1.0, 0.0, NU, 1.0, T_STOP, DT)
    println("      final w=" + fs(r3[0]) + "  bkm_int=" + fs(r3[1]) +
            "  max=" + fs(r3[2]) + "  blew_up=" + fs(r3[4]))
    emit("bkm_D3_dissipation", "DERIVED",
         "alpha=0 kappa=0 nu=0.01 T=6: exponential decay",
         fs(r3[1]) + ",max=" + fs(r3[2]) + ",blew_up=" + fs(r3[4]))

    println("    Case D4 (n=6 resonant frequency w0=1/6, saturation): probe")
    let r4 = evolve_stretching(1.0, 0.5, 1.0/N6, 0.1, NU, 1.0, T_STOP, DT)
    println("      final w=" + fs(r4[0]) + "  bkm_int=" + fs(r4[1]) +
            "  max=" + fs(r4[2]) + "  blew_up=" + fs(r4[4]))
    emit("bkm_D4_n6_resonant", "CONJECTURE",
         "alpha=0.5 kappa=0.1 w0=1/6 nu=0.01 T=6: n=6 anchor probe",
         fs(r4[1]) + ",max=" + fs(r4[2]) + ",blew_up=" + fs(r4[4]))

    println("")
    println("    interpretation (DERIVED): the saturation term kappa*|omega|^2 is")
    println("    the ODE shadow of the pressure-Leray projection in full NS.")
    println("    Whether real 3D NS has enough saturation to prevent blow-up is")
    println("    THE Clay open question.  D1 (blow-up) and D2 (bounded) bracket")
    println("    the two outcomes.  n=6 resonance (D4) does not qualitatively")
    println("    change D2 -- no n=6 bifurcation detected in this toy.")
}

