fn cmd_verify() {
    println("=== BT-544 VERIFY ===")
    println("  cos(0) = " + fs(cos_(0.0)) + "   expected 1.0")
    println("  sin(PI/2) = " + fs(sin_(PI/2.0)) + "   expected 1.0")
    println("  exp(1) = " + fs(exp_(1.0)) + "   expected 2.71828")
    println("  ln(e) ~ " + fs(ln_helper(exp_(1.0))) + "   expected 1.0")
    let tg_check = omega_tg2d(0.0, 0.0, 0.0, 0.01)
    println("  omega_tg2d(0,0,0,0.01) = " + fs(tg_check) + "  expected 2.0")
    // BKM analytic for Taylor-Green at T=6, nu=0.01:
    //   (1 - exp(-2*0.01*6))/0.01 = (1 - exp(-0.12))/0.01
    let bkm_tg = (1.0 - exp_(0.0 - 0.12)) / 0.01
    println("  BKM_TG(T=6, nu=0.01) = " + fs(bkm_tg) + "  expected ~11.308")
    println("  ok sanity")
}

fn cmd_status() {
    println("=== BT-544 STATUS ===")
    println("bt_id: BT-544 | target: Navier-Stokes global regularity (Clay)")
    println("round: 2 | task: BT-P8-2 | angle: BKM / vorticity numerical")
    println("")
    println("R1 (BT-544_prediction_d7.json):")
    println("  d=7 dimensional scan; d=3 unique n=6 match; MISS. lines=0 numeric")
    println("R2 (this attack):")
    println("  4 BKM probes (A=Taylor-Green 2D, B=Lamb-Oseen, C=linear proxy,")
    println("              D=3D stretching ODE 4 cases)")
    println("")
    println("hexa language gaps:")
    println("  - no mmap: grids capped 32x32 = 1024 cells")
    println("  - no native PDE solver: only ODE toys + closed-form flows")
    println("  - Taylor-series transcendentals OK in |x| < 60")
    println("  - struct-multi-float return bug avoided (scalar returns only)")
    println("")
    println("verdict: BT-544 numerically consistent with BKM bounded on 2D flows")
    println("         (expected -- d=2 global reg is a THEOREM, not a conjecture);")
    println("         3D toy shows saturation as necessary condition. Full 3D NS")
    println("         blow-up question remains open (Clay).")
    println("results: shared/bt/attacks/bt544_results.jsonl")
}

// ═══════════════════════════════════════════════════════════════════
fn main() {
    let argv = args()
    let mut mode = "scan"
    if argv.len() >= 2 { mode = _str(argv[1]).trim() }
    if argv.len() >= 3 { mode = _str(argv[2]).trim() }
    if mode == "scan" { cmd_scan() }
    else if mode == "verify" { cmd_verify() }
    else if mode == "status" { cmd_status() }
    else { println("usage: hexa run bt544_navier_stokes.hexa <scan|verify|status>") }
}

main()
