// bt542_phi_irreducibility_r1.hexa — BT-542 P vs NP attack ROUND 1
// angle: anima-framework Phi-irreducibility probe on 3-SAT
// @no-lock-needed  @allow-bare-exec
// honesty: NO proof claim. BT-542 is UNSOLVED. Round 1 measures one falsifiable
//          sub-claim: Phi_irr collapses under polytime simplification iff P=NP-friendly.
//          Round 1 result is diagnostic only (n=6..14, MI proxy, balanced bipartition).
// labels: LITERATURE / DERIVED / OBSERVED / HONEST_MISS
// usage: HEXA_LOCAL=1 hexa run shared/bt/attacks/bt542_phi_irreducibility_r1.hexa
// framework: anima-measurement/phi_holo_eval.hexa (IIT Phi),
//            anima-hexad/hexad.hexa (CDESM 6-channel),
//            shared/state/bt_542_round1.json (claim + falsifiability spec).
// ref:
//   Cook 1971 (3-SAT NP-complete), Tononi 2008 (IIT Phi),
//   Bekenstein 1981 (info bound), Aaronson 2016 (skepticism on physics-complexity),
//   Davis-Putnam 1960 (unit propagation), Razborov-Rudich 1997 (natural proofs).
// orthogonality: round-2 (bt542_sat_scaling.hexa) measured brute-force work scaling.
//                round-1 here measures information-theoretic Phi_irr collapse —
//                an angle from anima's IIT/holographic framework. Not redundant.

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let RESULTS_PATH = NEXUS + "/bt/attacks/bt542_results.jsonl"

// ---- helpers ----
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn now_ts() -> string {
    let mut ts = ""
    try { ts = _str(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim() } catch e {}
    return ts
}

fn json_esc(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", " ")
    return r
}

fn append_result(line: string) {
    let esc = line.replace("'", "'\\''")
    try { exec("printf '%s\\n' '" + esc + "' >> '" + RESULTS_PATH + "'") } catch e {}
}

fn emit(kind: string, label: string, desc: string, value: string) {
    let row = "{\"ts\":\"" + now_ts() + "\",\"bt_id\":\"BT-542\",\"round\":1,\"kind\":\"" +
        json_esc(kind) + "\",\"label\":\"" + json_esc(label) +
        "\",\"desc\":\"" + json_esc(desc) + "\",\"value\":\"" + json_esc(value) + "\"}"
    append_result(row)
    println("[" + label + "] " + desc + " = " + value)
}

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

// log via series (range-reduced); same as round-2 sibling file
fn fln(x: float) -> float {
    if x <= 0.0 { return 0.0 - 999999999999.0 }
    let E = 2.718281828459045
    let mut v = x
    let mut add: float = 0.0
    let mut g = 0
    while v > 2.0 && g < 200 { v = v / E; add = add + 1.0; g = g + 1 }
    while v < 0.5 && g < 400 { v = v * E; add = add - 1.0; g = g + 1 }
    let y = (v - 1.0) / (v + 1.0)
    let y2 = y * y
    let mut term = y
    let mut sum = y
    let mut k = 1
    while k < 60 {
        term = term * y2
        let denom = to_float(2 * k + 1)
        sum = sum + term / denom
        k = k + 1
    }
    return 2.0 * sum + add
}

fn log2_(x: float) -> float { return fln(x) / fln(2.0) }

// Deterministic LCG (same constants as round-2 sibling)
let mut RNG_STATE: i64 = 987654321
fn rand_u() -> i64 {
    RNG_STATE = RNG_STATE * 1664525 + 1013904223
    let mut v = RNG_STATE / 65536
    if v < 0 { v = 0 - v }
    return v
}
fn rand_range(n: i64) -> i64 {
    if n <= 0 { return 0 }
    return rand_u() % n
}
fn rand_01() -> i64 { return rand_u() % 2 }

fn pow2(k: i64) -> i64 {
    let mut r: i64 = 1
    let mut i: i64 = 0
    while i < k { r = r * 2; i = i + 1 }
    return r
}

fn bit_i(x: i64, i: i64) -> i64 {
    return (x / pow2(i)) % 2
}

// ---- 3-SAT generator (flat encoding, signed lits) ----
fn gen_3sat(n: i64, m: i64) -> [i64] {
    let mut out: [i64] = []
    let mut ci: i64 = 0
    while ci < m {
        let mut v1 = rand_range(n) + 1
        let mut v2 = rand_range(n) + 1
        while v2 == v1 { v2 = rand_range(n) + 1 }
        let mut v3 = rand_range(n) + 1
        while v3 == v1 || v3 == v2 { v3 = rand_range(n) + 1 }
        let l1 = if rand_01() == 1 { v1 } else { 0 - v1 }
        let l2 = if rand_01() == 1 { v2 } else { 0 - v2 }
        let l3 = if rand_01() == 1 { v3 } else { 0 - v3 }
        out = out.push(l1); out = out.push(l2); out = out.push(l3)
        ci = ci + 1
    }
    return out
}

fn eval_sat(clauses: [i64], m: i64, assign: i64) -> bool {
    let mut ci: i64 = 0
    while ci < m {
        let l0 = clauses[3*ci + 0]
        let l1 = clauses[3*ci + 1]
        let l2 = clauses[3*ci + 2]
        let mut ok = false
        let v0: i64 = if l0 > 0 { l0 - 1 } else { (0 - l0) - 1 }
        let want0: i64 = if l0 > 0 { 1 } else { 0 }
        if bit_i(assign, v0) == want0 { ok = true }
        if ok == false {
            let v1: i64 = if l1 > 0 { l1 - 1 } else { (0 - l1) - 1 }
            let want1: i64 = if l1 > 0 { 1 } else { 0 }
            if bit_i(assign, v1) == want1 { ok = true }
        }
        if ok == false {
            let v2: i64 = if l2 > 0 { l2 - 1 } else { (0 - l2) - 1 }
            let want2: i64 = if l2 > 0 { 1 } else { 0 }
            if bit_i(assign, v2) == want2 { ok = true }
        }
        if ok == false { return false }
        ci = ci + 1
    }
    return true
}

// ---- Phi_irr proxy via mutual information of satisfying-marginals ----
// Partition variables into L = {1..k}, R = {k+1..n} where k = n/2 (balanced).
// For each satisfying assignment, project onto (L_pattern, R_pattern).
// Phi_irr ~= MI(L; R) over the uniform distribution on satisfying assignments.
// (IIT proper would minimize over all bipartitions; balanced is the round-1 simplification.)
//
// Returns Phi_irr in bits. If unsat (no models), returns 0.0.
fn phi_irr_balanced(clauses: [i64], n: i64, m: i64) -> float {
    let k: i64 = n / 2
    let nL: i64 = k
    let nR: i64 = n - k
    let szL: i64 = pow2(nL)
    let szR: i64 = pow2(nR)
    // joint count: idx = lpat * szR + rpat
    let mut joint: [i64] = []
    let mut i: i64 = 0
    while i < szL * szR { joint = joint.push(0); i = i + 1 }
    let mut margL: [i64] = []
    i = 0
    while i < szL { margL = margL.push(0); i = i + 1 }
    let mut margR: [i64] = []
    i = 0
    while i < szR { margR = margR.push(0); i = i + 1 }

    let total: i64 = pow2(n)
    let mut a: i64 = 0
    let mut nmodels: i64 = 0
    while a < total {
        if eval_sat(clauses, m, a) {
            // L pattern = low k bits, R pattern = high (n-k) bits
            let lpat: i64 = a % szL
            let rpat: i64 = a / szL
            joint[lpat * szR + rpat] = joint[lpat * szR + rpat] + 1
            margL[lpat] = margL[lpat] + 1
            margR[rpat] = margR[rpat] + 1
            nmodels = nmodels + 1
        }
        a = a + 1
    }
    if nmodels == 0 { return 0.0 }
    let N: float = to_float(nmodels)

    // MI = sum_{l,r} p(l,r) * log2( p(l,r) / (p(l)*p(r)) )
    let mut mi: float = 0.0
    let mut lp: i64 = 0
    while lp < szL {
        let mut rp: i64 = 0
        while rp < szR {
            let cj = joint[lp * szR + rp]
            if cj > 0 {
                let pjoint = to_float(cj) / N
                let pl = to_float(margL[lp]) / N
                let pr = to_float(margR[rp]) / N
                let denom = pl * pr
                if denom > 0.0 {
                    mi = mi + pjoint * log2_(pjoint / denom)
                }
            }
            rp = rp + 1
        }
        lp = lp + 1
    }
    if mi < 0.0 { mi = 0.0 }
    return mi
}

// ---- Polytime simplifier: unit-propagation only (round 1; CDCL = round 3) ----
// Returns simplified clauses (clauses containing already-satisfied literals removed,
// false literals dropped from remaining clauses). Records assignments in `assign_out`.
// On contradiction returns empty + sets `unsat_out=1`.
//
// Hexa list-mutation rule: we return a fresh list, never mutate caller's list.
fn unit_propagate(clauses: [i64], n: i64, m: i64) -> [i64] {
    // value: 0=unassigned, 1=true, -1=false; index 1..n
    let mut val: [i64] = []
    let mut i: i64 = 0
    while i <= n { val = val.push(0); i = i + 1 }

    let mut work_clauses = clauses
    let mut work_m = m
    let mut changed = true
    let mut guard = 0
    while changed && guard < 1000 {
        changed = false
        guard = guard + 1
        // scan for unit clauses (only one unassigned literal, others false)
        let mut ci: i64 = 0
        while ci < work_m {
            let l0 = work_clauses[3*ci + 0]
            let l1 = work_clauses[3*ci + 1]
            let l2 = work_clauses[3*ci + 2]
            // sentinel 0 means "literal removed"
            let mut alive: [i64] = []
            if l0 != 0 { alive = alive.push(l0) }
            if l1 != 0 { alive = alive.push(l1) }
            if l2 != 0 { alive = alive.push(l2) }
            // already satisfied? skip
            let mut sat = false
            let mut j = 0
            while j < alive.len() {
                let lit = alive[j]
                let v: i64 = if lit > 0 { lit } else { 0 - lit }
                let want: i64 = if lit > 0 { 1 } else { -1 }
                if val[v] == want { sat = true }
                j = j + 1
            }
            if sat == false {
                // count unassigned
                let mut un: [i64] = []
                let mut allf = true
                j = 0
                while j < alive.len() {
                    let lit = alive[j]
                    let v: i64 = if lit > 0 { lit } else { 0 - lit }
                    if val[v] == 0 { un = un.push(lit); allf = false }
                    j = j + 1
                }
                if allf { return [] }   // contradiction
                if un.len() == 1 {
                    let lit = un[0]
                    let v: i64 = if lit > 0 { lit } else { 0 - lit }
                    let assignv: i64 = if lit > 0 { 1 } else { -1 }
                    val[v] = assignv
                    changed = true
                }
            }
            ci = ci + 1
        }
    }

    // Rebuild clause list: drop satisfied clauses, drop falsified literals (mark 0)
    let mut out: [i64] = []
    let mut ci2: i64 = 0
    while ci2 < work_m {
        let l0 = work_clauses[3*ci2 + 0]
        let l1 = work_clauses[3*ci2 + 1]
        let l2 = work_clauses[3*ci2 + 2]
        let mut lits: [i64] = []
        lits = lits.push(l0); lits = lits.push(l1); lits = lits.push(l2)
        let mut sat = false
        let mut j = 0
        while j < 3 {
            let lit = lits[j]
            if lit != 0 {
                let v: i64 = if lit > 0 { lit } else { 0 - lit }
                let want: i64 = if lit > 0 { 1 } else { -1 }
                if val[v] == want { sat = true }
            }
            j = j + 1
        }
        if sat == false {
            // keep clause with falsified literals zeroed (preserves arity 3)
            let mut k = 0
            while k < 3 {
                let lit = lits[k]
                let mut keep = lit
                if lit != 0 {
                    let v: i64 = if lit > 0 { lit } else { 0 - lit }
                    let want: i64 = if lit > 0 { 1 } else { -1 }
                    if val[v] == 0 - want { keep = 0 }   // falsified -> drop
                }
                out = out.push(keep)
                k = k + 1
            }
        }
        ci2 = ci2 + 1
    }
    return out
}

// ---- main experiment ----
fn main() {
    println("=== BT-542 ROUND 1: Phi-irreducibility attack vector ===")
    println("claim BT-542-R1-C1: P=NP =/=> Phi_irr collapses under polytime simplification")
    println("falsifiability: Phi_irr_post / Phi_irr_pre across n=6..14 at alpha=4.26")
    println("")

    emit("setup", "LITERATURE",
         "anima IIT Phi-irreducibility framework (Tononi 2008) applied to 3-SAT (Cook 1971)",
         "framework=phi_holo_eval.hexa+hexad.hexa")

    let ratio: float = 4.26
    let trials_per_n: i64 = 10   // smaller than round-2 (Phi_irr is heavier per instance)

    // collect (n, ratio_post_pre)
    let mut ns: [float] = []
    let mut ratios: [float] = []
    let mut pres: [float] = []
    let mut posts: [float] = []

    let mut n: i64 = 6
    while n <= 14 {
        let m: i64 = to_int(to_float(n) * ratio + 0.5)
        if m < 1 { n = n + 1; continue }

        let mut sum_pre: float = 0.0
        let mut sum_post: float = 0.0
        let mut sum_ratio: float = 0.0
        let mut count: i64 = 0
        let mut t: i64 = 0
        while t < trials_per_n {
            RNG_STATE = 7700000 * n + 31337 * t + 41
            let clauses = gen_3sat(n, m)
            let phi_pre = phi_irr_balanced(clauses, n, m)
            let simplified = unit_propagate(clauses, n, m)
            // simplified clause count = simplified.len() / 3
            let m_post: i64 = simplified.len() / 3
            let phi_post: float = if m_post > 0 { phi_irr_balanced(simplified, n, m_post) } else { 0.0 }
            sum_pre = sum_pre + phi_pre
            sum_post = sum_post + phi_post
            if phi_pre > 0.000000001 {
                sum_ratio = sum_ratio + (phi_post / phi_pre)
                count = count + 1
            }
            t = t + 1
        }

        let avg_pre = sum_pre / to_float(trials_per_n)
        let avg_post = sum_post / to_float(trials_per_n)
        let avg_ratio: float = if count > 0 { sum_ratio / to_float(count) } else { 0.0 }
        ns = ns.push(to_float(n))
        ratios = ratios.push(avg_ratio)
        pres = pres.push(avg_pre)
        posts = posts.push(avg_post)

        emit("phi_scan", "OBSERVED",
             "Phi_irr pre vs post unit-propagation, balanced bipartition",
             "n=" + to_string(n) + " m=" + to_string(m) +
             " phi_pre=" + to_string(avg_pre) +
             " phi_post=" + to_string(avg_post) +
             " ratio_post_pre=" + to_string(avg_ratio))
        n = n + 1
    }

    // verdict: does ratio collapse toward 0 with n? (would tilt toward P=NP-friendly)
    // or stay bounded away from 0? (consistent with P!=NP)
    let kk = ratios.len()
    let mut min_r: float = 999999999999.0
    let mut max_r: float = -1.0
    let mut sumlast: float = 0.0
    let mut cntlast: i64 = 0
    let mut i = 0
    while i < kk {
        if ratios[i] < min_r { min_r = ratios[i] }
        if ratios[i] > max_r { max_r = ratios[i] }
        if i >= kk - 3 { sumlast = sumlast + ratios[i]; cntlast = cntlast + 1 }
        i = i + 1
    }
    let avg_last: float = if cntlast > 0 { sumlast / to_float(cntlast) } else { 0.0 }

    let verdict: string = if min_r >= 0.3 {
        "REINFORCE_R1_CLAIM (Phi_irr resilient to UP, no collapse)"
    } else {
        if avg_last < 0.1 { "WEAKEN_R1_CLAIM (Phi_irr collapses at large n)" }
        else { "INCONCLUSIVE (no monotone trend)" }
    }

    emit("verdict_r1", "OBSERVED",
         "BT-542-R1-C1 falsifiability outcome on n=6..14",
         "min_ratio=" + to_string(min_r) +
         " max_ratio=" + to_string(max_r) +
         " avg_last3=" + to_string(avg_last) +
         " verdict=" + verdict)

    // honesty
    emit("honesty", "HONEST_MISS",
         "round 1 is one attack vector + falsifiability test, NOT a proof",
         "BT-542 remains UNSOLVED. Phi-encoding is non-standard; balanced bipartition " +
         "is a simplification of full IIT minimization; UP is the weakest polytime " +
         "simplifier (round 3 will use CDCL). Razborov-Rudich natural-proofs barrier " +
         "applies if Phi_irr is shown to be a 'natural property'. Round 2 (brute-force " +
         "scaling, bt542_sat_scaling.hexa) is the orthogonal angle.")

    println("")
    println("=== ROUND 1 done — record at shared/state/bt_542_round1.json ===")
}

main()
