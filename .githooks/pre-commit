#!/bin/bash
# H-COMMIT pre-commit wrapper — commit.hexa 에 위임
# 검증 체인: session_lock → git_fresh → lint --staged → commit_fence → peers → broadcast → release
R=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
HEXA="$R/shared/bin/hexa"
COMMIT="$R/shared/harness/commit.hexa"
[ -x "$HEXA" ] && [ -f "$COMMIT" ] || exit 0
TO=""
command -v timeout >/dev/null 2>&1 && TO="timeout 60"
[ -z "$TO" ] && command -v gtimeout >/dev/null 2>&1 && TO="gtimeout 60"
OUT=$($TO "$HEXA" run "$COMMIT" pre_commit 2>&1)
echo "$OUT"
echo "$OUT" | tail -1 | grep -q "__HARNESS_COMMIT_RESULT__ BLOCK" && exit 1
exit 0
