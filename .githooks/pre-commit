#!/usr/bin/env bash
# pre-commit — auto-rotate falsifier_registry baseline (R3 full)
# raw 73: minimal; raw 66: reason+fix trailers on failure paths; raw 71: report+rotate only.

set -uo pipefail

NEXUS_ROOT="${NEXUS_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null)}"
if [ -z "${NEXUS_ROOT}" ] || [ ! -d "${NEXUS_ROOT}" ]; then
    echo "pre-commit: cannot resolve repo root" >&2
    echo "  reason: 'git rev-parse --show-toplevel' returned empty / non-dir" >&2
    echo "  fix: run inside a git working tree, or set NEXUS_ROOT explicitly" >&2
    exit 0  # do not block commit on infra failure
fi

REGISTRY_REL="design/hexa_sim/falsifiers.jsonl"
REGISTRY="${NEXUS_ROOT}/${REGISTRY_REL}"
BASELINE="${NEXUS_ROOT}/state/falsifier_registry.sha256"
LOG="${NEXUS_ROOT}/state/falsifier_registry_rotation_log.jsonl"

# Only fire if the registry is in the staged change-set
if ! git diff --cached --name-only 2>/dev/null | grep -qxF "${REGISTRY_REL}"; then
    exit 0
fi

# Compute SHA256 of the STAGED blob (not the working tree) — portable shasum/sha256sum
sha_tool=""
if command -v shasum >/dev/null 2>&1; then
    sha_tool="shasum -a 256"
elif command -v sha256sum >/dev/null 2>&1; then
    sha_tool="sha256sum"
else
    echo "pre-commit: no sha tool available" >&2
    echo "  reason: neither 'shasum' nor 'sha256sum' on PATH" >&2
    echo "  fix: install coreutils, or skip baseline rotation manually" >&2
    exit 0
fi

NEW_SHA=$(git show ":${REGISTRY_REL}" 2>/dev/null | ${sha_tool} | awk '{print $1}')
if [ -z "${NEW_SHA}" ]; then
    echo "pre-commit: failed to hash staged registry" >&2
    echo "  reason: 'git show :${REGISTRY_REL}' produced empty content" >&2
    echo "  fix: re-stage ${REGISTRY_REL}, or check the file exists in the index" >&2
    exit 0
fi

OLD_SHA="(none)"
if [ -f "${BASELINE}" ]; then
    OLD_SHA=$(awk '{print $1; exit}' "${BASELINE}" 2>/dev/null)
    [ -z "${OLD_SHA}" ] && OLD_SHA="(none)"
fi

if [ "${OLD_SHA}" = "${NEW_SHA}" ]; then
    exit 0  # no rotation needed
fi

# Rotate baseline (state/ is gitignored — local-only rotation; no auto-stage)
mkdir -p "$(dirname "${BASELINE}")"
echo "${NEW_SHA}" > "${BASELINE}"

# Append forensic ledger entry (R4) with hash-chained prev_hash (R5 OPT-D)
TS=$(date -u +%Y-%m-%dT%H:%M:%SZ)
mkdir -p "$(dirname "${LOG}")"

# R5 OPT-D: compute prev_hash = sha256 of last ledger line (or "genesis" if first)
PREV_HASH="genesis"
if [ -s "${LOG}" ]; then
    LAST_LINE=$(tail -n 1 "${LOG}" 2>/dev/null)
    if [ -n "${LAST_LINE}" ]; then
        PREV_HASH=$(printf '%s' "${LAST_LINE}" | ${sha_tool} | awk '{print $1}')
        [ -z "${PREV_HASH}" ] && PREV_HASH="genesis"
    fi
fi

printf '{"ts":"%s","old_sha":"%s","new_sha":"%s","trigger":"pre-commit","prev_hash":"%s"}\n' \
    "${TS}" "${OLD_SHA}" "${NEW_SHA}" "${PREV_HASH}" >> "${LOG}"

echo "pre-commit: falsifier_registry baseline rotated" >&2
echo "  old: ${OLD_SHA}" >&2
echo "  new: ${NEW_SHA}" >&2

exit 0
