{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "p=$(jq -r '.tool_input.file_path // empty'); case \"$p\" in *.py|*.rs|*.sh|*.c) echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\".py/.rs/.sh/.c 파일 생성 금지 — hexa-only\"}}';; esac"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Edit(.claude/settings.local.json)",
      "NotebookEdit",
      "Read",
      "WebFetch",
      "WebSearch",
      "Write",
      "Write(.claude/settings.local.json)"
    ],
    "deny": [
      "Bash(dd if=*)",
      "Bash(git push * +*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push -f*)",
      "Bash(mkfs*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Edit(**/config/absolute_rules.json)",
      "Edit(**/hooks/**)",
      "Edit(/Users/ghost/.claude/CLAUDE.md)",
      "Edit(/Users/ghost/.claude/agents/**)",
      "Edit(/Users/ghost/.claude/commands/**)",
      "Edit(/Users/ghost/.claude/hooks/**)",
      "Write(**/*.c)",
      "Write(**/*.py)",
      "Write(**/*.rs)",
      "Write(**/*.sh)",
      "Write(**/config/absolute_rules.json)",
      "Write(**/config/core-lockdown.json)",
      "Write(**/config/core.json)",
      "Write(**/hooks/**)",
      "Write(/Users/ghost/.claude/CLAUDE.md)",
      "Write(/Users/ghost/.claude/agents/**)",
      "Write(/Users/ghost/.claude/commands/**)",
      "Write(/Users/ghost/.claude/hooks/**)"
    ],
    "additionalDirectories": [
      "/Users/ghost",
      "/Users/ghost/Dev/nexus"
    ]
  },
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  }
}
