{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "hexa ~/Dev/nexus/shared/hooks/nexus-prompt-scan.hexa",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "hexa ~/Dev/nexus/shared/hooks/cmd-dispatch.hexa",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "hexa ~/Dev/nexus/shared/hooks/go-parallel.hexa",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "hexa ~/Dev/nexus/shared/hooks/hexa-lang-improver.hexa",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "hexa ~/Dev/nexus/shared/hooks/project-aware-improver.hexa",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "R=$(git rev-parse --show-toplevel 2>/dev/null) && [ -f \"$R/.shared/hooks/l0-prompt-guard.hexa\" ] && hexa \"$R/.shared/hooks/l0-prompt-guard.hexa\" || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "hexa ~/Dev/nexus/shared/hooks/block-forbidden-ext.hexa",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "hexa ~/Dev/nexus/shared/hooks/absolute-rules-loader.hexa",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "hexa ~/Dev/nexus/shared/hooks/hook-entry.hexa guard",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "hexa ~/Dev/nexus/shared/hooks/hexa-grammar-guard.hexa",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "hexa ~/Dev/nexus/shared/hooks/build-fail-diag.hexa",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "hexa ~/Dev/nexus/shared/hooks/growth-tick.hexa post-bash",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "hexa ~/Dev/nexus/shared/hooks/hook-entry.hexa bash /Users/ghost/Dev/nexus/shared/hooks/blowup-filter-auto.hexa",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "R=$(git rev-parse --show-toplevel 2>/dev/null) && [ -f \"$R/.shared/hooks/loop-post-commit.hexa\" ] && hexa \"$R/.shared/hooks/loop-post-commit.hexa\" || true",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "hexa ~/Dev/nexus/shared/hooks/nexus-post-edit.hexa",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "hexa ~/Dev/nexus/shared/hooks/auto-sync.hexa",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "hexa ~/Dev/nexus/shared/hooks/atlas-sync.hexa",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hexa ~/Dev/nexus/shared/hooks/atlas-health-guard.hexa",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Edit(.claude/settings.local.json)",
      "Write(.claude/settings.local.json)"
    ]
  }
}
