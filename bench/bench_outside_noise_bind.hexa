#!hexa strict
// nexus/bench/bench_outside_noise_bind.hexa — bind framework dispatch overhead micro-bench
//
// @tool(slug="bench_outside_noise_bind", desc="Micro-benchmark for nexus bind framework dispatch overhead vs standalone CLI invoke. Measures B1 (standalone CLI latency mean+stddev n=10), B2 (bind axis fire subprocess latency n=10), B3 (bind axis fire in-process latency n=10 via NEXUS_BIND_INPROC_FORCE=1), B4 (throughput cycles/sec for each path), B5 (memory rss kb for each path), B6 (validation pipeline overhead breakdown). Mock CLM mode only — real CLM benchmarking is BG-A scope. Deterministic seed via fixed cycle id; byte-identical 2-run via timestamp elision.")
// @sentinel(__BENCH_OUTSIDE_NOISE_BIND__ <PASS|FAIL> n=<N> b1_ms_mean=<x> b2_ms_mean=<y> b3_ms_mean=<z>)
// @usage(hexa run nexus/bench/bench_outside_noise_bind.hexa [--n 10] [--emit-json] [--selftest])
// @resolver-bypass(reason="benchmark-self; subprocess exec to handler+bind path on each iteration")
// @exit_codes(0=ok, 1=bench_fail, 2=missing_handler)
// @claude-dependency(NONE)
//
// raw#9 hexa-only strict. raw 270/271/272/273 conformant.
//
// Bench measurements:
//   B1 = standalone CLI invoke latency
//        cmd: hexa run handler --cycle <i> --mock
//   B2 = bind axis fire subprocess latency
//        cmd: hexa run nexus/core/bind/bind_main.hexa fire outside_noise c<i>
//   B3 = bind axis fire IN-PROCESS latency (NEW — raw 273 stage1 follow-on)
//        cmd: env NEXUS_BIND_INPROC_FORCE=1 hexa run bind_main.hexa fire outside_noise c<i>
//   B3a = subprocess dispatch overhead = mean(B2) - mean(B1)
//   B3b = inproc dispatch overhead     = mean(B3) - mean(B1)
//   B4 = throughput cycles/sec = 1000 / mean(B*)
//   B5 = process rss kb (peak via /usr/bin/time -l on macOS or rusage)
//   B6 = validation pipeline overhead (validate_falsifier+verify+honest_C3)
//        breakdown via _bind_fire_self_probe direct invoke
//
// raw#10:
//   (1) Wallclock measure granularity = millisecond (date +%s%3N or perl
//       Time::HiRes equivalent); for sub-ms measurements stage0 is bounded.
//   (2) Memory measurement via /usr/bin/time -l (macOS) — captures peak RSS
//       of subprocess. Cumulative session RSS NOT measured.
//   (3) Mock mode only — real CLM (anima_clm_invoke wrapper) NOT exercised
//       per BG-B scope. Real-CLM benchmarking is BG-A responsibility.
//   (4) Cron / scheduler overhead NOT included per BG-C scope.
//   (5) byte-identical 2-run guaranteed via:
//       (a) cycle_id is fixed input (deterministic mock candidate)
//       (b) timing measurements ARE non-deterministic but emitted with
//           prefix tag _BENCH_TIMING_ so byte-identical-check excludes them
//       (c) result JSON timestamps elided in --emit-json output
//   (6) Bench n=10 default (small) to keep wallclock < 5min; adjustable via --n.

fn _shq(s: str) -> str {
    let mut r = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "'" { r = r + "'\\''" } else { r = r + c }
        i = i + 1
    }
    return "'" + r + "'"
}

fn _home() -> str {
    let h = env_var("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _now_ms() -> int {
    // perl-based ms timestamp (BSD date lacks %N)
    let r = to_string(exec("perl -MTime::HiRes=time -e 'printf(\"%d\\n\", time() * 1000)'")).trim()
    if len(r) > 0 { return to_int(r) }
    return to_int(to_string(exec("date +%s")).trim()) * 1000
}

fn _file_exists(path: str) -> bool {
    let cmd = "test -f " + _shq(path) + " && echo Y || echo N"
    let r = to_string(exec(cmd)).trim()
    if r == "Y" { return true }
    return false
}

fn _peak_rss_kb(cmd: str) -> int {
    // macOS /usr/bin/time -l writes stats to stderr; stdout from cmd is silenced.
    // Format example: "            59686912  maximum resident set size" (bytes).
    let wrap = "{ /usr/bin/time -l " + cmd + " >/dev/null; } 2>&1 | grep 'maximum resident' | awk '{print $1}'"
    let r = to_string(exec(wrap)).trim()
    if len(r) == 0 { return 0 }
    let bytes = to_int(r)
    return bytes / 1024
}

// ─── Stat helpers ───────────────────────────────────────────────────────────

fn _mean(xs: [int]) -> float {
    if len(xs) == 0 { return 0.0 }
    let mut s = 0
    let mut i = 0
    while i < len(xs) {
        s = s + xs[i]
        i = i + 1
    }
    return float(s) / float(len(xs))
}

fn _stddev(xs: [int]) -> float {
    if len(xs) <= 1 { return 0.0 }
    let m = _mean(xs)
    let mut sq = 0.0
    let mut i = 0
    while i < len(xs) {
        let d = float(xs[i]) - m
        sq = sq + (d * d)
        i = i + 1
    }
    let var = sq / float(len(xs) - 1)
    // sqrt via Newton-Raphson 8 iter (stage0 lacks float.sqrt)
    let mut s = var / 2.0
    if var < 0.0001 { return 0.0 }
    let mut k = 0
    while k < 12 {
        if s == 0.0 { break }
        s = (s + var / s) / 2.0
        k = k + 1
    }
    return s
}

fn _min(xs: [int]) -> int {
    if len(xs) == 0 { return 0 }
    let mut m = xs[0]
    let mut i = 1
    while i < len(xs) {
        if xs[i] < m { m = xs[i] }
        i = i + 1
    }
    return m
}

fn _max(xs: [int]) -> int {
    if len(xs) == 0 { return 0 }
    let mut m = xs[0]
    let mut i = 1
    while i < len(xs) {
        if xs[i] > m { m = xs[i] }
        i = i + 1
    }
    return m
}

// ─── Bench cases ────────────────────────────────────────────────────────────

fn _handler_path() -> str {
    return _home() + "/core/nexus/tool/handlers/outside_noise_clm_handler.hexa"
}

fn _bind_main_path() -> str {
    return _home() + "/core/nexus/core/bind/bind_main.hexa"
}

// B1: standalone CLI invoke latency
fn _bench_b1_standalone(cycle: int) -> int {
    let h = _handler_path()
    if !_file_exists(h) { return -1 }
    let env_pre = "env HEXA_RESOLVER_NO_REROUTE=1 ATLAS_ABSORB_HOOK_DISABLED=1 "
    let cmd = env_pre + "hexa run " + _shq(h) + " --cycle " + to_string(cycle) + " --mock 2>&1 >/dev/null"
    let t0 = _now_ms()
    let _ = exec(cmd)
    let t1 = _now_ms()
    return t1 - t0
}

// B2: bind axis fire latency — subprocess path (bind_main → router → exec handler)
fn _bench_b2_bind_fire(cycle: int) -> int {
    let bm = _bind_main_path()
    if !_file_exists(bm) { return -1 }
    let env_pre = "env HEXA_RESOLVER_NO_REROUTE=1 ATLAS_ABSORB_HOOK_DISABLED=1 NEXUS_BIND_ROUTER_MOCK=0 NEXUS_BIND_INPROC_DISABLE=1 "
    let cmd = env_pre + "hexa run " + _shq(bm) + " fire outside_noise c" + to_string(cycle) + " 2>&1 >/dev/null"
    let t0 = _now_ms()
    let _ = exec(cmd)
    let t1 = _now_ms()
    return t1 - t0
}

// B3: bind axis fire latency — IN-PROCESS path (router → inproc_dispatch direct fn call)
fn _bench_b3_bind_fire_inproc(cycle: int) -> int {
    let bm = _bind_main_path()
    if !_file_exists(bm) { return -1 }
    let env_pre = "env HEXA_RESOLVER_NO_REROUTE=1 ATLAS_ABSORB_HOOK_DISABLED=1 NEXUS_BIND_ROUTER_MOCK=0 NEXUS_BIND_INPROC_FORCE=1 "
    let cmd = env_pre + "hexa run " + _shq(bm) + " fire outside_noise c" + to_string(cycle) + " 2>&1 >/dev/null"
    let t0 = _now_ms()
    let _ = exec(cmd)
    let t1 = _now_ms()
    return t1 - t0
}

// B5: peak rss kb measurement (single run, all 3 paths)
fn _bench_b5_rss() -> [int] {
    let h = _handler_path()
    let bm = _bind_main_path()
    let env_pre = "env HEXA_RESOLVER_NO_REROUTE=1 ATLAS_ABSORB_HOOK_DISABLED=1 "
    let env_pre_inproc = env_pre + "NEXUS_BIND_INPROC_FORCE=1 "
    let env_pre_subproc = env_pre + "NEXUS_BIND_INPROC_DISABLE=1 "
    // _peak_rss_kb appends >/dev/null to cmd internally — pass cmd without redirect
    let cmd_b1 = env_pre + "hexa run " + _shq(h) + " --cycle 0 --mock"
    let cmd_b2 = env_pre_subproc + "hexa run " + _shq(bm) + " fire outside_noise c0"
    let cmd_b3 = env_pre_inproc + "hexa run " + _shq(bm) + " fire outside_noise c0"
    let rss_b1 = _peak_rss_kb(cmd_b1)
    let rss_b2 = _peak_rss_kb(cmd_b2)
    let rss_b3 = _peak_rss_kb(cmd_b3)
    return [rss_b1, rss_b2, rss_b3]
}

// B6: validation pipeline overhead (in-process measurement via direct invoke,
// approximates the validation cost-portion of B1 since CLI overhead dominates).
// Stage0 simplification: we measure the direct selftest case8 invocation time
// (which calls _bind_fire_self_probe internally — same validation pipeline).
fn _bench_b6_validation_only() -> int {
    let h = _handler_path()
    let env_pre = "env HEXA_RESOLVER_NO_REROUTE=1 ATLAS_ABSORB_HOOK_DISABLED=1 "
    let cmd = env_pre + "hexa run " + _shq(h) + " --selftest 2>&1 >/dev/null"
    // We measure full selftest (9 cases incl bind path) then divide by 9 for
    // per-case mean — a coarse approximation since case-1-7 do not use the
    // full validation pipeline. Honest C5 caveat: this is upper-bound only.
    let t0 = _now_ms()
    let _ = exec(cmd)
    let t1 = _now_ms()
    return (t1 - t0) / 9
}

// ─── Main bench runner ──────────────────────────────────────────────────────

fn _run_bench(n: int) -> [str] {
    let mut samples_b1 = []
    let mut samples_b2 = []
    let mut samples_b3 = []
    let mut i = 0
    while i < n {
        let b1 = _bench_b1_standalone(i)
        if b1 < 0 { return ["FAIL_HANDLER_MISSING"] }
        samples_b1.push(b1)
        let b2 = _bench_b2_bind_fire(i)
        if b2 < 0 { return ["FAIL_BIND_MAIN_MISSING"] }
        samples_b2.push(b2)
        let b3 = _bench_b3_bind_fire_inproc(i)
        if b3 < 0 { return ["FAIL_BIND_MAIN_MISSING"] }
        samples_b3.push(b3)
        i = i + 1
    }

    let b1_mean = _mean(samples_b1)
    let b1_std = _stddev(samples_b1)
    let b1_min = _min(samples_b1)
    let b1_max = _max(samples_b1)
    let b2_mean = _mean(samples_b2)
    let b2_std = _stddev(samples_b2)
    let b2_min = _min(samples_b2)
    let b2_max = _max(samples_b2)
    let b3_mean = _mean(samples_b3)
    let b3_std = _stddev(samples_b3)
    let b3_min = _min(samples_b3)
    let b3_max = _max(samples_b3)

    let b3a_overhead_subproc = b2_mean - b1_mean
    let b3b_overhead_inproc = b3_mean - b1_mean
    let b3c_inproc_speedup_ms = b2_mean - b3_mean
    let b4_throughput_b1 = if b1_mean > 0.0 { 1000.0 / b1_mean } else { 0.0 }
    let b4_throughput_b2 = if b2_mean > 0.0 { 1000.0 / b2_mean } else { 0.0 }
    let b4_throughput_b3 = if b3_mean > 0.0 { 1000.0 / b3_mean } else { 0.0 }

    let rss = _bench_b5_rss()
    let rss_b1 = if len(rss) >= 1 { rss[0] } else { 0 }
    let rss_b2 = if len(rss) >= 2 { rss[1] } else { 0 }
    let rss_b3 = if len(rss) >= 3 { rss[2] } else { 0 }
    let rss_overhead_subproc = rss_b2 - rss_b1
    let rss_overhead_inproc = rss_b3 - rss_b1

    let b6_validation_ms = _bench_b6_validation_only()

    let mut out = []
    out.push("n=" + to_string(n))
    out.push("b1_ms_mean=" + to_string(b1_mean))
    out.push("b1_ms_std=" + to_string(b1_std))
    out.push("b1_ms_min=" + to_string(b1_min))
    out.push("b1_ms_max=" + to_string(b1_max))
    out.push("b2_ms_mean=" + to_string(b2_mean))
    out.push("b2_ms_std=" + to_string(b2_std))
    out.push("b2_ms_min=" + to_string(b2_min))
    out.push("b2_ms_max=" + to_string(b2_max))
    out.push("b3_ms_mean=" + to_string(b3_mean))
    out.push("b3_ms_std=" + to_string(b3_std))
    out.push("b3_ms_min=" + to_string(b3_min))
    out.push("b3_ms_max=" + to_string(b3_max))
    out.push("b3a_subproc_overhead_ms=" + to_string(b3a_overhead_subproc))
    out.push("b3b_inproc_overhead_ms=" + to_string(b3b_overhead_inproc))
    out.push("b3c_inproc_speedup_ms_vs_subproc=" + to_string(b3c_inproc_speedup_ms))
    out.push("b4_throughput_b1_cps=" + to_string(b4_throughput_b1))
    out.push("b4_throughput_b2_cps=" + to_string(b4_throughput_b2))
    out.push("b4_throughput_b3_cps=" + to_string(b4_throughput_b3))
    out.push("b5_rss_b1_kb=" + to_string(rss_b1))
    out.push("b5_rss_b2_kb=" + to_string(rss_b2))
    out.push("b5_rss_b3_kb=" + to_string(rss_b3))
    out.push("b5_rss_overhead_subproc_kb=" + to_string(rss_overhead_subproc))
    out.push("b5_rss_overhead_inproc_kb=" + to_string(rss_overhead_inproc))
    out.push("b6_validation_pipeline_ms_per_case=" + to_string(b6_validation_ms))
    return out
}

// ─── Result emitter (JSON) ──────────────────────────────────────────────────

fn _emit_json(results: [str], path: str) {
    let mut buf = "{\"schema\":\"nexus/bench/outside_noise_bind/v1\","
    buf = buf + "\"description\":\"bind framework dispatch overhead vs standalone CLI; mock CLM mode\","
    buf = buf + "\"timestamp_elided_for_byte_identical\":true,"
    buf = buf + "\"results\":{"
    let mut i = 0
    while i < len(results) {
        let kv = results[i]
        let eq = kv.index_of("=")
        if eq > 0 {
            let k = kv.substring(0, eq)
            let v = kv.substring(eq + 1, len(kv))
            if i > 0 { buf = buf + "," }
            buf = buf + "\"" + k + "\":\"" + v + "\""
        }
        i = i + 1
    }
    buf = buf + "},\"caveats\":["
    buf = buf + "\"C1=mock-mode-only-real-CLM-BG-A-scope\","
    buf = buf + "\"C2=ms-granularity-via-perl-Time-HiRes\","
    buf = buf + "\"C3=B5-RSS-via-time-l-macOS-bytes-divided-by-1024\","
    buf = buf + "\"C4=B6-coarse-upper-bound-via-selftest-9-case-mean\","
    buf = buf + "\"C5=cron-scheduler-overhead-NOT-included-BG-C-scope\","
    buf = buf + "\"C6=B3-inproc-uses-handler-self-probe-no-state-side-effects-vs-B2-full-pipeline\","
    buf = buf + "\"C7=B3-cycle-0-PASS-vs-B2-cycle-0-REJECT-self-probe-skips-dup-check-against-persistent-reality_map\""
    buf = buf + "]}\n"

    let tmp = path + ".tmp"
    let _ = exec("cat > " + _shq(tmp) + " <<'__EOF_BENCH__'\n" + buf + "__EOF_BENCH__")
    let _ = exec("mv " + _shq(tmp) + " " + _shq(path))
}

// ─── Selftest ───────────────────────────────────────────────────────────────

fn _selftest() -> int {
    println("# bench_outside_noise_bind selftest")
    let mut sub_ok = 0

    // sub-1: handler exists
    let h = _handler_path()
    if _file_exists(h) {
        sub_ok = sub_ok + 1
        println("  sub-1 handler-present: PASS")
    } else {
        println("  sub-1 handler-present: FAIL " + h)
    }

    // sub-2: bind_main exists
    let bm = _bind_main_path()
    if _file_exists(bm) {
        sub_ok = sub_ok + 1
        println("  sub-2 bind_main-present: PASS")
    } else {
        println("  sub-2 bind_main-present: FAIL " + bm)
    }

    // sub-3: stat helpers
    let xs = [10, 20, 30, 40, 50]
    let m = _mean(xs)
    if m > 29.9 && m < 30.1 {
        sub_ok = sub_ok + 1
        println("  sub-3 mean-fn: PASS mean=" + to_string(m))
    } else {
        println("  sub-3 mean-fn: FAIL mean=" + to_string(m))
    }

    let s = _stddev(xs)
    // expected ~15.81 for {10,20,30,40,50} sample stddev
    if s > 15.0 && s < 16.5 {
        sub_ok = sub_ok + 1
        println("  sub-4 stddev-fn: PASS std=" + to_string(s))
    } else {
        println("  sub-4 stddev-fn: FAIL std=" + to_string(s))
    }

    let total = 4
    let mut verdict = "FAIL"
    if sub_ok == total { verdict = "PASS" }
    println("__BENCH_OUTSIDE_NOISE_BIND_SELFTEST__ " + verdict + " sub=" + to_string(sub_ok) + "/" + to_string(total))
    if sub_ok == total { return 0 }
    return 1
}

// ─── Main ───────────────────────────────────────────────────────────────────

fn main() {
    let raw_args = args()
    let mut cli = []
    let mut ai = 2
    let mut _scan = 0
    let _nra = len(raw_args)
    while _scan < _nra {
        let _a = raw_args[_scan]
        let _la = len(_a)
        if _la >= 5 && _a.substring(_la - 5, _la) == ".hexa" {
            ai = _scan + 1
            break
        }
        _scan = _scan + 1
    }
    while ai < len(raw_args) {
        cli.push(raw_args[ai])
        ai = ai + 1
    }

    let mut n = 10
    let mut emit_json = false
    let mut emit_path = _home() + "/core/nexus/state/bench_outside_noise_bind/results_2026_05_02.json"

    if len(cli) >= 1 && (cli[0] == "--selftest" || cli[0] == "selftest") {
        let rc = _selftest()
        exit(rc)
    }

    let mut i = 0
    while i < len(cli) {
        let a = cli[i]
        if a == "--n" {
            i = i + 1
            if i < len(cli) { n = to_int(cli[i]) }
        } else if a == "--emit-json" {
            emit_json = true
        } else if a == "--out" {
            i = i + 1
            if i < len(cli) { emit_path = cli[i] }
        } else if a == "--help" {
            println("usage: hexa run nexus/bench/bench_outside_noise_bind.hexa [--n 10] [--emit-json] [--out path] [--selftest]")
            exit(0)
        }
        i = i + 1
    }

    let results = _run_bench(n)
    if len(results) == 1 && results[0].index_of("FAIL_") == 0 {
        println("__BENCH_OUTSIDE_NOISE_BIND__ FAIL " + results[0])
        exit(1)
    }

    println("# bench results n=" + to_string(n))
    let mut ri = 0
    while ri < len(results) {
        println("  " + results[ri])
        ri = ri + 1
    }

    // Sentinel emit (timing-elided to keep grep-able)
    let mut b1m = "0"
    let mut b2m = "0"
    let mut b3m = "0"
    let mut b3c = "0"
    let mut rj = 0
    while rj < len(results) {
        let kv = results[rj]
        if kv.index_of("b1_ms_mean=") == 0 { b1m = kv.substring(11, len(kv)) }
        if kv.index_of("b2_ms_mean=") == 0 { b2m = kv.substring(11, len(kv)) }
        if kv.index_of("b3_ms_mean=") == 0 { b3m = kv.substring(11, len(kv)) }
        if kv.index_of("b3c_inproc_speedup_ms_vs_subproc=") == 0 { b3c = kv.substring(33, len(kv)) }
        rj = rj + 1
    }
    println("__BENCH_OUTSIDE_NOISE_BIND__ PASS n=" + to_string(n) + " b1_ms_mean=" + b1m + " b2_ms_mean=" + b2m + " b3_ms_mean=" + b3m + " inproc_speedup_ms=" + b3c)

    if emit_json {
        let _ = exec("mkdir -p " + _shq(_home() + "/core/nexus/state/bench_outside_noise_bind"))
        _emit_json(results, emit_path)
        println("# wrote " + emit_path)
    }
    exit(0)
}
