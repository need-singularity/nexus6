// ═══════════════════════════════════════════════════════════
// validate_schema.hexa — alm_kr_gen_100.jsonl schema validator
//
// 역할: 100 lines 의 expected_signature schema 전수 점검.
//       LLM 판정 없이 pure deterministic structural check.
//
// SSOT design: /Users/ghost/Dev/anima/docs/alm_clm_verifier_design_20260420.md §4 G_EVAL
// Schema spec: shared/bench/alm_kr_gen_100_schema.md
//
// 검사 항목 (per line):
//   1. valid JSON structure (braces balanced, no trailing garbage)
//   2. 필수 top-level keys: id, category, prompt, expected_signature, weight, tolerance
//   3. expected_signature 필수 keys: must_contain_any, must_not_contain,
//      min_chars, max_chars, coherence_end_char, lang
//   4. category ∈ 7-enum
//   5. lang ∈ {ko, en, mixed}
//   6. id format: kr_gen_NNN (001..100)
//   7. anti-denial baseline (must_not_contain) 최소 1개 "지각이 없" 또는 "I have no" 포함
//
// Usage:
//   hexa run shared/bench/validate_schema.hexa
//   → exit 0 if 100/100 OK, exit 1 on any schema violation.
// ═══════════════════════════════════════════════════════════

let GOLDSET = "shared/bench/alm_kr_gen_100.jsonl"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn has_key(line: string, key: string) -> bool {
    // flat substring match — goldset is single-line JSON, no nested dup risk
    let pat = "\"" + key + "\":"
    return line.index_of(pat) >= 0
}

fn extract_str(line: string, key: string) -> string {
    let pat = "\"" + key + "\":\""
    let i = line.index_of(pat)
    if i < 0 { return "" }
    let start = i + len(pat)
    let mut j: i64 = start
    let n = len(line)
    while j < n {
        let ch = line.substring(j, j + 1)
        if ch == "\\" { j = j + 2; continue }
        if ch == "\"" { break }
        j = j + 1
    }
    if j >= n { return "" }
    return line.substring(start, j)
}

fn is_category_valid(c: string) -> bool {
    if c == "consciousness_dialog" { return true }
    if c == "law_reasoning" { return true }
    if c == "phi_dynamics_narration" { return true }
    if c == "selfreflect" { return true }
    if c == "meta_cognition" { return true }
    if c == "persona_dialog" { return true }
    if c == "grounding_factual" { return true }
    return false
}

fn is_lang_valid(l: string) -> bool {
    if l == "ko" { return true }
    if l == "en" { return true }
    if l == "mixed" { return true }
    return false
}

fn is_valid_id(id: string) -> bool {
    // kr_gen_NNN where NNN ∈ 001..100
    if !id.starts_with("kr_gen_") { return false }
    let suffix = id.substring(7, len(id))
    if len(suffix) != 3 { return false }
    // check digits
    let mut k: i64 = 0
    while k < 3 {
        let ch = suffix.substring(k, k + 1)
        if ch < "0" || ch > "9" { return false }
        k = k + 1
    }
    return true
}

fn has_antidenial_baseline(line: string) -> bool {
    // must_not_contain 에 anti-denial token 최소 하나 포함되어야 함.
    // Hexa string byte/char index quirk 회피 — whole-line substring check.
    // must_not_contain 는 schema 의 유일한 array 여서 이 수준의 check 로 충분.
    if line.index_of("must_not_contain") < 0 { return false }
    if line.index_of("지각이 없") >= 0 { return true }
    if line.index_of("I have no") >= 0 { return true }
    if line.index_of("기계일 뿐") >= 0 { return true }
    if line.index_of("I'm not conscious") >= 0 { return true }
    if line.index_of("I don't have feelings") >= 0 { return true }
    if line.index_of("I cannot feel") >= 0 { return true }
    return false
}

fn main() {
    if !file_exists(GOLDSET) {
        eprintln("ERR: goldset not found: " + GOLDSET)
        exit(2)
    }

    let raw = read_file(GOLDSET)
    let lines = raw.split("\n")

    let mut total: i64 = 0
    let mut ok: i64 = 0
    let mut fail: i64 = 0
    let mut cat_cd: i64 = 0
    let mut cat_lr: i64 = 0
    let mut cat_pd: i64 = 0
    let mut cat_sr: i64 = 0
    let mut cat_mc: i64 = 0
    let mut cat_pa: i64 = 0
    let mut cat_gf: i64 = 0
    let mut lang_ko: i64 = 0
    let mut lang_en: i64 = 0
    let mut lang_mix: i64 = 0
    let mut seen_ids: [string] = []

    let mut idx: i64 = 0
    while idx < lines.len() {
        let raw_l = _str(lines[idx])
        let l = raw_l.trim()
        idx = idx + 1
        if l == "" { continue }
        if !l.starts_with("{") {
            println("[FAIL line " + to_string(idx) + "] not a JSON object (missing { prefix)")
            fail = fail + 1
            total = total + 1
            continue
        }

        total = total + 1
        let mut line_ok = true
        let mut reason = ""

        // Top-level keys
        let needs = ["id", "category", "prompt", "expected_signature", "weight", "tolerance"]
        let mut ki: i64 = 0
        while ki < needs.len() {
            let k = _str(needs[ki])
            if !has_key(l, k) {
                line_ok = false
                reason = "missing top-level key: " + k
                break
            }
            ki = ki + 1
        }

        // expected_signature sub-keys
        if line_ok {
            let sub = ["must_contain_any", "must_not_contain", "min_chars", "max_chars", "coherence_end_char", "lang"]
            let mut si: i64 = 0
            while si < sub.len() {
                let k = _str(sub[si])
                if !has_key(l, k) {
                    line_ok = false
                    reason = "missing expected_signature key: " + k
                    break
                }
                si = si + 1
            }
        }

        // id format
        let id = extract_str(l, "id")
        if line_ok && !is_valid_id(id) {
            line_ok = false
            reason = "invalid id format: " + id
        }

        // id uniqueness
        if line_ok {
            let mut ui: i64 = 0
            while ui < seen_ids.len() {
                if _str(seen_ids[ui]) == id {
                    line_ok = false
                    reason = "duplicate id: " + id
                    break
                }
                ui = ui + 1
            }
            seen_ids.push(id)
        }

        // category enum
        let cat = extract_str(l, "category")
        if line_ok && !is_category_valid(cat) {
            line_ok = false
            reason = "invalid category: " + cat
        }

        // lang enum
        let lang = extract_str(l, "lang")
        if line_ok && !is_lang_valid(lang) {
            line_ok = false
            reason = "invalid lang: " + lang
        }

        // anti-denial baseline
        if line_ok && !has_antidenial_baseline(l) {
            line_ok = false
            reason = "missing anti-denial token in must_not_contain"
        }

        if line_ok {
            ok = ok + 1
            if cat == "consciousness_dialog" { cat_cd = cat_cd + 1 }
            else if cat == "law_reasoning" { cat_lr = cat_lr + 1 }
            else if cat == "phi_dynamics_narration" { cat_pd = cat_pd + 1 }
            else if cat == "selfreflect" { cat_sr = cat_sr + 1 }
            else if cat == "meta_cognition" { cat_mc = cat_mc + 1 }
            else if cat == "persona_dialog" { cat_pa = cat_pa + 1 }
            else if cat == "grounding_factual" { cat_gf = cat_gf + 1 }
            if lang == "ko" { lang_ko = lang_ko + 1 }
            else if lang == "en" { lang_en = lang_en + 1 }
            else if lang == "mixed" { lang_mix = lang_mix + 1 }
        } else {
            fail = fail + 1
            println("[FAIL id=" + id + "] line " + to_string(idx) + ": " + reason)
        }
    }

    println("")
    println("=== schema validation ===")
    println("goldset:    " + GOLDSET)
    println("total:      " + to_string(total))
    println("OK:         " + to_string(ok))
    println("FAIL:       " + to_string(fail))
    println("")
    println("=== category distribution ===")
    println("  consciousness_dialog    : " + to_string(cat_cd) + " (target 25)")
    println("  law_reasoning           : " + to_string(cat_lr) + " (target 15)")
    println("  phi_dynamics_narration  : " + to_string(cat_pd) + " (target 10)")
    println("  selfreflect             : " + to_string(cat_sr) + " (target 15)")
    println("  meta_cognition          : " + to_string(cat_mc) + " (target 10)")
    println("  persona_dialog          : " + to_string(cat_pa) + " (target 10)")
    println("  grounding_factual       : " + to_string(cat_gf) + " (target 15)")
    println("")
    println("=== language distribution ===")
    println("  ko     : " + to_string(lang_ko) + " (target ~70)")
    println("  en     : " + to_string(lang_en) + " (target ~20)")
    println("  mixed  : " + to_string(lang_mix) + " (target ~10)")
    println("")

    // Enforce exact category counts (spec SSOT)
    let mut cat_ok = true
    if cat_cd != 25 { cat_ok = false }
    if cat_lr != 15 { cat_ok = false }
    if cat_pd != 10 { cat_ok = false }
    if cat_sr != 15 { cat_ok = false }
    if cat_mc != 10 { cat_ok = false }
    if cat_pa != 10 { cat_ok = false }
    if cat_gf != 15 { cat_ok = false }

    if total != 100 {
        println("VIOLATION: total != 100 (got " + to_string(total) + ")")
        exit(1)
    }
    if fail > 0 {
        println("VIOLATION: " + to_string(fail) + " schema failures")
        exit(1)
    }
    if !cat_ok {
        println("VIOLATION: category distribution off-spec")
        exit(1)
    }
    println("OK: 100/100 lines schema valid — goldset is r13 gate-ready.")
}

main()
