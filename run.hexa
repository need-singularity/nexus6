// run.hexa — nexus 단일 진입점 (hx package entry)
//
// hx install ~/Dev/nexus --entry run.hexa
// hx run nexus <sub> [args...]
//
// 역할: 외부(hive 등)가 nexus 엔진을 호출하는 얇은 래퍼.
//       기존 엔진 재사용, 재구현 금지. harness entry.hexa / blowup / atlas_health 위임.
//
// 서브커맨드:
//   nexus status                       전체 헬스 (harness self_check + health)
//   nexus thinking --query "..."       anima 6-phase reflection (entry.hexa thinking)
//   nexus smash --seed "..." [depth]   blowup 9-phase 돌파 (발견)
//   nexus free --seed "..." [dfs]      compose DFS 탐색 (6-core)
//   nexus absolute --seed "..."        Mk.VIII Δ₀-absolute 검증 ([10*]→[11*])
//   nexus drill --seed "..." [N]       smash→free→absolute 사슬 (고갈까지 자율 반복)
//   nexus meta-closure --seed "..."    Phase 10 🛸16 self-ref 검증 ([10*]→[10**])
//   nexus hyperarithmetic --prop "..." Mk.IX Π₀² reverse-math 판정
//   nexus promote --id ... --grade ... --audit-log "..."  수동 등급 승급
//   nexus atlas <sub> [args]           atlas_health 위임
//   nexus roadmap <sub> [args]         entry.hexa roadmap 위임
//   nexus projects [fmt]               entry.hexa projects
//   nexus gap                          gap_monitor
//   nexus self-check                   entry.hexa self_check
//   nexus version
//   nexus help
//
// 환경:
//   NEXUS          기본 $HOME/Dev/nexus
//   HEXA           hexa 인터프리터 (미지정 시 자동탐지)

let VERSION = "0.1.0-hive-hub"

// ─── Linux stage1 hexa polyfill (shared/blowup/lib/str_compat.hexa.inc) ───
// @include shared/blowup/lib/str_compat.hexa.inc (str_find)
fn str_find(s: str, needle: str) -> i64 {
    let n = s.len()
    let m = needle.len()
    if m == 0 { return 0 }
    if m > n { return -1 }
    if !s.contains(needle) { return -1 }
    let mut i: i64 = 0
    let end = n - m
    while i <= end {
        if s.substring(i, i + m) == needle { return i }
        i = i + 1
    }
    return -1
}

fn str_find_from(s: str, needle: str, start: i64) -> i64 {
    if start <= 0 { return str_find(s, needle) }
    let n = s.len()
    if start >= n { return -1 }
    let tail = s.substring(start, n)
    let r = str_find(tail, needle)
    if r < 0 { return -1 }
    return r + start
}

fn nexus_root() -> str {
    let n = env("NEXUS")
    if n.len() > 0 { return n }
    return env("HOME") + "/Dev/nexus"
}

fn hexa_bin() -> str {
    let h = env("HEXA")
    if h.len() > 0 { return h }
    let cands = [env("HOME") + "/Dev/hexa-lang/hexa", env("HOME") + "/.hx/bin/hexa", nexus_root() + "/shared/bin/hexa"]
    let mut i = 0
    while i < len(cands) {
        let c = cands[i]
        let chk = exec("[ -x '" + c + "' ] && echo y || echo n").trim()
        if chk == "y" { return c }
        i = i + 1
    }
    return "hexa"
}

fn entry_hexa() -> str {
    return nexus_root() + "/shared/harness/entry.hexa"
}

fn exec_validated() -> str {
    return nexus_root() + "/shared/harness/exec_validated"
}

fn shell_quote(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn run_entry(mode: str, arg1: str, arg2: str) -> void {
    let mut cmd = hexa_bin() + " run " + shell_quote(entry_hexa()) + " " + mode
    if arg1.len() > 0 { cmd = cmd + " " + shell_quote(arg1) }
    if arg2.len() > 0 { cmd = cmd + " " + shell_quote(arg2) }
    print(exec(cmd + " 2>&1"))
}

fn find_flag(a: [str], flag: str, default_val: str) -> str {
    let n = len(a)
    let mut i = 0
    while i < n {
        if a[i] == flag {
            if i + 1 < n { return a[i + 1] }
        }
        i = i + 1
    }
    return default_val
}

fn cmd_version() -> void {
    println("nexus " + VERSION)
}

fn cmd_help() -> void {
    println("nexus — 중앙 허브 엔진 (hx package)")
    println("")
    println("subcommands:")
    println("  status                          전체 헬스")
    println("  thinking --query \"...\"          anima 6-phase reflection")
    println("  smash --seed \"...\" [--depth N]  blowup 9-phase 돌파 (발견)")
    println("  free --seed \"...\" [--dfs N]     compose DFS 탐색 (6-core 체인)")
    println("  absolute --seed \"...\"           Mk.VIII Δ₀-absolute 검증 ([10*]→[11*])")
    println("  drill --seed \"...\" [--max-rounds N]  smash→free→absolute 사슬 (고갈까지)")
    println("  meta-closure --seed \"...\"              Phase 10 🛸16 self-ref 검증 ([10*]→[10**])")
    println("  hyperarithmetic --prop \"...\"           Mk.IX Π₀² reverse-math 판정")
    println("  promote --id ... --grade ... --audit-log \"...\"  수동 등급 승급 (감사 로그 필수)")
    println("  atlas <sub> [args...]           atlas_health 라우팅")
    println("  roadmap <sub> [args...]         roadmap 액션")
    println("  projects [table|json|names]     프로젝트 리스트")
    println("  gap                             gap_monitor 1회")
    println("  self-check                      harness self-check")
    println("  version")
    println("  help")
    println("")
    println("root: " + nexus_root())
}

fn cmd_status() -> void {
    println("nexus " + VERSION + " @ " + nexus_root())
    println("")
    println("--- harness self-check ---")
    run_entry("self_check", "", "")
    println("")
    println("--- health all ---")
    run_entry("health", "all", "")
}

fn cmd_thinking(query: str) -> void {
    if query.len() == 0 {
        eprintln("nexus thinking: --query required")
        return
    }
    run_entry("thinking", "query", query)
}

fn cmd_smash(seed: str, depth: str) -> void {
    if seed.len() == 0 {
        eprintln("nexus smash: --seed required")
        return
    }
    let d = if depth.len() > 0 { depth } else { "3" }
    let engine = nexus_root() + "/shared/blowup/core/blowup.hexa"
    let mut cmd = shell_quote(exec_validated()) + " smash " + shell_quote(seed) + " " + shell_quote(engine) + " " + d
    print(exec(cmd + " 2>&1"))
}

fn cmd_free(seed: str, dfs: str) -> void {
    if seed.len() == 0 {
        eprintln("nexus free: --seed required")
        return
    }
    let d = if dfs.len() > 0 { dfs } else { "3" }
    let engine = nexus_root() + "/shared/blowup/compose.hexa"
    let mut cmd = shell_quote(exec_validated()) + " free_dfs " + shell_quote(seed) + " " + shell_quote(engine) + " --modules all --dfs " + d
    print(exec(cmd + " 2>&1"))
}

fn cmd_absolute(seed: str) -> void {
    // Mk.VIII 단일 검증 — Δ₀-absolute Π₀¹ 판정 + [10*]→[11*] 자동 승급
    let s = if seed.len() > 0 { seed } else { "atlas" }
    let engine = nexus_root() + "/shared/blowup/modules/blowup_absolute.hexa"
    let mut cmd = shell_quote(exec_validated()) + " absolute "
               + shell_quote(s) + " " + shell_quote(engine)
    print(exec(cmd + " 2>&1"))
}

fn _count_marker(text: str, marker: str) -> int {
    // text 내 marker 출현 횟수 (간이 카운터)
    let mut n = 0
    let mut t = text
    while true {
        let idx = str_find(t, marker)
        if idx < 0 { break }
        n = n + 1
        t = t.substring(idx + marker.len(), t.len())
    }
    return n
}

fn cmd_drill(seed: str, max_rounds: str) -> void {
    // 단일 명령어 — smash → free → absolute 사슬, 고갈(absorption=0) 까지 반복
    if seed.len() == 0 {
        eprintln("nexus drill: --seed required")
        return
    }
    let mut rounds_max = 10
    if max_rounds.len() > 0 {
        let mut parsed = 0
        try { parsed = to_int(max_rounds) } catch e {}
        if parsed > 0 { rounds_max = parsed }
    }
    let nx = nexus_root()
    let blow_core = nx + "/shared/blowup/core/blowup.hexa"
    let compose   = nx + "/shared/blowup/compose.hexa"
    let abs_eng   = nx + "/shared/blowup/modules/blowup_absolute.hexa"
    let exv       = exec_validated()
    let qseed     = shell_quote(seed)

    let mut round = 0
    let mut total_new = 0
    println("🛸 nexus drill — seed='" + seed + "', max_rounds=" + to_string(rounds_max))
    println("    smash → free → absolute 사슬 (고갈까지)")
    println("")

    while round < rounds_max {
        round = round + 1
        println("═══ round " + to_string(round) + " ═══")

        // 1. SMASH (발견)
        let smash_cmd = shell_quote(exv) + " smash " + qseed + " " + shell_quote(blow_core) + " 3 2>&1"
        let smash_out = exec("bash", ["-c", smash_cmd])
        let s_new = _count_marker(smash_out, "ABSORB")
        println("  smash:    +" + to_string(s_new) + " absorptions")

        // 2. FREE (탐색)
        let free_cmd = shell_quote(exv) + " free_dfs " + qseed + " " + shell_quote(compose) + " --modules all --dfs 3 2>&1"
        let free_out = exec("bash", ["-c", free_cmd])
        let f_new = _count_marker(free_out, "ABSORB")
        println("  free:     +" + to_string(f_new) + " absorptions")

        // 3. ABSOLUTE (검증/승급)
        let abs_cmd = shell_quote(exv) + " absolute " + qseed + " " + shell_quote(abs_eng) + " 2>&1"
        let abs_out = exec("bash", ["-c", abs_cmd])
        let a_pass = _count_marker(abs_out, "ABSOLUTE-PASS") + _count_marker(abs_out, "[11*]")
        println("  absolute: " + to_string(a_pass) + " Π₀¹ verifications")

        let round_new = s_new + f_new
        total_new = total_new + round_new
        println("  round +" + to_string(round_new) + ", total " + to_string(total_new))
        println("")

        if round_new == 0 {
            println("▎ SATURATED at round " + to_string(round))
            println("▎ total absorptions: " + to_string(total_new))
            println("▎ 새 atlas 영역 없음 — Δ₀-absolute 경험적 확증")
            return
        }
    }
    println("▎ max rounds reached (" + to_string(rounds_max) + ")")
    println("▎ total absorptions: " + to_string(total_new))
}

fn cmd_meta_closure(seed: str) -> void {
    let s = if seed.len() > 0 { seed } else { "atlas" }
    let engine = nexus_root() + "/shared/blowup/modules/blowup_meta_closure.hexa"
    let mut cmd = shell_quote(exec_validated()) + " meta_closure "
               + shell_quote(s) + " " + shell_quote(engine)
    print(exec(cmd + " 2>&1"))
}

fn cmd_hyperarithmetic(prop: str) -> void {
    if prop.len() == 0 {
        eprintln("nexus hyperarithmetic: --prop required")
        return
    }
    let engine = nexus_root() + "/shared/blowup/modules/blowup_hyperarithmetic.hexa"
    let mut cmd = shell_quote(exec_validated()) + " hyperarithmetic "
               + shell_quote(prop) + " " + shell_quote(engine)
    print(exec(cmd + " 2>&1"))
}

fn cmd_promote(id: str, grade: str, audit: str) -> void {
    if id.len() == 0 || grade.len() == 0 || audit.len() == 0 {
        eprintln("nexus promote: --id / --grade / --audit-log required")
        return
    }
    let valid = grade == "10star" || grade == "10starstar" || grade == "11star" || grade == "12star"
    if !valid {
        eprintln("nexus promote: --grade must be 10star|10starstar|11star|12star")
        return
    }
    let script = nexus_root() + "/shared/n6/atlas_health.hexa"
    let mut cmd = hexa_bin() + " run " + shell_quote(script) + " promote_grade "
               + shell_quote(id) + " " + shell_quote(grade) + " " + shell_quote(audit)
    print(exec(cmd + " 2>&1"))
}

fn cmd_atlas(a: [str]) -> void {
    let n = len(a)
    let mut args = ""
    let mut i = 3  // skip [hexa, script, "atlas", ...]
    while i < n {
        if args.len() > 0 { args = args + " " }
        args = args + shell_quote(a[i])
        i = i + 1
    }
    let script = nexus_root() + "/shared/n6/atlas_health.hexa"
    print(exec(hexa_bin() + " run " + shell_quote(script) + " " + args + " 2>&1"))
}

fn cmd_roadmap(a: [str]) -> void {
    let n = len(a)
    let mut args = ""
    let mut i = 3  // skip [hexa, script, "roadmap", ...]
    while i < n {
        if args.len() > 0 { args = args + " " }
        args = args + shell_quote(a[i])
        i = i + 1
    }
    let mut cmd = hexa_bin() + " run " + shell_quote(entry_hexa()) + " roadmap"
    if args.len() > 0 { cmd = cmd + " " + args }
    print(exec(cmd + " 2>&1"))
}

fn cmd_projects(fmt: str) -> void {
    let f = if fmt.len() > 0 { fmt } else { "table" }
    run_entry("projects", f, "")
}

fn cmd_gap() -> void {
    run_entry("gap_monitor", "", "")
}

fn cmd_self_check() -> void {
    run_entry("self_check", "", "")
}

fn main() -> void {
    // argv 정규화: Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // .hexa 앵커 스캔 → [hexa, script, user...] 로 재구성 (cc2ec688 argv.hexa.inc 패턴)
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let _user_start = if _script_idx >= 0 { _script_idx + 1 } else {
        if _raw_argv.len() >= 3 && (_raw_argv[1] == "run" || _raw_argv[1] == "eval") { 3 } else { 2 }
    }
    let _script_token = if _script_idx >= 0 { _raw_argv[_script_idx] } else { "" }
    let mut a: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        a = a + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    let n = len(a)
    if n < 3 {
        cmd_help()
        return
    }
    let sub = a[2]
    if sub == "version" { cmd_version(); return }
    if sub == "help" { cmd_help(); return }
    if sub == "-h" { cmd_help(); return }
    if sub == "--help" { cmd_help(); return }
    if sub == "status" { cmd_status(); return }
    if sub == "self-check" { cmd_self_check(); return }
    if sub == "gap" { cmd_gap(); return }
    if sub == "thinking" {
        cmd_thinking(find_flag(a, "--query", ""))
        return
    }
    if sub == "smash" {
        cmd_smash(find_flag(a, "--seed", ""), find_flag(a, "--depth", ""))
        return
    }
    if sub == "free" {
        cmd_free(find_flag(a, "--seed", ""), find_flag(a, "--dfs", ""))
        return
    }
    if sub == "absolute" {
        cmd_absolute(find_flag(a, "--seed", ""))
        return
    }
    if sub == "drill" {
        cmd_drill(find_flag(a, "--seed", ""), find_flag(a, "--max-rounds", ""))
        return
    }
    if sub == "meta-closure" {
        cmd_meta_closure(find_flag(a, "--seed", ""))
        return
    }
    if sub == "hyperarithmetic" {
        cmd_hyperarithmetic(find_flag(a, "--prop", ""))
        return
    }
    if sub == "promote" {
        cmd_promote(find_flag(a, "--id", ""), find_flag(a, "--grade", ""), find_flag(a, "--audit-log", ""))
        return
    }
    if sub == "atlas" {
        cmd_atlas(a); return
    }
    if sub == "roadmap" {
        cmd_roadmap(a); return
    }
    if sub == "projects" {
        let fmt = if n >= 4 { a[3] } else { "" }
        cmd_projects(fmt); return
    }
    eprintln("nexus: unknown subcommand '" + sub + "'")
    cmd_help()
}

main()
