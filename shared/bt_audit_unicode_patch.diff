# bt_audit_unicode_patch — SKIP (특수기호 수식) 해소 패치
# 대상: shared/bt_audit.py
# 상태: 수동 병합 대기 (bt_audit parser v2 patch 에이전트와 충돌 회피)
# 작성: 2026-04-09
#
# 배경
# ----
# SKIP 613건 중 ~19건이 `6×10⁻⁵`, `a—b`, `x÷y` 같은 유니코드 특수기호
# 수식에서 발생. 기존 `_convert_superscripts`는 `⁻`(U+207B)를 SUP_MAP에
# 포함하지 않아 `10⁻⁵` → `10⁻**5` 로 깨지고 `allowed` 문자셋 검사에서
# 탈락해 SKIP. 본 패치는 부호 위첨자(⁻/⁺)를 런(run)의 일부로 인식하도록
# 수정하고, 진입 초반에 `normalize_expr_unicode` 전처리를 호출한다.
#
# 병합 방법
# ---------
# 1) cp shared/bt_audit.py shared/bt_audit.py.bak.before_unicode
# 2) 아래 unified diff 적용:   patch -p1 < shared/bt_audit_unicode_patch.diff
#    또는 수동 편집
# 3) 재실행:                   python3 shared/bt_audit.py
# 4) SKIP 카운트 before/after 비교
#
# 셀프 테스트 (Python REPL 에서 검증 가능)
# ----------------------------------------
#   '6×10⁻⁵'  → '6*10**-5'
#   '1.5×10³' → '1.5*10**3'
#   'a—b'     → 'a-b'
#   'x÷y'     → 'x/y'
#   '10⁻³'    → '10**-3'
#   'e⁺²'     → 'e**+2'

--- a/shared/bt_audit.py
+++ b/shared/bt_audit.py
@@ -95,25 +95,49 @@
 # 유니코드 윗첨자 → **N (거듭제곱)
 SUP_MAP = {
     '⁰': '0', '¹': '1', '²': '2', '³': '3', '⁴': '4',
     '⁵': '5', '⁶': '6', '⁷': '7', '⁸': '8', '⁹': '9',
 }

+# 위첨자 부호 (⁻⁵, ⁺³)
+SUP_SIGN_MAP = {'⁻': '-', '⁺': '+'}
+
+
+def normalize_expr_unicode(s):
+    """유니코드 특수기호를 ASCII 로 정규화 (parse 전처리 진입점).
+
+    - × · → *   |   ÷ → /
+    - − – — → -
+    - NBSP/얇은 공백 → 공백, 연속 공백 축약
+    위첨자 런은 _convert_superscripts 가 담당(부호 포함).
+    """
+    if s is None:
+        return s
+    s = s.replace('\u00a0', ' ').replace('\u2009', ' ')
+    s = s.replace('\u200b', '').replace('\ufeff', '')
+    s = s.replace('×', '*').replace('·', '*').replace('÷', '/')
+    s = s.replace('−', '-').replace('–', '-').replace('—', '-')
+    s = s.replace('\u2010', '-').replace('\u2011', '-')
+    return re.sub(r'\s+', ' ', s).strip()
+

 def _convert_superscripts(s):
-    """연속된 유니코드 윗첨자를 **N 으로 변환"""
+    """연속된 유니코드 윗첨자(부호 포함)를 **<sign>N 으로 변환"""
     out = []
     i = 0
     while i < len(s):
-        if s[i] in SUP_MAP:
+        if s[i] in SUP_MAP or s[i] in SUP_SIGN_MAP:
             j = i
+            sign = ''
+            if s[j] in SUP_SIGN_MAP:
+                sign = SUP_SIGN_MAP[s[j]]
+                j += 1
             digits = ''
             while j < len(s) and s[j] in SUP_MAP:
                 digits += SUP_MAP[s[j]]
                 j += 1
-            out.append('**' + digits)
+            if digits:
+                out.append('**' + sign + digits)
+            elif sign:
+                out.append('**' + sign)
             i = j
         else:
             out.append(s[i])
             i += 1
     return ''.join(out)
