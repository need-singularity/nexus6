  "keywords": {
    "trigger": ["못박아줘", "잠궈줘", "잠금", "고정해줘", "고정", "건드리지마", "건들지마", "코어로", "L0으로"],
    "action": "해당 파일/모듈을 L0(불변식)에 등록",
    "steps": [
      "1. core-lockdown.json 해당 프로젝트 L0 배열에 추가",
      "2. 이미 L1이면 L0으로 승격",
      "3. desc에 왜 못박는지 한 줄 설명 포함",
      "4. 커밋 + push"
    ],
    "example": "'blowup.hexa 못박아줘' → nexus.L0에 blowup.hexa 등록"
  },

  "ai_protocol": {
    "on_L0_edit_request": [
      "1. '이 파일은 L0 코어 보호 파일입니다. 수정 승인하시겠습니까?' 질문",
      "2. 승인 후 수정 → 커밋 메시지에 'L0-수정: [파일명] — [이유]' 명시",
      "3. 파일 상단 불변식 주석에 변경 사항 반영",
      "4. 해당 프로젝트 테스트 통과 확인"
    ],
    "on_L1_edit": [
      "1. 변경 이유 커밋 메시지에 기록",
      "2. 관련 테스트 통과 확인"
    ],
    "on_L2_edit": [
      "자유 수정 — 테스트 통과만 확인"
    ]
  }
