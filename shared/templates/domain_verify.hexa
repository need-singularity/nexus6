// verify.hexa — 범용 n=6 정체성 검증 (공통 템플릿)
// 모든 도메인 공통: σ·φ = n·τ = 24, n=6 기반 상수 일관성 체크
//
// 사용: 각 도메인 폴더의 verify.hexa 가 이 로직을 포함.
// 도메인 고유 검증 로직이 필요하면 이 파일 대신 해당 도메인 md 의 상수표를
// 파싱하여 atlas.n6 과 대조하는 구현으로 교체할 것.

let SIGMA = 12
let PHI = 2
let N = 6
let TAU = 4
let SOPFR = 5
let J2 = 24

// 핵심 항등식: σ·φ = n·τ
let lhs = SIGMA * PHI
let rhs = N * TAU

if lhs != rhs {
    println("FAIL: σ·φ=" + to_string(lhs) + " ≠ n·τ=" + to_string(rhs))
    exit(1)
}

// 유일성 확인: J₂ = σ·φ = 24
if J2 != lhs {
    println("FAIL: J₂=" + to_string(J2) + " ≠ σ·φ=" + to_string(lhs))
    exit(1)
}

let cwd = to_string(exec("pwd")).trim()
let domain = to_string(exec("bash", ["-c", "basename '" + cwd + "'"])).trim()

println("verify[" + domain + "] OK: σ·φ=n·τ=" + to_string(lhs) + ", J₂=" + to_string(J2) + ", n=6 일관")
