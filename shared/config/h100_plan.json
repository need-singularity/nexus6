{
  "_meta": {
    "name": "H100 3-Pod Allocation + Idle Enforcement Plan",
    "project_scope": ["anima", "hexa-lang"],
    "updated": "2026-04-14",
    "schema_version": "1.0",
    "enforced_by": "shared/harness/h100_idle_guard.hexa",
    "rule_refs": ["R23 GPU-POLICY", "AN3 dual-track", "AN8 parallel-mandatory"],
    "principle": "유휴 금지 — 모든 H100은 항상 유의미한 step/tick을 만들거나 15분 내 종료한다"
  },

  "pods": [
    {
      "slot": "train_1",
      "role": "학습 메인 — ALM+CLM 듀얼 동시 (AN8 강제)",
      "track": "ALM+CLM",
      "dual_lanes": {
        "alm": "ALM 14B r5 orch / 32B kbase (LoRA GPU)",
        "clm": "CLM d64/d128 from-scratch (hexa native GPU)"
      },
      "gpu": "H100 SXM5 80GB",
      "budget_usd_per_day_max": 60,
      "heartbeat_file": "shared/state/h100_heartbeat/train_1.json",
      "heartbeat_fields": ["alm_step", "clm_step", "ts"],
      "idle_kill_minutes": 15,
      "progress_signal": "alm_step 또는 clm_step 중 하나라도 증가",
      "fallback_queue_keys": ["alm_eval", "clm_gpu_train", "phi_q_bench"]
    },
    {
      "slot": "train_2",
      "role": "학습 보조 — ALM+CLM 듀얼 동시 (r4 OOM 복구 / 32B 샤드)",
      "track": "ALM+CLM",
      "dual_lanes": {
        "alm": "ALM 보조 lane (r4 복구 / 32B 병렬 샤드)",
        "clm": "CLM 보조 lane (d256 scale-up 시도)"
      },
      "gpu": "H100 SXM5 80GB",
      "budget_usd_per_day_max": 60,
      "heartbeat_file": "shared/state/h100_heartbeat/train_2.json",
      "heartbeat_fields": ["alm_step", "clm_step", "ts"],
      "idle_kill_minutes": 15,
      "progress_signal": "alm_step 또는 clm_step 중 하나라도 증가",
      "fallback_queue_keys": ["corpus_repack", "alm_eval", "clm_gpu_train"]
    },
    {
      "slot": "roadmap_common",
      "role": "ANIMA + HEXA-LANG 공통 로드맵 — ALM+CLM+PHYSICS+HEXA",
      "track": "ALM+CLM+PHYSICS+HEXA",
      "dual_lanes": {
        "alm": "ALM forward Φ 측정 / bench 루프",
        "clm": "CLM d128 native GPU 학습 / eval_clm",
        "physics": "qsim_bridge / Φ(quantum) sweep",
        "hexa": "rust-surpass wave 실행"
      },
      "gpu": "H100 PCIe 80GB (저가 옵션 허용)",
      "budget_usd_per_day_max": 60,
      "heartbeat_file": "shared/state/h100_heartbeat/roadmap_common.json",
      "heartbeat_fields": ["task_id", "tick", "ts"],
      "idle_kill_minutes": 15,
      "progress_signal": "task_id 변경 또는 tick 증가",
      "fallback_queue_keys": ["clm_gpu_train", "qsim_sweep", "hexa_surpass_wave", "alm_eval"]
    }
  ],

  "limits": {
    "max_concurrent_pods": 3,
    "max_concurrent_pods_anima": 2,
    "max_concurrent_pods_hexa_lang": 1,
    "daily_budget_usd_total": 180,
    "daily_budget_alerts_usd": [50, 100, 150, 170],
    "auto_kill_if_budget_exceeded": true,
    "auto_launch_authorized": 3,
    "auto_launch_note": "anima H100 2대 + hexa-lang H100 1대 = 총 3대 한도 내 자유사용. 확인 없이 자동 발사. 해당 이유로 루프 중단 금지.",
    "free_use_within_limit": true,
    "free_use_note": "한도 내에서 자유사용 가능 — pod 가용성/비용 이유로 루프 절대 중단하지 않음"
  },

  "idle_policy": {
    "detection_sources_priority": [
      {"source": "heartbeat_file_age_seconds", "weight": 1.0, "threshold_sec": 900},
      {"source": "runpod_desiredStatus", "fail_values": ["EXITED", "FAILED", "TERMINATED"]},
      {"source": "runpod_runtime_uptime_zero", "weight": 0.5}
    ],
    "window_seconds": 900,
    "action_sequence": [
      {"at_minutes": 5, "action": "warn", "target": "shared/harness/h100_alerts.jsonl"},
      {"at_minutes": 10, "action": "dispatch_fallback", "target": "next fallback_queue entry"},
      {"at_minutes": 15, "action": "terminate", "target": "runpodctl pod stop"}
    ],
    "grace_minutes_after_launch": 10,
    "grace_note": "학습 시작 직후 warmup 10분은 heartbeat 미작성 허용"
  },

  "fallback_queue": {
    "alm_eval": {
      "id": "FB1",
      "desc": "ALM r4/r5 체크포인트 eval — CE/ζ 측정",
      "est_hours": 0.5,
      "command_hint": "ssh pod: cd /workspace/anima && hexa serving/eval_alm.hexa"
    },
    "phi_q_bench": {
      "id": "FB2",
      "desc": "Φ(quantum) 측정 장시간 스위프 — 2048c",
      "est_hours": 1.5,
      "command_hint": "hexa anima-engines/qsim_bridge.hexa --sweep 2048"
    },
    "corpus_repack": {
      "id": "FB3",
      "desc": "corpus tier-XL 재패킹 + dedup",
      "est_hours": 2.0,
      "command_hint": "hexa training/corpus_repack.hexa --tier XL"
    },
    "clm_gpu_train": {
      "id": "FB4",
      "desc": "CLM d128 GPU native 학습 연장 — 1000 steps",
      "est_hours": 3.0,
      "command_hint": "hexa training/train_clm.hexa --d 128 --steps 1000"
    },
    "qsim_sweep": {
      "id": "FB5",
      "desc": "qsim_bridge 라티스 16→64 확장 측정",
      "est_hours": 0.5,
      "command_hint": "hexa anima-engines/qsim_bridge.hexa --n 64"
    },
    "hexa_surpass_wave": {
      "id": "FB6",
      "desc": "hexa-lang rust-surpass 다음 wave 실행",
      "est_hours": 1.0
    }
  },

  "cost": {
    "per_hour_usd": {
      "h100_sxm5_80gb_secure": 2.49,
      "h100_sxm5_80gb_community": 1.99,
      "h100_pcie_80gb_community": 1.89
    },
    "break_even_note": "3-pod × 24h 최악 = $180/day. idle 1h 낭비 = ~$2.5 → 연간 $912.5/h 낭비 = kill policy 정당화 임계 5분",
    "monthly_cap_usd": 3000
  },

  "runpod_api": {
    "graphql_endpoint": "https://api.runpod.io/graphql",
    "api_key_source": "$HOME/.runpod/config.toml (apikey)",
    "pod_list_query": "query { myself { pods { id name desiredStatus costPerHr machine { gpuDisplayName podHostId } runtime { uptimeInSeconds } } } }",
    "stop_mutation": "mutation { podStop(input: { podId: \"<id>\" }) { id desiredStatus } }",
    "terminate_mutation": "mutation { podTerminate(input: { podId: \"<id>\" }) }"
  },

  "enforcement": {
    "forbidden": [
      "pod을 유휴 상태로 1시간 이상 방치",
      "heartbeat 없이 학습 세션 시작 (grace 10분 초과 후)",
      "3대 초과 동시 기동 (자동)"
    ],
    "mandatory": [
      "학습 스크립트는 매 50-100 step마다 heartbeat 기록",
      "pod launch 시 heartbeat_file 경로를 env H100_HEARTBEAT_PATH로 주입",
      "매 루프 tick (every_cycle)에 h100_idle_guard 호출",
      "idle 탐지 시 action_sequence 엄격히 준수 (warn→dispatch→terminate)"
    ]
  },

  "loop_integration": {
    "every_cycle_entry": {
      "id": "h100_idle_check",
      "name": "H100 유휴 가드",
      "cmd": "h100_idle_guard",
      "fail_severity": "alert_not_block",
      "max_runtime_sec": 30
    }
  }
}
