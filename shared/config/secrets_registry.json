{
  "_meta": {
    "description": "비밀키 위치 레지스트리 — 실제 키는 $HOME/Dev/secret/ 에 보관. 여기는 위치만 기록.",
    "updated": "2026-04-11",
    "secret_repo": "$HOME/Dev/secret",
    "rule": "절대 이 파일에 실제 키/토큰 값을 기록하지 말 것. 경로와 용도만 기록."
  },
  "services": {
    "r2": {
      "name": "Cloudflare R2",
      "source": "$HOME/Dev/secret/README.md § 2",
      "env_vars": ["ANIMA_R2_ENDPOINT", "ANIMA_R2_ACCESS_KEY", "ANIMA_R2_SECRET_KEY"],
      "rclone_remote": "r2",
      "rclone_conf": "~/.config/rclone/rclone.conf",
      "buckets": {
        "anima-memory": "의식 DNA / 기억 저장",
        "anima-models": "모델 체크포인트 (학습 완료 즉시 업로드)",
        "anima-corpus": "학습 corpus (tier-S/M/L/XL)"
      },
      "used_by": ["anima", "anima-agent"],
      "checkpoint_naming": {
        "pattern": "{model}-r{round}-s{step}",
        "example": "alm14b-r2-s2000",
        "r2_path": "anima-models/{model}/r{round}/step_{step}/",
        "rule": "파일명에 날짜 불필요 (R2 메타데이터에 자동 기록). model+round+step만으로 유일 식별."
      }
    },
    "zenodo": {
      "name": "Zenodo (DOI 발행)",
      "source": "$HOME/Dev/secret/README.md § 6",
      "tokens": {
        "production": "$HOME/Dev/TECS-L/.local/zenodo_token",
        "sandbox": "$HOME/Dev/TECS-L/.local/zenodo_sandbox_token"
      },
      "account": "nerve011235@gmail.com",
      "scopes": ["deposit:actions", "deposit:write"],
      "used_by": ["papers"]
    },
    "osf": {
      "name": "OSF (논문 노드)",
      "source": "$HOME/Dev/secret/README.md § 7",
      "tokens": {
        "production": "$HOME/Dev/TECS-L/.local/osf_token",
        "sandbox": "$HOME/Dev/TECS-L/.local/osf_test_token"
      },
      "account": "nerve011235@gmail.com",
      "used_by": ["papers"]
    },
    "runpod": {
      "name": "RunPod GPU",
      "source": "$HOME/Dev/secret/README.md § 10",
      "ssh_key": "~/.runpod/ssh/RunPod-Key-Go",
      "used_by": ["anima"]
    },
    "vastai": {
      "name": "Vast.ai GPU (비활성)",
      "source": "$HOME/Dev/secret/README.md § 9",
      "cli": "~/.config/vastai/vast_api_key",
      "status": "deprecated — RunPod H100으로 통합",
      "used_by": []
    },
    "gmail": {
      "name": "Gmail API (아웃리치)",
      "source": "$HOME/Dev/secret/README.md § 5",
      "credentials": "$HOME/Dev/secret/gmail_credentials.json",
      "token": "$HOME/Dev/secret/gmail_token.json",
      "used_by": ["contact"]
    },
    "fal": {
      "name": "fal.ai (이미지 생성)",
      "source": "$HOME/Dev/secret/README.md § 3",
      "used_by": ["creator"]
    },
    "openrouter": {
      "name": "OpenRouter LLM",
      "source": "$HOME/Dev/secret/README.md § 4",
      "used_by": ["creator"]
    },
    "gemini": {
      "name": "Google AI (Gemini)",
      "source": "$HOME/Dev/secret/README.md § 8",
      "used_by": ["anima-agent"]
    },
    "namecheap": {
      "name": "Namecheap (도메인)",
      "source": "$HOME/Dev/secret/README.md § 10 (Namecheap)",
      "used_by": ["void"]
    },
    "linode": {
      "name": "Linode/Akamai (htz)",
      "source": "$HOME/Dev/secret/README.md § 11",
      "used_by": ["nexus", "void"]
    }
  }
}
