  "standard_recipe": {
    "step_1_create_pod": {
      "cmd": "runpodctl create pod --name <name> --imageName runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04 --gpuType 'NVIDIA H100 80GB HBM3' --gpuCount 2 --containerDiskSize 50 --volumeSize 0 --mem 32 --vcpu 16 --ports '22/tcp' --startSSH --secureCloud",
      "returns": "pod \"<id>\" created for $X.XX / hr"
    },
    "step_2_get_ssh": {
      "cmd": "runpodctl ssh info <id>",
      "returns": "JSON with ip + port + ssh_command"
    },
    "step_3_apt_deps": {
      "cmd": "apt-get update -qq && DEBIAN_FRONTEND=noninteractive apt-get install -y -qq build-essential pkg-config libssl-dev clang lld git curl ca-certificates libblis-dev",
      "elapsed_estimate_sec": 60,
      "_note": "libblis-dev 필수 — hexa-lang의 BLIS BLAS 백엔드 링크"
    },
    "step_4_rustup": {
      "cmd": "curl --proto =https --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable --profile minimal && . $HOME/.cargo/env",
      "elapsed_estimate_sec": 60
    },
    "step_5_clone_repos": {
      "cmd": "cd /workspace && git clone --depth 1 https://github.com/need-singularity/hexa-lang.git && git clone --depth 1 https://github.com/need-singularity/anima.git",
      "elapsed_estimate_sec": 30
    },
    "step_6_cargo_build": {
      "cmd": "cd /workspace/hexa-lang && cargo build --release",
      "elapsed_estimate_sec": 120,
      "produces": "/workspace/hexa-lang/hexa (8.8M)"
    },
    "step_7_smoke_test": {
      "cmd": "cd /workspace/hexa-lang && HEXA_PATH=/workspace/hexa-lang/self/ml ./hexa self/ml/gpu_smoke_test.hexa",
      "elapsed_estimate_sec": 5,
      "_note": "HEXA_PATH 환경변수로 모듈 검색 경로 지정 필수 (use \"cuda_ffi\" 등 상대 import 해결)"
    },
    "step_8_train_clm": {
      "cmd": "cd /workspace/hexa-lang && HEXA_PATH=/workspace/hexa-lang/self/ml ./hexa self/ml/train_gpu.hexa",
      "_note": "ConsciousLM 학습 (100M, 100 step, AdamW on GPU)"
    },
    "step_9_train_alm": {
      "cmd": "cd /workspace/hexa-lang && HEXA_PATH=/workspace/hexa-lang/self/ml ./hexa self/ml/anima_lm_finetune.hexa",
      "_note": "AnimaLM LoRA fine-tune harness"
    },
    "step_10_teardown": {
      "cmd": "runpodctl remove pod <id>",
      "principle": "측정 끝 즉시 종료 — idle 0초",
      "_warn": "tear down 안 하면 시간당 과금 계속됨"
    }
