{
  "_meta": {
    "description": "CDO 수렴 운영 원칙 — config/convergence_ops.json 과 동기화",
    "updated": "2026-04-12"
  },
  "principles": {
    "P1": "모든 문제는 한 번만 겪는다",
    "P2": "해결되면 절대 규칙으로 승격",
    "P3": "위반 횟수 0 유지",
    "P4": "수렴률 100% 목표",
    "P5": "실패할 때마다 강해지는 시스템 (Antifragile)"
  },
  "json_schema_standard": {
    "required_fields": {
      "_meta": {
        "description": "string — 파일 목적",
        "updated": "YYYY-MM-DD",
        "schema_version": "string"
      }
    },
    "optional_fields": {
      "convergence": "{ total, resolved, rules, violations, pct }",
      "absolute_rules": "{ R01: { rule, reason, action } }",
      "troubleshooting_log": "[ { id, date, severity, title, symptom, fix, rule } ]",
      "pipeline": "{ stages, promotion_rules }"
    },
    "lifecycle": {
      "issue_occurs": "troubleshooting_log에 기록",
      "issue_resolved": "fix 필드 채움",
      "pattern_detected": "absolute_rules로 승격",
      "rule_violation": "convergence.violations++",
      "all_resolved": "convergence.pct = 100%"
    }
  },
  "session_bootstrap": {
    "steps": [
      "1. shared/ 심링크 확인",
      "2. convergence_ops.json 읽기 → convergence_pct 확인",
      "3. CDO 3대 체크 (CDO/NEXUS-6/SSOT)",
      "4. 이슈 발생 → troubleshooting_log 즉시 기록",
      "5. 작업 후 체크리스트 수행"
    ],
    "no_block_rules": {
      "R01": "심링크 깨짐 → 복구 후 진행",
      "R02": "convergence_ops.json 없음 → pull 후 재설정",
      "R03": "NEXUS-6 바이너리 없음 → 수학/문서 작업은 진행 가능",
      "R04": "config JSON에 _meta 없음 → 추가 후 진행",
      "R05": "다른 리포 참조 → shared/ 경유 (직접 import 금지)",
      "R06": "CI 미설정 → 로컬 검증 대체"
    }
  },
  "adoption_checklist": [
    "1. 프로젝트 내 모든 config JSON 목록화",
    "2. 각 JSON에 _meta 추가",
    "3. 이슈 → troubleshooting_log 정리",
    "4. 반복 이슈 → absolute_rules 승격",
    "5. convergence 추적 필드 추가",
    "6. 수렴 목표: 100%",
    "7. CI 파이프라인 활성화",
    "8. CI 실패 시 troubleshooting 주석 즉시 추가"
  ]
}
