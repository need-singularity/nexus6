      "steps": [
        "교차 검증 (3회 반복)",
        "폐쇄 파이프라인 검증 (closed_loop.hexa)",
        "공식화",
        "4곳 동시 등록 (laws.json + theory.md + DD문서 + update_history)",
        "검증 (tests.hexa --verify)"
