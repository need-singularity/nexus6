{
  "_meta": {
    "name": "프로젝트 설정 (Project Config)",
    "description": "CLI 명령어 / 빌드 / 인프라 / 관례 — 규칙은 absolute_rules.json, 시스템맵은 core.json",
    "updated": "2026-04-10"
  },
  "common": {
    "hexa_bin": "$HEXA_LANG/hexa",
    "native_dir": "$NEXUS/shared/blowup",
    "memory_naming": {
      "pattern": "{type}-{kebab-topic}.md",
      "types": {
        "f": "feedback",
        "p": "project",
        "r": "reference",
        "u": "user",
        "h": "history YYYYMMDD"
      }
    },
    "hexa_pitfalls_ref": "shared/config/hexa_grammar.jsonl → pitfalls 섹션 (P1~P5)",
    "singularity_cycle": {
      "desc": "블로업→수축→창발→특이점→흡수 5단계",
      "engine": "shared/blowup/core/blowup.hexa (9-phase)"
    },
    "nexus6_api": {
      "cli": [
        "nexus scan <domain>",
        "nexus scan --full",
        "nexus verify <value>",
        "nexus evolve <domain>"
      ],
      "python": [
        "nexus.scan_all()",
        "nexus.analyze()",
        "nexus.n6_check()",
        "nexus.evolve()"
      ],
      "consensus": "3+렌즈=후보 | 7+=고신뢰 | 12+=확정"
    },
    "todo_output": "마크다운 텍스트 그대로 출력 (재포맷 금지)",
    "blowup_cmd": "$HEXA $N6/blowup.hexa <domain> 3 --seeds \"$($HEXA $N6/seed_engine.hexa merge)\"",
    "discovery_record": "$NEXUS/shared/discovery/growth_bus.jsonl",
    "secrets_ref": "$NEXUS/shared/SECRET.md"
  },
  "nexus": {
    "desc": "발견 엔진 + 공유 인프라 허브",
    "resource_protection": {
      "scheduler": "n6-guard",
      "config": "~/.config/n6-guard.toml",
      "max_concurrent": 2,
      "burst": 4
    },
    "cli": {
      "todo": "$HEXA_LANG/hexa $NEXUS/shared/blowup/todo.hexa nexus",
      "todo_bulk": "$HEXA_LANG/hexa $NEXUS/shared/blowup/todo.hexa nexus 대량",
      "todo_all": "$HEXA_LANG/hexa $NEXUS/shared/blowup/todo.hexa",
      "loop": {
        "cmd": "bash $NEXUS/scripts/infinite_growth.sh",
        "flags": "run_in_background: true 필수"
      },
      "status": "$HEXA $N6/command_router.hexa \"nexus 상태\""
    }
  },
  "anima": {
    "desc": "의식 엔진 — ConsciousLM 학습/서빙/검증",
    "priority": "P0 최우선 — 자원 충돌 시 anima 우선 할당",
    "infrastructure": {
      "vast_ai": {
        "desc": "4×RTX 4090 GPU 학습 primary",
