{
  "id": "permissions-ssot",
  "description": "전 프로젝트 .claude/settings.json 의 permissions 블록 SSOT — 훅 제거 이후 프로세스 레벨 강제 레이어",
  "version": "1.0.0",
  "updated": "2026-04-14",
  "rationale": "훅 시스템 해체 후 block-forbidden-ext / L0 가드 등 진짜 '차단' 이 필요한 규칙은 permissions.deny 로 이관. Claude Code 자체가 패턴 매칭으로 tool 호출 차단.",

  "allow": [
    "Bash",
    "Read",
    "Edit",
    "Write",
    "WebFetch",
    "WebSearch",
    "NotebookEdit"
  ],

  "deny_categories": {
    "hexa_first": {
      "description": "R1 HEXA-FIRST — .py/.rs/.sh 신규 작성 금지 (기존 편집은 Edit로 가능)",
      "patterns": [
        "Write(**/*.py)",
        "Write(**/*.rs)",
        "Write(**/*.sh)"
      ]
    },
    "global_claude_protect": {
      "description": "~/.claude/ 글로벌 내부 직접 수정 금지 (settings.json 만 허용)",
      "patterns": [
        "Write(/Users/ghost/.claude/hooks/**)",
        "Edit(/Users/ghost/.claude/hooks/**)",
        "Write(/Users/ghost/.claude/CLAUDE.md)",
        "Edit(/Users/ghost/.claude/CLAUDE.md)",
        "Write(/Users/ghost/.claude/commands/**)",
        "Edit(/Users/ghost/.claude/commands/**)",
        "Write(/Users/ghost/.claude/agents/**)",
        "Edit(/Users/ghost/.claude/agents/**)",
        "Write(/Users/ghost/.claude/plugins/**)",
        "Edit(/Users/ghost/.claude/plugins/**)"
      ]
    },
    "shared_l0_protect": {
      "description": "shared/config/ L0 파일 직접 수정 금지",
      "patterns": [
        "Write(**/shared/config/absolute_rules.json)",
        "Write(**/shared/config/core-lockdown.json)",
        "Write(**/shared/config/core.json)",
        "Edit(**/shared/config/absolute_rules.json)"
      ]
    },
    "shared_hooks_archive": {
      "description": "shared/hooks/ 는 archive 예정 — 신규 작성/수정 금지 (harness/ 사용)",
      "patterns": [
        "Write(**/shared/hooks/**)",
        "Edit(**/shared/hooks/**)"
      ]
    },
    "git_force": {
      "description": "force push / force with lease 금지",
      "patterns": [
        "Bash(git push -f*)",
        "Bash(git push --force*)",
        "Bash(git push * -f*)",
        "Bash(git push * --force*)",
        "Bash(git push * +*)",
        "Bash(git push --force-with-lease*)"
      ]
    },
    "destructive_shell": {
      "description": "위험한 shell 조작 금지",
      "patterns": [
        "Bash(rm -rf /*)",
        "Bash(rm -rf ~*)",
        "Bash(rm -rf $HOME*)",
        "Bash(:(){ :|:& };:*)",
        "Bash(mkfs*)",
        "Bash(dd if=*)"
      ]
    }
  },

  "deny_flat": "deny_categories 를 평면화한 최종 deny 배열. settings.json 에 이 배열을 그대로 사용",

  "build_deny_array": [
    "Write(**/*.py)",
    "Write(**/*.rs)",
    "Write(**/*.sh)",
    "Write(/Users/ghost/.claude/hooks/**)",
    "Edit(/Users/ghost/.claude/hooks/**)",
    "Write(/Users/ghost/.claude/CLAUDE.md)",
    "Edit(/Users/ghost/.claude/CLAUDE.md)",
    "Write(/Users/ghost/.claude/commands/**)",
    "Edit(/Users/ghost/.claude/commands/**)",
    "Write(/Users/ghost/.claude/agents/**)",
    "Edit(/Users/ghost/.claude/agents/**)",
    "Write(**/shared/config/absolute_rules.json)",
    "Write(**/shared/config/core-lockdown.json)",
    "Write(**/shared/config/core.json)",
    "Edit(**/shared/config/absolute_rules.json)",
    "Write(**/shared/hooks/**)",
    "Edit(**/shared/hooks/**)",
    "Bash(git push -f*)",
    "Bash(git push --force*)",
    "Bash(git push * -f*)",
    "Bash(git push * --force*)",
    "Bash(git push * +*)",
    "Bash(git push --force-with-lease*)",
    "Bash(rm -rf /*)",
    "Bash(rm -rf ~*)",
    "Bash(rm -rf $HOME*)",
    "Bash(mkfs*)",
    "Bash(dd if=*)"
  ],

  "additional_directories": [
    "/Users/ghost",
    "/Users/ghost/Dev/nexus"
  ],

  "skip_dangerous_mode_prompt": true,
  "default_mode": "bypassPermissions",

  "note": "이 파일은 SSOT. 프로젝트별 .claude/settings.json 은 이 파일의 build_deny_array 를 복사해서 permissions.deny 에 넣기. 수정 시 전 프로젝트 재동기화 필요 (shared/harness/sync_permissions.hexa 활용 예정)."
}
