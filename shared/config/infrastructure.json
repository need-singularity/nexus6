  "mac_perf": {
    "_meta": "Mac 부하 영구 대책 SSOT. 2026-04-11 골화. spotlight 인덱싱 + iTerm 누적 + claude 멀티세션 + hexa self-host 빌드 폭주 등 전형 패턴 통합. 연관 메모리: project_mac-load-profile.md",
    "principle": "mac 은 코딩/UI 만 (offload_strategy 참조). target/cache 디렉토리는 spotlight 인덱싱에서 제외. heavy compute 는 모두 ubu/htz/vast 로 라우팅.",
    "spotlight_excludes": {
      "marker": ".metadata_never_index",
      "method": "macOS 표준: 디렉토리 안에 빈 .metadata_never_index 파일 생성 → mds 가 해당 디렉토리 인덱싱 안 함. 즉시 효과 (mds 자동 인지).",
      "applied_2026-04-11": [
        "$HEXA_LANG/build_cache",
        "$ANIMA/build_cache"
      ],
      "trigger_pattern": "self-host 빌드 시 spotlightknowledged 100%+ CPU → build_cache/.metadata_never_index 누락 의심",
      "rebuild_command": "find ~/Dev -maxdepth 4 -type d -name build_cache 2>/dev/null | while read d; do touch \"$d/.metadata_never_index\"; done",
      "future": "hexa self-host 빌드 캐시는 build_cache/.metadata_never_index 자동 추가."
    },
    "iterm_accumulation": {
      "pattern": "24h+ 가동 시 iTerm2 + zsh 자식 9개+ 누적 → CPU 40-80%, WindowServer 15-25% 동반 폭주",
      "fix": "iTerm 재시작 (세션 손실 주의 — 중요 출력 미리 저장)",
      "ref": "memory/project_mac-load-profile.md"
    },
    "claude_multisession": {
      "pattern": "동시 5+ 세션 시 claude × N 합산 70%+ CPU. 백그라운드 세션도 활성 (auto-update, 메모리 hooks).",
      "fix": "불필요 세션 /quit. 단 진행 중 작업 손실 위험 — 작업 마무리 후 종료."
    },
    "hexa_build_routing": {
      "pattern": "hexa self-host 빌드는 `./hexa build self/main.hexa -o hexa && codesign --force --sign - hexa` (mac) 또는 clang 직접. ubu/htz는 SSH 경유.",
      "principle": "각 호스트 별도 빌드 — mac=ARM native, ubu/htz=x86_64 native. binary 직접 복사는 동일 아키 시만.",
      "ref": "hexa-lang/self/main.hexa (stage1 CLI SSOT) → hexa_v2 → C → clang → native. 2026-04-13~ go/cargo 스타일 서브커맨드."
    }
  },

