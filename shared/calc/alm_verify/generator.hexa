// ═══════════════════════════════════════════════════════════
// alm_verify/generator.hexa — ALM deterministic gate verifier stub generator
//
// Role: manifest.jsonl (1 line = 1 claim) → verify_<id>.hexa auto-emit.
// Pattern mirror: shared/calc/auto_stubs_gen.hexa (nexus closure-sweep calculator).
// Design SSOT: /Users/ghost/Dev/anima/docs/alm_clm_verifier_design_20260420.md
//
// Input:  shared/calc/alm_verify/manifest.jsonl
//         Each line = {"id":..., "round":..., "gate":..., "hyp":..., "target":...,
//                      "expr":..., "closure":..., "input_path":..., "verifier_type":...}
//
// Output: shared/calc/alm_verify/verify_<id>.hexa  (1 file per manifest line)
//
// usage:
//   hexa run shared/calc/alm_verify/generator.hexa --emit
//   hexa run shared/calc/alm_verify/generator.hexa --status
//   hexa run shared/calc/alm_verify/generator.hexa --append '<json>'
//   hexa run shared/calc/alm_verify/generator.hexa --append -          # stdin JSON
//
// Strict rule: LLM judge 금지 — 모든 emitted stub 은 deterministic (regex/jq/수치/hash).
//
// --emit: id 중복 시 기존 파일 overwrite 하지 않음 (수작업 2 examples 보호).
// --append sentinel: "__APPEND_RESULT__ <OK_NEW|OK_DUP|FAIL> <id_or_reason>"
// ═══════════════════════════════════════════════════════════

let HOME = env("HOME")
let REPO_ROOT = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
let STUBS_DIR = REPO_ROOT + "/shared/calc/alm_verify"
let MANIFEST = STUBS_DIR + "/manifest.jsonl"
let TRACK = "alm"

// ─── helpers ───

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn min_i64(a: i64, b: i64) -> i64 {
    if a < b { return a }
    return b
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "")
    r = r.replace("\t", " ")
    return r
}

// Hexa string literal body escape (for emit) — backslash + double-quote only.
fn hexa_str_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    return r
}

// Simple JSON value extraction — manifest is well-formed (we control it).
fn jget(line: string, key: string) -> string {
    let pat = "\"" + key + "\":\""
    let i = line.index_of(pat)
    if i < 0 { return "" }
    let start = i + len(pat)
    let mut j: i64 = start
    let n = len(line)
    while j < n {
        let ch = line.substring(j, j + 1)
        if ch == "\\" { j = j + 2; continue }
        if ch == "\"" { break }
        j = j + 1
    }
    if j >= n { return "" }
    return line.substring(start, j).replace("\\\"", "\"").replace("\\\\", "\\")
}

// ─── verifier_type templates ───
//
// Each template renders a complete verify_<id>.hexa body.
// Contract: emit "__VERIFY_RESULT__ <id> PASS|FAIL <actual> vs <target>" then exit(1) if FAIL.

fn tmpl_header(id: string, hyp: string, vtype: string, gate: string, round: string) -> string {
    let mut s = ""
    s = s + "// AUTO-GENERATED — shared/calc/alm_verify/generator.hexa\n"
    s = s + "// manifest line id: " + id + "\n"
    s = s + "// round: " + round + "  gate: " + gate + "  verifier_type: " + vtype + "\n"
    s = s + "// hyp: " + hyp + "\n"
    s = s + "//\n"
    s = s + "// Deterministic — LLM judge 금지.\n"
    s = s + "\n"
    s = s + "let id = \"" + hexa_str_escape(id) + "\"\n"
    return s
}

fn tmpl_footer(id: string) -> string {
    // footer wired per-template via println + __VERIFY_RESULT__ sentinel.
    return ""
}

// pod resolver (SSH gated for pod-side files)
fn tmpl_pod_block() -> string {
    let mut s = ""
    s = s + "let pod = env(\"HEXA_VERIFY_POD\")\n"
    s = s + "let pod_host = if pod != \"\" { pod } else { \"87xsc\" }\n"
    return s
}

// --- corpus_regex_ratio ---
// hyp: match_count / total_lines >= target_ratio
// input_path: pod path (SSH)
// target: "0.30" (float string)
fn tmpl_corpus_regex_ratio(id: string, hyp: string, target: string, expr: string, input_path: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, "corpus_regex_ratio", gate, round)
    // Extract regex from expr if in form "regex_count(/PATTERN/i) / ..." else use expr directly.
    let mut regex_body = expr
    let slash1 = expr.index_of("/")
    if slash1 >= 0 {
        let rest = expr.substring(slash1 + 1, len(expr))
        let slash2 = rest.index_of("/")
        if slash2 > 0 {
            regex_body = rest.substring(0, slash2)
        }
    }
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let target_ratio = to_float(\"" + hexa_str_escape(target) + "\")\n"
    s = s + "let corpus_path = \"" + hexa_str_escape(input_path) + "\"\n"
    s = s + "let keyword_re = \"" + hexa_str_escape(regex_body) + "\"\n"
    s = s + "\n"
    s = s + tmpl_pod_block()
    s = s + "let total_cmd = \"ssh \" + pod_host + \" 'wc -l < \" + corpus_path + \"'\"\n"
    s = s + "let match_cmd = \"ssh \" + pod_host + \" 'grep -c -i -E \\\"\" + keyword_re + \"\\\" \" + corpus_path + \"'\"\n"
    s = s + "let total = to_int(exec(total_cmd).trim())\n"
    s = s + "let matches = to_int(exec(match_cmd).trim())\n"
    s = s + "let ratio = if total > 0 { to_float(to_string(matches)) / to_float(to_string(total)) } else { 0.0 }\n"
    s = s + "let status = if ratio >= target_ratio { \"PASS\" } else { \"FAIL\" }\n"
    s = s + "let ratio_str = to_string(ratio)\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  corpus:   \" + corpus_path + \" (pod=\" + pod_host + \")\")\n"
    s = s + "println(\"  total:    \" + to_string(total))\n"
    s = s + "println(\"  matches:  \" + to_string(matches))\n"
    s = s + "println(\"  density:  \" + ratio_str)\n"
    s = s + "println(\"  target:   >= \" + target)\n"
    s = s + "println(\"  status:   \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + ratio_str + \" vs \" + target)\n"
    s = s + "if status == \"FAIL\" { exit(1) }\n"
    return s
}

// --- corpus_regex_zero ---
// hyp: regex match count == 0 over input_path
fn tmpl_corpus_regex_zero(id: string, hyp: string, target: string, expr: string, input_path: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, "corpus_regex_zero", gate, round)
    let mut regex_body = expr
    let slash1 = expr.index_of("/")
    if slash1 >= 0 {
        let rest = expr.substring(slash1 + 1, len(expr))
        let slash2 = rest.index_of("/")
        if slash2 > 0 {
            regex_body = rest.substring(0, slash2)
        }
    }
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let corpus_path = \"" + hexa_str_escape(input_path) + "\"\n"
    s = s + "let anti_re = \"" + hexa_str_escape(regex_body) + "\"\n"
    s = s + "\n"
    s = s + tmpl_pod_block()
    s = s + "let cmd = \"ssh \" + pod_host + \" 'grep -c -i -E \\\"\" + anti_re + \"\\\" \" + corpus_path + \" 2>/dev/null || true'\"\n"
    s = s + "let out = exec(cmd).trim()\n"
    s = s + "let count = to_int(out)\n"
    s = s + "let status = if count == 0 { \"PASS\" } else { \"FAIL\" }\n"
    s = s + "let count_str = to_string(count)\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  corpus:   \" + corpus_path + \" (pod=\" + pod_host + \")\")\n"
    s = s + "println(\"  regex:    \" + anti_re)\n"
    s = s + "println(\"  matches:  \" + count_str)\n"
    s = s + "println(\"  target:   == 0\")\n"
    s = s + "println(\"  status:   \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + count_str + \" vs \" + target)\n"
    s = s + "if status == \"FAIL\" { exit(1) }\n"
    return s
}

// --- jsonl_schema_valid ---
// jq -c . | wc -l == total line count
fn tmpl_jsonl_schema_valid(id: string, hyp: string, target: string, expr: string, input_path: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, "jsonl_schema_valid", gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let corpus_path = \"" + hexa_str_escape(input_path) + "\"\n"
    s = s + "\n"
    s = s + tmpl_pod_block()
    s = s + "let total_cmd = \"ssh \" + pod_host + \" 'wc -l < \" + corpus_path + \"'\"\n"
    s = s + "let parsed_cmd = \"ssh \" + pod_host + \" 'jq -c . \" + corpus_path + \" 2>/dev/null | wc -l'\"\n"
    s = s + "let total = to_int(exec(total_cmd).trim())\n"
    s = s + "let parsed = to_int(exec(parsed_cmd).trim())\n"
    s = s + "let ratio = if total > 0 { to_float(to_string(parsed)) / to_float(to_string(total)) } else { 0.0 }\n"
    s = s + "let status = if ratio >= 1.0 { \"PASS\" } else { \"FAIL\" }\n"
    s = s + "let ratio_str = to_string(ratio)\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  corpus:   \" + corpus_path + \" (pod=\" + pod_host + \")\")\n"
    s = s + "println(\"  total:    \" + to_string(total))\n"
    s = s + "println(\"  parsed:   \" + to_string(parsed))\n"
    s = s + "println(\"  ratio:    \" + ratio_str)\n"
    s = s + "println(\"  target:   == 1.0 (strict)\")\n"
    s = s + "println(\"  status:   \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + ratio_str + \" vs \" + target)\n"
    s = s + "if status == \"FAIL\" { exit(1) }\n"
    return s
}

// --- coherence_check ---
// last non-whitespace char ∈ {. ! ? 다 요 。 ！ ？}
fn tmpl_coherence_check(id: string, hyp: string, target: string, expr: string, input_path: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, "coherence_check", gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let corpus_path = \"" + hexa_str_escape(input_path) + "\"\n"
    s = s + "\n"
    s = s + tmpl_pod_block()
    // count lines whose last char is NOT in the sentence-ending set.
    s = s + "// awk counts lines not ending with [.!?다요。！？]\n"
    s = s + "let bad_cmd = \"ssh \" + pod_host + \" \\\"awk 'BEGIN{c=0} {s=\\\\$0; sub(/[[:space:]]+\\\\$/,\\\\\"\\\\\",s); if (length(s)==0) next; if (s !~ /[.!?\\xEB\\x8B\\xA4\\xEC\\x9A\\x94\\xE3\\x80\\x82\\xEF\\xBC\\x81\\xEF\\xBC\\x9F]\\\\$/) c++} END{print c}' \" + corpus_path + \"\\\"\"\n"
    s = s + "let out = exec(bad_cmd).trim()\n"
    s = s + "let bad = to_int(out)\n"
    s = s + "let status = if bad == 0 { \"PASS\" } else { \"FAIL\" }\n"
    s = s + "let bad_str = to_string(bad)\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  corpus:   \" + corpus_path + \" (pod=\" + pod_host + \")\")\n"
    s = s + "println(\"  truncs:   \" + bad_str)\n"
    s = s + "println(\"  target:   == 0\")\n"
    s = s + "println(\"  status:   \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + bad_str + \" vs \" + target)\n"
    s = s + "if status == \"FAIL\" { exit(1) }\n"
    return s
}

// --- log_grep_exact ---
// grep count of literal pattern >= 1 (or >= target if numeric)
fn tmpl_log_grep_exact(id: string, hyp: string, target: string, expr: string, input_path: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, "log_grep_exact", gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let log_path = \"" + hexa_str_escape(input_path) + "\"\n"
    // expr may contain grep pattern; expose as pattern var for human refinement.
    s = s + "// NOTE: pattern derived from manifest.expr — tune in stub if needed.\n"
    s = s + "let pattern = \"" + hexa_str_escape(expr) + "\"\n"
    s = s + "\n"
    s = s + tmpl_pod_block()
    s = s + "let cmd = \"ssh \" + pod_host + \" 'grep -c -E \\\"\" + pattern + \"\\\" \" + log_path + \" 2>/dev/null || true'\"\n"
    s = s + "let out = exec(cmd).trim()\n"
    s = s + "let count = to_int(out)\n"
    // Semantics: "0" target → count must be 0; else count >= 1.
    s = s + "let want_zero = target == \"0\"\n"
    s = s + "let status = if want_zero { if count == 0 { \"PASS\" } else { \"FAIL\" } } else { if count >= 1 { \"PASS\" } else { \"FAIL\" } }\n"
    s = s + "let count_str = to_string(count)\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  log:      \" + log_path + \" (pod=\" + pod_host + \")\")\n"
    s = s + "println(\"  pattern:  \" + pattern)\n"
    s = s + "println(\"  count:    \" + count_str)\n"
    s = s + "println(\"  target:   \" + if want_zero { \"== 0\" } else { \">= 1\" })\n"
    s = s + "println(\"  status:   \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + count_str + \" vs \" + target)\n"
    s = s + "if status == \"FAIL\" { exit(1) }\n"
    return s
}

// --- numeric_descent ---
// sliding window mean monotone over loss log.
fn tmpl_numeric_descent(id: string, hyp: string, target: string, expr: string, input_path: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, "numeric_descent", gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let log_path = \"" + hexa_str_escape(input_path) + "\"\n"
    s = s + "let window = 10\n"
    s = s + "\n"
    s = s + tmpl_pod_block()
    // awk pipeline: extract loss=NUM, sliding-window mean, check monotone (allow ≤2% rises).
    s = s + "// Extract loss numbers, compute sliding window means, check monotone non-increase.\n"
    s = s + "let awk_script = \"awk 'match(\\\\$0,/loss=([0-9.]+)/,m){v[++n]=m[1]} END{w=10; if(n<=w){print \\\\\"INSUFFICIENT\\\\\"; exit} inc=0; for(i=1;i<=n-w+1;i++){s=0; for(j=0;j<w;j++)s+=v[i+j]; mean[i]=s/w} for(i=1;i<length(mean);i++){if(mean[i+1]>mean[i]*1.02)inc++} print inc}'\"\n"
    s = s + "let cmd = \"ssh \" + pod_host + \" \\\"\" + awk_script + \" \" + log_path + \"\\\"\"\n"
    s = s + "let out = exec(cmd).trim()\n"
    s = s + "let status = if out == \"0\" { \"PASS\" } else { \"FAIL\" }\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  log:      \" + log_path + \" (pod=\" + pod_host + \")\")\n"
    s = s + "println(\"  window:   \" + to_string(window))\n"
    s = s + "println(\"  rises:    \" + out)\n"
    s = s + "println(\"  target:   0 rises (monotone non-increase, 2%% tolerance)\")\n"
    s = s + "println(\"  status:   \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + out + \" vs \" + target)\n"
    s = s + "if status == \"FAIL\" { exit(1) }\n"
    return s
}

// --- numeric_threshold ---
// value (op) threshold. op inferred from closure or defaults to ">=".
fn tmpl_numeric_threshold(id: string, hyp: string, target: string, expr: string, input_path: string, closure: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, "numeric_threshold", gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let threshold = to_float(\"" + hexa_str_escape(target) + "\")\n"
    s = s + "let input_path = \"" + hexa_str_escape(input_path) + "\"\n"
    // Infer op from closure
    let mut op = ">="
    if closure.index_of("<=") >= 0 { op = "<=" }
    else if closure.index_of(">=") >= 0 { op = ">=" }
    else if closure.index_of("==") >= 0 { op = "==" }
    else if closure.index_of("<") >= 0 { op = "<" }
    else if closure.index_of(">") >= 0 { op = ">" }
    s = s + "let op = \"" + op + "\"\n"
    s = s + "\n"
    s = s + tmpl_pod_block()
    // Default: use provided expr (free-form) via shell; human tunes if needed.
    s = s + "// TODO (human tune if auto-extract fails): replace measure_cmd with real query.\n"
    s = s + "let measure_cmd = \"ssh \" + pod_host + \" 'echo 0'\"  // PLACEHOLDER\n"
    s = s + "// Manifest expr (reference only): " + hexa_str_escape(expr) + "\n"
    s = s + "let out = exec(measure_cmd).trim()\n"
    s = s + "let actual = to_float(out)\n"
    let cmp_block = ""
    s = s + "let status = if op == \">=\" { if actual >= threshold { \"PASS\" } else { \"FAIL\" } }\n"
    s = s + "             else if op == \"<=\" { if actual <= threshold { \"PASS\" } else { \"FAIL\" } }\n"
    s = s + "             else if op == \"==\" { if actual == threshold { \"PASS\" } else { \"FAIL\" } }\n"
    s = s + "             else if op == \">\"  { if actual >  threshold { \"PASS\" } else { \"FAIL\" } }\n"
    s = s + "             else if op == \"<\"  { if actual <  threshold { \"PASS\" } else { \"FAIL\" } }\n"
    s = s + "             else { \"FAIL\" }\n"
    s = s + "let actual_str = to_string(actual)\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  input:    \" + input_path + \" (pod=\" + pod_host + \")\")\n"
    s = s + "println(\"  actual:   \" + actual_str)\n"
    s = s + "println(\"  threshold:\" + target)\n"
    s = s + "println(\"  op:       \" + op)\n"
    s = s + "println(\"  status:   \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + actual_str + \" vs \" + target)\n"
    s = s + "if status == \"FAIL\" { exit(1) }\n"
    return s
}

// --- numeric_tolerance ---
// abs(actual - expected) <= tolerance
fn tmpl_numeric_tolerance(id: string, hyp: string, target: string, expr: string, input_path: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, "numeric_tolerance", gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let tolerance = to_float(\"" + hexa_str_escape(target) + "\")\n"
    s = s + "let input_path = \"" + hexa_str_escape(input_path) + "\"\n"
    s = s + "\n"
    s = s + tmpl_pod_block()
    s = s + "// TODO (human tune): compute (actual, expected) floats. Defaults to 0 — PLACEHOLDER.\n"
    s = s + "// Manifest expr (reference only): " + hexa_str_escape(expr) + "\n"
    s = s + "let actual = 0.0\n"
    s = s + "let expected = 0.0\n"
    s = s + "let diff = if actual >= expected { actual - expected } else { expected - actual }\n"
    s = s + "let status = if diff <= tolerance { \"PASS\" } else { \"FAIL\" }\n"
    s = s + "let diff_str = to_string(diff)\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  input:    \" + input_path)\n"
    s = s + "println(\"  actual:   \" + to_string(actual))\n"
    s = s + "println(\"  expected: \" + to_string(expected))\n"
    s = s + "println(\"  diff:     \" + diff_str)\n"
    s = s + "println(\"  tol:      \" + target)\n"
    s = s + "println(\"  status:   \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + diff_str + \" vs \" + target)\n"
    s = s + "if status == \"FAIL\" { exit(1) }\n"
    return s
}

// --- hash_match ---
// sha256sum(local) == sha256sum(remote/R2)
fn tmpl_hash_match(id: string, hyp: string, target: string, expr: string, input_path: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, "hash_match", gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let asset = \"" + hexa_str_escape(input_path) + "\"\n"
    s = s + "\n"
    s = s + tmpl_pod_block()
    s = s + "// TODO (human tune): set local_path + remote_path explicitly if needed.\n"
    s = s + "let local_cmd = \"ssh \" + pod_host + \" 'sha256sum /workspace/\" + asset + \" 2>/dev/null | awk \\\"{print \\\\$1}\\\"'\"\n"
    s = s + "let remote_cmd = \"ssh \" + pod_host + \" 'rclone sha256sum r2:anima-models/\" + asset + \" 2>/dev/null | awk \\\"{print \\\\$1}\\\"'\"\n"
    s = s + "let local_hash = exec(local_cmd).trim()\n"
    s = s + "let remote_hash = exec(remote_cmd).trim()\n"
    s = s + "let status = if local_hash != \"\" && local_hash == remote_hash { \"PASS\" } else { \"FAIL\" }\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  asset:    \" + asset)\n"
    s = s + "println(\"  local:    \" + local_hash)\n"
    s = s + "println(\"  remote:   \" + remote_hash)\n"
    s = s + "println(\"  status:   \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + local_hash + \" vs \" + remote_hash)\n"
    s = s + "if status == \"FAIL\" { exit(1) }\n"
    return s
}

// --- file_exists ---
// test -f + size > 0 (local OR pod)
fn tmpl_file_exists(id: string, hyp: string, target: string, expr: string, input_path: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, "file_exists", gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let path = \"" + hexa_str_escape(input_path) + "\"\n"
    s = s + "\n"
    s = s + "// Local-first; pod-fallback if path starts with /workspace\n"
    s = s + tmpl_pod_block()
    s = s + "let is_pod = path.starts_with(\"/workspace/\") || path.starts_with(\"/root/\")\n"
    s = s + "let repo = exec(\"git rev-parse --show-toplevel 2>/dev/null\").trim()\n"
    s = s + "let local_path = if path.starts_with(\"/\") { path } else { repo + \"/\" + path }\n"
    s = s + "let cmd = if is_pod { \"ssh \" + pod_host + \" 'test -s \" + path + \" && wc -c < \" + path + \" || echo 0'\" } else { \"test -s \" + local_path + \" && wc -c < \" + local_path + \" || echo 0\" }\n"
    s = s + "let out = exec(cmd).trim()\n"
    s = s + "let size = to_int(out)\n"
    s = s + "let status = if size > 0 { \"PASS\" } else { \"FAIL\" }\n"
    s = s + "let size_str = to_string(size)\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  path:     \" + path + (if is_pod { \" (pod=\" + pod_host + \")\" } else { \" (local)\" }))\n"
    s = s + "println(\"  size:     \" + size_str + \" bytes\")\n"
    s = s + "println(\"  target:   size > 0\")\n"
    s = s + "println(\"  status:   \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + size_str + \" vs \" + target)\n"
    s = s + "if status == \"FAIL\" { exit(1) }\n"
    return s
}

// --- r2_object_exists ---
// rclone ls <r2_path> | wc -l >= 1
fn tmpl_r2_object_exists(id: string, hyp: string, target: string, expr: string, input_path: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, "r2_object_exists", gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let r2_path = \"" + hexa_str_escape(input_path) + "\"\n"
    s = s + "\n"
    s = s + tmpl_pod_block()
    s = s + "let cmd = \"ssh \" + pod_host + \" 'rclone ls \" + r2_path + \" 2>/dev/null | wc -l'\"\n"
    s = s + "let out = exec(cmd).trim()\n"
    s = s + "let count = to_int(out)\n"
    s = s + "let status = if count >= 1 { \"PASS\" } else { \"FAIL\" }\n"
    s = s + "let count_str = to_string(count)\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  r2 path:  \" + r2_path)\n"
    s = s + "println(\"  objects:  \" + count_str)\n"
    s = s + "println(\"  target:   >= 1\")\n"
    s = s + "println(\"  status:   \" + status)\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" \" + status + \" \" + count_str + \" vs \" + target)\n"
    s = s + "if status == \"FAIL\" { exit(1) }\n"
    return s
}

// --- benchmark_fixed_set --- (TBD, emits SKIP stub until dataset curated)
fn tmpl_benchmark_fixed_set(id: string, hyp: string, target: string, expr: string, input_path: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, "benchmark_fixed_set", gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let dataset = \"" + hexa_str_escape(input_path) + "\"\n"
    s = s + "\n"
    s = s + "// TBD — fixed benchmark dataset not yet curated (Tier B in design doc §10).\n"
    s = s + "// Contract when ready: load dataset, iterate prompts, compare actual signature\n"
    s = s + "// vs expected (exact or tolerance). Emit PASS iff match_count/N >= target.\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  dataset:  \" + dataset)\n"
    s = s + "println(\"  target:   \" + target)\n"
    s = s + "println(\"  status:   SKIP (benchmark dataset not yet built)\")\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" SKIP 0 vs \" + target)\n"
    s = s + "// SKIP exits 0 — gate-level aggregator treats SKIP as pending, not FAIL.\n"
    return s
}

// --- formula_closure --- (n=6 primitives; evaluates claimed_expr == target)
fn tmpl_formula_closure(id: string, hyp: string, target: string, expr: string, input_path: string, gate: string, round: string) -> string {
    let mut s = tmpl_header(id, hyp, "formula_closure", gate, round)
    s = s + "// n=6 primitives\n"
    s = s + "let n: i64 = 6\n"
    s = s + "let sigma: i64 = 12\n"
    s = s + "let tau: i64 = 4\n"
    s = s + "let phi: i64 = 2\n"
    s = s + "let sopfr: i64 = 5\n"
    s = s + "let J2: i64 = 24\n"
    s = s + "\n"
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "let claimed_expr = \"" + hexa_str_escape(expr) + "\"\n"
    s = s + "\n"
    s = s + "// TODO (human tune): compute expected from claimed_expr; assert |expected - target| < 1e-6.\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  target:   \" + target)\n"
    s = s + "println(\"  claim:    \" + claimed_expr)\n"
    s = s + "println(\"  status:   STUB (formula eval not implemented)\")\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" SKIP 0 vs \" + target)\n"
    return s
}

// ─── dispatcher ───

fn render_stub(id: string, round: string, gate: string, hyp: string, target: string, expr: string, closure: string, input_path: string, vtype: string) -> string {
    if vtype == "corpus_regex_ratio" { return tmpl_corpus_regex_ratio(id, hyp, target, expr, input_path, gate, round) }
    if vtype == "corpus_regex_zero" { return tmpl_corpus_regex_zero(id, hyp, target, expr, input_path, gate, round) }
    if vtype == "jsonl_schema_valid" { return tmpl_jsonl_schema_valid(id, hyp, target, expr, input_path, gate, round) }
    if vtype == "coherence_check" { return tmpl_coherence_check(id, hyp, target, expr, input_path, gate, round) }
    if vtype == "log_grep_exact" { return tmpl_log_grep_exact(id, hyp, target, expr, input_path, gate, round) }
    if vtype == "numeric_descent" { return tmpl_numeric_descent(id, hyp, target, expr, input_path, gate, round) }
    if vtype == "numeric_threshold" { return tmpl_numeric_threshold(id, hyp, target, expr, input_path, closure, gate, round) }
    if vtype == "numeric_tolerance" { return tmpl_numeric_tolerance(id, hyp, target, expr, input_path, gate, round) }
    if vtype == "hash_match" { return tmpl_hash_match(id, hyp, target, expr, input_path, gate, round) }
    if vtype == "file_exists" { return tmpl_file_exists(id, hyp, target, expr, input_path, gate, round) }
    if vtype == "r2_object_exists" { return tmpl_r2_object_exists(id, hyp, target, expr, input_path, gate, round) }
    if vtype == "benchmark_fixed_set" { return tmpl_benchmark_fixed_set(id, hyp, target, expr, input_path, gate, round) }
    if vtype == "formula_closure" { return tmpl_formula_closure(id, hyp, target, expr, input_path, gate, round) }
    // Unknown verifier_type — emit SKIP stub with hint.
    let mut s = tmpl_header(id, hyp, vtype, gate, round)
    s = s + "let target = \"" + hexa_str_escape(target) + "\"\n"
    s = s + "println(\"verify: \" + id)\n"
    s = s + "println(\"  verifier_type: " + hexa_str_escape(vtype) + " — not yet implemented in generator\")\n"
    s = s + "println(\"__VERIFY_RESULT__ \" + id + \" SKIP 0 vs \" + target)\n"
    return s
}

// ─── commands ───

fn cmd_emit() -> i64 {
    if !file_exists(MANIFEST) {
        println("ERR: manifest not found: " + MANIFEST)
        return 1
    }
    let raw = _str(read_file(MANIFEST))
    if raw == "" {
        println("ERR: manifest empty")
        return 1
    }
    let mut written: i64 = 0
    let mut skipped_dup: i64 = 0
    let mut skipped_bad: i64 = 0
    for line in raw.split("\n") {
        let l = _str(line).trim()
        if l == "" { continue }
        if !l.starts_with("{") { continue }
        let id = jget(l, "id")
        let round = jget(l, "round")
        let gate = jget(l, "gate")
        let hyp = jget(l, "hyp")
        let target = jget(l, "target")
        let expr = jget(l, "expr")
        let closure = jget(l, "closure")
        let input_path = jget(l, "input_path")
        let vtype = jget(l, "verifier_type")
        if id == "" || vtype == "" {
            skipped_bad = skipped_bad + 1
            continue
        }
        let out = STUBS_DIR + "/verify_" + id + ".hexa"
        // Skip if existing (protect hand-authored examples).
        if file_exists(out) {
            skipped_dup = skipped_dup + 1
            continue
        }
        let body = render_stub(id, round, gate, hyp, target, expr, closure, input_path, vtype)
        try { write_file(out, body); written = written + 1 } catch e {
            println("ERR: write failed " + out)
            skipped_bad = skipped_bad + 1
        }
    }
    println("emit[" + TRACK + "]: written=" + to_string(written) + " skipped_existing=" + to_string(skipped_dup) + " skipped_bad=" + to_string(skipped_bad))
    return 0
}

fn cmd_status() -> i64 {
    let mlines = _str(exec("wc -l < '" + MANIFEST + "' 2>/dev/null")).trim()
    let hexa_n = _str(exec("ls " + STUBS_DIR + "/verify_*.hexa 2>/dev/null | wc -l")).trim()
    println("track:          " + TRACK)
    println("manifest:       " + mlines + " lines (" + MANIFEST + ")")
    println("verify_*.hexa:  " + hexa_n + " files (" + STUBS_DIR + ")")
    // Diff: ids in manifest but no stub
    if file_exists(MANIFEST) {
        let raw = _str(read_file(MANIFEST))
        let mut missing: i64 = 0
        let mut miss_ids = ""
        for line in raw.split("\n") {
            let l = _str(line).trim()
            if l == "" || !l.starts_with("{") { continue }
            let id = jget(l, "id")
            if id == "" { continue }
            let out = STUBS_DIR + "/verify_" + id + ".hexa"
            if !file_exists(out) {
                missing = missing + 1
                miss_ids = miss_ids + "  - " + id + "\n"
            }
        }
        println("missing stubs:  " + to_string(missing))
        if missing > 0 {
            println(miss_ids)
            println("hint: hexa run shared/calc/" + TRACK + "_verify/generator.hexa --emit")
        }
    }
    return 0
}

fn manifest_has_id(id: string) -> bool {
    if !file_exists(MANIFEST) { return false }
    let raw = _str(read_file(MANIFEST))
    if raw == "" { return false }
    let needle = "\"id\":\"" + id + "\""
    return raw.index_of(needle) >= 0
}

fn cmd_append(raw_json: string) -> i64 {
    let line = _str(raw_json).trim()
    if line == "" {
        eprintln("ERR: --append got empty JSON")
        println("__APPEND_RESULT__ FAIL empty-input")
        return 1
    }
    if !line.starts_with("{") {
        eprintln("ERR: --append JSON must start with '{' — got: " + line.substring(0, min_i64(40, len(line))))
        println("__APPEND_RESULT__ FAIL not-json-object")
        return 1
    }
    let id = jget(line, "id")
    let round = jget(line, "round")
    let gate = jget(line, "gate")
    let hyp = jget(line, "hyp")
    let target = jget(line, "target")
    let expr = jget(line, "expr")
    let closure = jget(line, "closure")
    let input_path = jget(line, "input_path")
    let vtype = jget(line, "verifier_type")
    if id == "" {
        eprintln("ERR: --append JSON missing 'id'")
        println("__APPEND_RESULT__ FAIL missing-id")
        return 1
    }
    if vtype == "" {
        eprintln("ERR: --append JSON missing 'verifier_type'  id=" + id)
        println("__APPEND_RESULT__ FAIL missing-verifier-type")
        return 1
    }
    if manifest_has_id(id) {
        eprintln("WARN: --append id already in manifest — skip  id=" + id)
        println("__APPEND_RESULT__ OK_DUP " + id)
        return 0
    }
    let body = render_stub(id, round, gate, hyp, target, expr, closure, input_path, vtype)
    let out = STUBS_DIR + "/verify_" + id + ".hexa"
    try { write_file(out, body) } catch e {
        eprintln("ERR: --append write failed " + out)
        println("__APPEND_RESULT__ FAIL write-stub")
        return 1
    }
    try { append_file(MANIFEST, line + "\n") } catch e {
        eprintln("ERR: --append manifest append failed " + MANIFEST)
        println("__APPEND_RESULT__ FAIL append-manifest")
        return 1
    }
    println("__APPEND_RESULT__ OK_NEW " + id)
    return 0
}

// ─── main ───

fn main() {
    let argv = args()
    if argv.len() < 3 {
        println("usage: hexa run shared/calc/alm_verify/generator.hexa <--emit|--status|--append <json>|-)>")
        return
    }
    let mode = _str(argv[2])
    if mode == "--emit" {
        cmd_emit()
    } else if mode == "--status" {
        cmd_status()
    } else if mode == "--append" {
        let mut payload = ""
        if argv.len() >= 4 {
            let a3 = _str(argv[3])
            if a3 == "-" {
                payload = _str(read_stdin())
            } else {
                payload = a3
            }
        } else {
            payload = _str(read_stdin())
        }
        cmd_append(payload)
    } else {
        eprintln("ERR: unknown mode: " + mode)
        println("usage: hexa run shared/calc/alm_verify/generator.hexa <--emit|--status|--append <json>|-)>")
        println("__APPEND_RESULT__ FAIL unknown-mode")
    }
}

main()
