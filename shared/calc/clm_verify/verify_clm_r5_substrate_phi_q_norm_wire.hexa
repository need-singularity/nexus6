let id = "clm_r5_substrate_phi_q_norm_wire"
let target = "true"
let log_path = "training/train_clm.hexa"
let pattern = "grep -c phi_q_norm training/train_clm.hexa"

let pod = env("HEXA_VERIFY_POD")
let pod_host = if pod != "" { pod } else { "87xsc" }
let is_pod = log_path.starts_with("/workspace/") || log_path.starts_with("/root/")
let cmd = if is_pod { "ssh " + pod_host + " 'grep -c -E \"" + pattern + "\" " + log_path + " 2>/dev/null || true'" } else { "grep -c -E \"" + pattern + "\" " + log_path + " 2>/dev/null || true" }
let count = to_int(exec(cmd).trim())
let want_zero = target == "0"
let status = if want_zero { if count == 0 { "PASS" } else { "FAIL" } } else { if count >= 1 { "PASS" } else { "FAIL" } }
let count_str = to_string(count)
println("verify: " + id)
println("  log:      " + log_path)
println("  pattern:  " + pattern)
println("  count:    " + count_str)
println("  target:   " + if want_zero { "== 0" } else { ">= 1" })
println("  status:   " + status)
println("__VERIFY_RESULT__ " + id + " " + status + " " + count_str + " vs " + target)
if status == "FAIL" { exit(1) }
