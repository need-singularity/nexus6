{
  "_meta": {
    "name": "프로젝트 설정 (Project Config)",
    "description": "CLI 명령어 실행 구문 / 관례 / 리소스 보호 — 규칙은 absolute_rules.json, 시스템맵은 core.json",
    "updated": "2026-04-10"
  },

  "common": {
    "memory_naming": {
      "pattern": "{type}-{kebab-topic}.md",
      "types": {
        "f": "feedback",
        "p": "project",
        "r": "reference",
        "u": "user",
        "h": "history YYYYMMDD"
      }
    },
    "hexa_pitfalls_ref": "shared/hexa_grammar.jsonl → pitfalls 섹션 (P1~P5)",
    "overview": {
      "desc": "NEXUS-6 = 전 리포 공유 발견 엔진 + 인프라 허브",
      "engine": "mk2_hexa/native/*.hexa (hexa-lang 컴파일러)",
      "symlink": "모든 리포의 .shared/ → nexus/shared/"
    }
  },

  "nexus": {
    "resource_protection": {
      "scheduler": "n6-guard",
      "config": "~/.config/n6-guard.toml",
      "max_concurrent": 2,
      "burst": 4
    },
    "cli": {
      "hexa_bin": "$HOME/Dev/hexa-lang/target/release/hexa",
      "native_dir": "$HOME/Dev/nexus/mk2_hexa/native",
      "commands": {
        "todo": {
          "cmd": "$HOME/Dev/hexa-lang/target/release/hexa $HOME/Dev/nexus/mk2_hexa/native/todo.hexa nexus",
          "keywords": ["todo", "할일"],
          "output": "마크다운 텍스트 그대로 출력 (재포맷 금지)"
        },
        "todo_bulk": {
          "cmd": "$HOME/Dev/hexa-lang/target/release/hexa $HOME/Dev/nexus/mk2_hexa/native/todo.hexa nexus 대량",
          "keywords": ["todo 대량"]
        },
        "todo_all": {
          "cmd": "$HOME/Dev/hexa-lang/target/release/hexa $HOME/Dev/nexus/mk2_hexa/native/todo.hexa",
          "keywords": ["전체 할일"],
          "output": "마크다운 텍스트 그대로 출력 (재포맷 금지)"
        },
        "loop": {
          "cmd": "bash $HOME/Dev/nexus/scripts/infinite_growth.sh",
          "keywords": ["loop", "루프"],
          "flags": "run_in_background: true 필수",
          "note": "현재 프로젝트 리포에서 실행 시 해당 리포의 scripts/infinite_growth.sh, 정의는 shared/loop/{project}.json"
        },
        "blowup": {
          "cmd": "hexa blowup.hexa <domain> 3 --no-graph --seeds \"$(hexa seed_engine.hexa merge)\"",
          "keywords": ["블로업"]
        },
        "breakthrough": {
          "cmd": "hexa breakthrough.hexa",
          "keywords": ["돌파"],
          "note": "1회 자동: gap→mine→blowup"
        },
        "breakthrough_converge": {
          "cmd": "hexa breakthrough.hexa --converge",
          "keywords": ["연속돌파", "수렴"]
        },
        "directions": {
          "cmd": "hexa directions.hexa report",
          "keywords": ["방향", "다음"]
        },
        "full_report": {
          "cmd": "hexa command_router.hexa \"전체 리포트\"",
          "keywords": ["전체 리포트"]
        },
        "anima_status": {
          "cmd": "hexa anima_status.hexa",
          "keywords": ["anima 상태"]
        }
      }
    },
    "singularity_cycle": {
      "desc": "블로업→수축→창발→특이점→흡수 5단계",
      "engine": "mk2_hexa/native/blowup.hexa (9-phase)"
    }
  }
}
