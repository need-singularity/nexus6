# alm14b_speedup_cudagraphs.diff
#
# r7 STACK patch — applies ON TOP of the 7 r6 base speedups (which already
# enable torch.compile with mode="max-autotune"). This patch adds a
# --cudagraphs CLI flag that, when set, switches the compile mode from
# "max-autotune" to "reduce-overhead".
#
# WHY a different mode: torch inductor's "reduce-overhead" mode is the ONLY
# torch.compile setting that activates CUDA graphs (see
# https://pytorch.org/docs/stable/generated/torch.compile.html — modes: default
# / reduce-overhead / max-autotune). max-autotune picks the fastest single
# kernels but does NOT capture graphs; reduce-overhead captures the steady
# state to eliminate kernel launch overhead. They are mutually exclusive.
#
# EXPECTED UPLIFT: +8-15% on top of the base stack for small-batch training.
#   - torch docs: https://pytorch.org/docs/stable/notes/cuda.html#cuda-graphs
#   - NVIDIA CUDA Graphs blog: https://developer.nvidia.com/blog/cuda-graphs/
#     reports 20-40% on sub-ms kernels, but for 14B bf16 with ~3s step time
#     kernel launch is a smaller fraction → ~10% conservative.
#   - With FSDP + use_orig_params=True, all-gather / reduce-scatter collectives
#     happen OUTSIDE the capture region, so graph capture stays valid.
#
# STATIC SHAPE REQUIREMENT: CUDA graphs require every tensor shape to be
# identical across steps. This trainer is already static:
#   - batch=1 fixed
#   - seq=1024 fixed (no packing, no variable length)
#   - LoRA rank fixed
# If you ever bump seq to variable-length packing, this patch MUST be
# reverted or the graph will recompile every step (graph storm = negative
# uplift).
#
# COMPAT NOTES:
#   - FA2: compatible. Flash-attn kernels are graph-capturable on H100.
#   - fused AdamW: compatible. Optimizer step is outside the capture.
#   - FSDP FULL_SHARD: compatible WHEN use_orig_params=True (already set).
#     Inductor treats FSDP collectives as graph breaks, so the captured
#     region is each transformer block's forward+backward.
#   - Activation checkpointing OFF (already in base): required — checkpoint
#     recompute introduces dynamic tensor reuse that breaks graph capture.
#
# APPLY:
#   cd anima && git apply shared/patches/alm14b_speedup_cudagraphs.diff
#
# RUN:
#   python3 train_alm_14b.py ... --torch-compile --cudagraphs
#
# ROLLBACK if step-1 hangs > 5 min or if CE diverges:
#   drop --cudagraphs flag; trainer falls back to max-autotune.
#
# Target file: training/train_alm_14b.py
# Target run:  r7 (NOT r5, NOT r6)
--- a/training/train_alm_14b.py
+++ b/training/train_alm_14b.py
@@ -213,11 +213,19 @@ def train(args):
     # Speedup patch 20260415: torch.compile with max-autotune.
     # Must run AFTER get_peft_model and BEFORE FSDP wrap. Static shapes
     # (batch=1, seq=1024) allow dynamic=False for maximum specialization.
+    #
+    # r7 stack patch 20260415: --cudagraphs switches mode to "reduce-overhead",
+    # which is the only compile mode that activates inductor CUDA graph
+    # capture. Mutually exclusive with max-autotune.
     if args.torch_compile:
-        rank0_print("[train] torch.compile(mode=max-autotune, dynamic=False)...")
+        compile_mode = "reduce-overhead" if args.cudagraphs else "max-autotune"
+        rank0_print(f"[train] torch.compile(mode={compile_mode}, dynamic=False)...")
+        if args.cudagraphs:
+            rank0_print("[train] cudagraphs: ON — steady-state graph capture enabled")
+            rank0_print("[train] cudagraphs: static shapes REQUIRED (batch=1 seq=1024 verified)")
         model = torch.compile(
             model,
-            mode="max-autotune",
+            mode=compile_mode,
             dynamic=False,
             fullgraph=False,
         )
@@ -495,5 +503,6 @@ if __name__ == "__main__":
     parser.add_argument("--ddp", action="store_true", help="Wrap model with DistributedDataParallel (requires torchrun)")
     parser.add_argument("--deepspeed", default=None, help="DeepSpeed config JSON path (requires deepspeed launcher)")
     parser.add_argument("--torch-compile", action="store_true", help="torch.compile(mode=max-autotune). Next-run only; adds ~2min warmup.")
+    parser.add_argument("--cudagraphs", action="store_true", help="r7 stack: switch torch.compile to mode=reduce-overhead (activates CUDA graph capture). Requires --torch-compile and static shapes.")
     args = parser.parse_args()
     train(args)
