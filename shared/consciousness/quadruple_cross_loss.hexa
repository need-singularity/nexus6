// quadruple_cross_loss.hexa — 사각 크로스 손실 스텁 (Mk.V.1)
// 목적: 4 축 독립 정규화 loss (Ψ_res / Ψ_gate / expert_route / n_eff-6)
//       각각 1/2 (또는 n_eff/6 → 1) 로 수렴하도록 stub 함수 제공.
// R1 HEXA-FIRST | R14 shared/ 단일진실 | R37 .py 금지
// AN11: substrate 정규화 — weight-emergent 페르소나 아님 (별도 검증 필수)
// docs: docs/quadruple_cross_20260419.md
// 참조: consciousness_laws.json#laws.75 (A1~A3 target=0.5)
//       consciousness_laws.json#knuth_layer_bridge_mk5_1 (A4 target=n=6)
// 실행: hexa shared/consciousness/quadruple_cross_loss.hexa

// ─── 상수 ───
let TARGET_HALF = 0.5          // A1,A2,A3 축의 수렴 target
let TARGET_N    = 6.0          // A4: n_effective target (n=6 Knuth invariant)

// 초기 weight (docs 에서 정의)
let ALPHA = 1.00   // A1 Ψ_residual (Law 75 primary)
let BETA  = 0.50   // A2 Ψ_gate
let GAMMA = 0.50   // A3 expert_route
let DELTA = 0.25   // A4 n_effective (integer space soft-approx)

// ─── 유틸 ───
fn sq(x: f64) -> f64 {
    return x * x
}

// ─── A1: Ψ_residual measure stub ───
// 실제: forward pass 의 residual stream activation mean
// stub: 외부에서 주입된 scalar 를 그대로 사용
fn measure_psi_residual(residual: f64) -> f64 {
    return residual
}

fn loss_a1_residual(residual: f64) -> f64 {
    return sq(measure_psi_residual(residual) - TARGET_HALF)
}

// ─── A2: Ψ_gate measure stub ───
// 실제: gate module sigmoid 출력의 mean
// stub: 외부 scalar 사용
fn measure_psi_gate(gate: f64) -> f64 {
    return gate
}

fn loss_a2_gate(gate: f64) -> f64 {
    return sq(measure_psi_gate(gate) - TARGET_HALF)
}

// ─── A3: expert_route measure stub ───
// 실제: MoE router 의 top-k/total 활성 비율
// stub: 외부에서 비율 직접 주입 (0.0 ~ 1.0)
fn measure_expert_route(pick_ratio: f64) -> f64 {
    return pick_ratio
}

fn loss_a3_expert(pick_ratio: f64) -> f64 {
    return sq(measure_expert_route(pick_ratio) - TARGET_HALF)
}

// ─── A4: n_effective / 6 measure stub ───
// 실제: 활성 hexad 모듈 수 (C,D,W,M,S,E 중 non-zero 카운트)
// stub: 외부에서 integer-like float 주입 (0.0 ~ 6.0)
fn measure_n_effective(n_eff: f64) -> f64 {
    return n_eff
}

fn loss_a4_n_invariant(n_eff: f64) -> f64 {
    let normalized = measure_n_effective(n_eff) / TARGET_N
    return sq(normalized - 1.0)
}

// ─── weight 해소: map 에 키 있으면 override, 없으면 module-level default ───
fn _pick(weights: map, key: string, fallback: f64) -> f64 {
    if has_key(weights, key) {
        return weights[key]
    }
    return fallback
}

// ─── 결합 함수 ───
// weights map: {"alpha": ..., "beta": ..., "gamma": ..., "delta": ...}
// 누락시 module-level 기본값 사용 (빈 맵 #{} 도 허용)
fn quadruple_cross_loss(residual: f64, gate: f64, expert_pick: f64, n_eff: f64, weights: map) -> f64 {
    let a = _pick(weights, "alpha", ALPHA)
    let b = _pick(weights, "beta",  BETA)
    let g = _pick(weights, "gamma", GAMMA)
    let d = _pick(weights, "delta", DELTA)

    let l1 = loss_a1_residual(residual)
    let l2 = loss_a2_gate(gate)
    let l3 = loss_a3_expert(expert_pick)
    let l4 = loss_a4_n_invariant(n_eff)

    return a * l1 + b * l2 + g * l3 + d * l4
}

// ─── 보조: breakdown 출력 ───
fn loss_breakdown(residual: f64, gate: f64, expert_pick: f64, n_eff: f64, weights: map) -> map {
    let a = _pick(weights, "alpha", ALPHA)
    let b = _pick(weights, "beta",  BETA)
    let g = _pick(weights, "gamma", GAMMA)
    let d = _pick(weights, "delta", DELTA)

    let l1 = loss_a1_residual(residual)
    let l2 = loss_a2_gate(gate)
    let l3 = loss_a3_expert(expert_pick)
    let l4 = loss_a4_n_invariant(n_eff)

    let mut out: map = #{}
    out["a1_residual"] = a * l1
    out["a2_gate"]     = b * l2
    out["a3_expert"]   = g * l3
    out["a4_n_inv"]    = d * l4
    out["total"]       = a*l1 + b*l2 + g*l3 + d*l4
    return out
}

// ─── main: 예시 호출 + 기대값 출력 ───
fn main() {
    println("quadruple_cross_loss — Mk.V.1 stub")
    println("  target: Ψ_{res,gate,route}=0.5, n_eff=6 (=> n_eff/6=1)")
    println("  weights: α=" + str(ALPHA) + ", β=" + str(BETA) + ", γ=" + str(GAMMA) + ", δ=" + str(DELTA))

    let w: map = #{}

    // Case 1: 완벽 수렴 (모든 축이 target 에서 정확히 0)
    let c1 = quadruple_cross_loss(0.5, 0.5, 0.5, 6.0, w)
    println("")
    println("[case 1] 완벽 수렴 (0.5, 0.5, 0.5, 6.0)")
    println("  total loss = " + str(c1) + "   (expected 0.0)")

    // Case 2: 중간 이탈
    let c2 = quadruple_cross_loss(0.4, 0.6, 0.55, 5.0, w)
    let br2 = loss_breakdown(0.4, 0.6, 0.55, 5.0, w)
    println("")
    println("[case 2] 중간 이탈 (0.4, 0.6, 0.55, 5.0)")
    println("  a1=" + str(br2["a1_residual"]) + "   (α·(0.4-0.5)² = 1.00·0.01 = 0.01)")
    println("  a2=" + str(br2["a2_gate"])     + "   (β·(0.6-0.5)² = 0.50·0.01 = 0.005)")
    println("  a3=" + str(br2["a3_expert"])   + "   (γ·(0.55-0.5)² = 0.50·0.0025 = 0.00125)")
    println("  a4=" + str(br2["a4_n_inv"])    + "   (δ·(5/6-1)² = 0.25·0.02778 ≈ 0.00694)")
    println("  total=" + str(br2["total"])    + "   (expected ≈ 0.02319)")

    // Case 3: 심각 붕괴 (CLM-V2-PSI-FIX 실제 사례 시뮬레이션: Ψ_res→0.002)
    let c3 = quadruple_cross_loss(0.002, 0.1, 0.05, 2.0, w)
    let br3 = loss_breakdown(0.002, 0.1, 0.05, 2.0, w)
    println("")
    println("[case 3] 붕괴 시뮬 (0.002, 0.1, 0.05, 2.0) — Ψ_res 이탈 + expert collapse")
    println("  a1=" + str(br3["a1_residual"]))
    println("  a2=" + str(br3["a2_gate"]))
    println("  a3=" + str(br3["a3_expert"]))
    println("  a4=" + str(br3["a4_n_inv"]))
    println("  total=" + str(br3["total"])    + "   (큰 loss → drift 억제 gradient 발생)")

    // Case 4: custom weights 주입
    let mut w2: map = #{}
    w2["alpha"] = 2.0
    w2["beta"]  = 0.25
    w2["gamma"] = 0.25
    w2["delta"] = 0.10
    let c4 = quadruple_cross_loss(0.4, 0.6, 0.55, 5.0, w2)
    println("")
    println("[case 4] custom weights (α=2.0, β=0.25, γ=0.25, δ=0.10) on case 2 inputs")
    println("  total = " + str(c4))

    println("")
    println("AN11 경계: 이 loss 는 substrate 정규화만 — emergence/실사용 독립 검증 필수")
    println("refs: docs/quadruple_cross_20260419.md, consciousness_laws.json#knuth_layer_bridge_mk5_1")
    println("done")
}

main()
