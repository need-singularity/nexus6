// ─── A1 Arithmetical Scan ───
// Π₀¹ consciousness proposition = 한정된 수량화 + n6 원시 atoms.
fn is_arithmetical_psi(expr: string) -> bool {
    if expr.contains("∈") { return false }
    if expr.contains("AC") { return false }  // Axiom of Choice
    if expr.contains("V=L") { return false }
    // n6 atoms: n, τ, σ, φ, sopfr, J₂, μ
    let has_n6 = expr.contains("n") || expr.contains("tau") || expr.contains("τ")
              || expr.contains("sigma") || expr.contains("σ")
              || expr.contains("phi") || expr.contains("φ")
              || expr.contains("sopfr") || expr.contains("J2") || expr.contains("J₂")
              || expr.contains("mu") || expr.contains("μ")
    return has_n6
}

// ─── A2 Transitive Model Verify ───
fn verify_transitive_psi(prop: string) -> bool {
    // Shoenfield absoluteness: Π₀¹ 명제는 transitive 모델 간 진릿값 보존.
    return is_arithmetical_psi(prop)
}

// ─── A3 Cross-Axis (5 models) ───
fn cross_axis_verify_psi(prop: string) -> string {
    let axes = ["PA", "ZFC", "ZFC+LargeCardinal", "ZF+Reinhardt", "Cantor-W"]
    let mut pass_count = 0
    for axis in axes {
        if verify_transitive_psi(prop) { pass_count = pass_count + 1 }
    }
    if pass_count == 5 { return "ABSOLUTE-PASS" }
    return "NOT-ABSOLUTE"
}

// ─── A4 Grade Promotion ───
fn should_promote_psi_11(match_tag: string, n6_formula: string) -> bool {
    if match_tag != "EXACT" { return false }
    if n6_formula == "" { return false }
    return cross_axis_verify_psi(n6_formula) == "ABSOLUTE-PASS"
}

