{
  "name": "nexus",
  "domain": "discovery",
  "interval": 1800,
  "max_cycles": 999,
  "phases": {
    "every_cycle": [
      {"id": "nexus_scan", "name": "NEXUS-6 스캔", "cmd": "common_nexus_scan"},
      {"id": "blowup", "name": "블로업 (창발)", "cmd": "common_blowup"},
      {"id": "singularity", "name": "특이점 캐스케이드", "cmd": "common_singularity_cascade"},
      {"id": "cross_pollinate", "name": "교차수분", "cmd": "common_cross_pollinate"},
      {"id": "auto_route", "name": "자동 라우팅", "cmd": "common_auto_route"},
      {"id": "growth_bridge", "name": "성장 브릿지", "cmd": "common_growth_bridge"},
      {"id": "shared_graph", "name": "공유 그래프", "cmd": "common_shared_graph"},
      {"id": "heartbeat", "name": "심박", "cmd": "common_heartbeat"},
      {"id": "vector_clock", "name": "벡터 시계", "cmd": "common_vector_clock"},
      {"id": "metric_bus", "name": "메트릭 버스", "cmd": "common_metric_bus_publish"},
      {"id": "resonance", "name": "공명 브릿지", "cmd": "common_resonance_bridge"},
      {"id": "update_state", "name": "상태 갱신", "cmd": "common_update_state"},
      {"id": "auto_commit", "name": "자동 커밋", "cmd": "common_auto_commit"},
      {"id": "dashboard", "name": "대시보드 갱신", "cmd": "common_update_dashboard"},
      {"id": "cycle_report", "name": "사이클 리포트", "cmd": "common_cycle_report"}
    ],
    "every_3": [
      {"id": "sync_queue", "name": "동기화 우선순위 큐", "cmd": "common_sync_priority_queue"},
      {"id": "cross_test", "name": "교차 테스트", "cmd": "common_cross_test"},
      {"id": "live_graph", "name": "실시간 그래프", "cmd": "common_live_graph"},
      {"id": "timeline", "name": "성장 타임라인", "cmd": "common_growth_timeline"}
    ],
    "every_6": [
      {"id": "project_dna", "name": "프로젝트 DNA", "cmd": "common_project_dna"},
      {"id": "connection", "name": "연결 메트릭", "cmd": "common_connection_metrics"},
      {"id": "history", "name": "성장 이력", "cmd": "common_growth_history"},
      {"id": "auto_actions", "name": "자동 액션", "cmd": "common_auto_actions"},
      {"id": "federated", "name": "연방 성장", "cmd": "common_federated_growth"},
      {"id": "lens_sync", "name": "렌즈 동기화", "cmd": "common_reverse_lens_sync"},
      {"id": "cross_experiment", "name": "교차 실험", "cmd": "common_cross_experiment"}
    ],
    "every_10": [
      {"id": "seed_dormant", "name": "휴면 활성화", "cmd": "common_seed_dormant"}
    ],
    "every_12": [
      {"id": "lens_recommend", "name": "렌즈 추천", "cmd": "common_lens_recommend"}
    ]
  }
}
