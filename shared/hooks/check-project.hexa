// check-project.hexa — 프로젝트 화이트리스트 게이트 (check-project.sh 대체)
// 미등록 프로젝트 → exit(1), 등록 프로젝트 → exit(0)

let HOME = env("HOME")
let PROJ_JSON = HOME + "/Dev/nexus/shared/config/nexus-projects.json"

let repo_root = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
if len(repo_root) == 0 { exit(1) }
let repo_name = exec("basename '" + repo_root + "'").trim()

let raw = try { read_file(PROJ_JSON) } catch e { exit(1) }

// nexus-projects.json에서 프로젝트명 추출
if raw.contains("\"projects\"") == false { exit(1) }
let proj_block = raw.split("\"projects\"")[1]
let repo_key = "\"" + repo_name + "\""
let repo_lower = repo_name.to_lower()
let repo_key_lower = "\"" + repo_lower + "\""

if proj_block.contains(repo_key) || proj_block.contains(repo_key_lower) {
    exit(0)
}
exit(1)
