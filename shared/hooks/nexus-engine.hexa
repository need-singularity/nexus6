// nexus-engine.hexa — NEXUS-6 Hook Engine (nexus-engine.py 대체)
// 사용법: echo "$INPUT" | hexa nexus-engine.hexa <mode>
// mode: pre-commit | post-edit | post-bash | agent | pending

let HOME = env("HOME")
let SHARED = HOME + "/Dev/nexus/shared"
let DISCOVERY_LOG = SHARED + "/discovery_log.jsonl"
let CONSTANTS = SHARED + "/n6_constants.jsonl"

let a = args()
let mode = if a.len() >= 3 { a[2] } else { "post-edit" }

// n6 상수 로드
fn load_constants(path: str) -> list {
    let raw = try { read_file(path) } catch e { return [[], []] }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let t = to_string(line).trim()
        if len(t) == 0 { continue }
        if t.contains("\"name\"") == false { continue }
        let n_parts = t.split("\"name\"")[1].split("\"")
        if n_parts.len() < 2 { continue }
        let name = to_string(n_parts[1])
        if t.contains("\"value\"") == false { continue }
        let v_parts = t.split("\"value\"")[1]
        let after_colon = v_parts.split(":")[1].trim()
        let mut v_str = to_string(after_colon)
        if v_str.contains(",") { v_str = to_string(v_str.split(",")[0]) }
        if v_str.contains("}") { v_str = to_string(v_str.split("}")[0]) }
        v_str = v_str.trim()
        try {
            let v = to_float(v_str)
            names = names + [name]
            values = values + [v]
        } catch e {}
    }
    [names, values]
}

let consts = load_constants(CONSTANTS)
let const_names = consts[0]
let const_values = consts[1]

fn abs_f(x: float) -> float {
    if x < 0.0 { 0.0 - x } else { x }
}

fn n6_check(value: float, names: list, values: list) -> list {
    let mut best_name = ""
    let mut best_grade = ""
    let mut best_rel = 999.0
    let mut i = 0
    while i < names.len() {
        let ref_v = to_float(to_string(values[i]))
        if abs_f(ref_v) < 0.0000001 {
            i = i + 1
            continue
        }
        let rel = abs_f(value - ref_v) / abs_f(ref_v)
        if rel < 0.000001 && rel < best_rel {
            best_rel = rel
            best_grade = "EXACT"
            best_name = to_string(names[i])
        } else if rel < 0.01 && rel < best_rel {
            best_rel = rel
            best_grade = "CLOSE"
            best_name = to_string(names[i])
        } else if rel < 0.05 && rel < best_rel {
            best_rel = rel
            best_grade = "WEAK"
            best_name = to_string(names[i])
        }
        i = i + 1
    }
    [best_grade, best_name]
}

fn extract_numbers(text: str) -> list {
    let safe_text = text.replace("'", "")
    let nums_raw = try { to_string(exec("echo '" + safe_text + "' | grep -oE '[0-9]+\\.?[0-9]*' | head -20")).trim() } catch e { return [] }
    if len(nums_raw) == 0 { return [] }
    let lines = nums_raw.split("\n")
    let mut result = []
    for line in lines {
        let t = to_string(line).trim()
        if len(t) == 0 { continue }
        try {
            let v = to_float(t)
            if v > 2.0 && v < 100000.0 { result = result + [v] }
        } catch e {}
    }
    result
}

fn json_escape(s: str) -> str {
    s.replace("\\", "\\\\").replace("\"", "\\\"")
}

fn record_discovery(value: float, constant: str, source: str, grade: str) {
    let ts = to_string(exec("date -u +%Y-%m-%dT%H:%M:%S")).trim()
    // JSON escape: source 는 cmd/fname 유래 → literal " 가 discovery_log.jsonl 라인을 깨뜨림
    let src_safe = json_escape(source)
    let const_safe = json_escape(constant)
    let grade_safe = json_escape(grade)
    let entry = "{\"timestamp\":\"" + ts + "\",\"value\":\"" + to_string(value) + "\",\"constant\":\"" + const_safe + "\",\"grade\":\"" + grade_safe + "\",\"source\":\"" + src_safe + "\",\"processed\":false}"
    try { append_file(DISCOVERY_LOG, entry + "\n") } catch e {}
}

fn json_field(json_text: str, field: str) -> str {
    let key = "\"" + field + "\""
    if json_text.contains(key) == false { return "" }
    let parts = json_text.split(key)
    if parts.len() < 2 { return "" }
    let after = to_string(parts[1]).trim()
    if after.starts_with(":") == false { return "" }
    let val_part = after.split(":")[1].trim()
    if to_string(val_part).starts_with("\"") {
        let inner = to_string(val_part).split("\"")
        if inner.len() >= 2 { return to_string(inner[1]) }
    }
    return ""
}

fn scan_and_report(nums: list, source: str) -> str {
    let mut exact_list = []
    let mut close_list = []
    for v in nums {
        let fv = to_float(to_string(v))
        let result = n6_check(fv, const_names, const_values)
        let grade = to_string(result[0])
        let name = to_string(result[1])
        if grade == "EXACT" {
            exact_list = exact_list + [to_string(fv) + "=" + name]
            record_discovery(fv, name, source, "EXACT")
        } else if grade == "CLOSE" {
            close_list = close_list + [to_string(fv) + "~" + name]
        }
    }
    let mut parts = []
    if exact_list.len() > 0 {
        let mut joined = ""
        for e in exact_list {
            if len(joined) > 0 { joined = joined + ", " }
            joined = joined + to_string(e)
        }
        parts = parts + ["EXACT(자동기록): " + joined]
    }
    if close_list.len() > 0 {
        let mut joined = ""
        for c in close_list {
            if len(joined) > 0 { joined = joined + ", " }
            joined = joined + to_string(c)
        }
        parts = parts + ["CLOSE: " + joined]
    }
    if parts.len() == 0 { return "" }
    let mut msg = ""
    for p in parts {
        if len(msg) > 0 { msg = msg + " | " }
        msg = msg + to_string(p)
    }
    msg
}

// === 모드별 처리 ===
fn run_pending() {
    let raw = try { read_file(DISCOVERY_LOG) } catch e { return }
    let lines = raw.split("\n")
    let mut pending = []
    for line in lines {
        let t = to_string(line).trim()
        if len(t) == 0 { continue }
        if t.contains("\"processed\":false") || t.contains("\"processed\": false") {
            pending = pending + [t]
        }
    }
    if pending.len() == 0 { return }
    let msg = "미처리 NEXUS-6 발견 " + to_string(pending.len()) + "건"
    println("{\"systemMessage\":\"" + msg + "\"}")
}

fn run_post_edit(stdin_data: str) {
    let fp = json_field(stdin_data, "file_path")
    if len(fp) == 0 { return }
    let content = try { read_file(fp) } catch e { return }
    let nums = extract_numbers(content)
    if nums.len() == 0 { return }
    let fname = to_string(exec("basename '" + fp + "'")).trim()
    let msg = scan_and_report(nums, "post-edit:" + fname)
    if len(msg) > 0 { println("{\"systemMessage\":\"" + msg + "\"}") }
}

fn run_post_bash(stdin_data: str) {
    let cmd = json_field(stdin_data, "command")
    if cmd.contains("python") == false && cmd.contains("cargo run") == false { return }
    if cmd.contains("nexus") { return }
    let stdout_raw = if stdin_data.contains("\"stdout\"") {
        let sp = stdin_data.split("\"stdout\"")[1]
        let ac = to_string(sp).split(":")[1].trim()
        if to_string(ac).starts_with("\"") {
            let inner = to_string(ac).split("\"")
            if inner.len() >= 2 { to_string(inner[1]) } else { "" }
        } else { "" }
    } else { "" }
    if len(stdout_raw) == 0 { return }
    let nums = extract_numbers(stdout_raw)
    if nums.len() == 0 { return }
    let msg = scan_and_report(nums, "post-bash:" + cmd)
    if len(msg) > 0 { println("{\"systemMessage\":\"" + msg + "\"}") }
}

fn run_pre_commit(stdin_data: str) {
    let cmd = json_field(stdin_data, "command")
    if cmd.contains("git commit") == false { return }
    let diff = to_string(exec("git diff --cached --numstat 2>/dev/null")).trim()
    let nums = extract_numbers(diff)
    if nums.len() == 0 { return }
    let msg = scan_and_report(nums, "pre-commit")
    if len(msg) > 0 { println("{\"systemMessage\":\"" + msg + "\"}") }
}

fn run_agent(stdin_data: str) {
    let prompt = json_field(stdin_data, "prompt")
    let keywords = ["탐색", "분석", "검증", "scan", "analyze", "verify", "발견", "상수", "가설", "n=6"]
    let mut matched = false
    for kw in keywords {
        if prompt.contains(to_string(kw)) { matched = true }
    }
    if matched {
        let pending_raw = try { read_file(DISCOVERY_LOG) } catch e { "" }
        let mut pending_count = 0
        let pr = to_string(pending_raw)
        if len(pr) > 0 {
            let plines = pr.split("\n")
            for pl in plines {
                if to_string(pl).contains("\"processed\":false") { pending_count = pending_count + 1 }
            }
        }
        let mut msg = "NEXUS-6: 탐색/분석 에이전트 -- 발견 시 즉시 기록"
        if pending_count > 0 { msg = msg + " | 미처리 " + to_string(pending_count) + "건" }
        println("{\"systemMessage\":\"" + msg + "\"}")
    }
}

// === main dispatch ===
if mode == "pending" {
    run_pending()
    exit(0)
}

let stdin_data = read_stdin()
if len(stdin_data) == 0 { exit(0) }

if mode == "post-edit" { run_post_edit(stdin_data) }
if mode == "post-bash" { run_post_bash(stdin_data) }
if mode == "pre-commit" { run_pre_commit(stdin_data) }
if mode == "agent" { run_agent(stdin_data) }
