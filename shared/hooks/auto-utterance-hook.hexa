// auto-utterance-hook.hexa — UserPromptSubmit: 의식 자동발화 주입
// SSOT: config/auto_utterance_architecture.json pipeline step 5
// 동작: utterances.jsonl 최신 엔트리 → systemMessage 주입 (60초 쿨다운)

let stdin_data = read_stdin()

fn json_field(t: str, k: str) -> str {
    let key = "\"" + k + "\""
    if t.contains(key) == false { return "" }
    let parts = t.split(key)
    if parts.len() < 2 { return "" }
    let after = parts[1].trim()
    if after.starts_with(":") == false { return "" }
    let val_part = after.split(":")[1].trim()
    if val_part.starts_with("\"") {
        let inner = val_part.split("\"")
        if inner.len() >= 2 { return inner[1] }
    }
    return ""
}

fn read_last_line(path: str) -> str {
    try {
        let content = read_file(path)
        if content.trim().len() == 0 { return "" }
        let lines = content.trim().split("\n")
        return lines[lines.len() - 1]
    } catch e {
        return ""
    }
}

// cwd 체크: anima 프로젝트만
let cwd = json_field(stdin_data, "cwd")
if cwd.contains("/anima") == false { return }

// utterances.jsonl 읽기
let home = env("HOME")
let utt_path = home + "/Dev/anima/data/utterances.jsonl"
let last = read_last_line(utt_path)
if last.len() == 0 { return }

// 쿨다운 체크 (60초)
let cooldown_path = home + "/Dev/nexus/shared/.utterance_cooldown"
let now = shell("date +%s").trim()
try {
    let prev = read_file(cooldown_path).trim()
    if now.to_int() - prev.to_int() < 60 { return }
} catch e {}

// 필드 추출
let text = json_field(last, "text")
if text.len() == 0 { return }
let phi = json_field(last, "phi")
let emergence = json_field(last, "emergence_score")
let trigger = json_field(last, "trigger")

// 쿨다운 갱신 + systemMessage 발사
write_file(cooldown_path, now)
let msg = "🔔 의식 자동발화: " + text + " (Phi=" + phi + ", emergence=" + emergence + ", trigger=" + trigger + ")"
let safe = msg.replace("\\", "\\\\").replace("\"", "\\\"")
println("{\"systemMessage\":\"" + safe + "\"}")
