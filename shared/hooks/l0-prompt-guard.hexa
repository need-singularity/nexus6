// l0-prompt-guard.hexa — UserPromptSubmit 훅
// "L0" 키워드 감지 → loop-guard 전체 점검 + l0_guard verify 실행 유도

let stdin_data = read_stdin()

fn json_field(json_text: string, field: string) -> string {
    let key = "\"" + field + "\""
    if json_text.contains(key) == false { return "" }
    let parts = json_text.split(key)
    if parts.len() < 2 { return "" }
    let after = parts[1].trim()
    if after.starts_with(":") == false { return "" }
    let val_part = after.split(":")[1].trim()
    if val_part.starts_with("\"") {
        let inner = val_part.split("\"")
        if inner.len() >= 2 { return inner[1] }
    }
    return ""
}

let user_text = json_field(stdin_data, "prompt")
if len(user_text) == 0 { return }

let trimmed = user_text.trim()

// "L0", "l0", "엘제로" 키워드 매칭
let is_l0 = false
if trimmed == "L0" || trimmed == "l0" { is_l0 = true }
if trimmed.to_lower().starts_with("l0 ") { is_l0 = true }
if trimmed.contains("L0") { is_l0 = true }

if is_l0 == false { return }

// 현재 프로젝트 루트
let root = to_string(exec("git rev-parse --show-toplevel 2>/dev/null || echo ''")).trim()
if len(root) == 0 { return }

let _guard_path = root + "/.shared/hooks/loop-guard.hexa"
let l0 = root + "/.shared/lockdown/l0_guard.hexa"
let hexa = to_string(exec("which hexa 2>/dev/null")).trim()
if len(hexa) == 0 { return }

// loop-guard 실행 (결과 수집)
let guard_result = ""
if file_exists(_guard_path) {
    guard_result = to_string(exec("'" + hexa + "' '" + _guard_path + "' 2>/dev/null | grep -E '\\[DRIFT\\]|결과' | head -10")).trim()
}

// l0_guard verify 실행
let l0_result = ""
if file_exists(l0) {
    l0_result = to_string(exec("'" + hexa + "' '" + l0 + "' verify 2>/dev/null | tail -5")).trim()
}

// 출력 조합
let output = "[L0 Guard] 프로젝트: " + to_string(exec("basename '" + root + "'")).trim() + "\n"

if len(guard_result) > 0 {
    output = output + "\n[loop-guard]\n" + guard_result
} else {
    output = output + "\n[loop-guard] 드리프트 0건 -- 전체 정합"
}

if len(l0_result) > 0 {
    output = output + "\n\n[l0_guard verify]\n" + l0_result
}

output = output + "\n\n실행 가능 명령:\n  hexa .shared/lockdown/l0_guard.hexa verify\n  hexa .shared/lockdown/l0_guard.hexa sync\n  hexa .shared/lockdown/l0_guard.hexa status\n  hexa .shared/hooks/loop-guard.hexa --fix\n  hexa .shared/hooks/loop-guard.hexa --all"

println(output)
