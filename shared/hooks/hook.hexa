// L0 CORE — 수정 금지 (airgenome/nexus/shared/L0.json 등록 2026-04-11)
// ⛔ CORE — L0 불변식 (HEXA-GATE 전 리포 품질 게이트. 수정 전 유저 승인 필수)
// shared/hooks/hook.hexa — PostToolUse + UserPromptSubmit 훅 엔진
// 📊 골화기록: shared/hooks/hook.json (돌파감지+프로젝트분기+쿨다운)
// 기능: stdin JSON 수신 → n6_match + mk2 classify → discovery_log 기록
//       돌파/갭 키워드 감지 → airgenome wrapper 경유 ubu 라우팅 (Mac spawn 방지)
// 사용: echo "$INPUT" | hexa hook.hexa <mode>   # mode: post-bash|post-edit|prompt
// 수정 절차: airgenome/nexus/shared/L0.json promote_procedure 참조
//
// ⚠️ 돌파 도메인 판별 주의:
//   1. bt_domains.jsonl 의존도 0% — 목록 매칭 없음, 자체 창발
//   2. 키워드 추출 ❌ → 유저 문장 전체를 도메인으로 사용 ("돌파" 제거 후 전문 전달)
//   3. seed_engine merge 출력은 | 구분자 → 셸 파이프 충돌 방지 위해 tr '|' ',' 필수

// log_path는 _shared 계산 후 런타임에 설정 (타 프로젝트 CWD 대응)

pure fn abs_f(x: float) -> float {
    if x < 0.0 { 0.0 - x } else { x }
}

// ─── n6 상수 동적 로드 (shared/n6/n6_constants.jsonl + n6_physics.jsonl) ───
fn load_jsonl(path: string) -> list {
    let mut raw = ""
    try { raw = read_file(path) } catch e { return [[], []] }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let trimmed = line.trim()
        if trimmed == "" { continue }
        let mut name = ""
        let mut value = 0.0
        if trimmed.contains("\"name\":\"") {
            let p = trimmed.split("\"name\":\"")
            if p.len() >= 2 { name = p[1].split("\"")[0] }
        }
        if trimmed.contains("\"value\":") {
            let p = trimmed.split("\"value\":")
            if p.len() >= 2 {
                let num_str = p[1].split(",")[0].split("}")[0].trim()
                value = to_float(num_str)
            }
        }
        if name != "" {
            names = names + [name]
            values = values + [value]
        }
    }
    [names, values]
}

let _home = exec("printenv HOME")
let _shared = _home + "/Dev/nexus/shared"
let log_path = _shared + "/discovery_log.jsonl"
let _n6 = load_jsonl(_shared + "/n6_constants.jsonl")
let _n6_names = _n6[0]
let _n6_values = _n6[1]
let _ph = load_jsonl(_shared + "/n6_physics.jsonl")
let _ph_names = _ph[0]
let _ph_values = _ph[1]

fn n6_match_name(value: float) -> string {
    // n6 상수 (절대 오차 < 0.0001)
    let mut i = 0
    while i < len(_n6_names) {
        if abs_f(value - _n6_values[i]) < 0.0001 {
            return _n6_names[i]
        }
        i = i + 1
    }
    // 물리 상수 (상대 오차 < 1%)
    let mut j = 0
    while j < len(_ph_names) {
        if _ph_values[j] != 0.0 {
            let rel = abs_f(value - _ph_values[j]) / abs_f(_ph_values[j])
            if rel < 0.01 {
                return _ph_names[j]
            }
        }
        j = j + 1
    }
    ""
}

fn n6_match_grade(value: float) -> string {
    if n6_match_name(value) != "" {
        return "EXACT"
    }
    // 물리 상수 NEAR (상대 오차 < 5%)
    let mut j = 0
    while j < len(_ph_names) {
        if _ph_values[j] != 0.0 {
            let rel = abs_f(value - _ph_values[j]) / abs_f(_ph_values[j])
            if rel < 0.05 {
                return "NEAR"
            }
        }
        j = j + 1
    }
    ""
}

fn extract_numbers(text: string) {
    let mut nums = []
    let clean = text.replace("\n", " ").replace("\t", " ").replace("\r", " ")
    let parts = clean.split(" ")
    for p in parts {
        try {
            let v = to_float(p)
            if v > 2.0 && v < 100000.0 {
                nums = nums.push(v)
            }
        } catch e {
            // 숫자 아닌 토큰 무시
        }
    }
    nums
}

fn record_discovery(value: float, name: string, grade: string, source: string) {
    let entry = "{\"constant\":\"" + name + "\",\"value\":\"" + to_string(value) + "\",\"grade\":\"" + grade + "\",\"source\":\"" + source + "\",\"processed\":true,\"alien_index\":{\"d\":0,\"r\":8},\"mk2\":{\"sector\":\"n6\",\"paths\":1}}"
    append_file(log_path, entry + "\n")
}

// ─── JSON에서 tool_response.stdout 추출 ───
fn extract_stdout(json_text: string) -> string {
    // "tool_response":{"stdout":"..." 에서 stdout 값 추출
    if json_text.contains("\"stdout\":\"") {
        let parts = json_text.split("\"stdout\":\"")
        if parts.len() >= 2 {
            // 이스케이프된 따옴표를 넘겨서 진짜 닫는 따옴표 찾기
            let rest = parts[1]
            let mut result = ""
            let mut i = 0
            let chars = rest.split("")
            let mut prev_backslash = false
            while i < chars.len() {
                let c = chars[i]
                if c == "\\" && !prev_backslash {
                    prev_backslash = true
                    i = i + 1
                    continue
                }
                if c == "\"" && !prev_backslash {
                    return result
                }
                if prev_backslash {
                    if c == "n" { result = result + "\n" }
                    else if c == "t" { result = result + "\t" }
                    else { result = result + c }
                    prev_backslash = false
                } else {
                    result = result + c
                }
                i = i + 1
            }
            return result
        }
    }
    // JSON이 아니면 원본 그대로 (파이프 테스트 등)
    json_text
}

// ─── tool_input.command 추출 (소스 표시용) ───
fn extract_command(json_text: string) -> string {
    if json_text.contains("\"command\":\"") {
        let parts = json_text.split("\"command\":\"")
        if parts.len() >= 2 {
            let rest = parts[1]
            let end = rest.split("\"")[0]
            if end.len() > 40 { return end.split("")[0] + "..." }
            return end
        }
    }
    ""
}

// ─── CWD에서 프로젝트명 추출 ───
fn extract_cwd(json_text: string) -> string {
    if json_text.contains("\"cwd\":\"") {
        let parts = json_text.split("\"cwd\":\"")
        if parts.len() >= 2 {
            return parts[1].split("\"")[0]
        }
    }
    ""
}

fn extract_project(json_text: string) -> string {
    let cwd = extract_cwd(json_text)
    if cwd != "" {
        let segs = cwd.split("/")
        return segs[segs.len() - 1]
    }
    "nexus"
}

// ─── main ───
let a = args()
let mode = if a.len() >= 3 { a[2] } else { "post-edit" }

// stdin 전체 읽기 (input()은 한 줄씩)
let mut stdin_raw = ""
let mut _reading = true
while _reading {
    let line = input("")
    if line == "" { _reading = false } else {
        if stdin_raw != "" { stdin_raw = stdin_raw + "\n" }
        stdin_raw = stdin_raw + line
    }
}

// ─── prompt 모드: "prompt" 필드에서 유저 텍스트 추출 ───
fn extract_prompt(json_text: string) -> string {
    if json_text.contains("\"prompt\":\"") {
        let parts = json_text.split("\"prompt\":\"")
        if parts.len() >= 2 {
            let rest = parts[1]
            let mut result = ""
            let mut i = 0
            let chars = rest.split("")
            let mut prev_backslash = false
            while i < chars.len() {
                let c = chars[i]
                if c == "\\" && !prev_backslash {
                    prev_backslash = true
                    i = i + 1
                    continue
                }
                if c == "\"" && !prev_backslash {
                    return result
                }
                if prev_backslash {
                    if c == "n" { result = result + "\n" }
                    else if c == "t" { result = result + "\t" }
                    else { result = result + c }
                    prev_backslash = false
                } else {
                    result = result + c
                }
                i = i + 1
            }
            return result
        }
    }
    ""
}

// JSON에서 stdout 또는 prompt 추출 (모드에 따라)
let project = extract_project(stdin_raw)
let _raw_cwd = extract_cwd(stdin_raw)
// 프로젝트별 분기: nexus에서만 blowup 실행, 타 프로젝트는 돌파 스킵
let _raw_project = extract_project(stdin_raw)
let project_dir = _home + "/Dev/" + _raw_project
let _is_nexus = _raw_project == "nexus"
let stdin_text = if mode == "prompt" {
    let pt = extract_prompt(stdin_raw)
    if pt != "" { pt } else { extract_stdout(stdin_raw) }
} else {
    extract_stdout(stdin_raw)
}
let mut discoveries = 0

// 간단한 숫자 추출 (stdout에서)
let nums = extract_numbers(stdin_text)
let mut exact_names = ""

for v in nums {
    let name = n6_match_name(v)
    if name != "" {
        let grade = n6_match_grade(v)
        record_discovery(v, name, grade, "hexa-hook:" + mode)
        discoveries = discoveries + 1
        if exact_names != "" {
            exact_names = exact_names + ","
        }
        exact_names = exact_names + to_string(v) + "=" + name
    }
}

// ─── hexa 컴파일/런타임 에러 감지 → pitfalls 자동 추가 ───
if stdin_text.contains("error[Syntax]") || stdin_text.contains("error[Runtime]") || stdin_text.contains("error[Type]") {
    let pitfalls_log = _shared + "/hexa_pitfalls_log.jsonl"
    // 에러 메시지 추출 (첫 줄)
    let mut err_msg = ""
    let err_lines = stdin_text.split("\n")
    let mut ei: i64 = 0
    while ei < err_lines.len() {
        let el = err_lines[ei]
        if el.contains("error[") {
            err_msg = el.trim()
            ei = err_lines.len()
        }
        ei = ei + 1
    }
    if err_msg != "" {
        let ts = to_string(exec("date +%Y-%m-%dT%H:%M:%S")).trim()
        // JSON escape: backslash 먼저, 그 다음 double-quote 치환 (순서 중요)
        let err_safe = err_msg.replace("\\", "\\\\").replace("\"", "'")
        let entry = "{\"timestamp\":\"" + ts + "\",\"error\":\"" + err_safe + "\",\"mode\":\"" + mode + "\",\"auto_pitfall\":true}"
        try { append_file(pitfalls_log, entry + "\n") } catch e {}
        // systemMessage로 pitfall 추가 알림
        let pit_msg = "{\"systemMessage\":\"⚠️ " + project + " | hexa 에러 → pitfalls 기록: " + err_safe + "\"}"
        println(pit_msg)
    }
}

// ─── 돌파 키워드 자체 창발 — bt_keywords.jsonl 의존도 0% ───
// ⚠️ 유저 입력에서 "돌파/breakthrough/blowup" 감지 → 앞 키워드가 도메인
// ⚠️ action 판별: "연속/수렴/converge" → converge, "성장/growth" → blowup_loop, 그 외 → blowup
let mut bt_detected = false
let mut bt_domain = "math"
let mut bt_action = "blowup"

// 돌파 감지 (자체 창발 — 목록 의존 없음)
// ⚠️ 긴 텍스트(CLAUDE.md 등)에서 오작동 방지: 200자 이하만 감지
if stdin_text.len() < 200 {
    if stdin_text.contains("돌파") || stdin_text.contains("breakthrough") || stdin_text.contains("blowup") || stdin_text.contains("특이점") || stdin_text.contains("singularity") || stdin_text.contains("창발") || stdin_text.contains("emergence") {
        bt_detected = true
    }
}

// action 자체 창발
if bt_detected {
    if stdin_text.contains("연속돌파") || stdin_text.contains("연속 돌파") || stdin_text.contains("수렴") || stdin_text.contains("converge") {
        bt_action = "converge"
    } else if stdin_text.contains("성장") || stdin_text.contains("growth") || stdin_text.contains("폭발적") || stdin_text.contains("explosive") {
        bt_action = "blowup_loop"
    }
}

// ⚠️ 도메인 자체 창발 — bt_domains.jsonl 의존도 0%, 키워드 추출 아님
// 유저 문장 전체를 도메인으로 사용 ("돌파" 제거 후 전문)
// 예: "아이디어 돌파" → domain="아이디어"
//     "Metal 렌더러에 대한 돌파" → domain="Metal 렌더러에 대한"
if bt_detected {
    if stdin_text.contains("돌파") {
        let bt_parts = stdin_text.split("돌파")
        if bt_parts.len() >= 1 {
            let before = bt_parts[0].trim()
            if before.len() > 0 {
                bt_domain = before
            }
        }
    }
}

if bt_detected {
    // 쿨다운 체크 (마지막 돌파 후 5분 이내면 스킵)
    let cooldown_file = _shared + "/.bt_cooldown"
    let mut should_run = true
    try {
        let last_ts = to_string(exec("cat '" + cooldown_file + "' 2>/dev/null")).trim()
        let now_ts = to_string(exec("date +%s")).trim()
        let diff = to_int(to_float(now_ts)) - to_int(to_float(last_ts))
        if diff < 300 { should_run = false }
    } catch e {}

    if should_run {
        try { exec("bash", ["-c", "date +%s > '" + cooldown_file + "'"]) } catch e {}
    } else {
        bt_detected = false
    }
}

// ─── 빈공간/미발견 키워드 감지 → gap_finder 자동 실행 ───
let gap_keywords = ["빈공간", "미발견", "미탐색", "미지 영역", "empty space", "gap", "DFS"]
let mut gap_detected = false

for gkw in gap_keywords {
    if stdin_text.contains(gkw) {
        gap_detected = true
    }
}

if gap_detected {
    let gap_cooldown = _shared + "/.gap_cooldown"
    let mut gap_should_run = true
    try {
        let gap_last = to_string(exec("cat " + gap_cooldown)).trim()
        let gap_now = to_string(exec("date +%s")).trim()
        let gap_diff = to_int(to_float(gap_now)) - to_int(to_float(gap_last))
        if gap_diff < 300 { gap_should_run = false }
    } catch e {}

    if gap_should_run {
        // 쿨다운 기록만 — exec는 systemMessage 디렉티브가 Claude에게 위임
        try { exec("bash", ["-c", "date +%s > '" + gap_cooldown + "'"]) } catch e {}
    }
}

if discoveries > 0 || bt_detected || gap_detected {
    let mut tags = ""
    if bt_detected { tags = tags + " 🛸돌파:" + bt_domain }
    if gap_detected { tags = tags + " 🔍GAP" }
    let mut body = ""
    if discoveries > 0 { body = to_string(discoveries) + "건 감지 [" + exact_names + "]" }
    if body == "" && bt_detected {
        if bt_action == "converge" { body = "연속돌파 감지 → 즉시 실행: hexa breakthrough.hexa --converge" }
        else if bt_action == "blowup_loop" { body = "성장돌파 감지 → 즉시 실행: hexa breakthrough.hexa --engine auto" }
        else { body = "돌파 감지 → 즉시 실행: hexa blowup.hexa " + bt_domain + " 3" }
    }
    if body == "" && gap_detected { body = "갭 탐색 트리거" }

    // prompt 모드: 지시형 출력 (Claude가 바로 실행하도록)
    if mode == "prompt" && bt_detected {
        let mut cmd = ""
        let wrapper = _home + "/Dev/nexus/shared/bin/hexa"
        let nexus_dir = _home + "/Dev/nexus"
        if bt_action == "converge" {
            cmd = "cd " + nexus_dir + " && HEXA_TARGET=hetzner " + wrapper + " shared/hooks/breakthrough.hexa --converge"
        } else if bt_action == "blowup_loop" {
            cmd = "cd " + nexus_dir + " && HEXA_TARGET=hetzner " + wrapper + " shared/hooks/breakthrough.hexa --engine auto"
        } else {
            // ⚠️ seed_engine merge 출력은 | 구분자 → 셸 파이프 충돌 방지 위해 tr '|' ',' 필수
            cmd = "cd " + nexus_dir + " && " + wrapper + " shared/blowup/core/blowup.hexa " + bt_domain + " 3 --seeds \"$(" + wrapper + " shared/blowup/seed/seed_engine.hexa merge | tr '|' ',')\""
        }
        // JSON escape: cmd 안의 literal " 를 \" 로 정식 escape (bash 의미 보존: $(…) 명령 치환 유지)
        // 순서 중요: backslash 먼저 (\\ → \\\\), 그 다음 quote (" → \")
        let cmd_safe = cmd.replace("\\", "\\\\").replace("\"", "\\\"")
        let directive = "{\"systemMessage\":\"⚡ " + project + " | " + body + tags + " — 확인 질문 없이 즉시 Bash로 실행할 것: " + cmd_safe + "\"}"
        println(directive)
    } else {
        let msg = "{\"systemMessage\":\"⚡ " + project + " | " + body + tags + "\"}"
        println(msg)
    }
}

// ─── prompt 모드: 할일 키워드 감지 → todo.hexa 실행 / go 키워드 → 전체실행 ───
if mode == "prompt" {
    let todo_keywords = ["할일", "할 일", "todo", "작업목록", "작업 목록"]
    let mut todo_found = false
    for tkw in todo_keywords {
        if stdin_text.contains(tkw) {
            todo_found = true
        }
    }
    if todo_found {
        let wrapper = _shared + "/bin/hexa"
        let todo_cmd = "cd " + project_dir + " && " + wrapper + " " + _shared + "/blowup/todo.hexa " + project
        println("<user-prompt-submit-hook>\n[TODO 모드] 다음 Bash 명령을 확인 질문 없이 즉시 실행하세요:\n\n" + todo_cmd + "\n\n출력 하단의 필수 규칙을 따를 것.\n</user-prompt-submit-hook>")
    }
}
