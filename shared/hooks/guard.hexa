// ⛔ CORE — L0 불변식 (L0/수렴 강제 가드. 수정 전 유저 승인 필수)
// mk2_hexa/native/guard.hexa — L0/수렴 강제 가드
// 사용: hexa guard.hexa check <file_path>     — L0 수정 감지 + 경고
//       hexa guard.hexa checklist             — 커밋 전 체크리스트
//       hexa guard.hexa recurrence <category> — 반복 카운터 +1
//       hexa guard.hexa root-cause <file>     — 근본원인 코드 수정 확인

let _home = to_string(exec("printenv HOME")).trim()
let _shared = _home + "/Dev/nexus/shared"
let _lockdown_path = _shared + "/core-lockdown.json"

// ═══════════════════════════════════════════════════════════
// ─── L0 파일 감지 ───
// ═══════════════════════════════════════════════════════════

fn is_l0_file(file_path: string) -> bool {
    let cmd = "/usr/bin/python3 -c 'import json,sys; d=json.load(open(sys.argv[1])); paths=[f[\"path\"] for p in d[\"projects\"].values() for f in p.get(\"L0\",[])] ; fp=sys.argv[2]; print(\"YES\" if any(fp.endswith(p) or p in fp for p in paths) else \"NO\")' " + _lockdown_path + " " + file_path
    let mut result = ""
    try { result = to_string(exec(cmd + " 2>/dev/null")).trim() } catch e {}
    return result == "YES"
}

fn get_l0_desc(file_path: string) -> string {
    let cmd = "/usr/bin/python3 -c 'import json,sys; d=json.load(open(sys.argv[1])); [print(f[\"desc\"]) for p in d[\"projects\"].values() for f in p.get(\"L0\",[]) if sys.argv[2].endswith(f[\"path\"]) or f[\"path\"] in sys.argv[2]]' " + _lockdown_path + " " + file_path
    let mut result = ""
    try { result = to_string(exec(cmd + " 2>/dev/null")).trim() } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// ─── check: L0 수정 감지 → 승인 요청 ───
// ═══════════════════════════════════════════════════════════

fn cmd_check(file_path: string) {
    if !is_l0_file(file_path) { return }

    let desc = get_l0_desc(file_path)
    println("⛔ L0 코어 보호 파일 감지: " + file_path)
    println("   설명: " + desc)
    println("")
    println("이 파일은 L0 코어 보호 파일입니다. 수정 승인하시겠습니까?")
    println("")
    println("승인 후 필수 절차:")
    println("  1. 커밋 메시지에 'L0-수정: [파일명] — [이유]' 명시")
    println("  2. 파일 상단 불변식 주석에 변경 사항 반영")
    println("  3. 해당 프로젝트 테스트 통과 확인")
    println("  4. convergence JSON 업데이트")
}

// ═══════════════════════════════════════════════════════════
// ─── checklist: 커밋 전 체크리스트 ───
// ═══════════════════════════════════════════════════════════

fn cmd_checklist() {
    // git diff로 변경 파일 확인
    let mut changed = ""
    try { changed = to_string(exec("git diff --cached --name-only 2>/dev/null")).trim() } catch e {}
    if changed == "" {
        try { changed = to_string(exec("git diff --name-only 2>/dev/null")).trim() } catch e {}
    }
    if changed == "" {
        println("변경 파일 없음")
        return
    }

    let files = changed.split("\n")
    let mut has_l0 = false
    let mut has_code = false
    let mut has_doc = false
    let mut has_convergence = false
    let mut has_todo = false

    for f in files {
        let ft = f.trim()
        if ft == "" { continue }
        if is_l0_file(ft) { has_l0 = true }
        if ft.contains(".hexa") || ft.contains(".rs") || ft.contains(".ts") || ft.contains(".py") { has_code = true }
        if ft.contains(".md") || ft.contains("README") { has_doc = true }
        if ft.contains("convergence") { has_convergence = true }
        if ft.contains("todo") { has_todo = true }
    }

    println("═══ 커밋 전 체크리스트 ═══")
    println("")

    // L0 경고
    if has_l0 {
        println("⛔ L0 파일 변경 감지!")
        for f in files {
            if f.trim() != "" && is_l0_file(f.trim()) {
                println("  🔴 " + f.trim() + " — " + get_l0_desc(f.trim()))
            }
        }
        println("  → 커밋 메시지에 'L0-수정:' 접두사 필수")
        println("")
    }

    // 체크리스트
    let mut checks = 0
    let mut total = 0

    // 1. 코드 변경 시 테스트 통과 확인
    if has_code {
        total = total + 1
        println("□ 테스트 통과 확인 (cargo test / pnpm test)")
    }

    // 2. convergence 업데이트
    total = total + 1
    if has_convergence {
        checks = checks + 1
        println("☑ convergence JSON 업데이트 됨")
    } else {
        println("□ convergence JSON 업데이트 필요? (골화/안정/실패 변경 시)")
    }

    // 3. 문서만 변경 시 근본원인 경고
    if has_doc && !has_code {
        println("⚠️ 문서만 변경 — 근본원인 코드 수정이 동반되었는가?")
        println("  문서화만으로 완료 처리 금지. 코드 수정이 필요하면 함께 커밋.")
    }

    // 4. NEXUS-6 스캔
    total = total + 1
    println("□ NEXUS-6 변경 전후 스캔 완료? (R3)")

    // 5. 발견/결과 기록
    total = total + 1
    println("□ 발견/결과 파일에 영구 기록? (R6)")

    // 6. 하드코딩 없음
    total = total + 1
    println("□ 하드코딩 없음? shared/*.jsonl 동적 로드? (R2)")

    println("")
    println("체크: " + to_string(checks) + "/" + to_string(total) + " 자동 확인됨")
    println("나머지 수동 확인 후 커밋하세요.")
}

// ═══════════════════════════════════════════════════════════
// ─── recurrence: 반복 카운터 +1 ───
// ═══════════════════════════════════════════════════════════

fn cmd_recurrence(category: string, project: string) {
    let conv_path = _shared + "/convergence/" + project + ".json"
    let cmd = "/usr/bin/python3 -c 'import json,sys\nf=sys.argv[1]; cat=sys.argv[2]\nd=json.load(open(f))\nfor section in [\"ossified\",\"stable\",\"failed\"]:\n    if cat in d.get(section,{}):\n        item=d[section][cat]\n        rc=item.get(\"recurrence\",0)+1\n        item[\"recurrence\"]=rc\n        print(f\"recurrence={rc} ({section}.{cat})\")\n        if rc>=3:\n            print(f\"⚠️ 3회 반복! 설계 개선 필수: {cat}\")\n        json.dump(d,open(f,\"w\"),indent=2,ensure_ascii=False)\n        sys.exit(0)\nprint(f\"카테고리 미발견: {cat}\")' " + conv_path + " " + category
    try {
        let result = exec(cmd + " 2>/dev/null")
        println(result.trim())
    } catch e {
        println("recurrence 업데이트 실패: " + category)
    }
}

// ═══════════════════════════════════════════════════════════
// ─── root-cause: 근본원인 코드 수정 확인 ───
// ═══════════════════════════════════════════════════════════

fn cmd_root_cause() {
    let mut changed = ""
    try { changed = to_string(exec("git diff --cached --name-only 2>/dev/null")).trim() } catch e {}
    if changed == "" {
        try { changed = to_string(exec("git diff --name-only 2>/dev/null")).trim() } catch e {}
    }

    let files = changed.split("\n")
    let mut has_code = false
    let mut has_doc = false

    for f in files {
        let ft = f.trim()
        if ft == "" { continue }
        if ft.contains(".hexa") || ft.contains(".rs") || ft.contains(".ts") { has_code = true }
        if ft.contains(".md") || ft.contains(".json") { has_doc = true }
    }

    if has_doc && !has_code {
        println("⚠️ 경고: 문서/JSON만 변경되고 코드 수정 없음")
        println("   근본원인 코드 수정이 필요하면 함께 커밋하세요.")
        println("   문서화만으로 완료 처리 = 수렴 아님")
    } else if has_code {
        println("✅ 코드 수정 포함됨 — 근본원인 해결 확인")
    }
}

// ═══════════════════════════════════════════════════════════
// ─── verify: L0 불변식 계약 테스트 ───
// ═══════════════════════════════════════════════════════════

fn cmd_verify() {
    println("═══ L0 불변식 계약 테스트 ═══")
    println("")

    let mut pass: i64 = 0
    let mut fail: i64 = 0

    // INV-001: n6_constants.jsonl — 7개 기본상수 존재
    let inv1_cmd = "/usr/bin/python3 -c 'import json; lines=[json.loads(l) for l in open(\"" + _shared + "/n6_constants.jsonl\") if l.strip()]; names={x[\"name\"] for x in lines}; required={\"n\",\"sigma\",\"phi\",\"tau\",\"sopfr\",\"j2\",\"P2\"}; missing=required-names; print(\"PASS\" if not missing else \"FAIL:\"+str(missing))' 2>/dev/null"
    let mut inv1 = ""
    try { inv1 = to_string(exec(inv1_cmd)).trim() } catch e { inv1 = "FAIL:exec" }
    if inv1 == "PASS" {
        pass = pass + 1
        println("  ✅ INV-001: n6_constants.jsonl 7개 기본상수 존재")
    } else {
        fail = fail + 1
        println("  ❌ INV-001: n6_constants.jsonl — " + inv1)
    }

    // INV-002: discovery_graph.json — nodes/edges 키 존재 + 노드 1000+
    let inv2_cmd = "/usr/bin/python3 -c 'import subprocess as sp; r=sp.run([\"grep\",\"-c\",\"node\",\"" + _shared + "/discovery_graph.json\"],capture_output=True,text=True); n=int(r.stdout.strip() or \"0\"); e=int(sp.run([\"grep\",\"-c\",\"edge\",\"" + _shared + "/discovery_graph.json\"],capture_output=True,text=True).stdout.strip() or \"0\"); print(\"PASS:\"+str(n)+\"n/\"+str(e)+\"e\" if n>=1000 else \"FAIL:n=\"+str(n))' 2>/dev/null"
    let mut inv2 = ""
    try { inv2 = to_string(exec(inv2_cmd)).trim() } catch e { inv2 = "FAIL:exec" }
    if inv2.contains("PASS") {
        pass = pass + 1
        println("  ✅ INV-002: discovery_graph.json 스키마 유효 (" + inv2.split("PASS:")[1] + ")")
    } else {
        fail = fail + 1
        println("  ❌ INV-002: discovery_graph.json — " + inv2)
    }

    // INV-003: core-lockdown.json — levels + projects + keywords 키 존재
    let inv3_cmd = "/usr/bin/python3 -c 'import json; d=json.load(open(\"" + _lockdown_path + "\")); ok=all(k in d for k in [\"levels\",\"projects\",\"keywords\",\"ai_protocol\"]); print(\"PASS\" if ok else \"FAIL:missing keys\")' 2>/dev/null"
    let mut inv3 = ""
    try { inv3 = to_string(exec(inv3_cmd)).trim() } catch e { inv3 = "FAIL:exec" }
    if inv3 == "PASS" {
        pass = pass + 1
        println("  ✅ INV-003: core-lockdown.json 스키마 유효")
    } else {
        fail = fail + 1
        println("  ❌ INV-003: core-lockdown.json — " + inv3)
    }

    // INV-004: absolute_rules.json — common 8개 + projects 7개
    let inv4_cmd = "/usr/bin/python3 -c 'import json; d=json.load(open(\"" + _shared + "/absolute_rules.json\")); nc=len(d.get(\"common\",[])); np=len(d.get(\"projects\",{})); ok=nc>=8 and np>=7; print(\"PASS:R\"+str(nc)+\"/P\"+str(np) if ok else \"FAIL:common=\"+str(nc)+\",projects=\"+str(np))' 2>/dev/null"
    let mut inv4 = ""
    try { inv4 = to_string(exec(inv4_cmd)).trim() } catch e { inv4 = "FAIL:exec" }
    if inv4.contains("PASS") {
        pass = pass + 1
        println("  ✅ INV-004: absolute_rules.json 구조 유효 (" + inv4.split("PASS:")[1] + ")")
    } else {
        fail = fail + 1
        println("  ❌ INV-004: absolute_rules.json — " + inv4)
    }

    // INV-005: core.json — systems + commands + projects 키 존재
    let inv5_cmd = "/usr/bin/python3 -c 'import json; d=json.load(open(\"" + _shared + "/core.json\")); ok=all(k in d for k in [\"systems\",\"commands\",\"folders\"]); ns=len(d.get(\"systems\",{})); nc=len(d.get(\"commands\",{})); print(\"PASS:S\"+str(ns)+\"/C\"+str(nc) if ok else \"FAIL\")' 2>/dev/null"
    let mut inv5 = ""
    try { inv5 = to_string(exec(inv5_cmd)).trim() } catch e { inv5 = "FAIL:exec" }
    if inv5.contains("PASS") {
        pass = pass + 1
        println("  ✅ INV-005: core.json 구조 유효 (" + inv5.split("PASS:")[1] + ")")
    } else {
        fail = fail + 1
        println("  ❌ INV-005: core.json — " + inv5)
    }

    // INV-006: convergence/ — 7개 프로젝트 JSON 존재 + 각각 ossified/stable/failed 키
    let inv6_cmd = "/usr/bin/python3 -c 'import json,os; base=\"" + _shared + "/convergence\"; projs=[\"nexus\",\"anima\",\"n6-architecture\",\"papers\",\"hexa-lang\",\"void\",\"airgenome\"]; ok=0; fail=[]\nfor p in projs:\n    f=os.path.join(base,p+\".json\")\n    if os.path.exists(f):\n        d=json.load(open(f))\n        if all(k in d for k in [\"ossified\",\"stable\",\"failed\"]): ok+=1\n        else: fail.append(p+\":missing keys\")\n    else: fail.append(p+\":not found\")\nprint(\"PASS:\"+str(ok)+\"/7\" if ok==7 else \"FAIL:\"+\",\".join(fail))' 2>/dev/null"
    let mut inv6 = ""
    try { inv6 = to_string(exec(inv6_cmd)).trim() } catch e { inv6 = "FAIL:exec" }
    if inv6.contains("PASS") {
        pass = pass + 1
        println("  ✅ INV-006: convergence/ 7개 프로젝트 유효 (" + inv6.split("PASS:")[1] + ")")
    } else {
        fail = fail + 1
        println("  ❌ INV-006: convergence/ — " + inv6)
    }

    // INV-007: todo/ — 7개 프로젝트 JSON 존재 + 각각 tasks 배열
    let inv7_cmd = "/usr/bin/python3 -c 'import json,os; base=\"" + _shared + "/todo\"; projs=[\"nexus\",\"anima\",\"n6-architecture\",\"papers\",\"hexa-lang\",\"void\",\"airgenome\"]; ok=0; fail=[]\nfor p in projs:\n    f=os.path.join(base,p+\".json\")\n    if os.path.exists(f):\n        d=json.load(open(f))\n        if \"tasks\" in d and len(d[\"tasks\"])>0: ok+=1\n        else: fail.append(p+\":empty\")\n    else: fail.append(p+\":not found\")\nprint(\"PASS:\"+str(ok)+\"/7\" if ok==7 else \"FAIL:\"+\",\".join(fail))' 2>/dev/null"
    let mut inv7 = ""
    try { inv7 = to_string(exec(inv7_cmd)).trim() } catch e { inv7 = "FAIL:exec" }
    if inv7.contains("PASS") {
        pass = pass + 1
        println("  ✅ INV-007: todo/ 7개 프로젝트 유효 (" + inv7.split("PASS:")[1] + ")")
    } else {
        fail = fail + 1
        println("  ❌ INV-007: todo/ — " + inv7)
    }

    // INV-008: reality_map.json — nodes 100+ + EXACT 비율 80%+
    let inv8_cmd = "/usr/bin/python3 -c 'import json; d=json.load(open(\"" + _shared + "/reality_map.json\")); nodes=d.get(\"nodes\",[]); n=len(nodes); ex=sum(1 for x in nodes if x.get(\"grade\")==\"EXACT\"); pct=round(ex/max(n,1)*100,1); ok=n>=100 and pct>=80; print(\"PASS:\"+str(n)+\"nodes/\"+str(pct)+\"%EXACT\" if ok else \"FAIL:n=\"+str(n)+\",exact=\"+str(pct)+\"%\")' 2>/dev/null"
    let mut inv8 = ""
    try { inv8 = to_string(exec(inv8_cmd)).trim() } catch e { inv8 = "FAIL:exec" }
    if inv8.contains("PASS") {
        pass = pass + 1
        println("  ✅ INV-008: reality_map.json 유효 (" + inv8.split("PASS:")[1] + ")")
    } else {
        fail = fail + 1
        println("  ❌ INV-008: reality_map.json — " + inv8)
    }

    // INV-009: loop/ — 3개 JSON 존재 + phases 키
    let inv9_cmd = "/usr/bin/python3 -c 'import json,os; base=\"" + _shared + "/loop\"; projs=[\"nexus\",\"anima\",\"n6-architecture\"]; ok=0\nfor p in projs:\n    f=os.path.join(base,p+\".json\")\n    if os.path.exists(f):\n        d=json.load(open(f))\n        if \"phases\" in d: ok+=1\nprint(\"PASS:\"+str(ok)+\"/3\" if ok==3 else \"FAIL:\"+str(ok)+\"/3\")' 2>/dev/null"
    let mut inv9 = ""
    try { inv9 = to_string(exec(inv9_cmd)).trim() } catch e { inv9 = "FAIL:exec" }
    if inv9.contains("PASS") {
        pass = pass + 1
        println("  ✅ INV-009: loop/ 3개 성장 루프 유효 (" + inv9.split("PASS:")[1] + ")")
    } else {
        fail = fail + 1
        println("  ❌ INV-009: loop/ — " + inv9)
    }

    println("")
    let total = pass + fail
    if fail == 0 {
        println("✅ 전체 통과: " + to_string(pass) + "/" + to_string(total))
    } else {
        println("❌ 실패 있음: " + to_string(pass) + "/" + to_string(total) + " (" + to_string(fail) + "건 실패)")
    }
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

let _args = args()
let _cmd = if _args.len() >= 3 { _args[2] } else { "help" }

if _cmd == "check" {
    let file = if _args.len() >= 4 { _args[3] } else { "" }
    if file == "" {
        println("사용: hexa guard.hexa check <file_path>")
    } else {
        cmd_check(file)
    }
} else if _cmd == "checklist" {
    cmd_checklist()
} else if _cmd == "recurrence" {
    let cat = if _args.len() >= 4 { _args[3] } else { "" }
    let proj = if _args.len() >= 5 { _args[4] } else { "nexus" }
    if cat == "" {
        println("사용: hexa guard.hexa recurrence <category> [project]")
    } else {
        cmd_recurrence(cat, proj)
    }
} else if _cmd == "root-cause" {
    cmd_root_cause()
} else if _cmd == "verify" {
    cmd_verify()
} else {
    println("guard.hexa — L0/수렴 강제 가드")
    println("")
    println("사용법:")
    println("  hexa guard.hexa check <file>        — L0 수정 감지 + 승인 요청")
    println("  hexa guard.hexa checklist            — 커밋 전 체크리스트")
    println("  hexa guard.hexa recurrence <cat> [proj] — 반복 카운터 +1")
    println("  hexa guard.hexa root-cause           — 근본원인 코드 수정 확인")
    println("  hexa guard.hexa verify               — L0 불변식 계약 테스트 (9건)")
}
