// ⛔ CORE — L0 불변식 (L0/수렴 강제 가드. 수정 전 유저 승인 필수)
// shared/blowup/core/guard.hexa — L0/수렴 강제 가드
// 사용: hexa guard.hexa check <file_path>     — L0 수정 감지 + 경고
//       hexa guard.hexa checklist             — 커밋 전 체크리스트
//       hexa guard.hexa recurrence <category> — 반복 카운터 +1
//       hexa guard.hexa root-cause <file>     — 근본원인 코드 수정 확인

let _home = to_string(exec("printenv HOME")).trim()
let _shared = _home + "/Dev/nexus/shared"
let _lockdown_path = _shared + "/lockdown/lockdown.json"

// ═══════════════════════════════════════════════════════════
// ─── L0 파일 감지 ───
// ═══════════════════════════════════════════════════════════

fn is_l0_file(file_path: string) -> bool {
    let cmd = "/usr/bin/python3 -c 'import json,sys; d=json.load(open(sys.argv[1])); paths=[f[\"path\"] for p in d[\"projects\"].values() for f in p.get(\"L0\",[])] ; fp=sys.argv[2]; print(\"YES\" if any(fp.endswith(p) or p in fp for p in paths) else \"NO\")' " + _lockdown_path + " " + file_path
    let mut result = ""
    try { result = to_string(exec(cmd + " 2>/dev/null")).trim() } catch e {}
    return result == "YES"
}

fn get_l0_desc(file_path: string) -> string {
    let cmd = "/usr/bin/python3 -c 'import json,sys; d=json.load(open(sys.argv[1])); [print(f[\"desc\"]) for p in d[\"projects\"].values() for f in p.get(\"L0\",[]) if sys.argv[2].endswith(f[\"path\"]) or f[\"path\"] in sys.argv[2]]' " + _lockdown_path + " " + file_path
    let mut result = ""
    try { result = to_string(exec(cmd + " 2>/dev/null")).trim() } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// ─── check: L0 수정 감지 → 승인 요청 ───
// ═══════════════════════════════════════════════════════════

fn cmd_check(file_path: string) {
    if !is_l0_file(file_path) { return }

    let desc = get_l0_desc(file_path)
    println("⛔ L0 코어 보호 파일 감지: " + file_path)
    println("   설명: " + desc)
    println("")
    println("이 파일은 L0 코어 보호 파일입니다. 수정 승인하시겠습니까?")
    println("")
    println("승인 후 필수 절차:")
    println("  1. 커밋 메시지에 'L0-수정: [파일명] — [이유]' 명시")
    println("  2. 파일 상단 불변식 주석에 변경 사항 반영")
    println("  3. 해당 프로젝트 테스트 통과 확인")
    println("  4. convergence JSON 업데이트")
}

// ═══════════════════════════════════════════════════════════
// ─── checklist: 커밋 전 체크리스트 ───
// ═══════════════════════════════════════════════════════════

fn cmd_checklist() {
    // git diff로 변경 파일 확인
    let mut changed = ""
    try { changed = to_string(exec("git diff --cached --name-only 2>/dev/null")).trim() } catch e {}
    if changed == "" {
        try { changed = to_string(exec("git diff --name-only 2>/dev/null")).trim() } catch e {}
    }
    if changed == "" {
        println("변경 파일 없음")
        return
    }

    let files = changed.split("\n")
    let mut has_l0 = false
    let mut has_code = false
    let mut has_doc = false
    let mut has_convergence = false
    let mut has_todo = false

    for f in files {
        let ft = f.trim()
        if ft == "" { continue }
        if is_l0_file(ft) { has_l0 = true }
        if ft.contains(".hexa") || ft.contains(".rs") || ft.contains(".ts") || ft.contains(".py") { has_code = true }
        if ft.contains(".md") || ft.contains("README") { has_doc = true }
        if ft.contains("convergence") { has_convergence = true }
        if ft.contains("todo") { has_todo = true }
    }

    println("═══ 커밋 전 체크리스트 ═══")
    println("")

    // L0 경고
    if has_l0 {
        println("⛔ L0 파일 변경 감지!")
        for f in files {
            if f.trim() != "" && is_l0_file(f.trim()) {
                println("  🔴 " + f.trim() + " — " + get_l0_desc(f.trim()))
            }
        }
        println("  → 커밋 메시지에 'L0-수정:' 접두사 필수")
        println("")
    }

    // 체크리스트
    let mut checks = 0
    let mut total = 0

    // 1. 코드 변경 시 테스트 통과 확인
    if has_code {
        total = total + 1
        println("□ 테스트 통과 확인 (cargo test / pnpm test)")
    }

    // 2. convergence 업데이트
    total = total + 1
    if has_convergence {
        checks = checks + 1
        println("☑ convergence JSON 업데이트 됨")
    } else {
        println("□ convergence JSON 업데이트 필요? (골화/안정/실패 변경 시)")
    }

    // 3. 문서만 변경 시 근본원인 경고
    if has_doc && !has_code {
        println("⚠️ 문서만 변경 — 근본원인 코드 수정이 동반되었는가?")
        println("  문서화만으로 완료 처리 금지. 코드 수정이 필요하면 함께 커밋.")
    }

    // 4. NEXUS-6 스캔
    total = total + 1
    println("□ NEXUS-6 변경 전후 스캔 완료? (R3)")

    // 5. 발견/결과 기록
    total = total + 1
    println("□ 발견/결과 파일에 영구 기록? (R6)")

    // 6. 하드코딩 없음
    total = total + 1
    println("□ 하드코딩 없음? shared/*.jsonl 동적 로드? (R2)")

    println("")
    println("체크: " + to_string(checks) + "/" + to_string(total) + " 자동 확인됨")
    println("나머지 수동 확인 후 커밋하세요.")
}

// ═══════════════════════════════════════════════════════════
// ─── recurrence: 반복 카운터 +1 ───
// ═══════════════════════════════════════════════════════════

fn cmd_recurrence(category: string, project: string) {
    let conv_path = _shared + "/convergence/" + project + ".json"
    let cmd = "/usr/bin/python3 -c 'import json,sys\nf=sys.argv[1]; cat=sys.argv[2]\nd=json.load(open(f))\nfor section in [\"ossified\",\"stable\",\"failed\"]:\n    if cat in d.get(section,{}):\n        item=d[section][cat]\n        rc=item.get(\"recurrence\",0)+1\n        item[\"recurrence\"]=rc\n        print(f\"recurrence={rc} ({section}.{cat})\")\n        if rc>=3:\n            print(f\"⚠️ 3회 반복! 설계 개선 필수: {cat}\")\n        json.dump(d,open(f,\"w\"),indent=2,ensure_ascii=False)\n        sys.exit(0)\nprint(f\"카테고리 미발견: {cat}\")' " + conv_path + " " + category
    try {
        let result = exec(cmd + " 2>/dev/null")
        println(result.trim())
    } catch e {
        println("recurrence 업데이트 실패: " + category)
    }
}

// ═══════════════════════════════════════════════════════════
// ─── root-cause: 근본원인 코드 수정 확인 ───
// ═══════════════════════════════════════════════════════════

fn cmd_root_cause() {
    let mut changed = ""
    try { changed = to_string(exec("git diff --cached --name-only 2>/dev/null")).trim() } catch e {}
    if changed == "" {
        try { changed = to_string(exec("git diff --name-only 2>/dev/null")).trim() } catch e {}
    }

    let files = changed.split("\n")
    let mut has_code = false
    let mut has_doc = false

    for f in files {
        let ft = f.trim()
        if ft == "" { continue }
        if ft.contains(".hexa") || ft.contains(".rs") || ft.contains(".ts") { has_code = true }
        if ft.contains(".md") || ft.contains(".json") { has_doc = true }
    }

    if has_doc && !has_code {
        println("⚠️ 경고: 문서/JSON만 변경되고 코드 수정 없음")
        println("   근본원인 코드 수정이 필요하면 함께 커밋하세요.")
        println("   문서화만으로 완료 처리 = 수렴 아님")
    } else if has_code {
        println("✅ 코드 수정 포함됨 — 근본원인 해결 확인")
    }
}

// ═══════════════════════════════════════════════════════════
// ─── verify: L0 불변식 계약 테스트 ───
// ═══════════════════════════════════════════════════════════

fn cmd_verify() {
    println("═══ L0 불변식 계약 테스트 ═══")
    println("")

    let mut pass: i64 = 0
    let mut fail: i64 = 0

    // ─── Batch 1: 8개 JSON 검증을 단일 Python 프로세스로 병합 (INV-001~007,009) ───
    // 기존: 8회 exec() 직렬 호출 → 최적화: 1회 exec() 호출
    let batch_py_cmd = "/usr/bin/python3 -c 'import json,os\nB=\"" + _shared + "\"\nR=[]\ntry:\n    lines=[json.loads(l) for l in open(B+\"/n6_constants.jsonl\") if l.strip()]\n    names={x[\"name\"] for x in lines}\n    missing={\"n\",\"sigma\",\"phi\",\"tau\",\"sopfr\",\"j2\",\"P2\"}-names\n    R.append(\"INV-001:PASS\" if not missing else \"INV-001:FAIL:\"+str(missing))\nexcept Exception as e: R.append(\"INV-001:FAIL:\"+str(e))\ntry:\n    txt=open(B+\"/discovery_graph.json\").read()\n    n=txt.count(\"node\"); e=txt.count(\"edge\")\n    R.append(\"INV-002:PASS:\"+str(n)+\"n/\"+str(e)+\"e\" if n>=1000 else \"INV-002:FAIL:n=\"+str(n))\nexcept Exception as e: R.append(\"INV-002:FAIL:\"+str(e))\ntry:\n    d=json.load(open(B+\"/lockdown/lockdown.json\"))\n    ok=all(k in d for k in [\"levels\",\"projects\",\"keywords\",\"ai_protocol\"])\n    R.append(\"INV-003:PASS\" if ok else \"INV-003:FAIL:missing keys\")\nexcept Exception as e: R.append(\"INV-003:FAIL:\"+str(e))\ntry:\n    d=json.load(open(B+\"/absolute_rules.json\"))\n    nc=len(d.get(\"common\",[])); np=len(d.get(\"projects\",{}))\n    R.append(\"INV-004:PASS:R\"+str(nc)+\"/P\"+str(np) if nc>=8 and np>=7 else \"INV-004:FAIL:common=\"+str(nc)+\",projects=\"+str(np))\nexcept Exception as e: R.append(\"INV-004:FAIL:\"+str(e))\ntry:\n    d=json.load(open(B+\"/config/core.json\"))\n    ok=all(k in d for k in [\"systems\",\"commands\",\"folders\"])\n    ns=len(d.get(\"systems\",{})); nc=len(d.get(\"commands\",{}))\n    R.append(\"INV-005:PASS:S\"+str(ns)+\"/C\"+str(nc) if ok else \"INV-005:FAIL\")\nexcept Exception as e: R.append(\"INV-005:FAIL:\"+str(e))\ntry:\n    projs=[\"nexus\",\"anima\",\"n6-architecture\",\"papers\",\"hexa-lang\",\"void\",\"airgenome\"]\n    cok=0; cfail=[]; tok=0; tfail=[]\n    for p in projs:\n        cf=os.path.join(B,\"convergence\",p+\".json\")\n        if os.path.exists(cf):\n            cd=json.load(open(cf))\n            if all(k in cd for k in [\"ossified\",\"stable\",\"failed\"]): cok+=1\n            else: cfail.append(p+\":missing keys\")\n        else: cfail.append(p+\":not found\")\n        tf=os.path.join(B,\"todo\",p+\".json\")\n        if os.path.exists(tf):\n            td=json.load(open(tf))\n            if \"tasks\" in td and len(td[\"tasks\"])>0: tok+=1\n            else: tfail.append(p+\":empty\")\n        else: tfail.append(p+\":not found\")\n    R.append(\"INV-006:PASS:\"+str(cok)+\"/7\" if cok==7 else \"INV-006:FAIL:\"+\",\".join(cfail))\n    R.append(\"INV-007:PASS:\"+str(tok)+\"/7\" if tok==7 else \"INV-007:FAIL:\"+\",\".join(tfail))\nexcept Exception as e: R.append(\"INV-006:FAIL:\"+str(e)); R.append(\"INV-007:FAIL:\"+str(e))\ntry:\n    lok=0\n    for p in [\"nexus\",\"anima\",\"n6-architecture\"]:\n        f=os.path.join(B,\"config\",\"loop\",p+\".json\")\n        if os.path.exists(f):\n            ld=json.load(open(f))\n            if \"phases\" in ld: lok+=1\n    R.append(\"INV-009:PASS:\"+str(lok)+\"/3\" if lok==3 else \"INV-009:FAIL:\"+str(lok)+\"/3\")\nexcept Exception as e: R.append(\"INV-009:FAIL:\"+str(e))\nprint(\"\\n\".join(R))' 2>/dev/null"
    let mut batch_result = ""
    try { batch_result = to_string(exec(batch_py_cmd)).trim() } catch e { batch_result = "" }

    // 배치 결과 파싱
    let batch_lines = batch_result.split("\n")
    for line in batch_lines {
        let l = line.trim()
        if l == "" { continue }

        // INV-001
        if l.contains("INV-001:PASS") {
            pass = pass + 1
            println("  ✅ INV-001: n6_constants.jsonl 7개 기본상수 존재")
        } else if l.contains("INV-001:FAIL") {
            fail = fail + 1
            println("  ❌ INV-001: n6_constants.jsonl — " + l.split("INV-001:")[1])
        }

        // INV-002
        if l.contains("INV-002:PASS") {
            pass = pass + 1
            println("  ✅ INV-002: discovery_graph.json 스키마 유효 (" + l.split("PASS:")[1] + ")")
        } else if l.contains("INV-002:FAIL") {
            fail = fail + 1
            println("  ❌ INV-002: discovery_graph.json — " + l.split("INV-002:")[1])
        }

        // INV-003
        if l.contains("INV-003:PASS") {
            pass = pass + 1
            println("  ✅ INV-003: core-lockdown.json 스키마 유효")
        } else if l.contains("INV-003:FAIL") {
            fail = fail + 1
            println("  ❌ INV-003: core-lockdown.json — " + l.split("INV-003:")[1])
        }

        // INV-004
        if l.contains("INV-004:PASS") {
            pass = pass + 1
            println("  ✅ INV-004: absolute_rules.json 구조 유효 (" + l.split("PASS:")[1] + ")")
        } else if l.contains("INV-004:FAIL") {
            fail = fail + 1
            println("  ❌ INV-004: absolute_rules.json — " + l.split("INV-004:")[1])
        }

        // INV-005
        if l.contains("INV-005:PASS") {
            pass = pass + 1
            println("  ✅ INV-005: core.json 구조 유효 (" + l.split("PASS:")[1] + ")")
        } else if l.contains("INV-005:FAIL") {
            fail = fail + 1
            println("  ❌ INV-005: core.json — " + l.split("INV-005:")[1])
        }

        // INV-006
        if l.contains("INV-006:PASS") {
            pass = pass + 1
            println("  ✅ INV-006: convergence/ 7개 프로젝트 유효 (" + l.split("PASS:")[1] + ")")
        } else if l.contains("INV-006:FAIL") {
            fail = fail + 1
            println("  ❌ INV-006: convergence/ — " + l.split("INV-006:")[1])
        }

        // INV-007
        if l.contains("INV-007:PASS") {
            pass = pass + 1
            println("  ✅ INV-007: todo/ 7개 프로젝트 유효 (" + l.split("PASS:")[1] + ")")
        } else if l.contains("INV-007:FAIL") {
            fail = fail + 1
            println("  ❌ INV-007: todo/ — " + l.split("INV-007:")[1])
        }

        // INV-009
        if l.contains("INV-009:PASS") {
            pass = pass + 1
            println("  ✅ INV-009: loop/ 3개 성장 루프 유효 (" + l.split("PASS:")[1] + ")")
        } else if l.contains("INV-009:FAIL") {
            fail = fail + 1
            println("  ❌ INV-009: loop/ — " + l.split("INV-009:")[1])
        }
    }

    // ─── Batch 2: INV-008 + INV-008b 단일 exec (구분자로 합침) ───
    let inv8_cmd = "awk 'match($0,/\\[([0-9]+)([*!?]*)\\]/,a){g=a[1]; if(a[2]~/\\*/) ex++; n++} END{pct=n?ex/n*100:0; if(n>=100&&pct>=80) printf \"PASS:%dnodes/%.1f%%EXACT\",n,pct; else printf \"FAIL:n=%d,exact=%.1f%%\",n,pct}' " + _shared + "/n6/atlas.n6 2>/dev/null"
    let inv8b_cmd = _shared + "/bin/hexa " + _shared + "/n6/verify_formulas.hexa " + _shared + "/n6/atlas.n6 2>/dev/null | awk '/^errors:/{print \"PASS:\"$2\"err\" ; if($2>0) {gsub(\"PASS:\",\"FAIL:\")}}' | tail -1"
    // 두 명령을 구분자로 합쳐 1회 exec
    let parallel_cmd = "{ " + inv8_cmd + " ; echo '|||' ; " + inv8b_cmd + " ; }"
    let mut parallel_result = ""
    try { parallel_result = to_string(exec(parallel_cmd)).trim() } catch e { parallel_result = "|||" }
    let par_parts = parallel_result.split("|||")

    let mut inv8 = ""
    let mut inv8b = ""
    if par_parts.len() >= 1 { inv8 = par_parts[0].trim() }
    if par_parts.len() >= 2 { inv8b = par_parts[1].trim() }

    // INV-008: atlas.n6 — 등급 항목 100+ + EXACT([10*]) 비율 80%+
    if inv8.contains("PASS") {
        pass = pass + 1
        println("  ✅ INV-008: atlas.n6 유효 (" + inv8.split("PASS:")[1] + ")")
    } else {
        fail = fail + 1
        println("  ❌ INV-008: atlas.n6 — " + inv8)
    }

    // INV-008b: atlas.n6 — n6_expr 수식 산술 정확성 (verify_formulas 위임)
    if inv8b.contains("PASS:0err") {
        pass = pass + 1
        println("  ✅ INV-008b: atlas.n6 수식 산술 정확 (0 errors)")
    } else {
        fail = fail + 1
        println("  ❌ INV-008b: atlas.n6 수식 산술 — " + inv8b)
    }

    println("")
    let total = pass + fail
    if fail == 0 {
        println("✅ 전체 통과: " + to_string(pass) + "/" + to_string(total))
    } else {
        println("❌ 실패 있음: " + to_string(pass) + "/" + to_string(total) + " (" + to_string(fail) + "건 실패)")
    }
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

let _args = args()
let _cmd = if _args.len() >= 3 { _args[2] } else { "help" }

if _cmd == "check" {
    let file = if _args.len() >= 4 { _args[3] } else { "" }
    if file == "" {
        println("사용: hexa guard.hexa check <file_path>")
    } else {
        cmd_check(file)
    }
} else if _cmd == "checklist" {
    cmd_checklist()
} else if _cmd == "recurrence" {
    let cat = if _args.len() >= 4 { _args[3] } else { "" }
    let proj = if _args.len() >= 5 { _args[4] } else { "nexus" }
    if cat == "" {
        println("사용: hexa guard.hexa recurrence <category> [project]")
    } else {
        cmd_recurrence(cat, proj)
    }
} else if _cmd == "root-cause" {
    cmd_root_cause()
} else if _cmd == "verify" {
    cmd_verify()
} else {
    println("guard.hexa — L0/수렴 강제 가드")
    println("")
    println("사용법:")
    println("  hexa guard.hexa check <file>        — L0 수정 감지 + 승인 요청")
    println("  hexa guard.hexa checklist            — 커밋 전 체크리스트")
    println("  hexa guard.hexa recurrence <cat> [proj] — 반복 카운터 +1")
    println("  hexa guard.hexa root-cause           — 근본원인 코드 수정 확인")
    println("  hexa guard.hexa verify               — L0 불변식 계약 테스트 (9건)")
}
