// absolute-rules-loader.hexa — PreToolUse:Write|Edit hook
// 기존 python 인라인 대체: absolute_rules.json에서 고위험 규칙 추출 → systemMessage

fn main() {
    let rules_file = env("HOME") + "/Dev/nexus/shared/config/absolute_rules.json"
    if file_exists(rules_file) == false { return }

    let content = read_file(rules_file)

    // 고위험 레벨 규칙 추출 (🔴, ⛔, ★)
    let lines = content.split("\n")
    let mut rules = []
    let mut i = 0
    let mut current_id = ""
    let mut current_rule = ""
    let mut current_level = ""

    while i < len(lines) {
        let line = lines[i].trim()

        if line.contains("\"id\"") {
            let parts = line.split("\"")
            if parts.len() >= 4 {
                current_id = parts[3]
            }
        }

        if line.contains("\"level\"") {
            let parts = line.split("\"")
            if parts.len() >= 4 {
                current_level = parts[3]
            }
        }

        if line.contains("\"rule\"") {
            let parts = line.split("\"rule\"")
            if parts.len() >= 2 {
                let after = parts[1].trim()
                if after.starts_with(":") {
                    let val = after.split("\"")
                    if val.len() >= 2 {
                        current_rule = val[1]
                    }
                }
            }
        }

        // 객체 끝 감지
        if line.contains("}") {
            if current_level.contains("🔴") || current_level.contains("⛔") || current_level.contains("★") {
                if current_id != "" {
                    rules = rules.push(current_id + ": " + current_rule)
                }
            }
            if current_level != "" {
                current_id = ""
                current_rule = ""
                current_level = ""
            }
        }

        i = i + 1
    }

    if len(rules) == 0 { return }

    // 최대 8건
    let mut out = []
    let mut j = 0
    while j < len(rules) {
        if j >= 8 { break }
        // JSON escape: backslash 먼저, 그 다음 double-quote (순서 중요)
        let r = rules[j]
        let safe = r.replace("\\", "\\\\").replace("\"", "'")
        out = out.push(safe)
        j = j + 1
    }

    let msg = "[절대규칙] " + join(out, " | ")
    println("{\"systemMessage\":\"" + msg + "\"}")
}

main()
