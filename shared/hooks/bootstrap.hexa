// bootstrap.hexa — 화이트리스트 체크 + 심링크 자동 생성 + 깨진 링크 복구
// bootstrap.sh 대체. 다른 .hexa 훅에서 exec()로 호출 가능.
// 성공 시 stdout 없이 exit(0), 스킵 시 exit(1)

let HOME = env("HOME")
let HOOK_DIR = HOME + "/Dev/nexus/shared/hooks"
let CONFIG = HOOK_DIR + "/hooks-config.json"

// 1. 현재 리포 확인
let repo_root = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
if len(repo_root) == 0 { exit(1) }
let repo_name = exec("basename '" + repo_root + "'").trim()

// 2. 화이트리스트 체크
fn parse_whitelist(raw: str) -> list {
    let mut projects = []
    if raw.contains("\"whitelisted_projects\"") == false { return projects }
    let after = raw.split("\"whitelisted_projects\"")[1]
    let arr = after.split("[")[1].split("]")[0]
    let items = arr.split(",")
    for item in items {
        let clean = item.trim().replace("\"", "").replace("\n", "")
        if len(clean) > 0 { projects = projects + [clean] }
    }
    projects
}

let config_raw = try { read_file(CONFIG) } catch e { exit(1) }
let projects = parse_whitelist(config_raw)

let mut found = false
for p in projects {
    if p == repo_name { found = true }
}
if found == false { exit(1) }

// 3. .shared 심링크 자동 생성
if repo_name != "nexus" {
    let shared = repo_root + "/.shared"
    let exists = exec("test -e '" + shared + "' && echo y || echo n").trim()
    if exists == "n" {
        let mut link_to = "../nexus/shared"
        if repo_name != "TECS-L" && repo_name != "fathom" {
            let tecs = repo_root + "/../TECS-L/.shared"
            let tecs_ok = exec("test -e '" + tecs + "' && echo y || echo n").trim()
            if tecs_ok == "y" { link_to = "../TECS-L/.shared" }
        }
        exec("ln -s '" + link_to + "' '" + shared + "' 2>/dev/null")
        println("{\"systemMessage\":\"" + repo_name + "/.shared -> " + link_to + " 심링크 자동 생성\"}")
    }

    // 4. 깨진 심링크 복구
    let is_link = exec("test -L '" + shared + "' && echo y || echo n").trim()
    let is_valid = exec("test -e '" + shared + "' && echo y || echo n").trim()
    if is_link == "y" && is_valid == "n" {
        exec("rm '" + shared + "' 2>/dev/null")
        exec("ln -s '../nexus/shared' '" + shared + "' 2>/dev/null")
        println("{\"systemMessage\":\"" + repo_name + "/.shared 깨진 심링크 복구\"}")
    }
}
