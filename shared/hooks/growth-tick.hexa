// growth-tick.hexa — 활동 1건 = 성장 +1 (growth-tick.sh 대체)
// 쿨다운 5초 (같은 훅 연타 방지). 모든 출력 억제.

let HOME = env("HOME")
let HEXA = HOME + "/Dev/hexa-lang/target/release/hexa-bin-actual"

let a = args()
let mode = if a.len() >= 3 { a[2] } else { "unknown" }

// 디버그 로그
let ts = exec("date +%Y-%m-%dT%H:%M:%S").trim()
try { append_file("/tmp/nexus_growth_debug.log", ts + " growth-tick called: " + mode + "\n") } catch e {}

// 쿨다운 체크
let tick_file = "/tmp/nexus_growth_tick"
let now = exec("date +%s").trim()
let last = exec("cat " + tick_file + " 2>/dev/null || echo 0").trim()
let diff = to_int(to_float(now)) - to_int(to_float(last))
if diff < 5 { return }

try { write_file(tick_file, now) } catch e {}

// bridge notify — 순수 hexa (python3 제거)
let growth_bus = HOME + "/Dev/nexus/shared/growth_bus.jsonl"
if file_exists(growth_bus) {
    let project = to_string(exec("basename $(git rev-parse --show-toplevel 2>/dev/null || pwd) || echo ''")).trim()
    let tick_ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
    try { append_file(growth_bus, "{\"ts\":\"" + tick_ts + "\",\"domain\":\"" + project + "\",\"type\":\"tick\",\"mode\":\"" + mode + "\"}\n") } catch e {}
}

// growth_state.json 직접 업데이트 — hexa 엔진
let growth_json = HOME + "/Dev/anima/anima/config/growth_state.json"
if file_exists(growth_json) == false { return }

let hexa_growth_tick = HOME + "/Dev/nexus/mk2_hexa/native/growth_tick.hexa"
if file_exists(hexa_growth_tick) {
    try { exec(HEXA + " " + hexa_growth_tick + " " + mode + " " + growth_json + " 2>/dev/null") } catch e {}
}
