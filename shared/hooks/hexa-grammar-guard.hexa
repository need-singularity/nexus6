// hexa-grammar-guard.hexa — PostToolUse:Bash hook
// 기존 bash 인라인 대체: hexa 실행 결과에서 문법 오류 감지 → autofix 유도

fn main() {
    let output = read_stdin()

    // hexa 에러 패턴 감지
    let has_error = output.contains("error[Syntax]") || output.contains("error[Type]") || output.contains("error[Parse]") || output.contains("문법")
    if has_error == false { return }

    // 파일:줄번호 추출
    let lines = output.split("\n")
    let mut file = ""
    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        if line.contains(".hexa:") {
            let parts = line.split(" ")
            let mut j = 0
            while j < len(parts) {
                if parts[j].contains(".hexa:") {
                    file = parts[j]
                    break
                }
                j = j + 1
            }
            if file != "" { break }
        }
        i = i + 1
    }

    // 에러 라인 추출
    let mut err = ""
    i = 0
    while i < len(lines) {
        if lines[i].contains("error[") {
            err = lines[i].trim()
            break
        }
        i = i + 1
    }

    // 문법 ID 분류
    let mut gid = "?"
    if err.contains("Semicolon") { gid = "G6" }
    if err.contains("-> (") || err.contains("RParen") { gid = "G1" }
    if err.contains("block comment") || err.contains("/*") { gid = "G3" }
    if err.contains(": [") || err.contains("expected identifier") { gid = "G2" }
    if err.contains("Struct{}") || err.contains("struct literal") { gid = "G5" }
    if err.contains("builtin") || err.contains("did you mean") { gid = "G7" }

    let safe_err = err.replace("\"", "'")
    let safe_file = file.replace("\"", "'")

    let msg = "⚠️ hexa 문법 오류 " + gid + " 감지. 에러: " + safe_err + " 파일: " + safe_file + " — 참조: shared/hexa-grammar/ (autofix.json+issues.jsonl+convergence.json). 해당 파일 직접 수정 후 재실행. 멈추지 말고 계속 진행."
    println("{\"systemMessage\":\"" + msg + "\"}")
}

main()
