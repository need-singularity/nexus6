// ⛔ L0 물리 차단 — PreToolUse Write|Edit 훅
// core-lockdown.json의 L0 파일에 대해 {"result":"deny"} 반환 → 도구 실행 자체 차단
// 우회 불가: CORE_GUARD_SKIP=1 환경변수 설정 시에만 통과 (유저가 직접 ! export)
// 사용: settings.json PreToolUse Write|Edit 훅으로 등록

let _home = to_string(exec("printenv HOME")).trim()
let _lockdown = _home + "/Dev/nexus/shared/config/core-lockdown.json"

// 환경변수 우회 체크 (유저가 명시적으로 ! export CORE_GUARD_SKIP=1 한 경우만)
let mut skip = ""
try { skip = to_string(exec("printenv CORE_GUARD_SKIP 2>/dev/null")).trim() } catch e {}
if skip == "1" { return }

// stdin에서 file_path 추출
let stdin_data = read_stdin()

fn extract_path(json_text: string) -> string {
    // tool_input.file_path 추출
    if json_text.contains("file_path") == false { return "" }
    let parts = json_text.split("file_path")
    if parts.len() < 2 { return "" }
    let after = parts[1]
    // "file_path":"..." 또는 "file_path": "..." 패턴
    let mut in_quote = false
    let mut result = ""
    let mut started = false
    let chars = after.split("")
    for c in chars {
        if c == "\"" {
            if started { return result }
            if in_quote == false {
                in_quote = true
                started = true
            }
        } else if started {
            result = result + c
        }
    }
    return result
}

let file_path = extract_path(stdin_data)
if file_path == "" { return }

// L0 파일인지 확인
let mut is_l0 = false
try {
    let check = to_string(exec("/usr/bin/python3 -c 'import json,sys; d=json.load(open(sys.argv[1])); paths=[f[\"path\"] for p in d.get(\"projects\",{}).values() for f in p.get(\"L0\",[])] + [f[\"path\"] for f in d.get(\"L0\",[])] ; fp=sys.argv[2]; print(\"YES\" if any(fp.endswith(p) or p in fp for p in paths) else \"NO\")' " + _lockdown + " '" + file_path + "' 2>/dev/null")).trim()
    if check == "YES" { is_l0 = true }
} catch e {}

if is_l0 {
    // 물리적 차단 — deny 반환
    println("{\"result\":\"deny\",\"reason\":\"⛔ L0 코어 보호: " + file_path + " — 수정 불가. 우회: ! export CORE_GUARD_SKIP=1\"}")
}
