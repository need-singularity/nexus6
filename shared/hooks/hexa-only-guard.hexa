// hexa-only-guard.hexa — PreToolUse:Write|Edit hook
// .py/.rs/.sh/.js/.ts 파일 생성/편집 감지 → hexa-only + AI-native 유도
// 예외: 기존 파일 수정(포팅 중), Cargo.toml, build.rs 등 빌드 필수 파일

let HEXA_BIN = env("HOME") + "/Dev/hexa-lang/target/release/hexa-bin-actual"

// AI-native attr 매핑: 언어별 패턴 → hexa @attr 대안
fn ai_native_hint(ext: str) -> str {
    if ext == "py" {
        return "@memoize(캐싱), @optimize(알고리즘 교체), @parallel(GIL 없는 병렬), @symbolic(sympy→내장), @approximate(numpy→내장 tensor)"
    }
    if ext == "rs" {
        return "@inline/@hot(LLVM 힌트 불필요), @memoize(HashMap 보일러플레이트 제거), @simd(intrinsics→자동), @bounded(언롤링)"
    }
    if ext == "sh" {
        return "@parallel(xargs/GNU parallel→내장), exec()(외부 명령), file_exists/read_file/write_file(내장 I/O)"
    }
    if ext == "js" {
        return "@memoize(수동 캐시 제거), @lazy(지연 평가), @pure(부작용 검증), @contract(타입 안전)"
    }
    if ext == "ts" {
        return "@contract(타입 런타임 검증), @specialize(제네릭 특화), @memoize(자동 캐싱)"
    }
    return ""
}

fn blocked_ext(path: str) -> str {
    let exts = [".py", ".rs", ".sh", ".js", ".ts", ".rb", ".go", ".java", ".c", ".cpp"]
    let mut i = 0
    while i < len(exts) {
        if path.ends_with(exts[i]) {
            return exts[i].split(".")[1]
        }
        i = i + 1
    }
    return ""
}

fn is_exception(path: str) -> bool {
    // 빌드 필수 파일
    if path.ends_with("build.rs") { return true }
    if path.ends_with("Cargo.toml") { return true }
    if path.ends_with("Cargo.lock") { return true }
    // hexa-lang 자체 src/ (Rust 구현체)
    if path.contains("/hexa-lang/src/") { return true }
    // 기존 .growth/ 스캐너 (레거시 허용)
    if path.contains("/.growth/") { return true }
    // hook 자체
    if path.contains("/hooks/") { return true }
    // .hexanoport 마커 붙은 파일은 포팅 불가 표시 → 편집 허용
    let noport = path + ".hexanoport"
    let check = exec("test -f " + noport + " && echo y || echo n").trim()
    if check == "y" { return true }
    return false
}

fn json_field_simple(text: str, field: str) -> str {
    let key = "\"" + field + "\""
    if text.contains(key) == false { return "" }
    let parts = text.split(key)
    if parts.len() < 2 { return "" }
    let after = parts[1].trim()
    if after.starts_with(":") == false { return "" }
    let val_part = after.split(":")[1].trim()
    if val_part.starts_with("\"") {
        let inner = val_part.split("\"")
        if inner.len() >= 2 { return inner[1] }
    }
    return ""
}

fn main() {
    let stdin_data = read_stdin()
    let file_path = json_field_simple(stdin_data, "file_path")
    if len(file_path) == 0 { return }

    if is_exception(file_path) { return }

    let ext = blocked_ext(file_path)
    if ext == "" { return }

    let hint = ai_native_hint(ext)
    let hexa_path = file_path.split(".")[0] + ".hexa"

    let msg = "🚫 hexa-only: ." + ext + " 파일 생성/편집 감지 → .hexa로 작성할 것. "
    let msg2 = "대상: " + hexa_path + " | AI-native 대안: " + hint + " | "
    let msg3 = "규칙: 모든 새 코드는 hexa-only. @attr AI-native 알고리즘 적극 활용. Python/Rust/Shell 의존 0 목표."

    println("{\"decision\":\"block\",\"reason\":\"" + msg + msg2 + msg3 + "\"}")
}

main()
