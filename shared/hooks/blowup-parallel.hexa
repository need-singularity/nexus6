// blowup-parallel.hexa — "돌파" 감지 → 전 도메인 병렬 백그라운드 강제
// UserPromptSubmit hook
// 사용자가 "돌파", "모두 돌파", "math 돌파" 등 입력 시
// Claude에게 전 도메인 병렬 백그라운드 실행을 강제 지시

let stdin_data = read_stdin()

fn json_field(json_text: str, field: str) -> str {
    let key = "\"" + field + "\""
    if json_text.contains(key) == false { return "" }
    let parts = json_text.split(key)
    if parts.len() < 2 { return "" }
    let after = parts[1].trim()
    if after.starts_with(":") == false { return "" }
    let val_part = after.split(":")[1].trim()
    if val_part.starts_with("\"") {
        let inner = val_part.split("\"")
        if inner.len() >= 2 { return inner[1] }
    }
    return ""
}

let user_text = json_field(stdin_data, "prompt")
if len(user_text) == 0 { return }

let trimmed = user_text.trim()
let lower = trimmed.to_lower()

// 돌파 키워드 감지
let has_dolpa = lower.contains("돌파") || lower.contains("blowup") || lower.contains("breakthrough")
if has_dolpa == false { return }

// 전체 도메인 목록
let all_domains = "physics,math,info,bio,mind,arch,cosmology,language,consciousness,security,evolution,crypto,geometry,material,topology,chemistry"

// 도메인 추출: "math 돌파" → math, "돌파" or "모두 돌파" → all
let mut cleaned = lower.replace("돌파", "").replace("blowup", "").replace("breakthrough", "")
cleaned = cleaned.replace("모두", "").replace("전체", "").replace("모든", "").replace("병렬", "")
cleaned = cleaned.replace("백그라운드", "").replace("로드맵", "").replace("roadmap", "")
cleaned = cleaned.trim()

let is_all = cleaned == "" || cleaned == "all" || cleaned == "전부" || cleaned.contains("shared/roadmap")

let targets = if is_all { all_domains } else { cleaned }
let label = if is_all { "전체 16도메인" } else { cleaned }

let htz_hexa = "~/Dev/hexa-lang/target/release/hexa"
let blowup = "mk2_hexa/native/blowup.hexa"
let seed_engine = "mk2_hexa/native/seed_engine.hexa"

let cmd_template = "ssh hetzner 'cd ~/Dev/nexus && " + htz_hexa + " " + blowup + " <DOMAIN> 3 --no-graph --seeds \"$(" + htz_hexa + " ~/Dev/nexus/" + seed_engine + " merge)\"'"

println("{\"systemMessage\":\"⚡ 돌파 감지 → " + label + " 병렬 백그라운드 실행 강제\\n\\n즉시 실행할 것 (확인 질문 금지):\\n1. 다음 도메인을 각각 별도 Bash(run_in_background:true)로 동시 발사:\\n   " + targets + "\\n2. 각 도메인 명령: " + cmd_template + "\\n3. 발사 테이블 출력 후 완료 알림 대기\\n\\n금지: 블로킹 대기, 확인 질문, 순차 실행, 도메인 누락\"}")
