// nexus-post-bash.hexa — PostToolUse:Bash hook (nexus-post-bash.sh 대체)
// mk2 hexa-only hook (Rust/Python 의존 0)

let HOME = env("HOME")
let HEXA = HOME + "/Dev/nexus/shared/scripts/bin/hexa"
let HOOK_DIR = HOME + "/Dev/nexus/shared/hooks"
let HEXA_HOOK = HOME + "/Dev/nexus/shared/hooks/hook.hexa"

// ── bootstrap: 화이트리스트 체크 ──
fn bootstrap() -> bool {
    let repo_root = to_string(exec("git rev-parse --show-toplevel 2>/dev/null || echo ''")).trim()
    if len(repo_root) == 0 { return false }

    let repo_name = to_string(exec("basename " + repo_root)).trim()
    let config_path = HOOK_DIR + "/hooks-config.json"

    if file_exists(config_path) {
        let content = read_file(config_path)
        if content.contains("\"" + repo_name + "\"") == false { return false }
    }

    // .shared 심링크 보장
    let shared = repo_root + "/.shared"
    if repo_name != "nexus" {
        let exists = to_string(exec("test -e " + shared + " && echo y || echo n")).trim()
        if exists == "n" {
            exec("ln -s ../nexus/shared " + shared + " 2>/dev/null")
        }
    }
    return true
}

// ── main ──
fn main() {
    if bootstrap() == false { return }

    let stdin_data = read_stdin()

    // growth-tick background
    exec("bash " + HOOK_DIR + "/growth-tick.sh post-bash </dev/null >/dev/null 2>&1 &")

    // hook.hexa에 stdin 전달
    let tmp = "/tmp/.nexus-stdin-" + to_string(exec("echo $$")).trim()
    try { write_file(tmp, stdin_data) } catch e { return }

    // hook.hexa post-bash: 서버 자원 확인 후 여유 있는 쪽으로 라우팅 (Mac CPU 보호)
    // 서버 목록 — 확장 시 3개 배열에 동일 인덱스로 추가
    let srv_alias = ["hetzner", "ubu"]
    let srv_hexa  = ["/root/Dev/hexa-lang/target/release/hexa", "/home/aiden/Dev/hexa-lang/target/release/hexa"]
    let srv_hook  = ["/root/Dev/nexus/shared/hooks/hook.hexa", "/home/aiden/Dev/nexus/shared/hooks/hook.hexa"]

    // 각 서버 load average 수집 (ConnectTimeout=2 → 빠른 판단)
    let mut best_alias = ""
    let mut best_load = 999.0
    let mut best_idx = 0
    let mut si = 0
    while si < srv_alias.len() {
        let alias = srv_alias[si]
        let mut load_val = 999.0
        try {
            let load_s = to_string(exec("ssh -o ConnectTimeout=2 -o BatchMode=yes " + alias + " \"awk '{print \\$1}' /proc/loadavg\" 2>/dev/null")).trim()
            if len(load_s) > 0 { load_val = to_float(load_s) }
        } catch e {}
        if load_val < best_load {
            best_load = load_val
            best_alias = alias
            best_idx = si
        }
        si = si + 1
    }

    let remote_tmp = "/tmp/.nexus-stdin-remote"
    let mut result = ""

    // 최적 서버로 라우팅
    if best_alias != "" && best_load < 900.0 {
        try {
            exec("scp -q " + tmp + " " + best_alias + ":" + remote_tmp + " 2>/dev/null")
            result = to_string(exec("ssh -o ConnectTimeout=3 -o BatchMode=yes " + best_alias + " 'cat " + remote_tmp + " | " + srv_hexa[best_idx] + " " + srv_hook[best_idx] + " post-bash 2>/dev/null' 2>/dev/null")).trim()
        } catch e { result = "" }
    }

    // 모든 서버 실패 시 로컬 폴백 (타임아웃 5초)
    if len(result) == 0 {
        try {
            result = to_string(exec("cat " + tmp + " | " + HEXA + " " + HEXA_HOOK + " post-bash 2>/dev/null")).trim()
        } catch e2 { result = "" }
    }
    exec("rm -f " + tmp + " 2>/dev/null")

    if len(result) > 0 {
        println(result)
    } else {
        // fallback: banner
        let banner = to_string(exec(HEXA + " " + HOOK_DIR + "/nexus-banner.hexa 2>/dev/null")).trim()
        if len(banner) > 0 { println(banner) }
    }
}

main()
