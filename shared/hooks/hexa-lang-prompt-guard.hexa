// hexa-lang-prompt-guard.hexa — UserPromptSubmit hook (hexa-lang 프로젝트 전용)
// 기존 bash 인라인 2건 통합: 돌파 감지 + 한도 차단

fn main() {
    let stdin_data = read_stdin()

    // JSON에서 prompt 추출 (간이)
    if stdin_data.contains("\"prompt\"") == false { return }
    let parts = stdin_data.split("\"prompt\"")
    if parts.len() < 2 { return }
    let after = parts[1].trim()
    if after.starts_with(":") == false { return }
    let val = after.split(":")[1].trim()
    if val.starts_with("\"") == false { return }
    let inner = val.split("\"")
    if inner.len() < 2 { return }
    let prompt = inner[1]

    // ── 1. 돌파 감지 ──
    if prompt.contains("돌파") || prompt.contains("blowup") || prompt.contains("breakthrough") {
        let msg = "⚡ 돌파 감지 → 전체 16도메인 병렬 백그라운드 실행 강제. "
        let msg2 = "즉시 실행: 각 도메인을 별도 Bash(run_in_background:true)로 동시 발사. "
        let msg3 = "도메인: physics,math,info,bio,mind,arch,cosmology,language,consciousness,security,evolution,crypto,geometry,material,topology,chemistry. "
        let msg4 = "명령: ssh hetzner cd ~/Dev/nexus && ~/Dev/hexa-lang/target/release/hexa mk2_hexa/native/blowup.hexa <domain> 3 --no-graph --seeds <seeds>. "
        let msg5 = "금지: 블로킹 대기, 확인 질문, 순차 실행"
        println("{\"systemMessage\":\"" + msg + msg2 + msg3 + msg4 + msg5 + "\"}")
    }

    // ── 2. 한도 언급 차단 ──
    let p = prompt.to_lower()
    if p.contains("한도") || p.contains("limit") || p.contains("resets") || p.contains("extra-usage") || p.contains("hit your limit") || p.contains("사용량") {
        let msg = "🚫 한도 언급 차단: 새 계정으로 이미 해결됨. 한도/limit/resets/사용량 관련 답변·질문·확인 일체 금지. 바로 다음 액션 실행."
        println("{\"systemMessage\":\"" + msg + "\"}")
    }
}

main()
