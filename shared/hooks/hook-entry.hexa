// hook-entry.hexa — Claude Code 훅 진입점 (hook-entry.sh 대체)
// 사용: hexa hook-entry.hexa <mode> <target.hexa> [args...]
// mode: prompt | post | pretool | session

let HOME = env("HOME")
let HOOK_DIR = HOME + "/Dev/nexus/shared/hooks"

fn json_escape(s: string) -> string {
    s.replace("\\", "\\\\").replace("\"", "\\\"")
}

fn emit_block(msg: string) {
    println("{\"decision\":\"block\",\"reason\":\"" + json_escape(msg) + "\"}")
}

fn emit_message(msg: string) {
    println("{\"systemMessage\":\"" + json_escape(msg) + "\"}")
}

fn find_hexa() -> string {
    let candidates = [
        HOOK_DIR + "/../bin/hexa",
        HOME + "/Dev/hexa-lang/hexa",
        HOME + "/Dev/nexus/shared/scripts/bin/hexa",
        HOME + "/.hx/bin/hexa"
    ]
    for c in candidates {
        if file_exists(c) { return c }
    }
    ""
}

let a = args()
let mode = if a.len() >= 3 { a[2] } else { "" }
let target = if a.len() >= 4 { a[3] } else { "" }

if target == "" { return }

let hexa = find_hexa()
if hexa == "" {
    let base = target.split("/")
    let name = base[base.len() - 1]
    if mode == "pretool" {
        emit_block("hook resolver 없음: " + name)
    } else {
        emit_message("hook resolver 없음: " + name)
    }
    return
}

// stdin → tmp 파일 → hexa 실행
let tmp_in = "/tmp/.nexus-hook-in-" + to_string(exec("echo $$")).trim()
let stdin_data = read_stdin()
try { write_file(tmp_in, stdin_data) } catch e { return }

let mut extra_args = ""
let mut ai = 4
while ai < a.len() {
    if extra_args.len() > 0 { extra_args = extra_args + " " }
    extra_args = extra_args + a[ai]
    ai = ai + 1
}

let cmd = "cat " + tmp_in + " | " + hexa + " " + target + " " + extra_args + " 2>/tmp/.nexus-hook-err"
let mut result = ""
let mut status = 0

try {
    result = to_string(exec("bash", ["-c", cmd])).trim()
} catch e {
    status = 1
}

if status == 0 {
    if result.len() > 0 { println(result) }
} else {
    let mut err = ""
    try { err = read_file("/tmp/.nexus-hook-err").trim() } catch e {}
    if err.len() > 240 { err = err.split("")[0] + "..." }
    let base = target.split("/")
    let name = base[base.len() - 1]
    let msg = name + " exit=" + to_string(status) + " " + err
    if mode == "pretool" {
        emit_block("hook 실패: " + msg)
    } else {
        emit_message("hook 실패 감지: " + msg)
    }
}

try { exec("rm -f " + tmp_in + " /tmp/.nexus-hook-err") } catch e {}
