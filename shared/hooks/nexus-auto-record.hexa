// nexus-auto-record.hexa — EXACT 발견 시 자동 기록 (nexus-auto-record.sh 대체)
// 다른 훅에서 호출: hexa nexus-auto-record.hexa <value> <constant> <source>

let HOME = env("HOME")
let DISCOVERY_LOG = HOME + "/Dev/nexus/shared/discovery_log.jsonl"

let a = args()
if a.len() < 5 { return }

let value = a[2]
let constant = a[3]
let source = a[4]
let timestamp = exec("date '+%Y-%m-%d %H:%M:%S'").trim()

let entry = "{\"timestamp\":\"" + timestamp + "\",\"value\":\"" + value + "\",\"constant\":\"" + constant + "\",\"source\":\"" + source + "\",\"auto\":true}"
try { append_file(DISCOVERY_LOG, entry + "\n") } catch e {}
