// harness-gc-weekly.hexa — SessionStart 훅 shim
// 실제 대상: shared/harness/gc-weekly.hexa (7일 쿨다운 내장)
// 화이트리스트 체크 후 쿨다운 판정. 쿨다운 중이면 즉시 exit 0 (silent).
// 실행되어도 hook 출력은 무음 (JSON 스키마 따름).

let HOME = env("HOME")
let HEXA = HOME + "/Dev/nexus/shared/scripts/bin/hexa"
let GC_WEEKLY = HOME + "/Dev/nexus/shared/harness/gc-weekly.hexa"
let HOOK_DIR = HOME + "/Dev/nexus/shared/hooks"

// ── bootstrap: 화이트리스트 체크 ──
fn is_whitelisted() -> bool {
    let repo_root_raw = exec("git rev-parse --show-toplevel 2>/dev/null || echo ''")
    let repo_root = to_string(repo_root_raw).trim()
    if len(repo_root) == 0 { return false }
    let repo_name = to_string(exec("basename " + repo_root)).trim()
    let config_path = HOOK_DIR + "/hooks-config.json"
    if !file_exists(config_path) { return false }
    let content = read_file(config_path)
    return content.contains("\"" + repo_name + "\"")
}

if !is_whitelisted() { exit(0) }
if !file_exists(GC_WEEKLY) { exit(0) }
if !file_exists(HEXA) { exit(0) }

// 쿨다운 판정은 gc-weekly.hexa 내부에서. 비차단 (SessionStart 는 세션 시작 지연 금지).
// 백그라운드 fire-and-forget, 30s 내에 완료 (쿨다운 중이면 즉시 리턴)
try {
    exec("'" + HEXA + "' '" + GC_WEEKLY + "' >/dev/null 2>&1 &")
} catch e {}

exit(0)
