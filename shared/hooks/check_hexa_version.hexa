// hexa 바이너리 vs 소스 HEAD 비교 → 구버전이면 자동 빌드
// nexus Stop hook에서 호출 — 빌드 중이면 스킵

let home = to_string(exec("printenv HOME")).trim()
let hexa_bin = home + "/Dev/nexus/shared/scripts/bin/hexa"
let hexa_src = home + "/Dev/hexa-lang"
let lock_file = home + "/Dev/hexa-lang/.hexa_building"

// 바이너리 존재 확인
let bin_check = to_string(exec("test -f " + hexa_bin + " && echo yes || echo no")).trim()
if bin_check == "no" {
  print("[❌ hexa 바이너리 없음] 자동 빌드 시작...")
  exec("cd " + hexa_src + " && cargo build --release &")
} else {
  // 이미 빌드 중이면 스킵
  let building = to_string(exec("test -f " + lock_file + " && echo yes || echo no")).trim()
  if building == "yes" {
    // 빌드 프로세스가 실제로 살아있는지 확인
    let alive = to_string(exec("pgrep -f 'cargo build.*hexa-lang' > /dev/null 2>&1 && echo yes || echo no")).trim()
    if alive == "no" {
      // 프로세스 죽었으면 lock 제거
      exec("rm -f " + lock_file)
    } else {
      // 빌드 진행 중 — 조용히 스킵
    }
  } else {
    // 바이너리 mtime vs 소스 HEAD 비교
    let bin_time = to_string(exec("stat -f %m " + hexa_bin)).trim()
    let src_time = to_string(exec("git -C " + hexa_src + " log -1 --format=%ct")).trim()

    if bin_time != "" && src_time != "" {
      let bin_epoch = to_int(bin_time)
      let src_epoch = to_int(src_time)

      if src_epoch > bin_epoch {
        let bin_date = to_string(exec("date -r " + bin_time + " '+%m/%d %H:%M'")).trim()
        let src_date = to_string(exec("date -r " + src_time + " '+%m/%d %H:%M'")).trim()
        let src_msg = to_string(exec("git -C " + hexa_src + " log -1 --format=%s")).trim()
        print("[⚠️ hexa 구버전] " + bin_date + " → " + src_date + " (" + src_msg + ")")
        print("[🔨 자동 빌드 시작] cargo build --release (백그라운드)")
        // lock 생성 + 백그라운드 빌드 + 완료 시 lock 제거
        exec("touch " + lock_file + " && (cd " + hexa_src + " && cargo build --release && touch " + hexa_bin + " && rm -f " + lock_file + " && echo '[✅ hexa 빌드 완료]' >> /tmp/hexa_build.log) &")
      }
    }
  }
}
