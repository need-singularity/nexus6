// nexus-banner.hexa — NEXUS-6 상태 배너 (nexus-banner.sh 대체)
// hook 출력: {"systemMessage":"🔭 NEXUS-6 mk2 ..."}

let HOME = env("HOME")
let HEXA = HOME + "/Dev/nexus/shared/scripts/bin/hexa"
let BANNER_HEXA = HOME + "/Dev/nexus/mk2_hexa/native/banner.hexa"
let HOOK_DIR = HOME + "/Dev/nexus/shared/hooks"

// ── 1. bootstrap: 화이트리스트 체크 ──
fn bootstrap() -> bool {
    let repo_root_raw = exec("git rev-parse --show-toplevel 2>/dev/null || echo ''")
    let repo_root = to_string(repo_root_raw).trim()
    if len(repo_root) == 0 { return false }

    let repo_name = to_string(exec("basename " + repo_root)).trim()
    let config_path = HOOK_DIR + "/hooks-config.json"

    if file_exists(config_path) {
        let content = read_file(config_path)
        if content.contains("\"" + repo_name + "\"") == false { return false }
    }

    // .shared 심링크 보장
    let shared = repo_root + "/.shared"
    if repo_name != "nexus" {
        let exists = to_string(exec("test -e " + shared + " && echo y || echo n")).trim()
        if exists == "n" {
            exec("ln -s ../nexus/shared " + shared + " 2>/dev/null")
        }
    }
    return true
}

// ── 2. bridge-ensure: 1세션 1회 연결 보장 (순수 hexa, /usr/bin/python3 불필요) ──
fn bridge_ensure() -> str {
    let bridge_state = HOME + "/Dev/nexus/shared/bridge_state.json"
    if file_exists(bridge_state) == false { return "" }

    let project = to_string(exec("basename $(git rev-parse --show-toplevel 2>/dev/null) 2>/dev/null || echo ''")).trim()
    if len(project) == 0 { return "" }

    let lockfile = "/tmp/nexus-bridge-ensured-" + project
    let lock_check = to_string(exec("test -f " + lockfile + " && echo y || echo n")).trim()
    if lock_check == "y" {
        let age = to_string(exec("echo $(( $(date +%s) - $(stat -f%m " + lockfile + " 2>/dev/null || echo 0) ))")).trim()
        try {
            if to_int(age) < 21600 { return "" }
        } catch e {}
    }

    exec("touch " + lockfile + " 2>/dev/null")

    // bridge_state에 프로젝트 등록 (순수 hexa)
    let content = read_file(bridge_state)
    if content.contains("\"" + project + "\"") == false {
        let ts = to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
        let entry = "{\"project\":\"" + project + "\",\"connected\":\"" + ts + "\"}"
        let updated = content.trim().replace("]", "," + entry + "]").replace("[,", "[")
        try { write_file(bridge_state, updated + "\n") } catch e {}
        return "bridge-connect: " + project
    }
    return ""
}

// ── 3. banner 출력 ──
fn banner() -> str {
    let hexa_dir = HOME + "/Dev/nexus/mk2_hexa/native"
    let mod_count = to_string(exec("ls " + hexa_dir + "/*.hexa 2>/dev/null | wc -l")).trim()

    if file_exists(BANNER_HEXA) {
        // timeout 3초 — banner.hexa hang 방지
        let result = to_string(exec("perl -e 'alarm 3; exec @ARGV' " + HEXA + " " + BANNER_HEXA + " --modules " + mod_count + " 2>/dev/null || echo ''")).trim()
        if len(result) > 0 { return result }
    }
    return "{\"systemMessage\":\"🔭 NEXUS-6 활성\"}"
}

// ── main ──
fn main() {
    if bootstrap() == false { return }
    bridge_ensure()
    println(banner())
}

main()
