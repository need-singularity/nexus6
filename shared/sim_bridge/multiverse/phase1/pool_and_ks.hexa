// sim_bridge/multiverse/phase1/pool_and_ks.hexa
//   Pool pairwise MI values across all N_trial trials (per source, per estimator)
//   and run a single large-sample KS test on the pooled distribution.
//
// Usage:
//   hexa pool_and_ks.hexa <anu_glob_prefix> <prng_glob_prefix> <suffix> <N_trial> <out_dir> <tag>
//   Reads <anu_glob_prefix><i><suffix> for i in 0..N_trial, same for prng.
//   Writes <out_dir>/<tag>_pooled.csv (anu_pool, prng_pool) and <out_dir>/<tag>_ks.json

fn abs_i(x: i64) -> i64 { if x < 0 { return 0 - x } return x }

fn isqrt(n: i64) -> i64 {
    if n <= 0 { return 0 }
    if n < 4 { return 1 }
    let mut x = n
    let mut y = (x + 1) / 2
    while y < x { x = y; y = (x + n / x) / 2 }
    return x
}

fn sort_asc(a: [i64]) -> [i64] {
    let mut arr = a
    let mut i = 1
    while i < arr.len() {
        let v = arr[i]
        let mut j = i - 1
        while j >= 0 && arr[j] > v { arr[j + 1] = arr[j]; j = j - 1 }
        arr[j + 1] = v
        i = i + 1
    }
    return arr
}

fn exp_neg_scaled(x_scaled: i64) -> i64 {
    if x_scaled <= 0 { return 1000 }
    if x_scaled >= 20000 { return 0 }
    let k = x_scaled / 1000
    let r = x_scaled - k * 1000
    let mut eneg_k: i64 = 1000
    let mut ik = 0
    while ik < k { eneg_k = eneg_k * 368 / 1000; if eneg_k <= 0 { return 0 } ik = ik + 1 }
    let r2 = r * r / 1000
    let r3 = r2 * r / 1000
    let r4 = r3 * r / 1000
    let mut eneg_r = 1000 - r + (r2 / 2) - (r3 / 6) + (r4 / 24)
    if eneg_r < 0 { eneg_r = 0 }
    if eneg_r > 1000 { eneg_r = 1000 }
    return eneg_k * eneg_r / 1000
}

fn ks_d(a: [i64], b: [i64]) -> i64 {
    let sa = sort_asc(a)
    let sb = sort_asc(b)
    let n = sa.len()
    let m = sb.len()
    if n == 0 || m == 0 { return 0 }
    let mut i = 0
    let mut j = 0
    let mut max_d: i64 = 0
    while i < n && j < m {
        let va = sa[i]
        let vb = sb[j]
        if va < vb { i = i + 1 } else if vb < va { j = j + 1 } else { i = i + 1; j = j + 1 }
        let diff = abs_i(i * m - j * n)
        let d_s = diff * 1000 / (n * m)
        if d_s > max_d { max_d = d_s }
    }
    while i < n {
        i = i + 1
        let diff = abs_i(i * m - j * n)
        let d_s = diff * 1000 / (n * m)
        if d_s > max_d { max_d = d_s }
    }
    while j < m {
        j = j + 1
        let diff = abs_i(i * m - j * n)
        let d_s = diff * 1000 / (n * m)
        if d_s > max_d { max_d = d_s }
    }
    return max_d
}

fn ks_pval(d_s: i64, n: i64, m: i64) -> [i64] {
    let nm_over = n * m * 1000 * 1000 / (n + m)
    let sqrt_term = isqrt(nm_over)
    let lambda_s = d_s * sqrt_term / 1000
    let mut p_s: i64 = 0
    let mut k: i64 = 1
    let mut sign: i64 = 1
    while k <= 10 {
        let lambda_sq = lambda_s * lambda_s / 1000
        let exponent = 2 * k * k * lambda_sq
        let term = exp_neg_scaled(exponent)
        p_s = p_s + sign * term
        sign = 0 - sign
        k = k + 1
    }
    p_s = 2 * p_s
    if p_s < 0 { p_s = 0 }
    if p_s > 1000 { p_s = 1000 }
    let mut out: [i64] = []
    out.push(d_s); out.push(lambda_s); out.push(p_s)
    return out
}

fn load_ints(path: string) -> [i64] {
    let mut raw = ""
    try { raw = read_file(path) } catch e { raw = "" }
    let lines = raw.split("\n")
    let mut v: [i64] = []
    let mut i = 0
    while i < lines.len() {
        let t = lines[i].trim()
        if t.len() > 0 {
            let mut x = 0
            try { x = to_int(t) } catch e { x = 0 }
            v.push(x)
        }
        i = i + 1
    }
    return v
}

// skew and mean/std in one pass
fn stats_full(arr: [i64]) -> [i64] {
    let n = arr.len()
    let mut s: i64 = 0
    let mut i = 0
    while i < n { s = s + arr[i]; i = i + 1 }
    let m = if n > 0 { s / n } else { 0 }
    let mut sq: i64 = 0
    let mut cube: i64 = 0
    let mut j = 0
    while j < n {
        let d = arr[j] - m
        sq = sq + d * d
        // skew numerator: Σ (d/1000)³ but scale: we want skew scaled*1000 = (sum d³ / n) / std³ * 1000
        // keep d³ in i64 (careful with overflow; d ≤ 200 typically, d³ ≤ 8e6, n ≤ 30000, total ≤ 2e11 — safe)
        cube = cube + d * d * d
        j = j + 1
    }
    let var = if n > 0 { sq / n } else { 0 }
    let mut sv = var; let mut sy = (sv + 1) / 2
    while sy < sv { sv = sy; sy = (sv + var / sv) / 2 }
    let std = sv
    // skew = (cube / n) / std³, scaled *1000
    let mut skew_scaled: i64 = 0
    if std > 0 && n > 0 {
        let std3 = std * std * std
        if std3 > 0 {
            skew_scaled = (cube / n) * 1000 / std3
        }
    }
    let mut mn: i64 = 999999999
    let mut mx: i64 = 0 - 999999999
    let mut k = 0
    while k < n {
        if arr[k] < mn { mn = arr[k] }
        if arr[k] > mx { mx = arr[k] }
        k = k + 1
    }
    let mut out: [i64] = []
    out.push(m); out.push(std); out.push(skew_scaled); out.push(mn); out.push(mx); out.push(n)
    return out
}

// --- main ---
let _args = args()
if _args.len() < 8 {
    println("usage: hexa pool_and_ks.hexa <anu_prefix> <prng_prefix> <suffix> <N_trial> <out_dir> <tag>")
} else {
    let anu_prefix = _args[2]
    let prng_prefix = _args[3]
    let suffix = _args[4]
    let mut N_trial = 20
    try { N_trial = to_int(_args[5]) } catch e { N_trial = 20 }
    let out_dir = _args[6]
    let tag = _args[7]

    let mut anu_pool: [i64] = []
    let mut prng_pool: [i64] = []
    let mut t = 0
    while t < N_trial {
        let a_path = anu_prefix + to_string(t) + suffix
        let p_path = prng_prefix + to_string(t) + suffix
        let a = load_ints(a_path)
        let b = load_ints(p_path)
        let mut i = 0
        while i < a.len() { anu_pool.push(a[i]); i = i + 1 }
        let mut j = 0
        while j < b.len() { prng_pool.push(b[j]); j = j + 1 }
        t = t + 1
    }
    println("[pool] anu_n=" + to_string(anu_pool.len()) + " prng_n=" + to_string(prng_pool.len()))

    if anu_pool.len() < 5 || prng_pool.len() < 5 {
        println("[pool] ERROR: pool too small")
    } else {
        let sa = stats_full(anu_pool)
        let sb = stats_full(prng_pool)
        let d_s = ks_d(anu_pool, prng_pool)
        let pv = ks_pval(d_s, anu_pool.len(), prng_pool.len())

        let js = "{\"tag\":\"" + tag + "\",\"anu_n\":" + to_string(sa[5]) + ",\"prng_n\":" + to_string(sb[5]) + ",\"anu_mean_scaled\":" + to_string(sa[0]) + ",\"anu_std_scaled\":" + to_string(sa[1]) + ",\"anu_skew_scaled\":" + to_string(sa[2]) + ",\"anu_min_scaled\":" + to_string(sa[3]) + ",\"anu_max_scaled\":" + to_string(sa[4]) + ",\"prng_mean_scaled\":" + to_string(sb[0]) + ",\"prng_std_scaled\":" + to_string(sb[1]) + ",\"prng_skew_scaled\":" + to_string(sb[2]) + ",\"prng_min_scaled\":" + to_string(sb[3]) + ",\"prng_max_scaled\":" + to_string(sb[4]) + ",\"D_scaled\":" + to_string(pv[0]) + ",\"lambda_scaled\":" + to_string(pv[1]) + ",\"p_scaled\":" + to_string(pv[2]) + ",\"scale\":1000}\n"
        let out_json = out_dir + "/" + tag + "_pooled_ks.json"
        try { write_file(out_json, js) } catch e {}

        // Also write distributions CSV for downstream plotting
        let mut csv_text = "source,value_scaled\n"
        let mut k = 0
        while k < anu_pool.len() { csv_text = csv_text + "anu," + to_string(anu_pool[k]) + "\n"; k = k + 1 }
        let mut kk = 0
        while kk < prng_pool.len() { csv_text = csv_text + "prng," + to_string(prng_pool[kk]) + "\n"; kk = kk + 1 }
        let out_csv = out_dir + "/" + tag + "_pooled_values.csv"
        try { write_file(out_csv, csv_text) } catch e {}

        println("[pool] " + tag + " D=" + to_string(pv[0]) + " lambda=" + to_string(pv[1]) + " p=" + to_string(pv[2]))
        println("[pool] wrote " + out_json)
    }
}
