// ═══════════════════════════════════════════════════════════
// hub_centrality_top100.hexa — Top-100 허브 중심성 정기 산출
// ATLAS-P2-2 통합 모듈: hub_centrality_analyzer + hub_resilience
//
// READ-ONLY. Does NOT modify atlas.n6 (L0 protected).
// Outputs two sidecars:
//   atlas.n6.hub_centrality_top100      — TSV (rank, id, degree, cb, bridges, resilience)
//   atlas.n6.hub_centrality_top100.json — JSON manifest with meta
//
// 통합 점수: centrality_score = w_deg*deg_n + w_cb*cb_n + w_bridge*bridges_n
//   deg_n      = degree / max_degree              (hub_centrality 기여)
//   cb_n       = C_B / max_C_B                    (betweenness proxy)
//   bridges_n  = domain_reach / max_domain_reach  (hub_resilience 기여)
//
// 기본 가중치: 0.4 / 0.4 / 0.2
//
// Usage: hexa hub_centrality_top100.hexa [--top N] [--verbose]
//
// NOTE: 1회성 aggregation 은 단일-인자 exec() 호출 + inline bash 로 처리.
//       (hexa stage1 multi-arg exec 런타임 버그 회피)
// ═══════════════════════════════════════════════════════════

let a = args()
let mut verbose = false
let mut top_n: i64 = 100
let mut ai: i64 = 2
while ai < len(a) {
    let tok = a[ai]
    if tok == "--verbose" || tok == "-v" { verbose = true }
    else if tok == "--top" && ai + 1 < len(a) {
        ai = ai + 1
        try { top_n = to_int(a[ai]) } catch e {} // @allow-silent-catch arg parse fallback
    }
    ai = ai + 1
}

let _HOME = exec("printenv HOME").trim()
let _BASE = _HOME + "/Dev/nexus"
let _ATLAS = _BASE + "/shared/n6/atlas.n6"
let _DEG   = _ATLAS + ".deg"
let _STATS = _ATLAS + ".stats"
let _OUT_TSV  = _ATLAS + ".hub_centrality_top100"
let _OUT_JSON = _OUT_TSV + ".json"

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(s.trim()) } catch e {} // @allow-silent-catch parse fallback
    return v
}

if !file_exists(_ATLAS) {
    println("error: atlas not found: " + _ATLAS); exit(1) // @allow-silent-exit stdout println preceded
}
if !file_exists(_DEG) {
    println("error: degree sidecar not found: " + _DEG); exit(1) // @allow-silent-exit stdout println preceded
}

println("═══════════════════════════════════════════════════════")
println("  Hub Centrality Top-100 — ATLAS-P2-2 integrated module")
println("═══════════════════════════════════════════════════════")
println("")
println("  atlas:  " + _ATLAS)
println("  deg:    " + _DEG)
println("  output: " + _OUT_TSV)
println("          " + _OUT_JSON)
println("  top_n:  " + to_string(top_n))
println("")

// ─── 1. Compute integrated centrality via delegated python helper ───
// Python handles the heavy aggregation (stage1 exec multi-arg bug workaround).
// The helper reads atlas+deg, writes top-N TSV + JSON directly.
let py_helper = _BASE + "/shared/n6/hub_centrality_top100.py"

if !file_exists(py_helper) {
    println("error: helper missing: " + py_helper)
    exit(1) // @allow-silent-exit stdout println preceded
}

// Single-arg exec + absolute python3 path to bypass ~/.hx/bin/python3 GATE
// (~/.hx/bin/python3 dispatches to airgenome remote; we want local-only writes).
let py_bin = "/opt/homebrew/bin/python3"
let py_fallback = "/usr/bin/python3"
let py_path = if file_exists(py_bin) { py_bin } else { py_fallback }
let cmd = py_path + " '" + py_helper + "' '" + _ATLAS + "' '" + _DEG + "' '" + _OUT_TSV + "' '" + _OUT_JSON + "' " + to_string(top_n)
let py_out = exec(cmd + " 2>&1")
println(py_out.trim())

// ─── 2. Verify sidecars ───
let tsv_lines = safe_int(exec("wc -l < '" + _OUT_TSV + "' 2>/dev/null"))
let json_size = safe_int(exec("wc -c < '" + _OUT_JSON + "' 2>/dev/null"))

println("")
println("  TSV  : " + to_string(tsv_lines) + " lines -> " + _OUT_TSV)
println("  JSON : " + to_string(json_size) + " bytes -> " + _OUT_JSON)
println("")

// ─── 3. Preview Top-10 ───
println("  TOP-10 PREVIEW (integrated centrality):")
println("  ───────────────────────────────────────────────────")
// Skip header (4 lines) then show top-10
let prev = exec("awk 'NR>4 && NR<=14' '" + _OUT_TSV + "' 2>/dev/null").trim()
let prev_lines = prev.split("\n")
for pl in prev_lines {
    let t = pl.trim()
    if t == "" { continue }
    let parts = t.split("\t")
    if len(parts) >= 7 {
        println("    #" + parts[0] + "  " + parts[1] + "  deg=" + parts[2] + "  cb=" + parts[3] + "  domains=" + parts[4] + "  score=" + parts[6])
    }
}
println("")

println("═══════════════════════════════════════════════════════")
println("  DONE — Top-" + to_string(top_n) + " centrality sidecars written")
println("═══════════════════════════════════════════════════════")

exit(0)
