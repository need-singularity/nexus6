// scan_math_atlas.hexa — 수학 아틀라스 — 가설 마크다운 파서
// 목적: TECS-L, anima, SEDI 리포의 가설 마크다운 파일을 파싱하고
//       구조화된 메타데이터를 추출 (id, title, grade, refs 등)
// R1 HEXA-FIRST | R14 shared/ 단일진실
// 실행: hexa shared/n6/scan_math_atlas.hexa [--json|--summary|--save|--query FIELD=VALUE|--repo NAME]

// ── 등급 이모지 (탐지 순서 중요) ──
comptime const GRADE_EMOJIS = ["⭐", "🟩", "🟧", "🟦", "🟨", "🟥", "🟪", "⚪", "⬛", "★", "⚡", "✅"]

// ── 리포 색상 ──
comptime const REPO_COLORS = {
    "TECS-L": "#4A90D9", "SEDI": "#E67E22", "anima": "#2ECC71",
    "golden-moe": "#F1C40F", "conscious-lm": "#9B59B6",
    "energy-efficiency": "#1ABC9C"
}

// ── 리포 스캔 설정 ──
comptime const BASE = file_dir().parent().parent()  // TECS-L 루트
comptime const DEV = BASE.parent()                   // ~/Dev

comptime const REPO_SCANS = [
    {
        "name": "TECS-L", "root": BASE,
        "hypothesis_dirs": ["docs/hypotheses", "math/docs/hypotheses"],
        "constant_dirs": [".", "calc", "math"]
    },
    {
        "name": "SEDI", "root": DEV + "/SEDI",
        "hypothesis_dirs": ["docs/hypotheses"],
        "constant_dirs": ["sedi", "sedi/sources"]
    },
    {
        "name": "anima", "root": DEV + "/anima",
        "hypothesis_dirs": [
            "docs/hypotheses", "docs/hypotheses/cx", "docs/hypotheses/ce",
            "docs/hypotheses/dd", "docs/hypotheses/dasein", "docs/hypotheses/evo",
            "docs/hypotheses/genesis", "docs/hypotheses/hw", "docs/hypotheses/inf",
            "docs/hypotheses/omega", "docs/hypotheses/onto", "docs/hypotheses/phil",
            "docs/hypotheses/phys", "docs/hypotheses/se", "docs/hypotheses/sing",
            "docs/hypotheses/sl", "docs/hypotheses/three", "docs/hypotheses/topo",
            "docs/hypotheses/tp"
        ],
        "python_sources": ["hypothesis_recommender.py"],
        "constant_dirs": ["."]
    },
    { "name": "golden-moe", "root": DEV + "/golden-moe", "hypothesis_dirs": [], "constant_dirs": ["."] },
    { "name": "conscious-lm", "root": DEV + "/conscious-lm", "hypothesis_dirs": [], "constant_dirs": ["."] },
    { "name": "energy-efficiency", "root": DEV + "/energy-efficiency", "hypothesis_dirs": [], "constant_dirs": [".", "techniques", "experiments"] }
]

// ═════════════════════════════════════════════════════════════
// YAML 프론트매터 파싱
// ═════════════════════════════════════════════════════════════

fn parse_yaml_frontmatter(text) {
    let m = regex_match(r"^---\n(.*?)\n---", text, "s")
    if m == nil { return {} }
    let result = {}
    for line in m[1].split("\n") {
        let km = regex_match(r'^(\w[\w-]*):\s*"?([^"]*)"?\s*$', line.trim())
        if km != nil { result[km[1]] = km[2].trim() }
    }
    return result
}

// ═════════════════════════════════════════════════════════════
// 등급 추출
// ═════════════════════════════════════════════════════════════

fn extract_emoji_run(text) {
    // 텍스트에서 연속된 등급 이모지 추출
    let result = []
    let i = 0
    let started = false
    while i < text.len() {
        let matched = false
        for emoji in GRADE_EMOJIS {
            if text.slice(i).starts_with(emoji) {
                result.push(emoji)
                i = i + emoji.len()
                matched = true
                started = true
                break
            }
        }
        if not matched {
            if started { break }
            i = i + 1
        }
    }
    return if result.len() > 0 { result.join("") } else { nil }
}

fn extract_grade(text, yaml, title_line) {
    // 등급 추출 (우선순위: YAML > ## Grade > **Grade:** > 제목 이모지)
    if yaml.get("grade") != nil { return yaml["grade"] }

    let m = regex_match(r"^##\s*Grade:\s*(.+)", text, "m")
    if m != nil {
        let emojis = extract_emoji_run(m[1].trim())
        if emojis != nil { return emojis }
        return m[1].trim()
    }

    let m2 = regex_match(r'\*\*(?:Grade|Status):\s*(.+?)(?:\*\*|$)', text, "m")
    if m2 != nil {
        let emojis = extract_emoji_run(m2[1].trim())
        if emojis != nil { return emojis }
        return m2[1].trim()
    }

    if title_line != nil {
        let emojis = extract_emoji_run(title_line)
        if emojis != nil { return emojis }
        if title_line.contains("✅") { return "✅" }
    }

    return nil
}

// ═════════════════════════════════════════════════════════════
// 참조 추출
// ═════════════════════════════════════════════════════════════

fn extract_refs(text) {
    // 교차 참조 추출: 관련 가설 번호와 H-XX-NNN 패턴
    let refs = []
    let m = regex_match(r"[Rr]elated\s+hypothes[ei]s?:\s*(.+)", text)
    if m != nil {
        for num_match in regex_find_all(r"(\d{2,4})\s*\(", m[1]) {
            refs.push(num_match[1])
        }
    }
    for m2 in regex_find_all(r"\(H-([A-Z]+)-(\d+)\)", text) {
        refs.push("H-" + m2[1] + "-" + m2[2])
    }
    return refs
}

fn extract_gz_dependency(text) {
    // 황금지대 의존성 플래그 추출
    let m = regex_match(r"\*\*Golden Zone dependency:\*\*\s*(.+)", text)
    if m == nil { return nil }
    let value = m[1].trim().upper()
    if value.starts_with("NONE") or value.starts_with("NO") { return false }
    if value.starts_with("YES") { return true }
    return nil
}

fn extract_domain(hid) {
    // H-XX-NNN 스타일 ID에서 도메인 추출
    let m = regex_match(r"H-([A-Z]+)-", hid)
    if m != nil { return m[1] }
    return nil
}

// ═════════════════════════════════════════════════════════════
// 가설 마크다운 파싱
// ═════════════════════════════════════════════════════════════

fn parse_hypothesis_md(text, repo, filepath) {
    // 가설 마크다운 파일을 파싱하여 구조화된 메타데이터 반환
    let yaml = parse_yaml_frontmatter(text)
    let stem = path_stem(filepath)

    let title_match = regex_match(r"^#\s+(.+)", text, "m")
    let title_line = if title_match != nil { title_match[1].trim() } else { "" }

    let hid = nil
    let title = nil
    let domain = nil

    // 패턴 A: "Hypothesis Review NNN: Title"
    let m = regex_match(r"Hypothesis\s+Review\s+(\d+):\s*(.*)", title_line)
    if m != nil { hid = m[1]; title = m[2].trim() }

    // 패턴 B: "Hypothesis NNN: Title"
    if hid == nil {
        let m2 = regex_match(r"Hypothesis\s+(\d+):\s*(.*)", title_line)
        if m2 != nil { hid = m2[1]; title = m2[2].trim() }
    }

    // 패턴 C: "H-XX-NNN: Title"
    if hid == nil {
        let m3 = regex_match(r"(H-[A-Z]+-\d+):\s*(.*)", title_line)
        if m3 != nil { hid = m3[1]; title = m3[2].trim(); domain = extract_domain(hid) }
    }

    // 패턴 E: "Frontier NNN: Title"
    if hid == nil {
        let m4 = regex_match(r"Frontier\s+(\d+):\s*(.*)", title_line)
        if m4 != nil { hid = "F-" + m4[1]; title = m4[2].trim() }
    }

    // 패턴 D: YAML id 필드 (최우선)
    if yaml.get("id") != nil {
        hid = yaml["id"]
        domain = extract_domain(hid)
        if yaml.get("title") != nil { title = yaml["title"] }
    }

    // 폴백
    if hid == nil { hid = stem; title = if title_line.len() > 0 { title_line } else { stem } }
    if title == nil { title = title_line }

    let full_id = repo + ":" + hid
    let grade = extract_grade(text, yaml, title_line)
    let refs = extract_refs(text)
    let gz_dependent = extract_gz_dependency(text)

    return {
        "id": full_id, "title": title, "repo": repo,
        "domain": domain, "grade": grade, "refs": refs,
        "gz_dependent": gz_dependent, "file": filepath
    }
}

fn parse_anima_recommender(source) {
    // anima의 HYPOTHESIS_DB 파이썬 소스에서 가설 항목 추출
    let results = []
    for m in regex_find_all(r"Hypothesis\(\s*(.*?)\s*\)", source, "s") {
        let block = m[1]
        let entry = {}
        for field in ["code", "name", "category", "description"] {
            let fm = regex_match(field + r'\s*=\s*"([^"]*)"', block)
            if fm != nil { entry[field] = fm[1] }
        }
        let code = entry.get("code", "???")
        results.push({
            "id": "anima:" + code,
            "title": entry.get("name", ""),
            "code": code,
            "category": entry.get("category"),
            "description": entry.get("description"),
            "grade": nil
        })
    }
    return results
}

// ═════════════════════════════════════════════════════════════
// 상수 분류
// ═════════════════════════════════════════════════════════════

fn categorize_constant(name, file_path) {
    let upper = name.upper()
    let fpath = file_path.lower()
    if ["PSI", "CONSCIOUSNESS", "PHI_", "MIND", "WILL"].any(fn(k) { upper.contains(k) }) { return "consciousness" }
    if ["consciousness", "anima_alive", "conscious"].any(fn(k) { fpath.contains(k) }) { return "consciousness" }
    if ["ENGINE", "ARCH", "DECODER", "MODEL", "TOPOLOG"].any(fn(k) { upper.contains(k) }) { return "architecture" }
    if upper.contains("TARGET") { return "targets" }
    if ["PHYSICS", "PARTICLE", "MASS", "ZETA", "GAUGE", "STRING", "QUANTUM"].any(fn(k) { upper.contains(k) }) { return "physics" }
    if ["CONSTANT", "POOL", "PERFECT_NUMBER", "FIBONACCI", "KISSING"].any(fn(k) { upper.contains(k) }) { return "constants" }
    if upper.contains("DOMAIN") or upper.contains("CATEGOR") { return "domains" }
    if upper.contains("MAGIC") or upper.contains("NUCLEAR") { return "nuclear" }
    if ["EXPRESSION", "FORMULA", "IDENTITY"].any(fn(k) { upper.contains(k) }) { return "expressions" }
    if ["OBSERVED", "EMPIRICAL", "BENCHMARK"].any(fn(k) { upper.contains(k) }) { return "observed" }
    if ["PROFILE", "BRAIN", "EEG", "EMOTION", "GROWTH"].any(fn(k) { upper.contains(k) }) { return "neuroscience" }
    if ["CLAIM", "VERIFY", "TEST", "SCAN", "GRADE"].any(fn(k) { upper.contains(k) }) { return "verification" }
    if ["PRESET", "CONFIG", "PARAM", "SWEEP"].any(fn(k) { upper.contains(k) }) { return "config" }
    return "other"
}

// ═════════════════════════════════════════════════════════════
// 디렉토리 스캔
// ═════════════════════════════════════════════════════════════

fn scan_md_dir(repo_name, repo_root, rel_dir) {
    // 디렉토리에서 *.md 파일을 스캔하고 각각을 가설로 파싱
    let results = []
    let dirpath = repo_root + "/" + rel_dir
    if not dir_exists(dirpath) { return results }
    for mdfile in glob(dirpath + "/*.md").sort() {
        let name = path_basename(mdfile)
        if name.starts_with(".") or name == "README.md" { continue }
        let text = read_file(mdfile)
        if text == nil { continue }
        let filepath = mdfile.replace(repo_root + "/", "")
        let h = parse_hypothesis_md(text, repo_name, filepath)
        results.push(h)
    }
    return results
}

fn scan_anima_python(repo_root, source_file) {
    // anima 파이썬 소스 파일 읽기 및 파싱
    let fpath = repo_root + "/" + source_file
    if not file_exists(fpath) { return [] }
    let text = read_file(fpath)
    if text == nil { return [] }
    let entries = parse_anima_recommender(text)
    let results = []
    for e in entries {
        results.push({
            "id": e["id"], "title": e["title"], "repo": "anima",
            "domain": e.get("category"), "grade": e.get("grade"),
            "refs": [], "gz_dependent": nil, "file": source_file
        })
    }
    return results
}

// ═════════════════════════════════════════════════════════════
// 아틀라스 빌드
// ═════════════════════════════════════════════════════════════

fn build_atlas() {
    // 모든 리포를 스캔하고 통합 아틀라스 구축
    let all_hypotheses = []
    let stats = {}

    for repo_cfg in REPO_SCANS {
        let name = repo_cfg["name"]
        let root = repo_cfg["root"]
        let repo_count = 0

        // 마크다운 가설 디렉토리 스캔
        for rel_dir in repo_cfg.get("hypothesis_dirs", []) {
            let entries = scan_md_dir(name, root, rel_dir)
            all_hypotheses = all_hypotheses + entries
            repo_count = repo_count + entries.len()
        }

        // 파이썬 소스 스캔 (anima)
        for src in repo_cfg.get("python_sources", []) {
            let entries = scan_anima_python(root, src)
            all_hypotheses = all_hypotheses + entries
            repo_count = repo_count + entries.len()
        }

        stats[name] = repo_count
    }

    // ID 기준 중복 제거
    let seen = set()
    let unique = []
    for h in all_hypotheses {
        if not seen.contains(h["id"]) {
            seen.add(h["id"])
            unique.push(h)
        }
    }

    return {
        "version": "1.1",
        "generated": now_format("%Y-%m-%dT%H:%M:%S"),
        "stats": stats,
        "total": unique.len(),
        "hypotheses": unique,
        "constant_maps": [],
        "constant_stats": {}
    }
}

// ═════════════════════════════════════════════════════════════
// 출력 함수 (SQLite, DOT, Markdown, HTML)
// ═════════════════════════════════════════════════════════════

fn write_sqlite(atlas, dbpath) {
    // 아틀라스 데이터를 SQLite 데이터베이스에 쓰기
    let sql_cmds = [
        "DROP TABLE IF EXISTS hypotheses",
        "DROP TABLE IF EXISTS edges",
        "CREATE TABLE hypotheses (id TEXT PRIMARY KEY, repo TEXT, file TEXT, title TEXT, grade TEXT, domain TEXT, gz_dependent INTEGER, refs TEXT)",
        "CREATE TABLE edges (source_id TEXT, target_id TEXT, relation TEXT)",
        "CREATE INDEX idx_repo ON hypotheses(repo)",
        "CREATE INDEX idx_grade ON hypotheses(grade)",
        "CREATE INDEX idx_domain ON hypotheses(domain)"
    ]
    exec("sqlite3 " + dbpath + " '" + sql_cmds.join("; ") + "'")

    // 가설 삽입
    for h in atlas["hypotheses"] {
        let gz = if h["gz_dependent"] == true { "1" } else if h["gz_dependent"] == false { "0" } else { "NULL" }
        let refs_json = to_json(h["refs"])
        let sql = "INSERT INTO hypotheses VALUES ('" + h["id"].replace("'", "''") + "', '" + h["repo"] + "', '" + (h["file"] or "").replace("'", "''") + "', '" + (h["title"] or "").replace("'", "''") + "', '" + (h["grade"] or "").replace("'", "''") + "', '" + (h["domain"] or "").replace("'", "''") + "', " + gz + ", '" + refs_json.replace("'", "''") + "')"
        exec("sqlite3 " + dbpath + " \"" + sql + "\"")
    }

    // 엣지 빌드
    let id_lookup = {}
    for h in atlas["hypotheses"] {
        let full_id = h["id"]
        let short = if full_id.contains(":") { full_id.split(":")[1] } else { full_id }
        if not id_lookup.has(short) { id_lookup[short] = full_id }
    }
    for h in atlas["hypotheses"] {
        let source = h["id"]
        for ref in h.get("refs", []) {
            let target = id_lookup.get(ref)
            if target != nil and target != source {
                exec("sqlite3 " + dbpath + " \"INSERT INTO edges VALUES ('" + source.replace("'", "''") + "', '" + target.replace("'", "''") + "', 'ref')\"")
            }
        }
    }
}

fn write_dot(atlas, dotpath) {
    // 아틀라스 그래프를 Graphviz DOT 파일로 쓰기
    let id_lookup = {}
    let hyp_by_id = {}
    for h in atlas["hypotheses"] {
        let full_id = h["id"]
        let short = if full_id.contains(":") { full_id.split(":")[1] } else { full_id }
        if not id_lookup.has(short) { id_lookup[short] = full_id }
        hyp_by_id[full_id] = h
    }

    let edges = []
    let connected = set()
    for h in atlas["hypotheses"] {
        let source = h["id"]
        for ref in h.get("refs", []) {
            let target = id_lookup.get(ref)
            if target != nil and target != source {
                edges.push((source, target))
                connected.add(source)
                connected.add(target)
            }
        }
    }

    let lines = ["digraph math_atlas {", "  rankdir=LR;", "  node [style=filled];", ""]

    for nid in connected.to_list().sort() {
        let h = hyp_by_id.get(nid)
        if h == nil { continue }
        let safe = nid.replace(":", "_").replace("-", "_")
        let color = REPO_COLORS.get(h["repo"], "#999999")
        let label = if h["title"] != nil { h["title"].slice(0, 40).replace("\"", "\\\"") } else { nid }
        lines.push("  " + safe + " [label=\"" + label + "\" fillcolor=\"" + color + "\"];")
    }
    lines.push("")

    for (src, tgt) in edges {
        let s_safe = src.replace(":", "_").replace("-", "_")
        let t_safe = tgt.replace(":", "_").replace("-", "_")
        lines.push("  " + s_safe + " -> " + t_safe + ";")
    }
    lines.push("}")

    write_file(dotpath, lines.join("\n") + "\n")
}

fn write_markdown(atlas, mdpath) {
    // 아틀라스를 읽기 쉬운 마크다운 문서로 쓰기
    let lines = []
    let total = atlas["total"]
    let cm_count = atlas.get("constant_maps", []).len()
    lines.push("# 수학 아틀라스")
    lines.push("")
    lines.push("> 자동 생성: " + atlas["generated"] + " | " + str(total) + " 가설 | " + str(cm_count) + " 상수 맵")
    lines.push("")

    // 요약 테이블
    lines.push("## 요약")
    lines.push("")
    lines.push("| 리포 | 가설 | 상수 맵 |")
    lines.push("|------|------|---------|")
    for repo in ["TECS-L", "SEDI", "anima"] {
        let h_count = atlas["stats"].get(repo, 0)
        let c_count = atlas.get("constant_stats", {}).get(repo, 0)
        lines.push("| " + repo + " | " + str(h_count) + " | " + str(c_count) + " |")
    }
    lines.push("")

    // 리포별 가설
    lines.push("## 가설")
    lines.push("")
    for repo in ["TECS-L", "SEDI", "anima"] {
        let hyps = atlas["hypotheses"].filter(fn(h) { h["repo"] == repo })
        lines.push("### " + repo + " (" + str(hyps.len()) + ")")
        lines.push("")
        lines.push("| # | ID | 제목 | 등급 | 도메인 |")
        lines.push("|---|-----|------|------|--------|")
        for i, h in hyps.enumerate() {
            let hid = if h["id"].contains(":") { h["id"].split(":")[1] } else { h["id"] }
            let title = (h.get("title") or "").slice(0, 60)
            let grade = h.get("grade") or "-"
            let domain = h.get("domain") or "-"
            lines.push("| " + str(i + 1) + " | " + hid + " | " + title + " | " + grade + " | " + domain + " |")
        }
        lines.push("")
    }

    write_file(mdpath, lines.join("\n") + "\n")
}

// ═════════════════════════════════════════════════════════════
// CLI 진입점
// ═════════════════════════════════════════════════════════════

fn main() {
    let args = get_args()
    let do_json = args.contains("--json")
    let do_summary = args.contains("--summary")
    let do_save = args.contains("--save")
    let do_readme = args.contains("--readme-summary")
    let repo_filter = nil
    let query = nil

    for i, arg in args.enumerate() {
        if arg == "--repo" and i + 1 < args.len() { repo_filter = args[i + 1] }
        if arg == "--query" and i + 1 < args.len() { query = args[i + 1] }
    }

    // 기본: --save --summary
    if not do_json and not do_summary and not do_save and query == nil and not do_readme {
        do_save = true
        do_summary = true
    }

    let atlas = build_atlas()

    // --repo 필터
    if repo_filter != nil {
        atlas["hypotheses"] = atlas["hypotheses"].filter(fn(h) { h["repo"] == repo_filter })
        atlas["total"] = atlas["hypotheses"].len()
    }

    // --json
    if do_json {
        println(to_json(atlas, 2))
        return
    }

    // --save
    if do_save {
        let out_dir = file_dir()
        let json_path = out_dir + "/math_atlas.json"
        let db_path = out_dir + "/math_atlas.db"
        let dot_path = out_dir + "/math_atlas.dot"
        let md_path = out_dir + "/MATH_ATLAS.md"

        write_json(json_path, atlas)
        println("  JSON: " + json_path)

        write_sqlite(atlas, db_path)
        println("  SQLite: " + db_path)

        write_dot(atlas, dot_path)
        println("  DOT: " + dot_path)

        write_markdown(atlas, md_path)
        println("  Markdown: " + md_path)
    }

    // --summary
    if do_summary {
        println("\n=== 수학 아틀라스 요약 ===")
        println("  총 가설: " + str(atlas["total"]))
        println("  생성 시각: " + atlas.get("generated", "N/A"))
        println()
        println("  리포별:")
        for repo, count in atlas.get("stats", {}) {
            println("    " + repo.pad_right(10) + " " + str(count).pad_left(5))
        }
        println()

        // 등급 분포
        let grade_dist = {}
        for h in atlas["hypotheses"] {
            let g = h.get("grade") or "(none)"
            let key = "(none)"
            for emoji in GRADE_EMOJIS {
                if g.contains(emoji) { key = emoji; break }
            }
            if key == "(none)" and g != "(none)" { key = g.slice(0, 6) }
            grade_dist[key] = grade_dist.get(key, 0) + 1
        }
        println("  등급 분포 (상위 10):")
        let sorted_grades = grade_dist.entries().sort_by(fn(a, b) { b.1 - a.1 }).slice(0, 10)
        for (grade, count) in sorted_grades {
            let bar = "#" * min(count / 5, 40)
            println("    " + grade.pad_right(6) + " " + str(count).pad_left(5) + "  " + bar)
        }
    }

    // --query FIELD=VALUE
    if query != nil {
        if not query.contains("=") {
            println("오류: --query는 FIELD=VALUE 형식이어야 합니다 (예: domain=CX)")
            return
        }
        let (field, value) = query.split("=", 1)
        let matches = atlas["hypotheses"].filter(fn(h) {
            str(h.get(field, "")).lower().contains(value.lower())
        })
        println("\n  질의: " + field + "=" + value + " (" + str(matches.len()) + " 결과)")
        for h in matches.slice(0, 30) {
            let g = h.get("grade") or "-"
            println("    " + g.pad_right(4) + " " + h["id"].pad_right(30) + " " + (h.get("title") or "").slice(0, 50))
        }
        if matches.len() > 30 {
            println("    ... 외 " + str(matches.len() - 30) + "건")
        }
    }
}

main()
