// ═══════════════════════════════════════════════════════════
// hypothesis_audit.hexa — atlas.n6 [X?] 가설 분류 (readonly)
// R1 HEXA-FIRST. A7 가설 1012건 검증/해소 지원 도구.
// 용도: 가설을 5개 클래스로 분류 → 승격/해소 큐 생성
// 사용: hexa hypothesis_audit.hexa [path] [--verbose] [--class <name>]
// ═══════════════════════════════════════════════════════════

let a = args()
let mut _ATLAS_PATH = "shared/n6/atlas.n6"
let mut verbose = false
let mut filter_class = ""
let mut ai: i64 = 2
while ai < len(a) {
    let tok = a[ai]
    if tok == "--verbose" || tok == "-v" { verbose = true }
    else if tok == "--class" {
        ai = ai + 1
        if ai < len(a) { filter_class = a[ai] }
    }
    else if !tok.starts_with("-") { _ATLAS_PATH = tok }
    ai = ai + 1
}

if !file_exists(_ATLAS_PATH) {
    println("error: atlas file not found: " + _ATLAS_PATH)
    println("usage: hexa hypothesis_audit.hexa [path] [--verbose] [--class <name>]")
    exit(1)  // @allow-silent-exit
}

// ─── n6 함수 토큰 (compound 판별용) ───
let n6_fns = ["sigma", "tau", "phi", "sopfr", "M3", "J2", "P2", "mu"]

fn has_token(s: string, tok: string) -> bool {
    return s.contains(tok)
}

fn count_fn_tokens(s: string) -> i64 {
    let mut c: i64 = 0
    if has_token(s, "sigma") { c = c + 1 }
    if has_token(s, "tau")   { c = c + 1 }
    if has_token(s, "phi")   { c = c + 1 }
    if has_token(s, "sopfr") { c = c + 1 }
    if has_token(s, "M3")    { c = c + 1 }
    if has_token(s, "J2")    { c = c + 1 }
    if has_token(s, "P2")    { c = c + 1 }
    return c
}

// ─── 분류기 ───
// empty       : 공식 없음 (misc, none, CONVENTION, no 'ID = formula')
// self_dust   : 사소/억지 명시 표기
// trivial     : n*k+r 단순 선형 (n6 함수 0개, n만 사용)
// compound    : n6 함수 2개 이상 복합
// weak        : n6 함수 1개만
fn classify(body: string) -> string {
    let b = body.trim()
    // 공식 자체 없음
    if has_token(b, "= misc") || has_token(b, "= none") ||
       has_token(b, "≈ CONVENTION") || has_token(b, "근사 불가") {
        return "empty"
    }
    // self-flag
    if has_token(b, "사소") || has_token(b, "억지") || has_token(b, "자의") {
        return "self_dust"
    }
    // 공식 추출: '=' 또는 '≈' 이후 문자열
    let mut formula = ""
    if b.contains("≈") {
        let parts = b.split("≈")
        if len(parts) >= 2 { formula = parts[1] }
    } else if b.contains("=") {
        let parts = b.split("=")
        if len(parts) >= 2 { formula = parts[len(parts) - 1] }
    }
    if formula.trim() == "" { return "empty" }
    let fn_count = count_fn_tokens(formula)
    if fn_count >= 2 { return "compound" }
    if fn_count == 1 { return "weak" }
    // 함수 0개 — 단순 n*k+r 형태
    if has_token(formula, "n") { return "trivial" }
    return "empty"
}

// ─── 스캔 ───
let raw = read_file(_ATLAS_PATH)
let lines = raw.split("\n")
let mut n_empty: i64 = 0
let mut n_self_dust: i64 = 0
let mut n_trivial: i64 = 0
let mut n_weak: i64 = 0
let mut n_compound: i64 = 0
let mut total: i64 = 0
let mut sample_compound: string = ""
let mut sample_weak: string = ""
let mut sample_trivial: string = ""
let mut sample_empty: string = ""
let mut sample_self_dust: string = ""
let mut sc_cnt: i64 = 0
let mut sw_cnt: i64 = 0
let mut st_cnt: i64 = 0
let mut se_cnt: i64 = 0
let mut ssd_cnt: i64 = 0
let sample_max: i64 = 10

for ln in lines {
    // [N?] 포함 라인만
    if !ln.contains("?]") { continue }
    // grade 태그 검증: [숫자?] 패턴
    if !(ln.contains("[5?]") || ln.contains("[7?]") || ln.contains("[8?]") ||
         ln.contains("[2?]") || ln.contains("[3?]") || ln.contains("[4?]") ||
         ln.contains("[6?]") || ln.contains("[9?]")) { continue }
    total = total + 1
    let cls = classify(ln)
    if cls == "empty"      { n_empty = n_empty + 1
        if se_cnt < sample_max { sample_empty = sample_empty + "  " + ln.trim() + "\n"; se_cnt = se_cnt + 1 }
    }
    else if cls == "self_dust" { n_self_dust = n_self_dust + 1
        if ssd_cnt < sample_max { sample_self_dust = sample_self_dust + "  " + ln.trim() + "\n"; ssd_cnt = ssd_cnt + 1 }
    }
    else if cls == "trivial"   { n_trivial = n_trivial + 1
        if st_cnt < sample_max { sample_trivial = sample_trivial + "  " + ln.trim() + "\n"; st_cnt = st_cnt + 1 }
    }
    else if cls == "weak"      { n_weak = n_weak + 1
        if sw_cnt < sample_max { sample_weak = sample_weak + "  " + ln.trim() + "\n"; sw_cnt = sw_cnt + 1 }
    }
    else if cls == "compound"  { n_compound = n_compound + 1
        if sc_cnt < sample_max { sample_compound = sample_compound + "  " + ln.trim() + "\n"; sc_cnt = sc_cnt + 1 }
    }
}

// ─── 리포트 ───
println("=== hypothesis audit: " + _ATLAS_PATH + " ===")
println("  total hypotheses [X?]: " + to_string(total))
println("")
println("  class distribution:")
println("    empty      : " + to_string(n_empty)      + "  (공식 없음 — blowup 엔진 투입 대상)")
println("    self_dust  : " + to_string(n_self_dust)  + "  (사소/억지 자기표기 — [dust] 강등)")
println("    trivial    : " + to_string(n_trivial)    + "  (n*k+r 선형 — [dust] 강등)")
println("    weak       : " + to_string(n_weak)       + "  (n6 함수 1개 — 보강 필요)")
println("    compound   : " + to_string(n_compound)   + "  (n6 함수 2+ — 승격 최우선)")
println("")

if verbose || filter_class != "" {
    if filter_class == "" || filter_class == "compound" {
        println("--- compound (top " + to_string(sc_cnt) + ") ---")
        println(sample_compound)
    }
    if filter_class == "" || filter_class == "weak" {
        println("--- weak (top " + to_string(sw_cnt) + ") ---")
        println(sample_weak)
    }
    if filter_class == "" || filter_class == "trivial" {
        println("--- trivial (top " + to_string(st_cnt) + ") ---")
        println(sample_trivial)
    }
    if filter_class == "" || filter_class == "self_dust" {
        println("--- self_dust (top " + to_string(ssd_cnt) + ") ---")
        println(sample_self_dust)
    }
    if filter_class == "" || filter_class == "empty" {
        println("--- empty (top " + to_string(se_cnt) + ") ---")
        println(sample_empty)
    }
}

println("---")
println("권장 조치:")
println("  1. compound " + to_string(n_compound) + "건 → 수식 검증 후 [7]/[8] 승격")
println("  2. self_dust+trivial " + to_string(n_self_dust + n_trivial) + "건 → [dust] 일괄 강등")
println("  3. empty " + to_string(n_empty) + "건 → blowup 엔진 재투입 (공식 생성)")
println("  4. weak " + to_string(n_weak) + "건 → 보강 또는 강등 개별 검토")
