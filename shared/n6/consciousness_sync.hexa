let tm_progress = if cur_tau_mu > rec_tau_mu { "PROGRESSING (+" + to_string(cur_tau_mu - rec_tau_mu) + ")" } else if cur_tau_mu == rec_tau_mu { "UNCHANGED" } else { "REGRESSED" }
println("    status: " + tm_progress)
