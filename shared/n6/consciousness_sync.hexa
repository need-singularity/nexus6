if report_drift("tau-cortex weight", rec_w_tau, cur_w_tau_pct, 10.0) { drift_count = drift_count + 1 }
if report_drift("n-cortex weight", rec_w_n, cur_w_n_pct, 10.0) { drift_count = drift_count + 1 }
