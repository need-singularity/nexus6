fn cur_coupling(pattern: string) -> i64 {
    return safe_int(exec("grep -c '" + pattern + "' '" + _ATLAS + "' 2>/dev/null || echo 0"))
}

// Use same patterns as Mind Mapper engine for consistency
let cur_n_sigma = cur_coupling("sigma.*n\\|n.*sigma")
let cur_n_phi = cur_coupling("phi.*n\\|n.*phi")
let cur_phi_sigma = cur_coupling("phi.*sigma\\|sigma.*phi")
let cur_sigma_tau = cur_coupling("sigma.*tau\\|tau.*sigma")
let cur_phi_tau = cur_coupling("phi.*tau\\|tau.*phi")
let cur_n_tau = cur_coupling("tau.*n\\|n.*tau")
let cur_n_mu = cur_coupling("mu.*n\\|n.*mu")
let cur_tau_mu = cur_coupling("tau.*mu\\|mu.*tau")

if report_int_drift("n,sigma (highway)", rec_n_sigma, cur_n_sigma, 5.0) { drift_count = drift_count + 1 }
if report_int_drift("n,phi", rec_n_phi, cur_n_phi, 5.0) { drift_count = drift_count + 1 }
if report_int_drift("phi,sigma", rec_phi_sigma, cur_phi_sigma, 5.0) { drift_count = drift_count + 1 }
if report_int_drift("sigma,tau", rec_sigma_tau, cur_sigma_tau, 5.0) { drift_count = drift_count + 1 }
if report_int_drift("phi,tau", rec_phi_tau, cur_phi_tau, 5.0) { drift_count = drift_count + 1 }
if report_int_drift("n,tau", rec_n_tau, cur_n_tau, 5.0) { drift_count = drift_count + 1 }
if report_int_drift("n,mu (breakthrough)", rec_n_mu, cur_n_mu, 10.0) { drift_count = drift_count + 1 }
if report_int_drift("tau,mu (breakthrough)", rec_tau_mu, cur_tau_mu, 10.0) { drift_count = drift_count + 1 }
println("")

// Identify strongest/weakest current coupling
let coupling_pairs = [
    [to_string(cur_n_sigma), "n,sigma"],
    [to_string(cur_n_phi), "n,phi"],
    [to_string(cur_phi_sigma), "phi,sigma"],
    [to_string(cur_sigma_tau), "sigma,tau"],
    [to_string(cur_phi_tau), "phi,tau"],
    [to_string(cur_n_tau), "n,tau"],
    [to_string(cur_n_mu), "n,mu"],
    [to_string(cur_tau_mu), "tau,mu"]
]

let mut max_cp: i64 = 0
let mut max_cp_label = ""
let mut min_cp: i64 = 999999
let mut min_cp_label = ""
let mut ci: i64 = 0
while ci < len(coupling_pairs) {
    let val = safe_int(coupling_pairs[ci][0])
    let label = coupling_pairs[ci][1]
    if val > max_cp { max_cp = val; max_cp_label = label }
    if val < min_cp { min_cp = val; min_cp_label = label }
    ci = ci + 1
}
println("  Current strongest: " + max_cp_label + " (" + to_string(max_cp) + ")")
println("  Current weakest:   " + min_cp_label + " (" + to_string(min_cp) + ")")
println("")

