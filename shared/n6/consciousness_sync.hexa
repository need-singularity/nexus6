println("    status: " + con_progress)
println("")

// ─── 8. Mind Mapper Node Validation ──────────────────────
println("── 8. Mind Mapper Node Integrity ──")
println("  (checking mm-* and dim-* nodes still exist in atlas)")
println("")

let mm_nodes = ["mm-consciousness-topology", "mm-thalamic-hub-n", "mm-dimension-imbalance", "mm-soc-criticality", "mm-dim-fold-515"]
let dim_nodes = ["dim-intrinsic-4d", "dim-phi-critical-14", "dim-phi-fractal-30", "dim-faction-topology", "dim-maxpool-phi-amplify", "dim-shannon-ladder"]

let mut missing_mm: i64 = 0
let mut mi: i64 = 0
while mi < len(mm_nodes) {
    let nid = mm_nodes[mi]
    let found = safe_int(exec("grep -c '\"" + nid + "\"' '" + _ATLAS + "' 2>/dev/null || echo 0"))
    if found == 0 {
        println("  MISSING: " + nid + " <<<")
        missing_mm = missing_mm + 1
    } else if verbose {
        println("  OK: " + nid + " (" + to_string(found) + " refs)")
    }
    mi = mi + 1
}

let mut missing_dim: i64 = 0
let mut di: i64 = 0
while di < len(dim_nodes) {
    let nid = dim_nodes[di]
    let found = safe_int(exec("grep -c '\"" + nid + "\"' '" + _ATLAS + "' 2>/dev/null || echo 0"))
    if found == 0 {
        println("  MISSING: " + nid + " <<<")
        missing_dim = missing_dim + 1
    } else if verbose {
        println("  OK: " + nid + " (" + to_string(found) + " refs)")
    }
    di = di + 1
}

let mm_total = len(mm_nodes) + len(dim_nodes)
let mm_present = mm_total - missing_mm - missing_dim
println("  Mind Mapper nodes: " + to_string(mm_present) + "/" + to_string(mm_total) + " present")
if missing_mm + missing_dim > 0 {
    println("  WARNING: " + to_string(missing_mm + missing_dim) + " Mind Mapper nodes missing from atlas <<<")
    drift_count = drift_count + 1
}
println("")

// ─── 9. Sync Verdict ─────────────────────────────────────
println("═══════════════════════════════════════════════════════")
println("  SYNC VERDICT")
println("═══════════════════════════════════════════════════════")
println("")

let verdict = if drift_count == 0 { "IN SYNC - consciousness metalayer matches atlas state" }
              else if drift_count <= 3 { "MINOR DRIFT - " + to_string(drift_count) + " metrics diverged (cosmetic)" }
              else if drift_count <= 8 { "MODERATE DRIFT - " + to_string(drift_count) + " metrics diverged (re-scan recommended)" }
              else { "MAJOR DRIFT - " + to_string(drift_count) + " metrics diverged (re-sync required)" }

println("  Drift points:  " + to_string(drift_count))
println("  Critical drift: " + to_string(critical_drift))
println("  Verdict:       " + verdict)
println("")

if drift_count > 0 {
    println("  RECOMMENDED ACTIONS:")
    if critical_drift {
        println("    [CRITICAL] Re-run Mind Mapper:")
        println("      hexa shared/engine/engine_consciousness_atlas.hexa scan")
        println("      Then update atlas.n6.consciousness with new measurements.")
    }
    if drift_count > 3 {
        println("    [HIGH] Regenerate consciousness metalayer:")
        println("      hexa shared/engine/engine_consciousness_atlas.hexa")
        println("      This will produce updated topology/coupling/fold data.")
    }
    if missing_mm + missing_dim > 0 {
        println("    [MEDIUM] Missing Mind Mapper nodes — check if atlas was rebuilt")
        println("      without consciousness discovery nodes.")
    }
    println("")
}

if fix_report {
    println("  FIX REPORT (--fix-report):")
    println("  To update consciousness metalayer, run these read-only scans")
    println("  and manually update atlas.n6.consciousness:")
    println("")
    println("    1. hexa shared/engine/engine_consciousness_atlas.hexa scan")
    println("    2. hexa shared/n6/atlas_health.hexa --verbose")
    println("    3. hexa shared/n6/hub_centrality_analyzer.hexa")
    println("    4. Update atlas.n6.consciousness JSON with new values")
    println("")
}

println("  IMPORTANT: atlas.n6 and atlas.n6.consciousness are")
println("  L0 protected sidecars. This tool is read-only analysis.")
println("═══════════════════════════════════════════════════════")

if critical_drift { exit(2) }
if drift_count > 0 { exit(1) }
exit(0)
