let total_mentions = to_float(cur_count_n + cur_count_phi + cur_count_sigma + cur_count_tau + cur_count_sopfr + cur_count_mu)
let cur_w_sigma_pct = if total_mentions > 0.0 { to_float(cur_count_sigma) / total_mentions * 100.0 } else { 0.0 }
let cur_w_phi_pct = if total_mentions > 0.0 { to_float(cur_count_phi) / total_mentions * 100.0 } else { 0.0 }
let cur_w_sopfr_pct = if total_mentions > 0.0 { to_float(cur_count_sopfr) / total_mentions * 100.0 } else { 0.0 }
let cur_w_tau_pct = if total_mentions > 0.0 { to_float(cur_count_tau) / total_mentions * 100.0 } else { 0.0 }
let cur_w_n_pct = if total_mentions > 0.0 { to_float(cur_count_n) / total_mentions * 100.0 } else { 0.0 }
let cur_w_mu_pct = if total_mentions > 0.0 { to_float(cur_count_mu) / total_mentions * 100.0 } else { 0.0 }

if report_drift("sigma-cortex weight", rec_w_sigma, cur_w_sigma_pct, 10.0) { drift_count = drift_count + 1 }
