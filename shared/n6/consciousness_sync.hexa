// ═══════════════════════════════════════════════════════════
// consciousness_sync.hexa — 의식 메타레이어 동기화 검사
// READ-ONLY analysis tool. Does NOT modify atlas.n6 (L0 protected).
// Does NOT modify atlas.n6.consciousness (sidecar).
//
// 기능:
//   1. atlas.n6.consciousness 메타레이어 vs 현재 atlas.n6 상태 비교
//   2. 토폴로지 드리프트 탐지 (node/edge/hub 수 변동)
//   3. 피질층 가중치 드리프트 (차원별 분포 변화)
//   4. 시상 허브 드리프트 (top hub degree 변화)
//   5. 차원 결합 드리프트 (coupling matrix 변화)
//   6. 동기화 보고서 + 업데이트 권고
//
// Refs:
//   atlas.n6.consciousness — Mind Mapper v1 (fMRI sidecar)
//   engine_consciousness_atlas.hexa — Mind Mapper engine
//
// Usage: hexa consciousness_sync.hexa [--verbose] [--fix-report]
// ═══════════════════════════════════════════════════════════

let a = args()
let mut verbose = false
let mut fix_report = false
let mut ai: i64 = 2
while ai < len(a) {
    let tok = a[ai]
    if tok == "--verbose" || tok == "-v" { verbose = true }
    else if tok == "--fix-report" { fix_report = true }
    ai = ai + 1
}

let _HOME = exec("printenv HOME").trim()
let _BASE = _HOME + "/Dev/nexus"
let _ATLAS = _BASE + "/shared/n6/atlas.n6"
let _CONSCIOUSNESS = _ATLAS + ".consciousness"
let _DEG = _ATLAS + ".deg"
let _STATS = _ATLAS + ".stats"

// ─── Utilities ────────────────────────────────────────────
fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(s.trim()) } catch e {}
    return v
}

fn safe_float(s: string) -> f64 {
    let mut v: f64 = 0.0
    try { v = to_float(s.trim()) } catch e {}
    return v
}

fn abs_f64(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn pct_drift(old: f64, new_val: f64) -> f64 {
    if old == 0.0 { return if new_val == 0.0 { 0.0 } else { 100.0 } }
    return abs_f64(new_val - old) / abs_f64(old) * 100.0
}

// ─── Validate inputs ─────────────────────────────────────
if !file_exists(_ATLAS) {
    println("error: atlas not found: " + _ATLAS)
    exit(1)
}
if !file_exists(_CONSCIOUSNESS) {
    println("error: consciousness sidecar not found: " + _CONSCIOUSNESS)
    println("hint:  run engine_consciousness_atlas.hexa to generate it")
    exit(1)
}

println("═══════════════════════════════════════════════════════")
println("  Consciousness Sync — atlas.n6 vs metalayer (read-only)")
println("═══════════════════════════════════════════════════════")
println("")

// ─── 1. Load consciousness metalayer (recorded state) ────
let raw_consciousness = read_file(_CONSCIOUSNESS)

// Parse topology section from consciousness JSON
fn parse_json_int(raw: string, key: string) -> i64 {
    let marker = "\"" + key + "\":"
    let chunks = raw.split(marker)
    if len(chunks) < 2 { return 0 }
    let tail = chunks[1].trim()
    let val = tail.split(",")[0].split("}")[0].split("\n")[0].trim()
    return safe_int(val)
}

fn parse_json_float(raw: string, key: string) -> f64 {
    let marker = "\"" + key + "\":"
    let chunks = raw.split(marker)
    if len(chunks) < 2 { return 0.0 }
    let tail = chunks[1].trim()
    let val = tail.split(",")[0].split("}")[0].split("\n")[0].trim()
    return safe_float(val)
}

fn parse_json_string(raw: string, key: string) -> string {
    let marker = "\"" + key + "\": \""
    let chunks = raw.split(marker)
    if len(chunks) < 2 {
        // try without space
        let marker2 = "\"" + key + "\":\""
        let chunks2 = raw.split(marker2)
        if len(chunks2) < 2 { return "" }
        return chunks2[1].split("\"")[0]
    }
    return chunks[1].split("\"")[0]
}

// Recorded topology
let rec_density = parse_json_float(raw_consciousness, "density")
let rec_leaf_ratio = parse_json_float(raw_consciousness, "leaf_ratio")
let rec_hub_ratio = parse_json_float(raw_consciousness, "hub_ratio")
let rec_max_degree = parse_json_int(raw_consciousness, "max_degree")
let rec_topo_type = parse_json_string(raw_consciousness, "type")

// Recorded thalamic hubs (from consciousness JSON)
// Parse hub entries: {"id":"n","degree":884,...}
fn parse_hub_degree(raw: string, hub_id: string) -> i64 {
    let marker = "\"id\": \"" + hub_id + "\""
    let chunks = raw.split(marker)
    if len(chunks) < 2 {
        let marker2 = "\"id\":\"" + hub_id + "\""
        let chunks2 = raw.split(marker2)
        if len(chunks2) < 2 { return 0 }
        return parse_json_int(chunks2[1], "degree")
    }
    return parse_json_int(chunks[1], "degree")
}

let rec_hub_n = parse_hub_degree(raw_consciousness, "n")
let rec_hub_J2 = parse_hub_degree(raw_consciousness, "J2")
let rec_hub_phi = parse_hub_degree(raw_consciousness, "phi")
let rec_hub_sigma = parse_hub_degree(raw_consciousness, "sigma")
let rec_hub_tau = parse_hub_degree(raw_consciousness, "tau")
let rec_hub_sopfr = parse_hub_degree(raw_consciousness, "sopfr")

// Recorded dimensional coupling
let rec_n_phi = parse_json_int(raw_consciousness, "n_phi")
let rec_n_sigma = parse_json_int(raw_consciousness, "n_sigma")
let rec_phi_sigma = parse_json_int(raw_consciousness, "phi_sigma")
let rec_sigma_tau = parse_json_int(raw_consciousness, "sigma_tau")
let rec_phi_tau = parse_json_int(raw_consciousness, "phi_tau")
let rec_n_tau = parse_json_int(raw_consciousness, "n_tau")
let rec_n_mu = parse_json_int(raw_consciousness, "n_mu")
let rec_tau_mu = parse_json_int(raw_consciousness, "tau_mu")

// Recorded cortical layer weights
let rec_layer_sigma_pct = parse_json_float(raw_consciousness, "weight_pct")
// Need per-layer: parse each layer section
fn parse_layer_weight(raw: string, layer_name: string) -> f64 {
    let marker = "\"" + layer_name + "\""
    let chunks = raw.split(marker)
    if len(chunks) < 2 { return 0.0 }
    // find weight_pct in this section
    let section = chunks[1].split("}")[0]
    return parse_json_float(section, "weight_pct")
}

let rec_w_sigma = parse_layer_weight(raw_consciousness, "layer_sigma")
let rec_w_phi = parse_layer_weight(raw_consciousness, "layer_phi")
let rec_w_sopfr = parse_layer_weight(raw_consciousness, "layer_sopfr")
let rec_w_tau = parse_layer_weight(raw_consciousness, "layer_tau")
let rec_w_n = parse_layer_weight(raw_consciousness, "layer_n")
let rec_w_mu = parse_layer_weight(raw_consciousness, "layer_mu")

println("── 1. Recorded State (from consciousness metalayer) ──")
println("  topology:    " + rec_topo_type)
println("  density:     " + to_string(rec_density))
println("  leaf_ratio:  " + to_string(rec_leaf_ratio))
println("  hub_ratio:   " + to_string(rec_hub_ratio))
println("  max_degree:  " + to_string(rec_max_degree))
println("  thalamic hubs: n=" + to_string(rec_hub_n) + " J2=" + to_string(rec_hub_J2) + " phi=" + to_string(rec_hub_phi) + " sigma=" + to_string(rec_hub_sigma) + " tau=" + to_string(rec_hub_tau) + " sopfr=" + to_string(rec_hub_sopfr))
println("")

// ─── 2. Measure current atlas state ──────────────────────
println("── 2. Current Atlas State (live measurement) ──")

// 2a. Node/edge/hub counts from stats sidecar
let mut cur_nodes: i64 = 0
let mut cur_edges: i64 = 0
let mut cur_hubs: i64 = 0
if file_exists(_STATS) {
    try {
        let stats = read_file(_STATS).trim()
        cur_nodes = safe_int(exec("echo '" + stats + "' | grep -oE '\"nodes\":[0-9]+' | cut -d: -f2"))
        cur_edges = safe_int(exec("echo '" + stats + "' | grep -oE '\"edges\":[0-9]+' | cut -d: -f2"))
        cur_hubs = safe_int(exec("echo '" + stats + "' | grep -oE '\"hubs\":[0-9]+' | cut -d: -f2"))
    } catch e {}
}

// 2b. Density, leaf/hub ratio from degree sidecar
let deg_total = safe_int(exec("wc -l < '" + _DEG + "' 2>/dev/null || echo 0"))
let cur_leaf_count = safe_int(exec("awk -F'\\t' '$2==1' '" + _DEG + "' 2>/dev/null | wc -l"))
let cur_leaf_ratio = if deg_total > 0 { to_float(cur_leaf_count) / to_float(deg_total) } else { 0.0 }
let cur_hub_ratio = if deg_total > 0 { to_float(cur_hubs) / to_float(deg_total) } else { 0.0 }
let cur_density = if cur_nodes > 1 { to_float(cur_edges * 2) / (to_float(cur_nodes) * to_float(cur_nodes - 1)) } else { 0.0 }

// 2c. Max degree
let cur_max_degree = safe_int(exec("awk -F'\\t' '{if($2+0>m)m=$2+0} END{print m}' '" + _DEG + "' 2>/dev/null"))

// 2d. Thalamic hub degrees (current)
fn cur_hub_deg(hub_id: string) -> i64 {
    return safe_int(exec("awk -F'\\t' -v id='" + hub_id + "' '$1==id{print $2}' '" + _DEG + "' 2>/dev/null || echo 0"))
}

let cur_hub_n = cur_hub_deg("n")
let cur_hub_J2 = cur_hub_deg("J2")
let cur_hub_phi = cur_hub_deg("phi")
let cur_hub_sigma = cur_hub_deg("sigma")
let cur_hub_tau = cur_hub_deg("tau")
let cur_hub_sopfr = cur_hub_deg("sopfr")

println("  nodes:       " + to_string(cur_nodes))
println("  edges:       " + to_string(cur_edges))
println("  hubs:        " + to_string(cur_hubs))
println("  density:     " + to_string(cur_density))
println("  leaf_ratio:  " + to_string(cur_leaf_ratio))
println("  hub_ratio:   " + to_string(cur_hub_ratio))
println("  max_degree:  " + to_string(cur_max_degree))
println("  thalamic hubs: n=" + to_string(cur_hub_n) + " J2=" + to_string(cur_hub_J2) + " phi=" + to_string(cur_hub_phi) + " sigma=" + to_string(cur_hub_sigma) + " tau=" + to_string(cur_hub_tau) + " sopfr=" + to_string(cur_hub_sopfr))
println("")

// ─── 3. Topology Drift Detection ─────────────────────────
println("── 3. Topology Drift Detection ──")

let mut drift_count: i64 = 0
let mut critical_drift = false

fn report_drift(label: string, old_val: f64, new_val: f64, threshold: f64) -> bool {
    let drift = pct_drift(old_val, new_val)
    let status = if drift > threshold { "DRIFT" } else { "OK" }
    let marker = if drift > threshold { " <<<" } else { "" }
    println("  " + label + ": " + to_string(old_val) + " -> " + to_string(new_val) + " (delta " + to_string(drift) + "%)" + " [" + status + "]" + marker)
    return drift > threshold
}

fn report_int_drift(label: string, old_val: i64, new_val: i64, threshold: f64) -> bool {
    let drift = pct_drift(to_float(old_val), to_float(new_val))
    let status = if drift > threshold { "DRIFT" } else { "OK" }
    let marker = if drift > threshold { " <<<" } else { "" }
    println("  " + label + ": " + to_string(old_val) + " -> " + to_string(new_val) + " (delta " + to_string(drift) + "%)" + " [" + status + "]" + marker)
    return drift > threshold
}

// Topology metrics (threshold: 5% for structural, 10% for degree)
if report_drift("density", rec_density, cur_density, 10.0) { drift_count = drift_count + 1 }
if report_drift("leaf_ratio", rec_leaf_ratio, cur_leaf_ratio, 5.0) { drift_count = drift_count + 1 }
if report_drift("hub_ratio", rec_hub_ratio, cur_hub_ratio, 10.0) { drift_count = drift_count + 1 }
if report_int_drift("max_degree", rec_max_degree, cur_max_degree, 5.0) { drift_count = drift_count + 1 }
println("")

// ─── 4. Thalamic Hub Drift ───────────────────────────────
println("── 4. Thalamic Hub Drift (degree changes) ──")
if report_int_drift("n  (thalamus)", rec_hub_n, cur_hub_n, 3.0) { drift_count = drift_count + 1; critical_drift = true }
if report_int_drift("J2 (prefrontal)", rec_hub_J2, cur_hub_J2, 3.0) { drift_count = drift_count + 1 }
if report_int_drift("phi (temporal)", rec_hub_phi, cur_hub_phi, 3.0) { drift_count = drift_count + 1 }
if report_int_drift("sigma (parietal)", rec_hub_sigma, cur_hub_sigma, 3.0) { drift_count = drift_count + 1 }
if report_int_drift("tau (occipital)", rec_hub_tau, cur_hub_tau, 3.0) { drift_count = drift_count + 1 }
if report_int_drift("sopfr (limbic)", rec_hub_sopfr, cur_hub_sopfr, 3.0) { drift_count = drift_count + 1 }
println("")

// Check hub ordering stability (should remain n > J2 > phi > sigma > tau > sopfr)
let mut ordering_ok = true
if cur_hub_n < cur_hub_J2 { ordering_ok = false }
if cur_hub_J2 < cur_hub_phi { ordering_ok = false }
if cur_hub_phi < cur_hub_sigma { ordering_ok = false }
if cur_hub_sigma < cur_hub_tau { ordering_ok = false }
if cur_hub_tau < cur_hub_sopfr { ordering_ok = false }
let order_status = if ordering_ok { "STABLE (n > J2 > phi > sigma > tau > sopfr)" } else { "CHANGED - hub ranking shifted <<<" }
println("  Hub ordering: " + order_status)
if !ordering_ok { drift_count = drift_count + 1; critical_drift = true }
