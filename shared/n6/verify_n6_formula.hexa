// ═══════════════════════════════════════════════════════════
// verify_n6_formula.hexa — n6 arithmetic formula numeric verifier
// Agent/script formula pre-verification helper.
//
// usage:
//   hexa verify_n6_formula.hexa <target> <formula>
//   hexa verify_n6_formula.hexa 155 "n*J2+sigma-mu"
//   # exit 0 if within tolerance, 1 otherwise
//
// n6 constants: n=6, sigma=12, tau=4, phi=2, sopfr=5, M3=7, J2=24, P2=28, mu=1
// operators: + - * / ^ ( ) (^ is exponent, not XOR)
// tolerance: 5% of target or 0.01 absolute minimum
//
// Converted from verify_n6_formula.py
// ═══════════════════════════════════════════════════════════

fn verify(target_str: string, formula: string) -> list {
    // Returns [ok_str, target_str, computed_str, message]
    // ok_str: "true" or "false"

    // Parse target
    let mut target: f64 = 0.0
    let mut target_valid = false
    try {
        target = to_float(target_str)
        target_valid = true
    } catch e {}

    if !target_valid {
        return ["false", "0.0", "0.0", "invalid target: " + target_str]
    }

    // Normalize formula: ^ -> **, unicode superscripts
    let mut expr = formula.replace("^", "**")
    expr = expr.replace("\u00b2", "**2")
    expr = expr.replace("\u00b3", "**3")

    // Check for non-ASCII
    let py_ascii = "import re,sys; print('1' if re.search(r'[^\\x00-\\x7f]', sys.argv[1]) else '0')"
    let mut has_nonascii = false
    try {
        let check = to_string(exec("python3", ["-c", py_ascii, expr])).trim()
        if check == "1" { has_nonascii = true }
    } catch e {}

    if has_nonascii {
        return ["false", to_string(target), "0.0", "non-ASCII in formula: " + formula]
    }

    // Evaluate using python with n6 context
    let py_eval = "import sys; ctx={'n':6,'sigma':12,'tau':4,'phi':2,'sopfr':5,'M3':7,'J2':24,'P2':28,'mu':1}; v=eval(sys.argv[1],{'__builtins__':{}},ctx); print(type(v).__name__+'\\t'+str(float(v)) if isinstance(v,(int,float)) else 'bad\\t0')"
    let mut computed: f64 = 0.0
    let mut eval_ok = false
    try {
        let result = to_string(exec("python3", ["-c", py_eval, expr])).trim()
        let parts = result.split("\t")
        if len(parts) >= 2 {
            if parts[0] != "bad" {
                computed = to_float(parts[1])
                eval_ok = true
            }
        }
    } catch e {}

    if !eval_ok {
        return ["false", to_string(target), "0.0", "eval error for: " + formula]
    }

    // Calculate tolerance and diff
    let mut abs_target = target
    if abs_target < 0.0 { abs_target = -abs_target }
    let mut tol = abs_target * 0.05
    if tol < 0.01 { tol = 0.01 }

    let mut diff = computed - target
    if diff < 0.0 { diff = -diff }

    let ok = diff <= tol

    // Build message — use python for formatting
    let py_fmt = "import sys; print(f'{sys.argv[1]} = {float(sys.argv[2]):.6g} (target={float(sys.argv[3]):.6g}, diff={float(sys.argv[4]):.4f}, tol={float(sys.argv[5]):.4f})')"
    let mut msg = formula + " = " + to_string(computed) + " (target=" + to_string(target) + ")"
    try {
        msg = to_string(exec("python3", ["-c", py_fmt, formula, to_string(computed), to_string(target), to_string(diff), to_string(tol)])).trim()
    } catch e {}

    let ok_str = if ok { "true" } else { "false" }
    return [ok_str, to_string(target), to_string(computed), msg]
}

fn main() {
    let a = args()
    // args(): [interpreter, script, arg1, arg2, ...]
    if len(a) < 4 {
        println("verify_n6_formula.hexa -- n6 arithmetic formula numeric verifier")
        println("")
        println("usage:")
        println("    hexa verify_n6_formula.hexa <target> <formula>")
        println("    hexa verify_n6_formula.hexa 155 \"n*J2+sigma-mu\"")
        println("")
        println("n6 constants: n=6, sigma=12, tau=4, phi=2, sopfr=5, M3=7, J2=24, P2=28, mu=1")
        println("tolerance: 5% of target or 0.01 absolute minimum")
        exit(2)
    }

    let target_str = a[2]
    let formula = a[3]

    let result = verify(target_str, formula)
    let ok = result[0]
    let msg = result[3]

    if ok == "true" {
        println("OK: " + msg)
        exit(0)
    } else {
        println("FAIL: " + msg)
        exit(1)
    }
}

main()
