// ═══════════════════════════════════════════════════════════
// hypothesis_promote.hexa — atlas.n6 가설 마커 9건 승격 (one-shot)
// R1 HEXA-FIRST. todo #5 verified 항목 in-place 수정.
// 방법: 전체 read → line-wise 치환 → tempfile write → atomic rename
// ═══════════════════════════════════════════════════════════

let atlas_path = "shared/n6/atlas.n6"
let tmp_path   = "shared/n6/atlas.n6.tmp.promote"

if !file_exists(atlas_path) {
    println("error: atlas not found: " + atlas_path)
    exit(1)
}

// ─── 승격 규칙 테이블 (line_idx 1-based → old_tag → new_tag) ───
// 9건 verified: todo #5 atlas_hypothesis_resolution_2026-04-14.json
let targets = [
    [143,  "@X physics_n6 :: crossing [7?]",
           "@X physics_n6 :: crossing [dust]"],
    [4227, "@R L6-eco-poverty-world-ext = 2.15 ≈ phi+phi/10 :: economics [6?]",
           "@R L6-eco-poverty-world-ext = 2.15 ≈ phi+phi/10 :: economics [8]"],
    [4365, "@R LANG-hangul-syllables-unicode = 11172 = 21*28*19 :: linguistics [6?]",
           "@R LANG-hangul-syllables-unicode = 11172 = 21*28*19 :: linguistics [10]"],
    [4367, "@R LANG-jouyou-kanji = 2136 :: linguistics [6?]",
           "@R LANG-jouyou-kanji = 2136 :: linguistics [10]"],
    [4377, "@R LANG-iso639-2-codes = ~487 :: linguistics [6?]",
           "@R LANG-iso639-2-codes = ~487 :: linguistics [8]"],
    [7459, "@X L9-hubble-constant-km = sigma*sopfr + M3 + mu/phi (= 67.5, 실측 67.36±0.54) :: cosmological [8?]",
           "@X L9-hubble-constant-km = sigma*sopfr + M3 + mu/phi (= 67.5, 실측 67.36±0.54) :: cosmological [8]"],
    [7461, "@X L9-dark-energy-fraction = (tau*phi + M3/(sigma*n)) / (sigma - mu/n) (= 0.68427, 실측 0.6847±0.0073) :: cosmological [8?]",
           "@X L9-dark-energy-fraction = (tau*phi + M3/(sigma*n)) / (sigma - mu/n) (= 0.68427, 실측 0.6847±0.0073) :: cosmological [8]"],
    [7463, "@X L9-dark-matter-fraction = tau/(sigma + sopfr - phi) (= 4/15 = 0.2667, 실측 0.266~0.268) :: cosmological [5?]",
           "@X L9-dark-matter-fraction = tau/(sigma + sopfr - phi) (= 4/15 = 0.2667, 실측 0.266~0.268) :: cosmological [8]"],
    [7465, "@X L9-baryon-fraction = M3/(sigma^2 - mu) (= 7/143 = 0.04895, 실측 0.0493±0.0006) :: cosmological [8?]",
           "@X L9-baryon-fraction = M3/(sigma^2 - mu) (= 7/143 = 0.04895, 실측 0.0493±0.0006) :: cosmological [8]"]
]

// ─── Read → mutate → write-tmp → rename ───
let raw = read_file(atlas_path)
let lines = raw.split("\n")
let mut modified: i64 = 0
let mut report = []

let mut ti: i64 = 0
while ti < len(targets) {
    let tgt = targets[ti]
    let line_idx = tgt[0]  // 1-based
    let old_text = tgt[1]
    let new_text = tgt[2]
    let i0 = line_idx - 1  // 0-based
    if i0 < 0 || i0 >= len(lines) {
        println("warn: line " + to_string(line_idx) + " out of bounds (len=" + to_string(len(lines)) + ")")
        ti = ti + 1
        continue
    }
    let current = lines[i0]
    if current == old_text {
        lines[i0] = new_text
        modified = modified + 1
        println("  ok  line " + to_string(line_idx) + ": promoted")
    } else {
        println("  skip line " + to_string(line_idx) + ": mismatch")
        println("       got: " + current)
        println("       exp: " + old_text)
    }
    ti = ti + 1
}

// ─── Rebuild & write tempfile ───
let mut out = ""
let mut li: i64 = 0
while li < len(lines) {
    if li > 0 { out = out + "\n" }
    out = out + lines[li]
    li = li + 1
}

write_file(tmp_path, out)

// ─── Atomic rename (sys call via exec) ───
try {
    exec("mv -f " + tmp_path + " " + atlas_path)
} catch e { // @allow-silent-catch
    println("error: rename failed")
    exit(2)
}

println("")
println("=== promotion complete ===")
println("  atlas_path     : " + atlas_path)
println("  lines modified : " + to_string(modified) + " / " + to_string(len(targets)))
println("  atlas_lines    : " + to_string(len(lines)))
