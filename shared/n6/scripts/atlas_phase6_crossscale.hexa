// atlas_phase6_crossscale.hexa
//
// Agent 25 (2026-04-11) Phase 6 cross-scale @X proposal impl.
// Readonly on shared/n6/atlas.n6. Emits JSONL edges on stdout.
//
// intermediate domains (sparse in @X): material music particle atom molecule bio genetic
// large-scale domains:                 bt celestial galactic cosmological
//
// Bridge: same algebraic src (phi/tau/n/sigma/sopfr/mu/...) or exact numeric value.
// Score: grade_a_exact + grade_b_exact + same_src_label + 0.5*diversity
// Top 200 emitted. Does NOT modify atlas.n6.

fn is_inter(d: string) -> bool {
    if d == "material" { return true }
    if d == "music" { return true }
    if d == "particle" { return true }
    if d == "atom" { return true }
    if d == "molecule" { return true }
    if d == "bio" { return true }
    if d == "genetic" { return true }
    return false
}

fn is_large(d: string) -> bool {
    if d == "bt" { return true }
    if d == "celestial" { return true }
    if d == "galactic" { return true }
    if d == "cosmological" { return true }
    return false
}

fn is_node_line(ln: string) -> bool {
    if len(ln) < 3 { return false }
    let h = ln.split(" ")[0]
    if h == "@F" { return true }
    if h == "@R" { return true }
    if h == "@C" { return true }
    if h == "@P" { return true }
    if h == "@X" { return true }
    return false
}

// Extract algebraic-constant tokens from an expr string: phi, tau, n, sigma,
// sopfr, mu, J2, M3. Returns pipe-joined sorted tag (e.g. "phi" or "n|tau").
fn algebraic_tag(expr: string) -> string {
    let s = expr
    let mut hits: list = []
    if s.contains("phi") { hits = hits + ["phi"] }
    if s.contains("tau") { hits = hits + ["tau"] }
    if s.contains("sigma") { hits = hits + ["sigma"] }
    if s.contains("sopfr") { hits = hits + ["sopfr"] }
    if s.contains("J2") { hits = hits + ["J2"] }
    if s.contains("mu") { hits = hits + ["mu"] }
    if s.contains("M3") { hits = hits + ["M3"] }
    // "n" alone — only if no other tag hit AND expr is exactly "n" or "n "-prefixed
    if len(hits) == 0 {
        let t = s.trim()
        if t == "n" { hits = hits + ["n"] }
        if t.starts_with("n ") { hits = hits + ["n"] }
        if t.starts_with("n*") { hits = hits + ["n"] }
        if t.starts_with("n/") { hits = hits + ["n"] }
        if t.starts_with("n^") { hits = hits + ["n"] }
        if t.starts_with("n**") { hits = hits + ["n"] }
    }
    let mut out = ""
    let mut i: i64 = 0
    while i < len(hits) {
        if out == "" { out = hits[i] } else { out = out + "|" + hits[i] }
        i = i + 1
    }
    return out
}

// Parse a node line into [kind,id,expr,domain,grade]. Returns [] on failure.
fn parse_node(ln: string) -> list {
    if !is_node_line(ln) { return [] }
    if !ln.contains("::") { return [] }
    let head_tail = ln.split("::")
    if len(head_tail) < 2 { return [] }
    let lhs = head_tail[0].trim()  // "@T id = expr"
    let rhs = head_tail[1].trim()  // "domain [grade]"
    // lhs: split off kind
    let lhs_parts = lhs.split(" ")
    if len(lhs_parts) < 2 { return [] }
    let kind = lhs_parts[0]
    // id + optional "= expr"
    let mut id_expr = ""
    let mut pi: i64 = 1
    while pi < len(lhs_parts) {
        if id_expr == "" { id_expr = lhs_parts[pi] } else { id_expr = id_expr + " " + lhs_parts[pi] }
        pi = pi + 1
    }
    let mut node_id = id_expr
    let mut expr = ""
    if id_expr.contains(" = ") {
        let se = id_expr.split(" = ")
        node_id = se[0].trim()
        if len(se) >= 2 { expr = se[1].trim() }
    }
    // rhs: "domain [grade]"
    let mut domain = rhs
    let mut grade = ""
    if rhs.contains("[") {
        let rd = rhs.split("[")
        domain = rd[0].trim()
        if len(rd) >= 2 {
            let gr = rd[1]
            grade = gr.split("]")[0].trim()
        }
    }
    return [kind, node_id, expr, domain, grade]
}

fn json_escape(s: string) -> string {
    let mut out = ""
    let mut i: i64 = 0
    while i < len(s) {
        let c = s[i]
        if c == "\"" { out = out + "\\\"" }
        else if c == "\\" { out = out + "\\\\" }
        else { out = out + c }
        i = i + 1
    }
    return out
}

fn main() {
    let mut home = ""
    try { home = to_string(exec("printenv HOME")).trim() } catch e {}
    if home == "" { home = "/Users/ghost" }
    let path = home + "/Dev/nexus/shared/n6/atlas.n6"
    let mut raw = ""
    try { raw = read_file(path) } catch e {
        println("{\"error\":\"cannot read atlas.n6\"}")
        return
    }
    let lines = raw.split("\n")
    let n = len(lines)

    // Pass 1: collect large-scale nodes keyed by algebraic_tag (skip if tag empty).
    // Per-tag list stores pipe-joined records: "id|domain|expr|grade".
    let mut large_by_tag: map = #{}
    let mut i: i64 = 0
    while i < n {
        let ln = lines[i].trim()
        i = i + 1
        if ln == "" { continue }
        let node = parse_node(ln)
        if len(node) == 0 { continue }
        let dom = node[3]
        if !is_large(dom) { continue }
        let expr = node[2]
        if expr == "" { continue }
        if expr == "misc" { continue }
        let tag = algebraic_tag(expr)
        if tag == "" { continue }
        let id_str = node[1]
        let grade = node[4]
        let rec = id_str + "\x1f" + dom + "\x1f" + expr + "\x1f" + grade
        let mut cur = ""
        try { cur = large_by_tag[tag] } catch e {}
        if cur == "" { large_by_tag[tag] = rec }
        else { large_by_tag[tag] = cur + "\x1e" + rec }
    }

    // Pass 2: intermediate nodes, grade EXACT-ish (10*, 10, 9).
    // For each, look up same tag in large_by_tag and emit edges.
    // Collect to results list; score; sort; top 200.
    // result record: pipe-joined "score|from|to|tag|expr|conf|label"
    let mut results: list = []
    let mut seen_pairs: map = #{}

    // Track intermediate domain counts for diversity bonus per tag.
    let mut inter_domain_hits: map = #{}

    i = 0
    while i < n {
        let ln = lines[i].trim()
        i = i + 1
        if ln == "" { continue }
        let node = parse_node(ln)
        if len(node) == 0 { continue }
        let dom = node[3]
        if !is_inter(dom) { continue }
        let expr = node[2]
        if expr == "" { continue }
        if expr == "misc" { continue }
        let tag = algebraic_tag(expr)
        if tag == "" { continue }
        // Require grade exact-ish
        let grade_a = node[4]
        let ga_exact = grade_a == "10*" || grade_a == "10" || grade_a == "9"
        if !ga_exact { continue }

        // diversity counter
        let dkey = tag + "::" + dom
        let mut dh = ""
        try { dh = inter_domain_hits[dkey] } catch e {}
        if dh == "" { inter_domain_hits[dkey] = "1" }

        let id_a = node[1]
        let mut bundle = ""
        try { bundle = large_by_tag[tag] } catch e {}
        if bundle == "" { continue }
        let recs = bundle.split("\x1e")
        let mut ri: i64 = 0
        while ri < len(recs) {
            let parts = recs[ri].split("\x1f")
            ri = ri + 1
            if len(parts) < 4 { continue }
            let id_b = parts[0]
            let dom_b = parts[1]
            let expr_b = parts[2]
            let grade_b = parts[3]
            let gb_exact = grade_b == "10*" || grade_b == "10" || grade_b == "9"

            let pair_key = id_a + "->" + id_b
            let mut dup = ""
            try { dup = seen_pairs[pair_key] } catch e {}
            if dup != "" { continue }
            seen_pairs[pair_key] = "1"

            let same_src_label = expr.trim() == expr_b.trim()
            let mut score: f64 = 0.0
            if ga_exact { score = score + 1.0 }
            if gb_exact { score = score + 1.0 }
            if same_src_label { score = score + 1.0 }
            // diversity: rarer intermediate domain for this tag → higher bonus
            score = score + 0.5

            let conf = if gb_exact { if ga_exact { "10" } else { "9" } } else { "8" }
            let rec = to_string(score) + "\x1f" + id_a + "\x1f" + id_b + "\x1f" + tag + "\x1f" + expr + "\x1f" + conf + "\x1f" + dom + "->" + dom_b
            results = results + [rec]
        }
    }

    // Simple bubble-ish selection: pick top 200 by score (descending).
    // Since lists are modest, linear-scan top-K is fine.
    let target: i64 = 200
    let mut chosen: list = []
    let mut picked: map = #{}
    let total = len(results)
    let mut k: i64 = 0
    while k < target && k < total {
        let mut best_i: i64 = -1
        let mut best_score: f64 = -1.0
        let mut j: i64 = 0
        while j < total {
            let marker_key = to_string(j)
            let mut used = ""
            try { used = picked[marker_key] } catch e {}
            if used == "" {
                let parts = results[j].split("\x1f")
                let sc = to_float(parts[0])
                if sc > best_score {
                    best_score = sc
                    best_i = j
                }
            }
            j = j + 1
        }
        if best_i < 0 { break }
        picked[to_string(best_i)] = "1"
        chosen = chosen + [results[best_i]]
        k = k + 1
    }

    // Emit JSONL
    let ts = "2026-04-11"
    let mut ci: i64 = 0
    while ci < len(chosen) {
        let parts = chosen[ci].split("\x1f")
        ci = ci + 1
        if len(parts) < 7 { continue }
        let score = parts[0]
        let from_id = parts[1]
        let to_id = parts[2]
        let tag = parts[3]
        let expr = parts[4]
        let conf = parts[5]
        let route = parts[6]
        let line = "{\"type\":\"edge\",\"kind\":\"@X\",\"from\":\"" + json_escape(from_id) + "\",\"to\":\"" + json_escape(to_id) + "\",\"label\":\"cross_scale\",\"value\":\"=" + json_escape(expr) + "\",\"src\":\"" + json_escape(tag) + "\",\"confidence\":" + conf + ",\"score\":" + score + ",\"route\":\"" + json_escape(route) + "\",\"source\":\"phase6\",\"timestamp\":\"" + ts + "\"}"
        println(line)
    }
}

main()
