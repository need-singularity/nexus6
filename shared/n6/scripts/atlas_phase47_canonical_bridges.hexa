// ═══════════════════════════════════════════════════════════
// atlas_phase47_canonical_bridges.hexa — canonical cross-domain @S sweep
// Agent 28+ follow-up to Phase 46
// ───────────────────────────────────────────────────────────
// Finds commutative @S edges linking 8 canonical pivot nodes to
// ALL matching non-canonical nodes.
// Infra-only: reads atlas.n6, writes JSONL to stdout.
// Does NOT modify atlas.n6.
//
// Converted from atlas_phase47_canonical_bridges.py
// ═══════════════════════════════════════════════════════════

fn json_escape(s: string) -> string {
    let mut out = ""
    let mut i: i64 = 0
    while i < len(s) {
        let c = s[i]
        if c == "\"" { out = out + "\\\"" }
        else if c == "\\" { out = out + "\\\\" }
        else { out = out + c }
        i = i + 1
    }
    return out
}

fn _log(msg: string) {
    try { exec("bash", ["-c", "printf '%s\\n' \"" + msg + "\" 1>&2"]) } catch e {}
}

fn main() {
    let ATLAS = "shared/n6/atlas.n6"

    // 8 canonical pivots: token -> [id, value]
    let canon_tokens: list = ["n", "phi", "tau", "sigma", "sopfr", "mu", "j2", "m3"]
    let canon_ids: list    = ["n", "phi", "tau", "sigma", "sopfr", "mu", "J2", "M3"]
    let canon_vals: list   = [6,    2,     4,     12,      5,       1,    24,   7]

    // Load atlas nodes: build value-index via python for JSON parsing
    // Extract all node/absorb records: value -> list of "id\tdomain\tgrade\tsrc"
    let mut value_index: map = #{}
    let mut id_set: map = #{}

    if !file_exists(ATLAS) {
        println("# error: atlas not found: " + ATLAS)
        exit(1)
    }

    let raw = read_file(ATLAS)
    let lines = raw.split("\n")

    for line in lines {
        let s = line.trim()
        if s == "" { continue }
        if !s.starts_with("{") { continue }

        // Parse JSON fields via python
        let py = "import json,sys; o=json.loads(sys.argv[1]); t=o.get('type',''); i=o.get('id',''); v=o.get('value',''); d=o.get('domain',''); g=o.get('grade',''); s=o.get('src',''); print(f'{t}\\t{i}\\t{v}\\t{d}\\t{g}\\t{s}')"
        let mut parsed = ""
        try {
            parsed = to_string(exec("python3", ["-c", py, s])).trim()
        } catch e { continue }

        let parts = parsed.split("\t")
        if len(parts) < 6 { continue }
        let typ = parts[0]
        let nid = parts[1]
        let val_str = parts[2]
        let dom = parts[3]
        let grade = parts[4]
        let src = parts[5]

        if typ != "node" && typ != "absorb" { continue }
        if nid == "" { continue }

        // Deduplicate by id
        let mut dup = ""
        try { dup = id_set[nid] } catch e {}
        if dup != "" { continue }
        id_set[nid] = "1"

        if val_str == "" { continue }

        // Try to parse as float
        let mut vf_str = ""
        try {
            let check = to_string(exec("python3", ["-c", "print(float('" + val_str + "'))"]))
            vf_str = check.trim()
        } catch e { continue }
        if vf_str == "" { continue }

        // Store in value_index: key=vf_str, value = records separated by \x1e
        let rec = nid + "\x1f" + dom + "\x1f" + grade + "\x1f" + src
        let mut cur = ""
        try { cur = value_index[vf_str] } catch e {}
        if cur == "" { value_index[vf_str] = rec }
        else { value_index[vf_str] = cur + "\x1e" + rec }
    }

    println("# phase47 canonical cross-domain @S sweep — Agent 28 follow-up")
    println("# source=atlas.n6 canon=n6-*")

    let mut seen_edges: map = #{}
    let mut emitted: i64 = 0

    let mut i: i64 = 0
    while i < len(canon_tokens) {
        let mut j: i64 = 0
        while j < len(canon_tokens) {
            if i == j { j = j + 1; continue }
            let a_tok = canon_tokens[i]
            let b_tok = canon_tokens[j]
            let a_id = canon_ids[i]
            let b_id = canon_ids[j]
            let a_val = canon_vals[i]
            let b_val = canon_vals[j]

            // Two operations: * and +
            let ops: list = ["*", "+"]
            let results: list = [a_val * b_val, a_val + b_val]

            let mut oi: i64 = 0
            while oi < 2 {
                let op = ops[oi]
                let result = results[oi]

                // For +, only when i < j (commutative dedup)
                if op == "+" && i > j { oi = oi + 1; continue }

                let result_key = to_string(to_float(result))
                let mut bundle = ""
                try { bundle = value_index[result_key] } catch e {}
                if bundle == "" { oi = oi + 1; continue }

                let recs = bundle.split("\x1e")
                let mut ri: i64 = 0
                while ri < len(recs) {
                    let fields = recs[ri].split("\x1f")
                    ri = ri + 1
                    if len(fields) < 4 { continue }
                    let mid = fields[0]
                    let mdom = fields[1]
                    let mgrade = fields[2]

                    // Skip n6-* nodes
                    if mid.starts_with("n6-") { continue }

                    let edge_key = a_tok + ":" + b_tok + ":" + op + ":" + mid
                    let mut dup = ""
                    try { dup = seen_edges[edge_key] } catch e {}
                    if dup != "" { continue }
                    seen_edges[edge_key] = "1"

                    let label = "canonical_" + op + "_" + a_tok + "_" + b_tok
                    let expr = a_tok + " " + op + " " + b_tok + " = " + to_string(result)

                    let edge = "{\"type\":\"edge\",\"kind\":\"@S\",\"from\":\""
                        + json_escape(a_id) + "\",\"to\":\"" + json_escape(mid)
                        + "\",\"via\":\"" + json_escape(b_id)
                        + "\",\"label\":\"" + json_escape(label)
                        + "\",\"expr\":\"" + json_escape(expr)
                        + "\",\"value\":" + to_string(result)
                        + ",\"to_domain\":\"" + json_escape(mdom)
                        + "\",\"to_grade\":\"" + json_escape(mgrade)
                        + "\",\"confidence\":1.0,\"source\":\"phase47\",\"timestamp\":\"2026-04-11\"}"
                    println(edge)
                    emitted = emitted + 1
                }
                oi = oi + 1
            }
            j = j + 1
        }
        i = i + 1
    }

    _log("# emitted=" + to_string(emitted))
}

main()
