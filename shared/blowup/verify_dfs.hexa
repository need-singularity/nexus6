// shared/blowup/verify_dfs.hexa — Phase 9 DFS End-to-End Verification
// @no-lock-needed
//
// Dry-run trace of blowup.hexa Phase 9 DFS logic:
//   1. Flag parsing & session initialization
//   2. Recursive call flag construction & validation
//   3. Termination conditions (depth, energy, visited)
//   4. Visited file create/read/update/cleanup cycle
//   5. Race condition analysis
//
// Does NOT invoke blowup.hexa or modify any production files.
//
// Usage:
//   hexa shared/blowup/verify_dfs.hexa
//   hexa shared/blowup/verify_dfs.hexa --verbose

// ═══════════════════════════════════════════════════════════
// ─── SETUP ───
// ═══════════════════════════════════════════════════════════

let _NEXUS = env("NEXUS")
let _BLOWUP = _NEXUS + "/shared/blowup/core/blowup.hexa"

let a = args()
let mut verbose = false
let mut ai: i64 = 0
while ai < len(a) {
    if a[ai] == "--verbose" { verbose = true }
    ai = ai + 1
}

let mut pass_count: i64 = 0
let mut fail_count: i64 = 0
let mut warn_count: i64 = 0

fn report(tag: string, ok: bool, msg: string) {
    if ok {
        println("  [PASS] " + tag + " — " + msg)
        pass_count = pass_count + 1
    } else {
        println("  [FAIL] " + tag + " — " + msg)
        fail_count = fail_count + 1
    }
}

fn warn(tag: string, msg: string) {
    println("  [WARN] " + tag + " — " + msg)
    warn_count = warn_count + 1
}

println("═══════════════════════════════════════════════════════════")
println("  Phase 9 DFS End-to-End Verification")
println("  blowup.hexa: " + _BLOWUP)
println("═══════════════════════════════════════════════════════════")
println("")

// ═══════════════════════════════════════════════════════════
// ─── BATCH SCAN: single awk pass over blowup.hexa ───
// ROI #16 — replaces ~31 sequential exec(grep) with 1 awk read
// ═══════════════════════════════════════════════════════════

// --- count variables (grep -c equivalents) ---
let mut _c_phase9: i64 = 0
let mut _c_dfs_flag: i64 = 0
let mut _c_dfs_current_flag: i64 = 0
let mut _c_dfs_session_flag: i64 = 0
let mut _c_cur_incr: i64 = 0
let mut _c_sess_fwd: i64 = 0
let mut _c_guard: i64 = 0
let mut _c_already_seen: i64 = 0
let mut _c_backtrack: i64 = 0
let mut _c_fast_p8: i64 = 0
let mut _c_dual_write: i64 = 0
let mut _c_session_path: i64 = 0
let mut _c_dfs_out_exec: i64 = 0
let mut _c_depth_naming: i64 = 0
let mut _c_end_fast: i64 = 0
let mut _c_dfs_cap: i64 = 0

// --- content-match variables (grep without -c) ---
let mut _m_dfs_cmd_line: string = ""
let mut _m_dfs_max_fwd: string = ""
let mut _m_maxr1: string = ""
let mut _m_seeds_cond: string = ""
let mut _m_wt1: string = ""
let mut _m_wt2: string = ""
let mut _m_quote_vuln: string = ""
let mut _m_tail_cap: string = ""

// --- pipe-chain variables (grep | grep context matching) ---
let mut _c_dfs_cmd_fast: i64 = 0
let mut _c_dfs_cmd_nograph: i64 = 0
let mut _c_echo_pid_sess: i64 = 0
let mut _c_cleanup_root: i64 = 0
let mut _c_rmf_root_guard: i64 = 0
let mut _c_try_before_dfs_out: i64 = 0
let mut _c_session_root_only: i64 = 0

let mut _awk_raw = ""
try {
    _awk_raw = exec("awk '"
        + "BEGIN { "
        + "  c1=0; c2=0; c3=0; c4=0; c5=0; c6=0; c7=0; c8=0; c9=0; c10=0"
        + "; c11=0; c12=0; c13=0; c14=0; c15=0; c16=0"
        + "; c17=0; c18=0; c19=0; c20=0; c21=0; c22=0; c23=0"
        + "; m1=\"\"; m2=\"\"; m3=\"\"; m4=\"\"; m5=\"\"; m6=\"\"; m7=\"\"; m8=\"\""
        + "} "
        // --- simple counts ---
        + "/Phase 9: DFS Deep Dive/ { c1++ } "
        + "/\"--dfs\"/ { c2++ } "
        + "/\"--dfs-current\"/ { c3++ } "
        + "/\"--dfs-session\"/ { c4++ } "
        + "/dfs_current \\+ 1/ { c5++ } "
        + "/dfs-session \" \\+ dfs_session/ { c6++ } "
        + "/dfs_max_depth > 0 && dfs_current < dfs_max_depth && dfs_best_energy > 0/ { c7++ } "
        + "/\\_already_seen = true/ { c8++ } "
        + "/backtrack/ { c9++ } "
        + "/fast.*Phase 8.*\\355\\214\\214\\353\\217\\231 \\353\\243\\250\\355\\224\\204 \\354\\212\\244\\355\\202\\265/ { c10++ } "
        + "/printf.*>>.*_dfs_visited/ { c11++ } "
        + "/blowup_dfs_visited.*dfs_session/ { c12++ } "
        + "/let _dfs_out = exec/ { c13++ } "
        + "/blowup_dfs_visited.*max_depth/ { c14++ } "
        + "/end if !fast_mode/ { c15++ } "
        + "/dfs_max_depth = if dfs_max_depth/ { c16++ } "
        // --- content matches (first match kept) ---
        + "/let dfs_cmd = hexa_bin/ { if (m1==\"\") m1=$0 } "
        + "/dfs_cmd.*--dfs.*dfs_max_depth/ { if (m2==\"\") m2=$0 } "
        + "/dfs_cmd.*max-rounds 1/ { if (m3==\"\") m3=$0 } "
        + "/dfs_cmd.*wave_seed_csv/ { if (m4==\"\") m4=$0 } "
        + "/let mut wave_targets/ { if (m5==\"\") m5=NR\":\"$0 } "
        + "/fast.*Phase 8/ { if (m6==\"\") m6=NR\":\"$0 } "
        + "/dfs_best_target.*_dfs_visited/ { if (m7==\"\") m7=$0 } "
        + "/dfs_cmd.*tail/ { if (m8==\"\") m8=$0 } "
        // --- pipe-chain equivalents (context-aware) ---
        + "/let dfs_cmd/ { dfs_cmd_line=$0 } "
        + "dfs_cmd_line!=\"\" && /--fast/ { c17++ } "
        + "dfs_cmd_line!=\"\" && /no-graph/ { c18++ } "
        + "/let dfs_cmd/ { dfs_cmd_line=\"\" } "
        // echo $$ + dfs_session (grep 'echo ..' | grep -c dfs_session)
        + "/echo \\$\\$/ && /dfs_session/ { c19++ } "
        // grep -A1 dfs_current == 0 | grep -c rm -f
        + "/dfs_current == 0/ { saw_cur0=1; next_cur0=NR+1 } "
        + "NR==next_cur0 && /rm -f/ { c20++ } "
        // grep -B2 rm -f.*_dfs_visited | grep -c dfs_current == 0
        + "{ prev2=prev1; prev1=$0 } "
        + "/rm -f.*_dfs_visited/ && prev2 ~ /dfs_current == 0/ { c21++ } "
        + "/rm -f.*_dfs_visited/ && prev1 ~ /dfs_current == 0/ { c21++ } "
        // grep -B1 _dfs_out = exec | grep -c try
        + "/\\_dfs_out = exec/ { if (prev1 ~ /try/) c22++ } "
        // T8.4: dfs_session == "" on preceding line, then echo $$ (session root-only)
        + "/dfs_session == \"\"/ { prev_sess=1 } "
        + "prev_sess && /echo \\$\\$/ { c23++ } "
        + "/echo \\$\\$/ { prev_sess=0 } "
        // --- output ---
        + "END { "
        + "  printf \"%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d"
        + "|%s|%s|%s|%s|%s|%s|%s|%s"
        + "|%d|%d|%d|%d|%d|%d|%d\\n\","
        + "  c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16,"
        + "  m1,m2,m3,m4,m5,m6,m7,m8,"
        + "  c17,c18,c19,c20,c21,c22,c23"
        + "}"
        + "' '" + _BLOWUP + "' 2>/dev/null").trim()
} catch e {}  // @allow-silent-catch

// Parse the pipe-delimited output
let _awk_parts = _awk_raw.split("|")
if len(_awk_parts) >= 31 {
    _c_phase9 = to_int(_awk_parts[0])
    _c_dfs_flag = to_int(_awk_parts[1])
    _c_dfs_current_flag = to_int(_awk_parts[2])
    _c_dfs_session_flag = to_int(_awk_parts[3])
    _c_cur_incr = to_int(_awk_parts[4])
    _c_sess_fwd = to_int(_awk_parts[5])
    _c_guard = to_int(_awk_parts[6])
    _c_already_seen = to_int(_awk_parts[7])
    _c_backtrack = to_int(_awk_parts[8])
    _c_fast_p8 = to_int(_awk_parts[9])
    _c_dual_write = to_int(_awk_parts[10])
    _c_session_path = to_int(_awk_parts[11])
    _c_dfs_out_exec = to_int(_awk_parts[12])
    _c_depth_naming = to_int(_awk_parts[13])
    _c_end_fast = to_int(_awk_parts[14])
    _c_dfs_cap = to_int(_awk_parts[15])
    _m_dfs_cmd_line = _awk_parts[16]
    _m_dfs_max_fwd = _awk_parts[17]
    _m_maxr1 = _awk_parts[18]
    _m_seeds_cond = _awk_parts[19]
    _m_wt1 = _awk_parts[20]
    _m_wt2 = _awk_parts[21]
    _m_quote_vuln = _awk_parts[22]
    _m_tail_cap = _awk_parts[23]
    _c_dfs_cmd_fast = to_int(_awk_parts[24])
    _c_dfs_cmd_nograph = to_int(_awk_parts[25])
    _c_echo_pid_sess = to_int(_awk_parts[26])
    _c_cleanup_root = to_int(_awk_parts[27])
    _c_rmf_root_guard = to_int(_awk_parts[28])
    _c_try_before_dfs_out = to_int(_awk_parts[29])
    _c_session_root_only = to_int(_awk_parts[30])
}

if verbose {
    println("  [awk batch] parsed " + to_string(len(_awk_parts)) + " fields from single-pass scan")
}

// ═══════════════════════════════════════════════════════════
// TEST 1: Source file exists and contains Phase 9 DFS
// ═══════════════════════════════════════════════════════════

println("── T1: Source Integrity ──")

let mut src_exists = false
try {
    let _st = exec("test -f '" + _BLOWUP + "' && echo Y || echo N").trim()
    src_exists = _st == "Y"
} catch e {}  // @allow-silent-catch
report("T1.1", src_exists, "blowup.hexa exists")

let has_phase9 = _c_phase9 >= 1
report("T1.2", has_phase9, "Phase 9 DFS section present (grep 'Phase 9: DFS Deep Dive')")

let has_dfs_flag = _c_dfs_flag >= 1
report("T1.3", has_dfs_flag, "--dfs flag parsed in arg loop")

let has_dfs_current_flag = _c_dfs_current_flag >= 1
report("T1.4", has_dfs_current_flag, "--dfs-current flag parsed in arg loop")

let has_dfs_session_flag = _c_dfs_session_flag >= 1
report("T1.5", has_dfs_session_flag, "--dfs-session flag parsed in arg loop")

println("")

// ═══════════════════════════════════════════════════════════
// TEST 2: Flag Parsing Simulation
// ═══════════════════════════════════════════════════════════

println("── T2: Flag Parsing Dry-Run ──")

// Simulate what blowup.hexa does at lines 1562-1601
// Given args: <domain> <depth> --dfs 3 --dfs-current 1 --dfs-session abc123
let sim_args = ["math", "3", "--dfs", "3", "--dfs-current", "1", "--dfs-session", "abc123", "--max-rounds", "1"]
let mut sim_dfs_max: i64 = 0
let mut sim_dfs_cur: i64 = 0
let mut sim_dfs_sess: string = ""
let mut sim_fast: bool = false
let mut sim_max_rounds: i64 = 6

let mut si: i64 = 2
while si < len(sim_args) {
    if sim_args[si] == "--dfs" && si + 1 < len(sim_args) {
        sim_dfs_max = to_int(sim_args[si + 1])
        si = si + 1
    }
    if sim_args[si] == "--dfs-current" && si + 1 < len(sim_args) {
        sim_dfs_cur = to_int(sim_args[si + 1])
        si = si + 1
    }
    if sim_args[si] == "--dfs-session" && si + 1 < len(sim_args) {
        sim_dfs_sess = sim_args[si + 1]
        si = si + 1
    }
    if sim_args[si] == "--fast" { sim_fast = true }
    if sim_args[si] == "--max-rounds" && si + 1 < len(sim_args) {
        sim_max_rounds = to_int(sim_args[si + 1])
        si = si + 1
    }
    si = si + 1
}

report("T2.1", sim_dfs_max == 3, "--dfs parsed: expected 3, got " + to_string(sim_dfs_max))
report("T2.2", sim_dfs_cur == 1, "--dfs-current parsed: expected 1, got " + to_string(sim_dfs_cur))
report("T2.3", sim_dfs_sess == "abc123", "--dfs-session parsed: expected 'abc123', got '" + sim_dfs_sess + "'")
report("T2.4", sim_fast == false, "--fast not set (correct — DFS needs Phase 8)")
report("T2.5", sim_max_rounds == 1, "--max-rounds parsed: expected 1, got " + to_string(sim_max_rounds))

// Session init: root (dfs_current==0) generates session from PID
let mut sim_root_sess = ""
if sim_dfs_max > 0 && sim_root_sess == "" {
    // When dfs_current == 0, blowup generates session from PID
    // When dfs_current > 0, session is passed via --dfs-session
    sim_root_sess = "root_generates_pid"
}
report("T2.6", sim_dfs_cur > 0 && sim_dfs_sess != "", "child invocation: session inherited (not regenerated)")

// Verify session init only happens when session is empty
let mut sim_root_cur: i64 = 0
let mut sim_root_max: i64 = 3
let mut sim_root_s: string = ""
if sim_root_max > 0 && sim_root_s == "" {
    sim_root_s = "pid_based"
}
report("T2.7", sim_root_s != "", "root invocation: session auto-generated when empty")

println("")

// ═══════════════════════════════════════════════════════════
// TEST 3: Recursive Call Construction Validation
// ═══════════════════════════════════════════════════════════

println("── T3: Recursive Call Flag Validation ──")

// Extract the actual dfs_cmd line from blowup.hexa (from batch scan)
let dfs_cmd_line = _m_dfs_cmd_line.trim()

report("T3.1", dfs_cmd_line != "", "dfs_cmd construction line found in source")

// Verify --dfs-current is incremented (dfs_current + 1)
let has_cur_incr = _c_cur_incr >= 1
report("T3.2", has_cur_incr, "--dfs-current uses (dfs_current + 1) — depth incremented")

// Verify --dfs-session is forwarded unchanged
let has_sess_fwd = _c_sess_fwd >= 1
report("T3.3", has_sess_fwd, "--dfs-session forwarded from parent (same session ID)")

// Verify --dfs <max_depth> is forwarded (same max)
let has_max_fwd = len(_m_dfs_max_fwd.trim()) > 10
report("T3.4", has_max_fwd, "--dfs <max_depth> forwarded unchanged to child")

// Verify --fast is NOT in the recursive command
let fast_absent = _c_dfs_cmd_fast == 0
report("T3.5", fast_absent, "--fast NOT passed in recursive call (Phase 8 must run)")

// Verify --max-rounds 1 is set (prevent multi-round recursion explosion)
let has_maxr1 = len(_m_maxr1.trim()) > 10
report("T3.6", has_maxr1, "--max-rounds 1 set in recursive call (bounded recursion)")

// Verify seeds are conditionally forwarded
let has_seeds_cond = len(_m_seeds_cond.trim()) > 10
report("T3.7", has_seeds_cond, "--seeds conditionally forwarded from parent wave_seed_csv")

// Verify --no-graph is NOT passed (deep dive records to atlas)
let no_graph_absent = _c_dfs_cmd_nograph == 0
report("T3.8", no_graph_absent, "--no-graph NOT passed in recursive call (deep dive records)")

// Simulate command construction
let sim_hexa = "/path/to/hexa"
let sim_nexus = env("NEXUS")
let sim_target = "physics"
let sim_md: i64 = 3
let sim_dmax: i64 = 4
let sim_dcur: i64 = 1
let sim_dsess = "12345"
let sim_seeds = "6,12,2"

let sim_cmd = sim_hexa + " " + sim_nexus + "/shared/blowup/core/blowup.hexa '" + sim_target + "' " + to_string(sim_md) + " --dfs " + to_string(sim_dmax) + " --dfs-current " + to_string(sim_dcur + 1) + " --dfs-session " + sim_dsess + " --max-rounds 1" + (if sim_seeds != "" { " --seeds \"" + sim_seeds + "\"" } else { "" })

if verbose {
    println("    simulated cmd: " + sim_cmd)
}

// Verify the simulated command matches expected structure
let has_target = sim_cmd.contains("'" + sim_target + "'")
let has_depth_incr = sim_cmd.contains("--dfs-current 2")
let has_session = sim_cmd.contains("--dfs-session 12345")
let has_seeds = sim_cmd.contains("--seeds")
let no_fast = !(sim_cmd.contains("--fast"))
report("T3.9", has_target && has_depth_incr && has_session && has_seeds && no_fast, "simulated cmd matches expected structure")

println("")

// ═══════════════════════════════════════════════════════════
// TEST 4: Termination Conditions
// ═══════════════════════════════════════════════════════════

println("── T4: Termination Conditions ──")

// The Phase 9 entry guard is:
//   if dfs_max_depth > 0 && dfs_current < dfs_max_depth && dfs_best_energy > 0 && dfs_best_target != ""
// This means DFS terminates (does not recurse) when ANY of:
//   1. dfs_max_depth == 0 (DFS disabled)
//   2. dfs_current >= dfs_max_depth (depth limit reached)
//   3. dfs_best_energy == 0 (no energy from wave propagation)
//   4. dfs_best_target == "" (no target found)
//   5. _already_seen == true (visited collision)

let has_guard = _c_guard >= 1
report("T4.1", has_guard, "entry guard checks: max>0 AND current<max AND energy>0 AND target!=\"\"")

// T4.2: depth limit
let mut t4_dmax: i64 = 3
let mut t4_dcur: i64 = 3
let t4_depth_terminates = !(t4_dmax > 0 && t4_dcur < t4_dmax)
report("T4.2", t4_depth_terminates, "depth=3/max=3 terminates (current >= max)")

// T4.3: zero energy
let mut t4_energy: i64 = 0
let t4_energy_terminates = !(t4_energy > 0)
report("T4.3", t4_energy_terminates, "energy=0 terminates (no wave results)")

// T4.4: empty target
let t4_target = ""
let t4_target_terminates = !(t4_target != "")
report("T4.4", t4_target_terminates, "empty target terminates (no wave_targets)")

// T4.5: visited collision check
let has_visited_check = _c_already_seen >= 1
report("T4.5", has_visited_check, "visited collision detection: _already_seen flag set on grep match")

// T4.6: visited collision causes backtrack (not recurse)
let has_backtrack = _c_backtrack >= 1
report("T4.6", has_backtrack, "visited collision prints backtrack message and skips recursive call")

// T4.7: fast_mode blocks Phase 8 (and therefore Phase 9)
let fast_skips_p8 = _c_fast_p8 >= 1
report("T4.7", fast_skips_p8, "--fast mode skips Phase 8 entirely (Phase 9 unreachable)")

// T4.8: Simulate full depth traversal
if verbose {
    println("    depth trace simulation:")
}
let sim_max: i64 = 3
let mut sim_d: i64 = 0
let mut sim_term_reason = ""
while sim_d < sim_max {
    if verbose {
        println("      depth " + to_string(sim_d) + "/" + to_string(sim_max) + " -> recurse with --dfs-current " + to_string(sim_d + 1))
    }
    sim_d = sim_d + 1
}
sim_term_reason = "depth_limit"
report("T4.8", sim_term_reason == "depth_limit" && sim_d == sim_max, "simulation: depth 0->1->2->3, terminates at depth=" + to_string(sim_d))

println("")

// ═══════════════════════════════════════════════════════════
// TEST 5: Visited File Mechanism
// ═══════════════════════════════════════════════════════════

println("── T5: Visited File Lifecycle ──")

// Use a unique test session to avoid interfering with real runs
let mut test_session = ""
try { test_session = exec("echo $$").trim() } catch e { test_session = "test0" }  // @allow-silent-catch
test_session = "verify_dfs_test_" + test_session
let test_visited = "/tmp/.blowup_dfs_visited." + test_session

// T5.1: File does not pre-exist
try { exec("rm -f '" + test_visited + "' 2>/dev/null") } catch e {}  // @allow-silent-catch
let mut pre_clean = false
try {
    let _pc = exec("test -f '" + test_visited + "' && echo Y || echo N").trim()
    pre_clean = _pc == "N"
} catch e {}  // @allow-silent-catch
report("T5.1", pre_clean, "test visited file does not pre-exist")

// T5.2: Write domain to visited file (simulates line 3385)
let test_dom1 = "math"
let test_dom2 = "physics"
let mut write_ok = false
try {
    exec("bash", ["-c", "printf '%s\\n' '" + test_dom1 + "' >> " + test_visited + " 2>/dev/null"])
    exec("bash", ["-c", "printf '%s\\n' '" + test_dom2 + "' >> " + test_visited + " 2>/dev/null"])
    write_ok = true
} catch e {}  // @allow-silent-catch
report("T5.2", write_ok, "visited file write (printf append) succeeded")

// T5.3: File now exists
let mut file_exists = false
try {
    let _fe = exec("test -f '" + test_visited + "' && echo Y || echo N").trim()
    file_exists = _fe == "Y"
} catch e {}  // @allow-silent-catch
report("T5.3", file_exists, "visited file created at " + test_visited)

// T5.4: grep -Fxq detects existing domain (simulates line 3378)
let mut math_found = false
try {
    let _mf = exec("grep -Fxq '" + test_dom1 + "' " + test_visited + " 2>/dev/null && echo Y || echo N").trim()
    math_found = _mf == "Y"
} catch e {}  // @allow-silent-catch
report("T5.4", math_found, "grep -Fxq detects '" + test_dom1 + "' as visited")

// T5.5: grep -Fxq rejects non-existing domain
let mut unknown_absent = false
try {
    let _ua = exec("grep -Fxq 'topology' " + test_visited + " 2>/dev/null && echo Y || echo N").trim()
    unknown_absent = _ua == "N"
} catch e {}  // @allow-silent-catch
report("T5.5", unknown_absent, "grep -Fxq correctly rejects unvisited 'topology'")

// T5.6: Exact match (not substring) — "math_advanced" should NOT match "math"
try {
    exec("bash", ["-c", "printf '%s\\n' 'math_advanced' >> " + test_visited + " 2>/dev/null"])
} catch e {}  // @allow-silent-catch
let mut exact_only = false
try {
    // -Fx means fixed-string exact-line match
    let _eo = exec("grep -Fxq 'math_adv' " + test_visited + " 2>/dev/null && echo Y || echo N").trim()
    exact_only = _eo == "N"
} catch e {}  // @allow-silent-catch
report("T5.6", exact_only, "grep -Fxq is exact-line match (substring 'math_adv' does not match 'math_advanced')")

// T5.7: Both current domain AND target are written (lines 3385-3386)
// blowup writes dfs_best_target AND domain to visited (two writes per DFS step)
let has_dual_write = _c_dual_write >= 2
report("T5.7", has_dual_write, "visited file gets TWO entries per step (target + current domain)")

// T5.8: Root cleanup (line 3403-3404)
// batch awk: grep -A1 'dfs_current == 0' | grep -c 'rm -f'
let has_root_cleanup = _c_cleanup_root >= 1
report("T5.8", has_root_cleanup, "root (depth=0) cleans up visited file after DFS completes")

// T5.9: Non-root does NOT clean up
// batch awk: grep -B2 'rm -f.*_dfs_visited' | grep -c 'dfs_current == 0'
let no_child_cleanup = _c_rmf_root_guard >= 1
report("T5.9", no_child_cleanup, "only root cleans up (guarded by dfs_current == 0)")

// Cleanup test file
try { exec("rm -f '" + test_visited + "' 2>/dev/null") } catch e {}  // @allow-silent-catch

println("")

// ═══════════════════════════════════════════════════════════
// TEST 6: Race Condition & Session Isolation Analysis
// ═══════════════════════════════════════════════════════════

println("── T6: Race Condition & Session Isolation ──")

// T6.1: Session-based file naming prevents cross-contamination
let session_in_path = _c_session_path >= 1
report("T6.1", session_in_path, "visited filename includes session ID (per-run isolation)")

// T6.2: Session ID generated from PID (unique per process tree)
// batch awk: grep 'echo ..' | grep -c 'dfs_session'
let pid_session = _c_echo_pid_sess >= 1
report("T6.2", pid_session, "session ID derived from 'echo $$' (shell PID)")

// T6.3: Concurrent isolation test — two sessions write to different files
let sess_a = "verify_iso_A_" + test_session
let sess_b = "verify_iso_B_" + test_session
let vis_a = "/tmp/.blowup_dfs_visited." + sess_a
let vis_b = "/tmp/.blowup_dfs_visited." + sess_b

let mut iso_ok = false
try {
    exec("bash", ["-c", "printf '%s\\n' 'domain_A' >> " + vis_a + " 2>/dev/null"])
    exec("bash", ["-c", "printf '%s\\n' 'domain_B' >> " + vis_b + " 2>/dev/null"])
    let _ia = exec("grep -Fxq 'domain_B' " + vis_a + " 2>/dev/null && echo Y || echo N").trim()
    let _ib = exec("grep -Fxq 'domain_A' " + vis_b + " 2>/dev/null && echo Y || echo N").trim()
    iso_ok = _ia == "N" && _ib == "N"
} catch e {}  // @allow-silent-catch
try { exec("rm -f '" + vis_a + "' '" + vis_b + "' 2>/dev/null") } catch e {}  // @allow-silent-catch
report("T6.3", iso_ok, "concurrent sessions isolated: A's domains not in B's file and vice versa")

// T6.4: Potential race — grep+append is not atomic
// The window between grep check (line 3378) and printf append (line 3385)
// is non-atomic. However, DFS is sequential (child blocks parent via exec),
// so only one writer at a time per session. This is safe.
let dfs_is_sequential = _c_dfs_out_exec >= 1
report("T6.4", dfs_is_sequential, "DFS exec is synchronous (parent blocks until child finishes)")

// T6.5: No parallel DFS within same session
// Since exec blocks, only one process per session touches the visited file at a time
// The grep-then-append race is safe because it is single-threaded per session
report("T6.5", dfs_is_sequential, "no intra-session parallelism: grep-then-append race is safe (sequential exec)")

// T6.6: Old bug was max_depth-based naming; verify it is now session-based
let no_depth_naming = _c_depth_naming == 0
report("T6.6", no_depth_naming, "old max_depth-based naming removed (was source of collision bug)")

println("")

// ═══════════════════════════════════════════════════════════
// TEST 7: Fast Mode Mutual Exclusion
// ═══════════════════════════════════════════════════════════

println("── T7: --fast / --dfs Mutual Exclusion ──")

// T7.1: fast_mode wraps Phase 8+9 in else block
let fast_guards_p89 = _c_end_fast >= 1
report("T7.1", fast_guards_p89, "Phase 8+9 inside `if !fast_mode` block (explicit close comment)")

// T7.2: DFS recursive call does NOT include --fast
// Already verified in T3.5, cross-reference here
report("T7.2", fast_absent, "recursive call omits --fast (cross-ref T3.5)")

// T7.3: wave_targets only populated inside !fast_mode branch
// Phase 8 (wave_targets) is at ~line 3257, inside the else{} that starts at 3055.
// The else closes at line 3417. So wave_targets is unreachable in fast mode.
// batch awk: m5 = NR:line for 'let mut wave_targets', m6 = NR:line for 'fast.*Phase 8'
let wt_in_branch = len(_m_wt1.trim()) > 0 && len(_m_wt2.trim()) > 0
report("T7.3", wt_in_branch, "wave_targets populated only inside !fast_mode branch")

println("")

// ═══════════════════════════════════════════════════════════
// TEST 8: Edge Cases
// ═══════════════════════════════════════════════════════════

println("── T8: Edge Cases ──")

// T8.1: Domain with single quotes — potential injection
// blowup uses: grep -Fxq '<target>' and printf '%s\n' '<target>'
// If target contains single quote, the shell command breaks
// batch awk: m7 = first line matching dfs_best_target.*_dfs_visited
let quote_vuln = _m_quote_vuln.trim().contains("'\" + dfs_best_target + \"'")
if quote_vuln {
    warn("T8.1", "domain names with single quotes could break shell quoting in grep/printf (low risk: atlas domains rarely contain quotes)")
} else {
    report("T8.1", true, "domain quoting in grep/printf checked")
}

// T8.2: DFS depth 0 means disabled (no-op)
let t8_dmax0: i64 = 0
let t8_guard = t8_dmax0 > 0
report("T8.2", !t8_guard, "--dfs 0 correctly disables DFS (guard fails at dfs_max_depth > 0)")

// T8.3: Very large depth — bounded by entry guard only
// No explicit max on dfs_max_depth, but it is an i64 from user input
// max_depth for scan is capped at 10 (line 1546), but dfs_max_depth has no cap
// dfs_max_depth cap check: scan depth has `if _raw_depth > 10 { 10 }` but DFS depth
// is taken directly from user input without capping. Verify by checking for a cap pattern.
// `if dfs_max_depth > 0` is an enable guard, NOT a cap. A real cap would look like
// `if dfs_max_depth > N { N }` where N > 0.
let dfs_has_cap = _c_dfs_cap >= 1
if !dfs_has_cap {
    warn("T8.3", "dfs_max_depth has no upper bound cap (scan depth capped at 10, but DFS depth is uncapped). Consider adding a cap for safety.")
} else {
    report("T8.3", true, "dfs_max_depth is bounded")
}

// T8.4: PID-based session — echo $$ inside hexa exec
// echo $$ in `exec("echo $$")` returns the shell PID of the subprocess
// This is fine for uniqueness but note: every exec spawns a new shell, so PID varies
// The code uses this once at root init, then passes it down. This is correct.
// batch awk: prev line of 'echo $$' checked for 'dfs_session ==' — not directly
// modeled in single-pass; we use c19 (echo $$ && dfs_session on same line) as proxy
// The original grep -B1 checks that the PRECEDING line contains 'dfs_session =='
// For a stronger check we rely on the awk prev1 tracking — but this pattern often
// appears as: if ... dfs_session == "" { \n dfs_session = exec("echo $$") }
// So we add a dedicated awk match:
let mut session_at_root_only = false
try {
    let _sr = exec("awk '/dfs_session == \"\"/ { prev_sess=1 } prev_sess && /echo \\$\\$/ { found++ } /echo \\$\\$/ { prev_sess=0 } END { printf \"%d\", found+0 }' '" + _BLOWUP + "' 2>/dev/null").trim()
    session_at_root_only = to_int(_sr) >= 1
} catch e {}  // @allow-silent-catch
report("T8.4", session_at_root_only, "session ID generated once at root only (guard: dfs_session == \"\")")

// T8.5: exec output piped through tail -30 (prevents huge child output)
// batch awk: m8 = first line matching dfs_cmd.*tail
let has_tail_cap = _m_tail_cap.trim().contains("tail -30")
report("T8.5", has_tail_cap, "child output capped via 'tail -30' (prevents stdout explosion)")

// T8.6: Error handling — try/catch around recursive exec
// batch awk: c22 = grep -B1 '_dfs_out = exec' | grep -c 'try'
let has_try_catch = _c_try_before_dfs_out >= 1
report("T8.6", has_try_catch, "recursive exec wrapped in try/catch (failure does not crash parent)")

println("")

// ═══════════════════════════════════════════════════════════
// SUMMARY
// ═══════════════════════════════════════════════════════════

println("═══════════════════════════════════════════════════════════")
println("  SUMMARY")
println("═══════════════════════════════════════════════════════════")
println("")
println("  PASS : " + to_string(pass_count))
println("  FAIL : " + to_string(fail_count))
println("  WARN : " + to_string(warn_count))
println("  TOTAL: " + to_string(pass_count + fail_count + warn_count))
println("")

if fail_count == 0 && warn_count == 0 {
    println("  VERDICT: ALL PASS — Phase 9 DFS logic verified end-to-end.")
} else if fail_count == 0 {
    println("  VERDICT: PASS with " + to_string(warn_count) + " warning(s) — DFS logic correct, minor observations noted.")
} else {
    println("  VERDICT: FAIL — " + to_string(fail_count) + " issue(s) found. See [FAIL] entries above.")
}
println("")
println("  Key findings:")
println("    - Flag passing: --dfs-current incremented, --dfs-session preserved, --fast excluded")
println("    - Termination: 4 conditions (depth/energy/target/visited) + fast_mode guard")
println("    - Visited file: session-isolated, exact-match grep, dual-write (target+domain)")
println("    - Race safety: sequential exec (parent blocks) -> single writer per session")
if warn_count > 0 {
    println("    - Warnings: see [WARN] entries for low-risk observations")
}
println("")
println("═══════════════════════════════════════════════════════════")
