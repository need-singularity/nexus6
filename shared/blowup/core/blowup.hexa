// ── discovery_log append (append_file 사용 — 전체 읽기 제거) ──
let mut new_entries = ""
li = 0
while li < len(buf_lines) {
    let line = buf_lines[li]
    if len(line) > 5 {
        let parts = line.split("\t")
        if len(parts) >= 7 {
            let mut conf: f64 = 0.0
            let mut value: f64 = 0.0
            try { conf = to_float(parts[3]) } catch e {}
            try { value = to_float(parts[4]) } catch e {}
            if conf >= 0.5 {
                let grade = match_grade(value)
                let name = match_name(value)
                let sector = sector_of(parts[2])
                let mut ai_d: i64 = 0
                let mut ai_r: i64 = 0
                if grade == "EXACT" && conf >= 0.8 {
                    ai_d = 1
                    ai_r = 0
                }
                if grade == "EXACT" && conf < 0.8 {
                    ai_r = 8
                }
                if grade != "EXACT" && conf >= 0.5 {
                    ai_r = 6
                }
                let dn = if name != "" { name } else { parts[0] }
                let entry = "{\"constant\":\"blowup-" + dn + "\",\"value\":\"" + to_string(value) + "\",\"source\":\"hexa-blowup-mk2\",\"timestamp\":\"2026-04-06\",\"grade\":\"" + grade + "\",\"processed\":true,\"alien_index\":{\"d\":" + to_string(ai_d) + ",\"r\":" + to_string(ai_r) + "},\"mk2\":{\"sector\":\"" + sector + "\",\"confidence\":" + to_string(conf) + ",\"paths\":1,\"prime_set\":[],\"layer\":" + to_string(ai_d) + "},\"blowup\":{\"type\":\"" + parts[1] + "\",\"src\":\"" + parts[6] + "\"},\"telescope\":{\"consensus\":" + to_string(tele_agree) + ",\"level\":\"" + tele_level + "\",\"boost\":" + to_string(tele_boost) + "},\"evolution\":{\"cycles\":" + to_string(evo_max_cycles) + ",\"best_score\":" + to_string(evo_best_score) + ",\"status\":\"" + evo_status + "\"}}"
                new_entries = new_entries + entry + "\n"
                logged = logged + 1
            }
        }
    }
    li = li + 1
}
if logged > 0 {
    append_file(log_path, new_entries)
}

if logged > 0 {
    println("  discovery_log:", logged, "entries ->", log_path)
}
if !skip_graph && graph_added_nodes > 0 {
