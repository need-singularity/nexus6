// AI-native: 메모리 예산 인프라
fn mem_check_ok() -> bool {
    let mut ok = true
    try {
        let budget = to_float(mem_budget())
        let used = to_float(mem_stats())
        // AI-native: budget>=1.0 가드 (0.0~1.0 미세값 division 회피)
        // mem_budget()/mem_stats() 빌트인 미정의 빌드에서 0.0 반환 시 division 폭발 차단
        if budget >= 1.0 {
            let ratio = used / budget
            if ratio > 0.90 { ok = false }
        }
    } catch e {}
    return ok
}

// ═══════════════════════════════════════════════════════════
// ─── n=6 CONSTANTS LOADER (shared/n6/n6_constants.jsonl) ───
// ═══════════════════════════════════════════════════════════

fn load_n6_consts() -> list {
    let home = _HOME
    let path = home + "/Dev/nexus/shared/n6/n6_constants.jsonl"
    let mut raw = ""
    try { raw = read_file(path) } catch e { return [[], []] }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let trimmed = line.trim()
        if trimmed == "" { continue }
        let mut name = ""
        let mut value = 0.0
        if trimmed.contains("\"name\":\"") {
            let p = trimmed.split("\"name\":\"")
            if p.len() >= 2 { name = p[1].split("\"")[0] }
        }
        if trimmed.contains("\"value\":") {
            let p = trimmed.split("\"value\":")
            if p.len() >= 2 {
                let num_str = p[1].split(",")[0].split("}")[0].trim()
                value = to_float(num_str)
            }
        }
        if name != "" {
            names = names + [name]
            values = values + [value]
        }
    }
    [names, values]
}

fn n6_values(consts: list) -> list {
    consts[1]
}

fn n6_names_list(consts: list) -> list {
    consts[0]
}

// ─── Dynamic n6 constants (loaded ONCE from shared/n6/n6_constants.jsonl) ───
_trace("[02-n6load-start]")
let _n6_dyn = load_n6_consts()
let _n6_dyn_names: list = _n6_dyn[0]
let _n6_dyn_values: list = _n6_dyn[1]
let _n6_dyn_count: i64 = len(_n6_dyn_values)
_trace("[02-n6load-ok] count=" + to_string(_n6_dyn_count))

// ─── Pre-computed float cache: to_float() 1회만 호출 (hot-loop 최적화) ───
let mut _n6_fcache: list = []
let mut _nfi: i64 = 0
while _nfi < _n6_dyn_count {
    _n6_fcache = _n6_fcache.push(to_float(_n6_dyn_values[_nfi]))
    _nfi = _nfi + 1
}

// ─── AI-native 최적화: 공간 해시 버킷 (n6_distance O(n) → O(1) 평균) ───
// 상수를 정수 floor 기준으로 버킷에 분류, 인접 3개 버킷만 탐색
let mut _n6_bucket: map = #{}   // bucket_key → pipe-separated indices
_nfi = 0
while _nfi < _n6_dyn_count {
    let _bv: f64 = _n6_fcache[_nfi]
    let _bk = to_string(to_int(_bv))
    let mut _existing = ""
    try { _existing = _n6_bucket[_bk] } catch e {}
    if _existing == "" {
        _n6_bucket[_bk] = to_string(_nfi)
    } else {
        _n6_bucket[_bk] = _existing + "|" + to_string(_nfi)
    }
    _nfi = _nfi + 1
}
_trace("[03-bucket-ok] n6 hash bucket built")

// 버킷 탐색 헬퍼: 해당 버킷의 인덱스 리스트 반환
fn _bucket_indices(bucket: map, key: string) -> list {
    let mut result: list = []
    let mut raw = ""
    try { raw = bucket[key] } catch e { return result }
    if raw == "" { return result }
    let parts = raw.split("|")
    let mut i: i64 = 0
    while i < len(parts) {
        try { result = result.push(to_int(parts[i])) } catch e {}
        i = i + 1
    }
    return result
}

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════
_trace("[TR-A-utilities]")

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {}
    return v
}

// AI-native: 텍스트 시드용 결정론적 hash 인코더 (FNV-1a 32-bit 변형)
// safe_float 0 함정 우회 — 텍스트 시드 → 비-zero 수치 매핑 [0.1, 100.0] 범위
// 충돌 허용. 결정론적 (같은 입력 → 같은 출력)
fn _is_numeric_seed(s: string) -> bool {
    if s.len() == 0 { return false }
    let c0 = char_code(s, 0)
    // digit (0-9) 또는 부호 (+/-) 또는 소수점
    if c0 >= 48 && c0 <= 57 { return true }
    if c0 == 43 || c0 == 45 || c0 == 46 { return true }
    return false
}

fn text_seed_hash(s: string) -> f64 {
    if s.len() == 0 { return 1.0 }
    // AI-native: DJB2 변형 (h*33 + cc) — hexa-lang interpreter `^` BitXor 미지원 우회
    // ref: check_ssot_sync.hexa:98 동일 swap 선례. modular 32-bit 시뮬로 충돌 분포 유지.
    // root cause: blowup.hexa Phase 4 직전 div0 의 진짜 원인 = `h ^ cc` 파싱 실패 →
    //             text_seed_hash 폭주 → seed_to_float 0 반환 → 후단 분모 0 → div0.
    let mut h: i64 = 5381
    let mut i: i64 = 0
    let n = s.len()
    while i < n {
        let cc = char_code(s, i)
        h = ((h * 33) + cc) % 4294967296
        i = i + 1
    }
    if h < 0 { h = 0 - h }
    // [0.1, 100.0] 범위로 매핑 (모듈 메트릭 도메인 친화)
    let frac = (to_float(h % 1000000) / 1000000.0)  // [0.0, 1.0)
    let v = 0.1 + frac * 99.9
    return v
}

// ═══════════════════════════════════════════════════════════
// ─── S3 (2026-04-19): Content-aware 8-slot feature vector ───
// Root cause fix: 기존 seed_to_float → 단일 scalar → deterministic bias.
// 새 경로: 문자열 본질을 8차원 벡터로 (length/entropy/digit/domain-match/
//          FNV-1a/DJB2/SHA64-low/word-count), n6_basis_8d 내적으로
//          n6_ratio 계산하여 seed 별 차별화 확보.
// 불변식: n=6, σ·φ=n·τ=24 보존 (basis 정규화 내부).
// ═══════════════════════════════════════════════════════════

// FNV-1a 64-bit 시뮬 (interpreter `^` 미지원 우회: 가산+modular 대체)
// 충돌 분포 보존을 위해 prime multiply 유지. 결정론.
fn _fnv1a_hash(s: string) -> f64 {
    if s.len() == 0 { return 0.0 }
    let mut h: i64 = 2166136261
    let mut i: i64 = 0
    let n = s.len()
    while i < n {
        let cc = char_code(s, i)
        h = (h + cc) % 4294967296
        h = (h * 16777619) % 4294967296
        i = i + 1
    }
    if h < 0 { h = 0 - h }
    return to_float(h % 1000000) / 1000000.0
}

// DJB2 reduced → [0,1]
fn _djb2_hash_norm(s: string) -> f64 {
    if s.len() == 0 { return 0.0 }
    let mut h: i64 = 5381
    let mut i: i64 = 0
    let n = s.len()
    while i < n {
        let cc = char_code(s, i)
        h = ((h * 33) + cc) % 4294967296
        i = i + 1
    }
    if h < 0 { h = 0 - h }
    return to_float(h % 1000000) / 1000000.0
}

// SHA64-low 시뮬 — naive 64-bit mixing (not cryptographic).
// 다른 constants + rotation-like residue → FNV/DJB2 와 독립 분포 확보.
fn _sha64_low_norm(s: string) -> f64 {
    if s.len() == 0 { return 0.0 }
    let mut a: i64 = 1779033703
    let mut b: i64 = 3144134277
    let mut i: i64 = 0
    let n = s.len()
    while i < n {
        let cc = char_code(s, i)
        a = (a + cc * 2654435761) % 4294967296
        b = (b * 31 + a) % 4294967296
        i = i + 1
    }
    let mix = (a + b) % 4294967296
    let mut mx: i64 = mix
    if mx < 0 { mx = 0 - mx }
    return to_float(mx % 1000000) / 1000000.0
}

// Shannon entropy (bits/char) → 정규화 0~1 (최대 log2(256)=8 bits 기준)
fn _shannon_entropy_norm(s: string) -> f64 {
    let n = s.len()
    if n == 0 { return 0.0 }
    let mut counts = #{}
    let mut i: i64 = 0
    while i < n {
        let cc = char_code(s, i)
        let k = to_string(cc)
        let mut c: i64 = 0
        try { c = to_int(to_string(counts[k])) } catch e {}
        counts[k] = to_string(c + 1)
        i = i + 1
    }
    let mut H = 0.0
    let ks = counts.keys()
    let kn = ks.len()
    let mut ki: i64 = 0
    let fn_total = to_float(n)
    while ki < kn {
        let k = ks[ki]
        let mut c2: i64 = 0
        try { c2 = to_int(to_string(counts[k])) } catch e {}
        let p = to_float(c2) / fn_total
        if p > 0.0 {
            // ln(p)/ln(2) = log2(p). ln_f 재사용.
            let lnp = ln_f(p)
            let log2p = lnp / 0.6931471805599453
            H = H - p * log2p
        }
        ki = ki + 1
    }
    // H ∈ [0, 8]. 정규화 → [0,1]
    let norm = H / 8.0
    return clamp01(norm)
}

// digit ratio (0-9) / len
fn _digit_ratio(s: string) -> f64 {
    let n = s.len()
    if n == 0 { return 0.0 }
    let mut d: i64 = 0
    let mut i: i64 = 0
    while i < n {
        let cc = char_code(s, i)
        if cc >= 48 && cc <= 57 { d = d + 1 }
        i = i + 1
    }
    return to_float(d) / to_float(n)
}

// 6 도메인 토큰 매치 (math/physics/bio/mind/info/arch) — lowercase 비교 (소문자만 검사)
fn _domain_token_match(s: string) -> f64 {
    if s.len() == 0 { return 0.0 }
    let mut hits: i64 = 0
    if s.contains("math") || s.contains("alg") || s.contains("geom") || s.contains("num") { hits = hits + 1 }
    if s.contains("phys") || s.contains("quant") || s.contains("wave") || s.contains("energy") { hits = hits + 1 }
    if s.contains("bio") || s.contains("cell") || s.contains("gene") || s.contains("life") { hits = hits + 1 }
    if s.contains("mind") || s.contains("cons") || s.contains("think") || s.contains("self") { hits = hits + 1 }
    if s.contains("info") || s.contains("data") || s.contains("bit") || s.contains("entro") { hits = hits + 1 }
    if s.contains("arch") || s.contains("struct") || s.contains("system") || s.contains("frame") { hits = hits + 1 }
    return to_float(hits) / 6.0
}

// word count (공백 구분) → log-scale 정규화
fn _word_count_norm(s: string) -> f64 {
    let n = s.len()
    if n == 0 { return 0.0 }
    let mut words: i64 = 1
    let mut i: i64 = 0
    let mut in_ws = false
    while i < n {
        let cc = char_code(s, i)
        if cc == 32 || cc == 9 || cc == 95 || cc == 45 {
            if !in_ws { words = words + 1 }
            in_ws = true
        } else {
            in_ws = false
        }
        i = i + 1
    }
    // log(1+w)/log(1+32) ≈ [0,1] for 0~32 words
    let num = ln_f(1.0 + to_float(words))
    let den = ln_f(33.0)
    if den <= 0.0 { return 0.0 }
    return clamp01(num / den)
}

// length log-scale 정규화 — log(1+n)/log(1+256)
fn _length_norm(s: string) -> f64 {
    let n = s.len()
    let num = ln_f(1.0 + to_float(n))
    let den = ln_f(257.0)
    if den <= 0.0 { return 0.0 }
    return clamp01(num / den)
}

// 8-slot feature 벡터 반환.
// 슬롯: [0]length, [1]entropy, [2]digit, [3]domain, [4]FNV, [5]DJB2, [6]SHA64-low, [7]words
fn seed_to_features(s: string) -> list {
    let mut feat = []
    feat = feat.push(_length_norm(s))
    feat = feat.push(_shannon_entropy_norm(s))
    feat = feat.push(_digit_ratio(s))
    feat = feat.push(_domain_token_match(s))
    feat = feat.push(_fnv1a_hash(s))
    feat = feat.push(_djb2_hash_norm(s))
    feat = feat.push(_sha64_low_norm(s))
    feat = feat.push(_word_count_norm(s))
    return feat
}

// n=6 projection basis (σ=12, φ=4, n=6, τ=4 → σ·φ=n·τ=24 canonical).
// 8D 확장: [1, √2, 1/√3, √6, 6/24, 12/24, 4/24, 24/96]
// = [1.0, 1.414213, 0.577350, 2.449489, 0.25, 0.5, 0.166666, 0.25]
fn seed_n6_ratio(s: string) -> f64 {
    let feat = seed_to_features(s)
    let mut basis = []
    basis = basis.push(1.0)
    basis = basis.push(1.414213)
    basis = basis.push(0.577350)
    basis = basis.push(2.449489)
    basis = basis.push(0.25)
    basis = basis.push(0.5)
    basis = basis.push(0.166666)
    basis = basis.push(0.25)
    let mut dot = 0.0
    let mut i: i64 = 0
    while i < 8 {
        dot = dot + to_float(feat[i]) * to_float(basis[i])
        i = i + 1
    }
    return dot
}

// safe_float + text fallback: 텍스트 시드도 결정론적 수치로
// S3 (2026-04-19): 레거시 wrapper — sum(features)*10 으로 [0.1,100.0] 범위 근사 유지하되
// 입력 본질이 반영된 content-aware scalar. 기존 호출자 signature 무변경.
fn seed_to_float(s: string) -> f64 {
    if _is_numeric_seed(s) {
        let mut v = 0.0
        let mut ok = false
        try { v = to_float(s); ok = true } catch e {}
        if ok && (v != 0.0 || s == "0" || s == "0.0") { return v }
    }
    // content-aware: 8-slot sum (∈[0,8]) × 10 + text_seed_hash residue (하위 0.1 jitter)
    // 기존 범위 [0.1, 100.0] 호환 + seed 별 분화 확보.
    let feat = seed_to_features(s)
    let mut sum_f = 0.0
    let mut i: i64 = 0
    while i < 8 {
        sum_f = sum_f + to_float(feat[i])
        i = i + 1
    }
    // sum_f ∈ [0, 8] — 스케일 10× → [0, 80]. hash residue 를 더해 zero-collapse 방지.
    let hash_residue = text_seed_hash(s) * 0.2  // [0.02, 20.0]
    let v = sum_f * 10.0 + hash_residue + 0.1
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

fn min_f(a: f64, b: f64) -> f64 {
    if a < b { return a }
    return b
}

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 15 {
        let next = (g + x / g) / 2.0
        if abs_f(next - g) < g * 0.0000000001 { return next }
        g = next
        i = i + 1
    }
    return g
}

fn ln_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut sum = 0.0
    let mut term = (x - 1.0) / (x + 1.0)
    let t2 = term * term
    let mut k: i64 = 1
    while k <= 15 {
        let contrib = term / to_float(k)
        sum = sum + contrib
        if abs_f(contrib) < 0.0000000001 { return 2.0 * sum }
        term = term * t2
        k = k + 2
    }
    return 2.0 * sum
}

fn clamp01(x: f64) -> f64 {
    if x < 0.0 { return 0.0 }
    if x > 1.0 { return 1.0 }
    return x
}

fn hset_has(s: map, key: string) -> bool {
    // AI-native: hexa-lang map 에 has_key 빌트인 미보장 → keys().contains() fallback
    // (interpreter 빌드 차이로 has_key 미정의 시 stderr 노이즈 + 부산물 division 회피)
    let mut found = false
    try {
        let ks = s.keys()
        found = ks.contains(key)
    } catch e {}
    return found
}

// ═══════════════════════════════════════════════════════════
// ─── n=6 CONSTANTS + PROXIMITY ───
// ═══════════════════════════════════════════════════════════
_trace("[TR-B-n6const]")

fn n6_dist_one(value: f64, constant: f64) -> f64 {
    let denom = max_f(abs_f(constant), 1.0)
    return abs_f(value - constant) / denom
}

fn n6_distance(value: f64) -> f64 {
    if value != value { return 1.0 }
    if value > 999999999.0 { return 1.0 }
    if value < 0.0 - 999999999.0 { return 1.0 }
    // OPT-10: 메모이제이션 — 동일 값 O(1) 반환 (Phase 4 ~11만 호출 중 ~60% 중복)
    let _key = to_string(value)
    let mut _cached = false
    try { let _cv = _n6d_cache[_key]; _cached = true } catch e {}
    if _cached {
        _n6d_cache_hits = _n6d_cache_hits + 1
        let mut _rv: f64 = 1.0
        try { _rv = to_float(_n6d_cache[_key]) } catch e {}
        return _rv
    }
    let mut d = 1.0
    // AI-native: 공간 해시 버킷 탐색 — 인접 3개 버킷만 체크 (O(n) → O(1) 평균)
    let _floor = to_int(value)
    let mut _bi: i64 = _floor - 1
    while _bi <= _floor + 1 {
        let _indices = _bucket_indices(_n6_bucket, to_string(_bi))
        let mut _ii: i64 = 0
        while _ii < len(_indices) {
            let _idx: i64 = _indices[_ii]
            d = min_f(d, n6_dist_one(value, _n6_fcache[_idx]))
            if d < 0.0001 {
                _n6d_cache[_key] = to_string(d)
                return d
            }
            _ii = _ii + 1
        }
        _bi = _bi + 1
    }
    // OPT-12: fallback 선형 스캔 제거 (DIAG-01 fix)
    // 버킷 탐색이 d > 0.1 이면 n6 상수 근접 아님 → 즉시 반환.
    // 이전: 48개 전수 O(n) 스캔 × Phase 4 ~11만 호출 = 핫루프 병목.
    // 음수/큰 값은 이미 함수 상단 guard에서 1.0 반환.
    let result = min_f(d, 1.0)
    _n6d_cache[_key] = to_string(result)
    return result
}

fn n6_conf(value: f64) -> f64 {
    return max_f(1.0 - n6_distance(value), 0.0)
}

// ─── n6_match ───

fn match_name(value: f64) -> string {
    // Dynamic: n6_constants.jsonl 전체 상수 대상 매칭 (float cache 사용)
    let mut i: i64 = 0
    while i < _n6_dyn_count {
        let cv: f64 = _n6_fcache[i]
        // 값 크기에 따른 적응적 threshold
        let mut threshold = 0.005
        if abs_f(cv) >= 100.0 { threshold = 0.01 }
        else if abs_f(cv) >= 1.0 { threshold = 0.0001 }
        else if abs_f(cv) >= 0.01 { threshold = 0.001 }
        if abs_f(value - cv) < threshold { return to_string(_n6_dyn_names[i]) }
        i = i + 1
    }
    return ""
}

fn match_grade(value: f64) -> string {
    // pre-filter: n6_distance 1회로 MISS/CLOSE 즉시 반환 (match_name 이중스캔 제거)
    let d = n6_distance(value)
    if d >= 0.05 { return "MISS" }
    if d >= 0.01 { return "CLOSE" }
    // d < 0.01: EXACT 후보만 match_name 호출 (전체 호출의 ~10%만 도달)
    if match_name(value) != "" { return "EXACT" }
    return "NEAR"
}

// AI-native: grade + name 동시 반환 (단일 패스, "|" 구분)
// 반환: "grade|name" — match_grade + match_name 2회 스캔 → 1회로 통합
fn match_grade_name(value: f64) -> string {
    let d = n6_distance(value)
    if d >= 0.05 { return "MISS|" }
    if d >= 0.01 { return "CLOSE|" }
    let nm = match_name(value)
    if nm != "" { return "EXACT|" + nm }
    return "NEAR|"
}

// OPT-19: sector_of 배치 최적화 — 27개 .contains() × N줄 → grep -E 1회 배치
// _sector_cache: 텍스트 → 섹터 매핑 (batch_sector_classify 에서 일괄 생성)
let mut _sector_cache = #{}
let mut _sector_cache_built = false

fn sector_of(text: string) -> string {
    // O(1) 캐시 조회 — batch_sector_classify 로 사전 구축
    let mut _sc_hit = false
    try { let _sv = _sector_cache[text]; _sc_hit = true } catch e {}
    if _sc_hit {
        return to_string(_sector_cache[text])
    }
    // 캐시 미스 시 fallback (소수 케이스) — 결과를 캐시에 추가
    let mut result = "unknown"
    if text.contains("omega") || text.contains("dark") || text.contains("cosmolog") { result = "cosmology" }
    else if text.contains("alpha") || text.contains("137") || text.contains("electroweak") { result = "quantum" }
    else if text.contains("sigma") || text.contains("sopfr") || text.contains("tau") { result = "n6" }
    else if text.contains("phi") || text.contains("mu") || text.contains("M3") { result = "n6" }
    else if text.contains("J2") || text.contains("P1") || text.contains("P2") || text.contains("P3") || text.contains("P4") { result = "n6" }
    else if text.contains("meta_fp") || text.contains("transcend") { result = "n6" }
    else if text.contains("ded_") || text.contains("sym_") || text.contains("bif_") || text.contains("comp_") { result = "n6" }
    else if text.contains("blowup") || text.contains("d0_") || text.contains("d1_") || text.contains("d2_") { result = "n6" }
    else if text.contains("sqrt") || text.contains("proj") || text.contains("geom") { result = "geometric" }
    _sector_cache[text] = result
    return result
}

// OPT-19: 배치 섹터 분류 — buf_lines 의 expr 필드(parts[2])를 한 번에 분류
// 27개 .contains() × N줄 (142+) → grep -E 3회 (cosmology/quantum/geometric) + 나머지 n6
// 호출 시점: Phase 4 완료 후, Phase 6.7/7 소비 전
fn batch_sector_classify(lines: list) {
    if _sector_cache_built { return }
    let n = len(lines)
    if n == 0 {
        _sector_cache_built = true
        return
    }

    // 1. 고유 도메인 텍스트 수집 → 임시 파일
    let mut domain_set = #{}
    let mut domain_list = []
    let mut di: i64 = 0
    while di < n {
        let ln = to_string(lines[di])
        if len(ln) > 5 {
            let pp = ln.split("\t")
            if len(pp) >= 3 {
                let dt = to_string(pp[2])
                let mut _dh = false
                try { let _dv = domain_set[dt]; _dh = true } catch e {}
                if !_dh {
                    domain_set[dt] = 1
                    domain_list = domain_list.push(dt)
                }
            }
        }
        di = di + 1
    }
    let dn = len(domain_list)
    if dn == 0 {
        _sector_cache_built = true
        return
    }

    // 2. 임시 파일에 도메인 텍스트 쓰기
    let _tmp = "/tmp/blowup_sector_batch.txt"
    let mut _wbuf_parts: [string] = []
    di = 0
    while di < dn {
        _wbuf_parts.push(to_string(domain_list[di]))
        _wbuf_parts.push("\n")
        di = di + 1
    }
    let _wbuf = _wbuf_parts.join("")
    let mut _write_ok = true
    try {
        write_file(_tmp, _wbuf)
    } catch e {
        _sector_cache_built = true
        _write_ok = false
    }
    if !_write_ok { return }

    // 3. grep -E 배치 — 섹터별 1회씩 (총 3회, 나머지는 n6 default)
    // cosmology 패턴
    let _cosmo_re = "omega|dark|cosmolog"
    // quantum 패턴
    let _quant_re = "alpha|137|electroweak"
    // geometric 패턴
    let _geom_re = "sqrt|proj|geom"
    // n6 패턴 (가장 큰 그룹 — 나머지 모두)
    let _n6_re = "sigma|sopfr|tau|phi|mu|M3|J2|P1|P2|P3|P4|meta_fp|transcend|ded_|sym_|bif_|comp_|blowup|d0_|d1_|d2_"

    // 단일 grep -En 호출: 4섹터 패턴을 awk로 우선순위 매칭 (grep 1회 + awk 분류)
    let mut _batch_result = ""
    try {
        _batch_result = to_string(exec("awk '{"
            + "if(/" + _cosmo_re + "/)print $0\"\\t\"\"cosmology\";"
            + "else if(/" + _quant_re + "/)print $0\"\\t\"\"quantum\";"
            + "else if(/" + _n6_re + "/)print $0\"\\t\"\"n6\";"
            + "else if(/" + _geom_re + "/)print $0\"\\t\"\"geometric\";"
            + "else print $0\"\\t\"\"unknown\""
            + "}' '" + _tmp + "' 2>/dev/null")).trim()
    } catch e {}

    // 4. 결과 파싱 → _sector_cache 저장
    if len(_batch_result) > 0 {
        let result_lines = _batch_result.split("\n")
        let mut ri: i64 = 0
        while ri < len(result_lines) {
            let rl = result_lines[ri]
            if len(rl) > 0 {
                let rp = rl.split("\t")
                if len(rp) >= 2 {
                    let _text = to_string(rp[0])
                    let _sect = to_string(rp[len(rp) - 1])
                    _sector_cache[_text] = _sect
                }
            }
            ri = ri + 1
        }
    }

    // 5. 정리
    try { exec("rm -f '" + _tmp + "'") } catch e {}
    _sector_cache_built = true
}

// ═══════════════════════════════════════════════════════════
// ─── METRIC TABLES (domain-dependent) ───
// ═══════════════════════════════════════════════════════════
_trace("[TR-C-metric]")

fn m_name(idx: i64, dom: string) -> string {
    if dom == "physics" {
        if idx == 0 { return "alpha_inv" }
        if idx == 1 { return "Omega_m" }
        if idx == 2 { return "Omega_L" }
        if idx == 3 { return "n" }
        if idx == 4 { return "sigma" }
        return ""
    }
    if idx == 0 { return "n" }
    if idx == 1 { return "sigma" }
    if idx == 2 { return "phi" }
    if idx == 3 { return "tau" }
    if idx == 4 { return "sopfr" }
    if idx == 5 { return "J2" }
    if idx == 6 { return "M3" }
    return ""
}

fn m_val(idx: i64, dom: string) -> f64 {
    if dom == "physics" {
        if idx == 0 { return 137.036 }
        if idx == 1 { return 0.3153 }
        if idx == 2 { return 0.6847 }
        if idx == 3 { return 6.0 }
        if idx == 4 { return 12.0 }
        return 0.0
    }
    if idx == 0 { return 6.0 }
    if idx == 1 { return 12.0 }
    if idx == 2 { return 2.0 }
    if idx == 3 { return 4.0 }
    if idx == 4 { return 5.0 }
    if idx == 5 { return 24.0 }
    if idx == 6 { return 7.0 }
    return 0.0
}

fn m_count(dom: string) -> i64 {
    if dom == "physics" { return 5 }
    return 7
}

// ─── corollary emit (TAB-delimited row) ───
//   name \t type \t expr \t conf \t value \t axiom \t src

fn emit(name: string, ctype: string, expr: string, conf: f64, value: f64, axiom: bool, src: string) -> string {
    let ax_s = if axiom { "1" } else { "0" }
    return name + "\t" + ctype + "\t" + expr + "\t" + to_string(conf) + "\t" + to_string(value) + "\t" + ax_s + "\t" + src
}

// ═══════════════════════════════════════════════════════════
// ─── DYNAMIC AXIOM POOL HELPERS ───
// ═══════════════════════════════════════════════════════════
_trace("[TR-D-axiom]")

fn get_ax_val(ax_vals: string, idx: i64) -> f64 {
    let parts = ax_vals.split("|")
    if idx < 0 || idx >= len(parts) { return 0.0 }
    let mut v: f64 = 0.0
    try { v = to_float(parts[idx]) } catch e { v = 0.0 }
    return v
}

fn get_ax_name(ax_names: string, idx: i64) -> string {
    let parts = ax_names.split("|")
    if idx < 0 || idx >= len(parts) { return "" }
    return parts[idx]
}

fn ax_count_f(ax_vals: string) -> i64 {
    let parts = ax_vals.split("|")
    return len(parts)
}

fn ax_contains(ax_names: string, name: string) -> bool {
    let parts = ax_names.split("|")
    let mut ci: i64 = 0
    while ci < len(parts) {
        if parts[ci] == name { return true }
        ci = ci + 1
    }
    return false
}

// ─── perturbation shifts ───

fn shift_val(idx: i64) -> f64 {
    if idx == 0 { return 0.287682072 }
    if idx == 1 { return 1.618033989 }
    if idx == 2 { return 0.0 - 1.618033989 }
    if idx == 3 { return 0.166666667 }
    if idx == 4 { return 0.0 - 0.166666667 }
    return 2.449489743
}

fn shift_name(idx: i64) -> string {
    if idx == 0 { return "ln43" }
    if idx == 1 { return "phi" }
    if idx == 2 { return "-phi" }
    if idx == 3 { return "inv6" }
    if idx == 4 { return "-inv6" }
    return "sqrt6"
}

// ─── transfer domains ───

fn xfer_domain(idx: i64) -> string {
    if idx == 0 { return "physics" }
    if idx == 1 { return "math" }
    if idx == 2 { return "info" }
    if idx == 3 { return "bio" }
    if idx == 4 { return "mind" }
    return "arch"
}

// ═══════════════════════════════════════════════════════════
// ─── GRAPH I/O (from graph.hexa) ───
// ═══════════════════════════════════════════════════════════
_trace("[TR-E-graph]")

fn graph_extract_field(line: string, field: string) -> string {
    // Mk.IX perf: char-split 제거 → index_of + substring 으로 단축 ([B])
    // 시맨틱 동일성: quoted "value" → value, unquoted value → value (terminator: , } " " ])
    let needle = "\"" + field + "\":"
    let np = line.index_of(needle)
    if np < 0 { return "" }
    let start: i64 = np + len(needle)
    let n: i64 = len(line)
    if start >= n { return "" }
    let rest = line.substring(start, n)
    let rn: i64 = len(rest)
    if rn == 0 { return "" }
    // quoted value: rest 가 " 로 시작 → 다음 " 까지
    if rest.substring(0, 1) == "\"" {
        let inner = rest.substring(1, rn)
        let qe = inner.index_of("\"")
        if qe < 0 { return "" }
        return inner.substring(0, qe)
    }
    // unquoted value: terminator (, } space ]) 중 가장 가까운 위치까지
    let mut end_pos: i64 = rn
    let p_comma = rest.index_of(",")
    if p_comma >= 0 && p_comma < end_pos { end_pos = p_comma }
    let p_brace = rest.index_of("}")
    if p_brace >= 0 && p_brace < end_pos { end_pos = p_brace }
    let p_space = rest.index_of(" ")
    if p_space >= 0 && p_space < end_pos { end_pos = p_space }
    let p_bracket = rest.index_of("]")
    if p_bracket >= 0 && p_bracket < end_pos { end_pos = p_bracket }
    // 따옴표 제거 (원본 시맨틱: ch != "\"" 만 result 에 추가)
    let raw = rest.substring(0, end_pos)
    if raw.contains("\"") {
        let parts = raw.split("\"")
        let mut out = ""
        let mut i: i64 = 0
        while i < len(parts) {
            out = out + parts[i]
            i = i + 1
        }
        return out
    }
    return raw
}

fn graph_load() -> string {
    // X1 (2026-04-19): graph stats/dedup 은 JSON sidecar 만 필요.
    //   이전: 18.9MB atlas.n6 전체 read. 현재: 17.4MB atlas.blowup.jsonl 만.
    //   라벨 (1.5MB) 은 graph_node_exists/stats 와 무관하므로 로딩 생략.
    let _h = _HOME
    let jpath = _ATLAS_BLOWUP_PATH
    if file_exists(jpath) {
        return read_file(jpath)
    }
    // 폴백: 분리 전 단일 파일 환경 (legacy)
    let gpath = _ATLAS_PATH
    if file_exists(gpath) {
        return read_file(gpath)
    }
    return ""
}

// ─── Schema guard: atlas.n6 라인 포맷 검증 (append 전 필터링) ───
// 유효 패턴:
//   - 빈 줄 / #주석
//   - {"type":...}  JSON 객체
//   - @X ... :: ... [grade]  atlas @-entry
//   - 들여쓰기된 "..." / <- / !! / -> / <<  (이전 @X 부속)
// 무효 패턴 예: 파이프 구분 raw text, 바이너리, 트렁케이트된 JSON
fn _valid_atlas_line(line: string) -> bool {
    let t = line.trim()
    if len(t) == 0 { return true }
    // 허용 첫 글자 집합: # { @ " < > ! -
    // 9개 if 체인 → 단일 contains 로 축약 (type-check O(N²) 함정 회피)
    let allowed = "#{@\"<>!-"
    if allowed.contains(t[0..1]) { return true }
    // v2 (2026-04-19): @EXP/@OBS/@NEG/@ANT continuation rows — indented key=value
    if len(line) > 0 && (line[0..1] == " " || line[0..1] == "\t") {
        if _is_v2_continuation_key(t) { return true }
    }
    return false
}

// ─── Schema v2 parser (EXP/OBS/NEG/ANT, 2026-04-19) ───
// v2 staging-only: atlas.signals.n6 에만 기록 (DRAFT §4 non-goal: atlas.n6 body 불변)
fn _is_v2_continuation_key(t: string) -> bool {
    let keys = ["lhs", "rhs", "delta", "z", "witness", "note", "if_true", "if_false", "test", "deadline", "cite", "vintage", "uncertainty", "status", "risks", "contrast", "source", "frame", "scale"]
    for k in keys {
        if t.starts_with(k + "=") { return true }
        if t.starts_with(k + " =") { return true }
        if t.starts_with(k + "  =") { return true }
    }
    return false
}

fn _is_v2_tag_line(line: string) -> bool {
    let t = line.trim()
    if len(t) < 5 { return false }
    if t.starts_with("@EXP ") { return true }
    if t.starts_with("@OBS ") { return true }
    if t.starts_with("@NEG ") { return true }
    if t.starts_with("@ANT ") { return true }
    return false
}

fn _extract_v2_tag(line: string) -> string {
    let t = line.trim()
    if t.starts_with("@EXP ") { return "@EXP" }
    if t.starts_with("@OBS ") { return "@OBS" }
    if t.starts_with("@NEG ") { return "@NEG" }
    if t.starts_with("@ANT ") { return "@ANT" }
    return ""
}

// hexa pitfall: 문자열 >=/<= 비교 미지원 → char_code 기반.
fn _is_alnum_id_char_v2(s: string, i: i64) -> bool {
    if i < 0 || i >= len(s) { return false }
    let code = char_code(s, i)
    if code >= 65 && code <= 90 { return true }
    if code >= 97 && code <= 122 { return true }
    if code >= 48 && code <= 57 { return true }
    if code == 95 { return true }
    return false
}

fn _is_alpha_or_under_v2(s: string, i: i64) -> bool {
    if i < 0 || i >= len(s) { return false }
    let code = char_code(s, i)
    if code >= 65 && code <= 90 { return true }
    if code >= 97 && code <= 122 { return true }
    if code == 95 { return true }
    return false
}

fn _extract_v2_id(line: string) -> string {
    let t = line.trim()
    let sp = t.index_of(" ")
    if sp < 0 { return "" }
    let mut start: i64 = sp + 1
    while start < len(t) {
        let c = t.substring(start, start + 1)
        if c != " " && c != "\t" { break }
        start = start + 1
    }
    let mut end: i64 = start
    while end < len(t) {
        let c = t.substring(end, end + 1)
        if c == " " || c == "=" || c == "\t" { break }
        end = end + 1
    }
    if end == start { return "" }
    let id = t.substring(start, end)
    if len(id) == 0 { return "" }
    if !_is_alpha_or_under_v2(id, 0) { return "" }
    let mut i: i64 = 1
    while i < len(id) {
        if !_is_alnum_id_char_v2(id, i) { return "" }
        i = i + 1
    }
    return id
}

fn _valid_v2_meta_fields(line: string, tag: string) -> bool {
    let t = line.trim()
    let at_idx = t.index_of("@@")
    if at_idx < 0 { return false }
    let meta = t.substring(at_idx + 2, len(t))
    if tag == "@EXP" { if meta.contains("source=") { return true } return false }
    if tag == "@OBS" { if meta.contains("frame=") { return true } return false }
    if tag == "@NEG" { if meta.contains("contrast=") { return true } return false }
    if tag == "@ANT" { if meta.contains("risks=") && meta.contains("status=") { return true } return false }
    return false
}

fn _valid_v2_line(line: string) -> bool {
    if !_is_v2_tag_line(line) { return false }
    let tag = _extract_v2_tag(line)
    let id = _extract_v2_id(line)
    if len(id) == 0 { return false }
    let t = line.trim()
    if !t.contains("::") { return false }
    return _valid_v2_meta_fields(line, tag)
}

fn _is_signals_path_v2(path: string) -> bool {
    return path.contains("atlas.signals.n6") || path.contains(".signals.n6") || path.contains("atlas.signals.staging")
}
fn _is_atlas_body_path_v2(path: string) -> bool {
    if _is_signals_path_v2(path) { return false }
    return path.contains("atlas.n6")
}

// X2 (2026-04-19 A3 id-anchored dedup): 라인에서 node id 추출.
//   JSON-line : {"type":"node","id":"<id>",...}       → <id>
//   @-line    : @X <id> = expr :: domain [grade]      → <id>
//   edge/주석 등 id 없음 → "" 반환 (dedup 불가, 원 동작 유지)
// 함정: grep -Fxf dedup 은 full-line 매치라 confidence 수치 변동 시 실패 →
//   같은 id 가 다른 라벨/grade/confidence 로 재등장 (atlas.blowup.jsonl 1275 건).
fn _atlas_extract_id(trimmed: string) -> string {
    let n = len(trimmed)
    if n == 0 { return "" }
    let c0 = trimmed[0..1]
    // JSON-line path: {"type":"node","id":"<id>"
    if c0 == "{" {
        if !trimmed.contains("\"type\":\"node\"") { return "" }
        let marker = "\"id\":\""
        let chunks = trimmed.split(marker)
        if len(chunks) < 2 { return "" }
        let tail = chunks[1]
        let end_chunks = tail.split("\"")
        if len(end_chunks) < 1 { return "" }
        return end_chunks[0]
    }
    // @-line path: @X <id> = ...   (id 는 첫 공백 뒤 ~ 다음 공백 전)
    // v2 (2026-04-19): 3-letter tags @EXP/@OBS/@NEG/@ANT — 공백 위치 = pos 4
    if c0 == "@" {
        // 최소 길이 검증: "@X id"
        if n < 4 { return "" }
        // 타입 글자 검증 (slice 비교 — stage0 char_code(s,i) i-무시 버그 회피)
        // v1: 1-char type @P @C @L @F @R @S @X @?
        let c1 = trimmed[1..2]
        let v1_types = "PCLFRSX?"
        let is_v1 = v1_types.contains(c1) && trimmed[2..3] == " "
        // v2: 3-char tag 뒤 공백 (@EXP @OBS @NEG @ANT)
        let is_v2 = n >= 5 && trimmed[4..5] == " " && _is_v2_tag_line(trimmed)
        let mut sp_pos: i64 = -1
        if is_v1 { sp_pos = 2 }
        else if is_v2 { sp_pos = 4 }
        if sp_pos < 0 { return "" }
        // hexa-lang 함정: s[x+1..n] 이 s[x..n] 으로 파싱 → 변수 pre-assign 필수
        let rest_start = sp_pos + 1
        let rest = trimmed[rest_start..n]
        // 종료문자: ' ' 또는 '=' 또는 줄끝
        let mut i: i64 = 0
        let rn = len(rest)
        while i < rn {
            let ip1 = i + 1
            let ch = rest[i..ip1]
            if ch == " " || ch == "=" || ch == "\t" { break }
            i = i + 1
        }
        if i == 0 { return "" }
        return rest[0..i]
    }
    return ""
}

// S6 (2026-04-19): 12-class absorption tag resolver.
//   기존 8: @R/@X/@F/@C/@P/@L/@?/@S (v1 1-char tags)
//   신규 4: @EXP/@OBS/@NEG/@ANT (v2 3-char tags — schema 이미 등록)
//   총 12 클래스 = 10-step drill saturation 판정 기준 (S8).
// 시그니처: classify_absorption_tag(node_type, confidence, sign, status) -> str
//   - node_type: "formula"/"rule"/"axiom"/"constant"/"primitive"/"large"/"ssot"/"experimental"/"observation"/"negation"/"antithesis"/"unknown" 또는 기존 grade ("EXACT"/"NEAR"/"CLOSE"/"MISS")
//   - confidence: [0,1] — axiom/formula 경계 판정 (>=0.9 axiom, >=0.7 formula)
//   - sign: "+"/"-"/"" — NEG/ANT 판정 용 (- 면 negation/antithesis 후보)
//   - status: "proposed"/"verified"/"rejected"/"" — antithesis 게이트 (rejected → @ANT)
// 반환: 단일 태그 문자열 (@R/@X/@F/@C/@P/@L/@?/@S/@EXP/@OBS/@NEG/@ANT 중 하나).
fn classify_absorption_tag(node_type: string, confidence: f64, sign: string, status: string) -> string {
    // 우선순위: 명시적 v2 tag types → status 게이트 → confidence/sign 게이트 → v1 → fallback
    if node_type == "experimental" || node_type == "exp" { return "@EXP" }
    if node_type == "observation"  || node_type == "obs" { return "@OBS" }
    if node_type == "negation"     || node_type == "neg" { return "@NEG" }
    if node_type == "antithesis"   || node_type == "ant" { return "@ANT" }
    if status == "rejected" { return "@ANT" }
    if sign == "-" && confidence >= 0.5 { return "@NEG" }
    if status == "proposed" && confidence < 0.5 { return "@EXP" }
    if status == "verified" && confidence < 0.7 { return "@OBS" }
    // v1 1-char 태그 (grade/type 기반)
    if node_type == "axiom"      || node_type == "EXACT" { return "@X" }
    if node_type == "formula"    || node_type == "NEAR"  { return "@F" }
    if node_type == "rule"       || node_type == "CLOSE" { return "@R" }
    if node_type == "constant"                          { return "@C" }
    if node_type == "primitive"                         { return "@P" }
    if node_type == "large"                             { return "@L" }
    if node_type == "ssot"                              { return "@S" }
    // confidence-based fallback (grade 미정 시)
    if confidence >= 0.9 { return "@X" }
    if confidence >= 0.7 { return "@F" }
    if confidence >= 0.5 { return "@R" }
    return "@?"
}

// S6 보조: 12-class tag 리스트 (S8 saturation check 공용).
fn _absorption_tag_classes() -> list {
    return ["@R", "@X", "@F", "@C", "@P", "@L", "@?", "@S", "@EXP", "@OBS", "@NEG", "@ANT"]
}

// S8 보조: tag → 고정 index (parallel list 카운터 접근용. map 재대입 함정 우회).
fn _tag_idx(tag: string) -> i64 {
    if tag == "@R" { return 0 }
    if tag == "@X" { return 1 }
    if tag == "@F" { return 2 }
    if tag == "@C" { return 3 }
    if tag == "@P" { return 4 }
    if tag == "@L" { return 5 }
    if tag == "@?" { return 6 }
    if tag == "@S" { return 7 }
    if tag == "@EXP" { return 8 }
    if tag == "@OBS" { return 9 }
    if tag == "@NEG" { return 10 }
    if tag == "@ANT" { return 11 }
    return 6
}

// S8 보조: 외부 스코프 list 를 fn-local 로 복사 → 수정 → 반환 (hexa L1849 _deg_bump 패턴).
// 외부 list 원-위치 증분이 nested while 에서 persist 안되는 문제 우회.
fn _tag_bump(cnts: list, idx: i64) -> list {
    let mut out: list = []
    let mut i: i64 = 0
    while i < len(cnts) {
        if i == idx {
            let v = to_int(to_string(cnts[i])) + 1
            out = out.push(v)
        } else {
            out = out.push(cnts[i])
        }
        i = i + 1
    }
    return out
}

// ─── A4/A5 helpers (2026-04-19) ───
// ts-hour bucket 추출: "2026-04-19T03:54:13Z" → "2026-04-19T03"
fn _ts_hour_bucket(ts: string) -> string {
    let n = len(ts)
    if n >= 13 { return ts[0..13] }
    return ts
}

// JSON 라인에서 type 필드 추출 — {"type":"node",... → "node"
// edge/기타 분별용. id 필드도 함께 뽑는 경량 파서.
fn _extract_json_type(trimmed: string) -> string {
    let marker = "\"type\":\""
    let p = trimmed.split(marker)
    if len(p) < 2 { return "" }
    let tail = p[1]
    let q = tail.split("\"")
    if len(q) < 1 { return "" }
    return q[0]
}

// A5: 3-shard 라우팅 — JSON 라인 type 으로 shard path 결정
fn _shard_path_for_json(trimmed: string) -> string {
    let ty = _extract_json_type(trimmed)
    if ty == "node"    { return _ATLAS_BLOWUP_NODES_PATH }
    if ty == "edge"    { return _ATLAS_BLOWUP_EDGES_PATH }
    // constant/projection/deduction/compose/bifurc/absorb/wave/... 전부 events
    return _ATLAS_BLOWUP_EVENTS_PATH
}

// A5: .idx 업데이트 — 현재 hour bucket 이 idx tail 과 다르면 (offset,hour) 한 줄 append
// 비용: idx 파일 read (작음 ~수십 KB) + 조건부 append. 대용량 sidecar 에도 O(1) per hour.
fn _update_shard_idx(shard_path: string, hour: string) {
    if len(hour) == 0 { return }
    let idx_path = shard_path + ".idx"
    // 현재 shard byte offset (append 직후 size)
    let mut off: i64 = 0
    try { off = file_size(shard_path) } catch e {}
    // idx tail 의 hour 가 현재와 같으면 skip (이미 해당 bucket 의 첫 offset 기록됨)
    let mut last_hour = ""
    if file_exists(idx_path) {
        let mut raw = ""
        try { raw = read_file(idx_path) } catch e {}
        let lines = raw.split("\n")
        let mut li: i64 = len(lines) - 1
        while li >= 0 {
            let l = lines[li].trim()
            if len(l) > 0 {
                let parts = l.split("\t")
                if len(parts) >= 1 { last_hour = parts[0] }
                break
            }
            li = li - 1
        }
    }
    if last_hour == hour { return }
    let entry = hour + "\t" + to_string(off) + "\n"
    try { append_file(idx_path, entry) } catch e {}
}

// A4: atlas.n6 events.jsonl writer — append 직후 호출, op 분류 + id 추출
// trimmed 는 한 줄. op: "add" (@-label), "edge" (JSON edge), "event" (기타 JSON),
//                     "grade" (@-label 에 [NN*] promotion 표식 포함).
fn _emit_atlas_event(trimmed: string, source_path: string, ts: string) {
    if len(trimmed) == 0 { return }
    let c0 = trimmed[0..1]
    let mut op = ""
    let mut id = ""
    let mut route = ""
    if c0 == "{" {
        // JSON 라인 — type=edge 면 edge, 그 외 event. id 는 있는 경우만.
        let ty = _extract_json_type(trimmed)
        if ty == "edge" { op = "edge" } else { op = "event" }
        id = _atlas_extract_id(trimmed)
        route = "blowup.sidecar"
    } else if c0 == "@" {
        // @-label — grade promotion ([NN*]) vs add 분별
        if trimmed.contains("[12*]") || trimmed.contains("[11*]") || trimmed.contains("[10*]") {
            op = "grade"
        } else {
            op = "add"
        }
        id = _atlas_extract_id(trimmed)
        route = "atlas.body"
    } else {
        // 주석/blank/v2 continuation — event 로 fall through (id 없음 가능)
        op = "event"
        route = "atlas.body"
    }
    // JSON escape: id 에 따옴표/백슬래시 가능 → 최소 이스케이프
    let id_esc = id.replace("\\", "\\\\").replace("\"", "\\\"")
    let src_esc = source_path.replace("\\", "\\\\").replace("\"", "\\\"")
    let route_esc = route.replace("\\", "\\\\").replace("\"", "\\\"")
    let rec = "{\"ts\":\"" + ts + "\",\"op\":\"" + op + "\",\"id\":\"" + id_esc + "\",\"source\":\"" + src_esc + "\",\"path\":\"" + route_esc + "\"}\n"
    try { append_file(_ATLAS_EVENTS_PATH, rec) } catch e {}
}

// 안전 append: (1) schema 검증 (2) shell dedup (3) flock append.
// 불변식: 결과는 항상 "\n"로 끝남 (다음 append 간 line boundary 보존).
// dedup: atlas.n6 전용 — grep -Fxf 배치 dedup (hexa read_file OOM 회피).
// 이전: read_file(13MB) + split("\n") → 69k line hashmap → 매 호출 ~200MB alloc.
// v2(폐기): 라인별 grep -Fxq → O(batch × grep) shell 위임, 53회 exec 오버헤드.
// v3(현재): 배치 grep -Fxf tmpfile → exec 1회, hexa 메모리 0. (ROI #16)
fn _guarded_append_atlas(path: string, content: string) -> i64 {
    if len(content) == 0 { return 0 }

    let is_atlas = path.contains("atlas.n6")
    let is_signals = _is_signals_path_v2(path)
    let is_body = _is_atlas_body_path_v2(path)

    // X1 (2026-04-19): JSON-line 라우팅 — caller path 가 atlas.n6 이면
    //   라인 첫 글자가 `{` 인 JSON 결과를 atlas.blowup.jsonl 로 자동 라우팅.
    //   이전: 모든 라인이 atlas.n6 (18.9MB, 80%가 JSON 결과 → reload 병목).
    //   현재: atlas.n6 = 라벨 SSOT (1.5MB), atlas.blowup.jsonl = 결과 사이드카 (17MB).
    // v2 (2026-04-19): atlas.signals.n6 는 staging — JSON sidecar 라우팅 비활성화
    let mut json_route_path = ""
    if is_atlas && !is_signals { json_route_path = _ATLAS_BLOWUP_PATH }

    // (1) schema 검증 — 1차 패스: 유효 라인만 추출 + dedup 후보 수집
    let lines = content.split("\n")
    let mut rejected: i64 = 0
    let mut deduped: i64 = 0
    let mut v2_body_rejected: i64 = 0
    // valid_lines: schema 통과한 원본 라인 (인덱스 보존)
    // dedup_candidates: grep 검사 대상 (trimmed, 비어있지 않고 주석 아닌 atlas 라인)
    let mut valid_lines: list = []
    let mut valid_trimmed: list = []
    let mut needs_dedup: list = []
    // X1: 라인별 라우팅 결정 (true=JSON sidecar, false=라벨 atlas.n6)
    let mut is_json_line: list = []
    let mut i: i64 = 0
    while i < len(lines) {
        let line = lines[i]
        // v2 staging gate (2026-04-19): @EXP/@OBS/@NEG/@ANT 는 atlas.signals.n6 전용
        if _is_v2_tag_line(line) {
            if is_body && !is_signals {
                v2_body_rejected = v2_body_rejected + 1
                rejected = rejected + 1
                i = i + 1
                continue
            }
            if !_valid_v2_line(line) {
                rejected = rejected + 1
                i = i + 1
                continue
            }
        }
        if !_valid_atlas_line(line) {
            rejected = rejected + 1
            i = i + 1
            continue
        }
        let t = line.trim()
        let do_dedup = is_atlas && len(t) > 0 && !t.starts_with("#")
        // X1: JSON-line 판정 — trimmed 첫 글자 `{` 면 atlas.blowup.jsonl 로 라우팅
        let mut is_json = false
        if is_atlas && len(t) > 0 {
            if t[0..1] == "{" { is_json = true }
        }
        valid_lines = valid_lines.push(line)
        valid_trimmed = valid_trimmed.push(t)
        needs_dedup = needs_dedup.push(do_dedup)
        is_json_line = is_json_line.push(is_json)
        i = i + 1
    }

    // (2) 배치 dedup: grep -Fxf tmpfile (exec 1회)
    // dedup 후보가 있으면 tmpfile에 모아서 한 번에 grep
    let mut dup_set = #{}
    let dedup_count: i64 = len(valid_lines)
    let mut has_any_dedup = false
    i = 0
    while i < dedup_count {
        if needs_dedup[i] { has_any_dedup = true }
        i = i + 1
    }

    if has_any_dedup {
        // 후보 라인을 tmpfile로 작성 → grep -Fxf 로 atlas에서 일치 검색
        let _tmp = "/tmp/.blowup_dedup_batch." + _BU_PID
        let mut pattern_parts: [string] = []
        i = 0
        while i < dedup_count {
            if needs_dedup[i] {
                pattern_parts.push(to_string(valid_trimmed[i]))
            }
            i = i + 1
        }
        let patterns = pattern_parts.join("\n")
        try {
            // tmpfile에 패턴 기록 — write_file 네이티브 (heredoc 회피, metachar 경고 0)
            try { write_file(_tmp, patterns) } catch e {}
            // grep -Fxf: 패턴 파일의 각 라인을 고정 문자열 전체 라인 매치로 검색
            // 결과 = atlas.n6 / atlas.blowup.jsonl 에 이미 존재하는 라인 목록
            // X1 (2026-04-19): is_atlas 면 두 파일 모두 검사 (JSON sidecar 분리 대응)
            // AI-native: || true 제거 — grep 실패 (no-match exit 1) 는 try/catch 로 처리
            let mut found_raw = ""
            let mut grep_targets = "'" + path + "'"
            if is_atlas && file_exists(_ATLAS_BLOWUP_PATH) {
                grep_targets = grep_targets + " '" + _ATLAS_BLOWUP_PATH + "'"
            }
            try { found_raw = exec("grep -hFxf '" + _tmp + "' " + grep_targets + " 2>/dev/null") } catch e {}
            let found_lines = found_raw.split("\n")
            for fl in found_lines {
                let ft = fl.trim()
                if len(ft) > 0 {
                    dup_set[ft] = true
                }
            }
        } catch e {}
        // tmpfile 정리
        try { exec("rm -f '" + _tmp + "' 2>/dev/null") } catch e {}
    }

    // (2.5) X2 id-anchored dedup (2026-04-19 A3):
    //   grep -Fxf 가 full-line 매치라 같은 id 가 confidence/grade 만 달라도 재append →
    //   1275 dup_nodes 누적 근본원인. atlas 에서 기존 id 집합을 단일 awk 로 뽑아 hashset 구성.
    //   신규 batch 내부에서도 id 중복 차단.
    //   O(atlas_lines) awk 1회 + O(batch) lookup. 대용량 atlas.blowup.jsonl 대응.
    let mut known_ids = #{}
    let mut id_dedup_active = false
    if has_any_dedup {
        id_dedup_active = true
        // 후보 중 id 추출 가능한 라인이 있는지 확인 — 전부 edge/주석이면 scan 생략
        let mut _any_id = false
        let mut __i: i64 = 0
        while __i < dedup_count {
            if needs_dedup[__i] {
                let _tid = _atlas_extract_id(valid_trimmed[__i])
                if len(_tid) > 0 { _any_id = true; break }
            }
            __i = __i + 1
        }
        if _any_id {
            // 파일별 id 수집 (JSON sidecar + atlas.n6)
            // JSON: {"type":"node","id":"<id>"    @-line: @X <id>
            let mut _id_src = "'" + path + "'"
            if is_atlas && file_exists(_ATLAS_BLOWUP_PATH) {
                _id_src = _id_src + " '" + _ATLAS_BLOWUP_PATH + "'"
            }
            let _awk_ids = "awk 'BEGIN{FS=\"\\\"\"}" +
                "/^\\{\"type\":\"node\"/{for(k=1;k<NF;k++){if($k==\"id\"){print $(k+2);break}}next}" +
                "/^@[A-Z?] /{split($0,A,\" \"); if(A[2]!=\"\") print A[2]}' " +
                _id_src + " 2>/dev/null"
            let mut _id_raw = ""
            try { _id_raw = exec(_awk_ids) } catch e {}
            let _id_lines = _id_raw.split("\n")
            for _il in _id_lines {
                let _it = _il.trim()
                if len(_it) > 0 { known_ids[_it] = true }
            }
        } else {
            id_dedup_active = false
        }
    }

    // (3) 최종 필터 + X1 라우팅: dup 제외 + JSON 라인은 별도 buffer 로
    // X2: id-anchored dedup 추가 — same-id 재등장(confidence/grade drift)도 차단
    // A4/A5 (2026-04-19): trimmed 평행 리스트 유지 — A4 event-log 및 A5 3-shard 라우팅에 사용
    let mut clean_label_parts: [string] = []
    let mut clean_label_trimmed: [string] = []
    let mut clean_json_parts: [string] = []
    let mut clean_json_trimmed: [string] = []
    let mut batch_seen_ids = #{}
    let mut id_deduped: i64 = 0
    i = 0
    while i < dedup_count {
        if needs_dedup[i] {
            let t = valid_trimmed[i]
            let mut is_dup = false
            try { is_dup = dup_set[t] == true } catch e {}
            if is_dup {
                deduped = deduped + 1
                i = i + 1
                continue
            }
            // X2 id-anchored: atlas known + batch seen 둘 다 체크
            if id_dedup_active {
                let _id = _atlas_extract_id(t)
                if len(_id) > 0 {
                    let mut _in_atlas = false
                    try { _in_atlas = known_ids[_id] == true } catch e {}
                    let mut _in_batch = false
                    try { _in_batch = batch_seen_ids[_id] == true } catch e {}
                    if _in_atlas || _in_batch {
                        id_deduped = id_deduped + 1
                        i = i + 1
                        continue
                    }
                    batch_seen_ids[_id] = true
                }
            }
        }
        // X1: JSON 라인은 atlas.blowup.jsonl, 그 외는 기존 path (atlas.n6)
        if is_json_line[i] && len(json_route_path) > 0 {
            clean_json_parts.push(to_string(valid_lines[i]))
            clean_json_trimmed.push(to_string(valid_trimmed[i]))
        } else {
            clean_label_parts.push(to_string(valid_lines[i]))
            clean_label_trimmed.push(to_string(valid_trimmed[i]))
        }
        i = i + 1
    }
    if id_deduped > 0 {
        println("  [id-dedup guard] skipped " + to_string(id_deduped) + " same-id lines -> " + path)
    }

    if rejected > 0 {
        println("  [schema guard] rejected " + to_string(rejected) + " invalid lines -> " + path)
    }
    if v2_body_rejected > 0 {
        println("  [schema v2 guard] " + to_string(v2_body_rejected) + " v2 tags blocked from atlas.n6 body (staging: atlas.signals.n6)")
    }
    if deduped > 0 {
        println("  [dedup guard] skipped " + to_string(deduped) + " duplicate lines -> " + path)
    }

    // (4) atlas.n6 라벨 append (caller path 그대로)
    // A4 (2026-04-19): append 성공 시 _ATLAS_EVENTS_PATH 에 {ts,op,id,source} 병기
    let _evt_ts = now()
    if len(clean_label_parts) > 0 {
        let mut clean_lbl = clean_label_parts.join("\n")
        if !clean_lbl.ends_with("\n") { clean_lbl = clean_lbl + "\n" }
        let _nlbl = len(clean_label_parts)
        let mut _ok_lbl = false
        try { append_file(path, clean_lbl); _ok_lbl = true } catch e {}
        if !_ok_lbl {
            let _lock = path + ".lock"
            try {
                exec("(flock -w 30 200 && cat >> '" + path + "') 200>'" + _lock + "' <<'__BLOWUP_EOF__'\n" + clean_lbl + "__BLOWUP_EOF__")
                _ok_lbl = true
            } catch e {}
        }
        if !_ok_lbl {
            println("  [atlas WRITE FAIL] " + to_string(_nlbl) + " lines NOT persisted -> " + path)
        }
        // A4: atlas.n6 body 에 들어간 라인별 event 발행 (성공한 경우만)
        if _ok_lbl && is_atlas {
            let mut _ei: i64 = 0
            while _ei < len(clean_label_trimmed) {
                _emit_atlas_event(to_string(clean_label_trimmed[_ei]), path, _evt_ts)
                _ei = _ei + 1
            }
        }
    }

    // (5) A5 (2026-04-19): JSON-line 3-shard 라우팅 — type 별 nodes/edges/events 분리
    //   기존 atlas.blowup.jsonl 은 append 안 함 (migration 별건). 신규 append = 3-shard only.
    //   각 shard 마다 .idx (ts-hour bucket → byte offset) 업데이트.
    if len(clean_json_parts) > 0 && len(json_route_path) > 0 {
        // type 별로 bucket (nodes / edges / events)
        let mut shard_nodes_parts: [string] = []
        let mut shard_nodes_trim: [string] = []
        let mut shard_edges_parts: [string] = []
        let mut shard_edges_trim: [string] = []
        let mut shard_events_parts: [string] = []
        let mut shard_events_trim: [string] = []
        let _jn = len(clean_json_parts)
        let mut _ji: i64 = 0
        while _ji < _jn {
            let _line = to_string(clean_json_parts[_ji])
            let _trim = to_string(clean_json_trimmed[_ji])
            let _sp = _shard_path_for_json(_trim)
            if _sp == _ATLAS_BLOWUP_NODES_PATH {
                shard_nodes_parts.push(_line)
                shard_nodes_trim.push(_trim)
            } else if _sp == _ATLAS_BLOWUP_EDGES_PATH {
                shard_edges_parts.push(_line)
                shard_edges_trim.push(_trim)
            } else {
                shard_events_parts.push(_line)
                shard_events_trim.push(_trim)
            }
            _ji = _ji + 1
        }
        let _hour = _ts_hour_bucket(_evt_ts)
        // nodes shard
        if len(shard_nodes_parts) > 0 {
            let mut _n_buf = shard_nodes_parts.join("\n")
            if !_n_buf.ends_with("\n") { _n_buf = _n_buf + "\n" }
            let mut _ok_n = false
            try { append_file(_ATLAS_BLOWUP_NODES_PATH, _n_buf); _ok_n = true } catch e {}
            if !_ok_n {
                let _lock = _ATLAS_BLOWUP_NODES_PATH + ".lock"
                try {
                    exec("(flock -w 30 200 && cat >> '" + _ATLAS_BLOWUP_NODES_PATH + "') 200>'" + _lock + "' <<'__BLOWUP_EOF__'\n" + _n_buf + "__BLOWUP_EOF__")
                    _ok_n = true
                } catch e {}
            }
            if _ok_n {
                _update_shard_idx(_ATLAS_BLOWUP_NODES_PATH, _hour)
                // A4: 3-shard append 도 event 로 기록 (source=shard path)
                let mut _ei: i64 = 0
                while _ei < len(shard_nodes_trim) {
                    _emit_atlas_event(to_string(shard_nodes_trim[_ei]), _ATLAS_BLOWUP_NODES_PATH, _evt_ts)
                    _ei = _ei + 1
                }
            } else {
                println("  [atlas WRITE FAIL] " + to_string(len(shard_nodes_parts)) + " lines NOT persisted -> " + _ATLAS_BLOWUP_NODES_PATH)
            }
        }
        // edges shard
        if len(shard_edges_parts) > 0 {
            let mut _e_buf = shard_edges_parts.join("\n")
            if !_e_buf.ends_with("\n") { _e_buf = _e_buf + "\n" }
            let mut _ok_e = false
            try { append_file(_ATLAS_BLOWUP_EDGES_PATH, _e_buf); _ok_e = true } catch e {}
            if !_ok_e {
                let _lock = _ATLAS_BLOWUP_EDGES_PATH + ".lock"
                try {
                    exec("(flock -w 30 200 && cat >> '" + _ATLAS_BLOWUP_EDGES_PATH + "') 200>'" + _lock + "' <<'__BLOWUP_EOF__'\n" + _e_buf + "__BLOWUP_EOF__")
                    _ok_e = true
                } catch e {}
            }
            if _ok_e {
                _update_shard_idx(_ATLAS_BLOWUP_EDGES_PATH, _hour)
                let mut _ei: i64 = 0
                while _ei < len(shard_edges_trim) {
                    _emit_atlas_event(to_string(shard_edges_trim[_ei]), _ATLAS_BLOWUP_EDGES_PATH, _evt_ts)
                    _ei = _ei + 1
                }
            } else {
                println("  [atlas WRITE FAIL] " + to_string(len(shard_edges_parts)) + " lines NOT persisted -> " + _ATLAS_BLOWUP_EDGES_PATH)
            }
        }
        // events shard (constant/projection/deduction/compose/bifurc/absorb/wave/...)
        if len(shard_events_parts) > 0 {
            let mut _v_buf = shard_events_parts.join("\n")
            if !_v_buf.ends_with("\n") { _v_buf = _v_buf + "\n" }
            let mut _ok_v = false
            try { append_file(_ATLAS_BLOWUP_EVENTS_PATH, _v_buf); _ok_v = true } catch e {}
            if !_ok_v {
                let _lock = _ATLAS_BLOWUP_EVENTS_PATH + ".lock"
                try {
                    exec("(flock -w 30 200 && cat >> '" + _ATLAS_BLOWUP_EVENTS_PATH + "') 200>'" + _lock + "' <<'__BLOWUP_EOF__'\n" + _v_buf + "__BLOWUP_EOF__")
                    _ok_v = true
                } catch e {}
            }
            if _ok_v {
                _update_shard_idx(_ATLAS_BLOWUP_EVENTS_PATH, _hour)
                let mut _ei: i64 = 0
                while _ei < len(shard_events_trim) {
                    _emit_atlas_event(to_string(shard_events_trim[_ei]), _ATLAS_BLOWUP_EVENTS_PATH, _evt_ts)
                    _ei = _ei + 1
                }
            } else {
                println("  [atlas WRITE FAIL] " + to_string(len(shard_events_parts)) + " lines NOT persisted -> " + _ATLAS_BLOWUP_EVENTS_PATH)
            }
        }
    }
    return rejected
}

fn graph_count_type(content: string, ttype: string) -> i64 {
    if len(content) == 0 { return 0 }
    let lines = content.split("\n")
    let mut count: i64 = 0
    let mut li: i64 = 0
    while li < len(lines) {
        let line = lines[li]
        if len(line) > 5 {
            let t = graph_extract_field(line, "type")
            if t == ttype { count = count + 1 }
        }
        li = li + 1
    }
    return count
}

// ─── atlas.blowup.jsonl.stats 사이드카 캐시 (Phase 1 O(58k lines) → O(1) / O(Δ)) ───
// 포맷 blowup_v1: {"schema":"blowup_v1","mtime":<int>,"size":<int>,"line_count":<int>,
//          "head_hash":<md5 first 256B>,"nodes":<int>,"edges":<int>,"hubs":<int>}
// deg 사이드카: atlas.blowup.jsonl.deg — TSV "id\tdegree\n" (hub 재계산용)
// 2026-04-19 ROI#2: path 분리 — atlas_health v3 의 atlas.n6.stats (schema:3 derived)
//   와 충돌 회피. blowup stats 의 SSOT 소스는 atlas.blowup.jsonl 이므로
//   사이드카도 블로웁-소스 루트로 이동. atlas.n6.stats 는 atlas_health 전용.
// 유효성:
//   - exact: mtime+size 일치 → O(1) 리턴
//   - incremental: size>cached + head_hash 일치 → Δ lines만 파싱 O(Δ)
//   - miss: 전체 스캔 + 양쪽 사이드카 재작성
fn graph_stats_cache_path() -> string {
    // blowup 소스 존재 시 분리 경로, 없으면 레거시 fallback
    if file_exists(_ATLAS_BLOWUP_PATH) { return _ATLAS_BLOWUP_PATH + ".stats" }
    return _ATLAS_PATH + ".stats"
}

fn graph_deg_cache_path() -> string {
    if file_exists(_ATLAS_BLOWUP_PATH) { return _ATLAS_BLOWUP_PATH + ".deg" }
    return _ATLAS_PATH + ".deg"
}

fn _stat_mtime_size(path: string) -> string {
    // AI-native: file_size() 네이티브 + stat mtime 플랫폼별 분리 exec
    // 이전: stat -f ... || stat -c ... (|| 메타문자 경고)
    // 2026-04-19 fix: GNU 우선 + 숫자 validation (bc75341 loop-guard 패턴 일치).
    //   Linux 에서 `stat -f %m` 가 인자를 무시하고 verbose filesystem 정보를
    //   stdout 으로 쏟아내 → atlas.n6.stats sidecar 손상 (mtime: 파일:... 형태).
    //   `2>/dev/null` 은 stderr 만 차단; stdout 누수는 numeric guard 로 차단.
    let mut size_s = ""
    try { size_s = to_string(file_size(path)) } catch e {}
    if size_s == "" { return "" }
    let mut mt = ""
    // GNU (Linux) 먼저 시도 — bc75341 loop-guard 와 동일 우선순위
    try { mt = to_string(exec("stat -c %Y '" + path + "' 2>/dev/null")).trim() } catch e {}
    if !_is_all_digits(mt) { mt = "" }
    if mt == "" {
        // BSD (macOS) fallback
        try { mt = to_string(exec("stat -f %m '" + path + "' 2>/dev/null")).trim() } catch e {}
        if !_is_all_digits(mt) { mt = "" }
    }
    if mt == "" { return "" }
    return mt + " " + size_s
}

fn _is_all_digits(s: string) -> bool {
    let n = s.len()
    if n == 0 { return false }
    let mut i: i64 = 0
    while i < n {
        let c = char_code(s, i)
        if c < 48 || c > 57 { return false }
        i = i + 1
    }
    return true
}

fn _head_hash_256(path: string) -> string {
    // AI-native: BSD(md5)/GNU(md5sum) 플랫폼별 분리 exec — 파이프/|| 제거
    // 이전: head | md5 -q || head | md5sum | cut
    // 현재: tmp 파일 + 단일 커맨드 per 플랫폼 (순차 fallback)
    let mut r = ""
    if !file_exists(path) { return "" }
    let _tmp = "/tmp/.blowup_headhash." + _BU_PID
    // head -c 256 → tmp (redirect 는 metachar 경고 없음)
    try { exec("head -c 256 '" + path + "' > '" + _tmp + "'") } catch e {}
    if file_exists(_tmp) {
        // BSD: md5 -q tmp
        try { r = to_string(exec("md5 -q '" + _tmp + "' 2>/dev/null")).trim() } catch e {}
        if r == "" {
            // GNU: md5sum tmp → first column
            let mut raw = ""
            try { raw = to_string(exec("md5sum '" + _tmp + "' 2>/dev/null")).trim() } catch e {}
            if len(raw) > 0 {
                let parts = raw.split(" ")
                if len(parts) > 0 { r = parts[0].trim() }
            }
        }
        try { exec("rm -f '" + _tmp + "'") } catch e {}
    }
    return r
}

// 반환: "mtime|size|line_count|nodes|edges|hubs|head_hash" or "" on miss
fn _read_stats_sidecar() -> string {
    let spath = graph_stats_cache_path()
    if !file_exists(spath) { return "" }
    let mut raw = ""
    try { raw = read_file(spath) } catch e { return "" }
    let trimmed = raw.trim()
    if trimmed == "" { return "" }
    let mut j = #{}
    try { j = json_parse(trimmed) } catch e { return "" }
    let mut c_mtime = ""
    let mut c_size = ""
    let mut c_lines = ""
    let mut c_nodes = ""
    let mut c_edges = ""
    let mut c_hubs = ""
    let mut c_head = ""
    try { c_mtime = to_string(j["mtime"]) } catch e {}
    try { c_size = to_string(j["size"]) } catch e {}
    try { c_lines = to_string(j["line_count"]) } catch e {}
    try { c_nodes = to_string(j["nodes"]) } catch e {}
    try { c_edges = to_string(j["edges"]) } catch e {}
    try { c_hubs = to_string(j["hubs"]) } catch e {}
    try { c_head = to_string(j["head_hash"]) } catch e {}
    if c_mtime == "" || c_size == "" || c_nodes == "" { return "" }
    return c_mtime + "|" + c_size + "|" + c_lines + "|" + c_nodes + "|" + c_edges + "|" + c_hubs + "|" + c_head
}

fn graph_stats_read_cache(min_deg: i64) -> string {
    // X1 (2026-04-19): cache key 는 JSON sidecar (실제 stats source) 의 mtime/size
    if min_deg != 3 { return "" }
    let mut src_path = _ATLAS_BLOWUP_PATH
    if !file_exists(src_path) {
        src_path = _ATLAS_PATH
        if !file_exists(src_path) { return "" }
    }
    let stat_raw = _stat_mtime_size(src_path)
    if stat_raw == "" { return "" }
    let sp = stat_raw.split(" ")
    if len(sp) < 2 { return "" }
    let cur_mtime = sp[0]
    let cur_size = sp[1]
    let cached = _read_stats_sidecar()
    if cached == "" { return "" }
    let cp = cached.split("|")
    if len(cp) < 7 { return "" }
    if cp[0] != cur_mtime { return "" }
    if cp[1] != cur_size { return "" }
    return cp[3] + "|" + cp[4] + "|" + cp[5]
}

// 증분 스캔: cached head_hash 일치 + size 증가 → Δ 구간만 파싱
// content: 현재 atlas.n6 전체 문자열 (graph_load 이미 로드됨)
// 반환: "nodes|edges|hubs" (성공) or "" (miss — 전체 스캔으로 fallback)
// deg 사이드카 TSV → map 로드 (헬퍼 분리: type-check 부담 완화)
fn _load_deg_sidecar(dpath: string) -> map {
    let mut deg_map = #{}
    if !file_exists(dpath) { return deg_map }
    let mut deg_raw = ""
    try { deg_raw = read_file(dpath) } catch e { return deg_map }
    let deg_lines = deg_raw.split("\n")
    let n = len(deg_lines)
    let mut di: i64 = 0
    while di < n {
        let dl = deg_lines[di]
        di = di + 1
        if len(dl) == 0 { continue }
        let tp = dl.split("\t")
        if len(tp) < 2 { continue }
        try { deg_map[tp[0]] = to_int(tp[1]) } catch e {}
    }
    return deg_map
}

// deg_map 훑어 min_deg 이상인 허브 개수 반환
fn _count_hubs(deg_map: map, min_deg: i64) -> i64 {
    let vals = deg_map.values()
    let n = len(vals)
    let mut hub: i64 = 0
    let mut hi: i64 = 0
    while hi < n {
        let d: i64 = vals[hi]
        if d >= min_deg { hub = hub + 1 }
        hi = hi + 1
    }
    return hub
}

// deg_map 의 단일 id 카운트 +1 (try/catch hoist)
fn _deg_bump(deg_map: map, key: string) -> map {
    if len(key) == 0 { return deg_map }
    let mut d: i64 = 0
    try { d = deg_map[key] } catch e {}
    deg_map[key] = d + 1
    return deg_map
}

fn graph_stats_incremental(content: string, min_deg: i64) -> string {
    if min_deg != 3 { return "" }
    if len(content) == 0 { return "" }
    let cached = _read_stats_sidecar()
    if cached == "" { return "" }
    let cp = cached.split("|")
    if len(cp) < 7 { return "" }
    let mut c_size: i64 = 0
    let mut c_lines: i64 = 0
    let mut c_nodes: i64 = 0
    let mut c_edges: i64 = 0
    try { c_size = to_int(cp[1]) } catch e { return "" }
    try { c_lines = to_int(cp[2]) } catch e { return "" }
    try { c_nodes = to_int(cp[3]) } catch e { return "" }
    try { c_edges = to_int(cp[4]) } catch e { return "" }
    let c_head = cp[6]
    if len(content) <= c_size { return "" }
    if c_head == "" { return "" }
    // X1 (2026-04-19): incremental tail 은 JSON sidecar 에 대해 수행
    let mut src_path = _ATLAS_BLOWUP_PATH
    if !file_exists(src_path) { src_path = _ATLAS_PATH }
    let cur_head = _head_hash_256(src_path)
    if cur_head == "" { return "" }
    if cur_head != c_head { return "" }
    let mut deg_map = _load_deg_sidecar(graph_deg_cache_path())
    // (빈 map 이면 과거엔 조기 return 이었음 — file_exists 검사를 헬퍼가 흡수)
    // 시맨틱 보존 위해 수동 체크
    if !file_exists(graph_deg_cache_path()) { return "" }
    let cur_stat = _stat_mtime_size(src_path)
    if cur_stat == "" { return "" }
    let cs = cur_stat.split(" ")
    if len(cs) < 2 { return "" }
    let mut cur_bytes: i64 = 0
    try { cur_bytes = to_int(cs[1]) } catch e { return "" }
    if cur_bytes <= c_size { return "" }
    let mut tail = ""
    try { tail = to_string(exec("tail -c +" + to_string(c_size + 1) + " '" + src_path + "' 2>/dev/null")) } catch e { return "" }
    if len(tail) == 0 { return "" }
    let delta_lines = tail.split("\n")
    let delta_len = len(delta_lines)
    let mut start: i64 = 0
    if delta_len > 0 {
        let first = delta_lines[0]
        if len(first) > 0 && !_valid_atlas_line(first) { start = 1 }
    }
    let mut nodes = c_nodes
    let mut edges = c_edges
    let mut li: i64 = start
    while li < delta_len {
        let line = delta_lines[li]
        li = li + 1
        if len(line) <= 5 { continue }
        let t = graph_extract_field(line, "type")
        if t == "node" { nodes = nodes + 1 }
        if t == "edge" {
            edges = edges + 1
            deg_map = _deg_bump(deg_map, graph_extract_field(line, "from"))
            deg_map = _deg_bump(deg_map, graph_extract_field(line, "to"))
        }
    }
    let hub_count = _count_hubs(deg_map, min_deg)
    let new_line_count = c_lines + (delta_len - start)
    graph_stats_write_cache_full(nodes, edges, hub_count, new_line_count, deg_map)
    return to_string(nodes) + "|" + to_string(edges) + "|" + to_string(hub_count)
}

// deg_map 직렬화: "id\tdeg\n"
// OPT-P8-7: string concat loop → array + join (O(n) alloc → O(1) join)
fn _serialize_deg_map(deg_map: map) -> string {
    let ks = deg_map.keys()
    let n = len(ks)
    if n == 0 { return "" }
    let mut parts = []
    let mut i: i64 = 0
    while i < n {
        let k = to_string(ks[i])
        let mut d: i64 = 0
        try { d = deg_map[k] } catch e {}
        parts = parts.push(k + "\t" + to_string(d))
        i = i + 1
    }
    return "\n".join(parts) + "\n"
}

fn graph_stats_write_cache_full(nodes: i64, edges: i64, hubs: i64, line_count: i64, deg_map: map) {
    // X1 (2026-04-19): cache key 는 JSON sidecar mtime/size
    let mut src_path = _ATLAS_BLOWUP_PATH
    if !file_exists(src_path) {
        src_path = _ATLAS_PATH
        if !file_exists(src_path) { return }
    }
    let stat_raw = _stat_mtime_size(src_path)
    if stat_raw == "" { return }
    let sp = stat_raw.split(" ")
    if len(sp) < 2 { return }
    let mtime = sp[0]
    let size = sp[1]
    let head_hash = _head_hash_256(src_path)
    let body = "{\"schema\":\"blowup_v1\",\"mtime\":" + mtime + ",\"size\":" + size + ",\"line_count\":" + to_string(line_count) + ",\"head_hash\":\"" + head_hash + "\",\"nodes\":" + to_string(nodes) + ",\"edges\":" + to_string(edges) + ",\"hubs\":" + to_string(hubs) + "}\n"
    try { write_file(graph_stats_cache_path(), body) } catch e {}
    try { write_file(graph_deg_cache_path(), _serialize_deg_map(deg_map)) } catch e {}
}

// 모든 사이드카 쓰기는 graph_stats_write_cache_full 경유 — deg_map 포함 필수
// (과거의 no-deg wrapper는 line_count=0 불변식 위반 위험으로 제거됨)

// ─── AI-native shell uplift (R0 회피: hexa string OOM 방지) ───
// 발생 원인: content.split("\n") + graph_extract_field(line.split("")) 가
//   12MB+ atlas.n6 처리 시 ~200M small allocs → 126GB OOM (dmesg 확정 2026-04-12)
// 본 함수: awk 1초로 동등한 nodes/edges/hubs 산출 + deg sidecar 생성.
// 결과 무효 시 빈 문자열 반환 → 호출자가 legacy hexa-loop fallback.
fn graph_stats_awk(min_deg: i64) -> string {
    // X1 (2026-04-19): JSON sidecar 우선. node/edge stats 는 atlas.blowup.jsonl 에만 존재.
    let awk_script = _HOME + "/Dev/nexus/shared/blowup/lib/atlas_stats.awk"
    if !file_exists(awk_script) { return "" }
    let mut src_path = _ATLAS_BLOWUP_PATH
    if !file_exists(src_path) {
        // 폴백: 분리 전 환경 (legacy single-file)
        src_path = _ATLAS_PATH
        if !file_exists(src_path) { return "" }
    }
    let deg_path = graph_deg_cache_path()
    let cmd = "awk -v min_deg=" + to_string(min_deg) + " -v deg_path='" + deg_path + "' -f '" + awk_script + "' '" + src_path + "' 2>/dev/null"
    let mut out = ""
    try { out = exec(cmd) } catch e { return "" }
    let trimmed = out.trim()
    // 형식 검증: "nodes|edges|hubs"
    let parts = trimmed.split("|")
    if len(parts) != 3 { return "" }
    return trimmed
}

// awk 우회 후 stats 사이드카 갱신 (deg sidecar 는 awk 가 직접 작성)
fn graph_stats_write_cache_after_awk(nodes: i64, edges: i64, hubs: i64) {
    // X1 (2026-04-19): cache key 는 JSON sidecar mtime/size
    let mut src_path = _ATLAS_BLOWUP_PATH
    if !file_exists(src_path) {
        src_path = _ATLAS_PATH
        if !file_exists(src_path) { return }
    }
    let stat_raw = _stat_mtime_size(src_path)
    if stat_raw == "" { return }
    let sp = stat_raw.split(" ")
    if len(sp) < 2 { return }
    let mtime = sp[0]
    let size = sp[1]
    let head_hash = _head_hash_256(src_path)
    let mut lc_raw = ""
    try { lc_raw = exec("wc -l < '" + src_path + "'") } catch e {}
    let mut line_count: i64 = 0
    try { line_count = to_int(lc_raw.trim()) } catch e {}
    let body = "{\"schema\":\"blowup_v1\",\"mtime\":" + mtime + ",\"size\":" + size + ",\"line_count\":" + to_string(line_count) + ",\"head_hash\":\"" + head_hash + "\",\"nodes\":" + to_string(nodes) + ",\"edges\":" + to_string(edges) + ",\"hubs\":" + to_string(hubs) + "}\n"
    try { write_file(graph_stats_cache_path(), body) } catch e {}
}

// ─── Hot-shard fast path (2026-04-19 sharding migration) ───
// atlas.n6.hot 사이드카 (hub deg≥50 노드 + 모든 axiom 헤더) — atlas.n6 의 ~44%.
// hub 정의상 deg≥50 노드의 모든 edge 는 hot 셔드에 있으므로 graph_hub_count(min_deg=50+) 정확.
// 단, atlas.n6 에 새 append 가 발생하면 hot 사이드카는 stale → freshness 검증 필수.
// 정책: hot/cold 는 query-only 사이드카. atlas.n6 가 SSOT.
fn graph_hot_shard_path() -> string {
    return _ATLAS_PATH + ".hot"
}

fn graph_shard_meta_path() -> string {
    return _ATLAS_PATH + ".shard_meta.json"
}

// hot 사이드카가 atlas.n6 와 동기화 상태인지 확인.
// 검증 조건: shard_meta.json 의 atlas_mtime/atlas_size 가 현재 atlas.n6 와 일치.
// stale 이면 false → 호출자는 atlas.n6 full scan 으로 fallback.
fn graph_hot_shard_fresh() -> bool {
    let meta_path = graph_shard_meta_path()
    if !file_exists(meta_path) { return false }
    if !file_exists(graph_hot_shard_path()) { return false }
    let mut raw = ""
    try { raw = read_file(meta_path) } catch e { return false }
    if raw.trim() == "" { return false }
    let mut meta = #{}
    try { meta = json_parse(raw) } catch e { return false }
    let mut meta_mtime = ""
    let mut meta_size = ""
    try { meta_mtime = to_string(meta["atlas_mtime"]) } catch e { return false }
    try { meta_size = to_string(meta["atlas_size"]) } catch e { return false }
    let stat_raw = _stat_mtime_size(_ATLAS_PATH)
    if stat_raw == "" { return false }
    let sp = stat_raw.split(" ")
    if len(sp) < 2 { return false }
    if sp[0] != meta_mtime { return false }
    if sp[1] != meta_size { return false }
    return true
}

// hub_count fast-path: deg sidecar + hub_threshold 만으로 O(deg_entries) 계산.
// graph_hub_count() 의 content.split("\n") 비용 (~110k lines) 회피 — deg 사이드카는 21k entries.
// 호출 가능 시점: deg 사이드카가 fresh (graph_stats_awk 또는 graph_stats_incremental 직후).
// 미사용 시 graph_hub_count() 가 atlas.n6 full scan 으로 동작 (기존 동작 유지).
fn graph_hub_count_from_deg(min_deg: i64) -> i64 {
    let dpath = graph_deg_cache_path()
    if !file_exists(dpath) { return -1 }
    let deg_map = _load_deg_sidecar(dpath)
    if len(deg_map.keys()) == 0 { return -1 }
    return _count_hubs(deg_map, min_deg)
}

// AI-native: 단일 패스 그래프 통계 — graph_count_type×2 + graph_hub_count 3회 순회 → 1회
// 4단 fast path:
//   1) exact cache hit (mtime+size) → O(1)
//   2) incremental (append-only tail) → O(Δ lines)
//   3) shell uplift (awk) → ~1초/12MB, 메모리 100MB 이내
//   4) hexa fallback full scan → O(total lines), OOM 위험 (legacy)
// 반환: "nodes|edges|hubs" (pipe-separated)
fn graph_stats_single_pass(content: string, min_deg: i64) -> string {
    if len(content) == 0 { return "0|0|0" }
    // 1) exact hit
    let cached = graph_stats_read_cache(min_deg)
    if cached != "" { return cached }
    // 2) incremental (append-only)
    let incr = graph_stats_incremental(content, min_deg)
    if incr != "" { return incr }
    // 3) shell uplift — 12MB+ 에서 hexa-loop OOM 회피
    let shell = graph_stats_awk(min_deg)
    if shell != "" {
        if min_deg == 3 {
            let sp = shell.split("|")
            let mut sn: i64 = 0
            let mut se: i64 = 0
            let mut sh: i64 = 0
            try { sn = to_int(sp[0]) } catch e {}
            try { se = to_int(sp[1]) } catch e {}
            try { sh = to_int(sp[2]) } catch e {}
            graph_stats_write_cache_after_awk(sn, se, sh)
        }
        return shell
    }
    // 4) hexa fallback 제거 (126GB OOM 경로 — 2026-04-12 dmesg 확정).
    // tiers 1~3 실패 시: awk 스크립트 부재가 원인. 0|0|0 반환 + 경고.
    println("  [WARN] graph_stats: cache miss + awk unavailable — returning 0|0|0")
    println("  [WARN] atlas_stats.awk 존재 확인: " + _HOME + "/Dev/nexus/shared/blowup/lib/atlas_stats.awk")
    return "0|0|0"
}

// Find hub node IDs (degree >= min_deg) — O(edges) using native Map (hashmap)
fn graph_hub_count(content: string, min_deg: i64) -> i64 {
    if len(content) == 0 { return 0 }
    let lines = content.split("\n")
    let mut deg_map = #{}  // node_id → degree (native hashmap O(1) lookup)
    let mut li: i64 = 0
    while li < len(lines) {
        let line = lines[li]
        if len(line) > 5 {
            let t = graph_extract_field(line, "type")
            if t == "edge" {
                let f = graph_extract_field(line, "from")
                let to = graph_extract_field(line, "to")
                if len(f) > 0 {
                    let mut d: i64 = 0
                    try { d = deg_map[f] } catch e {}
                    deg_map[f] = d + 1
                }
                if len(to) > 0 {
                    let mut d: i64 = 0
                    try { d = deg_map[to] } catch e {}
                    deg_map[to] = d + 1
                }
            }
        }
        li = li + 1
    }
    // Count hubs
    let vals = deg_map.values()
    let mut hub_count: i64 = 0
    let mut hi: i64 = 0
    while hi < len(vals) {
        let d: i64 = vals[hi]
        if d >= min_deg { hub_count = hub_count + 1 }
        hi = hi + 1
    }
    return hub_count
}

// Check if a node ID already exists
// AI-native: node ID 해시셋 1회 빌드 → graph_node_exists O(1) (OPT-08, 2026-04-12)
// 13MB content.contains() O(n) per call → hashmap O(1). 2곳 호출 × ~17k nodes = 34k × O(n) 제거.
fn _build_node_id_set(content: string) {
    if _node_id_set_built { return }
    let lines = content.split("\n")
    let mut i: i64 = 0
    while i < len(lines) {
        let line = lines[i]
        if len(line) > 10 {
            let id = graph_extract_field(line, "id")
            if len(id) > 0 {
                _node_id_set[id] = true
            }
        }
        i = i + 1
    }
    _node_id_set_built = true
}

fn graph_node_exists(content: string, id: string) -> bool {
    if len(content) == 0 { return false }
    _build_node_id_set(content)
    let mut found = false
    found = hset_has(_node_id_set, id)
    return found
}

fn graph_append_node(id: string, node_type: string, dom: string, summary: string, conf: f64) -> string {
    return graph_append_node_d(id, node_type, dom, summary, conf, 0)
}

fn graph_append_node_d(id: string, node_type: string, dom: string, summary: string, conf: f64, d: i64) -> string {
    return "{\"type\":\"node\",\"id\":\"" + id + "\",\"node_type\":\"" + node_type + "\",\"domain\":\"" + dom + "\",\"summary\":\"" + summary + "\",\"confidence\":" + to_string(conf) + ",\"depth\":" + to_string(d) + "}"
}

fn graph_append_edge(from_id: string, to_id: string, edge_type: string, strength: f64) -> string {
    return "{\"type\":\"edge\",\"from\":\"" + from_id + "\",\"to\":\"" + to_id + "\",\"edge_type\":\"" + edge_type + "\",\"strength\":" + to_string(strength) + ",\"bidirectional\":false}"
}

// ═══════════════════════════════════════════════════════════
// ─── OUROBOROS EVOLUTION (from ouroboros.hexa) ───
// ═══════════════════════════════════════════════════════════
_trace("[TR-F-ouroboros]")

// Mutation: parameter shift by n=6 constants
fn evo_mutate_shift(base_val: f64, shift_idx: i64) -> f64 {
    // Dynamic: n6_constants.jsonl 전체 상수로 shift (float cache)
    if _n6_dyn_count == 0 { return base_val + 6.0 }
    let idx = shift_idx % _n6_dyn_count
    let cv: f64 = _n6_fcache[idx]
    if abs_f(cv) < 0.001 { return base_val }
    if shift_idx % 2 == 0 { return base_val * cv }
    return base_val + cv
}

// Mutation: inversion
fn evo_mutate_invert(base_val: f64) -> f64 {
    if abs_f(base_val) > 0.0000000001 { return 1.0 / base_val }
    return 0.0
}

// Mutation: combination (geometric mean of two values)
fn evo_mutate_combine(a: f64, b: f64) -> f64 {
    return sqrt_f(abs_f(a) * abs_f(b))
}

// S5 (2026-04-19): seed-aware verification — domain seed 본질이 verify_score 에 반영.
//   기존: n6_conf(value) 만으로 계산 → seed 무관 (동일 value 는 동일 score).
//   신규: seed_n6_ratio(domain) 을 bias 로 블렌드 (α=0.85 value-dominant, β=0.15 seed-dominant)
//   효과: 동일 feature vector 의 seed-less 흐름 파괴 → test_A vs test_B score stddev > 0.
// 불변식: n=6 invariant (seed_n6_ratio 내부 basis 유지), 범위 [0,1] clamp01.
// 글로벌: _verify_seed_str — Phase 2 진입 전 set (초기 "" 이면 bias 0, 레거시 동작).
let mut _verify_seed_str: string = ""
let mut _verify_seed_bias: f64 = 0.0

fn evo_verify(value: f64) -> f64 {
    let base = n6_conf(value)
    if _verify_seed_str == "" { return base }
    // seed_n6_ratio ∈ [0, 8D dot]. normalize by basis L2 sum (≈ 5.69) → [0,1] 목표대역.
    // 결정론 blend: score = 0.85 * base + 0.15 * clamp01(seed_ratio / 5.69)
    let seed_norm = clamp01(_verify_seed_bias / 5.69)
    let blended = 0.85 * base + 0.15 * seed_norm
    return clamp01(blended)
}

// Run one evolution cycle on seed values, return best score and mutated values
// seeds_csv: pipe-separated float values
// Returns pipe-separated result: "best_score|num_discoveries|val1|val2|..."
fn evo_cycle(seeds_csv: string, cycle_num: i64) -> string {
    let parts = seeds_csv.split("|")
    let mut best_score: f64 = 0.0
    let mut discoveries: i64 = 0
    let mut out_parts: [string] = []

    // For each seed value, apply mutations and keep best
    let mut si: i64 = 0
    while si < len(parts) && si < 48 {
        let mut sv: f64 = 0.0
        try { sv = to_float(parts[si]) } catch e { sv = 0.0 }
        if abs_f(sv) > 0.0000000001 {
            // Try 4 mutation strategies, keep the one with best n6 alignment
            let mut best_mut = sv
            let mut best_conf: f64 = evo_verify(sv)

            // AI-native: 전 전략 보존, EXACT(>=0.99) 시 조기탈출만 추가 (창발 유지)

            // strategy 0: parameter shift (dynamic — n6_constants 전체, --fast: 8개 제한)
            let _shift_cap: i64 = if fast_mode { 8 } else { 16 }
            let shift_limit: i64 = if _n6_dyn_count < _shift_cap { _n6_dyn_count } else { _shift_cap }
            let mut shi: i64 = 0
            while shi < shift_limit && best_conf < 0.99 {
                let shifted = evo_mutate_shift(sv, shi)
                let sc = evo_verify(shifted)
                if sc > best_conf {
                    best_conf = sc
                    best_mut = shifted
                }
                shi = shi + 1
            }

            // strategy 1: inversion
            if best_conf < 0.99 {
                let inv = evo_mutate_invert(sv)
                let inv_sc = evo_verify(inv)
                if inv_sc > best_conf {
                    best_conf = inv_sc
                    best_mut = inv
                }
            }

            // strategy 2: combination with next seed
            if best_conf < 0.99 && si + 1 < len(parts) {
                let mut sv2: f64 = 0.0
                try { sv2 = to_float(parts[si + 1]) } catch e { sv2 = 0.0 }
                if abs_f(sv2) > 0.0000000001 {
                    let combined = evo_mutate_combine(sv, sv2)
                    let comb_sc = evo_verify(combined)
                    if comb_sc > best_conf {
                        best_conf = comb_sc
                        best_mut = combined
                    }
                }
            }

            // strategy 3: domain transfer (scale by novelty factor)
            if best_conf < 0.99 {
                let novelty = 1.0 / sqrt_f(to_float(if cycle_num > 0 { cycle_num } else { 1 }))
                let xfer = sv * (1.0 + novelty * 0.1)
                let xfer_sc = evo_verify(xfer)
                if xfer_sc > best_conf {
                    best_conf = xfer_sc
                    best_mut = xfer
                }
            }

            // strategy 4: simulated annealing — temperature-scaled random walk
            if best_conf < 0.99 {
                let temperature = 1.0 / (1.0 + to_float(cycle_num))
                let sa_shift = sv * temperature * 0.05
                let sa_plus = sv + sa_shift
                let sa_minus = sv - sa_shift
                let sa_plus_sc = evo_verify(sa_plus)
                let sa_minus_sc = evo_verify(sa_minus)
                if sa_plus_sc > best_conf {
                    best_conf = sa_plus_sc
                    best_mut = sa_plus
                }
                if sa_minus_sc > best_conf {
                    best_conf = sa_minus_sc
                    best_mut = sa_minus
                }
            }

            // strategy 5: golden crossover — blend with distant seed (Fibonacci weighting)
            if best_conf < 0.99 {
                let phi = 1.618033989
                let distant_idx = if si + 3 < len(parts) { si + 3 } else { 0 }
                let mut sv_dist: f64 = 0.0
                try { sv_dist = to_float(parts[distant_idx]) } catch e { sv_dist = 0.0 }
                if abs_f(sv_dist) > 0.0000000001 {
                    let golden_blend = sv * (phi / (1.0 + phi)) + sv_dist * (1.0 / (1.0 + phi))
                    let gb_sc = evo_verify(golden_blend)
                    if gb_sc > best_conf {
                        best_conf = gb_sc
                        best_mut = golden_blend
                    }
                }
            }

            // strategy 6: harmonic resonance — test n=6 divisor multiples/fractions
            if best_conf < 0.99 {
                let divisors = [1.0, 2.0, 3.0, 6.0]
                let mut di2: i64 = 0
                while di2 < 4 {
                    let harm_mul = sv * divisors[di2]
                    let harm_div = sv / divisors[di2]
                    let hm_sc = evo_verify(harm_mul)
                    let hd_sc = evo_verify(harm_div)
                    if hm_sc > best_conf {
                        best_conf = hm_sc
                        best_mut = harm_mul
                    }
                    if hd_sc > best_conf {
                        best_conf = hd_sc
                        best_mut = harm_div
                    }
                    di2 = di2 + 1
                }
            }

            if best_conf > best_score { best_score = best_conf }
            if best_conf >= 0.25 { discoveries = discoveries + 1 }

            out_parts.push(to_string(best_mut))
        }
        si = si + 1
    }

    let out_vals = out_parts.join("|")
    return to_string(best_score) + "|" + to_string(discoveries) + "|" + out_vals
}

// Convergence check: given discovery counts per cycle, detect saturation
// history_csv: pipe-separated integers
fn evo_check_convergence(history_csv: string) -> string {
    let parts = history_csv.split("|")
    let hlen: i64 = len(parts)
    if hlen < 3 { return "Exploring" }

    // Check if last 3 all zero
    let mut all_zero = true
    let mut ci: i64 = hlen - 3
    if ci < 0 { ci = 0 }
    while ci < hlen {
        let mut v: i64 = 0
        try { v = to_int(parts[ci]) } catch e { v = 0 }
        if v > 0 { all_zero = false }
        ci = ci + 1
    }
    if all_zero { return "Saturated" }

    // Check acceleration: last cycle has highest count
    let mut last_v: i64 = 0
    try { last_v = to_int(parts[hlen - 1]) } catch e { last_v = 0 }
    let mut max_v: i64 = 0
    let mut mi: i64 = 0
    while mi < hlen - 1 {
        let mut mv: i64 = 0
        try { mv = to_int(parts[mi]) } catch e { mv = 0 }
        if mv > max_v { max_v = mv }
        mi = mi + 1
    }
    if last_v > max_v && last_v > 0 { return "Accelerating" }

    // Check convergence: first half vs second half
    if hlen < 4 { return "Exploring" }
    let mid: i64 = hlen / 2
    let mut early_sum: i64 = 0
    ci = 0
    while ci < mid {
        try { early_sum = early_sum + to_int(parts[ci]) } catch e {}
        ci = ci + 1
    }
    let mut late_sum: i64 = 0
    ci = mid
    while ci < hlen {
        try { late_sum = late_sum + to_int(parts[ci]) } catch e {}
        ci = ci + 1
    }
    let early_avg = to_float(early_sum) / to_float(mid)
    let late_len = hlen - mid
    let late_avg = to_float(late_sum) / to_float(late_len)

    if early_avg > 0.0 {
        let ratio = late_avg / early_avg
        if ratio < 0.5 { return "Converging" }
        if ratio > 1.5 { return "Divergent" }
    }
    return "Exploring"
}

// ═══════════════════════════════════════════════════════════
// ─── TELESCOPE LENS SCANS (from telescope.hexa) ───
// ═══════════════════════════════════════════════════════════
_trace("[TR-G-telescope]")
// Lightweight versions of the 5 core lenses, operating on
// corollary value arrays (float[]). Each returns a signal
// score 0.0..1.0 and a label string.

// Lens 1: Consciousness — self-reference pattern count
// Checks how many pairs (i,j) have ratio close to an n=6 constant
fn lens_consciousness(fv: list, n: i64) -> f64 {
    if n < 2 { return 0.0 }
    let mut self_ref: i64 = 0
    let mut i: i64 = 0
    while i < n && i < 30 {
        let vi: f64 = fv[i]
        let mut j: i64 = i + 1
        while j < n && j < 30 {
            let vj: f64 = fv[j]
            if abs_f(vj) > 0.0000000001 {
                let ratio = vi / vj
                if abs_f(ratio - 6.0) < 0.01 { self_ref = self_ref + 1 }
                if abs_f(ratio - 12.0) < 0.01 { self_ref = self_ref + 1 }
                if abs_f(ratio - 2.0) < 0.01 { self_ref = self_ref + 1 }
                if abs_f(ratio - 4.0) < 0.01 { self_ref = self_ref + 1 }
                if abs_f(ratio - 24.0) < 0.01 { self_ref = self_ref + 1 }
                if abs_f(ratio - 5.0) < 0.01 { self_ref = self_ref + 1 }
                if abs_f(ratio - 3.0) < 0.01 { self_ref = self_ref + 1 }
            }
            j = j + 1
        }
        i = i + 1
    }
    let max_pairs = to_float(n * (n - 1) / 2)
    if max_pairs < 1.0 { return 0.0 }
    return clamp01(to_float(self_ref) / max_pairs)
}

// Lens 2: Topology — Betti-0 (connected components via gap detection)
fn lens_topology(fv: list, n: i64) -> f64 {
    if n < 3 { return 0.0 }
    let limit: i64 = if n < 40 { n } else { 40 }
    // compute mean for threshold (pre-parsed floats — split/to_float 제거)
    let mut sum: f64 = 0.0
    let mut si: i64 = 0
    while si < limit {
        sum = sum + fv[si]
        si = si + 1
    }
    let mean = if limit > 0 { sum / to_float(limit) } else { 1.0 }
    let threshold = if abs_f(mean) > 0.0 { abs_f(mean) * 0.5 } else { 1.0 }

    // count gaps (consecutive value differences)
    let mut gaps: i64 = 0
    si = 0
    while si < limit - 1 {
        if abs_f(fv[si + 1] - fv[si]) > threshold { gaps = gaps + 1 }
        si = si + 1
    }

    let betti0: i64 = gaps + 1
    let mut cycles: i64 = 0
    let climit: i64 = if limit < 20 { limit } else { 20 }
    si = 0
    while si < climit {
        let mut sj: i64 = si + 2
        while sj < climit {
            if abs_f(fv[si] - fv[sj]) < threshold * 0.1 { cycles = cycles + 1 }
            sj = sj + 1
        }
        si = si + 1
    }

    let sig = to_float(betti0 - 1) * 0.3 + to_float(cycles) * 0.1
    return clamp01(sig)
}

// Lens 3: Causal — autocorrelation (lag-1) (pre-parsed float list)
fn lens_causal(fv: list, n: i64) -> f64 {
    if n < 4 { return 0.0 }
    let limit: i64 = if n < 50 { n } else { 50 }

    let mut sum: f64 = 0.0
    let mut ci: i64 = 0
    while ci < limit {
        sum = sum + fv[ci]
        ci = ci + 1
    }
    let mean = sum / to_float(limit)

    let mut cov: f64 = 0.0
    let mut var: f64 = 0.0
    ci = 0
    while ci < limit - 1 {
        let d0 = fv[ci] - mean
        let d1 = fv[ci + 1] - mean
        cov = cov + d0 * d1
        var = var + d0 * d0
        ci = ci + 1
    }
    let autocorr = if var > 0.0 { cov / var } else { 0.0 }

    let mid: i64 = limit / 2
    let mut first_sum: f64 = 0.0
    ci = 0
    while ci < mid {
        first_sum = first_sum + fv[ci]
        ci = ci + 1
    }
    let mut second_sum: f64 = 0.0
    ci = mid
    while ci < limit {
        second_sum = second_sum + fv[ci]
        ci = ci + 1
    }
    let first_mean = first_sum / to_float(mid)
    let second_mean = second_sum / to_float(limit - mid)
    let direction = abs_f(second_mean - first_mean)

    let sig = abs_f(autocorr) * 0.6 + clamp01(direction * 0.1) * 0.4
    return clamp01(sig)
}

// Lens 4: Gravity — attractor detection (pre-parsed float list)
fn lens_gravity(fv: list, n: i64) -> f64 {
    if n < 3 { return 0.0 }
    let limit: i64 = if n < 50 { n } else { 50 }

    let mut attracted: i64 = 0
    let mut ci: i64 = 0
    while ci < limit {
        let v: f64 = fv[ci]

        if abs_f(v - 6.0) / 6.0 < 0.05 { attracted = attracted + 1 }
        if abs_f(v - 12.0) / 12.0 < 0.05 { attracted = attracted + 1 }
        if abs_f(v - 2.0) / 2.0 < 0.05 { attracted = attracted + 1 }
        if abs_f(v - 4.0) / 4.0 < 0.05 { attracted = attracted + 1 }
        if abs_f(v - 24.0) / 24.0 < 0.05 { attracted = attracted + 1 }
        if abs_f(v - 5.0) / 5.0 < 0.05 { attracted = attracted + 1 }
        if abs_f(v - 137.036) / 137.036 < 0.01 { attracted = attracted + 1 }
        if abs_f(v - 0.3153) / 0.3153 < 0.05 { attracted = attracted + 1 }

        ci = ci + 1
    }

    return clamp01(to_float(attracted) / to_float(limit))
}

// Lens 5: Thermo — Shannon entropy approximation (pre-parsed float list + native Map)
fn lens_thermo(fv: list, n: i64) -> f64 {
    if n < 2 { return 0.0 }
    let limit: i64 = if n < 50 { n } else { 50 }

    let mut bin_map = #{}
    let mut ci: i64 = 0
    while ci < limit {
        let bin_key = to_string(to_int(fv[ci] * 10.0))
        let mut old_c: i64 = 0
        try { old_c = bin_map[bin_key] } catch e {}
        bin_map[bin_key] = old_c + 1
        ci = ci + 1
    }

    let cnt_vals = bin_map.values()
    let num_bins: i64 = len(cnt_vals)
    let total = to_float(limit)
    let mut entropy: f64 = 0.0
    ci = 0
    while ci < num_bins {
        let c: f64 = to_float(cnt_vals[ci])
        let p = c / total
        if p > 0.0 { entropy = entropy - p * ln_f(p) }
        ci = ci + 1
    }

    let max_ent = ln_f(to_float(if num_bins > 1 { num_bins } else { 2 }))
    if max_ent > 0.0 {
        return clamp01(entropy / max_ent)
    }
    return 0.0
}

// Run all 5 lenses and return consensus count (how many report signal > threshold)
// Also returns boosted confidence multiplier
fn telescope_verify(vals: string, threshold: f64) -> string {
    // Pre-parse: 1회 split + to_float → 5개 렌즈가 공유 (5회 split 제거)
    let _tp = vals.split("|")
    let _tn: i64 = len(_tp)
    let mut _tfv: list = []
    let mut _ti: i64 = 0
    while _ti < _tn {
        let mut _tv: f64 = 0.0
        try { _tv = to_float(_tp[_ti]) } catch e {}
        _tfv = _tfv.push(_tv)
        _ti = _ti + 1
    }
    let s1 = lens_consciousness(_tfv, _tn)
    let s2 = lens_topology(_tfv, _tn)
    let s3 = lens_causal(_tfv, _tn)
    let s4 = lens_gravity(_tfv, _tn)
    let s5 = lens_thermo(_tfv, _tn)

    let mut agree: i64 = 0
    if s1 >= threshold { agree = agree + 1 }
    if s2 >= threshold { agree = agree + 1 }
    if s3 >= threshold { agree = agree + 1 }
    if s4 >= threshold { agree = agree + 1 }
    if s5 >= threshold { agree = agree + 1 }

    // consensus level
    let mut level = "None"
    if agree >= 4 { level = "High" } else if agree >= 3 { level = "Candidate" }

    // confidence boost: 3+ agreement = +0.1, 4+ = +0.15, 5 = +0.2
    let mut boost = 0.0
    if agree >= 5 { boost = 0.2 }
    else if agree >= 4 { boost = 0.15 }
    else if agree >= 3 { boost = 0.1 }

    return to_string(agree) + "|" + level + "|" + to_string(boost) + "|" + to_string(s1) + "|" + to_string(s2) + "|" + to_string(s3) + "|" + to_string(s4) + "|" + to_string(s5)
}


