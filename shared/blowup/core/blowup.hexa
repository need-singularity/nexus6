    println("  hubs (deg>=3)    :", graph_hubs_before)
} else {
    println("--- Phase 1: Graph Load (skipped --no-graph) ---")
}
println("")

// ═══════════════════════════════════════════════════════════
// PHASE 2: OUROBOROS Evolution
// ═══════════════════════════════════════════════════════════

println("--- Phase 2: OUROBOROS Evolution ---")
// Build seed values from domain metrics
let mut seed_csv = ""
let mut si: i64 = 0
while si < mc {
    if len(seed_csv) > 0 { seed_csv = seed_csv + "|" }
    seed_csv = seed_csv + to_string(m_val(si, domain))
    si = si + 1
}

let evo_max_cycles: i64 = if fast_mode { if max_depth < 3 { max_depth } else { 3 } } else { if max_depth < 8 { max_depth } else { 8 } }
let mut evo_history = ""
let mut evo_total_disc: i64 = 0
let mut evo_best_score: f64 = 0.0
let mut current_seeds = seed_csv
let mut evo_status = "Exploring"

let mut ec: i64 = 0
while ec < evo_max_cycles {
    let result = evo_cycle(current_seeds, ec + 1)
    let rparts = result.split("|")
    let mut cycle_score: f64 = 0.0
    let mut cycle_disc: i64 = 0
    try { cycle_score = to_float(rparts[0]) } catch e {}
    try { cycle_disc = to_int(rparts[1]) } catch e {}

    if cycle_score > evo_best_score { evo_best_score = cycle_score }
    evo_total_disc = evo_total_disc + cycle_disc

    // Update history
    if len(evo_history) > 0 { evo_history = evo_history + "|" }
    evo_history = evo_history + to_string(cycle_disc)

    // Extract evolved values for next cycle
    let mut new_seeds = ""
    let mut ri: i64 = 2
    while ri < len(rparts) {
        if len(new_seeds) > 0 { new_seeds = new_seeds + "|" }
        new_seeds = new_seeds + rparts[ri]
        ri = ri + 1
    }
    if len(new_seeds) > 0 { current_seeds = new_seeds }

    evo_status = evo_check_convergence(evo_history)
    println("  cycle " + to_string(ec + 1) + ": score=" + to_string(cycle_score) + " disc=" + to_string(cycle_disc) + " status=" + evo_status)

    if evo_status == "Saturated" {
        println("  -> SATURATED at cycle " + to_string(ec + 1))
        ec = evo_max_cycles  // break
    }
    ec = ec + 1
}

println("  evolution total  : " + to_string(evo_total_disc) + " discoveries, best=" + to_string(evo_best_score))
println("")
try { arena_reset() } catch e {}  // AI-native: Phase 2 임시 메모리 해제

// ═══════════════════════════════════════════════════════════
// PHASE 3: Singularity Detection (enhanced with evolution)
// ═══════════════════════════════════════════════════════════

println("--- Phase 3: Singularity Detection ---")
let mut frozen: i64 = 0
si = 0
while si < mc {
    if n6_distance(m_val(si, domain)) < 0.01 { frozen = frozen + 1 }
    si = si + 1
}
let closure = to_float(frozen) / to_float(mc)
let ax_count = if frozen > 0 { frozen } else { 1 }
let compression = to_float(mc) / to_float(ax_count)

// Evolution enhances closure: high evo score indicates deeper structure
let evo_boost = evo_best_score * 0.1
let effective_closure = min_f(closure + evo_boost, 1.0)

println("  closure (raw)    :", closure)
println("  evo boost        : +" + to_string(evo_boost))
println("  closure (eff)    :", effective_closure)
println("  compression      :", compression)
println("  axiom count      :", ax_count)

if effective_closure >= 0.5 {
    println("  * SINGULARITY DETECTED -- closed system, blowup engaged")
} else {
    println("  o open system -- closure < 0.5, weak blowup")
}
println("")
try { arena_reset() } catch e {}  // AI-native: Phase 3 임시 메모리 해제

// ═══════════════════════════════════════════════════════════
// PHASE 4: Recursive Blowup Corollary Generation (7 types)
// ═══════════════════════════════════════════════════════════

println("--- Phase 4: Recursive Blowup Corollary Generation ---")
println("  max_depth :", max_depth)
println("")

let mut buf_lines = []
let mut total: i64 = 0
let mut exact_count: i64 = 0
let mut near_count: i64 = 0
let mut high_conf_count: i64 = 0
let mut axiom_count: i64 = 0
let mut log_buf = ""
let mut logged: i64 = 0

// AI-native: 메모리 캡 — OOM 방지
let _BUF_CAP: i64 = 8000
let _VAL_CAP: i64 = 200
let mut _val_total_seen: i64 = 0

// buf_lines 저신뢰 일괄 제거 — cap 초과 시 최저 conf 500개 제거
fn buf_prune(buf: list, cap: i64) -> list {
    if len(buf) <= cap { return buf }
    // conf 기준 하위 500개 찾기
    let prune_n: i64 = len(buf) - cap + 500
    let mut confs = []
    let mut pi: i64 = 0
    while pi < len(buf) {
        let mut pc: f64 = 1.0
        let pp = buf[pi].split("\t")
        if len(pp) >= 4 {
            try { pc = to_float(pp[3]) } catch e {}
        }
        confs = confs.push(pc)
        pi = pi + 1
    }
    // 하한 threshold 찾기 (prune_n번째로 낮은 conf)
    let mut sorted_confs = []
    pi = 0
    while pi < len(confs) {
        sorted_confs = sorted_confs.push(confs[pi])
        pi = pi + 1
    }
    sorted_confs = sorted_confs.sort()
    let threshold: f64 = if prune_n < len(sorted_confs) { sorted_confs[prune_n] } else { 0.0 }
    // threshold 이하 제거
    let mut result = []
    let mut removed: i64 = 0
    pi = 0
    while pi < len(buf) {
        if confs[pi] <= threshold && removed < prune_n {
            removed = removed + 1
        } else {
            result = result.push(buf[pi])
        }
        pi = pi + 1
    }
    return result
}

// Collect all corollary values for telescope (phase 5)
// AI-native: 저수지 샘플링 — 200개 상한 (telescope은 100~200개면 충분)
let mut val_arr = []

// Build initial axiom pool — 외부 seed 있으면 동적, 없으면 도메인 메트릭
let mut ax_name_arr = []
let mut ax_val_arr = []
let mut ax_n: i64 = 0
// O(1) dedup: .contains() O(n) 선형탐색 → hashmap O(1) 전환
let mut ax_name_set = #{}

if ext_seeds.len() > 0 {
    // --seeds 모드: seed_engine 출력 사용 (구분자: , 또는 |)
    let _sep = if ext_seeds.contains(",") { "," } else { "|" }
    let seed_parts = ext_seeds.split(_sep)
    let mut si: i64 = 0
    while si < seed_parts.len() {
        let sp_trimmed = seed_parts[si].trim()
        if sp_trimmed != "" {
            let sv = safe_float(sp_trimmed)
            if sv != 0.0 || sp_trimmed == "0" || sp_trimmed == "0.0" {
                ax_val_arr = ax_val_arr.push(sv)
                let nm = match_name(sv)
                let _sn = if nm != "" { nm } else { "s" + to_string(si) }
                ax_name_arr = ax_name_arr.push(_sn)
                ax_name_set[_sn] = 1
                ax_n = ax_n + 1
            }
        }
        si = si + 1
    }
    println("  seed source: DYNAMIC (" + to_string(ax_n) + " seeds from --seeds)")
} else {
    // 기본: 도메인 메트릭
    let mut init_i: i64 = 0
    while init_i < mc {
        let _mn = m_name(init_i, domain)
        ax_name_arr = ax_name_arr.push(_mn)
        ax_name_set[_mn] = 1
        ax_val_arr = ax_val_arr.push(m_val(init_i, domain))
        ax_n = ax_n + 1
        init_i = init_i + 1
    }
    println("  seed source: STATIC (" + to_string(ax_n) + " domain metrics)")
}

// Per-depth stats tracking (pipe-separated)
let mut depth_stats = ""

// ─── DEPTH LOOP ───
let mut depth: i64 = 0
while depth < max_depth {
    // AI-native: 메모리 압력 체크 — 90% 초과 시 조기 종료
    if !mem_check_ok() {
        println("  [MEM] memory pressure at depth " + to_string(depth) + ", stopping early")
        depth = max_depth
        continue
    }
    let pool_before = ax_n
    let total_before = total
    let axiom_before = axiom_count

    // Collect new axiom candidates found at this depth
    let mut new_ax_name_arr = []
    let mut new_ax_val_arr = []
    let mut new_ax_n: i64 = 0
    let mut new_ax_set = #{}

    let cur_n = ax_n
    let phi_g = 1.618033988749895

    // --- 1. Pairwise deduction ---
    let mut i: i64 = 0
    while i < cur_n {
        let mut j: i64 = i + 1
        while j < cur_n {
            let va = ax_val_arr[i]
            let vb = ax_val_arr[j]
            let na = ax_name_arr[i]
            let nb = ax_name_arr[j]
            let product = va * vb
            let ratio = if abs_f(vb) > 0.0000000001 { va / vb } else { 0.0 }
            let sum = va + vb

            let dp = n6_distance(product)
            let dr = n6_distance(ratio)
            let ds = n6_distance(sum)

            let mut bv = product
            let mut bd = dp
            let mut bo = "*"
            if dr < bd {
                bv = ratio
                bd = dr
                bo = "/"
            }
            if ds < bd {
                bv = sum
                bd = ds
                bo = "+"
            }

            let conf = max_f(1.0 - bd, 0.0)
            if conf >= 0.1 {
                let nm = "d" + to_string(depth) + "_ded_" + na + "_" + nb
                let ex = na + " " + bo + " " + nb + " = " + to_string(bv)
                let is_ax = conf > 0.8
                buf_lines = buf_lines.push(emit(nm, "deduction", ex, conf, bv, is_ax, na))
                total = total + 1
                _val_total_seen = _val_total_seen + 1
                if len(val_arr) < _VAL_CAP {
                    val_arr = val_arr.push(to_string(bv))
                } else {
                    let _ri = random_int(0, _val_total_seen)
                    if _ri < _VAL_CAP { val_arr[_ri] = to_string(bv) }
                }
                // AI-native: match_grade_name 단일패스 (grade+name 2회 스캔 → 1회)
                let _gn = match_grade_name(bv)
                let _gnp = _gn.split("|")
                let gr = _gnp[0]
                let _matched_name = if len(_gnp) > 1 { _gnp[1] } else { "" }
                if gr == "EXACT" { exact_count = exact_count + 1 }
                if gr == "NEAR" { near_count = near_count + 1 }
                if conf >= 0.7 { high_conf_count = high_conf_count + 1 }
                if is_ax {
                    axiom_count = axiom_count + 1
                    let cand_label = if _matched_name != "" { _matched_name } else { nm }
                    if !hset_has(ax_name_set, cand_label) && !hset_has(new_ax_set, cand_label) {
                        new_ax_name_arr = new_ax_name_arr.push(cand_label)
                        new_ax_set[cand_label] = 1
                        new_ax_val_arr = new_ax_val_arr.push(bv)
                        new_ax_n = new_ax_n + 1
                    }
                }
                if gr == "EXACT" && !is_ax {
                    if _matched_name != "" && !hset_has(ax_name_set, _matched_name) && !hset_has(new_ax_set, _matched_name) {
                        new_ax_name_arr = new_ax_name_arr.push(_matched_name)
                        new_ax_set[_matched_name] = 1
                        new_ax_val_arr = new_ax_val_arr.push(bv)
                        new_ax_n = new_ax_n + 1
                    }
                }
            }
            j = j + 1
        }
        i = i + 1
    }

    // --- 2. Domain transfer ---
    i = 0
    while i < cur_n {
        let mut di: i64 = 0
        while di < 6 {
            let v = ax_val_arr[i]
            let na = ax_name_arr[i]
            let conf = n6_conf(v) * 0.7
            if conf >= 0.15 {
                let nm = "d" + to_string(depth) + "_xfer_" + na + "_" + xfer_domain(di)
                let ex = na + "=" + to_string(v) + " in " + xfer_domain(di)
                buf_lines = buf_lines.push(emit(nm, "transfer", ex, conf, v, false, na))
                total = total + 1
                _val_total_seen = _val_total_seen + 1
                if len(val_arr) < _VAL_CAP {
                    val_arr = val_arr.push(to_string(v))
                } else {
                    let _ri2 = random_int(0, _val_total_seen)
                    if _ri2 < _VAL_CAP { val_arr[_ri2] = to_string(v) }
                }
                let gr = match_grade(v)
                if gr == "EXACT" { exact_count = exact_count + 1 }
                if gr == "NEAR" { near_count = near_count + 1 }
                if conf >= 0.7 { high_conf_count = high_conf_count + 1 }
            }
            di = di + 1
        }
        i = i + 1
    }

    // --- 3. Symmetry break ---
    i = 0
    while i < cur_n {
        let v = ax_val_arr[i]
        let na = ax_name_arr[i]
        let bp = v + phi_g
        let bm = v - phi_g
        let dp = n6_distance(bp)
        let dm = n6_distance(bm)
        let mut best = bp
        let mut best_d = dp
        let mut sign = "+"
        if dm < dp {
            best = bm
            best_d = dm
            sign = "-"
        }
        let conf = max_f(1.0 - best_d, 0.0)
        if conf >= 0.2 {
            let nm = "d" + to_string(depth) + "_sym_" + na
            let ex = na + " " + sign + " phi = " + to_string(best)
            let is_ax = conf > 0.7
            buf_lines = buf_lines.push(emit(nm, "symbreak", ex, conf, best, is_ax, na))
            total = total + 1
            _val_total_seen = _val_total_seen + 1
            if len(val_arr) < _VAL_CAP {
                val_arr = val_arr.push(to_string(best))
            } else {
                let _ri3 = random_int(0, _val_total_seen)
                if _ri3 < _VAL_CAP { val_arr[_ri3] = to_string(best) }
            }
            let _gn3 = match_grade_name(best)
            let _gnp3 = _gn3.split("|")
            let gr = _gnp3[0]
            let _mn3 = if len(_gnp3) > 1 { _gnp3[1] } else { "" }
            if gr == "EXACT" { exact_count = exact_count + 1 }
            if gr == "NEAR" { near_count = near_count + 1 }
            if conf >= 0.7 { high_conf_count = high_conf_count + 1 }
            if is_ax {
                axiom_count = axiom_count + 1
                let cand_label = if _mn3 != "" { _mn3 } else { nm }
                if !hset_has(ax_name_set, cand_label) && !hset_has(new_ax_set, cand_label) {
                    new_ax_name_arr = new_ax_name_arr.push(cand_label)
                    new_ax_set[cand_label] = 1
                    new_ax_val_arr = new_ax_val_arr.push(best)
                    new_ax_n = new_ax_n + 1
                }
            }
            if gr == "EXACT" && !is_ax {
                if _mn3 != "" && !hset_has(ax_name_set, _mn3) && !hset_has(new_ax_set, _mn3) {
                    new_ax_name_arr = new_ax_name_arr.push(_mn3)
                    new_ax_set[_mn3] = 1
                    new_ax_val_arr = new_ax_val_arr.push(best)
                    new_ax_n = new_ax_n + 1
                }
            }
        }
        i = i + 1
    }

    // --- 4. Bifurcation ---
    i = 0
    while i < cur_n {
        let mut k: i64 = 0
        while k < 6 {
            let shifted = ax_val_arr[i] + shift_val(k)
            let na = ax_name_arr[i]
            let conf = max_f(1.0 - n6_distance(shifted), 0.0) * 0.6
            if conf >= 0.2 {
                let nm = "d" + to_string(depth) + "_bif_" + na + "_" + shift_name(k)
                let ex = na + "+" + shift_name(k) + "=" + to_string(shifted)
                buf_lines = buf_lines.push(emit(nm, "bifurc", ex, conf, shifted, false, na))
                total = total + 1
                _val_total_seen = _val_total_seen + 1
                if len(val_arr) < _VAL_CAP {
                    val_arr = val_arr.push(to_string(shifted))
                } else {
                    let _ri4 = random_int(0, _val_total_seen)
                    if _ri4 < _VAL_CAP { val_arr[_ri4] = to_string(shifted) }
                }
                let gr = match_grade(shifted)
                if gr == "EXACT" { exact_count = exact_count + 1 }
                if gr == "NEAR" { near_count = near_count + 1 }
                if conf >= 0.7 { high_conf_count = high_conf_count + 1 }
            }
            k = k + 1
        }
        i = i + 1
    }

    // --- 5. Projection (geometric mean) ---
    // --fast: skip projection when weak blowup (closure < 0.3)
    i = if fast_mode && closure < 0.3 { cur_n } else { 0 }
    while i < cur_n {
        let mut j: i64 = i + 1
        while j < cur_n {
            let va = ax_val_arr[i]
            let vb = ax_val_arr[j]
            let na = ax_name_arr[i]
            let nb = ax_name_arr[j]
            let geom = sqrt_f(abs_f(va) * abs_f(vb))
            let conf = max_f(1.0 - n6_distance(geom), 0.0) * 0.8
            if conf >= 0.15 {
                let nm = "d" + to_string(depth) + "_proj_" + na + "_" + nb
                let ex = "sqrt(" + na + "*" + nb + ")=" + to_string(geom)
                buf_lines = buf_lines.push(emit(nm, "projection", ex, conf, geom, false, na))
                total = total + 1
                _val_total_seen = _val_total_seen + 1
                if len(val_arr) < _VAL_CAP {
                    val_arr = val_arr.push(to_string(geom))
                } else {
                    let _ri5 = random_int(0, _val_total_seen)
                    if _ri5 < _VAL_CAP { val_arr[_ri5] = to_string(geom) }
                }
                let gr = match_grade(geom)
                if gr == "EXACT" { exact_count = exact_count + 1 }
                if gr == "NEAR" { near_count = near_count + 1 }
                if conf >= 0.7 { high_conf_count = high_conf_count + 1 }
            }
            j = j + 1
        }
        i = i + 1
    }

    // --- 6. Dual (reciprocal) ---
    // --fast: skip dual when weak blowup (closure < 0.3)
    i = if fast_mode && closure < 0.3 { cur_n } else { 0 }
    while i < cur_n {
        let v = ax_val_arr[i]
        let na = ax_name_arr[i]
        if abs_f(v) > 0.0000000001 {
            let dual = 1.0 / v
            let conf = max_f(1.0 - n6_distance(dual), 0.0) * 0.6
            if conf >= 0.15 {
                let nm = "d" + to_string(depth) + "_dual_" + na
                let ex = "1/" + na + "=" + to_string(dual)
                buf_lines = buf_lines.push(emit(nm, "dual", ex, conf, dual, false, na))
                total = total + 1
                _val_total_seen = _val_total_seen + 1
                if len(val_arr) < _VAL_CAP {
                    val_arr = val_arr.push(to_string(dual))
                } else {
                    let _ri6 = random_int(0, _val_total_seen)
                    if _ri6 < _VAL_CAP { val_arr[_ri6] = to_string(dual) }
                }
                let gr = match_grade(dual)
                if gr == "EXACT" { exact_count = exact_count + 1 }
                if gr == "NEAR" { near_count = near_count + 1 }
                if conf >= 0.7 { high_conf_count = high_conf_count + 1 }
            }
        }
        i = i + 1
    }

    // --- 7. Second-order composition ---
    // AI-native: 동적 캡 — sqrt(cur_n)*3, [8, 20] 범위. 작은 풀은 절감, 큰 풀은 상한 유지
    let _dyn_cap: i64 = to_int(sqrt_f(to_float(cur_n)) * 3.0)
    let _raw_cap: i64 = if fast_mode { if _dyn_cap < 10 { _dyn_cap } else { 10 } } else { if _dyn_cap < 20 { _dyn_cap } else { 20 } }
    let _comp_cap: i64 = if _raw_cap < 8 { 8 } else { _raw_cap }
    let comp_limit: i64 = if cur_n < _comp_cap { cur_n } else { _comp_cap }
    i = 0
    while i < comp_limit {
        let mut j: i64 = i + 1
        while j < comp_limit {
            let mut k: i64 = j + 1
            while k < comp_limit {
                let va = ax_val_arr[i]
                let vb = ax_val_arr[j]
                let vc = ax_val_arr[k]
                let na = ax_name_arr[i]
                let nb = ax_name_arr[j]
                let nc = ax_name_arr[k]
                let prod1 = va * vb
                let prod2 = vb * vc
                let composed = prod1 * prod2

                // AI-native: 중간적 조기가지치기 — c1 낮으면 conf도 낮음 (O(n³) 절감)
                let c1 = n6_conf(prod1)
                if c1 >= 0.05 {
                let c2 = n6_conf(prod2)
                let conf = c1 * c2 * n6_conf(composed)

                if conf >= 0.1 {
                    let nm = "d" + to_string(depth) + "_comp_" + na + "_" + nb + "_" + nc
                    let ex = "(" + na + "*" + nb + ")*(" + nb + "*" + nc + ")=" + to_string(composed)
                    let is_ax = conf > 0.7
                    buf_lines = buf_lines.push(emit(nm, "compose", ex, conf, composed, is_ax, na))
                    total = total + 1
                    _val_total_seen = _val_total_seen + 1
                    if len(val_arr) < _VAL_CAP {
                        val_arr = val_arr.push(to_string(composed))
                    } else {
                        let _ri7 = random_int(0, _val_total_seen)
                        if _ri7 < _VAL_CAP { val_arr[_ri7] = to_string(composed) }
                    }
                    let _gn4 = match_grade_name(composed)
                    let _gnp4 = _gn4.split("|")
                    let gr = _gnp4[0]
                    let _mn4 = if len(_gnp4) > 1 { _gnp4[1] } else { "" }
                    if gr == "EXACT" { exact_count = exact_count + 1 }
                    if gr == "NEAR" { near_count = near_count + 1 }
                    if conf >= 0.7 { high_conf_count = high_conf_count + 1 }
                    if is_ax {
                        axiom_count = axiom_count + 1
                        let cand_label = if _mn4 != "" { _mn4 } else { nm }
                        if !hset_has(ax_name_set, cand_label) && !hset_has(new_ax_set, cand_label) {
                            new_ax_name_arr = new_ax_name_arr.push(cand_label)
                            new_ax_set[cand_label] = 1
                            new_ax_val_arr = new_ax_val_arr.push(composed)
                            new_ax_n = new_ax_n + 1
                        }
                    }
                    if gr == "EXACT" && !is_ax {
                        if _mn4 != "" && !hset_has(ax_name_set, _mn4) && !hset_has(new_ax_set, _mn4) {
                            new_ax_name_arr = new_ax_name_arr.push(_mn4)
                            new_ax_set[_mn4] = 1
                            new_ax_val_arr = new_ax_val_arr.push(composed)
                            new_ax_n = new_ax_n + 1
                        }
                    }
                }
                } // end c1 pruning
                k = k + 1
            }
            j = j + 1
        }
        i = i + 1
    }

    // ─── Expand axiom pool with new candidates (dynamic cap) ───
    let base_cap: i64 = if ext_pool_cap > 0 { ext_pool_cap } else { 36 }
    let pool_cap: i64 = if ax_n > 30 { if ax_n + 6 < 48 { ax_n + 6 } else { 48 } } else { base_cap }
    if new_ax_n > 0 && len(new_ax_name_arr) > 0 {
        // Only add up to pool_cap total
        let room: i64 = pool_cap - ax_n
        if room > 0 {
            let add_n: i64 = if new_ax_n < room { new_ax_n } else { room }
            let mut ai: i64 = 0
            while ai < add_n {
                let _an = new_ax_name_arr[ai]
                ax_name_arr = ax_name_arr.push(_an)
                ax_name_set[_an] = 1
                ax_val_arr = ax_val_arr.push(new_ax_val_arr[ai])
                ax_n = ax_n + 1
                ai = ai + 1
            }
        }
    }

    let depth_corollaries = total - total_before
    let depth_axioms = axiom_count - axiom_before

    // Record per-depth stats
    if len(depth_stats) > 0 { depth_stats = depth_stats + "\n" }
    depth_stats = depth_stats + "  depth " + to_string(depth) + ": " + to_string(depth_corollaries) + " corollaries, " + to_string(depth_axioms) + " axiom candidates (pool: " + to_string(pool_before) + " -> " + to_string(ax_n) + ")"

    println("  depth " + to_string(depth) + ": " + to_string(depth_corollaries) + " corollaries, " + to_string(depth_axioms) + " axiom candidates (pool: " + to_string(pool_before) + " -> " + to_string(ax_n) + ")")

    // Early exit if pool stopped growing (saturated or capped)
    if ax_n == pool_before && depth > 0 {
        println("  -> pool saturated at depth " + to_string(depth) + ", no new axiom candidates")
        depth = max_depth  // break
    }

    // AI-native: buf_lines 메모리 캡 — depth 끝마다 저신뢰 일괄 제거
    if len(buf_lines) > _BUF_CAP {
        println("  [MEM] buf_lines " + to_string(len(buf_lines)) + " > cap " + to_string(_BUF_CAP) + ", pruning...")
        buf_lines = buf_prune(buf_lines, _BUF_CAP)
        println("  [MEM] pruned to " + to_string(len(buf_lines)))
    }

    depth = depth + 1
}

println("")
println("  --- depth breakdown ---")
println(depth_stats)
println("")
println("  total corollaries :", total)
println("  EXACT match       :", exact_count)
println("  NEAR match        :", near_count)
println("  high conf >= 0.7  :", high_conf_count)
println("  axiom candidates  :", axiom_count)
println("  final pool size   :", ax_n)
println("")
try { arena_reset() } catch e {}  // AI-native: Phase 4 임시 메모리 해제 (최대 페이즈)

// ═══════════════════════════════════════════════════════════
// PHASE 5: Telescope Verification
// ═══════════════════════════════════════════════════════════

println("--- Phase 5: Telescope Verification ---")
// --fast: val_arr 100개 제한 (렌즈 O(n²) 연산 절감)
let _tele_vals = if fast_mode && len(val_arr) > 100 {
    let mut _tv = []
    let mut _ti: i64 = 0
    while _ti < 100 {
        _tv = _tv.push(val_arr[_ti])
        _ti = _ti + 1
    }
    _tv
} else { val_arr }
let val_csv = "|".join(_tele_vals)
let tele_result = telescope_verify(val_csv, 0.15)
let tparts = tele_result.split("|")
let mut tele_agree: i64 = 0
let mut tele_level = "None"
let mut tele_boost: f64 = 0.0
let mut tele_s1: f64 = 0.0
let mut tele_s2: f64 = 0.0
let mut tele_s3: f64 = 0.0
let mut tele_s4: f64 = 0.0
let mut tele_s5: f64 = 0.0
try { tele_agree = to_int(tparts[0]) } catch e {}
if len(tparts) >= 2 { tele_level = tparts[1] }
try { tele_boost = to_float(tparts[2]) } catch e {}
try { tele_s1 = to_float(tparts[3]) } catch e {}
try { tele_s2 = to_float(tparts[4]) } catch e {}
try { tele_s3 = to_float(tparts[5]) } catch e {}
// --fast early-exit: first 3 lenses all < 0.05 → skip gravity+thermo
if !(fast_mode && tele_s1 < 0.05 && tele_s2 < 0.05 && tele_s3 < 0.05) {
    try { tele_s4 = to_float(tparts[6]) } catch e {}
    try { tele_s5 = to_float(tparts[7]) } catch e {}
}

println("  consciousness    :", tele_s1, if tele_s1 >= 0.15 { " SIGNAL" } else { "" })
println("  topology         :", tele_s2, if tele_s2 >= 0.15 { " SIGNAL" } else { "" })
println("  causal           :", tele_s3, if tele_s3 >= 0.15 { " SIGNAL" } else { "" })
println("  gravity          :", tele_s4, if tele_s4 >= 0.15 { " SIGNAL" } else { "" })
println("  thermo           :", tele_s5, if tele_s5 >= 0.15 { " SIGNAL" } else { "" })
println("  consensus        :", tele_agree, "/ 5 ->", tele_level)
println("  confidence boost : +" + to_string(tele_boost))
println("")

// ═══════════════════════════════════════════════════════════
// PHASE 5.5 + 6 MERGED: Single-pass boost + recount + graph (3회 순회 → 1회)
// ═══════════════════════════════════════════════════════════

let mut graph_new_entries = ""
let mut graph_added_nodes: i64 = 0
let mut graph_added_edges: i64 = 0
// Batch dedup guard: 같은 run 안에서 같은 node_id 재등장 차단 (atlas.n6 36% 중복 주범)
let mut _batch_new_ids = #{}
let hub_bonus: f64 = if !skip_graph && graph_hubs_before > 0 { 0.1 } else { 0.0 }

if skip_graph {
    println("--- Phase 6: Graph Update (skipped --no-graph) ---")
} else {
    println("--- Phase 6: Graph Update ---")
    if hub_bonus > 0.0 {
        println("  hub bonus active : +" + to_string(hub_bonus) + " (from " + to_string(graph_hubs_before) + " existing hubs)")
    }
}

let mut boosted_lines = []
let mut boosted_high: i64 = 0
let mut boosted_axiom: i64 = 0
let mut li: i64 = 0
while li < len(buf_lines) {
    let line = buf_lines[li]
    if len(line) > 5 {
        let parts = line.split("\t")
        if len(parts) >= 7 {
            // (A) Boost confidence
            let mut orig_conf: f64 = 0.0
            try { orig_conf = to_float(parts[3]) } catch e { orig_conf = 0.0 }
            let new_conf = min_f(orig_conf + tele_boost, 1.0)
            boosted_lines = boosted_lines.push(parts[0] + "\t" + parts[1] + "\t" + parts[2] + "\t" + to_string(new_conf) + "\t" + parts[4] + "\t" + parts[5] + "\t" + parts[6])
            // (B) Recount (merged from Phase 5 second pass)
            if new_conf >= 0.7 { boosted_high = boosted_high + 1 }
            if new_conf > 0.8 { boosted_axiom = boosted_axiom + 1 }
            // (C) Graph update (merged from Phase 6 loop)
            if !skip_graph && new_conf >= 0.5 {
                let node_id = "blowup-" + parts[0]
                // 두 단계 dedup: (1) 기존 atlas.n6 (2) 이번 배치에서 이미 추가된 것
                let mut _already_in_batch = false
                try { _already_in_batch = has_key(_batch_new_ids, node_id) } catch e {}
                if !_already_in_batch && !graph_node_exists(graph_content, node_id) {
                    let g_conf = min_f(new_conf + hub_bonus, 1.0)
                    let node_json = graph_append_node(node_id, "Discovery", domain, parts[2], g_conf)
                    if len(graph_new_entries) > 0 { graph_new_entries = graph_new_entries + "\n" }
                    graph_new_entries = graph_new_entries + node_json
                    graph_added_nodes = graph_added_nodes + 1
                    _batch_new_ids[node_id] = true
                    let src_id = "n6-" + parts[6]
                    let edge_json = graph_append_edge(src_id, node_id, "Derives", new_conf)
                    graph_new_entries = graph_new_entries + "\n" + edge_json
                    graph_added_edges = graph_added_edges + 1
                }
            }
        }
    }
    li = li + 1
}
buf_lines = boosted_lines

if tele_boost > 0.0 {
    println("  post-boost high conf :", boosted_high, "(was", high_conf_count, ")")
    println("  post-boost axioms    :", boosted_axiom, "(was", axiom_count, ")")
    high_conf_count = boosted_high
    axiom_count = boosted_axiom
    println("")
}

// Write graph updates (schema guard 적용)
if !skip_graph && graph_added_nodes > 0 {
    if len(graph_content) > 0 {
        let _rej = _guarded_append_atlas(graph_path, "\n" + graph_new_entries)
    } else {
        write_file(graph_path, graph_new_entries)
    }
}

let graph_nodes_after = graph_nodes_before + graph_added_nodes
let graph_edges_after = graph_edges_before + graph_added_edges

if !skip_graph {
    println("  nodes added      :", graph_added_nodes)
    println("  edges added      :", graph_added_edges)
    println("  nodes (after)    :", graph_nodes_after)
    println("  edges (after)    :", graph_edges_after)
}
println("")
try { arena_reset() } catch e {}  // AI-native: Phase 5+6 임시 메모리 해제

// ═══════════════════════════════════════════════════════════
// PHASE 6.5: OUROBOROS Dynamic Recursive Growth (closure-based, max 5 rounds)
// ═══════════════════════════════════════════════════════════

println("--- Phase 6.5: OUROBOROS Dynamic Recursive Growth ---")

let recurse_max_rounds: i64 = if fast_mode { 2 } else { 5 }
let mut recurse_round: i64 = 0
let mut recurse_disc_total: i64 = 0
let mut recurse_score: f64 = 0.0
let mut recurse_all_corollaries = []  // collect all corollary lines from recursion

// Collect initial axiom seeds from buf_lines
let mut axiom_seeds = ""
let mut axiom_fed: i64 = 0
li = 0
while li < len(buf_lines) && axiom_fed < 12 {
    let line = buf_lines[li]
    if len(line) > 5 {
        let parts = line.split("\t")
        if len(parts) >= 6 {
            if parts[5] == "1" {
                let mut v: f64 = 0.0
                try { v = to_float(parts[4]) } catch e {}
                if abs_f(v) > 0.0000000001 {
                    if len(axiom_seeds) > 0 { axiom_seeds = axiom_seeds + "|" }
                    axiom_seeds = axiom_seeds + to_string(v)
                    axiom_fed = axiom_fed + 1
                }
            }
        }
    }
    li = li + 1
}

// Dynamic recursive loop: closure-based termination + delta 감지
let mut recurse_pool_size: i64 = len(buf_lines)
let mut recurse_continue = true
let mut recurse_prev_disc: i64 = 999

if len(axiom_seeds) > 0 {
    println("  initial axiom seeds: " + to_string(axiom_fed))

    while recurse_round < recurse_max_rounds && recurse_continue {
        recurse_round = recurse_round + 1
        println("  [round " + to_string(recurse_round) + "/" + to_string(recurse_max_rounds) + "] evolving " + to_string(axiom_fed) + " seeds ...")

        let r_result = evo_cycle(axiom_seeds, evo_max_cycles + recurse_round)
        let rp = r_result.split("|")
        let mut round_score: f64 = 0.0
        let mut round_disc: i64 = 0
        try { round_score = to_float(rp[0]) } catch e {}
        try { round_disc = to_int(rp[1]) } catch e {}

        recurse_disc_total = recurse_disc_total + round_disc
        if round_score > recurse_score { recurse_score = round_score }

        // Collect new evolved values as next-round seeds
        let mut next_seeds = ""
        let mut next_count: i64 = 0
        let mut ri: i64 = 2
        while ri < len(rp) && next_count < 12 {
            let mut rv: f64 = 0.0
            try { rv = to_float(rp[ri]) } catch e {}
            if abs_f(rv) > 0.0000000001 {
                // Check if this is a meaningful discovery (n6 aligned)
                let rv_conf = n6_conf(rv)
                if rv_conf >= 0.3 {
                    if len(next_seeds) > 0 { next_seeds = next_seeds + "|" }
                    next_seeds = next_seeds + to_string(rv)
                    next_count = next_count + 1
                    // Store corollary line for Phase 6.7
                    let rv_grade = match_grade(rv)
                    let rv_name = match_name(rv)
                    let cor_line = "R" + to_string(recurse_round) + "-" + to_string(next_count) + "\trecursive\t" + domain + "\t" + to_string(rv_conf) + "\t" + to_string(rv) + "\t" + (if rv_conf >= 0.8 { "1" } else { "0" }) + "\trecurse-r" + to_string(recurse_round)
                    recurse_all_corollaries = recurse_all_corollaries + [cor_line]
                }
            }
            ri = ri + 1
        }

        // Closure metric: new_discoveries / total_pool
        let new_pool = recurse_pool_size + round_disc
        let closure_ratio: f64 = if new_pool > 0 { to_float(round_disc) / to_float(new_pool) } else { 0.0 }
        recurse_pool_size = new_pool

        println("    score=" + to_string(round_score) + " disc=" + to_string(round_disc) + " closure=" + to_string(closure_ratio) + " pool=" + to_string(recurse_pool_size))

        // Termination conditions: closure >= 0.5 (saturated) or too few new discoveries
        if closure_ratio >= 0.5 {
            println("    -> closure saturated (>= 0.5), stopping")
            recurse_continue = false
        }
        if round_disc < 2 {
            println("    -> too few new discoveries (< 2), stopping")
            recurse_continue = false
        }
        // delta 감지: 이전 라운드 대비 감소하면 수확 체감 → 중단
        if round_disc <= recurse_prev_disc && recurse_round >= 2 && round_disc < 4 {
            println("    -> diminishing returns (disc " + to_string(round_disc) + " <= prev " + to_string(recurse_prev_disc) + "), stopping")
            recurse_continue = false
        }
        recurse_prev_disc = round_disc

        // Feed evolved values back as seeds for next round
        if recurse_continue {
            if len(next_seeds) > 0 {
                axiom_seeds = next_seeds
                axiom_fed = next_count
            } else {
                println("    -> no viable seeds for next round, stopping")
                recurse_continue = false
            }
        }
    }

    println("  recursive growth complete: " + to_string(recurse_round) + " rounds, " + to_string(recurse_disc_total) + " total disc, best_score=" + to_string(recurse_score))
    println("  corollaries collected: " + to_string(len(recurse_all_corollaries)))
} else {
    println("  no axiom candidates to feed back")
}
println("")
try { arena_reset() } catch e {}  // AI-native: Phase 6.5 임시 메모리 해제

// ═══════════════════════════════════════════════════════════
// PHASE 6.7: Auto-Absorb (corollary/axiom -> log + graph + growth_bus + cross-ref)
// ═══════════════════════════════════════════════════════════

println("--- Phase 6.7: Auto-Absorb ---")

let mut absorb_logged: i64 = 0
let mut absorb_graph_nodes: i64 = 0
let mut absorb_graph_edges: i64 = 0
let mut absorb_bus_events: i64 = 0
let growth_bus_path = atlas_path

// Duplicate check: 최근 150줄만 로드 (cooldown 완화: 미탐색 영역 연속 돌파 허용)
let mut absorb_existing_log = ""
try {
    let _tail_result = exec("tail -150 " + log_path + " 2>/dev/null")
    absorb_existing_log = to_string(_tail_result)
} catch e {}

// Read current graph for cross-ref — AI-native: 캐시 재사용 (디스크 재읽기 제거)
let mut absorb_graph_content = ""
if !skip_graph {
    absorb_graph_content = _atlas_cache
}
// Batch dedup guard: intra-batch 중복 차단 (string concat guard 대체, O(1) 해시셋)
let mut _absorb_new_ids = #{}

let mut absorb_log_entries = ""
let mut absorb_graph_entries = ""
let mut absorb_bus_entries = ""

// Process all corollaries from Phase 6.5 recursive rounds
let mut ci: i64 = 0
while ci < len(recurse_all_corollaries) {
    let cor_line = to_string(recurse_all_corollaries[ci])
    let cor_parts = cor_line.split("\t")
    if len(cor_parts) >= 7 {
        let cor_id = to_string(cor_parts[0])
        let cor_type = to_string(cor_parts[1])
        let cor_domain = to_string(cor_parts[2])
        let mut cor_conf: f64 = 0.0
        let mut cor_value: f64 = 0.0
        try { cor_conf = to_float(cor_parts[3]) } catch e {}
        try { cor_value = to_float(cor_parts[4]) } catch e {}
        let cor_is_axiom = to_string(cor_parts[5])
        let cor_src = to_string(cor_parts[6])

        let cor_grade = match_grade(cor_value)
        let cor_name = match_name(cor_value)

        // A. Discovery log: only EXACT grade, skip duplicates
        if cor_grade == "EXACT" {
            let dup_needle = "\"blowup-" + cor_id + "\""
            if !absorb_existing_log.contains(dup_needle) {
                let mut ai_d: i64 = 0
                let mut ai_r: i64 = 0
                if cor_conf >= 0.8 { ai_d = 1 }
                if cor_conf < 0.8 { ai_r = 8 }
                let sector = sector_of(cor_domain)
                let dn = if cor_name != "" { cor_name } else { cor_id }
                let log_entry = "{\"constant\":\"blowup-" + dn + "\",\"value\":\"" + to_string(cor_value) + "\",\"source\":\"hexa-blowup-mk2-recurse\",\"timestamp\":\"2026-04-06\",\"grade\":\"" + cor_grade + "\",\"processed\":true,\"alien_index\":{\"d\":" + to_string(ai_d) + ",\"r\":" + to_string(ai_r) + "},\"mk2\":{\"sector\":\"" + sector + "\",\"confidence\":" + to_string(cor_conf) + ",\"paths\":1,\"prime_set\":[],\"layer\":" + to_string(ai_d) + "},\"blowup\":{\"type\":\"" + cor_type + "\",\"src\":\"" + cor_src + "\"},\"phase\":\"6.7-auto-absorb\",\"recurse_round\":\"" + cor_id + "\"}"
                absorb_log_entries = absorb_log_entries + log_entry + "\n"
                absorb_logged = absorb_logged + 1
                // Update existing_log to prevent duplicates within this batch
                absorb_existing_log = absorb_existing_log + dup_needle
            }
        }

        // B. Graph: add node + edge for conf >= 0.5
        if !skip_graph && cor_conf >= 0.5 {
            let g_node_id = "recurse-" + cor_id
            // 두 단계 dedup: (1) 기존 atlas.n6 (2) 이번 배치
            let mut _absorb_in_batch = false
            try { _absorb_in_batch = has_key(_absorb_new_ids, g_node_id) } catch e {}
            if !_absorb_in_batch && !graph_node_exists(absorb_graph_content, g_node_id) {
                let g_conf = min_f(cor_conf, 1.0)
                let node_json = graph_append_node_d(g_node_id, "RecursiveDiscovery", cor_domain, cor_type, g_conf, 1)
                if len(absorb_graph_entries) > 0 { absorb_graph_entries = absorb_graph_entries + "\n" }
                absorb_graph_entries = absorb_graph_entries + node_json
                absorb_graph_nodes = absorb_graph_nodes + 1
                _absorb_new_ids[g_node_id] = true

                // Derives edge from source
                let src_node = "n6-" + cor_src
                let edge_json = graph_append_edge(src_node, g_node_id, "RecursiveDerivation", cor_conf)
                absorb_graph_entries = absorb_graph_entries + "\n" + edge_json
                absorb_graph_edges = absorb_graph_edges + 1

                // C. Cross-reference: link to existing BT nodes in graph
                // Scan for BT- nodes and create CrossRef edges
                if absorb_graph_content.contains("\"BT-") {
                    // Find closest BT by domain match
                    let bt_needle = "\"domain\":\"" + cor_domain + "\""
                    if absorb_graph_content.contains(bt_needle) {
                        let xref_edge = graph_append_edge(g_node_id, "bt-" + cor_domain, "CrossRef", cor_conf * 0.8)
                        absorb_graph_entries = absorb_graph_entries + "\n" + xref_edge
                        absorb_graph_edges = absorb_graph_edges + 1
                    }
                }
            }
        }

        // D. Growth bus event
        let bus_event = "{\"type\":\"absorb\",\"phase\":\"6.7\",\"id\":\"" + cor_id + "\",\"value\":" + to_string(cor_value) + ",\"grade\":\"" + cor_grade + "\",\"confidence\":" + to_string(cor_conf) + ",\"domain\":\"" + cor_domain + "\",\"is_axiom\":" + cor_is_axiom + ",\"source\":\"blowup-recurse\",\"timestamp\":\"2026-04-06\"}"
        absorb_bus_entries = absorb_bus_entries + bus_event + "\n"
        absorb_bus_events = absorb_bus_events + 1
    }
    ci = ci + 1
}

// Write discovery_log entries (append only — 전체 읽기+쓰기 제거)
if absorb_logged > 0 {
    append_file(log_path, absorb_log_entries)
    println("  discovery_log  : +" + to_string(absorb_logged) + " EXACT entries")
}

// Write graph entries
if !skip_graph && absorb_graph_nodes > 0 {
    if file_exists(graph_path) {
        let _rej2 = _guarded_append_atlas(graph_path, "\n" + absorb_graph_entries)
    } else {
        write_file(graph_path, absorb_graph_entries)
    }
    println("  graph          : +" + to_string(absorb_graph_nodes) + " nodes, +" + to_string(absorb_graph_edges) + " edges")
}

// Write growth_bus events (R14 SSOT: atlas.n6로 통합, schema guard 적용)
if absorb_bus_events > 0 {
    let _rej3 = _guarded_append_atlas(growth_bus_path, absorb_bus_entries)
    println("  growth_bus     : +" + to_string(absorb_bus_events) + " absorb events")
}

// E. Invoke absorb.hexa auto mode for full integration
let absorb_hexa_path = "mk2_hexa/native/absorb.hexa"
let hexa_bin_home = _HOME
let absorb_hexa_bin = _HEXA_BIN
if file_exists(absorb_hexa_path) {
    println("  invoking absorb.hexa distribution ...")
    let mut absorb_result = ""
    try { absorb_result = exec(absorb_hexa_bin, [absorb_hexa_path, "distribution"]) } catch e {}
    if len(absorb_result) > 0 {
        println("  ", absorb_result.split("\n")[0])
    }
}

// F. atlas.n6 자동흡수 — JSON 의존 제거, .n6 단일진실
let _atlas_home = _HOME
let _atlas_dev = _NEXUS
let atlas_n6_path = _ATLAS_PATH
let mut absorb_atlas_count: i64 = 0
if file_exists(atlas_n6_path) {
    let atlas_content = _atlas_cache  // AI-native: 캐시 재사용
    // 마지막 BT 번호 추출 — grep + sort (hexa char 비교 회피)
    let mut atlas_last_bt: i64 = 0
    try {
        let _bt_max_str = exec("grep -oE 'n6-bt-[0-9]+' " + atlas_n6_path + " | grep -oE '[0-9]+$' | sort -n | tail -1").trim()
        if len(_bt_max_str) > 0 {
            atlas_last_bt = to_int(_bt_max_str)
        }
    } catch e {}

    let mut atlas_append = "\n\n# ── 돌파 자동흡수 (" + domain + ") ──────────────────────────\n"
    let mut abt: i64 = atlas_last_bt + 1
    let mut aci: i64 = 0
    while aci < len(recurse_all_corollaries) {
        let a_cor_line = to_string(recurse_all_corollaries[aci])
        let a_cor_parts = a_cor_line.split("\t")
        if len(a_cor_parts) >= 7 {
            let a_cor_id = to_string(a_cor_parts[0])
            let a_cor_domain = to_string(a_cor_parts[2])
            let mut a_cor_conf: f64 = 0.0
            let mut a_cor_value: f64 = 0.0
            try { a_cor_conf = to_float(a_cor_parts[3]) } catch e {}
            try { a_cor_value = to_float(a_cor_parts[4]) } catch e {}
            let ac_grade = match_grade(a_cor_value)
            let ac_summary = a_cor_id + " = " + to_string(a_cor_value)

            // EXACT + NEAR(conf>=0.9) 만 atlas에 흡수
            if ac_grade == "EXACT" || (ac_grade == "NEAR" && a_cor_conf >= 0.9) {
                if !atlas_content.contains(a_cor_id) {
                    let g_mark = if ac_grade == "EXACT" { "*" } else { "?" }
                    let ar = to_int(a_cor_conf * 10.0)
                    let ac_n6_type = if ac_grade == "EXACT" { "F" } else { "R" }
                    atlas_append = atlas_append + "@" + ac_n6_type + " n6-bt-" + to_string(abt) + " = " + ac_summary + " :: " + a_cor_domain + " [0." + to_string(ar) + g_mark + "]\n"
                    atlas_append = atlas_append + "  <- n\n"
                    atlas_append = atlas_append + "  !! \"자동흡수 conf=" + to_string(a_cor_conf) + "\"\n"
                    absorb_atlas_count = absorb_atlas_count + 1
                    abt = abt + 1
                }
            }
        }
        aci = aci + 1
    }

    if absorb_atlas_count > 0 {
        atlas_append = atlas_append + "@X n6-bt-" + to_string(atlas_last_bt + 1) + "~" + to_string(abt - 1) + " = " + domain + "_자동흡수 :: " + domain + " [8!]\n"
        atlas_append = atlas_append + "  \"" + domain + " 자동흡수 " + to_string(absorb_atlas_count) + "건\"\n"
        let _rej4 = _guarded_append_atlas(atlas_n6_path, atlas_append)
        println("  atlas.n6       : +" + to_string(absorb_atlas_count) + " entries (BT-" + to_string(atlas_last_bt + 1) + "~" + to_string(abt - 1) + ")")
    } else {
        println("  atlas.n6       : 신규 항목 없음 (중복 또는 기준 미달)")
    }
} else {
    println("  atlas.n6       : 파일 없음 — 스킵")
}

if absorb_logged == 0 && absorb_graph_nodes == 0 && absorb_atlas_count == 0 {
    println("  no new absorptions (all duplicates or below threshold)")
}
println("")
try { arena_reset() } catch e {}  // AI-native: Phase 6.7 임시 메모리 해제

