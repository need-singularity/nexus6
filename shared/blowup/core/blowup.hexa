try {
    let off = to_string(exec("printenv BLOWUP_TRACE")).trim()
    if off == "0" { _TRACE_ON = false }
} catch e {}
// ROI #23: trace 로그를 append_file 기반 _trace() 헬퍼로 일괄 전환 (25 exec → 0 exec)
fn _trace(tag: string) {
    if !_TRACE_ON { return }
    let ts = now()
    try { append_file(_TRACE_PATH, ts + " " + tag + "\n") } catch e {}
}
