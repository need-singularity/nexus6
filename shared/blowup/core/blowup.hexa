// ─── auto 도메인 선택: growth_bus에서 최근 미방문 도메인 ───
fn auto_select_domain() -> string {
    try {
        let home = _HOME
        let gb = exec("tail -200 " + _ATLAS_PATH + " 2>/dev/null")
        let lines = gb.split("\n")
        let mut seen = []
        let mut li: i64 = len(lines) - 1
        while li >= 0 {
            let ln = lines[li].trim()
            li = li - 1
            if ln == "" { continue }
            // atlas.n6: "@R ... :: domain [grade]" 형식에서 도메인 추출
            if !ln.contains("::") { continue }
            let dp = ln.split("::")
            if len(dp) < 2 { continue }
            let dd = dp[1].split("\"")[0]
            if dd == "" { continue }
            let mut dup = false
            for s in seen { if s == dd { dup = true } }
            if dup { continue }
            seen = seen + [dd]
            if len(seen) >= 12 { break }
        }
        // 가장 오래된 것(= 최근 안 건드린 것)을 선택
        if len(seen) >= 2 {
            return seen[len(seen) - 1]
        }
        if len(seen) == 1 { return seen[0] }
    } catch e {}
    return "math"
}

// AI-native: domain sanitize — shell metachar 제거 (공백/대괄호/별표/슬래시 → '_')
// 원인: auto_select_domain() 이 atlas.n6 split("::")[1] → " n6atlas [10*]" 등 오염값 반환.
// 영향: /tmp/blowup_d*_<domain>.cf 파일명에 `[`, `]`, `*`, 공백 포함 시 reload glob 실패 →
//       buf_lines 빈 배열 → Phase 6 boost loop 0회 → post-boost 0/463 가짜 saturation.
// 2026-04-19 Phase 6 deep audit 발견.
let _raw_d = if _raw_domain != "" { _raw_domain } else { auto_select_domain() }
