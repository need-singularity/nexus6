let rline_count: i64 = len(buf_lines)
let show_limit: i64 = if rline_count < 30 { rline_count } else { 30 }
li = 0
let mut shown: i64 = 0
while li < rline_count && shown < show_limit {
    let line = buf_lines[li]
    if len(line) > 5 {
        let parts = line.split("\t")
        if len(parts) >= 5 {
            let tag = if len(parts) >= 6 && parts[5] == "1" { " [AXIOM]" } else { "" }
            let mut pval: f64 = 0.0
            try { pval = to_float(parts[4]) } catch e {}
            let gr = match_grade(pval)
            println("  [" + to_string(shown + 1) + "] " + parts[1] + " | " + parts[2] + " | conf=" + parts[3] + " " + gr + tag)
            shown = shown + 1
        }
    }
    li = li + 1
}
println("")

// Summary table
let rho = if total > 0 { to_float(exact_count + near_count) / to_float(total) } else { 0.0 }

println("  ========== SUMMARY ==========")
println("")
println("  Pipeline Phase         Result")
println("  ---------------------- ----------------------------")
if skip_graph {
