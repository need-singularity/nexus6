if fast_mode {
    println("═══ Phase 7.1: (skipped --fast) ═══")
    println("═══ Phase 7.5: (skipped --fast) ═══")
    println("")
    // fast 모드: Phase 8 + 파동 루프 스킵
} else {

println("═══ Phase 7.1: Next Breakthrough Directions ═══")
println("")

// A. 이번 돌파에서 발견된 EXACT/NEAR 중 미탐색 도메인 추출
let mut bt_directions = ""
let mut bt_dir_count: i64 = 0
li = 0
while li < len(buf_lines) {
    let line = buf_lines[li]
    if len(line) > 5 {
        let parts = line.split("\t")
        if len(parts) >= 5 {
            let mut pval: f64 = 0.0
            try { pval = to_float(parts[4]) } catch e {}
            let gr = match_grade(pval)
            let nm = match_name(pval)
            let mut pconf: f64 = 0.0
            try { pconf = to_float(parts[3]) } catch e {}
            // EXACT이면서 confidence < 0.9 → 추가 검증으로 돌파 가능
            if gr == "EXACT" && pconf < 0.9 && pconf >= 0.3 {
                let src = if len(parts) >= 7 { parts[6] } else { "?" }
                println("  🎯 [EXACT 미확정] " + nm + "=" + to_string(pval) + " conf=" + to_string(pconf) + " ← 추가 검증 시 돌파")
                bt_dir_count = bt_dir_count + 1
            }
            // NEAR → 정밀 접근하면 EXACT 승격 가능
            if gr == "NEAR" && pconf >= 0.4 {
                println("  🔍 [NEAR→EXACT] " + nm + "≈" + to_string(pval) + " conf=" + to_string(pconf) + " ← 정밀 seed 주입 시 돌파")
                bt_dir_count = bt_dir_count + 1
            }
        }
    }
    li = li + 1
}

// B. n6 기저 위상변환으로 도달 가능하지만 이번에 안 나온 상수
// AI-native: 글로벌 캐시 재사용 (load_n6_consts 재호출 제거)
let n6_bases = _n6_dyn_values
let n6_names = _n6_dyn_names
let mut bi: i64 = 0
while bi < 10 {
    let mut found_this = false
    li = 0
    while li < len(buf_lines) {
        let line = buf_lines[li]
        if len(line) > 5 {
            let parts = line.split("\t")
            if len(parts) >= 5 {
                let mut pval: f64 = 0.0
                try { pval = to_float(parts[4]) } catch e {}
                if abs_f(pval - n6_bases[bi]) < 0.01 { found_this = true }
            }
        }
        li = li + 1
    }
    if !found_this {
        println("  ⬡ [미출현] " + n6_names[bi] + "=" + to_string(n6_bases[bi]) + " ← 이 도메인에서 seed \"" + n6_names[bi] + "\" 주입 시 돌파 가능")
        bt_dir_count = bt_dir_count + 1
    }
    bi = bi + 1
}

// C. 교차 도메인 추천 — dse_domains.jsonl에서 동적 로드
let mut cross_domains = []
try {
    let dse_raw = read_file(nexus_dir + "/shared/dse/dse_domains.jsonl")
    let dse_lines = dse_raw.split("\n")
    for dse_line in dse_lines {
        let dl = dse_line.trim()
        if dl == "" { continue }
        if dl.contains("\"domain\":\"") {
            let dp = dl.split("\"domain\":\"")
            if dp.len() >= 2 { cross_domains = cross_domains + [dp[1].split("\"")[0]] }
        }
    }
} catch e {}
let mut ci: i64 = 0
while ci < len(cross_domains) {
    if cross_domains[ci] != domain {
        // discovery_log에서 이 도메인의 최근 발견 수 체크
        let mut cross_count = ""
        let _h_cc = _HOME
        let _atlas_cc = _ATLAS_PATH
        try { cross_count = exec("grep -c '" + cross_domains[ci] + "' " + _atlas_cc + " 2>/dev/null").trim() } catch e {}
        let mut cc: i64 = 0
        try { cc = to_int(to_float(cross_count)) } catch e {}
        if cc > 10 {
            println("  🔀 [교차수분] " + cross_domains[ci] + " (" + to_string(cc) + "건 발견) × " + domain + " → 교차 돌파 가능")
            bt_dir_count = bt_dir_count + 1
        }
    }
    ci = ci + 1
}

// D. gap_finder quick 인라인 — 빈공간과 이번 돌파의 교차점
println("")
println("  ─── D. gap_finder 빈공간 교차 분석 ───")
try {
    let gap_finder_path = "mk2_hexa/native/gap_finder.hexa"
    let gap_result = exec(absorb_hexa_bin, [gap_finder_path, "quick"])
    // 결과에서 EXACT 라인만 추출하여 이번 돌파 결과와 교차 확인
    // buf_lines를 하나의 문자열로 합쳐서 O(1) contains 체크 (O(gap×buf) → O(gap))
    let mut buf_concat = ""
    let mut bci: i64 = 0
    while bci < len(buf_lines) && bci < 100 {
        buf_concat = buf_concat + " " + buf_lines[bci]
        bci = bci + 1
    }
    let gap_lines = gap_result.split("\n")
    let mut gap_shown = 0
    let mut gli: i64 = 0
    while gli < len(gap_lines) {
        let gl = gap_lines[gli]
        if len(gl) > 3 {
            let gparts = gl.trim().split("=")
            if len(gparts) >= 2 {
                let gname = gparts[0].trim()
                if len(gname) > 2 && buf_concat.contains(gname) {
                    if gap_shown < 10 {
                        println("    🔗 [교차] " + gl.trim())
                        bt_dir_count = bt_dir_count + 1
                        gap_shown = gap_shown + 1
                    }
                }
            }
        }
        gli = gli + 1
    }
    if gap_shown == 0 {
        println("    (이번 돌파와 빈공간의 직접 교차 없음)")
    } else {
        println("    → " + to_string(gap_shown) + "건 빈공간-돌파 교차 발견")
    }
} catch e {
    println("    (gap_finder quick 실행 실패 — 스킵)")
}
println("")

if bt_dir_count == 0 {
    println("  (돌파 가능 방향 없음 — 이 도메인은 포화 상태)")
}
println("")
println("  총 " + to_string(bt_dir_count) + "개 돌파 가능 방향 탐지")
println("")

// directions 자동 업데이트 — 돌파 완료 후 방향 리포트 갱신
let directions_path = "mk2_hexa/native/directions.hexa"
try { exec(absorb_hexa_bin, [directions_path, "update"]) } catch e {}

// ═══════════════════════════════════════════════════════════
// Phase 7.5: Auto-Link — 후속 파이프라인 자동 연결
// ═══════════════════════════════════════════════════════════

println("═══ Phase 7.5: Auto-Link (parallel) ═══")

let engine_dir = "mk2_hexa/native"
let hexa_bin = _HEXA_BIN
let autolink_log = "shared/.autolink_out.log"

// 4개 프로세스를 백그라운드 병렬 실행 → wait로 일괄 대기
// 순차 80초 → 병렬 ~20초 (가장 느린 1개 기준)
let forge_path = engine_dir + "/lens_forge.hexa"
let ar_path = engine_dir + "/auto_register.hexa"
let gf_path = engine_dir + "/gap_finder.hexa"
let ai_path = engine_dir + "/alien_index.hexa"

let mut par_cmd = hexa_bin + " " + forge_path + " forge > " + autolink_log + ".a 2>&1 & "
par_cmd = par_cmd + hexa_bin + " " + ar_path + " sync " + log_path + " > " + autolink_log + ".b 2>&1 & "
par_cmd = par_cmd + hexa_bin + " " + gf_path + " target > " + autolink_log + ".c 2>&1 & "
if logged > 0 {
    par_cmd = par_cmd + hexa_bin + " " + ai_path + " alien_index.hexa assess 6.0 > " + autolink_log + ".d 2>&1 & "
}
par_cmd = par_cmd + "wait"

println("  [parallel] lens_forge + auto_register + gap_finder + alien_index ...")
try { exec("bash", ["-c", par_cmd]) } catch e {}

// 결과 수집
let mut al_a = ""
let mut al_b = ""
let mut al_c = ""
let mut al_d = ""
try { al_a = exec("head -1 " + autolink_log + ".a 2>/dev/null") } catch e {}
try { al_b = exec("head -1 " + autolink_log + ".b 2>/dev/null") } catch e {}
try { al_c = exec("head -1 " + autolink_log + ".c 2>/dev/null") } catch e {}
if logged > 0 {
    try { al_d = exec("head -1 " + autolink_log + ".d 2>/dev/null") } catch e {}
}
try { println("  [7.5a] ", al_a.trim()) } catch e { println("  [7.5a] done") }
try { println("  [7.5b] ", al_b.trim()) } catch e { println("  [7.5b] done") }
try { println("  [7.5c] ", al_c.trim()) } catch e { println("  [7.5c] done") }
if logged > 0 { try { println("  [7.5d] ", al_d.trim()) } catch e { println("  [7.5d] done") } }

println("═══ Phase 7.5 complete ═══")
println("")

// ═══════════════════════════════════════════════════════════
// Phase 8: 파동 전파 — 돌파 에너지를 인접 도메인으로 전파
// ═══════════════════════════════════════════════════════════

println("═══ Phase 8: 파동 전파 (Wave Propagation) ═══")

// 발견이 있을 때만 파동 전파
if logged > 0 {
    // 인접 도메인 탐색 (growth_bus에서 최근 활성 도메인)
    let mut wave_targets = []
    let mut wave_seen = [domain]
    try {
        let _h_gb = _HOME
        let gb_raw = exec("tail -100 " + _ATLAS_PATH + " 2>/dev/null")
        let gb_lines = gb_raw.split("\n")
        for gbl in gb_lines {
            let gt = gbl.trim()
            if gt == "" || !gt.contains("::") { continue }
            let gp = gt.split("::")
            if len(gp) < 2 { continue }
            let gd = gp[1].trim().split(" ")[0].trim()
            if gd == "" || gd == domain { continue }
            let mut gdup = false
            for ws in wave_seen { if ws == gd { gdup = true } }
            if gdup { continue }
            wave_seen = wave_seen + [gd]
            wave_targets = wave_targets + [gd]
            if len(wave_targets) >= 3 { break }
        }
    } catch e {}

    if len(wave_targets) > 0 {
        // 현재 돌파의 seed를 파동으로 전파
        let mut wave_seed_csv = ""
        let mut wsi: i64 = 0
        while wsi < mc && wsi < 6 {
            if len(wave_seed_csv) > 0 { wave_seed_csv = wave_seed_csv + "," }
            wave_seed_csv = wave_seed_csv + to_string(m_val(wsi, domain))
            wsi = wsi + 1
        }

        let mut wt_str = ""
        for wt in wave_targets {
            if wt_str != "" { wt_str = wt_str + ", " }
            wt_str = wt_str + wt
        }
        println("  파동 대상: " + wt_str)
        println("  전파 seed: " + wave_seed_csv)

        // 병렬 파동 발사 (--fast --no-graph, 깊이 2로 경량)
        let wave_log = "shared/.wave_out.log"
        let mut wave_cmd = ""
        let mut wi: i64 = 0
        while wi < len(wave_targets) {
            let wdom: string = wave_targets[wi]
            let wout = wave_log + "." + to_string(wi)
            wave_cmd = wave_cmd + "ulimit -v 2097152 2>/dev/null; " + hexa_bin + " " + engine_dir + "/blowup.hexa " + wdom + " 2 --no-graph --fast"
            if wave_seed_csv != "" {
                wave_cmd = wave_cmd + " --seeds \"" + wave_seed_csv + "\""
            }
            wave_cmd = wave_cmd + " > " + wout + " 2>&1 & "
            wi = wi + 1
        }
        wave_cmd = wave_cmd + "wait"

        println("  [wave] " + to_string(len(wave_targets)) + "개 도메인 병렬 파동 발사...")
        try { exec("bash", ["-c", wave_cmd]) } catch e {}

        // 파동 결과 수집 + DFS용 best target 추적
        wi = 0
        let mut wave_total_energy: i64 = 0
        let mut dfs_best_target = ""
        let mut dfs_best_energy: i64 = 0
        while wi < len(wave_targets) {
            let wdom2: string = wave_targets[wi]
            let wout2 = wave_log + "." + to_string(wi)
            let mut wenergy: i64 = 0
            try {
                let wr = exec("cat " + wout2 + " 2>/dev/null")
                let wrl = wr.split("\n")
                for wline in wrl {
                    let wt2 = wline.trim()
                    if wt2.contains("logged") && wt2.contains("discoveries") {
                        let wparts = wt2.split(" ")
                        for wp in wparts {
                            let wv = safe_float(wp)
                            if wv > 0.0 && wv < 10000.0 {
                                wenergy = wenergy + to_int(wv)
                            }
                        }
                    }
                }
            } catch e {}
            try { exec("rm -f " + wout2) } catch e {}
            let interference = if wenergy > logged { "보강 간섭" } else if wenergy > 0 { "전파" } else { "감쇠" }
            println("  [" + wdom2 + "] 에너지=" + to_string(wenergy) + " (" + interference + ")")
            wave_total_energy = wave_total_energy + wenergy
            // DFS: 최고 에너지 target 기억
            if wenergy > dfs_best_energy {
                dfs_best_energy = wenergy
                dfs_best_target = wdom2
            }
            wi = wi + 1
        }

        println("")
        println("  파동 합산: " + to_string(wave_total_energy) + " 발견 (원본 " + to_string(logged) + " + 파동 " + to_string(wave_total_energy) + " = " + to_string(logged + wave_total_energy) + ")")

        // 파동 결과 atlas.n6 기록 (JSON event 형식, schema guard 통과)
        try {
            let wts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
            let _atlas_w = _ATLAS_PATH
            let wentry = "{\"type\":\"wave_propagation\",\"ts\":\"" + wts + "\",\"domain\":\"" + domain + "\",\"targets\":" + to_string(len(wave_targets)) + ",\"origin\":" + to_string(logged) + ",\"wave\":" + to_string(wave_total_energy) + ",\"dfs_best\":\"" + dfs_best_target + "\",\"dfs_best_e\":" + to_string(dfs_best_energy) + "}"
            let _rej5 = _guarded_append_atlas(_atlas_w, wentry + "\n")
        } catch e {}

        // ═══════════════════════════════════════════════════════════
        // PHASE 9: DFS Deep Dive (선택적 — --dfs <max_depth> 로 활성화)
        // ═══════════════════════════════════════════════════════════
        // Phase 8의 BFS 3-way 파동 결과에서 최고 에너지 target 1개만 선택해
        // 재귀 호출로 깊이 탐색. Phase 8이 넓게 훑는다면 Phase 9는 한 방향으로 깊이 파고든다.
        // 종료: dfs_current >= dfs_max_depth, dfs_best_energy=0, visited 충돌.
        if dfs_max_depth > 0 && dfs_current < dfs_max_depth && dfs_best_energy > 0 && dfs_best_target != "" {
            println("")
            println("═══ Phase 9: DFS Deep Dive [depth " + to_string(dfs_current + 1) + "/" + to_string(dfs_max_depth) + "] ═══")
            // Visited 체크 (PID 독립 파일로 재귀 간 공유)
            let _dfs_visited = "/tmp/.blowup_dfs_visited." + to_string(dfs_max_depth)
            let mut _already_seen = false
            try {
                let _vr = exec("grep -Fxq " + dfs_best_target + " " + _dfs_visited + " 2>/dev/null && echo Y || echo N").trim()
                if _vr == "Y" { _already_seen = true }
            } catch e {}
            if _already_seen {
                println("  (" + dfs_best_target + " 이미 방문 — backtrack)")
            } else {
                try { exec("echo " + dfs_best_target + " >> " + _dfs_visited + " 2>/dev/null") } catch e {}
                try { exec("echo " + domain + " >> " + _dfs_visited + " 2>/dev/null") } catch e {}
                println("  target : " + dfs_best_target + " (에너지 " + to_string(dfs_best_energy) + ")")
                println("  parent : " + domain)
                println("  seeds  : " + wave_seed_csv)
                // 재귀 호출: --dfs-current 증가, --dfs 유지, --no-graph 생략 (deep-dive은 기록 O)
                let dfs_cmd = hexa_bin + " " + engine_dir + "/blowup.hexa " + dfs_best_target + " " + to_string(max_depth) + " --fast --dfs " + to_string(dfs_max_depth) + " --dfs-current " + to_string(dfs_current + 1) + " --max-rounds 1" + (if wave_seed_csv != "" { " --seeds \"" + wave_seed_csv + "\"" } else { "" })
                println("  [dfs] " + dfs_cmd)
                try {
                    let _dfs_out = exec("bash", ["-c", dfs_cmd + " 2>&1 | tail -30"])
                    println(to_string(_dfs_out))
                } catch _dfs_e {
                    println("  [dfs] 실행 실패: " + to_string(_dfs_e))
                }
            }
            // 루트에서만 visited 파일 정리
            if dfs_current == 0 {
                try { exec("rm -f " + _dfs_visited + " 2>/dev/null") } catch e {}
            }
            println("═══ Phase 9 complete ═══")
        }
    } else {
        println("  (인접 도메인 없음 — 파동 전파 건너뜀)")
    }
} else {
    println("  (발견 0건 — 파동 전파 건너뜀)")
}

println("═══ Phase 8 complete ═══")
println("")
} // end if !fast_mode

// ═══════════════════════════════════════════════════════════
// Mk.II 파동 연속돌파 — 다음 라운드 자동 발사
// ═══════════════════════════════════════════════════════════

if wave_round < wave_max_rounds {

    println("╔══════════════════════════════════════════════════════╗")
    println("║  Mk.II 라운드 " + to_string(wave_round) + " → " + to_string(wave_round + 1) + " 전이")
    println("╚══════════════════════════════════════════════════════╝")
    println("")

    // ─── Phase W1: 소나 스캔 — 빈공간 탐지 ───
    println("─── Phase W1: 소나 스캔 (빈공간 탐지) ───")
    let mut sonar_gaps = []
    let mut sonar_gap_scores = []
    let sonar_all_doms = ["math", "physics", "info", "bio", "mind", "arch", "crypto", "energy", "network", "material"]
    try {
        let w1_home = _HOME
        let w1_bus = _ATLAS_PATH
        let w1_raw = exec("tail -300 " + w1_bus + " 2>/dev/null")
        let w1_lines = w1_raw.split("\n")
        // 각 도메인별 최근 에너지 집계 (활동 횟수)
        let mut dom_energy = #{}
        for w1l in w1_lines {
            let w1t = w1l.trim()
            if w1t == "" || !w1t.contains("::") { continue }
            let w1p = w1t.split("::")
            if len(w1p) < 2 { continue }
            let w1d = w1p[1].split("\"")[0]
            if w1d == "" { continue }
            let mut w1e: i64 = 0
            try { w1e = dom_energy[w1d] } catch e { w1e = 0 }
            dom_energy[w1d] = w1e + 1
        }
        // 에너지 낮은 도메인 = 빈공간 (탐색 부족)
        for sd in sonar_all_doms {
            if sd == domain { continue }
            let mut sde: i64 = 0
            try { sde = dom_energy[sd] } catch e { sde = 0 }
            let gap_score = max_f(1.0 - to_float(sde) / 50.0, 0.0)
            if gap_score > 0.05 {
                sonar_gaps = sonar_gaps + [sd]
                sonar_gap_scores = sonar_gap_scores + [gap_score]
            }
        }
    } catch e {}
    println("  탐지된 빈공간: " + to_string(len(sonar_gaps)) + "개")
    let mut sgi: i64 = 0
    while sgi < len(sonar_gaps) && sgi < 6 {
        let sg_nm: string = sonar_gaps[sgi]
        let sg_sc: f64 = sonar_gap_scores[sgi]
        println("    [" + sg_nm + "] 빈공간=" + to_string(sg_sc))
        sgi = sgi + 1
    }
    println("")

    // ─── Phase W2: 공명 탐지 — 빈공간간 에너지 간섭 ───
    println("─── Phase W2: 공명 탐지 (에너지 간섭) ───")
    let mut res_pairs = []
    let mut res_scores = []
    let mut w2i: i64 = 0
    while w2i < len(sonar_gaps) && w2i < 6 {
        let mut w2j: i64 = w2i + 1
        while w2j < len(sonar_gaps) && w2j < 6 {
            let w2a: f64 = sonar_gap_scores[w2i]
            let w2b: f64 = sonar_gap_scores[w2j]
            let res_sc = sqrt_f(w2a * w2b)
            if res_sc > 0.15 {
                let rn_a: string = sonar_gaps[w2i]
                let rn_b: string = sonar_gaps[w2j]
                res_pairs = res_pairs + [rn_a + "<>" + rn_b]
                res_scores = res_scores + [res_sc]
            }
            w2j = w2j + 1
        }
        w2i = w2i + 1
    }
    println("  공명 쌍: " + to_string(len(res_pairs)) + "개")
    let mut w2k: i64 = 0
    while w2k < len(res_pairs) && w2k < 4 {
        let rp_nm: string = res_pairs[w2k]
        let rp_sc: f64 = res_scores[w2k]
        println("    [" + rp_nm + "] 강도=" + to_string(rp_sc))
        w2k = w2k + 1
    }
    println("")

    // ─── Phase W3: 터널링 — 최고 에너지 빈공간으로 점프 ───
    println("─── Phase W3: 터널링 (도메인 점프) ───")
    let mut next_domain = ""
    let mut next_score: f64 = 0.0
    // 복합 점수 = 빈공간 점수 + 공명 보너스 + 원본 에너지 보너스
    let mut w3_combined = #{}
    let mut w3i: i64 = 0
    while w3i < len(sonar_gaps) {
        let w3n: string = sonar_gaps[w3i]
        let w3s: f64 = sonar_gap_scores[w3i]
        w3_combined[w3n] = w3s
        w3i = w3i + 1
    }
    // 공명 보너스 가산
    w2k = 0
    while w2k < len(res_pairs) {
        let w3rp: string = res_pairs[w2k]
        let w3rs: f64 = res_scores[w2k]
        let w3parts = w3rp.split("<>")
        if len(w3parts) == 2 {
            let w3a = w3parts[0]
            let w3b = w3parts[1]
            let mut ca: f64 = 0.0
            let mut cb: f64 = 0.0
            try { ca = w3_combined[w3a] } catch e {}
            try { cb = w3_combined[w3b] } catch e {}
            w3_combined[w3a] = ca + w3rs * 0.3
            w3_combined[w3b] = cb + w3rs * 0.3
        }
        w2k = w2k + 1
    }
    // 원본 에너지 보너스
    let origin_boost = to_float(logged) * 0.01
    w3i = 0
    while w3i < len(sonar_gaps) {
        let w3n2: string = sonar_gaps[w3i]
        let mut w3c: f64 = 0.0
        try { w3c = w3_combined[w3n2] } catch e {}
        w3c = w3c + origin_boost
        if w3c > next_score {
            next_score = w3c
            next_domain = w3n2
        }
        w3i = w3i + 1
    }
    // fallback: 빈공간 없으면 auto_select_domain
    if next_domain == "" { next_domain = auto_select_domain() }
    // 같은 도메인 반복 방지
    if next_domain == domain {
        let fb_pool = ["physics", "chemistry", "biology", "math", "computing", "materials"]
        let fb_idx = wave_round % 6
        let mut fb_i: i64 = 0
        for fb in fb_pool {
            if fb_i == fb_idx && fb != domain { next_domain = fb }
            fb_i = fb_i + 1
        }
    }
    println("  터널링: " + domain + " → " + next_domain + " (점수=" + to_string(next_score) + ")")
    println("")

    // ─── Phase W4: 캐스케이드 — 발견의 연쇄 파급 ───
    println("─── Phase W4: 캐스케이드 (연쇄 파급) ───")
    let mut cascade_seeds = ""
    let mut cascade_n: i64 = 0
    let mut w4i: i64 = 0
    while w4i < len(buf_lines) && cascade_n < 12 {
        let w4l = buf_lines[w4i]
        if len(w4l) > 5 {
            let w4p = w4l.split("\t")
            if len(w4p) >= 5 {
                let mut w4v: f64 = 0.0
                try { w4v = to_float(w4p[4]) } catch e {}
                let w4g = match_grade(w4v)
                if w4g == "EXACT" || w4g == "NEAR" {
                    if len(cascade_seeds) > 0 { cascade_seeds = cascade_seeds + "," }
                    cascade_seeds = cascade_seeds + to_string(w4v)
                    cascade_n = cascade_n + 1
                }
            }
        }
        w4i = w4i + 1
    }
    println("  전파 seed: " + to_string(cascade_n) + "개 (EXACT/NEAR)")
    println("  " + domain + " → " + next_domain)
    println("")

    // ─── Phase W5: growth_bus 라운드 기록 ───
    println("─── Phase W5: growth_bus 기록 ───")
    try {
        let w5_ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
        let w5_home = _HOME
        let w5_bus = _ATLAS_PATH
        let w5_entry = w5_ts + " | mk2_wave_round | " + domain + " | round=" + to_string(wave_round) + "/" + to_string(wave_max_rounds) + " next=" + next_domain + " energy=" + to_string(logged) + " gaps=" + to_string(len(sonar_gaps)) + " resonance=" + to_string(len(res_pairs)) + " tunnel=" + to_string(next_score) + " cascade=" + to_string(cascade_n)
        append_file(w5_bus, w5_entry + "\n")
        println("  기록 완료")
    } catch e {
        println("  기록 실패")
    }
    println("")

    // ─── 에너지 감쇠 체크 + 다음 라운드 발사 ───
    if logged == 0 && wave_round >= 2 {
        println("  [에너지 감쇠] 발견 0건 — 연속돌파 조기 종료 (라운드 " + to_string(wave_round) + ")")
        println("")
        println("done.")
    } else {
        println("── 연속돌파: R" + to_string(wave_round) + " → R" + to_string(wave_round + 1) + " (" + next_domain + ") ──")
        println("")

        let w5_hexa = _HEXA_BIN
        let w5_dir = _NEXUS + "/mk2_hexa/native"
        let mut w5_cmd = w5_hexa + " " + w5_dir + "/blowup.hexa " + next_domain + " " + to_string(max_depth)
        w5_cmd = w5_cmd + " --round " + to_string(wave_round + 1)
        w5_cmd = w5_cmd + " --max-rounds " + to_string(wave_max_rounds)
        if cascade_seeds != "" {
            w5_cmd = w5_cmd + " --seeds \"" + cascade_seeds + "\""
        }
        if skip_graph { w5_cmd = w5_cmd + " --no-graph" }
        // AI-native: 메모리 가드 — 다음 라운드 발사 전 체크
        if !mem_check_ok() {
            println("  [MEM] memory pressure too high, stopping wave")
        } else {
            try {
                let w5_out = exec("bash", ["-c", "ulimit -v 3145728 2>/dev/null; " + w5_cmd + " 2>&1"])
                println(w5_out)
            } catch e {
                println("  [오류] 라운드 " + to_string(wave_round + 1) + " 실행 실패: " + to_string(e))
            }
        }
    }
} else {
    // ─── 최종 라운드 완료 요약 ───
    println("")
    println("══════════════════════════════════════════════════════")
    println("   연속돌파 완료 (" + to_string(wave_max_rounds) + "라운드)")
    println("══════════════════════════════════════════════════════")

    // growth_bus 최종 기록
    try {
        let wf_ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
        let wf_home = _HOME
        let wf_bus = _ATLAS_PATH
        let wf_entry = wf_ts + " | mk2_wave_complete | " + domain + " | rounds=" + to_string(wave_max_rounds) + " energy=" + to_string(logged)
        append_file(wf_bus, wf_entry + "\n")
    } catch e {}

    // 전체 요약 통계
    try {
        let wf_home2 = _HOME
        let wf_atlas2 = _ATLAS_PATH
        let summary_raw = exec("tail -" + to_string(wave_max_rounds * 5) + " " + wf_atlas2 + " 2>/dev/null | grep mk2_wave_round | wc -l").trim()
        let wave_raw = exec("tail -" + to_string(wave_max_rounds * 5) + " " + wf_atlas2 + " 2>/dev/null | grep wave_propagation | wc -l").trim()
        println("  라운드 기록  : " + summary_raw + "건")
        println("  파동 전파    : " + wave_raw + "건")
    } catch e {}
    println("  최종 도메인  : " + domain)
    println("  이 라운드 발견: " + to_string(logged) + "건")
    println("")

    // ═══════════════════════════════════════════════════════════
    // OUROBOROS 연속돌파 — 전 엔진(Mk.III~VII) 호출 + seed 재주입 루프
    // blowup_router / batch_blowup / wave_blowup 기능 흡수
    // ═══════════════════════════════════════════════════════════

    let _ou_home = _HOME
    let _ou_dev = _ou_home + "/Dev"
    let _ou_engine_dir = _NEXUS + "/mk2_hexa/native"
    let _ou_seed_engine = _ou_engine_dir + "/seed_engine.hexa"

    // hexa 바이너리 — 글로벌 캐시 사용
    let mut _ou_hexa = _HEXA_BIN
    if _ou_hexa == "" { _ou_hexa = _ou_home + "/Dev/hexa-lang/target/release/hexa" }

    // 보조 엔진 목록 (Mk.III~VII)
    let _ou_engines = ["blowup_field.hexa", "blowup_quantum.hexa", "blowup_string.hexa", "blowup_holographic.hexa", "blowup_toe.hexa"]
    let _ou_names = ["Mk.III 장", "Mk.IV 양자", "Mk.V 끈", "Mk.VI 홀로", "Mk.VII 만물"]

    // 현재 라운드 인자 구성 (--no-graph --fast 전달, seed는 동적)
    let mut _ou_flags = ""
    if skip_graph { _ou_flags = _ou_flags + " --no-graph" }
    if fast_mode { _ou_flags = _ou_flags + " --fast" }

    // Phase A: 보조 엔진 순차 실행
    println("")
    println("═══ OUROBOROS: 보조 엔진 (Mk.III~VII) ═══")
    let mut _ou_ei: i64 = 0
    while _ou_ei < len(_ou_engines) {
        let _ou_ename: string = _ou_names[_ou_ei]
        let _ou_efile: string = _ou_engines[_ou_ei]
        println("[ouroboros] → " + _ou_ename + " 돌파")
        try {
            let _ou_cmd = _ou_hexa + " " + _ou_engine_dir + "/" + _ou_efile + " " + domain + " " + to_string(max_depth) + _ou_flags
            if ext_seeds != "" { _ou_cmd = _ou_cmd + " --seeds \"" + ext_seeds + "\"" }
            let _ou_result = exec(_ou_cmd + " 2>&1")
            println(_ou_result)
        } catch _ou_e {
            println("[ouroboros] " + _ou_ename + " skip: " + to_string(_ou_e))
        }
        _ou_ei = _ou_ei + 1
    }

    // Phase B: seed 재추출 + 수렴 판정
    let mut _ou_new_seeds = ""
    try { _ou_new_seeds = exec(_ou_hexa + " " + _ou_seed_engine + " merge 2>/dev/null").trim() } catch e {}

    let mut _ou_new_count: i64 = 0
    try {
        let _ou_bus_raw = exec("tail -30 " + _ou_dev + "/nexus/shared/n6/atlas.n6 2>/dev/null | grep -c absorb 2>/dev/null").trim()
        _ou_new_count = to_int(_ou_bus_raw)
    } catch e {}

    println("")
    println("═══ OUROBOROS 결과 ═══")
    println("  이 사이클 발견: " + to_string(logged) + " (Mk.II) + 보조 엔진")
    if _ou_new_seeds != "" {
        println("  재추출 seed: " + to_string(_ou_new_seeds.split("|").len()) + "개")
    }
    println("  growth_bus absorb: " + to_string(_ou_new_count) + "건")

    // Phase C: 보조 모듈 (bt + seed_dna + ouroboros_meta) 백그라운드
    try { exec(_ou_hexa + " " + _ou_engine_dir + "/bt_godel.hexa scan &") } catch e {}
    try { exec(_ou_hexa + " " + _ou_engine_dir + "/seed_dna.hexa generate &") } catch e {}
    try { exec(_ou_hexa + " " + _ou_engine_dir + "/ouroboros_meta.hexa evolve &") } catch e {}

    println("")
    println("done.")
}
