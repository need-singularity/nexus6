// ═══════════════════════════════════════════════════════════

fn get_ax_val(ax_vals: string, idx: i64) -> f64 {
    let parts = ax_vals.split("|")
    if idx < 0 || idx >= len(parts) { return 0.0 }
    let mut v: f64 = 0.0
    try { v = to_float(parts[idx]) } catch e { v = 0.0 }
    return v
}

fn get_ax_name(ax_names: string, idx: i64) -> string {
    let parts = ax_names.split("|")
    if idx < 0 || idx >= len(parts) { return "" }
    return parts[idx]
}

fn ax_count_f(ax_vals: string) -> i64 {
    let parts = ax_vals.split("|")
    return len(parts)
}

fn ax_contains(ax_names: string, name: string) -> bool {
    let parts = ax_names.split("|")
    let mut ci: i64 = 0
    while ci < len(parts) {
        if parts[ci] == name { return true }
        ci = ci + 1
    }
    return false
}

// ─── perturbation shifts ───

fn shift_val(idx: i64) -> f64 {
    if idx == 0 { return 0.287682072 }
    if idx == 1 { return 1.618033989 }
    if idx == 2 { return 0.0 - 1.618033989 }
    if idx == 3 { return 0.166666667 }
    if idx == 4 { return 0.0 - 0.166666667 }
    return 2.449489743
}

fn shift_name(idx: i64) -> string {
    if idx == 0 { return "ln43" }
    if idx == 1 { return "phi" }
    if idx == 2 { return "-phi" }
    if idx == 3 { return "inv6" }
    if idx == 4 { return "-inv6" }
    return "sqrt6"
}

// ─── transfer domains ───

fn xfer_domain(idx: i64) -> string {
    if idx == 0 { return "physics" }
    if idx == 1 { return "math" }
    if idx == 2 { return "info" }
    if idx == 3 { return "bio" }
    if idx == 4 { return "mind" }
    return "arch"
}

// ═══════════════════════════════════════════════════════════
// ─── GRAPH I/O (from graph.hexa) ───
// ═══════════════════════════════════════════════════════════

fn graph_extract_field(line: string, field: string) -> string {
    let needle = "\"" + field + "\":"
    if !line.contains(needle) { return "" }
    let after = line.split(needle)
    if len(after) < 2 { return "" }
    let rest = after[1]
    // quoted value
    if len(rest) > 0 {
        let first_ch = rest.split("\"")
        // if starts with quote, extract between quotes
        if len(first_ch) >= 3 {
            // rest = "value"... -> split gives ["", "value", "..."]
            // but also rest = value,... -> split gives ["value,..."]
            // check if rest begins with a quote
            let trimmed = rest.split("\"")
            if len(trimmed) >= 2 {
                // could be ["", "value", ...] or ["value..."]
                if len(trimmed[0]) == 0 && len(trimmed) >= 2 {
                    return trimmed[1]
                }
            }
        }
    }
    // unquoted value: read until , or } or space
    let mut result = ""
    let chars = rest.split("")
    let mut ci: i64 = 0
    while ci < len(chars) {
        let ch = chars[ci]
        if ch == "," || ch == "}" || ch == " " || ch == "]" { return result }
        if ch != "\"" {
            result = result + ch
        }
        ci = ci + 1
    }
    return result
}

fn graph_load() -> string {
    let _h = _HOME
    let gpath = _ATLAS_PATH
    if file_exists(gpath) {
        return read_file(gpath)
    }
    return ""
}

// ─── Schema guard: atlas.n6 라인 포맷 검증 (append 전 필터링) ───
// 유효 패턴:
//   - 빈 줄 / #주석
//   - {"type":...}  JSON 객체
//   - @X ... :: ... [grade]  atlas @-entry
//   - 들여쓰기된 "..." / <- / !! / -> / <<  (이전 @X 부속)
// 무효 패턴 예: 파이프 구분 raw text, 바이너리, 트렁케이트된 JSON
fn _valid_atlas_line(line: string) -> bool {
    let t = line.trim()
    if len(t) == 0 { return true }
    let first = t[0..1]
    if first == "#" { return true }
    if first == "{" { return true }
    if first == "@" { return true }
    if first == "\"" { return true }
    if first == "<" { return true }
    if first == ">" { return true }
    if first == "!" { return true }
    if first == "-" { return true }
    return false
}

// 안전 append: 무효 라인 필터링 후 append_file. 거부 건수 stdout 보고.
fn _guarded_append_atlas(path: string, content: string) -> i64 {
    if len(content) == 0 { return 0 }
    let lines = content.split("\n")
    let mut clean = ""
    let mut rejected: i64 = 0
    let mut first = true
    let mut i: i64 = 0
    while i < len(lines) {
        let line = lines[i]
        if _valid_atlas_line(line) {
            if !first { clean = clean + "\n" }
            clean = clean + line
            first = false
        } else {
            rejected = rejected + 1
        }
        i = i + 1
    }
    if rejected > 0 {
        println("  [schema guard] rejected " + to_string(rejected) + " invalid lines -> " + path)
    }
    if len(clean) > 0 {
        try { append_file(path, clean) } catch e {}
    }
    return rejected
}

fn graph_count_type(content: string, ttype: string) -> i64 {
    if len(content) == 0 { return 0 }
    let lines = content.split("\n")
    let mut count: i64 = 0
    let mut li: i64 = 0
    while li < len(lines) {
        let line = lines[li]
        if len(line) > 5 {
            let t = graph_extract_field(line, "type")
            if t == ttype { count = count + 1 }
        }
        li = li + 1
    }
    return count
}

// ─── atlas.n6.stats 사이드카 캐시 (Phase 1 O(58k lines) → O(1) / O(Δ)) ───
// 포맷 v2: {"schema":2,"mtime":<int>,"size":<int>,"line_count":<int>,
//          "head_hash":<md5 first 256B>,"nodes":<int>,"edges":<int>,"hubs":<int>}
// deg 사이드카: atlas.n6.deg — TSV "id\tdegree\n" (hub 재계산용)
// 유효성:
//   - exact: mtime+size 일치 → O(1) 리턴
//   - incremental: size>cached + head_hash 일치 → Δ lines만 파싱 O(Δ)
//   - miss: 전체 스캔 + 양쪽 사이드카 재작성
fn graph_stats_cache_path() -> string {
    return _ATLAS_PATH + ".stats"
}

fn graph_deg_cache_path() -> string {
    return _ATLAS_PATH + ".deg"
}

fn _stat_mtime_size(path: string) -> string {
    let mut r = ""
    try { r = to_string(exec("stat -f '%m %z' " + path + " 2>/dev/null || stat -c '%Y %s' " + path + " 2>/dev/null")).trim() } catch e {}
    return r
}

fn _head_hash_256(path: string) -> string {
    let mut r = ""
    try { r = to_string(exec("head -c 256 " + path + " 2>/dev/null | md5 -q 2>/dev/null || head -c 256 " + path + " 2>/dev/null | md5sum | cut -d' ' -f1")).trim() } catch e {}
    return r
}

// 반환: "mtime|size|line_count|nodes|edges|hubs|head_hash" or "" on miss
fn _read_stats_sidecar() -> string {
    let spath = graph_stats_cache_path()
    if !file_exists(spath) { return "" }
    let mut raw = ""
    try { raw = read_file(spath) } catch e { return "" }
    let trimmed = raw.trim()
    if trimmed == "" { return "" }
    let mut j = #{}
    try { j = json_parse(trimmed) } catch e { return "" }
    let mut c_mtime = ""
    let mut c_size = ""
    let mut c_lines = ""
    let mut c_nodes = ""
    let mut c_edges = ""
    let mut c_hubs = ""
    let mut c_head = ""
    try { c_mtime = to_string(j["mtime"]) } catch e {}
    try { c_size = to_string(j["size"]) } catch e {}
    try { c_lines = to_string(j["line_count"]) } catch e {}
    try { c_nodes = to_string(j["nodes"]) } catch e {}
    try { c_edges = to_string(j["edges"]) } catch e {}
    try { c_hubs = to_string(j["hubs"]) } catch e {}
    try { c_head = to_string(j["head_hash"]) } catch e {}
    if c_mtime == "" || c_size == "" || c_nodes == "" { return "" }
    return c_mtime + "|" + c_size + "|" + c_lines + "|" + c_nodes + "|" + c_edges + "|" + c_hubs + "|" + c_head
}

fn graph_stats_read_cache(min_deg: i64) -> string {
    if min_deg != 3 { return "" }
    if !file_exists(_ATLAS_PATH) { return "" }
    let stat_raw = _stat_mtime_size(_ATLAS_PATH)
    if stat_raw == "" { return "" }
    let sp = stat_raw.split(" ")
    if len(sp) < 2 { return "" }
    let cur_mtime = sp[0]
    let cur_size = sp[1]
    let cached = _read_stats_sidecar()
    if cached == "" { return "" }
    let cp = cached.split("|")
    if len(cp) < 7 { return "" }
    if cp[0] != cur_mtime { return "" }
    if cp[1] != cur_size { return "" }
    return cp[3] + "|" + cp[4] + "|" + cp[5]
}

// 증분 스캔: cached head_hash 일치 + size 증가 → Δ 구간만 파싱
// content: 현재 atlas.n6 전체 문자열 (graph_load 이미 로드됨)
// 반환: "nodes|edges|hubs" (성공) or "" (miss — 전체 스캔으로 fallback)
fn graph_stats_incremental(content: string, min_deg: i64) -> string {
    if min_deg != 3 { return "" }
    if len(content) == 0 { return "" }
    let cached = _read_stats_sidecar()
    if cached == "" { return "" }
    let cp = cached.split("|")
    if len(cp) < 7 { return "" }
    let mut c_size: i64 = 0
    let mut c_lines: i64 = 0
    let mut c_nodes: i64 = 0
    let mut c_edges: i64 = 0
    try { c_size = to_int(cp[1]) } catch e { return "" }
    try { c_lines = to_int(cp[2]) } catch e { return "" }
    try { c_nodes = to_int(cp[3]) } catch e { return "" }
    try { c_edges = to_int(cp[4]) } catch e { return "" }
    let c_head = cp[6]
    // append-only 조건: cur_size > cached_size (같으면 exact match가 먼저 잡았음)
    if len(content) <= c_size { return "" }
    if c_head == "" { return "" }
    let cur_head = _head_hash_256(_ATLAS_PATH)
    if cur_head == "" { return "" }
    if cur_head != c_head { return "" }
    // deg 사이드카 로드
    let dpath = graph_deg_cache_path()
    if !file_exists(dpath) { return "" }
    let mut deg_raw = ""
    try { deg_raw = read_file(dpath) } catch e { return "" }
    let mut deg_map = #{}
    let deg_lines = deg_raw.split("\n")
    let mut di: i64 = 0
    while di < len(deg_lines) {
        let dl = deg_lines[di]
        di = di + 1
        if len(dl) == 0 { continue }
        let tp = dl.split("\t")
        if len(tp) < 2 { continue }
        try { deg_map[tp[0]] = to_int(tp[1]) } catch e {}
    }
    // Δ 구간: shell tail -c +N 으로 바이트 오프셋 이후만 추출 (hexa char-index 함정 회피)
    let cur_stat = _stat_mtime_size(_ATLAS_PATH)
    if cur_stat == "" { return "" }
    let cs = cur_stat.split(" ")
    if len(cs) < 2 { return "" }
    let mut cur_bytes: i64 = 0
    try { cur_bytes = to_int(cs[1]) } catch e { return "" }
    if cur_bytes <= c_size { return "" }
    let mut tail = ""
    try { tail = to_string(exec("tail -c +" + to_string(c_size + 1) + " " + _ATLAS_PATH + " 2>/dev/null")) } catch e { return "" }
    if len(tail) == 0 { return "" }
    let delta_lines = tail.split("\n")
    let delta_len = len(delta_lines)
    // 경계 보정: 첫 줄이 "{"로 시작하지 않으면 경계가 라인 중간이므로 skip
    let mut start: i64 = 0
    if delta_len > 0 {
        let first = delta_lines[0]
        if len(first) == 0 || !first.starts_with("{") { start = 1 }
    }
    let mut nodes = c_nodes
    let mut edges = c_edges
    let mut li: i64 = start
    while li < delta_len {
        let line = delta_lines[li]
        li = li + 1
        if len(line) <= 5 { continue }
        let t = graph_extract_field(line, "type")
        if t == "node" { nodes = nodes + 1 }
        if t == "edge" {
            edges = edges + 1
            let f = graph_extract_field(line, "from")
            let to = graph_extract_field(line, "to")
            if len(f) > 0 {
                let mut d: i64 = 0
                try { d = deg_map[f] } catch e {}
                deg_map[f] = d + 1
            }
            if len(to) > 0 {
                let mut d: i64 = 0
                try { d = deg_map[to] } catch e {}
                deg_map[to] = d + 1
            }
        }
    }
    // hub 재계산 (전체 deg_map 훑기)
    let vals = deg_map.values()
    let mut hub_count: i64 = 0
    let mut hi: i64 = 0
    while hi < len(vals) {
        let d: i64 = vals[hi]
        if d >= min_deg { hub_count = hub_count + 1 }
        hi = hi + 1
    }
    // 사이드카 재기록 — line_count는 (c_lines + delta_len - start) 근사
    let new_line_count = c_lines + (delta_len - start)
    graph_stats_write_cache_full(nodes, edges, hub_count, new_line_count, deg_map)
    return to_string(nodes) + "|" + to_string(edges) + "|" + to_string(hub_count)
}

// deg_map 직렬화: "id\tdeg\n"
fn _serialize_deg_map(deg_map: map) -> string {
    let keys = deg_map.keys()
    let mut buf = ""
    let mut i: i64 = 0
    while i < len(keys) {
        let k = to_string(keys[i])
        let mut d: i64 = 0
        try { d = deg_map[k] } catch e {}
        buf = buf + k + "\t" + to_string(d) + "\n"
        i = i + 1
    }
    return buf
}

fn graph_stats_write_cache_full(nodes: i64, edges: i64, hubs: i64, line_count: i64, deg_map: map) {
    if !file_exists(_ATLAS_PATH) { return }
    let stat_raw = _stat_mtime_size(_ATLAS_PATH)
    if stat_raw == "" { return }
    let sp = stat_raw.split(" ")
    if len(sp) < 2 { return }
    let mtime = sp[0]
    let size = sp[1]
    let head_hash = _head_hash_256(_ATLAS_PATH)
    let body = "{\"schema\":2,\"mtime\":" + mtime + ",\"size\":" + size + ",\"line_count\":" + to_string(line_count) + ",\"head_hash\":\"" + head_hash + "\",\"nodes\":" + to_string(nodes) + ",\"edges\":" + to_string(edges) + ",\"hubs\":" + to_string(hubs) + "}\n"
    try { write_file(graph_stats_cache_path(), body) } catch e {}
    try { write_file(graph_deg_cache_path(), _serialize_deg_map(deg_map)) } catch e {}
}

// 호환용: 기존 호출자를 위한 wrapper — deg_map 없으면 .deg 파일 생략
fn graph_stats_write_cache(nodes: i64, edges: i64, hubs: i64) {
    if !file_exists(_ATLAS_PATH) { return }
    let stat_raw = _stat_mtime_size(_ATLAS_PATH)
    if stat_raw == "" { return }
    let sp = stat_raw.split(" ")
    if len(sp) < 2 { return }
    let mtime = sp[0]
    let size = sp[1]
    let head_hash = _head_hash_256(_ATLAS_PATH)
    let body = "{\"schema\":2,\"mtime\":" + mtime + ",\"size\":" + size + ",\"line_count\":0,\"head_hash\":\"" + head_hash + "\",\"nodes\":" + to_string(nodes) + ",\"edges\":" + to_string(edges) + ",\"hubs\":" + to_string(hubs) + "}\n"
    try { write_file(graph_stats_cache_path(), body) } catch e {}
}

// AI-native: 단일 패스 그래프 통계 — graph_count_type×2 + graph_hub_count 3회 순회 → 1회
// 3단 fast path:
//   1) exact cache hit (mtime+size) → O(1)
//   2) incremental (append-only tail) → O(Δ lines)
//   3) full scan → O(total lines), 사이드카 재작성
// 반환: "nodes|edges|hubs" (pipe-separated)
fn graph_stats_single_pass(content: string, min_deg: i64) -> string {
    if len(content) == 0 { return "0|0|0" }
    // 1) exact hit
    let cached = graph_stats_read_cache(min_deg)
    if cached != "" { return cached }
    // 2) incremental (append-only)
    let incr = graph_stats_incremental(content, min_deg)
    if incr != "" { return incr }
    // 3) full scan
    let lines = content.split("\n")
    let mut nodes: i64 = 0
    let mut edges: i64 = 0
    let mut deg_map = #{}
    let mut li: i64 = 0
    while li < len(lines) {
        let line = lines[li]
        if len(line) > 5 {
            let t = graph_extract_field(line, "type")
            if t == "node" { nodes = nodes + 1 }
            if t == "edge" {
                edges = edges + 1
                let f = graph_extract_field(line, "from")
                let to = graph_extract_field(line, "to")
                if len(f) > 0 {
                    let mut d: i64 = 0
                    try { d = deg_map[f] } catch e {}
                    deg_map[f] = d + 1
                }
                if len(to) > 0 {
                    let mut d: i64 = 0
                    try { d = deg_map[to] } catch e {}
                    deg_map[to] = d + 1
                }
            }
        }
        li = li + 1
    }
    let vals = deg_map.values()
    let mut hub_count: i64 = 0
    let mut hi: i64 = 0
    while hi < len(vals) {
        let d: i64 = vals[hi]
        if d >= min_deg { hub_count = hub_count + 1 }
        hi = hi + 1
    }
    // 사이드카 전체 재기록 (deg_map 포함 — 후속 incremental path 활성화)
    if min_deg == 3 { graph_stats_write_cache_full(nodes, edges, hub_count, len(lines), deg_map) }
    return to_string(nodes) + "|" + to_string(edges) + "|" + to_string(hub_count)
}

// Find hub node IDs (degree >= min_deg) — O(edges) using native Map (hashmap)
fn graph_hub_count(content: string, min_deg: i64) -> i64 {
    if len(content) == 0 { return 0 }
    let lines = content.split("\n")
    let mut deg_map = #{}  // node_id → degree (native hashmap O(1) lookup)
    let mut li: i64 = 0
    while li < len(lines) {
        let line = lines[li]
        if len(line) > 5 {
            let t = graph_extract_field(line, "type")
            if t == "edge" {
                let f = graph_extract_field(line, "from")
                let to = graph_extract_field(line, "to")
                if len(f) > 0 {
                    let mut d: i64 = 0
                    try { d = deg_map[f] } catch e {}
                    deg_map[f] = d + 1
                }
                if len(to) > 0 {
                    let mut d: i64 = 0
                    try { d = deg_map[to] } catch e {}
                    deg_map[to] = d + 1
                }
            }
        }
        li = li + 1
    }
    // Count hubs
    let vals = deg_map.values()
    let mut hub_count: i64 = 0
    let mut hi: i64 = 0
    while hi < len(vals) {
        let d: i64 = vals[hi]
        if d >= min_deg { hub_count = hub_count + 1 }
        hi = hi + 1
    }
    return hub_count
}

// Check if a node ID already exists
fn graph_node_exists(content: string, id: string) -> bool {
    if len(content) == 0 { return false }
    let needle = "\"id\":\"" + id + "\""
    return content.contains(needle)
}

fn graph_append_node(id: string, node_type: string, dom: string, summary: string, conf: f64) -> string {
    return graph_append_node_d(id, node_type, dom, summary, conf, 0)
}

fn graph_append_node_d(id: string, node_type: string, dom: string, summary: string, conf: f64, d: i64) -> string {
    return "{\"type\":\"node\",\"id\":\"" + id + "\",\"node_type\":\"" + node_type + "\",\"domain\":\"" + dom + "\",\"summary\":\"" + summary + "\",\"confidence\":" + to_string(conf) + ",\"depth\":" + to_string(d) + "}"
}

fn graph_append_edge(from_id: string, to_id: string, edge_type: string, strength: f64) -> string {
    return "{\"type\":\"edge\",\"from\":\"" + from_id + "\",\"to\":\"" + to_id + "\",\"edge_type\":\"" + edge_type + "\",\"strength\":" + to_string(strength) + ",\"bidirectional\":false}"
}

// ═══════════════════════════════════════════════════════════
// ─── OUROBOROS EVOLUTION (from ouroboros.hexa) ───
// ═══════════════════════════════════════════════════════════

// Mutation: parameter shift by n=6 constants
fn evo_mutate_shift(base_val: f64, shift_idx: i64) -> f64 {
    // Dynamic: n6_constants.jsonl 전체 상수로 shift (float cache)
    if _n6_dyn_count == 0 { return base_val + 6.0 }
    let idx = shift_idx % _n6_dyn_count
    let cv: f64 = _n6_fcache[idx]
    if abs_f(cv) < 0.001 { return base_val }
    if shift_idx % 2 == 0 { return base_val * cv }
    return base_val + cv
}

// Mutation: inversion
fn evo_mutate_invert(base_val: f64) -> f64 {
    if abs_f(base_val) > 0.0000000001 { return 1.0 / base_val }
    return 0.0
}

// Mutation: combination (geometric mean of two values)
fn evo_mutate_combine(a: f64, b: f64) -> f64 {
    return sqrt_f(abs_f(a) * abs_f(b))
}

// Verification score: how well a value aligns with n=6
fn evo_verify(value: f64) -> f64 {
    return n6_conf(value)
}

// Run one evolution cycle on seed values, return best score and mutated values
// seeds_csv: pipe-separated float values
// Returns pipe-separated result: "best_score|num_discoveries|val1|val2|..."
fn evo_cycle(seeds_csv: string, cycle_num: i64) -> string {
    let parts = seeds_csv.split("|")
    let mut best_score: f64 = 0.0
    let mut discoveries: i64 = 0
    let mut out_vals = ""

    // For each seed value, apply mutations and keep best
    let mut si: i64 = 0
    while si < len(parts) && si < 48 {
        let mut sv: f64 = 0.0
        try { sv = to_float(parts[si]) } catch e { sv = 0.0 }
        if abs_f(sv) > 0.0000000001 {
            // Try 4 mutation strategies, keep the one with best n6 alignment
            let mut best_mut = sv
            let mut best_conf: f64 = evo_verify(sv)

            // AI-native: 전 전략 보존, EXACT(>=0.99) 시 조기탈출만 추가 (창발 유지)

            // strategy 0: parameter shift (dynamic — n6_constants 전체, --fast: 8개 제한)
            let _shift_cap: i64 = if fast_mode { 8 } else { 16 }
            let shift_limit: i64 = if _n6_dyn_count < _shift_cap { _n6_dyn_count } else { _shift_cap }
            let mut shi: i64 = 0
            while shi < shift_limit && best_conf < 0.99 {
                let shifted = evo_mutate_shift(sv, shi)
                let sc = evo_verify(shifted)
                if sc > best_conf {
                    best_conf = sc
                    best_mut = shifted
                }
                shi = shi + 1
            }

            // strategy 1: inversion
            if best_conf < 0.99 {
                let inv = evo_mutate_invert(sv)
                let inv_sc = evo_verify(inv)
                if inv_sc > best_conf {
                    best_conf = inv_sc
                    best_mut = inv
                }
            }

            // strategy 2: combination with next seed
            if best_conf < 0.99 && si + 1 < len(parts) {
                let mut sv2: f64 = 0.0
                try { sv2 = to_float(parts[si + 1]) } catch e { sv2 = 0.0 }
                if abs_f(sv2) > 0.0000000001 {
                    let combined = evo_mutate_combine(sv, sv2)
                    let comb_sc = evo_verify(combined)
                    if comb_sc > best_conf {
                        best_conf = comb_sc
                        best_mut = combined
                    }
                }
            }

            // strategy 3: domain transfer (scale by novelty factor)
            if best_conf < 0.99 {
                let novelty = 1.0 / sqrt_f(to_float(if cycle_num > 0 { cycle_num } else { 1 }))
                let xfer = sv * (1.0 + novelty * 0.1)
                let xfer_sc = evo_verify(xfer)
                if xfer_sc > best_conf {
                    best_conf = xfer_sc
                    best_mut = xfer
                }
            }

            // strategy 4: simulated annealing — temperature-scaled random walk
            if best_conf < 0.99 {
                let temperature = 1.0 / (1.0 + to_float(cycle_num))
                let sa_shift = sv * temperature * 0.05
                let sa_plus = sv + sa_shift
                let sa_minus = sv - sa_shift
                let sa_plus_sc = evo_verify(sa_plus)
                let sa_minus_sc = evo_verify(sa_minus)
                if sa_plus_sc > best_conf {
                    best_conf = sa_plus_sc
                    best_mut = sa_plus
                }
                if sa_minus_sc > best_conf {
                    best_conf = sa_minus_sc
                    best_mut = sa_minus
                }
            }

            // strategy 5: golden crossover — blend with distant seed (Fibonacci weighting)
            if best_conf < 0.99 {
                let phi = 1.618033989
                let distant_idx = if si + 3 < len(parts) { si + 3 } else { 0 }
                let mut sv_dist: f64 = 0.0
                try { sv_dist = to_float(parts[distant_idx]) } catch e { sv_dist = 0.0 }
                if abs_f(sv_dist) > 0.0000000001 {
                    let golden_blend = sv * (phi / (1.0 + phi)) + sv_dist * (1.0 / (1.0 + phi))
                    let gb_sc = evo_verify(golden_blend)
                    if gb_sc > best_conf {
                        best_conf = gb_sc
                        best_mut = golden_blend
                    }
                }
            }

            // strategy 6: harmonic resonance — test n=6 divisor multiples/fractions
            if best_conf < 0.99 {
                let divisors = [1.0, 2.0, 3.0, 6.0]
                let mut di2: i64 = 0
                while di2 < 4 {
                    let harm_mul = sv * divisors[di2]
                    let harm_div = sv / divisors[di2]
                    let hm_sc = evo_verify(harm_mul)
                    let hd_sc = evo_verify(harm_div)
                    if hm_sc > best_conf {
                        best_conf = hm_sc
                        best_mut = harm_mul
                    }
                    if hd_sc > best_conf {
                        best_conf = hd_sc
                        best_mut = harm_div
                    }
                    di2 = di2 + 1
                }
            }

            if best_conf > best_score { best_score = best_conf }
            if best_conf >= 0.25 { discoveries = discoveries + 1 }

            if len(out_vals) > 0 { out_vals = out_vals + "|" }
            out_vals = out_vals + to_string(best_mut)
        }
        si = si + 1
    }

    return to_string(best_score) + "|" + to_string(discoveries) + "|" + out_vals
}

// Convergence check: given discovery counts per cycle, detect saturation
// history_csv: pipe-separated integers
fn evo_check_convergence(history_csv: string) -> string {
    let parts = history_csv.split("|")
    let hlen: i64 = len(parts)
    if hlen < 3 { return "Exploring" }

    // Check if last 3 all zero
    let mut all_zero = true
    let mut ci: i64 = hlen - 3
    if ci < 0 { ci = 0 }
    while ci < hlen {
        let mut v: i64 = 0
        try { v = to_int(parts[ci]) } catch e { v = 0 }
        if v > 0 { all_zero = false }
        ci = ci + 1
    }
    if all_zero { return "Saturated" }

    // Check acceleration: last cycle has highest count
    let mut last_v: i64 = 0
    try { last_v = to_int(parts[hlen - 1]) } catch e { last_v = 0 }
    let mut max_v: i64 = 0
    let mut mi: i64 = 0
    while mi < hlen - 1 {
        let mut mv: i64 = 0
        try { mv = to_int(parts[mi]) } catch e { mv = 0 }
        if mv > max_v { max_v = mv }
        mi = mi + 1
    }
    if last_v > max_v && last_v > 0 { return "Accelerating" }

    // Check convergence: first half vs second half
    if hlen < 4 { return "Exploring" }
    let mid: i64 = hlen / 2
    let mut early_sum: i64 = 0
    ci = 0
    while ci < mid {
        try { early_sum = early_sum + to_int(parts[ci]) } catch e {}
        ci = ci + 1
    }
    let mut late_sum: i64 = 0
    ci = mid
    while ci < hlen {
        try { late_sum = late_sum + to_int(parts[ci]) } catch e {}
        ci = ci + 1
    }
    let early_avg = to_float(early_sum) / to_float(mid)
    let late_len = hlen - mid
    let late_avg = to_float(late_sum) / to_float(late_len)

    if early_avg > 0.0 {
        let ratio = late_avg / early_avg
        if ratio < 0.5 { return "Converging" }
        if ratio > 1.5 { return "Divergent" }
    }
    return "Exploring"
}

// ═══════════════════════════════════════════════════════════
// ─── TELESCOPE LENS SCANS (from telescope.hexa) ───
// ═══════════════════════════════════════════════════════════
// Lightweight versions of the 5 core lenses, operating on
// corollary value arrays (float[]). Each returns a signal
// score 0.0..1.0 and a label string.

// Lens 1: Consciousness — self-reference pattern count
// Checks how many pairs (i,j) have ratio close to an n=6 constant
fn lens_consciousness(fv: list, n: i64) -> f64 {
    if n < 2 { return 0.0 }
    let mut self_ref: i64 = 0
    let mut i: i64 = 0
    while i < n && i < 30 {
        let vi: f64 = fv[i]
        let mut j: i64 = i + 1
        while j < n && j < 30 {
            let vj: f64 = fv[j]
            if abs_f(vj) > 0.0000000001 {
                let ratio = vi / vj
                if abs_f(ratio - 6.0) < 0.01 { self_ref = self_ref + 1 }
                if abs_f(ratio - 12.0) < 0.01 { self_ref = self_ref + 1 }
                if abs_f(ratio - 2.0) < 0.01 { self_ref = self_ref + 1 }
                if abs_f(ratio - 4.0) < 0.01 { self_ref = self_ref + 1 }
                if abs_f(ratio - 24.0) < 0.01 { self_ref = self_ref + 1 }
                if abs_f(ratio - 5.0) < 0.01 { self_ref = self_ref + 1 }
                if abs_f(ratio - 3.0) < 0.01 { self_ref = self_ref + 1 }
            }
            j = j + 1
        }
        i = i + 1
    }
    let max_pairs = to_float(n * (n - 1) / 2)
    if max_pairs < 1.0 { return 0.0 }
    return clamp01(to_float(self_ref) / max_pairs)
}

// Lens 2: Topology — Betti-0 (connected components via gap detection)
fn lens_topology(fv: list, n: i64) -> f64 {
    if n < 3 { return 0.0 }
    let limit: i64 = if n < 40 { n } else { 40 }
    // compute mean for threshold (pre-parsed floats — split/to_float 제거)
    let mut sum: f64 = 0.0
    let mut si: i64 = 0
    while si < limit {
        sum = sum + fv[si]
        si = si + 1
    }
    let mean = if limit > 0 { sum / to_float(limit) } else { 1.0 }
    let threshold = if abs_f(mean) > 0.0 { abs_f(mean) * 0.5 } else { 1.0 }

    // count gaps (consecutive value differences)
    let mut gaps: i64 = 0
    si = 0
    while si < limit - 1 {
        if abs_f(fv[si + 1] - fv[si]) > threshold { gaps = gaps + 1 }
        si = si + 1
    }

    let betti0: i64 = gaps + 1
    let mut cycles: i64 = 0
    let climit: i64 = if limit < 20 { limit } else { 20 }
    si = 0
    while si < climit {
        let mut sj: i64 = si + 2
        while sj < climit {
            if abs_f(fv[si] - fv[sj]) < threshold * 0.1 { cycles = cycles + 1 }
            sj = sj + 1
        }
        si = si + 1
    }

    let sig = to_float(betti0 - 1) * 0.3 + to_float(cycles) * 0.1
    return clamp01(sig)
}

// Lens 3: Causal — autocorrelation (lag-1) (pre-parsed float list)
fn lens_causal(fv: list, n: i64) -> f64 {
    if n < 4 { return 0.0 }
    let limit: i64 = if n < 50 { n } else { 50 }

    let mut sum: f64 = 0.0
    let mut ci: i64 = 0
    while ci < limit {
        sum = sum + fv[ci]
        ci = ci + 1
    }
    let mean = sum / to_float(limit)

    let mut cov: f64 = 0.0
    let mut var: f64 = 0.0
    ci = 0
    while ci < limit - 1 {
        let d0 = fv[ci] - mean
        let d1 = fv[ci + 1] - mean
        cov = cov + d0 * d1
        var = var + d0 * d0
        ci = ci + 1
    }
    let autocorr = if var > 0.0 { cov / var } else { 0.0 }

    let mid: i64 = limit / 2
    let mut first_sum: f64 = 0.0
    ci = 0
    while ci < mid {
        first_sum = first_sum + fv[ci]
        ci = ci + 1
    }
    let mut second_sum: f64 = 0.0
    ci = mid
    while ci < limit {
        second_sum = second_sum + fv[ci]
        ci = ci + 1
    }
    let first_mean = first_sum / to_float(mid)
    let second_mean = second_sum / to_float(limit - mid)
    let direction = abs_f(second_mean - first_mean)

    let sig = abs_f(autocorr) * 0.6 + clamp01(direction * 0.1) * 0.4
    return clamp01(sig)
}

// Lens 4: Gravity — attractor detection (pre-parsed float list)
fn lens_gravity(fv: list, n: i64) -> f64 {
    if n < 3 { return 0.0 }
    let limit: i64 = if n < 50 { n } else { 50 }

    let mut attracted: i64 = 0
    let mut ci: i64 = 0
    while ci < limit {
        let v: f64 = fv[ci]

        if abs_f(v - 6.0) / 6.0 < 0.05 { attracted = attracted + 1 }
        if abs_f(v - 12.0) / 12.0 < 0.05 { attracted = attracted + 1 }
        if abs_f(v - 2.0) / 2.0 < 0.05 { attracted = attracted + 1 }
        if abs_f(v - 4.0) / 4.0 < 0.05 { attracted = attracted + 1 }
        if abs_f(v - 24.0) / 24.0 < 0.05 { attracted = attracted + 1 }
        if abs_f(v - 5.0) / 5.0 < 0.05 { attracted = attracted + 1 }
        if abs_f(v - 137.036) / 137.036 < 0.01 { attracted = attracted + 1 }
        if abs_f(v - 0.3153) / 0.3153 < 0.05 { attracted = attracted + 1 }

        ci = ci + 1
    }

    return clamp01(to_float(attracted) / to_float(limit))
}

// Lens 5: Thermo — Shannon entropy approximation (pre-parsed float list + native Map)
fn lens_thermo(fv: list, n: i64) -> f64 {
    if n < 2 { return 0.0 }
    let limit: i64 = if n < 50 { n } else { 50 }

    let mut bin_map = #{}
    let mut ci: i64 = 0
    while ci < limit {
        let bin_key = to_string(to_int(fv[ci] * 10.0))
        let mut old_c: i64 = 0
        try { old_c = bin_map[bin_key] } catch e {}
        bin_map[bin_key] = old_c + 1
        ci = ci + 1
    }

    let cnt_vals = bin_map.values()
    let num_bins: i64 = len(cnt_vals)
    let total = to_float(limit)
    let mut entropy: f64 = 0.0
    ci = 0
    while ci < num_bins {
        let c: f64 = to_float(cnt_vals[ci])
        let p = c / total
        if p > 0.0 { entropy = entropy - p * ln_f(p) }
        ci = ci + 1
    }

    let max_ent = ln_f(to_float(if num_bins > 1 { num_bins } else { 2 }))
    if max_ent > 0.0 {
        return clamp01(entropy / max_ent)
    }
    return 0.0
}

// Run all 5 lenses and return consensus count (how many report signal > threshold)
// Also returns boosted confidence multiplier
fn telescope_verify(vals: string, threshold: f64) -> string {
    // Pre-parse: 1회 split + to_float → 5개 렌즈가 공유 (5회 split 제거)
    let _tp = vals.split("|")
    let _tn: i64 = len(_tp)
    let mut _tfv: list = []
    let mut _ti: i64 = 0
    while _ti < _tn {
        let mut _tv: f64 = 0.0
        try { _tv = to_float(_tp[_ti]) } catch e {}
        _tfv = _tfv.push(_tv)
        _ti = _ti + 1
    }
    let s1 = lens_consciousness(_tfv, _tn)
    let s2 = lens_topology(_tfv, _tn)
    let s3 = lens_causal(_tfv, _tn)
    let s4 = lens_gravity(_tfv, _tn)
    let s5 = lens_thermo(_tfv, _tn)

    let mut agree: i64 = 0
    if s1 >= threshold { agree = agree + 1 }
    if s2 >= threshold { agree = agree + 1 }
    if s3 >= threshold { agree = agree + 1 }
    if s4 >= threshold { agree = agree + 1 }
    if s5 >= threshold { agree = agree + 1 }

    // consensus level
    let level = if agree >= 4 { "High" } else { if agree >= 3 { "Candidate" } else { "None" } }

    // confidence boost: 3+ agreement = +0.1, 4+ = +0.15, 5 = +0.2
    let boost = if agree >= 5 { 0.2 } else { if agree >= 4 { 0.15 } else { if agree >= 3 { 0.1 } else { 0.0 } } }

    return to_string(agree) + "|" + level + "|" + to_string(boost) + "|" + to_string(s1) + "|" + to_string(s2) + "|" + to_string(s3) + "|" + to_string(s4) + "|" + to_string(s5)
}


