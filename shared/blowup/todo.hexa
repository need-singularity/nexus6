fn project_icon(name: string) -> string {
    if name == "nexus" { return "🔭" }
    if name == "anima" { return "🧠" }
    if name == "n6-architecture" { return "🏗️" }
    if name == "papers" { return "📄" }
    if name == "hexa-lang" { return "💎" }
    if name == "void" { return "🖥️" }
    if name == "airgenome" { return "🧬" }
    return "📦"
}

fn project_title(name: string) -> string {
    if name == "nexus" { return "NEXUS — Discovery Engine" }
    if name == "anima" { return "Anima — Consciousness Engine" }
    if name == "n6-architecture" { return "N6 Architecture — System Design" }
    if name == "papers" { return "Papers — Distribution" }
    if name == "hexa-lang" { return "HEXA-LANG — Perfect Number Language" }
    if name == "void" { return "VOID — Hexa Terminal" }
    if name == "airgenome" { return "AirGenome — OS Genome Scanner" }
    return name
}

fn repo_path(name: string) -> string {
    if name == "anima" { return _dev + "/anima/anima" }
    return _dev + "/" + name
}

fn git_log1(rp: string) -> string {
    let mut msg = ""
    try { msg = exec("cd " + rp + " && git log --oneline -1 --format='%s' 2>/dev/null").trim() } catch e {} // @allow-silent-catch
    return msg
}

fn pri_label(pri: string) -> string {
    if pri == "CRITICAL" { return "🔴 CRITICAL" }
    if pri == "IMPORTANT" { return "🟡 IMPORTANT" }
    if pri == "NICE" { return "🟢 NICE TO HAVE" }
    return "⚪ BACKLOG"
}

fn status_emoji(st: string) -> string {
    if st.contains("진행중") || st.contains("wip") || st.contains("in_progress") { return "🔄 진행중 " }
    if st.contains("돌파대기") { return "⏳ 돌파대기" }
    if st.contains("완료") || st.contains("done") { return "✅ 완료   " }
    return "⬚ 대기   "
}

fn pad_right(s: string, width: i64) -> string {
    let slen = len(s)
    if slen >= width { return s }
    let mut result = s
    let mut i: i64 = slen
    while i < width {
        result = result + " "
        i = i + 1
    }
    return result
}

fn box_header_5(c1: string, c2: string, c3: string, c4: string, c5: string) {
    println("  +" + pad_right("", len(c1)+2).replace(" ", "-") + "+" + pad_right("", len(c2)+2).replace(" ", "-") + "+" + pad_right("", len(c3)+2).replace(" ", "-") + "+" + pad_right("", len(c4)+2).replace(" ", "-") + "+" + pad_right("", len(c5)+2).replace(" ", "-") + "+")
    println("  | " + c1 + " | " + c2 + " | " + c3 + " | " + c4 + " | " + c5 + " |")
    println("  +" + pad_right("", len(c1)+2).replace(" ", "-") + "+" + pad_right("", len(c2)+2).replace(" ", "-") + "+" + pad_right("", len(c3)+2).replace(" ", "-") + "+" + pad_right("", len(c4)+2).replace(" ", "-") + "+" + pad_right("", len(c5)+2).replace(" ", "-") + "+")
}

fn wave_row(id: string, cat: string, task: string, st: string, eff: string) {
    let emoji = status_emoji(st)
    println("  | " + pad_right(id, 5) + " | " + pad_right(cat, 10) + " | " + pad_right(task, 43) + " | " + emoji + " | " + pad_right(eff, 11) + " |")
}

fn box_footer_5() {
    println("  +-------+------------+---------------------------------------------+-----------+-------------+")
}

// ═══════════════════════════════════════════════════════════
// ─── 통합 표 출력 (수동 + 돌파) ───
// ═══════════════════════════════════════════════════════════

// status 라벨 단축 (commands.json format_rules: '상태' 컬럼)
fn _status_label(st: string) -> string {
    if st.contains("진행중") || st.contains("wip") || st.contains("in_progress") || st.contains("러닝") || st.contains("running") { return "진행중" }
    if st.contains("돌파대기") { return "돌파대기" }
    if st.contains("완료") || st.contains("done") || st.contains("달성") { return "완료" }
    if st.contains("미시작") { return "대기" }
    return "대기"
}

// box_table.scr 호출 — TSV → box-drawing
fn _render_box(tsv: string) {
    try {
        write_file("/tmp/_todo_box.tsv", tsv)
        let r = exec("/usr/bin/python3 " + _shared + "/blowup/lib/box_table.scr < /tmp/_todo_box.tsv 2>&1")
        println(r)
    } catch e { // @allow-silent-catch
        println("(box render failed)")
    }
}

fn print_project(name: string, bt_lines: string) {
    // JSON 폐기 — 자동 창발만 사용
    let project_bt = load_project_breakthroughs(name)

    // 프로젝트별 돌파만 합치기 (수동 JSON 제거)
    let mut combined = project_bt

    // nexus는 글로벌 돌파도 추가
    if name == "nexus" && bt_lines.trim() != "" {
        if combined.trim() != "" { combined = combined + "\n" + bt_lines }
        else { combined = bt_lines }
    }

    let icon = project_icon(name)
    let title = project_title(name)

    println("")
    println(icon + " " + title + " 할일")
    println("")

    // 통일 컬럼: # | 영역 | 설명 | 영향 | 상태 (commands.json format_rules)
    let mut tsv = "#\t영역\t설명\t영향\t상태\n"
    let mut row_id: i64 = 0
    let mut done_cnt: i64 = 0
    let mut todo_cnt: i64 = 0
    let mut proposed: i64 = 0

    let all_lines = combined.split("\n")
    let groups = ["CRITICAL", "IMPORTANT", "NICE", "BACKLOG"]

    // ─── 1) 메인 — 우선순위 그룹별 (CRITICAL → IMPORTANT → NICE → BACKLOG) ───
    for g in groups {
        for line in all_lines {
            if line.trim() == "" { continue }
            let cols = line.split("\t")
            if cols.len() < 6 { continue }
            if cols[1] != g { continue }
            let st = cols[4]
            let is_done = st.contains("완료") || st.contains("done") || st.contains("달성")
            if is_done { done_cnt = done_cnt + 1; continue }  // done 절대 제외
            row_id = row_id + 1
            todo_cnt = todo_cnt + 1
            // # | 영역 | 설명 | 영향 | 상태  (cols: 0=id 1=pri 2=area 3=desc 4=status 5=impact)
            tsv = tsv + to_string(row_id) + "\t" + cols[2] + "\t" + cols[3] + "\t" + cols[5] + "\t" + _status_label(st) + "\n"
        }
    }

    // ─── 2) 제안 (파동 창발): 통일 표 안에 통합. target 20건 미만 시 채움 ───
    let target_count: i64 = 20
    if true {
        let mut need = target_count - todo_cnt
        if need < 10 { need = 10 }  // 최소 10건 창발

        let mut gen: i64 = 0

        // 공통: atlas.n6 EMPIRICAL [7]→EXACT 승격 (상위 6개 섹션)
        try {
            let emp = exec("/usr/bin/awk '/^# ══/{sec=$0; gsub(/# ══ /,\"\",sec); gsub(/ \\(.*/,\"\",sec)} /\\[7\\]/{c[sec]++} END{for(s in c) print s\"\\t\"c[s]}' " + _shared + "/n6/atlas.n6 2>/dev/null | sort -k2 -t'\t' -rn | head -6")
            let emp_lines = emp.split("\n")
            for el in emp_lines {
                if el.trim() == "" || gen >= need { continue }
                let ep = el.split("\t")
                if ep.len() < 2 { continue }
                gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                tsv = tsv + to_string(row_id) + "\t아틀라스\t" + ep[0] + " [7] " + ep[1] + "건 → [10] 승격\t정밀도 상승\t제안\n"
            }
        } catch e {} // @allow-silent-catch

        // 공통: 가설(?) 해소
        if gen < need {
            try {
                let conj = _atlas_conj
                if conj > 0 {
                    gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                    tsv = tsv + to_string(row_id) + "\t아틀라스\t가설(?) " + to_string(conj) + "건 검증/해소\t신뢰도 ↑\t제안\n"
                }
            } catch e {} // @allow-silent-catch
        }

        // 공통: 발견 로그 다음 목표 (캐시 참조)
        if gen < need {
            try {
                let dc = _atlas_line_count
                let nt = ((dc / _disc_step) + 1) * _disc_step
                gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                tsv = tsv + to_string(row_id) + "\t발견\tatlas " + to_string(dc) + " → " + to_string(nt) + " 목표\t특이점 심화\t진행중\n"
            } catch e {} // @allow-silent-catch
        }

        // n6-architecture 전용
        if name == "n6-architecture" {
            // DSE 미탐색
            if gen < need {
                try {
                    let dse_m = exec("comm -23 <(ls -1 " + _dev + "/n6-architecture/docs 2>/dev/null | while read d; do test -d " + _dev + "/n6-architecture/docs/\"$d\" && echo \"$d\"; done | sort) <(ls -1 " + _shared + "/dse/domains/*.toml 2>/dev/null | xargs -I{} basename {} .toml | sort) | head -5")
                    let dse_lines = dse_m.split("\n")
                    for dl in dse_lines {
                        if dl.trim() == "" || gen >= need { continue }
                        gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                        tsv = tsv + to_string(row_id) + "\tDSE\t" + dl.trim() + " TOML 생성\t도메인 확장\t제안\n"
                    }
                } catch e {} // @allow-silent-catch
            }

            // goal.md 부실 보강
            if gen < need {
                try {
                    let weak_list = exec("for d in $(ls -1 " + _dev + "/n6-architecture/docs 2>/dev/null); do f=" + _dev + "/n6-architecture/docs/$d/goal.md; test -f \"$f\" && n=$(wc -l < \"$f\") && [ \"$n\" -lt " + to_string(_goal_min) + " ] && printf '%s\\t%s\\n' \"$d\" \"$n\"; done | sort -t'\t' -k2 -n | head -5")
                    let wl = weak_list.split("\n")
                    for wline in wl {
                        if wline.trim() == "" || gen >= need { continue }
                        let wp = wline.split("\t")
                        if wp.len() < 2 { continue }
                        gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                        tsv = tsv + to_string(row_id) + "\tgoal.md\t" + wp[0] + " 보강 (" + wp[1] + "줄)\t문서 품질\t제안\n"
                    }
                } catch e {} // @allow-silent-catch
            }

            // 렌즈 미구현
            if gen < need {
                try {
                    let lens_r = _count_lens_status("registered")
                    if lens_r > 0 {
                        gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                        tsv = tsv + to_string(row_id) + "\t렌즈\tregistered " + to_string(lens_r) + "건 → .rs 구현\t탐색 확대\t제안\n"
                    }
                } catch e {} // @allow-silent-catch
            }
        }

        // nexus 전용
        if name == "nexus" {
            // 모듈 확장 (캐시 참조)
            if gen < need {
                try {
                    let mc = _module_count
                    let nm = ((mc / _mod_step) + 1) * _mod_step
                    gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                    tsv = tsv + to_string(row_id) + "\t모듈\t" + to_string(mc) + "개 → " + to_string(nm) + "+ 확장 (OUROBOROS)\t커버리지 ↑\t제안\n"
                } catch e {} // @allow-silent-catch
            }

            // BT 확장 (hexa native — n6/docs 또는 원본에서 BT 카운트)
            if gen < need {
                try {
                    let bt_file = _shared + "/n6/docs/breakthrough-theorems.md"
                    let bt_raw = read_file(bt_file)
                    let bt_lns = bt_raw.split("\n")
                    let mut bt_count: i64 = 0
                    for btl in bt_lns {
                        if btl.contains("BT-") {
                            let parts = btl.split("BT-")
                            let mut pi: i64 = 1
                            while pi < parts.len() {
                                let num_s = parts[pi].split(" ")[0].split(":")[0].split("|")[0].split(")")[0].split("]")[0].trim()
                                let num = safe_int(num_s)
                                if num > bt_count { bt_count = num }
                                pi = pi + 1
                            }
                        }
                    }
                    if bt_count > 0 {
                        let bt_next = ((bt_count / 100) + 1) * 100
                        gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                        tsv = tsv + to_string(row_id) + "\tBT\tBT " + to_string(bt_count) + " → " + to_string(bt_next) + "+ 확장\t정리 커버리지\t제안\n"
                    }
                } catch e {} // @allow-silent-catch
            }

            // 외계인지수 승격
            if gen < need {
                try {
                    let alien_list = _alien_items_below(_alien_target)
                    let al = alien_list.split("\n")
                    for aline in al {
                        if aline.trim() == "" || gen >= need { continue }
                        let ap = aline.split("\t")
                        if ap.len() < 2 { continue }
                        gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                        tsv = tsv + to_string(row_id) + "\t승격\t" + ap[0] + " 🛸" + ap[1] + "→" + to_string(_alien_target) + "\t천장 돌파\t제안\n"
                    }
                } catch e {} // @allow-silent-catch
            }

            // verify_*_n6.hexa 커버리지 (done 제외)
            if gen < need {
                let vbase = _P["verify_n6_base"]
                if _is_missing(vbase) == false {
                    try {
                        let vscan = exec("for d in $(ls -1 " + vbase + " 2>/dev/null | sort); do test -d " + vbase + "/\"$d\" || continue; test -f " + vbase + "/\"$d\"/goal.md || continue; ls " + vbase + "/\"$d\"/verify_*_n6.hexa >/dev/null 2>&1 && st=완료 || st=미시작; printf '%s\\t%s\\n' \"$d\" \"$st\"; done | sort -t'\t' -k2 | head -8")
                        let vl = vscan.split("\n")
                        for vline in vl {
                            if vline.trim() == "" || gen >= need { continue }
                            let vp = vline.split("\t")
                            if vp.len() < 2 { continue }
                            if vp[1] == "완료" { done_cnt = done_cnt + 1; continue }  // done 제외
                            gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                            tsv = tsv + to_string(row_id) + "\t검증\t" + vp[0] + " verify_*_n6.hexa\t검증 커버리지\t제안\n"
                        }
                    } catch e {} // @allow-silent-catch
                }
            }

            // seed_engine merge — done 카운트만 (행 표시 X)
            try {
                let se_path = _P["seed_engine"]
                if _is_missing(se_path) == false {
                    let sm = exec(_hexa_bin + " " + se_path + " merge 2>/dev/null")
                    if sm.trim() != "" { done_cnt = done_cnt + 1 }
                }
            } catch e {} // @allow-silent-catch

            // 논문 미발행
            if gen < need {
                try {
                    let papers_dir = exec("ls " + _dev + "/n6-architecture/docs/paper/n6-*-paper.md 2>/dev/null | wc -l").trim()
                    gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                    tsv = tsv + to_string(row_id) + "\t논문\t" + papers_dir + "편 Zenodo DOI 발행\t학술화\t제안\n"
                } catch e {} // @allow-silent-catch
            }
        }

        // nexus 전용 추가
        if name == "nexus" {
            // convergence 실패 항목
            if gen < need {
                let cs_path = _P["convergence_scanner"]
                if _is_missing(cs_path) == false {
                try {
                    let conv_raw = exec(_hexa_bin + " " + cs_path + " brief 2>/dev/null")
                    let cl = conv_raw.split("\n")
                    for cline in cl {
                        if cline.trim() == "" || gen >= need { continue }
                        if cline.contains("failed") || cline.contains("실패") {
                            gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                            tsv = tsv + to_string(row_id) + "\t수렴\t" + cline.trim() + "\t수렴률\t제안\n"
                        }
                    }
                } catch e { // @allow-silent-catch
                    try {
                        let conv_files = exec("ls " + _shared + "/convergence/*.json 2>/dev/null")
                        let cf_lines = conv_files.split("\n")
                        for cf in cf_lines {
                            if cf.trim() == "" || gen >= need { continue }
                            try {
                                let cf_raw = read_file(cf.trim())
                                if cf_raw.contains("\"failed\":") && !cf_raw.contains("\"failed\":0") && !cf_raw.contains("\"failed\": 0") {
                                    let cf_name = cf.trim().split("/")
                                    let proj_name = cf_name[cf_name.len() - 1].replace(".json", "")
                                    gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                                    tsv = tsv + to_string(row_id) + "\t수렴\t" + proj_name + " 실패 항목 해소\t수렴률\t제안\n"
                                }
                            } catch e2 {} // @allow-silent-catch
                        }
                    } catch e3 {} // @allow-silent-catch
                }
                }
            }

            // 대시보드
            if gen < need {
                gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                tsv = tsv + to_string(row_id) + "\t대시보드\tnexus-dashboard 신규 차트 추가\t가시화\t제안\n"
            }

            // 렌즈 .rs 구현
            if gen < need {
                try {
                    let lr = _count_lens_status("registered")
                    if lr > 0 {
                        gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                        tsv = tsv + to_string(row_id) + "\t렌즈\tregistered " + to_string(lr) + "건 → .rs 구현\t탐색 확대\t제안\n"
                    }
                } catch e {} // @allow-silent-catch
            }

            // growth_bus 분석 (캐시 참조)
            if gen < need {
                try {
                    let gb = _atlas_line_count
                    gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                    tsv = tsv + to_string(row_id) + "\t분석\tgrowth_bus " + to_string(gb) + "건 패턴 분석\t돌파 패턴\t제안\n"
                } catch e {} // @allow-silent-catch
            }
        }

        // hexa-lang 전용
        if name == "hexa-lang" {
            if gen < need {
                try {
                    let tc = safe_int(exec("grep -rh 'proof [a-z_]' " + _dev + "/hexa-lang/self/ " + _dev + "/hexa-lang/examples/ --include='*.hexa' 2>/dev/null | wc -l").trim())
                    if tc < 1000 {
                        gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                        tsv = tsv + to_string(row_id) + "\t테스트\t" + to_string(tc) + " → 1000+ proof blocks\t안정성\t제안\n"
                    }
                } catch e {} // @allow-silent-catch
            }
            if gen < need {
                try {
                    let has_ops = exec("test -f " + _dev + "/hexa-lang/self/ml/tensor_ops.hexa && echo 1 || echo 0").trim()
                    if has_ops == "0" {
                        gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                        tsv = tsv + to_string(row_id) + "\t빌트인\tTensor ops 추가 확장\tAI 지원\t제안\n"
                    }
                } catch e {} // @allow-silent-catch
            }
            if gen < need {
                try {
                    let has_ref = exec("test -f " + _dev + "/hexa-lang/docs/language_reference.hexa && echo 1 || echo 0").trim()
                    if has_ref == "0" {
                        gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                        tsv = tsv + to_string(row_id) + "\t문서\tHEXA 언어 레퍼런스 v1.0 (.hexa doc)\t온보딩\t제안\n"
                    }
                } catch e {} // @allow-silent-catch
            }
        }

        // anima 전용
        if name == "anima" {
            if gen < need {
                try {
                    let lc = safe_int(exec("ls " + _dev + "/anima/anima/consciousness_laws/ 2>/dev/null | wc -l").trim())
                    let nl = ((lc / 500) + 1) * 500
                    gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                    tsv = tsv + to_string(row_id) + "\t법칙\t의식 법칙 " + to_string(lc) + " → " + to_string(nl) + "+\t커버리지\t제안\n"
                } catch e {} // @allow-silent-catch
            }
            if gen < need {
                gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                tsv = tsv + to_string(row_id) + "\t학습\t다음 체크포인트 학습\tPhi 상승\t제안\n"
            }
            if gen < need {
                gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                tsv = tsv + to_string(row_id) + "\t이식\t14B→70B 의식 이식 검증\t스케일 불변\t제안\n"
            }
        }

        // papers 전용
        if name == "papers" {
            if gen < need {
                try {
                    // papers manifest hexa native — Draft 제목 추출 (캐시 참조)
                    let _mani_raw = _papers_raw_cache
                    // 각 paper 블록에서 status=Draft인 것의 title 추출
                    let _paper_blocks = _mani_raw.split("\"title\":")
                    let mut _draft_list = ""
                    let mut _dcount: i64 = 0
                    for _pb in _paper_blocks {
                        if _dcount >= 5 { break }
                        if !_pb.contains("\"status\"") { continue }
                        let _st = _pb.split("\"status\"")[1]
                        if !_st.contains(":") { continue }
                        let _sv = _st.split(":")[1].trim().split("\"")[1]
                        if _sv != "Draft" { continue }
                        let _tt = _pb.trim().split("\"")[1]
                        if _tt == "" { continue }
                        _draft_list = _draft_list + _tt + "\n"
                        _dcount = _dcount + 1
                    }
                    let draft = _draft_list
                    let dl = draft.split("\n")
                    for dline in dl {
                        if dline.trim() == "" || gen >= need { continue }
                        gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                        tsv = tsv + to_string(row_id) + "\t발행\t" + dline.trim() + " DOI 발행\t학술화\t제안\n"
                    }
                } catch e {} // @allow-silent-catch
            }
        }

        // ─── 범용 자율 창발: 프로젝트 디렉토리 스캔 ───
        let proj_dir = _dev + "/" + name
        if gen < need {
            try {
                let empty_dirs = exec("find " + proj_dir + " -mindepth 1 -maxdepth 2 -type d -empty 2>/dev/null | head -3")
                let edl = empty_dirs.split("\n")
                let mut edi: i64 = 0
                while edi < len(edl) && gen < need {
                    let ed = edl[edi].trim()
                    if ed != "" {
                        let short = ed.split("/")
                        let label = short[len(short) - 1]
                        gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                        tsv = tsv + to_string(row_id) + "\t빈공간\t" + label + " 디렉토리 구현\t커버리지\t제안\n"
                    }
                    edi = edi + 1
                }
            } catch e {} // @allow-silent-catch
        }
        if gen < need {
            try {
                let todo_count = safe_int(exec("grep -r 'TODO\\|FIXME\\|HACK' " + proj_dir + " --include='*.hexa' --include='*.rs' --include='*.py' 2>/dev/null | wc -l").trim())
                if todo_count > 0 {
                    gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                    tsv = tsv + to_string(row_id) + "\t정리\tTODO/FIXME " + to_string(todo_count) + "건 해소\t코드 품질\t제안\n"
                }
            } catch e {} // @allow-silent-catch
        }
        if gen < need {
            try {
                let stale = exec("find " + proj_dir + " \\( -name '*.hexa' -o -name '*.rs' -o -name '*.py' \\) -mtime +30 -not -path '*/examples/*' -not -path '*/.git/*' 2>/dev/null | head -3")
                let sl = stale.split("\n")
                let mut si: i64 = 0
                while si < len(sl) && gen < need {
                    let sf = sl[si].trim()
                    if sf != "" {
                        let sp = sf.split("/")
                        let sname = sp[len(sp) - 1]
                        gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                        tsv = tsv + to_string(row_id) + "\t정체\t" + sname + " 갱신 필요\t활성화\t제안\n"
                    }
                    si = si + 1
                }
            } catch e {} // @allow-silent-catch
        }

        // ─── 파동 간섭: growth_bus 최근 돌파 → 후속 할일 전파 ───
        if gen < need {
            try {
                let gb_raw = exec("tail -30 " + _shared + "/n6/atlas.n6 2>/dev/null")
                let gb_lines = gb_raw.split("\n")
                let mut wave_seen = []
                for gbl in gb_lines {
                    if gbl.trim() == "" || gen >= need { continue }
                    let mut has_type = false
                    if gbl.contains("\"blowup\"") || gbl.contains("\"discovery\"") || gbl.contains("\"wave_blowup\"") || gbl.contains("\"singularity\"") {
                        has_type = true
                    }
                    if !has_type { continue }
                    if !gbl.contains("\"domain\":\"") { continue }
                    let dp = gbl.split("\"domain\":\"")
                    if len(dp) < 2 { continue }
                    let dom = dp[1].split("\"")[0]
                    if dom == "" { continue }
                    let mut dup = false
                    for ws in wave_seen { if ws == dom { dup = true } }
                    if dup { continue }
                    wave_seen = wave_seen + [dom]
                    let mut typ = "돌파"
                    if gbl.contains("\"wave_blowup\"") { typ = "파동" }
                    if gbl.contains("\"singularity\"") { typ = "특이점" }
                    gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                    tsv = tsv + to_string(row_id) + "\t파동\t" + dom + " 후속 돌파 (" + typ + " 전파)\t파동 증폭\t제안\n"
                }
            } catch e {} // @allow-silent-catch
        }

        // ─── 파동 간섭 2차: next_directions → 방향 기반 할일 ───
        if gen < need {
            try {
                let nd_raw = exec("tail -20 " + _shared + "/next_directions.jsonl 2>/dev/null")
                let nd_lines = nd_raw.split("\n")
                let mut dir_seen = []
                for ndl in nd_lines {
                    if ndl.trim() == "" || gen >= need { continue }
                    if !ndl.contains("\"domain\":\"") || !ndl.contains("\"direction\":\"") { continue }
                    let dp2 = ndl.split("\"domain\":\"")
                    if len(dp2) < 2 { continue }
                    let dom2 = dp2[1].split("\"")[0]
                    if dom2 == "" { continue }
                    let mut dup2 = false
                    for ds in dir_seen { if ds == dom2 { dup2 = true } }
                    if dup2 { continue }
                    dir_seen = dir_seen + [dom2]
                    let dr = ndl.split("\"direction\":\"")
                    let mut direction = ""
                    if len(dr) >= 2 { direction = dr[1].split("\"")[0] }
                    if direction == "" { continue }
                    gen = gen + 1; row_id = row_id + 1; proposed = proposed + 1
                    tsv = tsv + to_string(row_id) + "\t방향\t" + dom2 + ": " + direction + "\t다음 파동\t제안\n"
                }
            } catch e {} // @allow-silent-catch
        }
    }

    // ─── 통일 box-drawing 표 출력 (commands.json format_rules) ───
    _render_box(tsv)

    println("")
    println("> 진행: 완료 " + to_string(done_cnt) + " / 할일 " + to_string(todo_cnt) + " / 제안 " + to_string(proposed))
}

// ═══════════════════════════════════════════════════════════
// ─── 프로젝트 리졸버 ───
// ═══════════════════════════════════════════════════════════

fn resolve_project(name: string) -> string {
    if name == "nexus" { return "nexus" }
    if name == "anima" { return "anima" }
    if name == "n6-arch" || name == "n6-architecture" || name == "n6arch" { return "n6-architecture" }
    if name == "papers" { return "papers" }
    if name == "hexa" || name == "hexa-lang" { return "hexa-lang" }
    if name == "void" { return "void" }
    if name == "airgenome" { return "airgenome" }
    if name == "all" || name == "전체" { return "all" }
    return "all"
}

// ═══════════════════════════════════════════════════════════
// ─── (대량 모드 폐기됨 — 자동 생성이 기본 모드에 통합) ───
// ═══════════════════════════════════════════════════════════

fn _bulk_scan_deprecated(project: string) {
    println("")
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    println("  🔥 대량 모드 — 오래 걸려도 전수 스캔")
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

    // ─── 1) 기본 할일 표 (일반 모드와 동일) ───
    let mut bt = ""
    if project == "nexus" {
        bt = load_breakthrough_todos()
    }
    println("")
    println("## 1. 기본 할일")
    print_project(project, bt)

    // ─── 2) gap_finder 전체 (brief가 아닌 full) ───
    println("")
    println("## 2. 빈공간 전수 (gap_finder full)")
    let _gap_full_path = _P["gap_finder"]
    if _is_missing(_gap_full_path) {
        println("> gap_finder MISSING — paths.json 참고")
    } else {
    try {
        let gap_full = exec(_hexa_bin + " " + _gap_full_path + " full 2>/dev/null")
        let gap_lines = gap_full.split("\n")
        let mut gc: i64 = 0
        for gl in gap_lines {
            let gt = gl.trim()
            if gt == "" { continue }
            gc = gc + 1
            println("  " + to_string(gc) + ". " + gt)
        }
        println("> 빈공간 " + to_string(gc) + "건")
    } catch e { // @allow-silent-catch
        println("> gap_finder 실행 불가")
    }
    }

    // ─── 3) goal.md 미작성 전수 ───
    if project == "n6-architecture" {
        println("")
        println("## 3. goal.md 미작성 도메인 전수")
        try {
            let missing = exec("i=0; for d in $(ls -1 " + _dev + "/n6-architecture/docs 2>/dev/null | sort); do test -d " + _dev + "/n6-architecture/docs/\"$d\" || continue; test -f " + _dev + "/n6-architecture/docs/\"$d\"/goal.md && continue; i=$((i+1)); echo \"  $i. $d\"; done; echo \"> 미작성 ${i}건\"")
            println(missing)
        } catch e { // @allow-silent-catch
            println("> goal.md 스캔 불가")
        }

        // ─── 4) goal.md 부실 (" + to_string(_goal_min) + "줄 미만) 전수 ───
        println("")
        println("## 4. goal.md 부실 (" + to_string(_goal_min) + "줄 미만) 전수")
        try {
            let weak = exec("i=0; total=0; for d in $(ls -1 " + _dev + "/n6-architecture/docs 2>/dev/null | sort); do f=" + _dev + "/n6-architecture/docs/$d/goal.md; test -d " + _dev + "/n6-architecture/docs/\"$d\" || continue; test -f \"$f\" || continue; total=$((total+1)); n=$(wc -l < \"$f\"); [ \"$n\" -lt " + to_string(_goal_min) + " ] && { i=$((i+1)); echo \"  $i. $d (${n}줄)\"; }; done; echo \"> 부실 ${i}건 / 전체 ${total}건\"")
            println(weak)
        } catch e { // @allow-silent-catch
            println("> goal.md 줄수 스캔 불가")
        }

        // ─── 5) BT 도메인별 분포 ───
        println("")
        println("## 5. BT 도메인별 분포")
        try {
            let bt_dist = exec("grep '^## BT-' " + _dev + "/n6-architecture/docs/breakthrough-theorems.md 2>/dev/null | sed 's/## BT-//;s/:.*//' | sed 's/[^가-힣a-zA-Z/ ]//g' | sed 's/^ *//;s/ *$//' | sort | uniq -c | sort -rn | head -30 | awk '{cnt=$1; $1=\"\"; sub(/^ /,\"\"); printf \"  %s: %d건\\n\",$0,cnt}'; total=$(grep -c '^## BT-' " + _dev + "/n6-architecture/docs/breakthrough-theorems.md 2>/dev/null); doms=$(grep '^## BT-' " + _dev + "/n6-architecture/docs/breakthrough-theorems.md 2>/dev/null | sed 's/## BT-//;s/:.*//' | sed 's/[^가-힣a-zA-Z/ ]//g' | sed 's/^ *//;s/ *$//' | sort -u | wc -l); echo \"> BT 총 ${total}건, ${doms}개 도메인\"") // @allow-bare-interp
            println(bt_dist)
        } catch e { // @allow-silent-catch
            println("> BT 분포 스캔 불가")
        }

        // ─── 6) DSE TOML 미탐색 ───
        println("")
        println("## 6. DSE TOML 미탐색 도메인")
        try {
            let dse_miss_raw = _dse_missing_domains(50)
            let dse_miss_lines = dse_miss_raw.split("\n")
            let mut dsi: i64 = 0
            for dml in dse_miss_lines {
                if dml.trim() == "" { continue }
                dsi = dsi + 1
                println("  " + to_string(dsi) + ". " + dml.trim())
            }
            println("> DSE 미탐색 " + to_string(dsi) + "건 (상위 50건)")
        } catch e { // @allow-silent-catch
            println("> DSE 스캔 불가")
        }

        // ─── 7) 렌즈 미구현 ───
        println("")
        println("## 7. 렌즈 미구현 (registered only)")
        try {
            // hexa native — lens_registry.json에서 registered 렌즈 id:name 추출 (캐시 참조)
            let _lens_raw = _lens_raw_cache
            // 각 렌즈 블록 분리 ('{' 기준)
            let _lens_blocks = _lens_raw.split("{")
            let mut _li: i64 = 0
            let _lr_total = _count_lens_status("registered")
            for _lb in _lens_blocks {
                if _li >= 50 { break }
                if !_lb.contains("\"status\"") { continue }
                let _ls = _lb.split("\"status\"")[1]
                if !_ls.contains(":") { continue }
                let _lsv = _ls.split(":")[1].trim().split("\"")[1]
                if _lsv != "registered" { continue }
                let _lid = _json_val(_lb, "id")
                let _lname = _json_val(_lb, "name")
                _li = _li + 1
                println("  " + to_string(_li) + ". " + _lid + ": " + _lname)
            }
            println("> 미구현 " + to_string(_lr_total) + "건 (상위 50건)")
        } catch e { // @allow-silent-catch
            println("> 렌즈 스캔 불가")
        }

        // ─── 8) verify FAIL 목록 (있으면) ───
        println("")
        println("## 8. verify 실패 목록")
        try {
            let vfail = exec("scripts=$(find " + _dev + "/n6-architecture -name 'verify_*.py' -o -name 'verify_*.hexa' 2>/dev/null | head -20); total=$(echo \"$scripts\" | grep -c .); fail=0; for s in $scripts; do if [[ \"$s\" == *.py ]]; then /usr/bin/python3 \"$s\" >/dev/null 2>&1 || fail=$((fail+1)); elif [[ \"$s\" == *.hexa ]]; then " + _hexa_bin + " \"$s\" >/dev/null 2>&1 || fail=$((fail+1)); fi; done; if [ $fail -gt 0 ]; then echo \"> 샘플 ${total}건 중 FAIL ${fail}건\"; else echo \"> 샘플 ${total}건 전부 PASS\"; fi")
            println(vfail)
        } catch e { // @allow-silent-catch
            println("> verify 스캔 불가")
        }

        // ─── 9) products.json 외계인지수 < 10 ───
        println("")
        println("## 9. 외계인지수 < 10 (승격 대상)")
        try {
            let _alien_raw = _alien_items_below(_alien_target)
            let _alien_lines = _alien_raw.split("\n")
            let mut _alien_out = ""
            let mut _ac: i64 = 0
            for _al in _alien_lines {
                if _al.trim() == "" { continue }
                let _ap = _al.split("\t")
                if _ap.len() < 2 { continue }
                _ac = _ac + 1
                _alien_out = _alien_out + "  " + _ap[0] + ": 🛸" + _ap[1] + "\n"
            }
            _alien_out = _alien_out + "> 승격 대상 " + to_string(_ac) + "건"
            let alien = _alien_out
            println(alien)
        } catch e { // @allow-silent-catch
            println("> products 스캔 불가")
        }
    }

    // ─── nexus 맞춤 ───
    if project == "nexus" {
        // 3) 모듈 현황
        println("")
        println("## 3. NEXUS 모듈 현황")
        try {
            let mod_count = to_string(_module_count)
            println("  shared/blowup/core 모듈: " + mod_count + "개")
            let mod_list = exec("find " + _engine_dir + " -name '*.hexa' -type f 2>/dev/null | xargs -I{} basename {} .hexa | sort")
            let mlines = mod_list.split("\n")
            let mut mi: i64 = 0
            for ml in mlines {
                if ml.trim() == "" { continue }
                mi = mi + 1
                println("  " + to_string(mi) + ". " + ml.trim())
            }
        } catch e { // @allow-silent-catch
            println("> 모듈 스캔 불가")
        }

        // 4) 렌즈 레지스트리 전체 통계
        println("")
        println("## 4. 렌즈 레지스트리")
        try {
            let _ls_impl = _count_lens_status("implemented")
            let _ls_reg = _count_lens_status("registered")
            let _ls_total = _ls_impl + _ls_reg
            println("  전체: " + to_string(_ls_total))
            println("  implemented: " + to_string(_ls_impl))
            println("  registered: " + to_string(_ls_reg))
        } catch e { // @allow-silent-catch
            println("> 렌즈 스캔 불가")
        }

        // 5) seed 현황
        println("")
        println("## 5. seed 현황")
        try {
            // hexa native — seed 파일 카운트 + 각 파일의 seeds 배열 크기
            let _seed_files = exec("ls -1 " + _shared + "/seeds/*.json 2>/dev/null")
            let _sf_lines = _seed_files.split("\n")
            let mut _sf_count: i64 = 0
            let mut _sf_total: i64 = 0
            let mut _sf_out = ""
            for _sf in _sf_lines {
                if _sf.trim() == "" { continue }
                _sf_count = _sf_count + 1
                try {
                    let _sf_raw = read_file(_sf.trim())
                    // "seeds" 배열의 항목 수 = '"seeds"' 이후 '}' 카운트 (근사)
                    let _sc = _sf_raw.split("\"seeds\"")
                    if _sc.len() >= 2 {
                        let _sarr = _sc[1].split("[")[1].split("]")[0]
                        let _sitems = _sarr.split("{")
                        let _scount = _sitems.len() - 1
                        _sf_total = _sf_total + _scount
                        let _sfname = _sf.trim().split("/")
                        let _sfbase = _sfname[_sfname.len() - 1].replace(".json", "")
                        _sf_out = _sf_out + "  " + _sfbase + ": " + to_string(_scount) + "개\n"
                    }
                } catch e3 {} // @allow-silent-catch
            }
            println("  seed 파일: " + to_string(_sf_count) + "개")
            if _sf_out != "" { print(_sf_out) }
            println("  합계: " + to_string(_sf_total) + "개")
        } catch e { // @allow-silent-catch
            // 간단 버전
            try {
                let sc = exec("ls " + _shared + "/seeds/*.json 2>/dev/null | wc -l").trim()
                println("  seed 파일: " + sc + "개")
            } catch e2 { // @allow-silent-catch
                println("> seed 스캔 불가")
            }
        }

        // 6) BT 전체 통계
        println("")
        println("## 6. BT 전체 통계")
        try {
            let _btf = _dev + "/n6-architecture/docs/breakthrough-theorems.md"
            let bt_stat = exec("sec=$(grep -c '^## BT-' " + _btf + " 2>/dev/null); ex=$(grep -c 'EXACT' " + _btf + " 2>/dev/null); ne=$(grep -c 'NEAR' " + _btf + " 2>/dev/null); mi=$(grep -c 'MISS' " + _btf + " 2>/dev/null); printf '  BT 섹션: %s\\n  EXACT 언급: %s\\n  NEAR 언급: %s\\n  MISS 언급: %s\\n' \"$sec\" \"$ex\" \"$ne\" \"$mi\"")
            println(bt_stat)
        } catch e { // @allow-silent-catch
            println("> BT 스캔 불가")
        }

        // 7) 돌파 엔진 상태
        println("")
        println("## 7. 돌파 엔진 상태")
        try {
            let rho = exec("tail -5 " + _shared + "/n6/atlas.n6 2>/dev/null")
            println(rho)
            let bus_count = to_string(_atlas_line_count)
            println("  atlas.n6 항목: " + bus_count + "건")
        } catch e { // @allow-silent-catch
            println("> 돌파 엔진 스캔 불가")
        }

        // 8) DSE 도메인 TOML 전체 통계
        println("")
        println("## 8. DSE TOML 통계")
        try {
            let dse_count = exec("ls " + _shared + "/dse/domains/*.toml 2>/dev/null | wc -l").trim()
            println("  TOML 파일: " + dse_count + "개")
        } catch e { // @allow-silent-catch
            println("> DSE 스캔 불가")
        }

        // 9) convergence 상태
        println("")
        println("## 9. convergence 상태")
        try {
            let conv_files = exec("ls " + _shared + "/convergence/*.json 2>/dev/null | xargs -I{} basename {} .json | sort")
            let clines = conv_files.split("\n")
            for cl in clines {
                if cl.trim() == "" { continue }
                let cpath = _shared + "/convergence/" + cl.trim() + ".json"
                // hexa native — convergence JSON에서 ossified/stable/failed 추출
                try {
                    let _craw = read_file(cpath)
                    let _co = _json_int(_craw, "ossified")
                    let _cs = _json_int(_craw, "stable")
                    let _cf = _json_int(_craw, "failed")
                    println("  " + cl.trim() + ": 골화=" + to_string(_co) + " 안정=" + to_string(_cs) + " 실패=" + to_string(_cf))
                } catch e4 {} // @allow-silent-catch
            }
        } catch e { // @allow-silent-catch
            println("> convergence 스캔 불가")
        }
    }

    // hexa-lang 맞춤
    if project == "hexa-lang" {
        println("")
        println("## 3. HEXA-LANG 테스트 현황")
        try {
            let test_count = exec("grep -rl '#\\[test\\]' " + _dev + "/hexa-lang/src/ " + _dev + "/hexa-lang/tests/ 2>/dev/null | wc -l").trim()
            println("  테스트 파일: " + test_count + "개")
        } catch e { // @allow-silent-catch
            println("> 테스트 스캔 불가")
        }

        println("")
        println("## 4. HEXA-LANG 소스 통계")
        try {
            let src_stat = exec("find " + _dev + "/hexa-lang/src -name '*.rs' | wc -l").trim()
            let src_lines = exec("find " + _dev + "/hexa-lang/src -name '*.rs' -exec cat {} + | wc -l").trim()
            println("  .rs 파일: " + src_stat + "개")
            println("  소스 줄: " + src_lines + "줄")
        } catch e { // @allow-silent-catch
            println("> 소스 스캔 불가")
        }
    }

    // anima 맞춤
    if project == "anima" {
        println("")
        println("## 3. ANIMA 의식 법칙")
        try {
            let law_count = exec("ls " + _dev + "/anima/anima/consciousness_laws/ 2>/dev/null | wc -l").trim()
            println("  의식 법칙: " + law_count + "개")
        } catch e { // @allow-silent-catch
            println("> 법칙 스캔 불가")
        }

        println("")
        println("## 4. ANIMA 소스 통계")
        try {
            let py_count = exec("find " + _dev + "/anima -name '*.py' 2>/dev/null | wc -l").trim()
            let py_lines = exec("find " + _dev + "/anima -name '*.py' 2>/dev/null -exec cat {} + | wc -l").trim()
            println("  .py 파일: " + py_count + "개")
            println("  소스 줄: " + py_lines + "줄")
        } catch e { // @allow-silent-catch
            println("> 소스 스캔 불가")
        }

        println("")
        println("## 5. ANIMA 체크포인트")
        try {
            let ckpt = exec("ls " + _dev + "/anima/checkpoints/ 2>/dev/null | wc -l").trim()
            println("  체크포인트: " + ckpt + "개")
        } catch e { // @allow-silent-catch
            println("> 체크포인트 스캔 불가")
        }

        println("")
        println("## 6. ANIMA 학습 상태")
        try {
            // hexa native — consciousness_engine_status.json k:v 추출
            let _ce_raw = read_file(_dev + "/airgenome/consciousness_engine_status.json")
            let _ce_pairs = _ce_raw.split("\"")
            let mut _ce_out = ""
            let mut _ci: i64 = 0
            let mut _ck = ""
            for _cp in _ce_pairs {
                if _ci >= 20 { break }  // 10쌍 = 20 tokens
                if _ci % 4 == 1 { _ck = _cp }
                if _ci % 4 == 3 {
                    _ce_out = _ce_out + "  " + _ck + ": " + _cp + "\n"
                }
                _ci = _ci + 1
            }
            let status = _ce_out.trim()
            println(status)
        } catch e { // @allow-silent-catch
            println("> 학습 상태 스캔 불가")
        }
    }

    // papers 맞춤
    if project == "papers" {
        println("")
        println("## 3. 논문 발행 현황")
        try {
            let _pt = _papers_total()
            let _pp = _papers_count_status("Published")
            let _pd = _papers_count_status("Draft")
            let paper_stat = "  전체: " + to_string(_pt) + "\n  Published: " + to_string(_pp) + "\n  Draft: " + to_string(_pd)
            println(paper_stat)
        } catch e { // @allow-silent-catch
            println("> 논문 스캔 불가")
        }

        println("")
        println("## 4. DOI 현황")
        try {
            // hexa native — DOI 발행 통계
            let _doi_has = _papers_doi_count()
            let _doi_total = _papers_total()
            let mut _doi_out = "  DOI 발행: " + to_string(_doi_has) + "/" + to_string(_doi_total)
            // 미발행 제목 추출
            try {
                // 캐시 참조 — _papers_raw_cache
                let _doi_raw = _papers_raw_cache
                let _doi_blocks = _doi_raw.split("\"title\":")
                let mut _doi_miss: i64 = 0
                for _db in _doi_blocks {
                    if _doi_miss >= 10 { break }
                    if !_db.contains("\"doi\"") { continue }
                    let _dv = _db.split("\"doi\"")[1]
                    if !_dv.contains(":") { continue }
                    let _dvs = _dv.split(":")[1].trim()
                    // doi가 ""이거나 null이면 미발행
                    if _dvs.starts_with("\"\"") || _dvs.starts_with("null") {
                        let _dt = _db.trim().split("\"")[1]
                        _doi_out = _doi_out + "\n  미발행: " + _dt
                        _doi_miss = _doi_miss + 1
                    }
                }
            } catch e5 {} // @allow-silent-catch
            let doi_stat = _doi_out
            println(doi_stat)
        } catch e { // @allow-silent-catch
            println("> DOI 스캔 불가")
        }

        println("")
        println("## 5. 논문 도메인 분포")
        try {
            // hexa native — 도메인 분포 (캐시 참조, shell sort|uniq -c)
            let _dom_raw = _papers_raw_cache
            let _dom_parts = _dom_raw.split("\"domain\"")
            let mut _dom_list = ""
            for _dp in _dom_parts {
                if !_dp.contains(":") { continue }
                let _dv2 = _dp.split(":")[1].trim().split("\"")[1]
                if _dv2 != "" {
                    _dom_list = _dom_list + _dv2 + "\n"
                }
            }
            write_file("/tmp/_todo_dom.txt", _dom_list)
            let dom_stat = exec("sort /tmp/_todo_dom.txt | uniq -c | sort -rn | head -15 | awk '{cnt=$1; $1=\"\"; sub(/^ /,\"\"); printf \"  %s: %d편\\n\",$0,cnt}'") // @allow-bare-interp
            println(dom_stat)
        } catch e { // @allow-silent-catch
            println("> 도메인 분포 스캔 불가")
        }
    }

    // void 맞춤
    if project == "void" {
        println("")
        println("## 3. VOID 소스 통계")
        try {
            let hexa_count = exec("find " + _dev + "/void -name '*.hexa' 2>/dev/null | wc -l").trim()
            let js_count = exec("find " + _dev + "/void -name '*.js' -o -name '*.ts' 2>/dev/null | wc -l").trim()
            println("  .hexa 파일: " + hexa_count + "개")
            println("  .js/.ts 파일: " + js_count + "개")
        } catch e { // @allow-silent-catch
            println("> 소스 스캔 불가")
        }

        println("")
        println("## 4. VOID 플러그인")
        try {
            let plug_count = exec("ls " + _dev + "/void/plugins/ 2>/dev/null | wc -l").trim()
            println("  플러그인: " + plug_count + "개")
            let plug_list = exec("ls " + _dev + "/void/plugins/ 2>/dev/null")
            if plug_list.trim() != "" { println(plug_list) }
        } catch e { // @allow-silent-catch
            println("> 플러그인 스캔 불가")
        }

        println("")
        println("## 5. VOID lib 현황")
        try {
            let lib_files = exec("ls -la " + _dev + "/void/lib/ 2>/dev/null")
            println(lib_files)
        } catch e { // @allow-silent-catch
            println("> lib 스캔 불가")
        }
    }

    // airgenome 맞춤
    if project == "airgenome" {
        println("")
        println("## 3. AIRGENOME 소스 통계")
        try {
            let hexa_count = exec("find " + _dev + "/airgenome -name '*.hexa' 2>/dev/null | wc -l").trim()
            let rs_count = exec("find " + _dev + "/airgenome -name '*.rs' 2>/dev/null | wc -l").trim()
            println("  .hexa 파일: " + hexa_count + "개")
            println("  .rs 파일: " + rs_count + "개")
        } catch e { // @allow-silent-catch
            println("> 소스 스캔 불가")
        }

        println("")
        println("## 4. AIRGENOME 게놈 수집")
        try {
            let genome_count = exec("find " + _dev + "/airgenome -name '*.genome' -o -name '*.json' 2>/dev/null | wc -l").trim()
            println("  게놈/JSON 파일: " + genome_count + "개")
        } catch e { // @allow-silent-catch
            println("> 게놈 스캔 불가")
        }

        println("")
        println("## 5. AIRGENOME 의식 엔진 상태")
        try {
            // hexa native — consciousness_engine_status.json k:v 추출
            let _ce_raw2 = read_file(_dev + "/airgenome/consciousness_engine_status.json")
            let _ce_pairs2 = _ce_raw2.split("\"")
            let mut _ce_out2 = ""
            let mut _ci2: i64 = 0
            let mut _ck2 = ""
            for _cp2 in _ce_pairs2 {
                if _ci2 >= 20 { break }
                if _ci2 % 4 == 1 { _ck2 = _cp2 }
                if _ci2 % 4 == 3 {
                    _ce_out2 = _ce_out2 + "  " + _ck2 + ": " + _cp2 + "\n"
                }
                _ci2 = _ci2 + 1
            }
            let ce_stat = _ce_out2.trim()
            println(ce_stat)
        } catch e { // @allow-silent-catch
            println("> 의식 엔진 스캔 불가")
        }
    }

    // ─── 10) 아틀라스 등급 요약 ───
    println("")
    println("## 10. 아틀라스 등급 요약")
    try {
        let rm = exec("/usr/bin/awk 'match($0,/\\[([0-9]+)([*!?]*)\\]/,a){g=a[1]; if(a[2]~/\\*/) ex++; else if(g==\"10\") ex++; else if(g==\"9\") ne++; else if(g+0>=5) emp++; else if(a[2]~/\\?/) conj++; else mi++; n++} END{printf \"  항목: %d\\n  EXACT[10*]: %d (%.1f%%)\\n  NEAR[9]: %d\\n  EMPIRICAL[5-8]: %d\\n  CONJECTURE[?]: %d\\n  기타: %d\\n\", n, ex, ex/(n?n:1)*100, ne, emp, conj, mi}' " + _shared + "/n6/atlas.n6 2>/dev/null") // @allow-atlas-direct
        println(rm)
    } catch e { // @allow-silent-catch
        println("> atlas.n6 스캔 불가") // @allow-atlas-direct
    }

    // ─── 11) 발견 로그 통계 ───
    println("")
    println("## 11. 발견 로그 통계")
    try {
        let disc = to_string(_atlas_line_count)
        println("  발견: " + disc + "건")
        let graph = to_string(_atlas_edges)
        println("  그래프(atlas.n6): " + graph + "건")
    } catch e { // @allow-silent-catch
        println("> discovery 스캔 불가")
    }

    // ─── 12) 스캔 기반 자동 TODO 목록 ───
    println("")
    println("## 12. 스캔 기반 자동 TODO 목록")
    println("")
    println("| # | 카테고리 | 작업 | 수량 | 우선순위 |")
    println("|---|---------|------|------|---------|")

    let mut auto_id: i64 = 1

    if project == "n6-architecture" {
        // goal.md 부실
        try {
            let weak_count = to_string(_goal_weak_count(_goal_min))
            let wc = safe_int(weak_count)
            if wc > 0 {
                println("| " + to_string(auto_id) + " | goal.md 보강 | " + to_string(_goal_min) + "줄 미만 도메인 보강 | " + weak_count + "건 | 🔴 |")
                auto_id = auto_id + 1
            }
        } catch e {} // @allow-silent-catch

        // goal.md 미작성
        try {
            let miss_count = to_string(_goal_missing_count())
            let mc = safe_int(miss_count)
            if mc > 0 {
                println("| " + to_string(auto_id) + " | goal.md 생성 | 미작성 도메인 goal.md 생성 | " + miss_count + "건 | 🔴 |")
                auto_id = auto_id + 1
            }
        } catch e {} // @allow-silent-catch

        // DSE 미탐색
        try {
            let dse_miss = exec("comm -23 <(ls -1 " + _dev + "/n6-architecture/docs 2>/dev/null | while read d; do test -d " + _dev + "/n6-architecture/docs/\"$d\" && echo \"$d\"; done | sort) <(ls -1 " + _shared + "/dse/domains/*.toml 2>/dev/null | xargs -I{} basename {} .toml | sort) | wc -l").trim()
            let dm = safe_int(dse_miss)
            if dm > 0 {
                println("| " + to_string(auto_id) + " | DSE TOML | 미탐색 도메인 TOML 생성 | " + dse_miss + "건 | 🟡 |")
                auto_id = auto_id + 1
            }
        } catch e {} // @allow-silent-catch

        // 렌즈 미구현
        try {
            let lens_reg = to_string(_count_lens_status("registered"))
            let lr = safe_int(lens_reg)
            if lr > 0 {
                println("| " + to_string(auto_id) + " | 렌즈 구현 | registered → .rs implemented | " + lens_reg + "건 | 🟡 |")
                auto_id = auto_id + 1
            }
        } catch e {} // @allow-silent-catch

        // 외계인지수 승격
        try {
            let _ac_raw = _alien_items_below(_alien_target)
            let _ac_lines = _ac_raw.split("\n")
            let mut _ac_cnt: i64 = 0
            for _acl in _ac_lines { if _acl.trim() != "" { _ac_cnt = _ac_cnt + 1 } }
            let alien_count = to_string(_ac_cnt)
            let ac = safe_int(alien_count)
            if ac > 0 {
                println("| " + to_string(auto_id) + " | 승격 | 외계인지수 < 10 → 10 승격 | " + alien_count + "건 | 🟡 |")
                auto_id = auto_id + 1
            }
        } catch e {} // @allow-silent-catch
    }

    // 공통: atlas.n6 EMPIRICAL [7] 항목
    try {
        let emp_count = to_string(_atlas_emp7)
        let ec = _atlas_emp7
        if ec > 0 {
            println("| " + to_string(auto_id) + " | 아틀라스 | [7] → [10] 승격 | " + emp_count + "건 | 🟡 |")
            auto_id = auto_id + 1
        }
    } catch e {} // @allow-silent-catch

    // 공통: atlas.n6 가설(?) 항목
    try {
        let conj_count = to_string(_atlas_conj)
        let cc = _atlas_conj
        if cc > 0 {
            println("| " + to_string(auto_id) + " | 아틀라스 | 가설(?) 검증/해소 | " + conj_count + "건 | 🔴 |")
            auto_id = auto_id + 1
        }
    } catch e {} // @allow-silent-catch

    // 공통: 발견 로그 목표 (캐시 참조)
    try {
        let dc = _atlas_line_count
        let disc_count = to_string(dc)
        let next_disc = ((dc / _disc_step) + 1) * _disc_step
        if dc < next_disc {
            let remain = next_disc - dc
            println("| " + to_string(auto_id) + " | 발견 | " + to_string(next_disc / 1000) + "K 목표까지 | " + to_string(remain) + "건 | 🟢 |")
            auto_id = auto_id + 1
        }
    } catch e {} // @allow-silent-catch

    println("")
    println("> 자동 생성 TODO " + to_string(auto_id - 1) + "건 (스캔 결과 기반)")

    println("")
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    println("  🔥 대량 스캔 완료")
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

let _args = args()
let mut _filter = if _args.len() >= 3 { _args[2] } else { "" }
if _filter == "" || _filter == "all" {
    let cwd = exec("pwd").trim()
    let segs = cwd.split("/")
    _filter = segs[segs.len() - 1]
}
let _target = resolve_project(_filter)

if _target == "all" {
    println("❌ 프로젝트를 특정할 수 없습니다: " + _filter)
    println("사용법: hexa todo.hexa <nexus|anima|n6-arch|papers|hexa-lang|void|airgenome>")
} else {
    let mut _bt_todos = ""
    if _target == "nexus" {
        _bt_todos = load_breakthrough_todos()
    }
    println("## 할일 (돌파 엔진 통합)")
    print_project(_target, _bt_todos)
}

println("")
println("")
