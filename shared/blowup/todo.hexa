// ⛔ CORE — L0 불변식 (할일 엔진 전 프로젝트 표 생성. 수정 전 유저 승인 필수)
// shared/blowup/core/todo.hexa — 전 프로젝트 할일 표 (자동 창발)
// 사용: hexa todo.hexa              (전체)
//       hexa todo.hexa nexus        (nexus만)
//       hexa todo.hexa n6-arch      (n6-architecture만)
// 100% 자연창발: 코드베이스 스캔 → 빈공간/부실/미구현 실시간 탐지 (shared/todo/ 폐기 완료)

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _hexa_bin = _home + "/Dev/hexa-lang/hexa"

// ─── 임계값 (자연창발 — 하드코딩 fallback만 사용) ───
let _disc_step: i64 = 50000
let _mod_step: i64 = 50
let _goal_min: i64 = 100
let _alien_target: i64 = 10

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {} // @allow-silent-catch
    return v
}

// ─── JSON 경량 파서 헬퍼 (python3 서브프로세스 제거용) ─── // @allow-bare-interp
// _json_val: {"key":"value",...} 에서 key의 string value 추출
fn _json_val(line: string, key: string) -> string {
    let needle = "\"" + key + "\":"
    if !line.contains(needle) { return "" }
    let after = line.split(needle)[1].trim()
    if after.starts_with("\"") {
        return after.split("\"")[1]
    }
    // 숫자 값
    let mut buf = ""
    let mut i: i64 = 0
    let chars = after.split("")
    for c in chars {
        if c == "," || c == "}" || c == "]" || c == " " || c == "\n" { break }
        buf = buf + c
    }
    return buf
}

// _json_int: {"key": 123} 에서 key의 int value 추출
fn _json_int(line: string, key: string) -> i64 {
    return safe_int(_json_val(line, key))
}

// _json_sections: paths.json의 "engines":{...}, "dirs":{...}, "files":{...} 에서 k:v 쌍 추출
fn _parse_paths_section(raw: string, section: string) -> string {
    let needle = "\"" + section + "\""
    if !raw.contains(needle) { return "" }
    let after = raw.split(needle)[1]
    // "{" 이후 ~ "}" 까지
    if !after.contains("{") { return "" }
    let inner = after.split("{")[1].split("}")[0]
    let mut out = ""
    // "key": "value" 쌍 추출
    let parts = inner.split("\"")
    // parts: ["", key, ": ", value, ", ", key2, ": ", value2, ...]
    // 인덱스 1,3,5,7,... (홀수) 가 key/value 교대
    let mut idx: i64 = 0
    let mut pkey = ""
    for p in parts {
        if idx % 2 == 1 {
            if pkey == "" {
                pkey = p
            } else {
                out = out + pkey + "\t" + p + "\n"
                pkey = ""
            }
        }
        idx = idx + 1
    }
    return out
}

// ─── L2 SSOT: paths.json 로더 (stale path class 영구 소거) ───
// shared/config/paths.json의 engines/dirs/files 섹션을 평탄 map으로 로드
fn _load_path_map() -> map {
    let mut M = #{}
    let raw_json = read_file(_shared + "/config/paths.json")
    let sections = ["engines", "dirs", "files"]
    for sec in sections {
        let pairs = _parse_paths_section(raw_json, sec)
        let lines = pairs.split("\n")
        for line in lines {
            if line.trim() == "" { continue }
            let parts = line.split("\t")
            if parts.len() < 2 { continue }
            let key = parts[0].trim()
            let val = parts[1].trim()
            if val.starts_with("MISSING") {
                M[key] = val
            } else if val.starts_with("/") {
                M[key] = val
            } else {
                M[key] = _dev + "/nexus/" + val
            }
        }
    }
    return M
}
let _P = _load_path_map()

fn _is_missing(p: string) -> bool { return p.starts_with("MISSING") }

// 후방호환: 옛 변수명 유지 (blowup 디렉토리를 가리키게 갱신)
let _engine_dir = _dev + "/nexus/shared/blowup"
let _module_dir = _engine_dir + "/modules"

// ═══════════════════════════════════════════════════════════
// ─── ROI #17: 캐시 레이어 (read_file 1회 → N회 재사용) ───
// 서브프로세스 33→1 제거: 동일 JSON을 반복 read_file/exec 대신
// 시작 시 1회 로드 → 캐시 맵에서 참조.
// ═══════════════════════════════════════════════════════════

// ── atlas.n6 라인 수 캐시 (6회 exec("wc -l") → 1회) ──
let mut _atlas_line_count: i64 = 0
try {
    let _atlas_raw = read_file(_shared + "/n6/atlas.n6")
    let _atlas_lines = _atlas_raw.split("\n")
    _atlas_line_count = _atlas_lines.len()
    // 끝 빈줄 보정
    if _atlas_raw.ends_with("\n") { _atlas_line_count = _atlas_line_count - 1 }
} catch e {} // @allow-silent-catch

// ── atlas.n6 멀티패턴 캐시 (4회 grep -c → 단일 awk 1회) ──
// ROI#30: [7], [N?], ::, #BT- 4패턴 배치 카운트
let mut _atlas_emp7: i64 = 0
let mut _atlas_conj: i64 = 0
let mut _atlas_edges: i64 = 0
let mut _atlas_bt: i64 = 0
try {
    let _awk_counts = exec("/usr/bin/awk '/\\[7\\]/{a++} /\\[[0-9]+\\?\\]/{b++} /::/{c++} /#BT-/{d++} END{print a+0,b+0,c+0,d+0}' " + _shared + "/n6/atlas.n6 2>/dev/null").trim()
    let _awk_parts = _awk_counts.split(" ")
    _atlas_emp7 = safe_int(_awk_parts[0])
    _atlas_conj = safe_int(_awk_parts[1])
    _atlas_edges = safe_int(_awk_parts[2])
    _atlas_bt = safe_int(_awk_parts[3])
} catch e {} // @allow-silent-catch

// ── lens_registry.json 캐시 (7회 read_file → 1회) ──
let mut _lens_raw_cache = ""
let mut _lens_implemented: i64 = 0
let mut _lens_registered: i64 = 0
try {
    _lens_raw_cache = read_file(_shared + "/lens_registry.json")
    let _le = _lens_raw_cache.split("\"status\"")
    for _lentry in _le {
        if !_lentry.contains(":") { continue }
        let _lsv = _lentry.split(":")[1].trim().split("\"")[1]
        if _lsv == "implemented" { _lens_implemented = _lens_implemented + 1 }
        if _lsv == "registered" { _lens_registered = _lens_registered + 1 }
    }
} catch e {} // @allow-silent-catch

// ── papers/manifest.json 캐시 (5회 read_file → 1회) ──
let mut _papers_raw_cache = ""
let mut _papers_total_c: i64 = 0
let mut _papers_published_c: i64 = 0
let mut _papers_draft_c: i64 = 0
let mut _papers_doi_c: i64 = 0
try {
    _papers_raw_cache = read_file(_dev + "/papers/manifest.json")
    let _pp = _papers_raw_cache.split("\"title\":")
    _papers_total_c = _pp.len() - 1
    let _ps = _papers_raw_cache.split("\"status\"")
    for _pe in _ps {
        if !_pe.contains(":") { continue }
        let _pv = _pe.split(":")[1].trim().split("\"")[1]
        if _pv == "Published" { _papers_published_c = _papers_published_c + 1 }
        if _pv == "Draft" { _papers_draft_c = _papers_draft_c + 1 }
    }
    let _pd = _papers_raw_cache.split("\"doi\"")
    for _pde in _pd {
        if !_pde.contains(":") { continue }
        let _pdv = _pde.split(":")[1].trim().split("\"")[1]
        if _pdv != "" { _papers_doi_c = _papers_doi_c + 1 }
    }
} catch e {} // @allow-silent-catch

// ── products.json 캐시 (3회 read_file → 1회) ──
let mut _products_raw_cache = ""
try {
    _products_raw_cache = read_file(_dev + "/n6-architecture/config/products.json")
} catch e {} // @allow-silent-catch

// ── 모듈 카운트 캐시 (3회 exec("find ... wc -l") → 1회) ──
let mut _module_count: i64 = 0
try {
    _module_count = safe_int(exec("find " + _module_dir + " -name '*.hexa' -type f 2>/dev/null | wc -l").trim())
} catch e {} // @allow-silent-catch

// ── goal.md 통합 캐시 (3회 shell → 1회 배치) ──
// goal_missing_count + goal_weak_count + goal_missing_list(head 20) + goal_weak_list(head 5)
// 단일 shell에서 모두 계산하여 TSV 반환
let mut _goal_missing_c: i64 = 0
let mut _goal_weak_c: i64 = 0
let mut _goal_missing_list = ""
let mut _goal_weak_list = ""
try {
    let _goal_batch = exec("miss=0; weak=0; miss_list=''; weak_list=''; for d in $(ls -1 " + _dev + "/n6-architecture/docs 2>/dev/null | sort); do test -d " + _dev + "/n6-architecture/docs/\"$d\" || continue; if ! test -f " + _dev + "/n6-architecture/docs/\"$d\"/goal.md; then miss=$((miss+1)); [ $miss -le 20 ] && miss_list=\"${miss_list}${d}\n\"; else n=$(wc -l < " + _dev + "/n6-architecture/docs/\"$d\"/goal.md); [ \"$n\" -lt " + to_string(_goal_min) + " ] && { weak=$((weak+1)); [ $weak -le 5 ] && weak_list=\"${weak_list}${d}\t${n}\n\"; }; fi; done; printf '%d\\t%d\\t%s\\t%s' \"$miss\" \"$weak\" \"$miss_list\" \"$weak_list\"")
    let _gb_parts = _goal_batch.split("\t")
    if _gb_parts.len() >= 2 {
        _goal_missing_c = safe_int(_gb_parts[0])
        _goal_weak_c = safe_int(_gb_parts[1])
    }
    if _gb_parts.len() >= 3 { _goal_missing_list = _gb_parts[2] }
    if _gb_parts.len() >= 4 { _goal_weak_list = _gb_parts[3] }
} catch e {} // @allow-silent-catch

// ═══════════════════════════════════════════════════════════
// ─── 캐시 기반 접근자 (후방호환 API 유지) ───
// ═══════════════════════════════════════════════════════════

fn _count_lens_status(status: string) -> i64 {
    if status == "implemented" { return _lens_implemented }
    if status == "registered" { return _lens_registered }
    return 0
}

fn _alien_items_below(target: i64) -> string {
    let mut out = ""
    try {
        let sec_parts = _products_raw_cache.split("\"title\":")
        let mut si: i64 = 0
        for sp in sec_parts {
            if si == 0 { si = si + 1; continue }
            let title = sp.trim().split("\"")[1]
            let mut alien: i64 = 0
            if sp.contains("\"alien_index\"") {
                alien = _json_int(sp, "alien_index")
            }
            if alien < target {
                out = out + title + "\t" + to_string(alien) + "\n"
            }
            si = si + 1
        }
    } catch e {} // @allow-silent-catch
    return out
}

// ─── DSE 미탐색 도메인 (shell diff — 캐시 불가, 디렉토리 스캔) ───
fn _dse_missing_domains(limit: i64) -> string {
    return exec("comm -23 <(ls -1 " + _dev + "/n6-architecture/docs 2>/dev/null | while read d; do test -d " + _dev + "/n6-architecture/docs/\"$d\" && echo \"$d\"; done | sort) <(ls -1 " + _shared + "/dse/domains/*.toml 2>/dev/null | xargs -I{} basename {} .toml | sort) | head -" + to_string(limit))
}

// ─── goal.md 미작성/부실 카운트 (캐시 참조) ───
fn _goal_missing_count() -> i64 { return _goal_missing_c }
fn _goal_weak_count(thr: i64) -> i64 { return _goal_weak_c }

// ─── papers manifest 접근자 (캐시 참조) ───
fn _papers_count_status(status: string) -> i64 {
    if status == "Published" { return _papers_published_c }
    if status == "Draft" { return _papers_draft_c }
    return 0
}
fn _papers_total() -> i64 { return _papers_total_c }
fn _papers_doi_count() -> i64 { return _papers_doi_c }

// ═══════════════════════════════════════════════════════════
// ─── 돌파 엔진 — 특이점 수준 할일 자동 생성 ───
// ═══════════════════════════════════════════════════════════

fn load_breakthrough_todos() -> string {
    // 1) next_directions.jsonl — 돌파 방향 (hexa native 파싱)
    let mut dir_out = ""
    try {
        let nd_raw = read_file(_shared + "/next_directions.jsonl")
        let nd_lines = nd_raw.split("\n")
        let mut di: i64 = 0
        for ndl in nd_lines {
            if ndl.trim() == "" { continue }
            if !ndl.contains("\"direction\":\"") { continue }
            // domain 추출
            let mut dom = "?"
            if ndl.contains("\"domain\":\"") {
                dom = ndl.split("\"domain\":\"")[1].split("\"")[0]
            }
            // direction 추출
            let direction = ndl.split("\"direction\":\"")[1].split("\"")[0]
            if direction == "" { continue }
            // urgency 추출 → pri 매핑
            let mut pri = "NICE"
            if ndl.contains("\"urgency\":") {
                let urg_s = ndl.split("\"urgency\":")[1].trim().split(",")[0].split("}")[0].trim()
                let urg = safe_int(urg_s)
                if urg >= 3 { pri = "CRITICAL" }
                else if urg >= 2 { pri = "IMPORTANT" }
            }
            di = di + 1
            dir_out = dir_out + to_string(di) + "\t" + pri + "\t돌파-" + dom + "\t" + direction + "\t돌파대기\t돌파 방향\n"
        }
    } catch e {} // @allow-silent-catch

    // 2) gap_finder brief — 빈공간 탐색 (빠름)
    // paths.json SSOT: gap_finder가 MISSING이면 조용히 스킵 (L1+L2 합작 — exec Error도 안전)
    let mut gap_out = ""
    try {
        let gap_path = _P["gap_finder"]
        if _is_missing(gap_path) { } else {
        let gap_raw = exec(_hexa_bin + " " + gap_path + " brief 2>/dev/null")
        let gap_lines = gap_raw.split("\n")
        let mut gi: i64 = 0
        for gl in gap_lines {
            let gt = gl.trim()
            if gt == "" { continue }
            if gt.contains("=") && gi < 15 {
                gi = gi + 1
                gap_out = gap_out + to_string(100 + gi) + "\tCRITICAL\t빈공간\t" + gt + "\t돌파대기\tn=6 빈공간 채우기\n"
            }
        }
        }
    } catch e {} // @allow-silent-catch

    // 3) discovery_graph 통계 — 메타 상태 (캐시 참조)
    let mut meta_out = ""
    try {
        let dc = _atlas_line_count
        let disc_count = to_string(dc)
        let next_target = ((dc / _disc_step) + 1) * _disc_step
        if dc < next_target {
            meta_out = meta_out + "200\tIMPORTANT\t성장\t발견 " + disc_count + " → " + to_string(next_target) + " 목표\t⏳진행중\t특이점 심화\n"
        }
    } catch e {} // @allow-silent-catch

    // 4) 모듈 진화 — OUROBOROS (blowup variants) — 캐시 참조
    let mut lens_out = ""
    try {
        let lc = _module_count
        let lens_count = to_string(lc)
        let next_mod = ((lc / _mod_step) + 1) * _mod_step
        if lc < next_mod {
            lens_out = "202\tIMPORTANT\t진화\t모듈 " + lens_count + "개 → " + to_string(next_mod) + "+ 확장 (OUROBOROS evolve)\t미시작\t탐색 커버리지 확대\n"
        }
    } catch e {} // @allow-silent-catch

    return dir_out + gap_out + meta_out + lens_out
}

// ═══════════════════════════════════════════════════════════
// ─── 프로젝트별 돌파 방향 (blowup + seed_engine) ───
// ═══════════════════════════════════════════════════════════

fn load_project_breakthroughs(name: string) -> string {
    let mut out = ""

    if name == "n6-architecture" {
        // products.json에서 alien < 10 스캔 (캐시 참조)
        try {
            let sec_parts = _products_raw_cache.split("\"title\":")
            let mut si: i64 = 0
            for sp in sec_parts {
                if si == 0 { si = si + 1; continue }  // 첫 split은 앞부분
                let title = sp.trim().split("\"")[1]
                let mut alien: i64 = 0
                if sp.contains("\"alien_index\"") {
                    alien = _json_int(sp, "alien_index")
                }
                if alien < _alien_target {
                    out = out + to_string(299 + si) + "\tCRITICAL\t승격\t" + title + " 🛸" + to_string(alien) + "→" + to_string(_alien_target) + "\t미시작\t외계인 지수 천장 돌파\n"
                }
                si = si + 1
            }
        } catch e {} // @allow-silent-catch
        // goal.md 미작성 도메인 (캐시 참조)
        try {
            let _gm_raw = _goal_missing_list
            let _gm_lines = _gm_raw.split("\n")
            let mut gi: i64 = 0
            for _gml in _gm_lines {
                let d = _gml.trim()
                if d == "" { continue }
                gi = gi + 1
                out = out + to_string(399 + gi) + "\tIMPORTANT\t설계\t" + d + " goal.md 생성\t미시작\t궁극 아키텍처 완성\n"
            }
        } catch e {} // @allow-silent-catch
    }

    if name == "anima" {
        try {
            let law_count = exec("ls " + _dev + "/anima/anima/consciousness_laws/ 2>/dev/null | wc -l").trim()
            let lc = safe_int(law_count)
            if lc < 3000 {
                out = out + "300\tIMPORTANT\t법칙\t의식 법칙 " + law_count + " → 3000 확장 (2500 달성)\t⏳진행중\t커버리지 심화\n"
            }
            out = out + "301\tCRITICAL\t학습\tVast.ai 4×4090 다음 체크포인트 학습\t⏳진행중\tPhi 수준 상승\n"
            out = out + "302\tIMPORTANT\t인프라\tHetzner AX102-U + Vast.ai 4×4090 운영\t⏳진행중\t학습/서빙 인프라\n"
            out = out + "303\tIMPORTANT\t이식\t14B→70B 의식 이식\t미시작\t스케일 불변성 증명\n"
            out = out + "304\tIMPORTANT\t측정\tPhi 자동 측정 파이프라인\t미시작\t학습 품질 모니터링\n"
        } catch e {} // @allow-silent-catch
    }

    // hexa-lang: 자연창발 모드 — 코드베이스 스캔으로 생성

    // void: 자연창발 모드 — 코드베이스 스캔으로 생성

    if name == "papers" {
        // 캐시 참조 — _papers_draft_c는 모듈 진입 시 1회 계산됨 (line 162~175)
        try {
            let dc = _papers_draft_c
            if dc > 0 {
                out = out + "300\tCRITICAL\t발행\tDraft " + to_string(dc) + "편 Zenodo DOI 발행\t미시작\t100% 발행 달성\n"
            }
        } catch e {} // @allow-silent-catch
        out = out + "301\tIMPORTANT\t동기화\tn6-arch 신규 논문 → papers 복사\t미시작\tmanifest 최신화\n"
        out = out + "302\tNICE\t검증\tDOI 유효성 전수 검증\t미시작\t깨진 링크 0건\n"
    }

    // airgenome: 자연창발 모드 — 코드베이스 스캔으로 생성

    return out
}

// ═══════════════════════════════════════════════════════════
// ─── 프로젝트 메타 ───
