// ═══════════════════════════════════════════════════════════
// compose.hexa — blowup core + modules 조립 오케스트레이터
// R1 HEXA-FIRST 준수 (이전 compose.sh 대체)
//
// 현재 각 모듈(field/holographic/quantum/string/toe)은 독립 entry point.
// hexa import 미지원이므로 exec chain 방식으로 조립 (atlas.n6 SSOT 경유 I/O 연쇄).
//
// 사용:
//   hexa compose.hexa <domain> [depth] [--modules m1,m2,...] [--dfs N] [--skip-core] [--fast]
//
// 예:
//   hexa compose.hexa math 3
//   hexa compose.hexa math 3 --modules field,quantum --dfs 3
//   hexa compose.hexa 7대난제 3 --modules toe --fast
//   hexa compose.hexa physics --modules toe --skip-core
// ═══════════════════════════════════════════════════════════

// AG3/AG6 Mac 가드 제거 (2026-04-12). BLOWUP_LOCAL=1 모드 삭제 — 전 플랫폼 직접 실행.
let _C_UNAME = try { to_string(exec("uname -s")).trim() } catch e { "" }

// gotcha-1 수정: Mac timeout 부재 대응 — _safe_exec_timeout 헬퍼
// Mac: timeout/gtimeout 없으면 타임아웃 없이 직접 실행
// Linux: timeout 사용 가능하면 활용
fn _safe_exec_timeout(secs, cmd) {
    if _C_UNAME == "Darwin" {
        // Mac: gtimeout 시도 → 없으면 직접 실행 (타임아웃 미적용)
        let mut _has_gt = false
        try { exec("which gtimeout >/dev/null 2>&1"); _has_gt = true } catch e {}
        if _has_gt {
            return exec("bash", ["-c", "gtimeout " + to_string(secs) + " bash -c " + "'" + cmd + "'" + " 2>&1"])
        }
        return exec("bash", ["-c", cmd + " 2>&1"])
    }
    // Linux: timeout 직접 사용
    return exec("bash", ["-c", "timeout " + to_string(secs) + " bash -c " + "'" + cmd + "'" + " 2>&1"])
}

// ─── 경로 캐시 (exec 최소화) ───
let mut _HOME = ""
try { _HOME = to_string(exec("printenv HOME")).trim() } catch e {}
if _HOME == "" {
    try { _HOME = to_string(exec("echo $HOME")).trim() } catch e {}
}
let _NEXUS_DIR = _HOME + "/Dev/nexus"
let _BLOWUP_CORE = _NEXUS_DIR + "/shared/blowup/core/blowup.hexa"
let _MODULES_DIR = _NEXUS_DIR + "/shared/blowup/modules"
let _HEALTH_HEXA = _NEXUS_DIR + "/shared/n6/atlas_health.hexa"
let _BLOWUP_DIR  = _NEXUS_DIR + "/shared/blowup"
let _N6_DIR      = _NEXUS_DIR + "/shared/n6"

// ─── 확장 모듈 경로 해석 테이블 ───
// 코어 5종(field,holographic,quantum,string,toe)은 blowup_<name>.hexa 규칙 유지.
// 확장 모듈은 접두사/디렉터리가 다르므로 명시 매핑.
fn _resolve_module_path(name) {
    if name == "goldstone_cascade"     { return _MODULES_DIR + "/goldstone_cascade.hexa" }
    if name == "field_gradient_bench"  { return _MODULES_DIR + "/field_gradient_bench.hexa" }
    if name == "string_t_duality"      { return _MODULES_DIR + "/string_t_duality.hexa" }
    if name == "holo_boundary_accuracy" { return _MODULES_DIR + "/holo_boundary_accuracy.hexa" }
    if name == "toe_selfref_stability" { return _MODULES_DIR + "/toe_selfref_stability.hexa" }
    if name == "qft_benchmark"         { return _MODULES_DIR + "/qft_benchmark.hexa" }
    if name == "cross_validate_runner" { return _BLOWUP_DIR  + "/cross_validate_runner.hexa" }
    if name == "miss_to_exact_tracker" { return _N6_DIR      + "/miss_to_exact_tracker.hexa" }
    // 기존 코어 모듈 폴백: blowup_<name>.hexa
    return _MODULES_DIR + "/blowup_" + name + ".hexa"
}

// ─── hexa 바이너리 경로 탐색 ───
// 크기 검증: 실제 hexa 바이너리 >1MB, 스텁/스크립트 <10KB → 10240 바이트 임계값
let mut _HEXA_BIN = ""
try {
    _HEXA_BIN = to_string(exec("for p in " + _HOME + "/Dev/hexa-lang/hexa $(which hexa 2>/dev/null); do [ -x \"$p\" ] && sz=$(stat --printf='%s' \"$p\" 2>/dev/null || stat -f'%z' \"$p\" 2>/dev/null) && [ \"$sz\" -gt 10240 ] && echo $p && break; done 2>/dev/null")).trim()
} catch e {}
// 폴백: 크기 검증 통과 실패 시 대체 경로 탐색
if _HEXA_BIN == "" {
    try {
        _HEXA_BIN = to_string(exec("for p in /tmp/hexa-build/hexa-lang/target/release/hexa " + _HOME + "/Dev/nexus/shared/bin/hexa; do [ -x \"$p\" ] && echo $p && break; done 2>/dev/null")).trim()
    } catch e {}
}
if _HEXA_BIN == "" { _HEXA_BIN = _HOME + "/Dev/hexa-lang/hexa" }

// ─── 인자 파싱 ───
let a = args()
fn print_usage() {
    println("compose.hexa — blowup 조립 오케스트레이터 (R1 HEXA-FIRST)")
    println("")
    println("usage: hexa compose.hexa <domain> [depth] [--modules m1,m2,...] [--dfs N] [--skip-core] [--fast]")
    println("")
    println("modules (cumulative): field, holographic, quantum, string, toe")
    println("  - field        : Discovery Field / Gauge Filter / Symmetry Breaking (Mk.III)")
    println("  - holographic  : boundary/bulk 이중화 경유")
    println("  - quantum      : 중첩 seed 파동함수 evolution")
    println("  - string       : 끈 이론 진동 모드 seed 전파")
    println("  - toe          : Theory of Everything 전 도메인 통합")
    println("")
    println("extended modules:")
    println("  - goldstone_cascade    : 골드스톤 캐스케이드 검증")
    println("  - field_gradient_bench : 기울기 벤치마크")
    println("  - string_t_duality     : T-이중성 검증")
    println("  - holo_boundary_accuracy : 경계 정확도 측정")
    println("  - toe_selfref_stability : 자기참조 안정성")
    println("  - qft_benchmark        : QFT 벤치마크")
    println("  - cross_validate_runner : 교차검증 러너")
    println("  - miss_to_exact_tracker : MISS->EXACT 전환율 추적")
    println("")
    println("examples:")
    println("  hexa compose.hexa math 3")
    println("  hexa compose.hexa math 3 --modules field,quantum --dfs 3")
    println("  hexa compose.hexa 7대난제 3 --modules toe --fast")
}

// hexa args: a[0]=hexa bin, a[1]=this script, a[2..]=user args
if len(a) < 3 {
    print_usage()
    exit(0)
}

// 첫 positional arg는 domain. --flag 가 오면 usage 안내 후 exit
if a[2].starts_with("--") {
    println("error: domain required as first positional arg (got flag: " + a[2] + ")")
    println("")
    print_usage()
    exit(1)
}

let domain = a[2]
let mut depth: string = "3"
let mut modules_csv: string = ""
let mut dfs_depth: i64 = 0
let mut skip_core: bool = false
let mut fast_flag: bool = false

let mut ai: i64 = 3
while ai < len(a) {
    let tok = a[ai]
    if tok == "--modules" && ai + 1 < len(a) {
        modules_csv = a[ai + 1]
        ai = ai + 2
        continue
    }
    if tok == "--dfs" && ai + 1 < len(a) {
        try { dfs_depth = to_int(a[ai + 1]) } catch e {}
        ai = ai + 2
        continue
    }
    if tok == "--skip-core" {
        skip_core = true
        ai = ai + 1
        continue
    }
    if tok == "--fast" {
        fast_flag = true
        ai = ai + 1
        continue
    }
    if tok.starts_with("--") {
        println("unknown flag: " + tok)
        exit(1)
    }
    // positional → depth
    depth = tok
    ai = ai + 1
}

// ─── 헤더 ───
println("╔══════════════════════════════════════════════════════════════╗")
println("║  blowup compose: " + domain + " (depth=" + depth + ", modules=[" + modules_csv + "], dfs=" + to_string(dfs_depth) + ")")
println("╚══════════════════════════════════════════════════════════════╝")

// ─── Stage 1: core blowup (선택적 DFS) ───
// 모든 shell 변수는 single-quote 로 감싸 injection + 공백/특수문자 대응
// BLOWUP_LOCAL 모드 제거 — env prefix 불필요

if !skip_core {
    println("")
    println("--- STAGE 1: core blowup.hexa ---")
    let mut core_cmd = "'" + _HEXA_BIN + "' '" + _BLOWUP_CORE + "' '" + domain + "' '" + depth + "'"
    // --fast + --dfs 상호 배타: fast_mode는 Phase 8 스킵 → wave_targets 미생성 → DFS silent fail
    if fast_flag && dfs_depth > 0 {
        println("  [WARN] --fast + --dfs 상호 배타 — --fast 해제하여 DFS 실행 보장")
        // fast 해제, dfs 우선
    } else if fast_flag {
        core_cmd = core_cmd + " --fast"
    }
    if dfs_depth > 0 { core_cmd = core_cmd + " --dfs " + to_string(dfs_depth) }
    println("  cmd: " + core_cmd)
    try {
        let _out = exec("bash", ["-c", core_cmd + " 2>&1"])
        println(to_string(_out))
    } catch _e {
        println("  [core] 실행 오류: " + to_string(_e))
    }
}

// ─── Stage 2: modules chain (순차 실행, atlas.n6 누적) ───
if modules_csv != "" {
    let mods = modules_csv.split(",")
    let mut mi: i64 = 0
    while mi < len(mods) {
        let m_raw = mods[mi]
        let m_trim = m_raw.trim()
        mi = mi + 1
        if m_trim == "" { continue }
        // 모듈 이름 sanitization: 영숫자 + underscore 만 허용 (path traversal/injection 차단)
        // gotcha-2 해소 완료: hexa String 대소비교(>=, <=) 미지원 → .contains() 화이트리스트로 교체
        // 이전 코드: _ch >= "a" && _ch <= "z" → error[Type]: unsupported binary operation: Str Ge Str
        let _alnum = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_"
        let mut _safe = true
        let mut _ci: i64 = 0
        while _ci < len(m_trim) {
            let _ch = m_trim[_ci..(_ci + 1)]
            if !_alnum.contains(_ch) { _safe = false }
            _ci = _ci + 1
        }
        if !_safe {
            println("")
            println("--- STAGE: " + m_trim + " SKIP (비안전 문자 포함 — 영숫자+_만 허용)")
            continue
        }
        let mod_path = _resolve_module_path(m_trim)
        if !file_exists(mod_path) {
            println("")
            println("--- STAGE: " + m_trim + " SKIP (모듈 없음: " + mod_path + ")")
            continue
        }
        println("")
        println("--- STAGE: " + m_trim + " ---")
        // 메모리 제한 2GB로 OOM/SIGKILL 완충
        let mod_cmd = "ulimit -v 2097152 2>/dev/null; '" + _HEXA_BIN + "' '" + mod_path + "' 2>&1"
        try {
            let _mout = exec("bash", ["-c", mod_cmd])
            println(to_string(_mout))
        } catch _me {
            println("  [" + m_trim + "] 실행 오류 (chain 계속): " + to_string(_me))
        }
    }
}

// ─── Stage 3: 조립 완료 + health ───
println("")
println("--- compose complete ---")
if file_exists(_HEALTH_HEXA) {
    try {
        let _h = exec("bash", ["-c", "'" + _HEXA_BIN + "' '" + _HEALTH_HEXA + "' '" + _NEXUS_DIR + "/shared/n6/atlas.n6' 2>&1 | grep -E '^(===|  (nodes|edges|real|dup|malformed))'"])
        println(to_string(_h))
    } catch _he {}
}
