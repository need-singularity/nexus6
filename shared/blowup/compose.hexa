// ═══════════════════════════════════════════════════════════
// @no-lock-needed
// compose.hexa — blowup core + modules 조립 오케스트레이터
// R1 HEXA-FIRST 준수 (이전 compose.sh 대체)
//
// 현재 각 모듈(field/holographic/quantum/string/toe/absolute/meta_closure/hyperarithmetic)은 독립 entry point.
// Mk.VIII (2026-04-19): absolute 모듈 추가 — Δ₀-absolute Π₀¹ 검증 엔진, n=6 6개 core 완성.
// Mk.IX (2026-04-19): core8 = 6-core + meta_closure + hyperarithmetic (Phase 10 Π₀² 준비).
// hexa import 미지원이므로 exec chain 방식으로 조립 (atlas.n6 SSOT 경유 I/O 연쇄).
//
// 사용:
//   hexa compose.hexa <domain> [depth] [--modules m1,m2,...] [--dfs N] [--skip-core] [--fast]
//
// 예:
//   hexa compose.hexa math 3
//   hexa compose.hexa math 3 --modules field,quantum --dfs 3
//   hexa compose.hexa 7대난제 3 --modules toe --fast
//   hexa compose.hexa physics --modules toe --skip-core
// ═══════════════════════════════════════════════════════════

// AG3/AG6 Mac 가드 제거 (2026-04-12). BLOWUP_LOCAL=1 모드 삭제 — 전 플랫폼 직접 실행.
let mut _C_UNAME = ""
try { _C_UNAME = to_string(exec("uname -s")).trim() } catch e {}  // @allow-silent-catch

// gotcha-1 수정: Mac timeout 부재 대응 — _safe_exec_timeout 헬퍼
// Mac: timeout/gtimeout 없으면 타임아웃 없이 직접 실행
// Linux: timeout 사용 가능하면 활용
fn _safe_exec_timeout(secs, cmd) {
    if _C_UNAME == "Darwin" {
        // Mac: gtimeout 시도 → 없으면 직접 실행 (타임아웃 미적용)
        let mut _has_gt = false
        try { let _gt = exec("which gtimeout 2>/dev/null").trim() ; if _gt != "" && _gt.contains("gtimeout") { _has_gt = true } } catch e {}  // @allow-silent-catch
        if _has_gt {
            return exec("bash", ["-c", "gtimeout " + to_string(secs) + " bash -c " + "'" + cmd + "'" + " 2>&1"])
        }
        return exec("bash", ["-c", cmd + " 2>&1"])
    }
    // Linux: timeout 직접 사용
    return exec("bash", ["-c", "timeout " + to_string(secs) + " bash -c " + "'" + cmd + "'" + " 2>&1"])
}

// ─── 경로 캐시 (exec 최소화) ───
let mut _HOME = ""
try { _HOME = to_string(exec("printenv HOME")).trim() } catch e {}  // @allow-silent-catch
if _HOME == "" {
    try { _HOME = to_string(exec("echo $HOME")).trim() } catch e {}  // @allow-silent-catch
}
let _NEXUS_DIR = _HOME + "/Dev/nexus"
let _BLOWUP_CORE = _NEXUS_DIR + "/shared/blowup/core/blowup.hexa"
let _MODULES_DIR = _NEXUS_DIR + "/shared/blowup/modules"
let _HEALTH_HEXA = _NEXUS_DIR + "/shared/n6/atlas_health.hexa"
let _BLOWUP_DIR  = _NEXUS_DIR + "/shared/blowup"
let _N6_DIR      = _NEXUS_DIR + "/shared/n6"
let _ATLAS_N6    = _NEXUS_DIR + "/shared/n6/atlas.n6"

// ─── ai-native JSON emit helpers (stderr typed death signals) ───
// NEXUS_ENGINE_{DEAD,ERROR,WARN} — engine 내부 silent-fail 차단용.
// 외부 preflight 스크립트 대신 engine 진입부/에러 지점/의심 경로에서 직접 emit.
fn _ce_json_esc(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", " ")
    r = r.replace("\r", " ")
    r = r.replace("\t", " ")
    return r
}

// 간이 seed_hash (문자열 길이 + 앞 16자 prefix — 식별 추적용. 외부 해시 빌트인 비가용 환경 방어).
fn _ce_seed_hash(seed: string) -> string {
    let n = len(seed)
    let mut head: string = ""
    if n >= 16 {
        head = seed[0..16]
    } else {
        head = seed
    }
    return "l" + to_string(n) + "_" + _ce_json_esc(head)
}

fn emit_engine_dead(engine_name: string, missing_path: string, stage: string, hint: string) {
    eprintln("NEXUS_ENGINE_DEAD {\"engine\":\"" + _ce_json_esc(engine_name)
        + "\",\"missing\":\"" + _ce_json_esc(missing_path)
        + "\",\"stage\":\"" + _ce_json_esc(stage)
        + "\",\"recovery_hint\":\"" + _ce_json_esc(hint) + "\"}")
}

fn emit_engine_error(engine_name: string, phase: string, code: string, msg: string,
                     recoverable: bool, seed_hash: string) {
    let mut rec = "false"
    if recoverable { rec = "true" }
    eprintln("NEXUS_ENGINE_ERROR {\"engine\":\"" + _ce_json_esc(engine_name)
        + "\",\"phase\":\"" + _ce_json_esc(phase)
        + "\",\"code\":\"" + _ce_json_esc(code)
        + "\",\"msg\":\"" + _ce_json_esc(msg)
        + "\",\"recoverable\":" + rec
        + ",\"seed_hash\":\"" + _ce_json_esc(seed_hash) + "\"}")
}

fn emit_engine_warn(engine_name: string, reason: string, detail: string, seed_hash: string) {
    eprintln("NEXUS_ENGINE_WARN {\"engine\":\"" + _ce_json_esc(engine_name)
        + "\",\"reason\":\"" + _ce_json_esc(reason)
        + "\",\"detail\":\"" + _ce_json_esc(detail)
        + "\",\"seed_hash\":\"" + _ce_json_esc(seed_hash) + "\"}")
}

// ─── F1: engine self-check (compose 진입부) ───
// atlas.n6 read 가능 + core blowup.hexa 존재 — 둘 중 하나라도 없으면 DEAD emit 후 exit(1).
// 정상 경로는 빠르게 통과. file_exists 는 순수 경로 체크, IO 부하 수 μs.
let mut _compose_selfcheck_ok = true
if !file_exists(_ATLAS_N6) {
    emit_engine_dead("compose", _ATLAS_N6, "init",
        "run scan_math_atlas or restore shared/n6/atlas.n6 from backup")
    _compose_selfcheck_ok = false
}
if _compose_selfcheck_ok && !file_exists(_BLOWUP_CORE) {
    emit_engine_dead("compose", _BLOWUP_CORE, "init",
        "verify shared/blowup/core/blowup.hexa exists — may have been moved/deleted")
    _compose_selfcheck_ok = false
}
if !_compose_selfcheck_ok { exit(1) }  // @allow-silent-exit

// ─── 확장 모듈 경로 해석 테이블 ───
// 코어 6종(field,holographic,quantum,string,toe,absolute)은 blowup_<name>.hexa 규칙 유지.
// 확장 모듈은 접두사/디렉터리가 다르므로 명시 매핑.
fn _resolve_module_path(name) {
    if name == "goldstone_cascade"     { return _MODULES_DIR + "/goldstone_cascade.hexa" }
    if name == "field_gradient_bench"  { return _MODULES_DIR + "/field_gradient_bench.hexa" }
    if name == "string_t_duality"      { return _MODULES_DIR + "/string_t_duality.hexa" }
    if name == "holo_boundary_accuracy" { return _MODULES_DIR + "/holo_boundary_accuracy.hexa" }
    if name == "toe_selfref_stability" { return _MODULES_DIR + "/toe_selfref_stability.hexa" }
    if name == "qft_benchmark"         { return _MODULES_DIR + "/qft_benchmark.hexa" }
    if name == "cross_validate_runner" { return _BLOWUP_DIR  + "/cross_validate_runner.hexa" }
    if name == "miss_to_exact_tracker" { return _N6_DIR      + "/miss_to_exact_tracker.hexa" }
    // 기존 코어 모듈 폴백: blowup_<name>.hexa
    return _MODULES_DIR + "/blowup_" + name + ".hexa"
}

// ─── hexa 바이너리 경로 탐색 ───
// 크기 검증: 실제 hexa 바이너리 >1MB, 스텁/스크립트 <10KB → 10240 바이트 임계값
let mut _HEXA_BIN = ""
try {
    _HEXA_BIN = to_string(exec("for p in " + _HOME + "/Dev/hexa-lang/hexa $(which hexa 2>/dev/null); do [ -x \"$p\" ] && sz=$(stat --printf='%s' \"$p\" 2>/dev/null || stat -f'%z' \"$p\" 2>/dev/null) && [ \"$sz\" -gt 10240 ] && echo $p && break; done 2>/dev/null")).trim()
} catch e {}  // @allow-silent-catch
// 폴백: 크기 검증 통과 실패 시 대체 경로 탐색
if _HEXA_BIN == "" {
    try {
        _HEXA_BIN = to_string(exec("for p in /tmp/hexa-build/hexa-lang/target/release/hexa " + _HOME + "/Dev/nexus/shared/bin/hexa; do [ -x \"$p\" ] && echo $p && break; done 2>/dev/null")).trim()
    } catch e {}  // @allow-silent-catch
}
if _HEXA_BIN == "" { _HEXA_BIN = _HOME + "/Dev/hexa-lang/hexa" }

// ─── 인자 파싱 ───
let a = args()
fn print_usage() {
    println("compose.hexa — blowup 조립 오케스트레이터 (R1 HEXA-FIRST)")
    println("")
    println("usage: hexa compose.hexa <domain> [depth] [--modules m1,m2,...] [--dfs N] [--skip-core] [--fast]")
    println("")
    println("modules (cumulative): field, holographic, quantum, string, toe, absolute, meta, meta_closure, hyperarithmetic, higher_category, topos, hott, motivic, derived_algebraic")
    println("aliases: all=core8+sparse5, core6, core8, sparse5, meta")
    println("  - field          : Discovery Field / Gauge Filter / Symmetry Breaking (Mk.III)")
    println("  - holographic    : boundary/bulk 이중화 경유")
    println("  - quantum        : 중첩 seed 파동함수 evolution")
    println("  - string         : 끈 이론 진동 모드 seed 전파")
    println("  - toe            : Theory of Everything 전 도메인 통합")
    println("  - absolute       : Mk.VIII Δ₀-absolute (Π₀¹ 검증 + [10*]→[11*] 승급, n=6 6th core)")
    println("  - meta           : Mk.IX meta-core (7th observer — C(6,2)=15 pair Jaccard resonance)")
    println("  - meta_closure   : Mk.IX meta-closure (fixed-point self-ref, Phase 10 준비)")
    println("  - hyperarithmetic: Mk.IX hyperarithmetic (8th core, Π₀² 계층)")
    println("  - higher_category: Mk.X 축4 HCT (∞,n)-cat / Lurie HTT (sparse, atlas 0)")
    println("  - topos          : Mk.X 축4 elementary/Grothendieck topos (sparse, atlas 0)")
    println("  - hott           : Mk.X 축4 univalence / HIT / cubical (sparse, atlas 1)")
    println("  - motivic        : Mk.X 축4 Beilinson / Voevodsky / Bloch-Kato (sparse, atlas 1)")
    println("  - derived_algebraic : Mk.X 축4 E∞-ring / spectral scheme / DAG (sparse, atlas 1)")
    println("")
    println("extended modules:")
    println("  - goldstone_cascade    : 골드스톤 캐스케이드 검증")
    println("  - field_gradient_bench : 기울기 벤치마크")
    println("  - string_t_duality     : T-이중성 검증")
    println("  - holo_boundary_accuracy : 경계 정확도 측정")
    println("  - toe_selfref_stability : 자기참조 안정성")
    println("  - qft_benchmark        : QFT 벤치마크")
    println("  - cross_validate_runner : 교차검증 러너")
    println("  - miss_to_exact_tracker : MISS->EXACT 전환율 추적")
    println("")
    println("examples:")
    println("  hexa compose.hexa math 3")
    println("  hexa compose.hexa math 3 --modules field,quantum --dfs 3")
    println("  hexa compose.hexa 7대난제 3 --modules toe --fast")
}

// hexa args: a[0]=hexa bin, a[1]=this script, a[2..]=user args
if len(a) < 3 {
    print_usage()
    exit(0)
}

// 첫 positional arg는 domain. --flag 가 오면 usage 안내 후 exit
if a[2].starts_with("--") {
    println("error: domain required as first positional arg (got flag: " + a[2] + ")")
    println("")
    print_usage()
    exit(1)  // @allow-silent-exit
}

// ROI#48b FOLLOWUP (2026-04-21): domain sanitize — drill 의 _round_seed prefix
//   `round=N-r<salt>|` + _nonce_seed suffix `#iter-nonce=<N>` 형식이 compose.hexa 경유
//   shell pipeline 및 /tmp/blowup_*.cf 파일명에서 metachar 로 해석 → core engine crash +
//   free stage 매 round +0 증상.
//   commit 49c20260 (blowup.hexa) 와 동일 sanitize 확장 적용 — compose 가 core 에 넘기기
//   이전 단계에서 1차 정제 (defensive: blowup.hexa 도 2차 sanitize 하지만 shell 인용 단계
//   에서 이미 깨지는 경우 방어 불가).
//   char_code/==  만 사용 (hexa stage1 string `>=` `<=` 함정 회피) — replace 체인은 문자열
//   패턴 대체라 해당 함정과 무관.
//   bias_jitter 는 compose.hexa 범위 밖 (seed 구성은 core/blowup.hexa Phase 4 에서만
//   수행) — 이식 대상 아님.
let _raw_domain_arg = a[2]
let domain = _raw_domain_arg.trim().replace(" ", "_").replace("[", "").replace("]", "").replace("*", "").replace("/", "_").replace("\t", "_").replace("|", "_").replace("#", "_").replace("=", "_").replace(";", "_").replace("$", "_").replace("`", "_").replace("'", "_").replace("\"", "_").replace("&", "_").replace("(", "_").replace(")", "_").replace("<", "_").replace(">", "_").replace("!", "_")
let mut depth: string = "3"
let mut modules_csv: string = ""
let mut dfs_depth: i64 = 0
let mut skip_core: bool = false
let mut fast_flag: bool = false

let mut ai: i64 = 3
while ai < len(a) {
    let tok = a[ai]
    if tok == "--modules" && ai + 1 < len(a) {
        modules_csv = a[ai + 1]
        ai = ai + 2
        continue
    }
    if tok == "--dfs" && ai + 1 < len(a) {
        try { dfs_depth = to_int(a[ai + 1]) } catch e {}  // @allow-silent-catch
        ai = ai + 2
        continue
    }
    if tok == "--skip-core" {
        skip_core = true
        ai = ai + 1
        continue
    }
    if tok == "--fast" {
        fast_flag = true
        ai = ai + 1
        continue
    }
    if tok.starts_with("--") {
        println("unknown flag: " + tok)
        exit(1)  // @allow-silent-exit
    }
    // positional → depth
    depth = tok
    ai = ai + 1
}

// ─── 헤더 ───
println("╔══════════════════════════════════════════════════════════════╗")
println("║  blowup compose: " + domain + " (depth=" + depth + ", modules=[" + modules_csv + "], dfs=" + to_string(dfs_depth) + ")")
println("╚══════════════════════════════════════════════════════════════╝")

// ─── Stage 1: core blowup (선택적 DFS) ───
// 모든 shell 변수는 single-quote 로 감싸 injection + 공백/특수문자 대응
// BLOWUP_LOCAL 모드 제거 — env prefix 불필요

if !skip_core {
    println("")
    println("--- STAGE 1: core blowup.hexa ---")
    let mut core_cmd = "'" + _HEXA_BIN + "' '" + _BLOWUP_CORE + "' '" + domain + "' '" + depth + "'"
    // --fast + --dfs 상호 배타: fast_mode는 Phase 8 스킵 → wave_targets 미생성 → DFS silent fail
    if fast_flag && dfs_depth > 0 {
        println("  [WARN] --fast + --dfs 상호 배타 — --fast 해제하여 DFS 실행 보장")
        // fast 해제, dfs 우선
    } else if fast_flag {
        core_cmd = core_cmd + " --fast"
    }
    if dfs_depth > 0 { core_cmd = core_cmd + " --dfs " + to_string(dfs_depth) }
    println("  cmd: " + core_cmd)
    try {
        let _out = exec("bash", ["-c", core_cmd + " 2>&1"])
        println(to_string(_out))
    } catch _e {  // @allow-silent-catch
        println("  [core] 실행 오류: " + to_string(_e))
    }
}

// ─── Stage 2: modules chain (순차 실행, atlas.n6 누적) ───
// 'all'     → core8 + sparse5 (Mk.X 축 4): 13 모듈 (2026-04-19)
// 'core6'   → 6-core only (field/holo/quantum/string/toe/absolute, Mk.VIII)
// 'core8'   → 6-core + meta_closure + hyperarithmetic (Mk.IX, Π₀² 준비)
// 'sparse5' → Mk.X 축 4 sparse 도메인 (HCT/TOP/HOTT/MOT/DAG, atlas coverage 0-1)
// Mk.VIII (2026-04-19): absolute 모듈 편입 — Δ₀-absolute Π₀¹ 검증 + [11*] 자동 승급
// Mk.IX   (2026-04-19): core8 = 6-core + meta_closure + hyperarithmetic
// Mk.X 축4 (2026-04-19): sparse5 = higher_category/topos/hott/motivic/derived_algebraic
if modules_csv == "all" {
    modules_csv = "field,holographic,quantum,string,toe,absolute,meta,meta_closure,hyperarithmetic,higher_category,topos,hott,motivic,derived_algebraic"
}
if modules_csv == "core6" {
    modules_csv = "field,holographic,quantum,string,toe,absolute"
}
if modules_csv == "core6_meta" {
    // 7th meta-observer alias — core6 직후 meta 관찰 실행
    modules_csv = "field,holographic,quantum,string,toe,absolute,meta"
}
if modules_csv == "core8" {
    modules_csv = "field,holographic,quantum,string,toe,absolute,meta_closure,hyperarithmetic"
}
if modules_csv == "sparse5" {
    modules_csv = "higher_category,topos,hott,motivic,derived_algebraic"
}
// F2/F3 추적 카운터 — 요청된 모듈 resolution 결과 타입화.
let mut _mod_requested: i64 = 0
let mut _mod_resolved:  i64 = 0
let mut _mod_missing:   i64 = 0
let mut _mod_unsafe:    i64 = 0
let mut _mod_exec_err:  i64 = 0
let _compose_seed_hash = _ce_seed_hash(domain)
if modules_csv != "" {
    let mods = modules_csv.split(",")
    let mut mi: i64 = 0
    while mi < len(mods) {
        let m_raw = mods[mi]
        let m_trim = m_raw.trim()
        mi = mi + 1
        if m_trim == "" { continue }
        _mod_requested = _mod_requested + 1
        // 모듈 이름 sanitization: 영숫자 + underscore 만 허용 (path traversal/injection 차단)
        // gotcha-2 해소 완료: hexa String 대소비교(>=, <=) 미지원 → .contains() 화이트리스트로 교체
        // 이전 코드: _ch >= "a" && _ch <= "z" → error[Type]: unsupported binary operation: Str Ge Str
        let _alnum = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_"
        let mut _safe = true
        let mut _ci: i64 = 0
        while _ci < len(m_trim) {
            let _ch = m_trim[_ci..(_ci + 1)]
            if !_alnum.contains(_ch) { _safe = false }
            _ci = _ci + 1
        }
        if !_safe {
            _mod_unsafe = _mod_unsafe + 1
            // F2: 비안전 모듈 이름 — typed CONSTRAINT_VIOLATION
            emit_engine_error("compose", "stage2", "CONSTRAINT_VIOLATION",
                "module name contains non-alnum char: " + m_trim,
                false, _compose_seed_hash)
            println("")
            println("--- STAGE: " + m_trim + " SKIP (비안전 문자 포함 — 영숫자+_만 허용)")
            continue
        }
        let mod_path = _resolve_module_path(m_trim)
        if !file_exists(mod_path) {
            _mod_missing = _mod_missing + 1
            // F2: 모듈 파일 부재 — typed DOMAIN_MISS
            emit_engine_error("compose", "stage2", "DOMAIN_MISS",
                "module file missing: " + mod_path,
                false, _compose_seed_hash)
            println("")
            println("--- STAGE: " + m_trim + " SKIP (모듈 없음: " + mod_path + ")")
            continue
        }
        _mod_resolved = _mod_resolved + 1
        println("")
        println("--- STAGE: " + m_trim + " ---")
        // 메모리 제한 2GB로 OOM/SIGKILL 완충
        let mod_cmd = "ulimit -v 2097152 2>/dev/null; '" + _HEXA_BIN + "' '" + mod_path + "' 2>&1"
        try {
            let _mout = exec("bash", ["-c", mod_cmd])
            println(to_string(_mout))
        } catch _me {  // @allow-silent-catch
            _mod_exec_err = _mod_exec_err + 1
            // F2: 모듈 실행 예외 — typed PHASE_FAIL
            emit_engine_error("compose", "stage2", "PHASE_FAIL",
                "module exec raised: " + m_trim,
                true, _compose_seed_hash)
            println("  [" + m_trim + "] 실행 오류 (chain 계속): " + to_string(_me))
        }
    }
}

// F3: 요청 모듈 0/N resolved 는 의심 — 모든 모듈이 DOMAIN_MISS 인데 exit 1 은 깨지는
// call site 호환성 훼손 → 경고만 emit (caller 가 연속 WARN 집계).
if _mod_requested > 0 && _mod_resolved == 0 {
    emit_engine_warn("compose", "zero_yield_suspicious",
        "requested=" + to_string(_mod_requested)
        + " resolved=0 missing=" + to_string(_mod_missing)
        + " unsafe=" + to_string(_mod_unsafe),
        _compose_seed_hash)
}

// ─── Stage 3: 조립 완료 + health ───
println("")
println("--- compose complete ---")
