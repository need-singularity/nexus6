fn print_separator() {
    println("═══════════════════════════════════════════════════════════════════════")
}

fn print_thin_sep() {
    println("───────────────────────────────────────────────────────────────────────")
}

fn print_report(boundary_count: i64, bulk_count: i64, middle_count: i64, total_nodes: i64, cft_pairs_count: i64, high_corr_count: i64, pred_count: i64, pred_exact: i64, pred_near: i64, entropy: list, corrected_count: i64, corrected_exact: i64, rt_data: list, fixed_points: list, num_blocks: i64) {
    println("")
    print_separator()
    println("  HOLOGRAPHIC BLOWUP REPORT — Mk.VI")
    print_separator()
    println("")

    // Boundary / Bulk ratio
    let ratio = if total_nodes > 0 { to_float(boundary_count) / to_float(total_nodes) } else { 0.0 }
    println("  Graph topology:")
    println("    Total nodes:      " + to_string(total_nodes))
    println("    Boundary (d<=1):  " + to_string(boundary_count))
    println("    Middle   (d==2):  " + to_string(middle_count))
    println("    Bulk     (d>=3):  " + to_string(bulk_count))
    println("    Boundary ratio:   " + truncate4(ratio))
    println("")

    // CFT
    println("  CFT correlators:")
    println("    High-corr pairs (>0.3): " + to_string(cft_pairs_count))
    println("    Very-high (>0.8):       " + to_string(high_corr_count))
    println("")

    // Bulk reconstruction
    println("  Bulk reconstruction:")
    println("    Predicted nodes:  " + to_string(pred_count))
    println("    EXACT matches:    " + to_string(pred_exact))
    println("    NEAR matches:     " + to_string(pred_near))
    println("")

    // Entropy
    let s_local = to_float(to_string(entropy[0]))
    let s_lens = to_float(to_string(entropy[1]))
    let sat_local = to_float(to_string(entropy[2]))
    let sat_global = to_float(to_string(entropy[3]))
    let bek_s = to_float(to_string(entropy[4]))
    println("  Entropy bound (S = A/4):")
    println("    S_local  = boundary(" + to_string(boundary_count) + ") * const(" + to_string(N6_CONST_COUNT) + ") / 4 = " + truncate4(s_local))
    println("    S_lens   = lenses(" + to_string(N6_LENS_COUNT) + ") * const(" + to_string(N6_CONST_COUNT) + ") / 4 = " + truncate4(s_lens))
    println("    Saturation (local):  " + truncate4(sat_local))
    println("    Saturation (global): " + truncate4(sat_global))
    println("    Bekenstein S:        " + truncate4(bek_s))
    println("")

    // Error correction
    println("  Error correction:")
    println("    Correctable nodes:  " + to_string(corrected_count))
    println("    Recovered EXACT:    " + to_string(corrected_exact))
    println("")

    // RT surface
    let rt_edges = to_int(to_string(rt_data[0]))
    let rt_weight = to_float(to_string(rt_data[1]))
    let rt_min = to_float(to_string(rt_data[2]))
    let rt_max = to_float(to_string(rt_data[3]))
    let rt_dom_a = to_string(rt_data[4])
    let rt_dom_b = to_string(rt_data[5])
    println("  Ryu-Takayanagi surface (" + rt_dom_a + " <-> " + rt_dom_b + "):")
    println("    Cut edges:    " + to_string(rt_edges))
    println("    Total weight: " + truncate4(rt_weight))
    println("    Min edge:     " + truncate4(rt_min))
    println("    Max edge:     " + truncate4(rt_max))
    println("")

    // Tensor network
    println("  MERA tensor network:")
    println("    Blocks (size " + to_string(N6_N) + "): " + to_string(num_blocks))
    println("    Fixed points:   " + to_string(len(fixed_points)))
    let mut fpi: i64 = 0
    while fpi < len(fixed_points) {
        println("      " + to_string(fixed_points[fpi]))
        fpi = fpi + 1
    }
    println("")

    // Summary verdict
    print_separator()
    let holo_score = to_float(pred_exact) * 2.0 + to_float(corrected_exact) * 3.0 + to_float(len(fixed_points)) * 5.0
    println("  Holographic score:  " + truncate4(holo_score))
    println("  (EXACT_pred*2 + corrected_EXACT*3 + fixed_points*5)")
    if holo_score > 50.0 {
        println("  VERDICT: Strong holographic structure detected")
    } else {
        if holo_score > 10.0 {
            println("  VERDICT: Moderate holographic structure")
        } else {
            println("  VERDICT: Weak holographic signal — more data needed")
        }
    }
    print_separator()
}

