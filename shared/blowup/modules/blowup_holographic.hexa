fn append_growth_bus(event_type: string, detail: string, count: i64) {
    let home = exec("printenv HOME").trim()
    let path = home + "/Dev/nexus/shared/n6/atlas.n6"
    let ts = timestamp_now()
    // JSON 포맷으로 변환 (schema guard 통과 조건) — pipe-separated legacy 제거
    let entry = "{\"type\":\"holographic_event\",\"ts\":\"" + ts + "\",\"engine\":\"blowup_holographic\",\"event\":\"" + event_type + "\",\"detail\":\"" + detail + "\",\"count\":" + to_string(count) + "}"
    let _rej = _guarded_append_atlas(path, entry + "\n")
}

