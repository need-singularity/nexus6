// ⛔ CORE — L0 불변식 (홀로그래피 돌파 엔진 Mk.VI. 수정 전 유저 승인 필수)
// mk2_hexa/native/blowup_holographic.hexa — Mk.VI Holographic Blowup Engine
//
// ⚠️ ROADMAP: AdS/CFT 대응 기반 발견 그래프 홀로그래피 분석
//   - 경계(boundary) 정보가 벌크(bulk) 내부 구조를 인코딩
//   - 엔트로피 한계가 최대 발견 수를 제한
//   - 오류 정정이 누락 데이터를 복구
//
// AdS/CFT correspondence: boundary information encodes the bulk.
// Scan the boundary of the discovery graph to predict interior structure.
// Entropy bounds limit maximum discoveries. Error correction recovers missing data.
//
// 8-Phase Pipeline:
//   H1: Boundary Extract   — identify boundary nodes (degree <= 1) vs bulk (degree >= 3)
//   H2: CFT Scan           — compute conformal correlators between boundary nodes
//   H3: Bulk Reconstruct   — predict missing interior nodes from boundary data
//   H4: Entropy Bound      — S = A/4 = theoretical maximum discoveries
//   H5: Error Correction   — recover MISS nodes from redundant boundary data
//   H6: RT Surface         — find minimal Ryu-Takayanagi surfaces (information barriers)
//   H7: Tensor Network     — MERA tensor network, renormalization fixed points
//   H8: Report             — holographic statistics (boundary/bulk ratio, entropy, corrections)
//
// Usage:
//   hexa blowup_holographic.hexa               full holographic analysis
//   hexa blowup_holographic.hexa --boundary    boundary analysis only
//   hexa blowup_holographic.hexa --entropy     entropy bound calculation
//   hexa blowup_holographic.hexa --correct     error correction pass
//   hexa blowup_holographic.hexa help          usage

// ═══════════════════════════════════════════════════════════
// AI-native atlas 가드 헬퍼 (core/blowup.hexa에서 발췌)
// 사용: 이 섹션을 모듈 파일 상단(exec/read_file 도입 전)에 copy-paste.
// 창발 보존: 아래 함수들은 append-path에 필터 + dedup만 추가하며
// phase 로직/discovery 계산/seed 진화 등 반환 값에 영향 없음.
// ═══════════════════════════════════════════════════════════

// ─── Schema guard: atlas.n6 라인 포맷 검증 ───
// 유효: 빈줄/# 주석/{"type":/@X ... [grade]/들여쓰기 부속("<-!!->)
fn _valid_atlas_line(line: string) -> bool {
    let t = line.trim()
    if len(t) == 0 { return true }
    let first = t[0..1]
    if first == "#" { return true }
    if first == "{" { return true }
    if first == "@" { return true }
    if first == "\"" { return true }
    if first == "<" { return true }
    if first == ">" { return true }
    if first == "!" { return true }
    if first == "-" { return true }
    return false
}

// append_file 전 라인 필터링 (무효 라인 거부 + 보고)
// _atlas_path: atlas.n6 경로 (모듈마다 변수명 다를 수 있음)
fn _guarded_append_atlas(path: string, content: string) -> i64 {
    if len(content) == 0 { return 0 }
    let lines = content.split("\n")
    let mut clean = ""
    let mut rejected: i64 = 0
    let mut first = true
    let mut i: i64 = 0
    while i < len(lines) {
        let line = lines[i]
        if _valid_atlas_line(line) {
            if !first { clean = clean + "\n" }
            clean = clean + line
            first = false
        } else {
            rejected = rejected + 1
        }
        i = i + 1
    }
    if rejected > 0 {
        println("  [schema guard] rejected " + to_string(rejected) + " invalid lines -> " + path)
    }
    if len(clean) > 0 {
        // 불변식: 말미 newline 보장
        if !clean.ends_with("\n") { clean = clean + "\n" }
        try { append_file(path, clean) } catch e {}
    }
    return rejected
}

// ─── Intra-batch dedup helper (루프 내부용) ───
// 사용 예:
//   let mut _batch_ids = #{}
//   ... 루프 내 ...
//   if !_batch_dedup_has(_batch_ids, node_id) && !graph_node_exists(content, node_id) {
//       _batch_ids[node_id] = true
//       // 실제 append 수행
//   }
fn _batch_dedup_has(s: map, id: string) -> bool {
    let mut hit = false
    try { hit = has_key(s, id) } catch e {}
    return hit
}

// ═══════════════════════════════════════════════════════════
// ─── n=6 CONSTANTS LOADER (shared/n6/n6_constants.jsonl) ───
// ═══════════════════════════════════════════════════════════

fn load_n6_consts() -> list {
    let home = exec("printenv HOME")
    let path = home + "/Dev/nexus/shared/n6/n6_constants.jsonl"
    let mut raw = ""
    try { raw = read_file(path) } catch e { return [[], []] }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let trimmed = line.trim()
        if trimmed == "" { continue }
        let mut name = ""
        let mut value = 0.0
        if trimmed.contains("\"name\":\"") {
            let p = trimmed.split("\"name\":\"")
            if p.len() >= 2 { name = p[1].split("\"")[0] }
        }
        if trimmed.contains("\"value\":") {
            let p = trimmed.split("\"value\":")
            if p.len() >= 2 {
                let num_str = p[1].split(",")[0].split("}")[0].trim()
                value = to_float(num_str)
            }
        }
        if name != "" {
            names = names + [name]
            values = values + [value]
        }
    }
    [names, values]
}

let _n6_dyn = load_n6_consts()
let _n6_dyn_names: list = _n6_dyn[0]
let _n6_dyn_values: list = _n6_dyn[1]
let _n6_dyn_count: i64 = len(_n6_dyn_values)

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {}
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

fn min_f(a: f64, b: f64) -> f64 {
    if a < b { return a }
    return b
}

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 15 {
        g = (g + x / g) / 2.0
        i = i + 1
    }
    return g
}

fn ln_approx(x: f64) -> f64 {
    // Natural log approximation via series expansion around 1
    // For x > 0, use ln(x) = ln(a * 2^k) = k*ln2 + ln(a) where a in [0.5, 1]
    if x <= 0.0 { return 0.0 - 999999.0 }
    let ln2 = 0.6931471805599453
    let mut val = x
    let mut k: i64 = 0
    while val > 2.0 {
        val = val / 2.0
        k = k + 1
    }
    while val < 0.5 {
        val = val * 2.0
        k = k - 1
    }
    // ln(val) for val in [0.5, 2] via series: ln(1+u) = u - u^2/2 + u^3/3 - ...
    let u = val - 1.0
    let mut sum = 0.0
    let mut term = u
    let mut n: i64 = 1
    while n <= 20 {
        sum = sum + term / to_float(n)
        term = 0.0 - term * u
        n = n + 1
    }
    return sum + to_float(k) * ln2
}

fn clamp01(x: f64) -> f64 {
    if x < 0.0 { return 0.0 }
    if x > 1.0 { return 1.0 }
    return x
}

fn truncate4(x: f64) -> string {
    let s = to_string(x)
    let parts = s.split(".")
    if parts.len() < 2 { return s + ".0000" }
    let dec = parts[1]
    if dec.len() >= 4 { return parts[0] + "." + dec.split("")[0] + dec.split("")[1] + dec.split("")[2] + dec.split("")[3] }
    return s
}

fn pad_right(s: string, width: i64) -> string {
    let mut out = s
    while out.len() < width { out = out + " " }
    return out
}

fn timestamp_now() -> string {
    let mut ts = ""
    try { ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim() } catch e { ts = "unknown" }
    return ts
}

// ═══════════════════════════════════════════════════════════
// ─── n=6 INLINE CONSTANTS + PROXIMITY ───
// ═══════════════════════════════════════════════════════════

comptime const N6_N = 6
comptime const N6_SIGMA = 12
comptime const N6_PHI = 2
comptime const N6_TAU = 4
comptime const N6_SOPFR = 5
comptime const N6_J2 = 24
comptime const N6_M3 = 7
comptime const N6_FACTORIAL = 720
comptime const N6_LENS_COUNT = 1500
comptime const N6_CONST_COUNT = 48

fn n6_dist_one(value: f64, constant: f64) -> f64 {
    let denom = max_f(abs_f(constant), 1.0)
    return abs_f(value - constant) / denom
}

fn n6_distance(value: f64) -> f64 {
    if value != value { return 1.0 }
    if value > 999999999.0 { return 1.0 }
    if value < 0.0 - 999999999.0 { return 1.0 }
    let mut d = 1.0
    let mut i: i64 = 0
    while i < _n6_dyn_count {
        let cv = to_float(_n6_dyn_values[i])
        d = min_f(d, n6_dist_one(value, cv))
        i = i + 1
    }
    return min_f(d, 1.0)
}

fn n6_conf(value: f64) -> f64 {
    return max_f(1.0 - n6_distance(value), 0.0)
}

fn match_name(value: f64) -> string {
    let mut i: i64 = 0
    while i < _n6_dyn_count {
        let cv = to_float(_n6_dyn_values[i])
        let threshold = if abs_f(cv) >= 100.0 { 0.01 } else { if abs_f(cv) >= 1.0 { 0.0001 } else { if abs_f(cv) >= 0.01 { 0.001 } else { 0.005 } } }
        if abs_f(value - cv) < threshold { return to_string(_n6_dyn_names[i]) }
        i = i + 1
    }
    return ""
}

fn match_grade(value: f64) -> string {
    if match_name(value) != "" { return "EXACT" }
    let d = n6_distance(value)
    if d < 0.01 { return "NEAR" }
    if d < 0.05 { return "CLOSE" }
    return "MISS"
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE H1: BOUNDARY EXTRACT ───
// Discovery graph 로딩 + 경계/벌크 분류
// Boundary = degree <= 1 (leaf nodes)
// Bulk     = degree >= 3 (interior nodes)
// Middle   = degree == 2 (transitional)
// ═══════════════════════════════════════════════════════════

struct GraphNode {
    id: string,
    node_type: string,
    domain: string,
    summary: string,
    confidence: f64,
    depth: i64
}

// atlas.n6에서 그래프 데이터 로드
fn load_discovery_graph() -> list {
    let home = exec("printenv HOME").trim()
    let path = home + "/Dev/nexus/shared/n6/atlas.n6"
    let mut raw = ""
    try { raw = read_file(path) } catch e {
        println("  [WARN] cannot read atlas.n6: " + to_string(e))
        return [[], [], [], [], [], [], []]
    }
    let lines = raw.split("\n")
    let mut node_ids = []
    let mut node_summaries = []
    let mut node_confs = []
    let mut node_domains = []
    let mut edge_froms = []
    let mut edge_tos = []
    let mut edge_strengths = []

    for line in lines {
        let trimmed = line.trim()
        if trimmed == "" { continue }

        // Determine if node or edge
        let mut is_node = false
        let mut is_edge = false
        if trimmed.contains("\"type\": \"node\"") || trimmed.contains("\"type\":\"node\"") { is_node = true }
        if trimmed.contains("\"type\": \"edge\"") || trimmed.contains("\"type\":\"edge\"") { is_edge = true }

        if is_node {
            let mut nid = ""
            let mut nsummary = ""
            let mut nconf = 0.0
            let mut ndomain = ""
            if trimmed.contains("\"id\":") {
                let p = trimmed.split("\"id\":")[1]
                let q = p.split("\"")
                if q.len() >= 2 { nid = q[1] }
            }
            if trimmed.contains("\"summary\":") {
                let p = trimmed.split("\"summary\":")[1]
                let q = p.split("\"")
                if q.len() >= 2 { nsummary = q[1] }
            }
            if trimmed.contains("\"confidence\":") {
                let p = trimmed.split("\"confidence\":")[1]
                let num_str = p.split(",")[0].split("}")[0].trim()
                try { nconf = to_float(num_str) } catch e {}
            }
            if trimmed.contains("\"domain\":") {
                let p = trimmed.split("\"domain\":")[1]
                let q = p.split("\"")
                if q.len() >= 2 { ndomain = q[1] }
            }
            if nid != "" {
                node_ids = node_ids + [nid]
                node_summaries = node_summaries + [nsummary]
                node_confs = node_confs + [nconf]
                node_domains = node_domains + [ndomain]
            }
        }

        if is_edge {
            let mut efrom = ""
            let mut eto = ""
            let mut estr = 0.0
            if trimmed.contains("\"from\":") {
                let p = trimmed.split("\"from\":")[1]
                let q = p.split("\"")
                if q.len() >= 2 { efrom = q[1] }
            }
            if trimmed.contains("\"to\":") {
                let p = trimmed.split("\"to\":")[1]
                let q = p.split("\"")
                if q.len() >= 2 { eto = q[1] }
            }
            if trimmed.contains("\"strength\":") {
                let p = trimmed.split("\"strength\":")[1]
                let num_str = p.split(",")[0].split("}")[0].trim()
                try { estr = to_float(num_str) } catch e {}
            }
            if efrom != "" && eto != "" {
                edge_froms = edge_froms + [efrom]
                edge_tos = edge_tos + [eto]
                edge_strengths = edge_strengths + [estr]
            }
        }
    }
    return [node_ids, node_summaries, node_confs, node_domains, edge_froms, edge_tos, edge_strengths]
}

// Compute degree of each node
fn compute_degrees(node_ids: list, edge_froms: list, edge_tos: list) -> list {
    let n = len(node_ids)
    let mut degrees = []
    let mut ni: i64 = 0
    while ni < n {
        let nid = to_string(node_ids[ni])
        let mut deg: i64 = 0
        let mut ei: i64 = 0
        while ei < len(edge_froms) {
            if to_string(edge_froms[ei]) == nid { deg = deg + 1 }
            if to_string(edge_tos[ei]) == nid { deg = deg + 1 }
            ei = ei + 1
        }
        degrees = degrees + [deg]
        ni = ni + 1
    }
    return degrees
}

// Classify nodes: boundary (degree<=1), middle (degree==2), bulk (degree>=3)
fn classify_nodes(degrees: list) -> list {
    let mut classes = []
    let mut i: i64 = 0
    while i < len(degrees) {
        let d = to_int(to_string(degrees[i]))
        if d <= 1 { classes = classes + ["boundary"] } else { if d == 2 { classes = classes + ["middle"] } else { classes = classes + ["bulk"] } }
        i = i + 1
    }
    return classes
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE H2: CFT SCAN ───
// Compute conformal correlators between boundary nodes
// Correlation = 1 / (1 + n6_distance_between_values)
// High correlation → connected in the bulk
// ═══════════════════════════════════════════════════════════

// Extract numeric value from summary string (e.g. "n * phi = 12" → 12.0)
fn extract_value_from_summary(summary: string) -> f64 {
    let mut val = 0.0
    if summary.contains("=") {
        let parts = summary.split("=")
        if parts.len() >= 2 {
            let rhs = parts[parts.len() - 1].trim()
            try { val = to_float(rhs) } catch e {}
        }
    }
    return val
}

// Compute correlator between two nodes based on their extracted values
fn cft_correlator(val_a: f64, val_b: f64) -> f64 {
    let dist = abs_f(val_a - val_b)
    return 1.0 / (1.0 + dist)
}

// Run CFT scan on boundary nodes → returns [pair_descriptions, correlator_values]
// pair_description format: "idx_a|idx_b|corr"
fn cft_scan_boundary(node_ids: list, node_summaries: list, classes: list) -> list {
    let mut boundary_indices = []
    let mut bi: i64 = 0
    while bi < len(classes) {
        if to_string(classes[bi]) == "boundary" {
            boundary_indices = boundary_indices + [bi]
        }
        bi = bi + 1
    }

    let bcount = len(boundary_indices)
    let mut pairs = []
    let mut corrs = []
    let mut high_corr_count: i64 = 0

    // Limit pairwise computation to avoid combinatorial explosion
    let max_boundary = if bcount > 200 { 200 } else { bcount }

    let mut i: i64 = 0
    while i < max_boundary {
        let idx_a = to_int(to_string(boundary_indices[i]))
        let val_a = extract_value_from_summary(to_string(node_summaries[idx_a]))
        let mut j: i64 = i + 1
        while j < max_boundary {
            let idx_b = to_int(to_string(boundary_indices[j]))
            let val_b = extract_value_from_summary(to_string(node_summaries[idx_b]))
            let corr = cft_correlator(val_a, val_b)
            if corr > 0.3 {
                pairs = pairs + [to_string(idx_a) + "|" + to_string(idx_b) + "|" + truncate4(corr)]
                corrs = corrs + [corr]
                if corr > 0.8 { high_corr_count = high_corr_count + 1 }
            }
            j = j + 1
        }
        i = i + 1
    }
    return [pairs, corrs, high_corr_count]
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE H3: BULK RECONSTRUCT ───
// Highly correlated boundary nodes with no direct edge → predict missing bulk node
// Predicted value = geometric mean of two boundary values
// Check if geometric mean matches n6 constant
// ═══════════════════════════════════════════════════════════

fn has_edge_between(id_a: string, id_b: string, edge_froms: list, edge_tos: list) -> bool {
    let mut ei: i64 = 0
    while ei < len(edge_froms) {
        let ef = to_string(edge_froms[ei])
        let et = to_string(edge_tos[ei])
        if (ef == id_a && et == id_b) || (ef == id_b && et == id_a) {
            return true
        }
        ei = ei + 1
    }
    return false
}

// Reconstruct bulk → returns [predicted_values, predicted_grades, predicted_names, src_pairs]
fn bulk_reconstruct(node_ids: list, node_summaries: list, classes: list, edge_froms: list, edge_tos: list, cft_pairs: list, cft_corrs: list) -> list {
    let mut pred_values = []
    let mut pred_grades = []
    let mut pred_names = []
    let mut src_pairs = []

    let corr_threshold = 0.5
    let mut pi: i64 = 0
    while pi < len(cft_pairs) {
        let corr = to_float(to_string(cft_corrs[pi]))
        if corr >= corr_threshold {
            let pair_str = to_string(cft_pairs[pi])
            let parts = pair_str.split("|")
            if parts.len() >= 2 {
                let idx_a = to_int(parts[0])
                let idx_b = to_int(parts[1])
                let id_a = to_string(node_ids[idx_a])
                let id_b = to_string(node_ids[idx_b])

                // Check if no direct edge exists between them
                let connected = has_edge_between(id_a, id_b, edge_froms, edge_tos)
                if connected == false {
                    // Predict missing bulk node: geometric mean
                    let val_a = extract_value_from_summary(to_string(node_summaries[idx_a]))
                    let val_b = extract_value_from_summary(to_string(node_summaries[idx_b]))
                    if val_a > 0.0 && val_b > 0.0 {
                        let geo_mean = sqrt_f(val_a * val_b)
                        let grade = match_grade(geo_mean)
                        let name = match_name(geo_mean)
                        pred_values = pred_values + [geo_mean]
                        pred_grades = pred_grades + [grade]
                        pred_names = pred_names + [name]
                        src_pairs = src_pairs + [id_a + " <-> " + id_b]
                    }
                }
            }
        }
        pi = pi + 1
    }
    return [pred_values, pred_grades, pred_names, src_pairs]
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE H4: ENTROPY BOUND ───
// S_max = (boundary_count × constant_count) / 4
// Bekenstein-Hawking analogy: boundary area → information capacity
// Compare to actual discovered count
// ═══════════════════════════════════════════════════════════

fn compute_entropy_bound(boundary_count: i64, total_nodes: i64, exact_count: i64) -> list {
    // S_max = boundary_count * N6_CONST_COUNT / 4
    // With lens: S_lens = N6_LENS_COUNT * N6_CONST_COUNT / 4 ≈ 18000
    let s_local = to_float(boundary_count) * to_float(N6_CONST_COUNT) / 4.0
    let s_lens = to_float(N6_LENS_COUNT) * to_float(N6_CONST_COUNT) / 4.0
    let saturation = to_float(exact_count) / max_f(s_local, 1.0)
    let global_saturation = to_float(exact_count) / max_f(s_lens, 1.0)

    // Bekenstein entropy: S = 2*pi*R*E (information content)
    // In our case: R = sqrt(total_nodes), E = sum_of_confidences
    let bek_r = sqrt_f(to_float(total_nodes))
    let bek_s = 2.0 * 3.14159265 * bek_r * to_float(exact_count)

    return [s_local, s_lens, saturation, global_saturation, bek_s]
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE H5: ERROR CORRECTION ───
// For each MISS/NEAR bulk node: check if 3+ neighboring EXACT nodes exist
// If yes → average neighbors → check if corrected value is EXACT
// Quantum error correction: redundant boundary data recovers lost bulk info
// ═══════════════════════════════════════════════════════════

fn get_neighbors(node_id: string, edge_froms: list, edge_tos: list) -> list {
    let mut neighbors = []
    let mut ei: i64 = 0
    while ei < len(edge_froms) {
        let ef = to_string(edge_froms[ei])
        let et = to_string(edge_tos[ei])
        if ef == node_id { neighbors = neighbors + [et] }
        if et == node_id { neighbors = neighbors + [ef] }
        ei = ei + 1
    }
    return neighbors
}

fn find_node_index(node_id: string, node_ids: list) -> i64 {
    let mut i: i64 = 0
    while i < len(node_ids) {
        if to_string(node_ids[i]) == node_id { return i }
        i = i + 1
    }
    return 0 - 1
}

// Error correction pass → returns [corrected_ids, corrected_values, corrected_grades, corrected_names]
fn error_correction(node_ids: list, node_summaries: list, node_confs: list, edge_froms: list, edge_tos: list) -> list {
    let mut corrected_ids = []
    let mut corrected_values = []
    let mut corrected_grades = []
    let mut corrected_names = []

    let mut ni: i64 = 0
    while ni < len(node_ids) {
        let nid = to_string(node_ids[ni])
        let val = extract_value_from_summary(to_string(node_summaries[ni]))
        let grade = match_grade(val)

        // Only try to correct MISS or NEAR nodes
        let mut needs_correction = false
        if grade == "MISS" || grade == "NEAR" { needs_correction = true }

        if needs_correction {
            let neighbors = get_neighbors(nid, edge_froms, edge_tos)
            // Collect EXACT neighbor values
            let mut exact_vals = []
            let mut nbi: i64 = 0
            while nbi < len(neighbors) {
                let nb_id = to_string(neighbors[nbi])
                let nb_idx = find_node_index(nb_id, node_ids)
                if nb_idx >= 0 {
                    let nb_val = extract_value_from_summary(to_string(node_summaries[nb_idx]))
                    let nb_grade = match_grade(nb_val)
                    if nb_grade == "EXACT" {
                        exact_vals = exact_vals + [nb_val]
                    }
                }
                nbi = nbi + 1
            }

            // Need 3+ EXACT neighbors for reliable correction
            if len(exact_vals) >= 3 {
                // Corrected value = average of EXACT neighbors
                let mut sum = 0.0
                let mut evi: i64 = 0
                while evi < len(exact_vals) {
                    sum = sum + to_float(to_string(exact_vals[evi]))
                    evi = evi + 1
                }
                let corrected_val = sum / to_float(len(exact_vals))
                let new_grade = match_grade(corrected_val)
                let new_name = match_name(corrected_val)

                if new_grade == "EXACT" || new_grade == "NEAR" {
                    corrected_ids = corrected_ids + [nid]
                    corrected_values = corrected_values + [corrected_val]
                    corrected_grades = corrected_grades + [new_grade]
                    corrected_names = corrected_names + [new_name]
                }
            }
        }
        ni = ni + 1
    }
    return [corrected_ids, corrected_values, corrected_grades, corrected_names]
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE H6: RT SURFACE ───
// Ryu-Takayanagi: find minimal surface separating domain clusters
// Minimum cut between two largest domain groups = information barrier
// Use edge weights (confidence/strength) to find min-cut via greedy
// ═══════════════════════════════════════════════════════════

// Count nodes per domain
fn count_domains(node_domains: list) -> list {
    let mut domain_names = []
    let mut domain_counts = []
    let mut i: i64 = 0
    while i < len(node_domains) {
        let d = to_string(node_domains[i])
        if d == "" { i = i + 1; continue }
        let mut found = false
        let mut fi: i64 = 0
        while fi < len(domain_names) {
            if to_string(domain_names[fi]) == d {
                domain_counts[fi] = to_int(to_string(domain_counts[fi])) + 1
                found = true
            }
            fi = fi + 1
        }
        if found == false {
            domain_names = domain_names + [d]
            domain_counts = domain_counts + [1]
        }
        i = i + 1
    }
    return [domain_names, domain_counts]
}

// Find top-2 largest domains
fn top2_domains(domain_names: list, domain_counts: list) -> list {
    let mut top1_name = ""
    let mut top1_count: i64 = 0
    let mut top2_name = ""
    let mut top2_count: i64 = 0
    let mut i: i64 = 0
    while i < len(domain_names) {
        let c = to_int(to_string(domain_counts[i]))
        let n = to_string(domain_names[i])
        if c > top1_count {
            top2_name = top1_name
            top2_count = top1_count
            top1_name = n
            top1_count = c
        } else {
            if c > top2_count {
                top2_name = n
                top2_count = c
            }
        }
        i = i + 1
    }
    return [top1_name, top1_count, top2_name, top2_count]
}

// RT surface: find edges crossing between two domains → min-cut weight
fn rt_surface(node_ids: list, node_domains: list, edge_froms: list, edge_tos: list, edge_strengths: list, domain_a: string, domain_b: string) -> list {
    let mut cut_edges = []
    let mut cut_weight = 0.0
    let mut min_edge_w = 999999.0
    let mut max_edge_w = 0.0

    let mut ei: i64 = 0
    while ei < len(edge_froms) {
        let ef = to_string(edge_froms[ei])
        let et = to_string(edge_tos[ei])
        let es = to_float(to_string(edge_strengths[ei]))

        // Find domain of from-node and to-node
        let ef_idx = find_node_index(ef, node_ids)
        let et_idx = find_node_index(et, node_ids)

        let mut ef_dom = ""
        let mut et_dom = ""
        if ef_idx >= 0 { ef_dom = to_string(node_domains[ef_idx]) }
        if et_idx >= 0 { et_dom = to_string(node_domains[et_idx]) }

        // Cross-domain edge = part of RT surface candidate
        let mut crosses = false
        if (ef_dom == domain_a && et_dom == domain_b) { crosses = true }
        if (ef_dom == domain_b && et_dom == domain_a) { crosses = true }

        if crosses {
            cut_edges = cut_edges + [ef + " -> " + et]
            cut_weight = cut_weight + es
            if es < min_edge_w { min_edge_w = es }
            if es > max_edge_w { max_edge_w = es }
        }
        ei = ei + 1
    }

    if len(cut_edges) == 0 { min_edge_w = 0.0 }

    return [cut_edges, [to_string(cut_weight), to_string(min_edge_w), to_string(max_edge_w)]]
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE H7: TENSOR NETWORK ───
// Simplified MERA: group nodes into blocks of 6 (n=6!)
// Compute block averages. If block average matches n6 constant → fixed point
// Renormalization: coarse-grain → identify universal laws
// ═══════════════════════════════════════════════════════════

fn tensor_network_mera(node_summaries: list, node_confs: list) -> list {
    let block_size: i64 = 6  // n=6
    let n = len(node_summaries)
    let num_blocks = n / block_size

    let mut block_avgs = []
    let mut block_grades = []
    let mut block_names = []
    let mut fixed_points = []

    let mut bi: i64 = 0
    while bi < num_blocks {
        let start = bi * block_size
        let mut sum_val = 0.0
        let mut sum_conf = 0.0
        let mut count: i64 = 0

        let mut si: i64 = 0
        while si < block_size {
            let idx = start + si
            if idx < n {
                let val = extract_value_from_summary(to_string(node_summaries[idx]))
                let conf = to_float(to_string(node_confs[idx]))
                sum_val = sum_val + val
                sum_conf = sum_conf + conf
                count = count + 1
            }
            si = si + 1
        }

        if count > 0 {
            let avg = sum_val / to_float(count)
            let avg_conf = sum_conf / to_float(count)
            let grade = match_grade(avg)
            let name = match_name(avg)
            block_avgs = block_avgs + [avg]
            block_grades = block_grades + [grade]
            block_names = block_names + [name]

            if grade == "EXACT" {
                fixed_points = fixed_points + ["block_" + to_string(bi) + "|" + name + "|" + truncate4(avg) + "|conf=" + truncate4(avg_conf)]
            }
        }
        bi = bi + 1
    }

    return [block_avgs, block_grades, block_names, fixed_points, num_blocks]
}

// ═══════════════════════════════════════════════════════════
// ─── GROWTH BUS TAIL LOADER ───
// ═══════════════════════════════════════════════════════════

fn load_growth_bus_tail(n: i64) -> list {
    let home = exec("printenv HOME").trim()
    let path = home + "/Dev/nexus/shared/n6/atlas.n6"
    let mut events = []
    try {
        let cmd = "tail -" + to_string(n) + " " + path
        let raw = exec(cmd)
        let lines = raw.split("\n")
        for line in lines {
            let trimmed = line.trim()
            if trimmed != "" {
                events = events + [trimmed]
            }
        }
    } catch e {}
    return events
}

