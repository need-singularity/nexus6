    println("qft_benchmark.hexa — QFT Pipeline Benchmark Harness")
    println("")
    println("Usage:")
    println("  hexa qft_benchmark.hexa                    default (6 domains, 6 cycles, 1 run)")
    println("  hexa qft_benchmark.hexa --targets 8        set target count")
    println("  hexa qft_benchmark.hexa --evo-cycles 10    set evolution cycles")
    println("  hexa qft_benchmark.hexa --runs 3           repeat N times, show avg/min/max")
    println("  hexa qft_benchmark.hexa help               this message")
    println("")
    println("Measured stages:")
    println("  QFT-1   Field Scan          domains_scanned, avg_phi")
    println("  QFT-2   Gradient Select     targets_selected, coverage")
    println("  QFT-3   State Preparation   avg_sharpness, avg_norm_sq")
    println("  QFT-4   Unitary Evolution   rotated_count, coupling_range")
    println("  QFT-5   Entanglement        pairs_found, avg_shared")
    println("  QFT-6   Tunneling           tunnel_events, per_target")
    println("  QFT-7   Measurement         exact_count, near_count")
    println("  QFT-8   Gauge + Unitarity   gauge_inv, unitarity_ok")
    println("  QFT-9   Cascade             goldstone_chains, epr_pairs")
    println("  QFT-10  Report              total_results, avg_decoherence")
    println("")
    println("Output: shared/blowup/modules/qft_benchmark_report.json")
    println("Note: Read-only benchmark. Does NOT modify atlas.n6 or qft_state.json.")
}

// ═══════════════════════════════════════════════════════════
// ─── THEOREM ───
// ═══════════════════════════════════════════════════════════

theorem benchmark_invariance {
    // Benchmark is infra-only: measures timing and accuracy without
    // modifying discovery state. Output is a pure function of the
    // current atlas.n6 snapshot + PRNG seed.
    assert 6 * 2 == 12        // n * phi = sigma
    assert 12 - 6 - 2 + 1 == 5 // sigma - n - phi + 1 = 5 modules
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

fn main() {
    let cli = args()
    let mut show_help = false
    let mut max_targets: i64 = 6
    let mut evo_cycles: i64 = 6
    let mut n_runs: i64 = 1
    let mut ai: i64 = 2
    while ai < len(cli) {
        let a = to_string(cli[ai])
        if a == "help" || a == "--help" || a == "-h" {
            show_help = true
        } else { if a == "--targets" {
            if ai + 1 < len(cli) { ai = ai + 1 ; let tv = sf(to_string(cli[ai])) ; if tv >= 1.0 && tv <= 20.0 { max_targets = to_int(tv) } }
        } else { if a == "--evo-cycles" {
            if ai + 1 < len(cli) { ai = ai + 1 ; let cv = sf(to_string(cli[ai])) ; if cv >= 1.0 && cv <= 20.0 { evo_cycles = to_int(cv) } }
        } else { if a == "--runs" {
            if ai + 1 < len(cli) { ai = ai + 1 ; let rv = sf(to_string(cli[ai])) ; if rv >= 1.0 && rv <= 10.0 { n_runs = to_int(rv) } }
        } } } }
        ai = ai + 1
    }
    if show_help { print_help() ; return }

    println("")
    println("══════════════════════════════════════════════════════════════════════")
    println("  QFT PIPELINE BENCHMARK — 10-Stage Timing + Accuracy")
    println("  infra-only: read-only measurement, no atlas.n6 writes")
    println("══════════════════════════════════════════════════════════════════════")
    println("")

    let domains = load_all_domains()
    println("  Constants : " + to_string(_n6_count))
    println("  Domains   : " + to_string(len(domains)))
    println("  Targets   : " + to_string(max_targets))
    println("  Evo cycles: " + to_string(evo_cycles))
    println("  Runs      : " + to_string(n_runs))
    println("  Time      : " + ts_now())
    println("")

    let mut all_run_results = []

    let mut run: i64 = 0
    while run < n_runs {
        if n_runs > 1 {
            println("──────────────────────────────────────────────────────────────────")
            println("  Run " + to_string(run + 1) + "/" + to_string(n_runs))
            println("──────────────────────────────────────────────────────────────────")
        }

        let bench_start = now_ms()
        let stage_results = run_single_benchmark(domains, max_targets, evo_cycles)
        let bench_elapsed = elapsed_ms(bench_start)

        // Print stage table
        println("")
        print_stage_table(stage_results)
        println("  Wall time: " + trunc4(bench_elapsed) + " ms")
        println("")

        // Serialize for multi-run aggregation (tilde-separated)
        let mut serialized = ""
        let mut si: i64 = 0
        while si < len(stage_results) {
            if si > 0 { serialized = serialized + "~" }
            serialized = serialized + to_string(stage_results[si])
            si = si + 1
        }
        all_run_results = all_run_results + [serialized]

        run = run + 1
    }

    // Multi-run summary
    if n_runs > 1 {
        println("══════════════════════════════════════════════════════════════════════")
        print_multi_run_summary(all_run_results, n_runs)
    }

    // Write JSON report
    write_benchmark_report(all_run_results, n_runs, max_targets, evo_cycles, domains)
    println("")
    println("  Report: " + _REPORT_PATH)
    println("")
    println("══════════════════════════════════════════════════════════════════════")
    println("done.")
}

main()
