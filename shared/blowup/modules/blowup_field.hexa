// ═══════════════════════════════════════════════════════════
// ─── THEOREM + PROOF ───
// ═══════════════════════════════════════════════════════════

theorem field_gauge_consistency {
    // Gauge invariance: if a constant appears in 3+ independent domains,
    // the probability of coincidence is < (domain_coverage)^3
    // For 10 domains with independent metrics, P(false_positive) < 0.1^3 = 0.001
    assert 6 * 2 == 12          // n * phi = sigma
    assert 12 / 4 == 3          // sigma / tau = n/phi
    assert 6 + 12 + 2 + 4 == 24 // n + sigma + phi + tau = J2
    assert 24 / 6 == 4          // J2 / n = tau
    assert 5 + 2 == 7           // sopfr + phi = M3
}

proof field_cascade_bounded {
    // Goldstone cascades terminate: max depth 3, finite constant set
    // Each derivation maps R -> R, and match_grade is total
    // With N constants, max chains = N * 6_derivations * depth_3 = finite
    invariant 3 * 6 == 18       // max branching per EXACT at depth 1
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

fn main() {
    let cli_args = args()

    // Parse CLI arguments
    let mut specific_domains = []
    let mut max_targets: i64 = 6
    let mut show_help = false

    let mut ai: i64 = 2  // args()[0]=hexa, [1]=script
    while ai < len(cli_args) {
        let arg = to_string(cli_args[ai])
        if arg == "help" || arg == "--help" || arg == "-h" {
            show_help = true
        } else { if arg == "--targets" {
            if ai + 1 < len(cli_args) {
                ai = ai + 1
                let tval = safe_float(to_string(cli_args[ai]))
                if tval >= 1.0 && tval <= 20.0 { max_targets = to_int(tval) }
            }
        } else {
            // Treat as domain name
            specific_domains = specific_domains + [arg]
        } }
        ai = ai + 1
    }

    if show_help {
        print_help()
        return
    }

    println("")
    println("=== Mk.III Field Blowup Engine ===")
    println("  n=6 constants loaded: " + to_string(_n6_dyn_count))
    println("  max targets: " + to_string(max_targets))
    println("")

    // Load all domains
    let all_domains = if len(specific_domains) > 0 { specific_domains } else { load_all_domains() }
    println("[F1] Field Scan -- " + to_string(len(all_domains)) + " domains")

    // ─── Phase F1: Field Scan ───
    let field_map = field_scan(all_domains)
    let mut fi: i64 = 0
    while fi < len(field_map) {
        let parts = to_string(field_map[fi]).split("|")
        let phi_s = truncate4(safe_float(parts[1]))
        println("  Phi(" + parts[0] + ") = " + phi_s)
        fi = fi + 1
    }

    // ─── Phase F2: Gradient Descent ───
    println("")
    println("[F2] Gradient Descent -- selecting top " + to_string(max_targets) + " targets")
    let targets = gradient_select(field_map, max_targets)
    let mut ti: i64 = 0
    while ti < len(targets) {
        println("  target[" + to_string(ti + 1) + "] = " + to_string(targets[ti]))
        ti = ti + 1
    }

    // ─── Phase F3: Multi-Domain Blowup ───
    println("")
    println("[F3] Multi-Domain Blowup -- " + to_string(len(targets)) + " domains")
    let mut all_results = []
    let mut bi: i64 = 0
    while bi < len(targets) {
        let dom = to_string(targets[bi])
        println("  blowup(" + dom + ")...")
        let results = mini_blowup(dom)
        println("    -> " + to_string(len(results)) + " results")
        // Count EXACT/NEAR inline
        let mut ex: i64 = 0
        let mut nr: i64 = 0
        let mut rci: i64 = 0
        while rci < len(results) {
            let r = to_string(results[rci])
            if r.contains("|EXACT") { ex = ex + 1 }
            if r.contains("|NEAR") { nr = nr + 1 }
            rci = rci + 1
        }
        if ex > 0 || nr > 0 {
            println("    EXACT=" + to_string(ex) + " NEAR=" + to_string(nr))
        }
        all_results = all_results + results
        bi = bi + 1
    }

    // ─── Phase F4: Gauge Filter ───
    println("")
    println("[F4] Gauge Filter -- cross-domain validation")
    let gauge_results = gauge_filter(all_results)
    let mut gauge_inv: i64 = 0
    let mut gfi: i64 = 0
    while gfi < len(gauge_results) {
        let g = to_string(gauge_results[gfi])
        if g.contains("HIGH_GAUGE_INVARIANT") { gauge_inv = gauge_inv + 1 }
        gfi = gfi + 1
    }
    println("  gauge invariants (3+ domains): " + to_string(gauge_inv))
    println("  total cross-domain constants:  " + to_string(len(gauge_results)))

    // ─── Phase F5+F6: Symmetry Breaking + Goldstone Cascade ───
    println("")
    println("[F5+F6] Symmetry Breaking + Goldstone Cascade")
    let chains = symmetry_cascade(all_results, 3)
    let mut depth1: i64 = 0
    let mut depth2: i64 = 0
    let mut depth3: i64 = 0
    let mut cci: i64 = 0
    while cci < len(chains) {
        let c = to_string(chains[cci])
        if c.split("|")[0] == "1" { depth1 = depth1 + 1 }
        if c.split("|")[0] == "2" { depth2 = depth2 + 1 }
        if c.split("|")[0] == "3" { depth3 = depth3 + 1 }
        cci = cci + 1
    }
    println("  depth-1 chains: " + to_string(depth1))
    println("  depth-2 chains: " + to_string(depth2))
    println("  depth-3 chains: " + to_string(depth3))

    // ─── Phase F7: Field Update ───
    println("")
    println("[F7] Field Update -- writing discovery_field.json + growth_bus")
    write_field_map(field_map)
    append_growth_bus_events(all_results, gauge_results, chains)
    println("  done.")

    // ─── Phase F8: Report ───
    print_report(field_map, targets, all_results, gauge_results, chains)
}

main()
