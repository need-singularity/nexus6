    println("  " + pad_right("Pattern detect", 24) + pad_right("corollary", 14) + pad_right("interference", 14) + pad_right("Goldstone", 14) + pad_right("q-collapse", 14) + "modular forms")
    println("  " + pad_right("Stability", 24) + pad_right("manual", 14) + pad_right("amplitude", 14) + pad_right("field map", 14) + pad_right("decoherence", 14) + "landscape vacua")
