    println("  " + pad_right("Feature", 24) + pad_right("Mk.I", 14) + pad_right("Mk.II", 14) + pad_right("Mk.III", 14) + pad_right("Mk.IV", 14) + "Mk.V")
    println("  " + pad_right("---", 24) + pad_right("---", 14) + pad_right("---", 14) + pad_right("---", 14) + pad_right("---", 14) + "---")
    println("  " + pad_right("Paradigm", 24) + pad_right("brute force", 14) + pad_right("wave/interf", 14) + pad_right("field theory", 14) + pad_right("quantum", 14) + "string theory")
    println("  " + pad_right("Domains", 24) + pad_right("1 manual", 14) + pad_right("1 rotating", 14) + pad_right("N field-guided", 14) + pad_right("superposed", 14) + "compactified")
    println("  " + pad_right("Key insight", 24) + pad_right("scan+evolve", 14) + pad_right("propagation", 14) + pad_right("gauge filter", 14) + pad_right("entanglement", 14) + "T-duality")
