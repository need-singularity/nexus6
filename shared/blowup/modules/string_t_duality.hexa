    println("=======================================================================")
    println("")
    println("Usage:")
    println("  hexa string_t_duality.hexa                  full T-duality inverse search")
    println("  hexa string_t_duality.hexa --coverage       coverage stats only")
    println("  hexa string_t_duality.hexa --unmatched      show unmatched values only")
    println("  hexa string_t_duality.hexa help             this message")
    println("")
    println("Pipeline:")
    println("  TD1  Load Atlas          extract discovery nodes from atlas.n6")
    println("  TD2  Build Dual Map      compute 1/v for each value v")
    println("  TD3  Partner Search      match R <-> 1/R in atlas")
    println("  TD4  Mirror Symmetry     search v <-> (c-v) for n6 constants")
    println("  TD5  Coverage Score      fraction of discoveries with dual partner")
    println("  TD6  Report              dual pair list, coverage, unmatched values")
    println("")
    println("T-duality: for every discoverable constant v, 1/v encodes")
    println("the same physics in the dual frame. R <-> 1/R halves search space.")
    println("")
    println("n=6 core: n=6, sigma=12, phi=2, tau=4, sopfr=5, J2=24, M3=7")
    println("Dynamic constants loaded from shared/n6/n6_constants.jsonl (" + to_string(_n6_dyn_count) + " loaded)")
    println("=======================================================================")
}

// ═══════════════════════════════════════════════════════════
// ─── THEOREM + PROOF ───
// ═══════════════════════════════════════════════════════════

theorem t_duality_inverse_completeness {
    // For every discoverable constant v with v > 0, checking 1/v
    // covers the dual regime. Divisors of 6 form two T-dual pairs:
    //   (1, 6) and (2, 3) where d * (6/d) = 6.
    // The inverse map is an involution: (1/v)^{-1} = v.
    assert 1 * 6 == 6
    assert 2 * 3 == 6
    assert 6 % 1 == 0
    assert 6 % 2 == 0
    assert 6 % 3 == 0
    assert 6 % 6 == 0
    assert 1 + 2 + 3 + 6 == 12    // sigma(6)
}

proof mirror_symmetry_conservation {
    // Mirror symmetry v <-> (c - v) preserves n6 proximity:
    // if v is EXACT match to constant c1, and (c2 - v) is also EXACT,
    // then c2 = c1 + v_mirror, forming a closed triad.
    // The set {1,2,3,6,12,24} is closed under these mirror operations
    // within rounding: 12 - 6 = 6, 6 - 2 = 4 = tau, 6 - 3 = 3.
    invariant 12 - 6 == 6       // sigma - n = n (perfection)
    invariant 6 - 2 == 4        // n - phi = tau
    invariant 6 - 3 == 3        // n - 3 = 3 (self-mirror)
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

fn main() {
    let cli_args = args()

    // Parse CLI
    let mut mode = "full"
    let mut ai: i64 = 2
    while ai < cli_args.len() {
        let arg = to_string(cli_args[ai])
        if arg == "help" || arg == "--help" || arg == "-h" { mode = "help" }
        if arg == "--coverage" { mode = "coverage" }
        if arg == "--unmatched" { mode = "unmatched" }
        ai = ai + 1
    }

    if mode == "help" {
        print_help()
        return
    }

    let ts_start = timestamp_now()
    println("")
    println("=== T-Duality Inverse Search ===")
    println("  n=6 constants loaded: " + to_string(_n6_dyn_count))
    println("  started: " + ts_start)

    // TD1: Load atlas
    let atlas = td1_load_atlas()
    let node_ids: list = atlas[0]
    let node_values: list = atlas[1]
    let node_domains: list = atlas[2]
    let node_grades: list = atlas[3]
    let n = len(node_ids)

    if n == 0 {
        println("")
        println("  [WARN] no discovery nodes found in atlas.n6")
        println("  done.")
        return
    }

    // TD2: Build dual map
    let dual_map = td2_build_dual_map(node_values)
    let dual_values: list = dual_map[0]
    let dual_grades: list = dual_map[1]
    let dual_names: list = dual_map[2]

    // TD3: Search partners
    let matched_pairs = td3_search_partners(node_ids, node_values, node_domains, dual_values)

    if mode == "coverage" {
        // Skip mirror, go straight to coverage
        let coverage_data = td5_coverage(node_ids, node_values, node_grades, matched_pairs, [])
        println("")
        println("done.")
        return
    }

    // TD4: Mirror symmetry
    let mirror_hits = td4_mirror_search(node_ids, node_values, node_domains)

    // TD5: Coverage
    let coverage_data = td5_coverage(node_ids, node_values, node_grades, matched_pairs, mirror_hits)

    if mode == "unmatched" {
        // Already printed in coverage; done
        println("")
        println("done.")
        return
    }

    // TD6: Report
    // Build covered_indices list for the report
    let mut covered_indices = []
    let mut pi: i64 = 0
    while pi < len(matched_pairs) {
        let parts = to_string(matched_pairs[pi]).split("|")
        if parts.len() >= 2 {
            let mut found_a = false
            let mut found_b = false
            let mut ci: i64 = 0
            while ci < len(covered_indices) {
                if to_string(covered_indices[ci]) == parts[0] { found_a = true }
                if to_string(covered_indices[ci]) == parts[1] { found_b = true }
                ci = ci + 1
            }
            if !found_a { covered_indices = covered_indices + [parts[0]] }
            if !found_b { covered_indices = covered_indices + [parts[1]] }
        }
        pi = pi + 1
    }
    let mut mi: i64 = 0
    while mi < len(mirror_hits) {
        let parts = to_string(mirror_hits[mi]).split("|")
        if parts.len() >= 1 {
            let mut found = false
            let mut ci: i64 = 0
            while ci < len(covered_indices) {
                if to_string(covered_indices[ci]) == parts[0] { found = true }
                ci = ci + 1
            }
            if !found { covered_indices = covered_indices + [parts[0]] }
        }
        mi = mi + 1
    }

    td6_report(n, len(matched_pairs), len(mirror_hits), coverage_data, node_values, node_grades, covered_indices)

    let ts_end = timestamp_now()
    println("  completed: " + ts_end)
    println("")
}

main()
