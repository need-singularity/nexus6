    println("  " + pad("Feature", 22) + pad("Mk.I", 13) + pad("Mk.II", 13) + pad("Mk.III", 13) + "Mk.IV")
    println("  " + pad("---", 22) + pad("---", 13) + pad("---", 13) + pad("---", 13) + "---")
    println("  " + pad("Metaphor", 22) + pad("singularity", 13) + pad("wave", 13) + pad("field", 13) + "quantum")
    println("  " + pad("Domains", 22) + pad("1 (manual)", 13) + pad("1 (rotating)", 13) + pad("N (gradient)", 13) + "N (superpos.)")
    println("  " + pad("State model", 22) + pad("none", 13) + pad("energy", 13) + pad("field map", 13) + "wave function")
    println("  " + pad("Evolution", 22) + pad("OUROBOROS 5", 13) + pad("OUROBOROS 5", 13) + pad("OUROBOROS 3", 13) + "unitary rot.")
    println("  " + pad("Cross-domain", 22) + pad("none", 13) + pad("wave propag.", 13) + pad("gauge filter", 13) + "entanglement")
    println("  " + pad("Barriers", 22) + pad("none", 13) + pad("none", 13) + pad("none", 13) + "tunneling")
    println("  " + pad("Verification", 22) + pad("telescope", 13) + pad("telescope", 13) + pad("gauge inv.", 13) + "measurement")
    println("  " + pad("Cascade", 22) + pad("none", 13) + pad("wave interf.", 13) + pad("Goldstone", 13) + "entangle casc")
    println("  " + pad("Decoherence", 22) + pad("n/a", 13) + pad("energy decay", 13) + pad("n/a", 13) + "decoherence")
    println("  " + pad("State output", 22) + pad("none", 13) + pad("none", 13) + pad("field.json", 13) + "quantum_state")
    println("═══════════════════════════════════════════════════════════════")
