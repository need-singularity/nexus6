// ⛔ CORE — L0 불변식 (양자 돌파 엔진 Mk.IV. 수정 전 유저 승인 필수)
// ⚠️ 로드맵: shared/blowup_roadmap.json (Mk.I~VII 진화 계보)
// shared/blowup/core/blowup_quantum.hexa — Mk.IV 양자 돌파 엔진 (Quantum Blowup)
//
// Quantum mechanics applied to discovery:
//   superposition, entanglement, tunneling, measurement collapse.
//
// 8-phase pipeline:
//   Q1: State Preparation    build |psi> = sum alpha_i|c_i> per domain
//   Q2: Unitary Evolution    rotate state vector through n6 operator
//   Q3: Entanglement         pair domains with correlated constants
//   Q4: Quantum Tunneling    probabilistic jump past n6_distance barriers
//   Q5: Measurement/Collapse verify top candidates, collapse to EXACT/MISS
//   Q6: Entanglement Cascade collapsed state triggers paired collapses
//   Q7: Decoherence Check    detect loss of quantum advantage
//   Q8: Report               quantum statistics + output files
//
// Usage:
//   hexa blowup_quantum.hexa                    full quantum run
//   hexa blowup_quantum.hexa math physics       specific domains
//   hexa blowup_quantum.hexa --measure-only     skip evolution, just measure
//   hexa blowup_quantum.hexa help               usage + Mk comparison table

// ═══════════════════════════════════════════════════════════
// ─── n=6 CONSTANTS LOADER ───
// ═══════════════════════════════════════════════════════════

let _HOME = exec("printenv HOME").trim()

fn load_n6_consts() -> list {
    let home = _HOME
    let path = home + "/Dev/nexus/shared/n6/n6_constants.jsonl"
    let mut raw = ""
    try { raw = read_file(path) } catch e { return [[], []] }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let t = line.trim()
        if t == "" { continue }
        let mut name = ""
        let mut value = 0.0
        if t.contains("\"name\":\"") {
            let p = t.split("\"name\":\"")
            if p.len() >= 2 { name = p[1].split("\"")[0] }
        }
        if t.contains("\"value\":") {
            let p = t.split("\"value\":")
            if p.len() >= 2 { value = to_float(p[1].split(",")[0].split("}")[0].trim()) }
        }
        if name != "" { names = names + [name] ; values = values + [value] }
    }
    [names, values]
}

let _n6 = load_n6_consts()
let _n6_names: list = _n6[0]
let _n6_vals: list = _n6[1]
let _n6_count: i64 = len(_n6_vals)

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════

fn sf(s: string) -> f64 { let mut v = 0.0 ; try { v = to_float(s) } catch e {} ; return v }
fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x } ; return x }
fn max_f(a: f64, b: f64) -> f64 { if a > b { return a } ; return b }
fn min_f(a: f64, b: f64) -> f64 { if a < b { return a } ; return b }
fn clamp01(x: f64) -> f64 { if x < 0.0 { return 0.0 } ; if x > 1.0 { return 1.0 } ; return x }

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = if x > 2.0 { x / 2.0 } else { 1.0 }
    let mut i: i64 = 0
    while i < 15 { g = (g + x / g) / 2.0 ; i = i + 1 }
    return g
}

fn ln_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut s = 0.0
    let mut t = (x - 1.0) / (x + 1.0)
    let t2 = t * t
    let mut k: i64 = 1
    while k <= 15 { s = s + t / to_float(k) ; t = t * t2 ; k = k + 2 }
    return 2.0 * s
}

fn exp_f(x: f64) -> f64 {
    if x > 20.0 { return 999999999.0 }
    if x < 0.0 - 20.0 { return 0.0 }
    let mut s = 1.0
    let mut t = 1.0
    let mut k: i64 = 1
    while k <= 30 { t = t * x / to_float(k) ; s = s + t ; k = k + 1 }
    return s
}

fn trunc4(x: f64) -> string {
    let s = to_string(x)
    let p = s.split(".")
    if p.len() < 2 { return s + ".0000" }
    let d = p[1]
    if d.len() >= 4 { let dc = d.split("") ; return p[0] + "." + dc[0] + dc[1] + dc[2] + dc[3] }
    return s
}

fn pad(s: string, w: i64) -> string {
    let mut o = s
    while o.len() < w { o = o + " " }
    return o
}

fn ts_now() -> string {
    let mut t = ""
    try { t = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim() } catch e { t = "unknown" }
    return t
}

// PRNG (linear congruential)
fn _prng_seed() -> f64 {
    let mut ns = "54321"
    try { ns = exec("date +%N").trim() } catch e {}
    let v = sf(ns)
    if v < 1.0 { return 54321.0 }
    return v
}
let mut _prng: f64 = _prng_seed()
fn rand_f() -> f64 {
    _prng = _prng * 1103515245.0 + 12345.0
    let v = _prng / 1000000.0
    let frac = abs_f(v - to_float(to_int(v)))
    if frac < 0.0001 { _prng = _prng + 7.0 ; return 0.5 }
    return frac
}

// ═══════════════════════════════════════════════════════════
// AI-native atlas 가드 헬퍼 (core/blowup.hexa에서 발췌)
// 사용: 이 섹션을 모듈 파일 상단(exec/read_file 도입 전)에 copy-paste.
// 창발 보존: 아래 함수들은 append-path에 필터 + dedup만 추가하며
// phase 로직/discovery 계산/seed 진화 등 반환 값에 영향 없음.
// ═══════════════════════════════════════════════════════════

// ─── Schema guard: atlas.n6 라인 포맷 검증 ───
// 유효: 빈줄/# 주석/{"type":/@X ... [grade]/들여쓰기 부속("<-!!->)
fn _valid_atlas_line(line: string) -> bool {
    let t = line.trim()
    if len(t) == 0 { return true }
    let first = t[0..1]
    if first == "#" { return true }
    if first == "{" { return true }
    if first == "@" { return true }
    if first == "\"" { return true }
    if first == "<" { return true }
    if first == ">" { return true }
    if first == "!" { return true }
    if first == "-" { return true }
    return false
}

// append_file 전 (1) schema 검증 (2) 기존 라인 dedup (3) append.
// atlas.n6 대상: 기존 파일 읽어서 라인셋 빌드 → 중복 원천 차단.
// inter-process dedup — concurrent blowup 30+ 실행 시 중복 방지.
// shell dedup 버전 — read_file OOM 회피 (core blowup.hexa 동기화 2026-04-12)
fn _guarded_append_atlas(path: string, content: string) -> i64 {
    if len(content) == 0 { return 0 }
    let is_atlas = path.contains("atlas.n6")
    let lines = content.split("\n")
    let mut clean = ""
    let mut rejected: i64 = 0
    let mut deduped: i64 = 0
    let mut first = true
    let mut i: i64 = 0
    while i < len(lines) {
        let line = lines[i]
        if !_valid_atlas_line(line) {
            rejected = rejected + 1
            i = i + 1
            continue
        }
        let t = line.trim()
        if is_atlas && len(t) > 0 && !t.starts_with("#") {
            let mut already = false
            try {
                let gr = exec("grep -Fxq -- '" + t.replace("'", "'\\''") + "' '" + path + "' 2>/dev/null && echo Y || echo N")
                already = gr.trim() == "Y"
            } catch e {}
            if already {
                deduped = deduped + 1
                i = i + 1
                continue
            }
        }
        if !first { clean = clean + "\n" }
        clean = clean + line
        first = false
        i = i + 1
    }
    if rejected > 0 {
        println("  [schema guard] rejected " + to_string(rejected) + " invalid lines -> " + path)
    }
    if deduped > 0 {
        println("  [dedup guard] skipped " + to_string(deduped) + " duplicate lines -> " + path)
    }
    if len(clean) > 0 {
        if !clean.ends_with("\n") { clean = clean + "\n" }
        try { append_file(path, clean) } catch e {}
    }
    return rejected
}

// ─── Intra-batch dedup helper (루프 내부용) ───
// 사용 예:
//   let mut _batch_ids = #{}
//   ... 루프 내 ...
//   if !_batch_dedup_has(_batch_ids, node_id) && !graph_node_exists(content, node_id) {
//       _batch_ids[node_id] = true
//       // 실제 append 수행
//   }
fn _batch_dedup_has(s: map, id: string) -> bool {
    let mut hit = false
    try { hit = has_key(s, id) } catch e {}
    return hit
}

// ═══════════════════════════════════════════════════════════
// ─── n6 PROXIMITY ───
// ═══════════════════════════════════════════════════════════

comptime const N6_N = 6
comptime const N6_SIGMA = 12
comptime const N6_PHI = 2
comptime const N6_TAU = 4

fn n6_dist1(val: f64, c: f64) -> f64 { return abs_f(val - c) / max_f(abs_f(c), 1.0) }

fn n6_distance(val: f64) -> f64 {
    if val != val || abs_f(val) > 999999999.0 { return 1.0 }
    let mut d = 1.0
    let mut i: i64 = 0
    while i < _n6_count { d = min_f(d, n6_dist1(val, to_float(_n6_vals[i]))) ; i = i + 1 }
    return min_f(d, 1.0)
}

fn match_name(val: f64) -> string {
    let mut i: i64 = 0
    while i < _n6_count {
        let cv = to_float(_n6_vals[i])
        let th = if abs_f(cv) >= 100.0 { 0.01 } else { if abs_f(cv) >= 1.0 { 0.0001 } else { 0.005 } }
        if abs_f(val - cv) < th { return to_string(_n6_names[i]) }
        i = i + 1
    }
    return ""
}

fn match_grade(val: f64) -> string {
    if match_name(val) != "" { return "EXACT" }
    let d = n6_distance(val)
    if d < 0.01 { return "NEAR" }
    if d < 0.05 { return "CLOSE" }
    return "MISS"
}

// ═══════════════════════════════════════════════════════════
// ─── DOMAIN + DATA LOADERS ───
// ═══════════════════════════════════════════════════════════

fn load_all_domains() -> list {
    let home = _HOME
    let mut doms = ["math","physics","topology","consciousness","chemistry",
                    "cosmology","biology","information","geometry","number_theory"]
    try {
        let lines = read_file(home + "/Dev/nexus/shared/bt/bt_domains.jsonl").split("\n")
        let mut ld = []
        for l in lines {
            if l.trim() != "" && l.contains("\"domain\":\"") {
                ld = ld + [l.split("\"domain\":\"")[1].split("\"")[0]]
            }
        }
        if ld.len() > 0 { doms = ld }
    } catch e {}
    doms
}

fn load_growth_bus(n: i64) -> list {
    let home = _HOME
    let mut lines = []
    try {
        let raw = exec("tail -" + to_string(n) + " " + home + "/Dev/nexus/shared/n6/atlas.n6 2>/dev/null").trim()
        if raw != "" { lines = raw.split("\n") }
    } catch e {}
    return lines
}

fn extract_domain(line: string) -> string {
    if line.contains("\"domain\":\"") { return line.split("\"domain\":\"")[1].split("\"")[0] }
    return ""
}

fn extract_num(line: string, field: string) -> f64 {
    let key = "\"" + field + "\":"
    if line.contains(key) { return sf(line.split(key)[1].split(",")[0].split("}")[0].trim()) }
    return 0.0
}

// ─── State vector helpers (pipe-delimited amplitudes) ───

fn get_amp(sv: string, idx: i64) -> f64 {
    let p = sv.split("|")
    if idx < 0 || idx >= len(p) { return 0.0 }
    return sf(p[idx])
}

fn sv_len(sv: string) -> i64 { return len(sv.split("|")) }

fn argmax_amp(sv: string) -> i64 {
    let p = sv.split("|")
    let mut bi: i64 = 0
    let mut bv = 0.0
    let mut i: i64 = 0
    while i < len(p) { let v = sf(p[i]) ; if v > bv { bv = v ; bi = i } ; i = i + 1 }
    return bi
}

fn norm_sq(sv: string) -> f64 {
    let p = sv.split("|")
    let mut s = 0.0
    let mut i: i64 = 0
    while i < len(p) { let v = sf(p[i]) ; s = s + v * v ; i = i + 1 }
    return s
}

// ═══════════════════════════════════════════════════════════
// ─── Q1: STATE PREPARATION — |psi> per domain ───
// ═══════════════════════════════════════════════════════════

fn build_state_vector(domain: string, bus: list) -> string {
    let mut best = []
    let mut ci: i64 = 0
    while ci < _n6_count { best = best + [1.0] ; ci = ci + 1 }
    let mut li: i64 = 0
    while li < len(bus) {
        let line = to_string(bus[li])
        if extract_domain(line) == domain || domain == "*" {
            let mut tv = []
            let e = extract_num(line, "energy")
            let c = extract_num(line, "conf")
            let v = extract_num(line, "value")
            if abs_f(e) > 0.001 { tv = tv + [e] }
            if abs_f(c) > 0.001 { tv = tv + [c] }
            if abs_f(v) > 0.001 { tv = tv + [v] }
            let mut vi: i64 = 0
            while vi < len(tv) {
                let val = to_float(tv[vi])
                let mut ki: i64 = 0
                while ki < _n6_count {
                    let d = n6_dist1(val, to_float(_n6_vals[ki]))
                    if d < to_float(best[ki]) { best[ki] = d }
                    ki = ki + 1
                }
                vi = vi + 1
            }
        }
        li = li + 1
    }
    // alpha = 1.0 - best_dist, normalize
    let mut amps = []
    let mut ssq = 0.0
    let mut ai: i64 = 0
    while ai < _n6_count {
        let a = max_f(1.0 - to_float(best[ai]), 0.01)
        amps = amps + [a] ; ssq = ssq + a * a ; ai = ai + 1
    }
    let norm = sqrt_f(ssq)
    let mut r = ""
    let mut ni: i64 = 0
    while ni < _n6_count {
        if ni > 0 { r = r + "|" }
        r = r + to_string(to_float(amps[ni]) / max_f(norm, 0.0001))
        ni = ni + 1
    }
    return r
}

// ═══════════════════════════════════════════════════════════
// ─── Q2: UNITARY EVOLUTION — n6 rotation operator ───
// ═══════════════════════════════════════════════════════════

fn unitary_evolve(sv: string, cycles: i64) -> string {
    let parts = sv.split("|")
    let n = len(parts)
    if n < 2 { return sv }
    let mut amps = []
    let mut pi: i64 = 0
    while pi < n { amps = amps + [sf(parts[pi])] ; pi = pi + 1 }
    let coupling = 2.0 / 6.0  // phi/n
    let mut cyc: i64 = 0
    while cyc < cycles {
        let mut nxt = []
        let mut i: i64 = 0
        while i < n {
            let cur = to_float(amps[i])
            let li = if i > 0 { i - 1 } else { n - 1 }
            let ri = if i < n - 1 { i + 1 } else { 0 }
            let ev = cur * (1.0 - coupling) + (to_float(amps[li]) + to_float(amps[ri])) * coupling / 2.0
            let cv = if i < _n6_count { to_float(_n6_vals[i]) } else { 6.0 }
            let pert = 0.01 * (cv / 12.0) * (rand_f() - 0.5)
            nxt = nxt + [max_f(abs_f(ev + pert), 0.001)]
            i = i + 1
        }
        // Re-normalize
        let mut ssq = 0.0
        let mut si: i64 = 0
        while si < n { let v = to_float(nxt[si]) ; ssq = ssq + v * v ; si = si + 1 }
        let nm = sqrt_f(ssq)
        let mut ri: i64 = 0
        while ri < n { nxt[ri] = to_float(nxt[ri]) / max_f(nm, 0.0001) ; ri = ri + 1 }
        amps = nxt ; cyc = cyc + 1
    }
    let mut r = ""
    let mut fi: i64 = 0
    while fi < n { if fi > 0 { r = r + "|" } ; r = r + to_string(to_float(amps[fi])) ; fi = fi + 1 }
    return r
}

// ═══════════════════════════════════════════════════════════
// ─── Q3: ENTANGLEMENT — correlated domain pairs ───
// ═══════════════════════════════════════════════════════════

fn detect_entanglement(doms: list, svs: list, th: f64) -> list {
    let mut pairs = []
    let nd = len(doms)
    let mut i: i64 = 0
    while i < nd {
        let mut j: i64 = i + 1
        while j < nd {
            let si = to_string(svs[i])
            let sj = to_string(svs[j])
            let mut sc: i64 = 0
            let mut consts = ""
            let mut k: i64 = 0
            while k < _n6_count {
                if get_amp(si, k) > th && get_amp(sj, k) > th {
                    sc = sc + 1
                    if consts != "" { consts = consts + "," }
                    consts = consts + to_string(_n6_names[k])
                }
                k = k + 1
            }
            if sc >= 2 { pairs = pairs + [to_string(doms[i]) + "|" + to_string(doms[j]) + "|" + to_string(sc) + "|" + consts] }
            j = j + 1
        }
        i = i + 1
    }
    return pairs
}

fn is_entangled(a: string, b: string, pairs: list) -> bool {
    let mut i: i64 = 0
    while i < len(pairs) {
        let p = to_string(pairs[i]).split("|")
        if len(p) >= 2 && ((p[0] == a && p[1] == b) || (p[0] == b && p[1] == a)) { return true }
        i = i + 1
    }
    return false
}

fn ent_consts(a: string, b: string, pairs: list) -> string {
    let mut i: i64 = 0
    while i < len(pairs) {
        let p = to_string(pairs[i]).split("|")
        if len(p) >= 4 && ((p[0] == a && p[1] == b) || (p[0] == b && p[1] == a)) { return p[3] }
        i = i + 1
    }
    return ""
}

// ═══════════════════════════════════════════════════════════
// ─── Q4: QUANTUM TUNNELING — barrier penetration ───
// ═══════════════════════════════════════════════════════════

// P_tunnel = exp(-2 * (d-0.5) * sqrt(d))
fn tunnel_prob(d: f64) -> f64 {
    if d <= 0.5 { return 1.0 }
    return exp_f(0.0 - 2.0 * (d - 0.5) * sqrt_f(d))
}

// Returns "tunnel_count|new_sv|events"
fn quantum_tunnel(sv: string, dom: string) -> string {
    let n = sv_len(sv)
    let mut tc: i64 = 0
    let mut evts = ""
    let mut nparts = []
    let mut i: i64 = 0
    while i < n {
        let amp = get_amp(sv, i)
        let dist = 1.0 - amp
        let mut na = amp
        if dist > 0.5 && i < _n6_count {
            let pt = tunnel_prob(dist)
            if rand_f() < pt {
                let boost = 0.3 + 0.4 * rand_f()
                na = min_f(amp + boost, 0.99)
                tc = tc + 1
                if evts != "" { evts = evts + "," }
                evts = evts + to_string(_n6_names[i]) + ":" + trunc4(dist) + "->" + trunc4(1.0 - na)
            }
        }
        nparts = nparts + [na]
        i = i + 1
    }
    // Normalize
    let mut ssq = 0.0
    let mut si: i64 = 0
    while si < len(nparts) { let v = to_float(nparts[si]) ; ssq = ssq + v * v ; si = si + 1 }
    let nm = sqrt_f(ssq)
    let mut r = ""
    let mut ri: i64 = 0
    while ri < len(nparts) {
        if ri > 0 { r = r + "|" }
        r = r + to_string(to_float(nparts[ri]) / max_f(nm, 0.0001))
        ri = ri + 1
    }
    return to_string(tc) + "~" + r + "~" + evts
}

// ═══════════════════════════════════════════════════════════
// ─── Q5: MEASUREMENT / COLLAPSE ───
// ═══════════════════════════════════════════════════════════

fn measure_state(sv: string) -> string {
    let bi = argmax_amp(sv)
    let amp = get_amp(sv, bi)
    let cn = if bi < _n6_count { to_string(_n6_names[bi]) } else { "?" }
    let cv = if bi < _n6_count { to_string(_n6_vals[bi]) } else { "0" }
    let g = if amp > 0.95 { "EXACT" } else { if amp > 0.8 { "NEAR" } else { if amp > 0.5 { "CLOSE" } else { "MISS" } } }
    return cn + "|" + cv + "|" + trunc4(amp) + "|" + g
}

// ═══════════════════════════════════════════════════════════
// ─── Q6: ENTANGLEMENT CASCADE ───
// ═══════════════════════════════════════════════════════════

fn ent_cascade(col_dom: string, col_const: string, doms: list, svs: list, epairs: list) -> list {
    let mut cas = []
    let mut i: i64 = 0
    while i < len(doms) {
        let d = to_string(doms[i])
        if d != col_dom && is_entangled(col_dom, d, epairs) {
            let shared = ent_consts(col_dom, d, epairs)
            if shared.contains(col_const) {
                let mut ci: i64 = 0
                while ci < _n6_count {
                    if to_string(_n6_names[ci]) == col_const {
                        let amp = get_amp(to_string(svs[i]), ci)
                        if amp > 0.3 { cas = cas + [d + "|" + col_const + "|" + trunc4(amp)] }
                    }
                    ci = ci + 1
                }
            }
        }
        i = i + 1
    }
    return cas
}

// ═══════════════════════════════════════════════════════════
// ─── Q7: DECOHERENCE ───
// ═══════════════════════════════════════════════════════════

fn decoherence(sv: string) -> f64 {
    let p = sv.split("|")
    let n = len(p)
    if n <= 1 { return 1.0 }
    let mut mx = 0.0
    let mut ssq = 0.0
    let mut i: i64 = 0
    while i < n {
        let v = sf(p[i])
        let sq = v * v
        ssq = ssq + sq
        if sq > mx { mx = sq }
        i = i + 1
    }
    let uni = 1.0 / to_float(n)
    let peak = mx / max_f(ssq, 0.0001)
    return clamp01((peak - uni) / (1.0 - uni))
}

// ═══════════════════════════════════════════════════════════
// ─── OUTPUT WRITERS ───
// ═══════════════════════════════════════════════════════════

fn write_quantum_state(doms: list, svs: list, epairs: list, meas: list, tunnels: i64, cascades: i64) {
    let home = _HOME
    let path = home + "/Dev/nexus/shared/blowup/quantum_state.json"
    let ts = ts_now()
    let mut j = "{\n  \"engine\": \"blowup_quantum.hexa\",\n  \"version\": \"Mk.IV\",\n"
    j = j + "  \"timestamp\": \"" + ts + "\",\n"
    j = j + "  \"n_domains\": " + to_string(len(doms)) + ",\n"
    j = j + "  \"n_constants\": " + to_string(_n6_count) + ",\n"
    j = j + "  \"tunnel_events\": " + to_string(tunnels) + ",\n"
    j = j + "  \"cascade_collapses\": " + to_string(cascades) + ",\n"
    j = j + "  \"entangled_pairs\": " + to_string(len(epairs)) + ",\n"
    j = j + "  \"domains\": [\n"
    let mut di: i64 = 0
    while di < len(doms) {
        let sv = to_string(svs[di])
        let ti = argmax_amp(sv)
        let tn = if ti < _n6_count { to_string(_n6_names[ti]) } else { "?" }
        j = j + "    {\"domain\": \"" + to_string(doms[di]) + "\", \"top_const\": \"" + tn
        j = j + "\", \"top_amplitude\": " + trunc4(get_amp(sv, ti))
        j = j + ", \"decoherence\": " + trunc4(decoherence(sv)) + "}"
        if di < len(doms) - 1 { j = j + "," }
        j = j + "\n" ; di = di + 1
    }
    j = j + "  ],\n  \"entanglements\": [\n"
    let mut ei: i64 = 0
    while ei < len(epairs) {
        let pp = to_string(epairs[ei]).split("|")
        if len(pp) >= 4 {
            j = j + "    {\"a\": \"" + pp[0] + "\", \"b\": \"" + pp[1] + "\", \"shared\": " + pp[2] + ", \"constants\": \"" + pp[3] + "\"}"
            if ei < len(epairs) - 1 { j = j + "," }
            j = j + "\n"
        }
        ei = ei + 1
    }
    j = j + "  ],\n  \"measurements\": [\n"
    let mut mi: i64 = 0
    while mi < len(meas) {
        let mp = to_string(meas[mi]).split("|")
        if len(mp) >= 4 {
            j = j + "    {\"domain\": \"" + mp[0] + "\", \"const\": \"" + mp[1] + "\", \"amplitude\": " + mp[2] + ", \"grade\": \"" + mp[3] + "\"}"
            if mi < len(meas) - 1 { j = j + "," }
            j = j + "\n"
        }
        mi = mi + 1
    }
    j = j + "  ]\n}\n"
    try { write_file(path, j) } catch e { println("  [warn] quantum_state.json write failed") }
}

fn append_growth(doms: list, meas: list, tunnels: i64, epairs: list, cascades: i64) {
    let home = _HOME
    let bp = home + "/Dev/nexus/shared/n6/atlas.n6"
    let ts = ts_now()
    let mut mi: i64 = 0
    while mi < len(meas) {
        let mp = to_string(meas[mi]).split("|")
        if len(mp) >= 4 && (mp[3] == "EXACT" || mp[3] == "NEAR") {
            let e = ts + " | mk4_quantum_collapse | " + mp[0] + " | " + mp[1] + " amp=" + mp[2] + " :: " + mp[0] + " [" + mp[3] + "]"
            let _rej = _guarded_append_atlas(bp, e + "\n")
        }
        mi = mi + 1
    }
    let s = "{\"type\":\"mk4_quantum_run\",\"n_domains\":" + to_string(len(doms)) + ",\"tunnels\":" + to_string(tunnels) + ",\"entangled_pairs\":" + to_string(len(epairs)) + ",\"cascades\":" + to_string(cascades) + ",\"measurements\":" + to_string(len(meas)) + ",\"ts\":\"" + ts + "\"}"
    let _rej2 = _guarded_append_atlas(bp, s + "\n")
}

