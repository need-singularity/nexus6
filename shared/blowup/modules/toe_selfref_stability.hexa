    println("=======================================================================")
    println("")
    println("Usage:")
    println("  hexa toe_selfref_stability.hexa                full stability analysis")
    println("  hexa toe_selfref_stability.hexa --iterate      fixed-point iteration only")
    println("  hexa toe_selfref_stability.hexa --lyapunov     Lyapunov exponent only")
    println("  hexa toe_selfref_stability.hexa help           this message")
    println("")
