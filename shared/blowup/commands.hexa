// ─── 빈공간 DFS 탐색 (EXPLORE_EMPTY) ───

fn handle_explore_empty(c: Classification) {
    print_header("EXPLORE_EMPTY", "empty space DFS")

    // 1. gap_finder scan
    let gap_finder_path = engine_dir + "/gap_finder.hexa"
    let mut gap_result = ""
    try {
        gap_result = exec(hexa_bin, [gap_finder_path, "scan"])  // @allow-bare-exec
    } catch e {  // @allow-silent-catch
        gap_result = "ERROR: gap_finder — " + to_string(e)
    }
    println("|  [gap_finder scan]")
    print_result(gap_result)
    println("|")

    // 2. deep_scan explore (6중 탐색)
    let deep_scan_path = engine_dir + "/deep_scan.hexa"
    let mut deep_result = ""
    try {
        deep_result = exec(hexa_bin, [deep_scan_path, "explore"])  // @allow-bare-exec
    } catch e {  // @allow-silent-catch
        deep_result = "ERROR: deep_scan — " + to_string(e)
    }
    println("|  [deep_scan explore]")
    print_result(deep_result)
    println("|")

    // 3. n6 위상변환: 빈공간 값을 n6 기저로 변환 시도
    println("|  [n6 위상변환 — 빈공간 → 기저(σ,φ,τ,n,sopfr,M3)]")
    // n6_constants.jsonl에서 동적 로드
    let n6c = load_n6_constants()
    let sigma = n6c[0]   // sigma
    let phi = n6c[1]     // phi
    let tau = n6c[2]     // tau
    let n = n6c[3]       // n
    let sopfr = n6c[4]   // sopfr
    let m3 = n6c[5]      // M3

    // gap 결과에서 빈 상수/도메인 추출 시도
    let gap_lines = gap_result.split("\n")
    let mut transform_count = 0
    for gl in gap_lines {
        let trimmed = gl.trim()
        if trimmed == "" { continue }
        // 숫자가 포함된 줄에서 값 추출
        let tokens = trimmed.split(" ")
        for tok in tokens {
            let t = tok.trim().replace(",", "").replace(":", "")
            if t == "" { continue }
            let first = t[0]
            if first == "0" || first == "1" || first == "2" || first == "3" || first == "4" || first == "5" || first == "6" || first == "7" || first == "8" || first == "9" {
                // 간이 n6 기저 변환
                if transform_count < 10 {
                    println("|    gap_value " + t + " → σ/φ = " + to_string(sigma) + "/" + to_string(phi) + " = 6, τ+sopfr = " + to_string(tau) + "+" + to_string(sopfr) + " = 9")
                    transform_count = transform_count + 1
                }
                break
            }
        }
    }
    if transform_count == 0 {
        println("|    (변환 대상 없음 — gap 결과에서 수치 미검출)")
    }

    print_footer()
    log_cmd("EXPLORE_EMPTY", "gap+deep+n6", "ok")
}

// ─── 다음 돌파 방향 제시 (NEXT_BREAKTHROUGH) ───

fn handle_next_breakthrough(c: Classification) {
    print_header("NEXT_BREAKTHROUGH", "direction recommendation")

    // 1. discovery_log 최근 50건에서 도메인 빈도 추출
    let _h_cmd = exec("printenv HOME").trim()  // @allow-bare-exec
    let log_path = _h_cmd + "/Dev/nexus/shared/n6/atlas.n6"
    let raw_log = read_file_safe(log_path)
    let mut domain_counts = []    // [[domain, count], ...]
    let mut domain_names = []

    if raw_log != "" {
        let log_lines = raw_log.split("\n")
        // 최근 50건만 (뒤에서)
        let total = log_lines.len()
        let start_idx = if total > 50 { total - 50 } else { 0 }
        let mut idx = 0
        for ll in log_lines {
            if idx >= start_idx && ll.trim() != "" {
                // domain 필드 추출
                if ll.contains("\"domain\":\"") {
                    let dp = ll.split("\"domain\":\"")
                    if dp.len() >= 2 {
                        let dname = dp[1].split("\"")[0]
                        // 카운트 증가
                        let mut found = false
                        let mut di = 0
                        while di < domain_names.len() {
                            if domain_names[di] == dname {
                                domain_counts[di] = domain_counts[di] + 1
                                found = true
                            }
                            di = di + 1
                        }
                        if !found {
                            domain_names = domain_names + [dname]
                            domain_counts = domain_counts + [1]
                        }
                    }
                }
            }
            idx = idx + 1
        }
    }

    // 2. gap_finder scan에서 미커버 도메인 추출
    let gap_finder_path = engine_dir + "/gap_finder.hexa"
    let mut gap_result = ""
    try {
        gap_result = exec(hexa_bin, [gap_finder_path, "scan"])  // @allow-bare-exec
    } catch e {  // @allow-silent-catch
        gap_result = ""
    }

    let mut gap_domains = []
    if gap_result != "" {
        let gap_lines = gap_result.split("\n")
        for gl in gap_lines {
            let trimmed = gl.trim()
            if trimmed != "" {
                // domain 키워드 추출
                if trimmed.contains("domain") || trimmed.contains("gap") || trimmed.contains("uncovered") {
                    // 도메인명 추출 시도
                    if trimmed.contains("\"") {
                        let parts = trimmed.split("\"")
                        let mut pi = 0
                        for p in parts {
                            if p != "" && p != "domain" && p != ":" && p != "gap" && p.len() > 2 {
                                let mut already = false
                                for gd in gap_domains {
                                    if gd == p { already = true }
                                }
                                if !already {
                                    gap_domains = gap_domains + [p]
                                }
                            }
                            pi = pi + 1
                        }
                    }
                }
            }
        }
    }

    // 3. 결과 출력
    println("|")
    println("|  +" + pad_right("", 48) + "+")
    println("|  | 다음 돌파 방향" + pad_right("", 33) + "|")
    println("|  +" + pad_right("", 48) + "+")

    let mut rec_num = 1

    // 활발한 도메인 (최근 발견 빈도 상위)
    let mut best_idx = -1
    let mut best_count = 0
    let mut di = 0
    while di < domain_names.len() {
        if domain_counts[di] > best_count {
            best_count = domain_counts[di]
            best_idx = di
        }
        di = di + 1
    }
    if best_idx >= 0 {
        println("|  | " + to_string(rec_num) + ". [" + domain_names[best_idx] + "] — 근거: 최근 " + to_string(best_count) + "건 발견" + pad_right("", 5) + "|")
        rec_num = rec_num + 1
    }

    // 빈공간 도메인
    if gap_domains.len() > 0 {
        println("|  | " + to_string(rec_num) + ". [" + gap_domains[0] + "] — 근거: 빈공간 " + to_string(gap_domains.len()) + "개" + pad_right("", 8) + "|")
        rec_num = rec_num + 1
    }

    // 교차수분 후보: 활발 + 빈공간 조합
    if best_idx >= 0 && gap_domains.len() > 0 {
        let cross_name = domain_names[best_idx] + " x " + gap_domains[0]
        println("|  | " + to_string(rec_num) + ". [" + cross_name + "] — 근거: 교차수분 가능" + pad_right("", 3) + "|")
        rec_num = rec_num + 1
    }

    // 추천이 하나도 없을 경우
    if rec_num == 1 {
        println("|  | (discovery_log / gap_finder 데이터 부족)" + pad_right("", 6) + "|")
    }

    println("|  +" + pad_right("", 48) + "+")
    println("|")

    print_footer()
    log_cmd("NEXT_BREAKTHROUGH", "direction", "ok")
}

// ─── TODO: shared/blowup/todo.hexa 자연창발 ───

fn handle_todo(c: Classification) {
    let target = c.project
    print_header("TODO", if target == "" { "all projects" } else { target })
    let todo_path = shared_dir + "/blowup/todo.hexa"
    let mut output = ""
    try {
        if target == "" {
            output = exec(hexa_bin, [todo_path])  // @allow-bare-exec
        } else {
            output = exec(hexa_bin, [todo_path, target])  // @allow-bare-exec
        }
    } catch e {  // @allow-silent-catch
        output = "ERROR: todo.hexa — " + to_string(e)
    }
    print_result(output)
    print_footer()
    log_cmd("TODO", if target == "" { "all" } else { target }, "ok")
}

// ─── GO: 100% 골화 수렴 루프 (go_loop.hexa, 백그라운드) ───

fn handle_go(c: Classification) {
    print_header("GO", "go_loop — 100% ossification")
    let go_loop_path = engine_dir + "/go_loop.hexa"
    let cmd = hexa_bin + " " + go_loop_path + " >> " + log_file + " 2>&1 &"
    try { exec("bash", ["-c", cmd]) } catch e {}  // @allow-bare-exec  // @allow-silent-catch
    print_bg_notice("go_loop.hexa")
    print_footer()
    log_cmd("GO", "go_loop", "dispatched_bg")
}

// ─── CLI 진입점 ───

let a = args()
let input = if a.len() >= 3 { a[2] } else { "help" }

let c = classify(input)

if c.category == "STATUS_ALL" {
    handle_status_all(c)
} else if c.category == "STATUS_ONE" {
    handle_status_one(c)
} else if c.category == "BREAKTHROUGH" {
    handle_breakthrough(c)
} else if c.category == "CROSSFEED" {
    handle_crossfeed(c)
} else if c.category == "H100" {
    handle_h100(c)
} else if c.category == "ABSORB" {
    handle_absorb(c)
} else if c.category == "GROWTH" {
    handle_growth(c)
} else if c.category == "GAP" {
    handle_gap(c)
} else if c.category == "ALIEN" {
    handle_alien(c)
} else if c.category == "TICK" {
    handle_tick(c)
} else if c.category == "CYCLE" {
    handle_cycle(c)
} else if c.category == "CHECK" {
    handle_check(c)
} else if c.category == "EXPLORE" {
    handle_explore(c)
} else if c.category == "DIRECTION" {
    handle_direction(c)
} else if c.category == "EXPLORE_EMPTY" {
    handle_explore_empty(c)
} else if c.category == "NEXT_BREAKTHROUGH" {
    handle_next_breakthrough(c)
} else if c.category == "SEED" {
    handle_seed(c)
} else if c.category == "AUDIT" {
    handle_audit(c)
} else if c.category == "VERIFY" {
    handle_verify(c)
} else if c.category == "BRIDGE" {
    handle_bridge(c)
} else if c.category == "HEAL" {
    handle_heal(c)
} else if c.category == "HISTORY" {
    handle_history(c)
} else if c.category == "RED_TEAM" {
    handle_red_team(c)
} else if c.category == "DSE_CROSS" {
    handle_dse_cross(c)
} else if c.category == "SONAR" {
    if c.verb == "sonar_strike" { handle_sonar_strike(c) }
    else { handle_sonar(c) }
} else if c.category == "WAVE" {
    if c.verb == "wave_cross" { handle_wave_cross(c) }
    else { handle_wave(c) }
} else if c.category == "TODO" {
    handle_todo(c)
} else if c.category == "GO" {
    handle_go(c)
} else if c.category == "HELP" {
    handle_help()
} else {
    handle_help()
}
