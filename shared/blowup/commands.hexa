// ⛔ CORE — L0 불변식 (24종 명령 라우터. 수정 전 유저 승인 필수)
// @no-lock-needed
// command_router.hexa -- nexus 중앙 지휘 라우터
// 자연어 입력 -> 3단 게이트 파싱 -> 모듈 디스패치 -> 결과 출력
// 사용: hexa command_router.hexa "<자연어 입력>"
// 예시: hexa command_router.hexa "anima 상태"
//       hexa command_router.hexa "전체 리포트"
//       hexa command_router.hexa "수학 돌파"

comptime const version = "2.0.0"

// ─── 경로 설정 (env 기반, 하드코딩 금지) ───

let home = exec("printenv HOME")  // @allow-bare-exec
let dev = home + "/Dev"
let hexa_bin = dev + "/hexa-lang/hexa"
let shared_dir = dev + "/nexus/shared"
let engine_dir = shared_dir + "/blowup"
let project_engine_dir = shared_dir + "/engine"
let aliases_file = shared_dir + "/cmd_aliases.jsonl"
let domains_file = shared_dir + "/bt_domains.jsonl"
let projects_file = shared_dir + "/projects.json"
let project_aliases_file = shared_dir + "/project_aliases.jsonl"
let n6_constants_file = shared_dir + "/n6_constants.jsonl"
let log_file = shared_dir + "/cmd_router.log"

// ─── 유틸 (선행 정의) ───

fn read_file_safe(path: string) -> string {
    try {
        return read_file(path)
    } catch e {  // @allow-silent-catch
        return ""
    }
}

// ─── 프로젝트 레지스트리 (projects.json에서 동적 로드) ───

fn load_projects() {
    // projects.json에서 "projects" 키 아래의 각 프로젝트를 파싱
    // 각 키가 display name, "root" 필드가 internal name
    let raw = read_file_safe(projects_file)
    if raw == "" { return [[], []] }
    let mut names = []
    let mut displays = []
    // "root": "..." 패턴으로 internal name 추출
    // 각 프로젝트 블록: "DISPLAY": { "root": "NAME", ...
    // 간이 파싱: "projects" 섹션에서 최상위 키 + root 필드 추출
    let lines = raw.split("\n")
    let mut in_projects = false
    let mut brace_depth = 0
    let mut current_display = ""
    for line in lines {
        let trimmed = line.trim()
        // "projects": { 진입
        if trimmed.contains("\"projects\"") && trimmed.contains("{") {
            in_projects = true
            brace_depth = 0
            continue
        }
        if !in_projects { continue }
        // 중괄호 깊이 추적 (문자열 직접 순회 불가 → count 방식)
        let open_count = trimmed.split("{").len() - 1
        let close_count = trimmed.split("}").len() - 1
        brace_depth = brace_depth + open_count - close_count
        // depth 1에서 키 발견 = 프로젝트명 (display)
        if brace_depth == 1 && trimmed.contains("\":") && !trimmed.contains("\"root\"") {
            // "TECS-L": { 패턴
            let parts = trimmed.split("\"")
            if parts.len() >= 2 {
                let key = parts[1]
                if key != "" && key != "_meta" && !key.contains("_comment") {
                    current_display = key
                }
            }
        }
        // "root": "..." 패턴
        if trimmed.contains("\"root\":") && current_display != "" {
            let rp = trimmed.split("\"root\":")
            if rp.len() >= 2 {
                let rv = rp[1].trim()
                let rp2 = rv.split("\"")
                if rp2.len() >= 2 {
                    let root_name = rp2[1]
                    // root를 _로 정규화 (- → _)
                    let internal = root_name.replace("-", "_").replace("/", "_")
                    names = names + [internal]
                    displays = displays + [current_display]
                    current_display = ""
                }
            }
        }
        // projects 블록 종료
        if brace_depth <= 0 && in_projects && names.len() > 0 {
            break
        }
    }
    [names, displays]
}

let _proj_data = load_projects()
let project_names = if _proj_data.len() >= 2 && _proj_data[0].len() > 0 { _proj_data[0] } else { [] }
let project_display = if _proj_data.len() >= 2 && _proj_data[1].len() > 0 { _proj_data[1] } else { [] }

// ─── 유틸 ───

fn timestamp() -> string {
    exec("date +%Y-%m-%dT%H:%M:%S").trim()  // @allow-bare-exec
}

fn pad_right(s: string, width: int) -> string {
    let mut out = s
    while out.len() < width { out = out + " " }
    out
}

fn log_cmd(classification: string, target: string, result_summary: string) {
    let ts = timestamp()
    let line = "{\"ts\":\"" + ts + "\",\"class\":\"" + classification + "\",\"target\":\"" + target + "\",\"result\":\"" + result_summary + "\"}"
    try { append_file(log_file, line + "\n") } catch e {}  // @allow-silent-catch
}

// ─── Gate 1: cmd_aliases.jsonl 에서 명령 동사 매칭 ───

struct AliasEntry {
    verb: string,
    aliases: list,
    category: string
}

fn cmd_to_category(cmd: string) -> string {
    // cmd_aliases.jsonl의 "category" 필드에서 동적 매핑
    let raw = read_file_safe(aliases_file)
    if raw != "" {
        let lines = raw.split("\n")
        for line in lines {
            if line.trim() == "" { continue }
            // cmd 필드 매칭
            let mut line_cmd = ""
            if line.contains("\"cmd\":\"") {
                let p = line.split("\"cmd\":\"")
                if p.len() >= 2 {
                    line_cmd = p[1].split("\"")[0]
                }
            }
            if line_cmd == cmd {
                // category 필드 추출
                if line.contains("\"category\":\"") {
                    let cp = line.split("\"category\":\"")
                    if cp.len() >= 2 {
                        return cp[1].split("\"")[0]
                    }
                }
            }
        }
    }
    "HELP"
}

fn load_aliases() {
    let raw = read_file_safe(aliases_file)
    if raw == "" { return [] }
    let lines = raw.split("\n")
    let mut entries = []
    for line in lines {
        if line.trim() != "" {
            // 간이 JSON 파싱 (split 기반) — cmd_aliases.jsonl 형식:
            // {"cmd":"status","keywords":["상태","status",...]}
            let mut cmd = ""
            let mut aliases = []

            // cmd 필드
            if line.contains("\"cmd\":\"") {
                let p = line.split("\"cmd\":\"")
                if p.len() >= 2 {
                    cmd = p[1].split("\"")[0]
                }
            }
            // keywords 배열
            if line.contains("\"keywords\":[") {
                let p = line.split("\"keywords\":[")
                if p.len() >= 2 {
                    let body = p[1].split("]")[0]
                    let items = body.split(",")
                    for item in items {
                        let clean = item.trim().replace("\"", "")
                        if clean != "" {
                            aliases = aliases + [clean]
                        }
                    }
                }
            }
            if cmd != "" {
                let category = cmd_to_category(cmd)
                entries = entries + [AliasEntry { verb: cmd, aliases: aliases, category: category }]
            }
        }
    }
    entries
}

fn match_verb(input: string, entries) -> string {
    // 정확한 카테고리 매칭 — 가장 긴 별칭부터 매칭 (다어절 우선)
    let lower = input
    let mut best_cat = ""
    let mut best_len = 0
    for entry in entries {
        for alias in entry.aliases {
            if lower.contains(alias) && alias.len() > best_len {
                best_cat = entry.category
                best_len = alias.len()
            }
        }
    }
    best_cat
}

// ─── Gate 2: 프로젝트명 매칭 ───

fn load_project_aliases() {
    // shared/config/project_aliases.jsonl에서 [[alias, project], ...] 동적 로드
    let raw = read_file_safe(project_aliases_file)
    if raw == "" { return [] }
    let lines = raw.split("\n")
    let mut pairs = []
    for line in lines {
        if line.trim() == "" { continue }
        let mut alias_val = ""
        let mut project_val = ""
        if line.contains("\"alias\":\"") {
            let p = line.split("\"alias\":\"")
            if p.len() >= 2 {
                alias_val = p[1].split("\"")[0]
            }
        }
        if line.contains("\"project\":\"") {
            let p = line.split("\"project\":\"")
            if p.len() >= 2 {
                project_val = p[1].split("\"")[0]
            }
        }
        if alias_val != "" && project_val != "" {
            pairs = pairs + [[alias_val, project_val]]
        }
    }
    pairs
}

fn match_project(input: string) -> string {
    let lower = input
    // project_aliases.jsonl에서 동적 매핑 (자연어 → 내부명)
    let aliases_map = load_project_aliases()
    let mut best_name = ""
    let mut best_len = 0
    for pair in aliases_map {
        let alias = pair[0]
        let name = pair[1]
        if lower.contains(alias) && alias.len() > best_len {
            best_name = name
            best_len = alias.len()
        }
    }
    best_name
}

// ─── n6 상수 로더 (n6_constants.jsonl에서 동적 로드) ───

fn load_n6_constants() {
    // [sigma, phi, tau, n, sopfr, M3] 순서로 반환
    // 기본값 (파일 로드 실패 시 방어)
    let mut sigma = 12
    let mut phi = 2
    let mut tau = 4
    let mut n_val = 6
    let mut sopfr = 5
    let mut m3 = 3

    let raw = read_file_safe(n6_constants_file)
    if raw != "" {
        let lines = raw.split("\n")
        for line in lines {
            if line.trim() == "" { continue }
            let mut name = ""
            let mut value = 0
            // name 필드
            if line.contains("\"name\":\"") {
                let p = line.split("\"name\":\"")
                if p.len() >= 2 {
                    name = p[1].split("\"")[0]
                }
            }
            // value 필드 (정수)
            if line.contains("\"value\":") {
                let p = line.split("\"value\":")
                if p.len() >= 2 {
                    let num_str = p[1].split(",")[0].split("}")[0].trim()
                    value = to_int(num_str)
                }
            }
            if name == "sigma" { sigma = value }
            if name == "phi" { phi = value }
            if name == "tau" { tau = value }
            if name == "n" { n_val = value }
            if name == "sopfr" { sopfr = value }
            if name == "M3" { m3 = value }
        }
    }
    return [sigma, phi, tau, n_val, sopfr, m3]
}

// ─── Gate 3: bt_domains.jsonl 에서 도메인 키워드 매칭 ───

fn match_domain(input: string) -> string {
    let raw = read_file_safe(domains_file)
    if raw == "" { return "math" }
    let lines = raw.split("\n")
    let lower = input
    let mut best_domain = ""
    let mut best_len = 0

    for line in lines {
        if line.trim() != "" {
            let mut d_name = ""
            if line.contains("\"domain\":\"") {
                let p = line.split("\"domain\":\"")
                if p.len() >= 2 {
                    d_name = p[1].split("\"")[0]
                }
            }
            if d_name != "" {
                if line.contains("\"keywords\":[") {
                    let kw_parts = line.split("\"keywords\":[")
                    if kw_parts.len() >= 2 {
                        let kw_body = kw_parts[1].split("]")[0]
                        let kw_items = kw_body.split(",")
                        for kp in kw_items {
                            let kw_clean = kp.trim().replace("\"", "")
                            if kw_clean != "" && lower.contains(kw_clean) && kw_clean.len() > best_len {
                                best_domain = d_name
                                best_len = kw_clean.len()
                            }
                        }
                    }
                }
            }
        }
    }
    if best_domain == "" { "math" } else { best_domain }
}

// ─── 분류 엔진 (3단 게이트 결합) ───

struct Classification {
    category: string,   // STATUS_ALL, STATUS_ONE, BREAKTHROUGH, ...
    project: string,    // 프로젝트명 (없으면 "")
    domain: string,     // 도메인 (없으면 "math")
    raw_input: string
}

// shared/blowup/ 단독 처리: cmd_aliases.jsonl 우회 — 짧은 메시지 직접 매칭
fn match_short_verb(input: string) -> string {
    let t = input.trim()
    // 정확 매칭 (한 토큰)
    if t == "todo" || t == "할일" || t == "할 일" { return "TODO" }
    if t == "go" || t == "ㄱㄱ" || t == "ㄱㅏ" { return "GO" }
    // 부분 매칭 (구문 안에 포함) — 가장 흔한 표현만
    if t.contains("작업목록") || t.contains("작업 목록") || t.contains("플랜") { return "TODO" }
    if t.contains("진행상황") || t.contains("진행 상황") || t.contains("progress") { return "TODO" }
    if t.contains("골화루프") || t.contains("수렴루프") || t.contains("go_loop") { return "GO" }
    ""
}

fn classify(input: string) -> Classification {
    let entries = load_aliases()
    let verb_cat = match_verb(input, entries)
    let short_cat = match_short_verb(input)
    let project = match_project(input)
    let domain = match_domain(input)

    // "전체" 키워드 체크
    let is_all = input.contains("전체") || input.contains("all") || input.contains("모든")

    let mut category = ""

    // 짧은 메시지 우선 처리 (cmd_aliases.jsonl 미등록 명령)
    if short_cat == "TODO" {
        category = "TODO"
    } else if short_cat == "GO" {
        category = "GO"
    }
    // 분류 로직: 동사 카테고리 + 프로젝트 존재 여부로 최종 결정
    else if verb_cat == "STATUS" && is_all {
        category = "STATUS_ALL"
    } else if verb_cat == "STATUS" && project != "" {
        category = "STATUS_ONE"
    } else if verb_cat == "STATUS" {
        category = "STATUS_ALL"
    } else if verb_cat == "BREAKTHROUGH" && (input.contains("다음") || input.contains("방향") || input.contains("제시") || input.contains("next") || domain == "next_breakthrough") {
        category = "NEXT_BREAKTHROUGH"
    } else if verb_cat == "BREAKTHROUGH" {
        category = "BREAKTHROUGH"
    } else if verb_cat == "CROSSFEED" {
        category = "CROSSFEED"
    } else if verb_cat == "H100" {
        category = "H100"
    } else if verb_cat == "ABSORB" {
        category = "ABSORB"
    } else if verb_cat == "GROWTH" {
        category = "GROWTH"
    } else if verb_cat == "GAP" {
        category = "GAP"
    } else if verb_cat == "ALIEN" {
        category = "ALIEN"
    } else if verb_cat == "TICK" && project != "" {
        category = "TICK"
    } else if verb_cat == "TICK" {
        category = "STATUS_ALL"
    } else if verb_cat == "CYCLE" {
        category = "CYCLE"
    } else if verb_cat == "CHECK" {
        category = "CHECK"
    } else if verb_cat == "EXPLORE" {
        category = "EXPLORE"
    } else if verb_cat == "DIRECTION" {
        category = "DIRECTION"
    } else if verb_cat == "EXPLORE_EMPTY" {
        category = "EXPLORE_EMPTY"
    } else if domain == "next_breakthrough" {
        category = "NEXT_BREAKTHROUGH"
    } else if domain == "hexa_direction" && verb_cat == "" {
        category = "DIRECTION"
    } else if domain == "empty_space" && verb_cat == "" {
        category = "EXPLORE_EMPTY"
    } else if verb_cat == "SEED" {
        category = "SEED"
    } else if verb_cat == "AUDIT" {
        category = "AUDIT"
    } else if verb_cat == "VERIFY" {
        category = "VERIFY"
    } else if verb_cat == "BRIDGE" {
        category = "BRIDGE"
    } else if verb_cat == "HEAL" {
        category = "HEAL"
    } else if verb_cat == "HISTORY" {
        category = "HISTORY"
    } else if verb_cat == "RED_TEAM" {
        category = "RED_TEAM"
    } else if verb_cat == "DSE_CROSS" {
        category = "DSE_CROSS"
    } else if verb_cat == "HELP" {
        category = "HELP"
    } else if project != "" {
        // 동사 없이 프로젝트명만 → 상태 조회
        category = "STATUS_ONE"
    } else {
        category = "HELP"
    }

    Classification {
        category: category,
        project: project,
        domain: domain,
        raw_input: input
    }
}

// ─── 결과 포맷터 ───

fn print_header(classification: string, target: string) {
    println("")
    println("+" + pad_right("", 46) + "+")
    println("|  NEXUS COMMAND" + pad_right("", 32) + "|")
    println("|  " + pad_right("cmd: " + classification, 44) + "|")
    println("|  " + pad_right("target: " + target, 44) + "|")
    println("+" + pad_right("", 46) + "+")
}

fn print_footer() {
    println("+" + pad_right("", 46) + "+")
    println("")
}

fn print_result(output: string) {
    let lines = output.split("\n")
    for line in lines {
        println("|  " + line)
    }
}

fn print_bg_notice(module: string) {
    println("|  >> background dispatch: " + module)
    println("|  >> log: shared/logs/cmd_router.log")
}

// ─── 결과 정규화 (텍스트→JSON) ───

fn extract_number_after(text: string, keyword: string) -> string {
    // keyword 뒤의 첫 번째 숫자(정수 또는 소수)를 추출
    if !text.contains(keyword) { return "" }
    let parts = text.split(keyword)
    if parts.len() < 2 { return "" }
    let after = parts[1].trim()
    // ": N" 또는 "= N" 또는 " N" 패턴
    let clean = after.replace(":", " ").replace("=", " ").trim()
    let tokens = clean.split(" ")
    for tok in tokens {
        let t = tok.trim().replace(",", "").replace("%", "")
        if t == "" { continue }
        // 숫자인지 확인 (첫 문자가 0-9 또는 .)
        let first = t[0]
        if first == "0" || first == "1" || first == "2" || first == "3" || first == "4" || first == "5" || first == "6" || first == "7" || first == "8" || first == "9" || first == "." {
            return t
        }
    }
    ""
}

fn normalize_result(raw: string) -> string {
    // 비표준 텍스트에서 discoveries, laws, health 숫자 추출
    let mut discoveries = extract_number_after(raw, "discover")
    if discoveries == "" { discoveries = extract_number_after(raw, "found") }
    if discoveries == "" { discoveries = extract_number_after(raw, "발견") }

    let mut laws = extract_number_after(raw, "law")
    if laws == "" { laws = extract_number_after(raw, "rule") }
    if laws == "" { laws = extract_number_after(raw, "법칙") }

    let mut health = extract_number_after(raw, "health")
    if health == "" { health = extract_number_after(raw, "상태") }
    if health == "" { health = extract_number_after(raw, "score") }

    // 숫자 기본값
    let d_val = if discoveries != "" { discoveries } else { "0" }
    let l_val = if laws != "" { laws } else { "0" }
    let h_val = if health != "" { health } else { "0.0" }

    // raw 문자열 JSON escape: backslash 먼저, 그 다음 quote + 줄바꿈 제거
    let safe_raw = raw.replace("\\", "\\\\").replace("\"", "'").replace("\n", " ").replace("\r", "")
    // 200자로 자르기
    let truncated = if safe_raw.len() > 200 { safe_raw.substring(0, 200) } else { safe_raw }

    "{\"discoveries\":" + d_val + ",\"laws\":" + l_val + ",\"health\":" + h_val + ",\"raw\":\"" + truncated + "\"}"
}

// ─── 디스패치 (동기) ───

fn dispatch_sync(module: string, mode: string) -> string {
    let path = engine_dir + "/" + module
    let mut result = ""
    try {
        result = exec(hexa_bin, [path, mode])  // @allow-bare-exec
    } catch e {  // @allow-silent-catch
        result = "ERROR: " + to_string(e)
    }

    // 결과 정규화 + 구조화 로그 기록
    let normalized = normalize_result(result)
    let ts = timestamp()
    let structured_log = "{\"ts\":\"" + ts + "\",\"module\":\"" + module + "\",\"mode\":\"" + mode + "\",\"result\":" + normalized + "}"
    try { append_file(log_file, structured_log + "\n") } catch e {}  // @allow-silent-catch

    result
}

// ─── 디스패치 (비동기 — 장시간 명령) ───

fn dispatch_async(module: string, mode: string, extra_args: string) {
    let path = engine_dir + "/" + module
    let cmd = hexa_bin + " " + path + " " + mode + " " + extra_args + " >> " + log_file + " 2>&1 &"
    try {
        exec("bash", ["-c", cmd])  // @allow-bare-exec
    } catch e {}  // @allow-silent-catch
}

// ─── 명령별 실행 핸들러 ───

fn handle_status_all(c: Classification) {
    print_header("STATUS_ALL", "all projects")
    let output = dispatch_sync("nexus_hub.hexa", "report")
    print_result(output)
    print_footer()
    log_cmd("STATUS_ALL", "all", "ok")
}

fn handle_status_one(c: Classification) {
    let target = c.project
    print_header("STATUS_ONE", target)
    let path = project_engine_dir + "/engine_" + target + ".hexa"
    let mut output = ""
    try { output = exec(hexa_bin, [path, "status"]) } catch e { output = "ERROR: " + to_string(e) }  // @allow-bare-exec  // @allow-silent-catch
    print_result(output)
    print_footer()
    log_cmd("STATUS_ONE", target, "ok")
}

fn handle_breakthrough(c: Classification) {
    let domain = c.domain
    print_header("BREAKTHROUGH", domain)

    // seed 취득
    let mut seeds = ""
    try {
        seeds = exec(hexa_bin, [engine_dir + "/seed/seed_engine.hexa", "merge"]).trim()  // @allow-bare-exec
    } catch e {}  // @allow-silent-catch

    let extra = if seeds != "" { "--no-graph --seeds \"" + seeds + "\"" } else { "--no-graph" }

    // 비동기 실행 (장시간)
    dispatch_async("core/blowup.hexa", domain + " 3", extra)
    print_bg_notice("blowup.hexa " + domain)
    print_footer()
    log_cmd("BREAKTHROUGH", domain, "dispatched_bg")
}

