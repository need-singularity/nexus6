// shared/blowup/core/lenses_math.hexa — 37 math lenses ported from mk1 Rust
// Uses LensResult, ScanEntry, result_add, empty_result, abs_f, sqrt_f, ln_f,
// sanitize, list_mean, list_variance, list_sort from telescope.hexa
//
// Lenses (37):
//  1. finance          2. fisher_geometric    3. fission
//  4. flash_attention   5. formula_combination 6. fractal
//  7. frequency_dependent 8. frustration       9. fusion
// 10. gene_network     11. gods_eye           12. golden_ratio
// 13. golden_zone      14. gradient           15. graph
// 16. gravity_mk2      17. harmonic_series    18. heat_conduction
// 19. hexagonal        20. hexameter          21. holonomy_group
// 22. infinite_discovery 23. infinity          24. info
// 25. inverse          26. isogeny_walk       27. isometry_group
// 28. isomorphism      29. k_theory           30. kaleidoscope
// 31. kernel_fusion    32. kernel_method_geometry 33. keyword
// 34. lattice_basis    35. lattice_congruence 36. lattice_field
// 37. lens_discovery

// ─── 공용 상수 + 헬퍼 (lens_common.hexa.inc copy-paste) ───
// source: shared/blowup/lens/lens_common.hexa.inc

comptime const phi_golden = 1.618033988749895
comptime const pi_approx = 3.14159265358979
comptime const e_approx = 2.71828182845905
comptime const n6     = 6.0
comptime const sigma6 = 12.0
comptime const tau6   = 4.0
comptime const phi6   = 2.0
comptime const sopfr6 = 5.0

pure fn min_f(a: float, b: float) -> float { if a < b { a } else { b } }
pure fn max_f(a: float, b: float) -> float { if a > b { a } else { b } }
pure fn clamp_f(v: float, lo: float, hi: float) -> float { min_f(max_f(v, lo), hi) }
pure fn to_int(x: float) -> int {
    if x >= 0.0 { int(x) } else { 0 - int(0.0 - x) }
}

pure fn list_min(data) -> float {
    if data.len() == 0 { return 0.0 }
    let mut m = data[0]
    let mut i = 1
    while i < data.len() {
        if data[i] < m { m = data[i] }
        i = i + 1
    }
    m
}

pure fn list_max(data) -> float {
    if data.len() == 0 { return 0.0 }
    let mut m = data[0]
    let mut i = 1
    while i < data.len() {
        if data[i] > m { m = data[i] }
        i = i + 1
    }
    m
}

pure fn list_sum(data) -> float {
    let mut s = 0.0
    for v in data { s = s + v }
    s
}

pure fn list_std(data, mean: float) -> float {
    sqrt_f(list_variance(data, mean))
}

pure fn autocorr_lag(data, lag: int) -> float {
    let mean = list_mean(data)
    let mut cov = 0.0
    let mut var = 0.0
    let mut i = 0
    while i < data.len() - lag {
        let d0 = data[i] - mean
        let d1 = data[i + lag] - mean
        cov = cov + d0 * d1
        var = var + d0 * d0
        i = i + 1
    }
    if var > 0.000000000001 { cov / var } else { 0.0 }
}

pure fn cosine_sim(a, b) -> float {
    let n = if a.len() < b.len() { a.len() } else { b.len() }
    let mut dot = 0.0
    let mut na = 0.0
    let mut nb = 0.0
    let mut i = 0
    while i < n {
        dot = dot + a[i] * b[i]
        na = na + a[i] * a[i]
        nb = nb + b[i] * b[i]
        i = i + 1
    }
    if na > 0.000000000001 && nb > 0.000000000001 { dot / (sqrt_f(na) * sqrt_f(nb)) } else { 0.0 }
}

pure fn pairwise_dist(data, i: int, j: int) -> float {
    abs_f(data[i] - data[j])
}

// Shannon entropy on a list of floats (histogram-based, ~16 bins)
pure fn shannon_entropy(data) -> float {
    if data.len() < 2 { return 0.0 }
    let sorted = list_sort(data)
    let mut bins = []
    let mut counts = []
    let mut current = sorted[0]
    let mut count = 1
    let mut i = 1
    while i < sorted.len() {
        if abs_f(sorted[i] - current) < 0.01 {
            count = count + 1
        } else {
            bins = bins + [current]
            counts = counts + [count]
            current = sorted[i]
            count = 1
        }
        i = i + 1
    }
    bins = bins + [current]
    counts = counts + [count]
    let total = to_float(data.len())
    let mut ent = 0.0
    for c in counts {
        let p = to_float(c) / total
        if p > 0.0 { ent = ent - p * ln_f(p) }
    }
    ent
}

// ─── (1) finance ───

fn scan_finance(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // returns (volatility, mean_reversion, momentum, sharpe_ratio)
    let mean = list_mean(data)
    let std = list_std(data, mean)
    let volatility = if abs_f(mean) > 0.000000000001 { std / abs_f(mean) } else { 0.0 }
    r = result_add(r, "volatility", [volatility])

    // mean reversion: lag-1 autocorrelation of returns
    let mut returns = []
    let mut i = 1
    while i < data.len() {
        returns = returns + [data[i] - data[i - 1]]
        i = i + 1
    }
    if returns.len() > 2 {
        let ac = autocorr_lag(returns, 1)
        r = result_add(r, "mean_reversion", [ac])
    }

    // momentum: sum of signs of returns
    let mut pos = 0
    let mut neg = 0
    for ret in returns {
        if ret > 0.0 { pos = pos + 1 } else if ret < 0.0 { neg = neg + 1 }
    }
    let momentum = to_float(pos - neg) / max_f(to_float(returns.len()), 1.0)
    r = result_add(r, "momentum", [momentum])

    // sharpe ratio proxy
    let ret_mean = list_mean(returns)
    let ret_std = list_std(returns, ret_mean)
    let sharpe = if ret_std > 0.000000000001 { ret_mean / ret_std } else { 0.0 }
    r = result_add(r, "sharpe_ratio", [sharpe])
    r
}

// ─── (2) fisher_geometric ───

fn scan_fisher_geometric(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // fitness landscape: gaussian fitness from centroid distance
    let mean = list_mean(data)
    let mut fitness_vals = []
    let mut total_fitness = 0.0
    for v in data {
        let dist = abs_f(v - mean)
        let f = exp_approx(0.0 - dist * dist / (2.0 * n6))
        fitness_vals = fitness_vals + [f]
        total_fitness = total_fitness + f
    }
    let mean_fitness = total_fitness / to_float(data.len())
    r = result_add(r, "mean_fitness", [mean_fitness])

    // beneficial mutation fraction: count where perturbed fitness > original
    let mut beneficial = 0
    let mut i = 0
    while i < data.len() {
        let perturbed = data[i] + 0.1
        let f_orig = fitness_vals[i]
        let d2 = abs_f(perturbed - mean)
        let f_new = exp_approx(0.0 - d2 * d2 / (2.0 * n6))
        if f_new > f_orig { beneficial = beneficial + 1 }
        i = i + 1
    }
    let p_ben = to_float(beneficial) / to_float(data.len())
    r = result_add(r, "p_beneficial", [p_ben])
    r
}

pure fn exp_approx(x: float) -> float {
    // e^x via exp(x) = e^(x) approximation using ln inverse
    // exp(x) ~ 1 + x + x^2/2 + x^3/6 + x^4/24 + x^5/120
    let cx = clamp_f(x, -20.0, 20.0)
    let mut sum = 1.0
    let mut term = cx
    sum = sum + term
    term = term * cx / 2.0
    sum = sum + term
    term = term * cx / 3.0
    sum = sum + term
    term = term * cx / 4.0
    sum = sum + term
    term = term * cx / 5.0
    sum = sum + term
    term = term * cx / 6.0
    sum = sum + term
    term = term * cx / 7.0
    sum = sum + term
    term = term * cx / 8.0
    sum = sum + term
    if sum < 0.0 { 0.0 } else { sum }
}

// ─── (3) fission ───

fn scan_fission(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // detect splitting: find gaps in sorted data that split into fragments
    let sorted = list_sort(data)
    let mean = list_mean(data)
    let std = list_std(data, mean)
    let threshold = max_f(std * 0.5, 0.01)

    let mut fragments = 1
    let mut max_gap = 0.0
    let mut gap_positions = []
    let mut i = 1
    while i < sorted.len() {
        let gap = sorted[i] - sorted[i - 1]
        if gap > threshold {
            fragments = fragments + 1
            gap_positions = gap_positions + [to_float(i)]
        }
        if gap > max_gap { max_gap = gap }
        i = i + 1
    }
    r = result_add(r, "fragment_count", [to_float(fragments)])
    r = result_add(r, "fission_energy", [max_gap])

    // mass asymmetry
    if fragments > 1 && gap_positions.len() > 0 {
        let split_idx = to_int(gap_positions[0])
        let mass1 = to_float(split_idx)
        let mass2 = to_float(data.len() - split_idx)
        let asymmetry = abs_f(mass1 - mass2) / (mass1 + mass2)
        r = result_add(r, "mass_asymmetry", [asymmetry])
    }
    r
}

// ─── (4) flash_attention ───

fn scan_flash_attention(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    // soft attention: A[i][j] = exp(-|d_i - d_j|^2 / bw)
    let std = list_std(data, list_mean(data))
    let bw = max_f(std * std * 2.0, 0.01)
    let n = data.len()

    // block sparsity: partition into blocks of ~sqrt(n)
    let block_size = max_f(sqrt_f(to_float(n)), 2.0)
    let bs = to_int(block_size)

    // attention entropy per row (sample first 50)
    let mut total_entropy = 0.0
    let sample = if n < 50 { n } else { 50 }
    let mut i = 0
    while i < sample {
        let mut row_sum = 0.0
        let mut weights = []
        let mut j = 0
        while j < n {
            let diff = data[i] - data[j]
            let w = exp_approx(0.0 - diff * diff / bw)
            weights = weights + [w]
            row_sum = row_sum + w
            j = j + 1
        }
        // entropy of attention distribution
        let mut ent = 0.0
        if row_sum > 0.000000000001 {
            for w in weights {
                let p = w / row_sum
                if p > 0.000000000001 { ent = ent - p * ln_f(p) }
            }
        }
        total_entropy = total_entropy + ent
        i = i + 1
    }
    let mean_ent = total_entropy / to_float(sample)
    r = result_add(r, "mean_attention_entropy", [mean_ent])

    // causal ratio: lower-triangular attention mass
    let mut causal = 0.0
    let mut total = 0.0
    i = 0
    while i < sample {
        let mut j = 0
        while j < n {
            let diff = data[i] - data[j]
            let w = exp_approx(0.0 - diff * diff / bw)
            total = total + w
            if j <= i { causal = causal + w }
            j = j + 1
        }
        i = i + 1
    }
    let causal_ratio = if total > 0.000000000001 { causal / total } else { 0.5 }
    r = result_add(r, "causal_ratio", [causal_ratio])
    let flash_score = (1.0 - mean_ent / max_f(ln_f(to_float(n)), 1.0)) * 0.5 + causal_ratio * 0.5
    r = result_add(r, "flash_score", [flash_score])
    r
}

// ─── (5) formula_combination ───

fn scan_formula_combination(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // find linear, ratio, power relations between consecutive pairs
    let mut linear_count = 0
    let mut ratio_count = 0
    let mut power_count = 0
    let mut i = 0
    while i < data.len() - 1 {
        let a = data[i]
        let b = data[i + 1]
        // linear: b ≈ k*a for small integer k
        if abs_f(a) > 0.000000000001 {
            let ratio = b / a
            let rounded = to_float(to_int(ratio + 0.5))
            if abs_f(ratio - rounded) < 0.05 && abs_f(rounded) <= 12.0 {
                linear_count = linear_count + 1
            }
            // ratio near n6 constants
            if abs_f(ratio - n6) < 0.3 || abs_f(ratio - sigma6) < 0.5 || abs_f(ratio - phi6) < 0.1 {
                ratio_count = ratio_count + 1
            }
        }
        // power: ln(b)/ln(a) ≈ integer
        if a > 0.01 && b > 0.01 {
            let la = ln_f(a)
            let lb = ln_f(b)
            if abs_f(la) > 0.01 {
                let exp_ratio = lb / la
                let er = to_float(to_int(exp_ratio + 0.5))
                if abs_f(exp_ratio - er) < 0.1 && er >= 2.0 && er <= 6.0 {
                    power_count = power_count + 1
                }
            }
        }
        i = i + 1
    }
    r = result_add(r, "linear_relations", [to_float(linear_count)])
    r = result_add(r, "ratio_relations", [to_float(ratio_count)])
    r = result_add(r, "power_relations", [to_float(power_count)])
    r
}

// ─── (6) fractal ───

fn scan_fractal(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 8 { return r }
    // correlation dimension via correlation integral C(r)
    let n = if data.len() < 100 { data.len() } else { 100 }
    // compute all pairwise distances
    let mut dists = []
    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            dists = dists + [abs_f(data[i] - data[j])]
            j = j + 1
        }
        i = i + 1
    }
    let sorted_d = list_sort(dists)
    let max_d = if sorted_d.len() > 0 { sorted_d[sorted_d.len() - 1] } else { 1.0 }
    if max_d < 0.000000000001 { return r }

    // correlation integral at multiple scales
    let mut log_r = []
    let mut log_c = []
    let total_pairs = to_float(sorted_d.len())
    let mut scale = 0.1
    while scale <= 1.0 {
        let radius = max_d * scale
        // count pairs within radius
        let mut count = 0
        for d in sorted_d {
            if d <= radius { count = count + 1 }
        }
        let c = to_float(count) / total_pairs
        if c > 0.0 && radius > 0.0 {
            log_r = log_r + [ln_f(radius)]
            log_c = log_c + [ln_f(c)]
        }
        scale = scale + 0.1
    }

    // linear regression: slope = correlation dimension
    if log_r.len() >= 3 {
        let n_pts = to_float(log_r.len())
        let sx = list_sum(log_r)
        let sy = list_sum(log_c)
        let mut sxy = 0.0
        let mut sxx = 0.0
        let mut k = 0
        while k < log_r.len() {
            sxy = sxy + log_r[k] * log_c[k]
            sxx = sxx + log_r[k] * log_r[k]
            k = k + 1
        }
        let denom = n_pts * sxx - sx * sx
        if abs_f(denom) > 0.000000000001 {
            let dim = (n_pts * sxy - sx * sy) / denom
            r = result_add(r, "correlation_dimension", [dim])
        }
    }
    r
}

// ─── (7) frequency_dependent ───

fn scan_frequency_dependent(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // classify into 6 phenotype bins, measure frequency distribution
    let sorted = list_sort(data)
    let lo = sorted[0]
    let hi = sorted[sorted.len() - 1]
    let range = hi - lo
    if range < 0.000000000001 { return r }

    let mut bins = [0, 0, 0, 0, 0, 0]
    for v in data {
        let idx = to_int((v - lo) / range * 5.999)
        let ci = if idx < 0 { 0 } else if idx > 5 { 5 } else { idx }
        bins[ci] = bins[ci] + 1
    }
    let mut freqs = []
    let total = to_float(data.len())
    for b in bins { freqs = freqs + [to_float(b) / total] }
    r = result_add(r, "phenotype_freqs", freqs)

    // entropy of distribution (uniformity)
    let mut ent = 0.0
    for f in freqs {
        if f > 0.0 { ent = ent - f * ln_f(f) }
    }
    let max_ent = ln_f(6.0)
    let uniformity = if max_ent > 0.0 { ent / max_ent } else { 0.0 }
    r = result_add(r, "frequency_uniformity", [uniformity])

    // cyclic dominance: check if sequential bins have alternating high/low
    let mut cyclic = 0
    let mut k = 0
    while k < 5 {
        if (freqs[k] > freqs[k + 1] && k > 0 && freqs[k - 1] < freqs[k]) || (freqs[k] < freqs[k + 1] && k > 0 && freqs[k - 1] > freqs[k]) {
            cyclic = cyclic + 1
        }
        k = k + 1
    }
    r = result_add(r, "cyclic_dominance", [to_float(cyclic)])
    r
}

// ─── (8) frustration ───

fn scan_frustration(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    let n = if data.len() < 60 { data.len() } else { 60 }
    // median distance as threshold
    let mut dists = []
    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            dists = dists + [abs_f(data[i] - data[j])]
            j = j + 1
        }
        i = i + 1
    }
    let sorted_d = list_sort(dists)
    let median = if sorted_d.len() > 0 { sorted_d[sorted_d.len() / 2] } else { 1.0 }

    // count frustrated triangles: exactly 2 short edges
    let mut frustrated = 0
    let mut total_tri = 0
    let mut energy = 0.0
    i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            let mut k = j + 1
            while k < n {
                let dij = abs_f(data[i] - data[j])
                let djk = abs_f(data[j] - data[k])
                let dik = abs_f(data[i] - data[k])
                let mut short = 0
                let mut long_d = 0.0
                let mut short_sum = 0.0
                if dij < median {
                    short = short + 1
                    short_sum = short_sum + dij
                } else { long_d = max_f(long_d, dij) }
                if djk < median {
                    short = short + 1
                    short_sum = short_sum + djk
                } else { long_d = max_f(long_d, djk) }
                if dik < median {
                    short = short + 1
                    short_sum = short_sum + dik
                } else { long_d = max_f(long_d, dik) }
                total_tri = total_tri + 1
                if short == 2 {
                    frustrated = frustrated + 1
                    energy = energy + abs_f(long_d - short_sum / 2.0)
                }
                k = k + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    let frust_index = if total_tri > 0 { to_float(frustrated) / to_float(total_tri) } else { 0.0 }
    r = result_add(r, "frustration_index", [frust_index])
    r = result_add(r, "frustration_energy", [energy])
    r
}

// ─── (9) fusion ───

fn scan_fusion(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    let n = if data.len() < 200 { data.len() } else { 200 }
    // fusion rate: close pairs (dist < mean*0.3)
    let mut total_dist = 0.0
    let mut pair_count = 0
    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            total_dist = total_dist + abs_f(data[i] - data[j])
            pair_count = pair_count + 1
            j = j + 1
        }
        i = i + 1
    }
    let mean_dist = if pair_count > 0 { total_dist / to_float(pair_count) } else { 1.0 }
    let threshold = mean_dist * 0.3

    let mut fused = 0
    i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            if abs_f(data[i] - data[j]) < threshold { fused = fused + 1 }
            j = j + 1
        }
        i = i + 1
    }
    let fusion_rate = if pair_count > 0 { to_float(fused) / to_float(pair_count) } else { 0.0 }
    r = result_add(r, "fusion_rate", [fusion_rate])

    // confinement: std / mean_dist (tight = well confined)
    let mean = list_mean(data)
    let std = list_std(data, mean)
    let confinement = if mean_dist > 0.000000000001 { std / mean_dist } else { 0.0 }
    r = result_add(r, "confinement", [confinement])

    // ignition: fusion_rate > 0.15 (Lawson criterion proxy)
    let ignition = if fusion_rate > 0.15 { 1.0 } else { 0.0 }
    r = result_add(r, "ignition", [ignition])
    r
}

// ─── (10) gene_network ───

fn scan_gene_network(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // 6-gene circuit: use first 6 values as expression levels
    let g = if data.len() < 6 { data.len() } else { 6 }
    let mut expressions = []
    let mut i = 0
    while i < g {
        expressions = expressions + [data[i]]
        i = i + 1
    }

    // pairwise correlation → regulatory interaction
    let mut edges = 0
    let mut i = 0
    while i < g {
        let mut j = i + 1
        while j < g {
            // correlation proxy: both above or below mean
            let mean = list_mean(expressions)
            let ai = expressions[i] - mean
            let aj = expressions[j] - mean
            if ai * aj > 0.0 { edges = edges + 1 }  // co-regulated
            j = j + 1
        }
        i = i + 1
    }
    let connectivity = to_float(edges) / to_float(g * (g - 1) / 2)
    r = result_add(r, "network_connectivity", [connectivity])

    // feed-forward loops: A→B, A→C, B→C
    let ffl_score = if connectivity > 0.5 { connectivity * connectivity } else { 0.0 }
    r = result_add(r, "feed_forward_loop_score", [ffl_score])

    // robustness: variance of expression (low var = robust)
    let mean = list_mean(expressions)
    let var = list_variance(expressions, mean)
    let robustness = 1.0 / (1.0 + var)
    r = result_add(r, "robustness", [robustness])
    r
}

// ─── (11) gods_eye ───

fn scan_gods_eye(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // global coherence: 1 - (mean_dist / max_dist)
    let mut dist_sum = 0.0
    let mut max_dist = 0.0
    let mut pair_count = 0
    let n = if data.len() < 200 { data.len() } else { 200 }
    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            let d = abs_f(data[i] - data[j])
            dist_sum = dist_sum + d
            if d > max_dist { max_dist = d }
            pair_count = pair_count + 1
            j = j + 1
        }
        i = i + 1
    }
    let mean_dist = if pair_count > 0 { dist_sum / to_float(pair_count) } else { 0.0 }
    let coherence = if max_dist > 0.000000000001 { 1.0 - mean_dist / max_dist } else { 1.0 }
    r = result_add(r, "global_coherence", [coherence])

    // hidden order: compare global entropy vs local entropy
    let global_ent = shannon_entropy(data)
    // local entropy: first half vs second half average
    let mid = data.len() / 2
    let mut first_half = []
    let mut second_half = []
    i = 0
    while i < mid {
        first_half = first_half + [data[i]]
        i = i + 1
    }
    while i < data.len() {
        second_half = second_half + [data[i]]
        i = i + 1
    }
    let local_avg_ent = (shannon_entropy(first_half) + shannon_entropy(second_half)) / 2.0
    let hidden_order = if local_avg_ent > 0.000000000001 { max_f(0.0, 1.0 - global_ent / local_avg_ent) } else { 0.0 }
    r = result_add(r, "hidden_order", [hidden_order])

    // destiny convergence: check if data converges to a single attractor
    let last_quarter = data.len() * 3 / 4
    let mut tail = []
    i = last_quarter
    while i < data.len() {
        tail = tail + [data[i]]
        i = i + 1
    }
    let tail_var = list_variance(tail, list_mean(tail))
    let full_var = list_variance(data, list_mean(data))
    let convergence = if full_var > 0.000000000001 { 1.0 - tail_var / full_var } else { 0.0 }
    r = result_add(r, "destiny_convergence", [convergence])
    r
}

// ─── (12) golden_ratio ───

fn scan_golden_ratio(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // count consecutive ratios near phi = 1.618...
    let mut phi_matches = 0
    let mut ratio_count = 0
    let mut i = 1
    while i < data.len() {
        let prev = abs_f(data[i - 1])
        let curr = abs_f(data[i])
        if prev > 0.000000000001 {
            let ratio = curr / prev
            ratio_count = ratio_count + 1
            if abs_f(ratio - phi_golden) < 0.08 || abs_f(ratio - 1.0 / phi_golden) < 0.05 {
                phi_matches = phi_matches + 1
            }
        }
        i = i + 1
    }
    let phi_score = if ratio_count > 0 { to_float(phi_matches) / to_float(ratio_count) } else { 0.0 }
    r = result_add(r, "phi_ratio_score", [phi_score])

    // fibonacci check: a[i] ≈ a[i-1] + a[i-2]
    let mut fib_count = 0
    i = 2
    while i < data.len() {
        let expected = data[i - 1] + data[i - 2]
        if abs_f(expected) > 0.000000000001 {
            let rel_err = abs_f(data[i] - expected) / abs_f(expected)
            if rel_err < 0.05 { fib_count = fib_count + 1 }
        }
        i = i + 1
    }
    let fib_score = to_float(fib_count) / max_f(to_float(data.len() - 2), 1.0)
    r = result_add(r, "fibonacci_score", [fib_score])
    r
}

// ─── (13) golden_zone ───

fn scan_golden_zone(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // golden zone: [1/e - ln(4/3)/2, 1/e + ln(4/3)/2] ≈ [0.224, 0.512]
    let center = 1.0 / e_approx  // 0.368
    let width = 0.28768          // ln(4/3)
    let zone_lo = center - width / 2.0
    let zone_hi = center + width / 2.0

    // normalize to [0,1]
    let lo = list_min(data)
    let hi = list_max(data)
    let range = hi - lo
    let mut in_zone = 0
    let mut boltzmann = 0
    let mut mertens = 0
    for v in data {
        let norm = if range > 0.000000000001 { (v - lo) / range } else { 0.5 }
        if norm >= zone_lo && norm <= zone_hi { in_zone = in_zone + 1 }
        if abs_f(norm - center) < 0.03 { boltzmann = boltzmann + 1 }
        if abs_f(norm - width) < 0.03 { mertens = mertens + 1 }
    }
    let total = to_float(data.len())
    r = result_add(r, "golden_zone_fraction", [to_float(in_zone) / total])
    r = result_add(r, "boltzmann_match", [to_float(boltzmann) / total])
    r = result_add(r, "mertens_match", [to_float(mertens) / total])
    r
}

// ─── (14) gradient ───

fn scan_gradient(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }
    // first differences (gradient)
    let mut grad = []
    let mut i = 1
    while i < data.len() {
        grad = grad + [data[i] - data[i - 1]]
        i = i + 1
    }
    // second differences (acceleration)
    let mut accel = []
    i = 1
    while i < grad.len() {
        accel = accel + [grad[i] - grad[i - 1]]
        i = i + 1
    }

    let grad_mean = list_mean(grad)
    let grad_std = list_std(grad, grad_mean)
    r = result_add(r, "mean_gradient", [grad_mean])
    r = result_add(r, "gradient_stability", [if grad_std > 0.000000000001 { abs_f(grad_mean) / grad_std } else { 0.0 }])

    if accel.len() > 0 {
        let accel_mean = list_mean(accel)
        r = result_add(r, "mean_acceleration", [accel_mean])
    }

    // sign change rate
    let mut sign_changes = 0
    i = 1
    while i < grad.len() {
        if (grad[i] > 0.0 && grad[i - 1] < 0.0) || (grad[i] < 0.0 && grad[i - 1] > 0.0) {
            sign_changes = sign_changes + 1
        }
        i = i + 1
    }
    let scr = to_float(sign_changes) / max_f(to_float(grad.len() - 1), 1.0)
    r = result_add(r, "sign_change_rate", [scr])
    r
}

// ─── (15) graph ───

fn scan_graph(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }
    let n = if data.len() < 100 { data.len() } else { 100 }
    // build proximity graph via median distance threshold
    let mut all_dists = []
    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            all_dists = all_dists + [abs_f(data[i] - data[j])]
            j = j + 1
        }
        i = i + 1
    }
    let sorted_d = list_sort(all_dists)
    let median = if sorted_d.len() > 0 { sorted_d[sorted_d.len() / 2] } else { 1.0 }

    // adjacency + degree
    let mut degrees = []
    i = 0
    while i < n {
        let mut deg = 0
        let mut j = 0
        while j < n {
            if i != j && abs_f(data[i] - data[j]) < median { deg = deg + 1 }
            j = j + 1
        }
        degrees = degrees + [to_float(deg)]
        i = i + 1
    }
    let mean_deg = list_mean(degrees)
    r = result_add(r, "mean_degree", [mean_deg])

    // clustering coefficient: for each node, fraction of neighbor pairs that are connected
    let mut total_cc = 0.0
    i = 0
    while i < n {
        let mut neighbors = []
        let mut j = 0
        while j < n {
            if i != j && abs_f(data[i] - data[j]) < median { neighbors = neighbors + [j] }
            j = j + 1
        }
        let k = neighbors.len()
        if k >= 2 {
            let mut connected = 0
            let mut a = 0
            while a < k {
                let mut b = a + 1
                while b < k {
                    if abs_f(data[neighbors[a]] - data[neighbors[b]]) < median {
                        connected = connected + 1
                    }
                    b = b + 1
                }
                a = a + 1
            }
            total_cc = total_cc + to_float(connected * 2) / to_float(k * (k - 1))
        }
        i = i + 1
    }
    let avg_cc = total_cc / to_float(n)
    r = result_add(r, "clustering_coefficient", [avg_cc])
    r
}

// ─── (16) gravity_mk2 ───

fn scan_gravity_mk2(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    // density peak detection via mean-shift proxy
    let mean = list_mean(data)
    let std = list_std(data, mean)
    let bandwidth = max_f(std, 0.01)

    // density at each point: sum of gaussian kernel weights
    let n = if data.len() < 200 { data.len() } else { 200 }
    let mut densities = []
    let mut i = 0
    while i < n {
        let mut dens = 0.0
        let mut j = 0
        while j < n {
            let d = abs_f(data[i] - data[j])
            dens = dens + exp_approx(0.0 - d * d / (2.0 * bandwidth * bandwidth))
            j = j + 1
        }
        densities = densities + [dens / to_float(n)]
        i = i + 1
    }

    // find density peaks (local maxima)
    let mut peak_count = 0
    let mut max_density = 0.0
    i = 0
    while i < n {
        if densities[i] > max_density { max_density = densities[i] }
        // check if local max (higher than neighbors in sorted order)
        let is_peak = if i == 0 { densities[i] > densities[i + 1] }
                      else if i == n - 1 { densities[i] > densities[i - 1] }
                      else { densities[i] > densities[i - 1] && densities[i] > densities[i + 1] }
        if is_peak { peak_count = peak_count + 1 }
        i = i + 1
    }
    r = result_add(r, "attractor_count", [to_float(peak_count)])
    r = result_add(r, "peak_density", [max_density])
    r
}

// ─── (17) harmonic_series ───

fn scan_harmonic_series(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // harmonic ratios: 1/1, 2/1, 3/2, 4/3, 5/4, 6/5
    let harmonic_ratios = [1.0, 2.0, 1.5, 1.333333, 1.25, 1.2]
    let mut consonance_count = 0
    let mut total_checks = 0
    let mut i = 0
    while i < data.len() {
        let mut j = i + 1
        while j < data.len() {
            let a = abs_f(data[i])
            let b = abs_f(data[j])
            if a > 0.000000000001 && b > 0.000000000001 {
                let ratio = max_f(a, b) / min_f(a, b)
                total_checks = total_checks + 1
                for hr in harmonic_ratios {
                    if abs_f(ratio - hr) < 0.05 {
                        consonance_count = consonance_count + 1
                    }
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    let consonance = if total_checks > 0 { to_float(consonance_count) / to_float(total_checks) } else { 0.0 }
    r = result_add(r, "consonance_score", [consonance])

    // harmonic alignment: check if data[k] ≈ data[0] * k for k=1..6
    if abs_f(data[0]) > 0.000000000001 {
        let mut aligned = 0
        let mut k = 1
        while k < 7 && k < data.len() {
            let expected = data[0] * to_float(k)
            if abs_f(expected) > 0.000000000001 {
                let rel_err = abs_f(data[k] - expected) / abs_f(expected)
                if rel_err < 0.1 { aligned = aligned + 1 }
            }
            k = k + 1
        }
        r = result_add(r, "harmonic_alignment", [to_float(aligned) / 6.0])
    }
    r
}

// ─── (18) heat_conduction ───

fn scan_heat_conduction(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    // treat data as temperatures; compute heat flux
    let n = if data.len() < 200 { data.len() } else { 200 }
    // net heat flux per point: sum of q_ij = -(T_i - T_j)
    let mut gradient_mag = 0.0
    let mut i = 0
    while i < n {
        let mut flux = 0.0
        let mut j = 0
        while j < n {
            if i != j {
                let dist = max_f(abs_f(to_float(i - j)), 1.0)
                flux = flux + (data[j] - data[i]) / dist
            }
            j = j + 1
        }
        gradient_mag = gradient_mag + abs_f(flux)
        i = i + 1
    }
    gradient_mag = gradient_mag / to_float(n)
    r = result_add(r, "thermal_gradient", [gradient_mag])

    // equilibration: one-step diffusion, measure variance reduction
    let alpha = 0.1
    let mut diffused = []
    i = 0
    while i < n {
        let left = if i > 0 { data[i - 1] } else { data[i] }
        let right = if i < n - 1 { data[i + 1] } else { data[i] }
        let new_val = data[i] + alpha * (left + right - 2.0 * data[i])
        diffused = diffused + [new_val]
        i = i + 1
    }
    let orig_var = list_variance(data, list_mean(data))
    let diff_var = list_variance(diffused, list_mean(diffused))
    let eq_rate = if orig_var > 0.000000000001 { 1.0 - diff_var / orig_var } else { 0.0 }
    r = result_add(r, "equilibration_rate", [eq_rate])
    r
}

// ─── (19) hexagonal ───

fn scan_hexagonal(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // 6-fold symmetry detection via autocorrelation at lag = n/6
    let n = data.len()
    let lag6 = n / 6
    if lag6 < 1 { return r }

    let ac6 = autocorr_lag(data, lag6)
    r = result_add(r, "sixfold_symmetry", [ac6])

    // also check lag = n/3 (should be high for hex symmetry)
    let lag3 = n / 3
    if lag3 >= 1 {
        let ac3 = autocorr_lag(data, lag3)
        r = result_add(r, "threefold_symmetry", [ac3])
    }

    // hex score: combines 6-fold and 3-fold signals
    let hex_score = abs_f(ac6) * 0.7 + (if lag3 >= 1 { abs_f(autocorr_lag(data, lag3)) * 0.3 } else { 0.0 })
    r = result_add(r, "hexagonal_score", [hex_score])
    r
}

// ─── (20) hexameter ───

fn scan_hexameter(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // prosodic analysis: long (above mean) vs short (below mean)
    let mean = list_mean(data)
    // classify into metrical feet (groups of 2-3)
    let mut dactyls = 0   // long-short-short
    let mut spondees = 0  // long-long
    let mut i = 0
    let mut feet = 0
    while i < data.len() - 2 {
        let a = data[i] >= mean
        let b = data[i + 1] >= mean
        let c = data[i + 2] >= mean
        if a && !b && !c {
            dactyls = dactyls + 1
            feet = feet + 1
            i = i + 3
        } else if a && b {
            spondees = spondees + 1
            feet = feet + 1
            i = i + 2
        } else {
            i = i + 1
        }
    }
    let total_feet = max_f(to_float(feet), 1.0)
    r = result_add(r, "dactyl_ratio", [to_float(dactyls) / total_feet])
    r = result_add(r, "spondee_ratio", [to_float(spondees) / total_feet])

    // foot count match to 6
    let foot_match = if feet == 6 { 1.0 } else { 1.0 - abs_f(to_float(feet) - 6.0) / 6.0 }
    r = result_add(r, "foot_count_match", [max_f(foot_match, 0.0)])

    // regularity: variance of foot sizes
    let reg_score = to_float(dactyls + spondees) / max_f(to_float(data.len() / 2), 1.0)
    r = result_add(r, "scansion_regularity", [reg_score])
    r
}

// ─── (21) holonomy_group ───

fn scan_holonomy_group(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // parallel transport proxy: transport along data trajectory
    let n = data.len()
    let alpha = 0.1  // connection strength

    // initial tangent = data[1] - data[0]
    let mut tangent = data[1] - data[0]
    let initial_tangent = tangent

    let mut i = 1
    while i < n - 1 {
        let new_dir = data[i + 1] - data[i]
        let new_norm = abs_f(new_dir)
        if new_norm > 0.000000000001 {
            tangent = (1.0 - alpha) * tangent + alpha * new_dir / new_norm
            let tn = abs_f(tangent)
            if tn > 0.000000000001 { tangent = tangent / tn }
        }
        i = i + 1
    }

    // holonomy: how much tangent rotated (1D: sign flip detection)
    let holonomy = if abs_f(initial_tangent) > 0.000000000001 && abs_f(tangent) > 0.000000000001 {
        tangent * (if initial_tangent > 0.0 { 1.0 } else { 0.0 - 1.0 })
    } else { 0.0 }
    // holonomy_angle proxy: 0 = no rotation, 1 = full flip
    let angle = (1.0 - holonomy) / 2.0
    r = result_add(r, "holonomy_angle", [angle * pi_approx])

    // curvature: average abs second difference (discrete curvature)
    let mut curv_sum = 0.0
    i = 1
    while i < n - 1 {
        let curv = abs_f(data[i + 1] - 2.0 * data[i] + data[i - 1])
        curv_sum = curv_sum + curv
        i = i + 1
    }
    let mean_curv = curv_sum / max_f(to_float(n - 2), 1.0)
    r = result_add(r, "mean_curvature", [mean_curv])
    r
}

// ─── (22) infinite_discovery ───

fn scan_infinite_discovery(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // recursive discovery: iteratively find outliers at each depth
    let max_depth = 6
    let mut active = data
    let mut discoveries = []
    let mut total_disc = 0
    let mut sat_depth = max_depth

    let mut depth = 0
    while depth < max_depth {
        if active.len() < 3 {
            sat_depth = depth
            depth = max_depth
        }
        else {
            let mean = list_mean(active)
            let std = max_f(list_std(active, mean), 0.000000000001)
            let mut outliers = []
            let mut normals = []
            for v in active {
                if abs_f(v - mean) > std * 1.5 { outliers = outliers + [v] }
                else { normals = normals + [v] }
            }
            let found = outliers.len()
            discoveries = discoveries + [to_float(found)]
            total_disc = total_disc + found
            if found == 0 {
                sat_depth = depth
                depth = max_depth
            }
            else {
                active = if outliers.len() >= 3 { outliers } else { normals }
                depth = depth + 1
            }
        }
    }
    r = result_add(r, "total_discoveries", [to_float(total_disc)])
    r = result_add(r, "saturation_depth", [to_float(sat_depth)])

    // fractal discovery dimension
    if discoveries.len() >= 2 {
        let first = max_f(discoveries[0], 1.0)
        let last = max_f(discoveries[discoveries.len() - 1], 1.0)
        let frac_dim = ln_f(first / last) / ln_f(to_float(discoveries.len()))
        r = result_add(r, "fractal_discovery_dim", [frac_dim])
    }
    r
}

// ─── (23) infinity ───

fn scan_infinity(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // divergence rate: fit log|a_n| vs log(n)
    let mut sx = 0.0
    let mut sy = 0.0
    let mut sxy = 0.0
    let mut sxx = 0.0
    let mut valid = 0
    let mut i = 1
    while i < data.len() {
        let av = abs_f(data[i])
        if av > 0.000000000000001 {
            let x = ln_f(to_float(i))
            let y = ln_f(av)
            sx = sx + x
            sy = sy + y
            sxy = sxy + x * y
            sxx = sxx + x * x
            valid = valid + 1
        }
        i = i + 1
    }
    let div_rate = if valid > 1 {
        let nf = to_float(valid)
        let denom = nf * sxx - sx * sx
        if abs_f(denom) > 0.000000000000001 { (nf * sxy - sx * sy) / denom } else { 0.0 }
    } else { 0.0 }
    r = result_add(r, "divergence_rate", [div_rate])

    // ratio test: avg |a_{n+1}/a_n|
    let mut ratio_sum = 0.0
    let mut ratio_count = 0
    i = 0
    while i < data.len() - 1 {
        if abs_f(data[i]) > 0.000000000000001 {
            let ratio = abs_f(data[i + 1] / data[i])
            if ratio < 1000.0 {
                ratio_sum = ratio_sum + ratio
                ratio_count = ratio_count + 1
            }
        }
        i = i + 1
    }
    let avg_ratio = if ratio_count > 0 { ratio_sum / to_float(ratio_count) } else { 1.0 }
    let convergence = if avg_ratio < 1.0 { 1.0 - avg_ratio } else { 0.0 }
    r = result_add(r, "convergence_score", [convergence])
    r = result_add(r, "ratio_test", [avg_ratio])
    r
}

// ─── (24) info ───

fn scan_info(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    // Shannon entropy
    let ent = shannon_entropy(data)
    r = result_add(r, "shannon_entropy", [ent])

    // LZ complexity approximation: count distinct substrings
    // quantize to bins
    let lo = list_min(data)
    let hi = list_max(data)
    let range = hi - lo
    let num_bins = to_int(sqrt_f(to_float(data.len()))) + 2
    let mut symbols = []
    for v in data {
        let idx = if range > 0.000000000001 { to_int((v - lo) / range * to_float(num_bins - 1)) } else { 0 }
        symbols = symbols + [if idx < 0 { 0 } else if idx >= num_bins { num_bins - 1 } else { idx }]
    }

    // simple LZ count: new symbol transitions
    let mut complexity = 1
    let mut i = 1
    while i < symbols.len() {
        if symbols[i] != symbols[i - 1] { complexity = complexity + 1 }
        i = i + 1
    }
    let compression = to_float(complexity) / to_float(symbols.len())
    r = result_add(r, "lz_complexity", [to_float(complexity)])
    r = result_add(r, "compression_ratio", [compression])
    r
}

// ─── (25) inverse ───

fn scan_inverse(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }
    // pseudo-inverse: predict each point from its neighbors
    let n = data.len()
    let mut ss_res = 0.0
    let mut ss_tot = 0.0
    let mean = list_mean(data)
    let mut i = 1
    while i < n - 1 {
        let predicted = (data[i - 1] + data[i + 1]) / 2.0
        let res = data[i] - predicted
        ss_res = ss_res + res * res
        let tot = data[i] - mean
        ss_tot = ss_tot + tot * tot
        i = i + 1
    }
    let r_squared = if ss_tot > 0.000000000001 { 1.0 - ss_res / ss_tot } else { 0.0 }
    r = result_add(r, "reconstructability", [r_squared])

    // causal direction: first→second half influence
    let mid = n / 2
    let mut first_half = []
    let mut second_half = []
    i = 0
    while i < mid {
        first_half = first_half + [data[i]]
        i = i + 1
    }
    while i < n {
        second_half = second_half + [data[i]]
        i = i + 1
    }
    let cs = cosine_sim(first_half, second_half)
    r = result_add(r, "causal_direction", [cs])
    r
}

// ─── (26) isogeny_walk ───

fn scan_isogeny_walk(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    let n = if data.len() < 100 { data.len() } else { 100 }
    // build degree-6 graph: each point connects to 6 nearest by value
    let degree = 6

    // for 1D data, nearest neighbors are adjacent values in sorted order
    let sorted = list_sort(data)

    // mean path length proxy: average steps between random pairs in sorted order
    let mean_path = to_float(n) / to_float(degree * 2)
    r = result_add(r, "mean_path_length", [mean_path])

    // spectral gap proxy: variance of degree (uniform = good expander)
    // in sorted 1D data with degree-6, all internal nodes have degree 6
    let internal = max_f(to_float(n - degree), 1.0)
    let boundary = to_float(if n > degree { degree } else { n })
    let mean_deg = (internal * to_float(degree) + boundary * to_float(degree / 2)) / to_float(n)
    r = result_add(r, "mean_degree", [mean_deg])

    // diameter: longest shortest path
    let diameter = to_float(n / degree + 1)
    r = result_add(r, "diameter", [diameter])

    // mixing time ~ log(n) / spectral_gap
    let spectral_gap = to_float(degree) / to_float(n)
    let mixing_time = if spectral_gap > 0.000000000001 { ln_f(to_float(n)) / spectral_gap } else { to_float(n) }
    r = result_add(r, "mixing_time", [mixing_time])
    r
}

// ─── (27) isometry_group ───

fn scan_isometry_group(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // killing vector detection: find directions where distance structure is invariant
    let n = data.len()
    let half = n / 2
    // compare distance structure of first half vs second half
    let mut dist_a = 0.0
    let mut count_a = 0
    let mut i = 0
    while i < half {
        let mut j = i + 1
        while j < half {
            dist_a = dist_a + abs_f(data[i] - data[j])
            count_a = count_a + 1
            j = j + 1
        }
        i = i + 1
    }
    let mut dist_b = 0.0
    let mut count_b = 0
    i = half
    while i < n {
        let mut j = i + 1
        while j < n {
            dist_b = dist_b + abs_f(data[i] - data[j])
            count_b = count_b + 1
            j = j + 1
        }
        i = i + 1
    }
    let mean_a = if count_a > 0 { dist_a / to_float(count_a) } else { 0.0 }
    let mean_b = if count_b > 0 { dist_b / to_float(count_b) } else { 0.0 }
    let avg = (mean_a + mean_b) / 2.0
    let killing_score = if avg > 0.000000000001 { 1.0 - abs_f(mean_a - mean_b) / avg } else { 1.0 }
    r = result_add(r, "killing_score", [killing_score])

    // transitivity: how uniform is the overall distance spread
    let mean = list_mean(data)
    let std = list_std(data, mean)
    let transitivity = if abs_f(mean) > 0.000000000001 { 1.0 - std / abs_f(mean) } else { 0.0 }
    r = result_add(r, "transitivity", [clamp_f(transitivity, 0.0, 1.0)])
    r
}

// ─── (28) isomorphism ───

fn scan_isomorphism(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }
    let n = if data.len() < 60 { data.len() } else { 60 }
    // structural equivalence: sorted distance profiles
    // compare each pair's sorted distance profile correlation
    let mut profiles = []
    let mut i = 0
    while i < n {
        let mut dists = []
        let mut j = 0
        while j < n {
            if i != j { dists = dists + [abs_f(data[i] - data[j])] }
            j = j + 1
        }
        profiles = profiles + [list_sort(dists)]
        i = i + 1
    }

    // mean isomorphism score (cosine similarity of profiles)
    let mut sim_sum = 0.0
    let mut pair_count = 0
    i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            sim_sum = sim_sum + cosine_sim(profiles[i], profiles[j])
            pair_count = pair_count + 1
            j = j + 1
        }
        i = i + 1
    }
    let mean_iso = if pair_count > 0 { sim_sum / to_float(pair_count) } else { 0.0 }
    r = result_add(r, "mean_isomorphism", [mean_iso])

    // equivalence class count: cluster by high similarity (>0.95)
    let mut labels = []
    i = 0
    while i < n {
        labels = labels + [i]
        i = i + 1
    }
    // simple union: merge if cosine_sim > 0.95
    i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            if cosine_sim(profiles[i], profiles[j]) > 0.95 {
                let li = labels[i]
                let lj = labels[j]
                if li != lj {
                    let mut k = 0
                    while k < n {
                        if labels[k] == lj { labels[k] = li }
                        k = k + 1
                    }
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    let mut unique = []
    for l in labels {
        let mut found = false
        for u in unique { if u == l { found = true } }
        if !found { unique = unique + [l] }
    }
    r = result_add(r, "equivalence_classes", [to_float(unique.len())])
    r
}

// ─── (29) k_theory ───

fn scan_k_theory(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // Bott periodicity: autocorrelation at period 2, 6, 8
    let p2 = autocorr_lag(data, 2)
    let p6 = autocorr_lag(data, if data.len() > 6 { 6 } else { 2 })
    let p8 = autocorr_lag(data, if data.len() > 8 { 8 } else { 2 })
    r = result_add(r, "bott_period_2", [p2])
    r = result_add(r, "bott_period_6_bridge", [p6])
    r = result_add(r, "bott_period_8", [p8])

    // Chern class proxy: curvature from second differences
    let mut curv_sum = 0.0
    let mut i = 1
    while i < data.len() - 1 {
        let curv = data[i + 1] - 2.0 * data[i] + data[i - 1]
        curv_sum = curv_sum + curv
        i = i + 1
    }
    let c1 = curv_sum / (2.0 * pi_approx * max_f(to_float(data.len() - 2), 1.0))
    r = result_add(r, "chern_c1", [c1])
    r
}

// ─── (30) kaleidoscope ───

fn scan_kaleidoscope(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    let n = data.len()
    let norm2 = list_sum(data)  // for normalization

    // rotational symmetry: test orders 2..12
    let mut best_order = 0
    let mut best_score = 0.0 - 1.0
    let mut k = 2
    while k <= 12 {
        let shift = n / k
        if shift > 0 {
            let mut corr = 0.0
            let mut count = 0
            let mut i = 0
            while i < n - shift {
                corr = corr + data[i] * data[i + shift]
                count = count + 1
                i = i + 1
            }
            let var = list_variance(data, list_mean(data)) * to_float(n)
            let score = if var > 0.000000000001 && count > 0 { corr / to_float(count) / (var / to_float(n)) } else { 0.0 }
            if score > best_score {
                best_score = score
                best_order = k
            }
        }
        k = k + 1
    }
    r = result_add(r, "symmetry_order", [to_float(best_order)])
    r = result_add(r, "symmetry_score", [best_score])

    // reflection score: compare first half with reversed second half
    let half = n / 2
    let mut refl_corr = 0.0
    let mut refl_norm = 0.0
    let mut i = 0
    while i < half {
        let mirror = n - 1 - i
        if mirror < n {
            refl_corr = refl_corr + data[i] * data[mirror]
            refl_norm = refl_norm + data[i] * data[i] + data[mirror] * data[mirror]
        }
        i = i + 1
    }
    let reflection = if refl_norm > 0.000000000001 { clamp_f(2.0 * refl_corr / refl_norm, -1.0, 1.0) } else { 0.0 }
    r = result_add(r, "reflection_score", [reflection])

    // pattern count: autocorrelation peaks > 0.5
    let mean = list_mean(data)
    let var = list_variance(data, mean) * to_float(n)
    let mut patterns = 0
    if var > 0.000000000001 {
        let mut lag = 1
        while lag < n / 2 {
            let mut ac = 0.0
            i = 0
            while i < n - lag {
                ac = ac + (data[i] - mean) * (data[i + lag] - mean)
                i = i + 1
            }
            if ac / var > 0.5 { patterns = patterns + 1 }
            lag = lag + 1
        }
    }
    r = result_add(r, "pattern_count", [to_float(patterns)])
    r
}

// ─── (31) kernel_fusion ───

fn scan_kernel_fusion(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    let n = if data.len() < 100 { data.len() } else { 100 }
    // distance statistics
    let mut dist_sum = 0.0
    let mut pair_count = 0
    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            dist_sum = dist_sum + abs_f(data[i] - data[j])
            pair_count = pair_count + 1
            j = j + 1
        }
        i = i + 1
    }
    let dist_mean = if pair_count > 0 { dist_sum / to_float(pair_count) } else { 1.0 }
    let threshold = dist_mean * 0.5

    // fusion candidates: close pairs
    let mut fused_pairs = 0
    i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            if abs_f(data[i] - data[j]) < threshold { fused_pairs = fused_pairs + 1 }
            j = j + 1
        }
        i = i + 1
    }
    let fusion_ratio = if pair_count > 0 { to_float(fused_pairs) / to_float(pair_count) } else { 0.0 }
    r = result_add(r, "fusion_ratio", [fusion_ratio])

    // group count: connected components in proximity graph
    let mut labels = []
    i = 0
    while i < n {
        labels = labels + [i]
        i = i + 1
    }
    i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            if abs_f(data[i] - data[j]) < threshold {
                let li = labels[i]
                let lj = labels[j]
                if li != lj {
                    let mut k = 0
                    while k < n {
                        if labels[k] == lj { labels[k] = li }
                        k = k + 1
                    }
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    let mut groups = []
    for l in labels {
        let mut found = false
        for g in groups { if g == l { found = true } }
        if !found { groups = groups + [l] }
    }
    r = result_add(r, "fusion_groups", [to_float(groups.len())])
    r = result_add(r, "bandwidth_saving", [fusion_ratio])
    r
}

// ─── (32) kernel_method_geometry ───

fn scan_kernel_method_geometry(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }
    let n = if data.len() < 80 { data.len() } else { 80 }
    // polynomial kernel: k(x,y) = (1 + x*y)^6
    let mut trace = 0.0
    let mut frobenius_sq = 0.0
    let mut i = 0
    while i < n {
        let mut j = 0
        while j < n {
            let dot = data[i] * data[j]
            let mut k_val = 1.0 + dot
            // (1+dot)^6
            k_val = k_val * k_val * k_val * k_val * k_val * k_val
            frobenius_sq = frobenius_sq + k_val * k_val
            if i == j { trace = trace + k_val }
            j = j + 1
        }
        i = i + 1
    }
    // effective rank: trace^2 / frobenius^2
    let eff_rank = if frobenius_sq > 0.000000000000001 { trace * trace / frobenius_sq } else { 0.0 }
    r = result_add(r, "effective_rank", [eff_rank])
    r = result_add(r, "kernel_trace", [trace])

    // RKHS norm proxy: mean diagonal element
    let rkhs_norm = trace / to_float(n)
    r = result_add(r, "rkhs_norm", [rkhs_norm])

    // spectral decay: compare trace vs n*max_diag
    let mut max_diag = 0.0
    i = 0
    while i < n {
        let dot = data[i] * data[i]
        let mut kv = 1.0 + dot
        kv = kv * kv * kv * kv * kv * kv
        if kv > max_diag { max_diag = kv }
        i = i + 1
    }
    let decay = if max_diag > 0.000000000001 { trace / (to_float(n) * max_diag) } else { 0.0 }
    r = result_add(r, "spectral_decay", [decay])
    r
}

// ─── (33) keyword ───

fn scan_keyword(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // key feature extraction: importance = variance share
    // treat data as single dimension; split into blocks for multi-dim proxy
    let block_size = 6
    let n_blocks = data.len() / block_size
    if n_blocks < 2 { return r }

    let mut block_vars = []
    let mut i = 0
    while i < n_blocks {
        let start = i * block_size
        let mut block = []
        let mut j = 0
        while j < block_size {
            block = block + [data[start + j]]
            j = j + 1
        }
        let bm = list_mean(block)
        block_vars = block_vars + [list_variance(block, bm)]
        i = i + 1
    }
    let total_var = max_f(list_sum(block_vars), 0.000000000001)

    // importance scores
    let mut importance = []
    for bv in block_vars { importance = importance + [bv / total_var] }
    r = result_add(r, "importance_scores", importance)

    // top-k blocks
    let sorted_imp = list_sort(importance)
    let top_k_sum = if sorted_imp.len() >= 2 { sorted_imp[sorted_imp.len() - 1] + sorted_imp[sorted_imp.len() - 2] } else { list_sum(importance) }
    r = result_add(r, "compression_ratio", [top_k_sum])

    // redundancy: mean abs correlation between blocks
    let mut redundancy = 0.0
    let mut rc = 0
    i = 0
    while i < n_blocks {
        let mut j = i + 1
        while j < n_blocks {
            let mut block_i = []
            let mut block_j = []
            let mut k = 0
            while k < block_size {
                block_i = block_i + [data[i * block_size + k]]
                block_j = block_j + [data[j * block_size + k]]
                k = k + 1
            }
            redundancy = redundancy + abs_f(cosine_sim(block_i, block_j))
            rc = rc + 1
            j = j + 1
        }
        i = i + 1
    }
    if rc > 0 { redundancy = redundancy / to_float(rc) }
    r = result_add(r, "redundancy", [redundancy])
    r
}

// ─── (34) lattice_basis ───

fn scan_lattice_basis(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // treat first 6 values as 1D lattice basis vectors
    let basis_count = if data.len() < 6 { data.len() } else { 6 }
    let mut norms = []
    let mut i = 0
    while i < basis_count {
        norms = norms + [abs_f(data[i])]
        i = i + 1
    }

    let shortest = list_min(norms)
    let longest = list_max(norms)

    // orthogonality defect: product of norms / det (1D: product/product = 1)
    let mut log_product = 0.0
    for n in norms { if n > 0.000000000001 { log_product = log_product + ln_f(n) } }

    // Hermite factor: shortest / det^(1/n)
    let det_root = exp_approx(log_product / to_float(basis_count))
    let hermite = if det_root > 0.000000000001 { shortest / det_root } else { 0.0 }
    r = result_add(r, "hermite_factor", [hermite])

    // lattice gap: ratio between successive minima
    let sorted_norms = list_sort(norms)
    if sorted_norms.len() >= 2 && sorted_norms[0] > 0.000000000001 {
        let gap = sorted_norms[1] / sorted_norms[0]
        r = result_add(r, "lattice_gap", [gap])
    }

    // LLL quality: how orthogonal are the vectors (for 1D: spacing regularity)
    if sorted_norms.len() >= 3 {
        let mut spacing_var = 0.0
        let mut spacings = []
        i = 1
        while i < sorted_norms.len() {
            spacings = spacings + [sorted_norms[i] - sorted_norms[i - 1]]
            i = i + 1
        }
        let sp_mean = list_mean(spacings)
        spacing_var = list_variance(spacings, sp_mean)
        let lll_quality = 1.0 / (1.0 + spacing_var)
        r = result_add(r, "lll_quality", [lll_quality])
    }
    r
}

// ─── (35) lattice_congruence ───

fn scan_lattice_congruence(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // congruence class distribution mod 6
    let mut class_counts = [0, 0, 0, 0, 0, 0]
    for v in data {
        let rounded = to_int(abs_f(v) + 0.5)
        let cls = rounded - (rounded / 6) * 6   // mod 6
        let ci = if cls < 0 { cls + 6 } else if cls > 5 { 0 } else { cls }
        class_counts[ci] = class_counts[ci] + 1
    }
    let total = to_float(data.len())
    let mut class_dist = []
    for c in class_counts { class_dist = class_dist + [to_float(c) / total] }
    r = result_add(r, "congruence_class_dist", class_dist)

    // uniformity (entropy / max_entropy)
    let mut ent = 0.0
    for c in class_counts {
        if c > 0 {
            let p = to_float(c) / total
            ent = ent - p * ln_f(p)
        }
    }
    let max_ent = ln_f(6.0)
    let uniformity = if max_ent > 0.0 { ent / max_ent } else { 0.0 }
    r = result_add(r, "congruence_uniformity", [uniformity])

    // boolean lattice coverage: distinct 6-bit patterns
    let mut patterns = []
    for v in data {
        let bits = to_int(abs_f(v) + 0.5)
        let low6 = bits - (bits / 64) * 64  // mod 64
        let mut found = false
        for p in patterns { if p == low6 { found = true } }
        if !found { patterns = patterns + [low6] }
    }
    let coverage = to_float(patterns.len()) / 64.0
    r = result_add(r, "boolean_lattice_coverage", [coverage])
    r
}

// ─── (36) lattice_field ───

fn scan_lattice_field(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    let n = if data.len() < 200 { data.len() } else { 200 }

    // coordination number: count neighbors within r_cut per point
    let sorted = list_sort(data)
    let mut nn_dists = []
    let mut i = 0
    while i < n {
        let mut min_d = 999999999.0
        let mut j = 0
        while j < n {
            if i != j {
                let d = abs_f(data[i] - data[j])
                if d < min_d { min_d = d }
            }
            j = j + 1
        }
        nn_dists = nn_dists + [min_d]
        i = i + 1
    }
    let sorted_nn = list_sort(nn_dists)
    let median_nn = sorted_nn[n / 2]
    let r_cut = median_nn * 1.3

    let mut cn_sum = 0.0
    i = 0
    while i < n {
        let mut cn = 0
        let mut j = 0
        while j < n {
            if i != j && abs_f(data[i] - data[j]) <= r_cut { cn = cn + 1 }
            j = j + 1
        }
        cn_sum = cn_sum + to_float(cn)
        i = i + 1
    }
    let mean_cn = cn_sum / to_float(n)
    r = result_add(r, "coordination_number", [mean_cn])

    // check known CN targets
    let cn_targets = [4.0, 6.0, 8.0, 12.0, 24.0]
    let mut best_match = 0.0
    for target in cn_targets {
        let rel = abs_f(mean_cn - target) / target
        if rel < 0.08 { best_match = target }
    }
    if best_match > 0.0 { r = result_add(r, "cn_match", [best_match]) }

    // packing fraction proxy: fraction of range covered by point neighborhoods
    let range = list_max(data) - list_min(data)
    let packing = if range > 0.000000000001 { to_float(n) * r_cut / range } else { 0.0 }
    r = result_add(r, "packing_fraction", [clamp_f(packing, 0.0, 1.0)])
    r
}

// ─── (37) lens_discovery ───

fn scan_lens_discovery(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // meta-lens: score which analysis type would be most informative
    let mean = list_mean(data)
    let variance = list_variance(data, mean)
    let ent = shannon_entropy(data)
    let ac1 = autocorr_lag(data, 1)

    // score analysis types
    let statistical_score = variance / (variance + 1.0)
    let temporal_score = abs_f(ac1)
    let topological_score = ent / (ent + 1.0)

    // spectral: variance concentration in first vs second half
    let mid = data.len() / 2
    let mut first = []
    let mut second = []
    let mut i = 0
    while i < mid {
        first = first + [data[i]]
        i = i + 1
    }
    while i < data.len() {
        second = second + [data[i]]
        i = i + 1
    }
    let spectral_score = if variance > 0.000000000001 {
        abs_f(list_variance(first, list_mean(first)) - list_variance(second, list_mean(second))) / variance
    } else { 0.0 }

    let scores = [statistical_score, temporal_score, topological_score, spectral_score]
    let mut best_idx = 0
    let mut best_val = scores[0]
    i = 1
    while i < 4 {
        if scores[i] > best_val {
            best_val = scores[i]
            best_idx = i
        }
        i = i + 1
    }
    let sum_scores = max_f(list_sum(scores), 0.000000000001)
    let confidence = best_val / sum_scores
    let complexity = ent * (1.0 + ln_f(max_f(to_float(data.len()), 1.0)))

    r = result_add(r, "best_analysis_type", [to_float(best_idx)])
    r = result_add(r, "analysis_confidence", [confidence])
    r = result_add(r, "data_complexity", [complexity])
    r = result_add(r, "unexplored_potential", [1.0 - confidence])
    r
}

// ─── registration ───

fn register_math_lenses(data)  {
    let mut entries = []

    entries = entries + [ScanEntry { lens_name: "finance", lens_category: "math", result: scan_finance(data) }]
    entries = entries + [ScanEntry { lens_name: "fisher_geometric", lens_category: "math", result: scan_fisher_geometric(data) }]
    entries = entries + [ScanEntry { lens_name: "fission", lens_category: "math", result: scan_fission(data) }]
    entries = entries + [ScanEntry { lens_name: "flash_attention", lens_category: "math", result: scan_flash_attention(data) }]
    entries = entries + [ScanEntry { lens_name: "formula_combination", lens_category: "math", result: scan_formula_combination(data) }]
    entries = entries + [ScanEntry { lens_name: "fractal", lens_category: "math", result: scan_fractal(data) }]
    entries = entries + [ScanEntry { lens_name: "frequency_dependent", lens_category: "math", result: scan_frequency_dependent(data) }]
    entries = entries + [ScanEntry { lens_name: "frustration", lens_category: "math", result: scan_frustration(data) }]
    entries = entries + [ScanEntry { lens_name: "fusion", lens_category: "math", result: scan_fusion(data) }]
    entries = entries + [ScanEntry { lens_name: "gene_network", lens_category: "math", result: scan_gene_network(data) }]
    entries = entries + [ScanEntry { lens_name: "gods_eye", lens_category: "math", result: scan_gods_eye(data) }]
    entries = entries + [ScanEntry { lens_name: "golden_ratio", lens_category: "math", result: scan_golden_ratio(data) }]
    entries = entries + [ScanEntry { lens_name: "golden_zone", lens_category: "math", result: scan_golden_zone(data) }]
    entries = entries + [ScanEntry { lens_name: "gradient", lens_category: "math", result: scan_gradient(data) }]
    entries = entries + [ScanEntry { lens_name: "graph", lens_category: "math", result: scan_graph(data) }]
