// ─── 공용 상수 + 헬퍼 (lenses_base.hexa.inc copy-paste) ───
// source: shared/blowup/lens/lenses_base.hexa.inc (ROI #22)
// provides: pi,two_pi,e_const,phi_golden,sqrt2,sqrt3,ln2,one_third
//           n6,sigma6,tau6,phi6,sopfr6
//           min_f,max_f,clamp_f,clamp01,to_int
//           exp_f,sin_f,cos_f,pow_f
//           list_sum,list_min,list_max
//           load_jsonl_kv,kv_lookup

comptime const pi = 3.141592653589793
comptime const two_pi = 6.283185307179586
comptime const e_const = 2.718281828459045
comptime const phi_golden = 1.618033988749895
comptime const sqrt2 = 1.4142135623730951
comptime const sqrt3 = 1.7320508075688772
comptime const ln2 = 0.6931471805599453
comptime const one_third = 0.33333333333333

pure fn min_f(a: float, b: float) -> float { if a < b { a } else { b } }
pure fn max_f(a: float, b: float) -> float { if a > b { a } else { b } }
pure fn clamp_f(v: float, lo: float, hi: float) -> float { min_f(max_f(v, lo), hi) }
pure fn clamp01(x: float) -> float { max_f(0.0, min_f(1.0, x)) }

pure fn exp_f(x: float) -> float {
    let cx = clamp_f(x, 0.0 - 20.0, 20.0)
    let mut sum = 1.0
    let mut term = 1.0
    let mut k = 1
    while k <= 20 { term = term * cx / to_float(k)
        sum = sum + term
        k = k + 1 }
    sum
}

pure fn sin_f(x: float) -> float {
    let mut v = x
    while v > pi { v = v - two_pi }
    while v < 0.0 - pi { v = v + two_pi }
    let mut sum = 0.0
    let mut term = v
    let mut k = 1
    while k <= 12 { sum = sum + term
        term = 0.0 - term * v * v / to_float((2 * k) * (2 * k + 1))
        k = k + 1 }
    sum
}

pure fn cos_f(x: float) -> float { sin_f(x + pi / 2.0) }

pure fn pow_f(base: float, exp: int) -> float {
    let mut r = 1.0
    let mut i = 0
    while i < exp { r = r * base
        i = i + 1 }
    r
}

pure fn list_sum(data) -> float {
    let mut s = 0.0
    for v in data { s = s + v }
    s
}

pure fn list_min(data) -> float {
    if data.len() == 0 { return 0.0 }
    let mut m = data[0]
    let mut i = 1
    while i < data.len() { if data[i] < m { m = data[i] }
        i = i + 1 }
    m
}

pure fn list_max(data) -> float {
    if data.len() == 0 { return 0.0 }
    let mut m = data[0]
    let mut i = 1
    while i < data.len() { if data[i] > m { m = data[i] }
        i = i + 1 }
    m
}

fn load_jsonl_kv(path: string) -> list {
    let raw = try { read_file(path) } catch e { return [[], []] }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let trimmed = line.trim()
        if trimmed == "" { continue }
        let mut name = ""
        let mut value = 0.0
        if trimmed.contains("\"name\":\"") {
            let p = trimmed.split("\"name\":\"")
            if p.len() >= 2 { name = p[1].split("\"")[0] }
        }
        if trimmed.contains("\"value\":") {
            let p = trimmed.split("\"value\":")
            if p.len() >= 2 {
                let num_str = p[1].split(",")[0].split("}")[0].trim()
                value = to_float(num_str)
            }
        }
        if name != "" {
            names = names + [name]
            values = values + [value]
        }
    }
    [names, values]
}

fn kv_lookup(data: list, key: string) -> float {
    let names = data[0]
    let values = data[1]
    let mut i = 0
    while i < len(names) {
        if names[i] == key { return values[i] }
        i = i + 1
    }
    0.0
}

// ─── constants-specific: n6 + physics 상수 (jsonl 로드) ───
let _home = exec("printenv HOME")
let _shared = _home + "/Dev/nexus/shared"
let _n6_data = load_jsonl_kv(_shared + "/n6_constants.jsonl")
let _ph_data = load_jsonl_kv(_shared + "/n6_physics.jsonl")

let n6 = kv_lookup(_n6_data, "n")
let sigma = kv_lookup(_n6_data, "sigma")
let tau = kv_lookup(_n6_data, "tau")
let phi_euler = kv_lookup(_n6_data, "phi")
let j2 = kv_lookup(_n6_data, "j2")
let sopfr = kv_lookup(_n6_data, "sopfr")
let sigma_minus_phi = kv_lookup(_n6_data, "sigma_minus_phi")
let sigma_minus_tau = kv_lookup(_n6_data, "phi_tau")
let sigma_sq = kv_lookup(_n6_data, "sigma_sq")
let sigma_times_j2 = kv_lookup(_n6_data, "sigma_j2")
let ln_4_3 = kv_lookup(_n6_data, "ln_4_3")

let fine_structure_inv = kv_lookup(_ph_data, "alpha_inv")
let fine_structure = kv_lookup(_n6_data, "fine_structure")
let proton_electron = kv_lookup(_ph_data, "mp_me")
let omega_m = kv_lookup(_ph_data, "omega_m")
let omega_l = kv_lookup(_ph_data, "omega_lambda")

let _math_names = ["pi", "e", "phi_golden", "sqrt2", "sqrt3", "ln2"]
let _math_values = [pi, e_const, phi_golden, sqrt2, sqrt3, ln2]
let known_names = _math_names + _n6_data[0] + _ph_data[0]
let known_values = _math_values + _n6_data[1] + _ph_data[1]

// ─── (1) constant_collector: 알려진 상수 탐지 ───

fn scan_constant_collector(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 1 { return r }
    let mut i = 0
    while i < data.len() {
        let v = data[i]
        let mut k = 0
        while k < known_values.len() {
            let c = known_values[k]
            let tol = if abs_f(c) > 1.0 { abs_f(c) * 0.005 } else { 0.005 }
            if abs_f(v - c) < tol {
                r = result_add(r, "const_" + known_names[k], [v])
            }
            // ratio check
            if v != 0.0 && abs_f(c) > 0.001 {
                let ratio = v / c
                if abs_f(ratio - 2.0) < 0.01 || abs_f(ratio - 0.5) < 0.01 {
                    r = result_add(r, "ratio_" + known_names[k], [ratio])
                }
            }
            k = k + 1
        }
        i = i + 1
    }
    r
}

// ─── (2) constant_combination: 상수 조합 탐지 ───

fn scan_constant_combination(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 2 { return r }
    let mut i = 0
    while i < data.len() {
        let mut j = i + 1
        while j < data.len() {
            let s = data[i] + data[j]
            let d = abs_f(data[i] - data[j])
            let p = data[i] * data[j]
            // check sum/diff/product against known constants
            let mut k = 0
            while k < known_values.len() {
                let c = known_values[k]
                let tol = if abs_f(c) > 1.0 { abs_f(c) * 0.01 } else { 0.01 }
                if abs_f(s - c) < tol {
                    r = result_add(r, "sum_" + known_names[k], [data[i], data[j]])
                }
                if abs_f(d - c) < tol {
                    r = result_add(r, "diff_" + known_names[k], [data[i], data[j]])
                }
                if abs_f(p) > 0.001 && abs_f(p - c) < tol {
                    r = result_add(r, "prod_" + known_names[k], [data[i], data[j]])
                }
                k = k + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    r
}

// ─── (3) constant_discovery_engine: 새로운 상수 후보 발견 ───

fn scan_constant_discovery_engine(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    // Find values that appear multiple times (within tolerance) -> candidate constants
    let sorted = list_sort(data)
    let mut candidates = []
    let mut counts = []
    let mut cur = sorted[0]
    let mut cnt = 1
    let mut i = 1
    while i < sorted.len() {
        if abs_f(sorted[i] - cur) < 0.01 {
            cnt = cnt + 1
        } else {
            if cnt >= 2 {
                candidates = candidates + [cur]
                counts = counts + [to_float(cnt)]
            }
            cur = sorted[i]
            cnt = 1
        }
        i = i + 1
    }
    if cnt >= 2 {
        candidates = candidates + [cur]
        counts = counts + [to_float(cnt)]
    }
    let mut ci = 0
    while ci < candidates.len() {
        r = result_add(r, "candidate_constant", [candidates[ci], counts[ci]])
        ci = ci + 1
    }
    // Ratio mining: frequent ratios between pairs
    let mut ratios = []
    i = 0
    while i < data.len() && i < 50 {
        let mut j = i + 1
        while j < data.len() && j < 50 {
            if abs_f(data[j]) > 0.001 {
                ratios = ratios + [data[i] / data[j]]
            }
            j = j + 1
        }
        i = i + 1
    }
    if ratios.len() > 0 {
        let sr = list_sort(ratios)
        let mut rc = sr[0]
        let mut rn = 1
        let mut ri = 1
        while ri < sr.len() {
            if abs_f(sr[ri] - rc) < 0.02 {
                rn = rn + 1
            } else {
                if rn >= 3 {
                    r = result_add(r, "frequent_ratio", [rc, to_float(rn)])
                }
                rc = sr[ri]
                rn = 1
            }
            ri = ri + 1
        }
        if rn >= 3 {
            r = result_add(r, "frequent_ratio", [rc, to_float(rn)])
        }
    }
    r
}

// ─── (4) constant_formula: 수식 피팅 ───

fn scan_constant_formula(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    let mean = list_mean(data)
    let var = list_variance(data, mean)
    let std = sqrt_f(var)
    // Check if data fits linear, quadratic, or exponential pattern
    // Linear: data[i] ~ a*i + b
    let n = data.len()
    let t_mean = to_float(n - 1) / 2.0
    let mut cov_ty = 0.0
    let mut t_var = 0.0
    let mut i = 0
    while i < n {
        let t = to_float(i) - t_mean
        cov_ty = cov_ty + t * (data[i] - mean)
        t_var = t_var + t * t
        i = i + 1
    }
    let slope = if t_var > 0.0001 { cov_ty / t_var } else { 0.0 }
    let intercept = mean - slope * t_mean
    // R-squared
    let mut ss_res = 0.0
    let mut ss_tot = 0.0
    i = 0
    while i < n {
        let pred = slope * to_float(i) + intercept
        ss_res = ss_res + (data[i] - pred) * (data[i] - pred)
        ss_tot = ss_tot + (data[i] - mean) * (data[i] - mean)
        i = i + 1
    }
    let r2 = if ss_tot > 0.0001 { 1.0 - ss_res / ss_tot } else { 0.0 }
    if r2 > 0.7 {
        r = result_add(r, "linear_fit", [slope, intercept, r2])
    }
    // Check constant-like: low variance relative to mean
    if abs_f(mean) > 0.001 && std / abs_f(mean) < 0.05 {
        r = result_add(r, "near_constant", [mean, std])
    }
    // Exponential check: ln(data) linear?
    let mut all_positive = true
    i = 0
    while i < n {
        if data[i] <= 0.0 { all_positive = false }
        i = i + 1
    }
    if all_positive {
        let mut log_data = []
        i = 0
        while i < n {
            log_data = log_data + [ln_f(data[i])]
            i = i + 1
        }
        let lm = list_mean(log_data)
        let lv = list_variance(log_data, lm)
        let ls = sqrt_f(lv)
        if abs_f(lm) > 0.001 && ls / abs_f(lm) < 0.1 {
            r = result_add(r, "exponential_constant", [exp_f(lm)])
        }
    }
    r
}

// ─── (5) contracting_scan: 수축 스케일 분석 ───

fn scan_contracting_scan(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // Multi-scale contraction: from full range to local
    let n = data.len()
    let mut scale = n
    let mut entropies = []
    let mut densities = []
    while scale >= 3 {
        let chunk = data[0..scale]
        let m = list_mean(chunk)
        let v = list_variance(chunk, m)
        densities = densities + [if v > 0.0 { 1.0 / sqrt_f(v) } else { 1000.0 }]
        // simple entropy
        let sorted = list_sort(chunk)
        let mut ent = 0.0
        let mut ci = 0
        let total = to_float(chunk.len())
        while ci < sorted.len() {
            let p = 1.0 / total
            ent = ent - p * ln_f(p)
            ci = ci + 1
        }
        entropies = entropies + [ent]
        scale = scale / 2
    }
    // Contraction rate: density increase as scale shrinks
    if densities.len() >= 2 {
        let rate = densities[densities.len() - 1] - densities[0]
        r = result_add(r, "contraction_rate", [rate])
    }
    // Critical scale: max entropy change
    let mut max_change = 0.0
    let mut crit_idx = 0
    let mut ei = 1
    while ei < entropies.len() {
        let change = abs_f(entropies[ei] - entropies[ei - 1])
        if change > max_change {
            max_change = change
            crit_idx = ei
        }
        ei = ei + 1
    }
    r = result_add(r, "critical_scale", [to_float(crit_idx), max_change])
    r = result_add(r, "density_profile", densities)
    r
}

// ─── (6) convection_pattern: 대류 패턴 탐지 ───

fn scan_convection_pattern(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    // Rayleigh-like analysis: detect rising/falling alternation
    let n = data.len()
    let mean = list_mean(data)
    let mut rises = 0
    let mut falls = 0
    let mut reversals = 0
    let mut prev_dir = 0  // 1=up, -1=down
    let mut i = 1
    while i < n {
        let diff = data[i] - data[i - 1]
        let dir = if diff > 0.0 { 1 } else if diff < 0.0 { 0 - 1 } else { 0 }
        if dir == 1 { rises = rises + 1 }
        if dir == 0 - 1 { falls = falls + 1 }
        if prev_dir != 0 && dir != 0 && dir != prev_dir { reversals = reversals + 1 }
        if dir != 0 { prev_dir = dir }
        i = i + 1
    }
    // Convective if roughly equal rises/falls with many reversals
    let balance = if rises + falls > 0 { to_float(rises) / to_float(rises + falls) } else { 0.5 }
    let reversal_rate = to_float(reversals) / to_float(n - 1)
    r = result_add(r, "convection_balance", [balance])
    r = result_add(r, "reversal_rate", [reversal_rate])
    // Rayleigh number analog: amplitude * frequency
    let amp = list_max(data) - list_min(data)
    let rayleigh = amp * reversal_rate
    r = result_add(r, "rayleigh_analog", [rayleigh])
    // Cell detection: segments between reversals
    if reversals > 0 {
        r = result_add(r, "convection_cells", [to_float(reversals + 1)])
    }
    r
}

// ─── (7) convex_conjugacy: 볼록 켤레 분석 ───

fn scan_convex_conjugacy(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    let n = data.len()
    // Legendre transform: f*(p) = sup_x(px - f(x))
    // Treat data as f(x_i) at evenly spaced x_i
    let mut conjugate_vals = []
    let mut p = 0.0 - 5.0
    while p <= 5.0 {
        let mut sup = 0.0 - 999999999.0
        let mut i = 0
        while i < n {
            let x = to_float(i) / to_float(n - 1) * 2.0 - 1.0  // x in [-1, 1]
            let val = p * x - data[i]
            if val > sup { sup = val }
            i = i + 1
        }
        conjugate_vals = conjugate_vals + [sup]
        p = p + 0.5
    }
    // Measure duality gap: f + f* >= px (Young's inequality)
    let mut gap_sum = 0.0
    let mut gap_count = 0
    let mut pi = 0
    while pi < conjugate_vals.len() {
        let pp = 0.0 - 5.0 + to_float(pi) * 0.5
        let mut i = 0
        while i < n {
            let x = to_float(i) / to_float(n - 1) * 2.0 - 1.0
            let gap = data[i] + conjugate_vals[pi] - pp * x
            gap_sum = gap_sum + gap
            gap_count = gap_count + 1
            i = i + 1
        }
        pi = pi + 1
    }
    let mean_gap = if gap_count > 0 { gap_sum / to_float(gap_count) } else { 0.0 }
    r = result_add(r, "duality_gap", [mean_gap])
    // Convexity check: second differences
    let mut convex_count = 0
    let mut total_check = 0
    let mut i = 1
    while i < n - 1 {
        let second_diff = data[i + 1] - 2.0 * data[i] + data[i - 1]
        total_check = total_check + 1
        if second_diff >= 0.0 - 0.001 { convex_count = convex_count + 1 }
        i = i + 1
    }
    let convexity = if total_check > 0 { to_float(convex_count) / to_float(total_check) } else { 0.0 }
    r = result_add(r, "convexity_fraction", [convexity])
    r = result_add(r, "conjugate_profile", conjugate_vals)
    r
}

// ─── (8) convex: 볼록 껍질 분석 ───

fn scan_convex(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    let n = data.len()
    let sorted = list_sort(data)
    // Convex hull in 1D: just range
    let hull_range = sorted[n - 1] - sorted[0]
    r = result_add(r, "hull_range", [hull_range])
    // Interior fraction: how many points are strictly inside the hull
    let mut interior = 0
    let mut i = 0
    while i < n {
        if data[i] > sorted[0] + 0.001 && data[i] < sorted[n - 1] - 0.001 {
            interior = interior + 1
        }
        i = i + 1
    }
    let interior_frac = to_float(interior) / to_float(n)
    r = result_add(r, "interior_fraction", [interior_frac])
    // Dispersion: variance / range^2
    let mean = list_mean(data)
    let var = list_variance(data, mean)
    let dispersion = if hull_range > 0.001 { var / (hull_range * hull_range) } else { 0.0 }
    r = result_add(r, "dispersion", [dispersion])
    // Convexity test: sorted increments should be monotonic for convex functions
    let mut monotonic_inc = 0
    i = 2
    while i < n {
        let d1 = sorted[i] - sorted[i - 1]
        let d0 = sorted[i - 1] - sorted[i - 2]
        if d1 >= d0 - 0.001 { monotonic_inc = monotonic_inc + 1 }
        i = i + 1
    }
    let mono_frac = if n > 2 { to_float(monotonic_inc) / to_float(n - 2) } else { 0.0 }
    r = result_add(r, "increment_monotonicity", [mono_frac])
    r
}

// ─── (9) correlation: 상관 분석 ───

fn scan_correlation(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }
    let n = data.len()
    let mean = list_mean(data)
    let var = list_variance(data, mean)
    if var < 0.0001 { return r }
    // Autocorrelation at multiple lags
    let max_lag = if n / 4 < 10 { n / 4 } else { 10 }
    let mut autocorrs = []
    let mut lag = 1
    while lag <= max_lag {
        let mut cov = 0.0
        let mut i = 0
        while i < n - lag {
            cov = cov + (data[i] - mean) * (data[i + lag] - mean)
            i = i + 1
        }
        let ac = cov / (to_float(n - lag) * var)
        autocorrs = autocorrs + [ac]
        lag = lag + 1
    }
    r = result_add(r, "autocorrelations", autocorrs)
    // Correlation length: first lag where |ac| < 0.1
    let mut corr_length = to_float(max_lag)
    let mut li = 0
    while li < autocorrs.len() {
        if abs_f(autocorrs[li]) < 0.1 {
            corr_length = to_float(li + 1)
            li = autocorrs.len()  // break
        }
        li = li + 1
    }
    r = result_add(r, "correlation_length", [corr_length])
    // Pearson between first half and second half
    let mid = n / 2
    let m1 = list_mean(data[0..mid])
    let m2 = list_mean(data[mid..n])
    let v1 = list_variance(data[0..mid], m1)
    let v2 = list_variance(data[mid..n], m2)
    let len = if mid < n - mid { mid } else { n - mid }
    let mut cross_cov = 0.0
    let mut ci = 0
    while ci < len {
        cross_cov = cross_cov + (data[ci] - m1) * (data[mid + ci] - m2)
        ci = ci + 1
    }
    let denom = sqrt_f(v1) * sqrt_f(v2) * to_float(len)
    let pearson = if denom > 0.001 { cross_cov / denom } else { 0.0 }
    r = result_add(r, "half_split_pearson", [pearson])
    r
}

// ─── (10) cosmological_constant: 우주상수 탐지 ───

fn scan_cosmological_constant(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    let n = data.len()
    let mean = list_mean(data)
    let var = list_variance(data, mean)
    // Dark energy fraction: data near Omega_Lambda = 0.6847
    let mut de_count = 0
    let mut i = 0
    while i < n {
        if abs_f(data[i] - omega_l) < 0.02 { de_count = de_count + 1 }
        if abs_f(data[i] - omega_m) < 0.02 { de_count = de_count + 1 }
        i = i + 1
    }
    if de_count > 0 {
        r = result_add(r, "cosmological_match", [to_float(de_count)])
    }
    // Expansion rate: cumulative sum slope (Hubble analog)
    let mut cumsum = []
    let mut cs = 0.0
    i = 0
    while i < n {
        cs = cs + data[i]
        cumsum = cumsum + [cs]
        i = i + 1
    }
    // Fit linear to cumsum -> Hubble-like expansion
    let cm = list_mean(cumsum)
    let tm = to_float(n - 1) / 2.0
    let mut cov_ct = 0.0
    let mut tv = 0.0
    i = 0
    while i < n {
        let t = to_float(i) - tm
        cov_ct = cov_ct + t * (cumsum[i] - cm)
        tv = tv + t * t
        i = i + 1
    }
    let hubble = if tv > 0.001 { cov_ct / tv } else { 0.0 }
    r = result_add(r, "hubble_analog", [hubble])
    // Acceleration: second derivative of cumsum
    if n >= 3 {
        let mut accel = 0.0
        i = 1
        while i < n - 1 {
            accel = accel + cumsum[i + 1] - 2.0 * cumsum[i] + cumsum[i - 1]
            i = i + 1
        }
        accel = accel / to_float(n - 2)
        r = result_add(r, "expansion_acceleration", [accel])
    }
    r
}

// ─── (11) cp_violation: CP 대칭 위반 탐지 ───

fn scan_cp_violation(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    let n = data.len()
    // Forward-backward asymmetry
    let mid = n / 2
    let mut fwd_sum = 0.0
    let mut bwd_sum = 0.0
    let mut i = 0
    while i < mid {
        fwd_sum = fwd_sum + data[i]
        i = i + 1
    }
    i = mid
    while i < n {
        bwd_sum = bwd_sum + data[i]
        i = i + 1
    }
    let fwd_avg = fwd_sum / to_float(mid)
    let bwd_avg = bwd_sum / to_float(n - mid)
    let asymmetry = if abs_f(fwd_avg + bwd_avg) > 0.001 {
        (fwd_avg - bwd_avg) / abs_f(fwd_avg + bwd_avg)
    } else { 0.0 }
    r = result_add(r, "cp_asymmetry", [asymmetry])
    // Jarlskog-like invariant_str: measure from triplet correlations
    let mut jarlskog = 0.0
    let mut triplets = 0
    i = 0
    while i < n - 2 && i < 30 {
        let a = data[i]
        let b = data[i + 1]
        let c = data[i + 2]
        // J ~ sin(phase differences)
        if abs_f(a) > 0.001 && abs_f(b) > 0.001 {
            jarlskog = jarlskog + sin_f(a - b) * sin_f(b - c) * sin_f(c - a)
            triplets = triplets + 1
        }
        i = i + 1
    }
    if triplets > 0 {
        jarlskog = jarlskog / to_float(triplets)
    }
    r = result_add(r, "jarlskog_invariant", [jarlskog])
    r = result_add(r, "unitarity_area", [abs_f(jarlskog) / 2.0])
    r
}

// ─── (12) crypto: 암호학적 패턴 탐지 ───

fn scan_crypto(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }
    let n = data.len()
    // Entropy (randomness test)
    let sorted = list_sort(data)
    let range = sorted[n - 1] - sorted[0]
    if range < 0.001 { return r }
    let n_bins = 10
    let bin_width = range / to_float(n_bins)
    let mut bins = []
    let mut bi = 0
    while bi < n_bins {
        bins = bins + [0.0]
        bi = bi + 1
    }
    let mut i = 0
    while i < n {
        let mut b = to_int((data[i] - sorted[0]) / bin_width)
        if b >= n_bins { b = n_bins - 1 }
        bins[b] = bins[b] + 1.0
        i = i + 1
    }
    let mut entropy = 0.0
    bi = 0
    while bi < n_bins {
        let p = bins[bi] / to_float(n)
        if p > 0.0 { entropy = entropy - p * ln_f(p) }
        bi = bi + 1
    }
    let max_entropy = ln_f(to_float(n_bins))
    let uniformity = if max_entropy > 0.0 { entropy / max_entropy } else { 0.0 }
    r = result_add(r, "entropy", [entropy])
    r = result_add(r, "uniformity", [uniformity])
    // Serial correlation (should be ~0 for cryptographic data)
    let mean = list_mean(data)
    let var = list_variance(data, mean)
    let mut serial_corr = 0.0
    if var > 0.001 {
        i = 0
        while i < n - 1 {
            serial_corr = serial_corr + (data[i] - mean) * (data[i + 1] - mean)
            i = i + 1
        }
        serial_corr = serial_corr / (to_float(n - 1) * var)
    }
    r = result_add(r, "serial_correlation", [serial_corr])
    // Chi-squared uniformity test analog
    let expected = to_float(n) / to_float(n_bins)
    let mut chi2 = 0.0
    bi = 0
    while bi < n_bins {
        let diff = bins[bi] - expected
        chi2 = chi2 + diff * diff / expected
        bi = bi + 1
    }
    r = result_add(r, "chi2_uniformity", [chi2])
    r
}

// ─── (13) density: 밀도 분석 ───

fn scan_density(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    let n = data.len()
    let sorted = list_sort(data)
    let range = sorted[n - 1] - sorted[0]
    if range < 0.001 { return r }
    // KDE-like density estimate using gaps
    let mut gaps = []
    let mut i = 1
    while i < n {
        gaps = gaps + [sorted[i] - sorted[i - 1]]
        i = i + 1
    }
    let mean_gap = list_mean(gaps)
    let max_gap = list_max(gaps)
    let min_gap = list_min(gaps)
    // Density peaks: small gaps = high density
    let mut peak_count = 0
    i = 0
    while i < gaps.len() {
        if gaps[i] < mean_gap * 0.3 { peak_count = peak_count + 1 }
        i = i + 1
    }
    r = result_add(r, "density_peaks", [to_float(peak_count)])
    r = result_add(r, "gap_ratio", [if min_gap > 0.0001 { max_gap / min_gap } else { 0.0 }])
    // Cluster detection via large gaps
    let mut cluster_count = 1
    i = 0
    while i < gaps.len() {
        if gaps[i] > mean_gap * 3.0 { cluster_count = cluster_count + 1 }
        i = i + 1
    }
    r = result_add(r, "clusters", [to_float(cluster_count)])
    r = result_add(r, "mean_density", [to_float(n) / range])
    r
}

// ─── (14) derived_functor: 파생 함자 (코호몰로지 근사) ───

fn scan_derived_functor(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }
    let n = data.len()
    // Chain complex: d0: data -> differences, d1: differences -> second differences
    let mut d0 = []
    let mut i = 0
    while i < n - 1 {
        d0 = d0 + [data[i + 1] - data[i]]
        i = i + 1
    }
    let mut d1 = []
    i = 0
    while i < d0.len() - 1 {
        d1 = d1 + [d0[i + 1] - d0[i]]
        i = i + 1
    }
    // H0 = ker(d0) / im(0) ~ constant segments
    let mut h0 = 0
    i = 0
    while i < d0.len() {
        if abs_f(d0[i]) < 0.01 { h0 = h0 + 1 }
        i = i + 1
    }
    // H1 = ker(d1) / im(d0) ~ linear segments among d0
    let mut ker_d1 = 0
    i = 0
    while i < d1.len() {
        if abs_f(d1[i]) < 0.01 { ker_d1 = ker_d1 + 1 }
        i = i + 1
    }
    let h1 = ker_d1 - h0
    r = result_add(r, "H0_dim", [to_float(h0)])
    r = result_add(r, "H1_dim", [to_float(if h1 > 0 { h1 } else { 0 })])
    // Euler characteristic: h0 - h1
    let euler = h0 - (if h1 > 0 { h1 } else { 0 })
    r = result_add(r, "euler_characteristic", [to_float(euler)])
    // Exactness measure
    let exactness = if d0.len() > 0 { to_float(h0) / to_float(d0.len()) } else { 0.0 }
    r = result_add(r, "exactness", [exactness])
    r
}

// ─── (15) destiny: 목적지/수렴점 예측 ───

fn scan_destiny(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }
    let n = data.len()
    // Trend analysis: where is the data heading?
    let mean = list_mean(data)
    let half = n / 2
    let m1 = list_mean(data[0..half])
    let m2 = list_mean(data[half..n])
    let trend = m2 - m1
    // Extrapolate destination
    let dest = m2 + trend
    r = result_add(r, "destiny_point", [dest])
    r = result_add(r, "trend", [trend])
    // Convergence test: is variance decreasing?
    let v1 = list_variance(data[0..half], m1)
    let v2 = list_variance(data[half..n], m2)
    let converging = if v1 > 0.001 { v2 / v1 } else { 1.0 }
    r = result_add(r, "convergence_ratio", [converging])
    // Attractor detection: last few values cluster?
    let tail_size = if n > 6 { 6 } else { n }
    let tail = data[n - tail_size..n]
    let tail_m = list_mean(tail)
    let tail_v = list_variance(tail, tail_m)
    if tail_v < v2 * 0.5 || tail_v < 0.01 {
        r = result_add(r, "attractor", [tail_m])
    }
    r
}

// ─── (16) diamond: 다이아몬드 격자 패턴 ───

fn scan_diamond(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }
    let n = data.len()
    let sorted = list_sort(data)
    // Diamond lattice: tetrahedral coordination (4 neighbors)
    // Check if differences form regular patterns
    let mut diffs = []
    let mut i = 1
    while i < n {
        diffs = diffs + [sorted[i] - sorted[i - 1]]
        i = i + 1
    }
    if diffs.len() < 2 { return r }
    let mean_diff = list_mean(diffs)
    let diff_var = list_variance(diffs, mean_diff)
    // Regularity: low variance in spacings = lattice-like
    let regularity = if mean_diff > 0.001 { 1.0 - sqrt_f(diff_var) / mean_diff } else { 0.0 }
    r = result_add(r, "lattice_regularity", [max_f(0.0, regularity)])
    // Tetrahedral coordination number: count points within 1.5 * mean_diff
    let mut coord_nums = []
    i = 0
    while i < n {
        let mut count = 0
        let mut j = 0
        while j < n {
            if i != j && abs_f(data[i] - data[j]) < mean_diff * 1.5 {
                count = count + 1
            }
            j = j + 1
        }
        coord_nums = coord_nums + [to_float(count)]
        i = i + 1
    }
    let avg_coord = list_mean(coord_nums)
    r = result_add(r, "coordination_number", [avg_coord])
    // Diamond: coordination should be ~4
    if abs_f(avg_coord - 4.0) < 1.5 {
        r = result_add(r, "diamond_signature", [avg_coord])
    }
    r
}

// ─── (17) dimension_reduction: 차원 축소 (PCA 근사) ───

fn scan_dimension_reduction(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }
    let n = data.len()
    let mean = list_mean(data)
    let var = list_variance(data, mean)
    // Effective dimensionality from eigenvalue-like analysis
    // Use autocorrelation spectrum as proxy for eigenvalues
    let max_lag = if n / 4 < 10 { n / 4 } else { 10 }
    let mut eigenvalues = []
    let mut lag = 0
    while lag <= max_lag {
        let mut ac = 0.0
        let mut i = 0
        while i < n - lag {
            ac = ac + (data[i] - mean) * (data[i + lag] - mean)
            i = i + 1
        }
        ac = if var > 0.001 { ac / (to_float(n - lag) * var) } else { 0.0 }
        eigenvalues = eigenvalues + [abs_f(ac)]
        lag = lag + 1
    }
    // Participation ratio: effective dimensionality
    let eig_sum = list_sum(eigenvalues)
    let mut eig_sq_sum = 0.0
    let mut ei = 0
    while ei < eigenvalues.len() {
        eig_sq_sum = eig_sq_sum + eigenvalues[ei] * eigenvalues[ei]
        ei = ei + 1
    }
    let eff_dim = if eig_sq_sum > 0.001 { eig_sum * eig_sum / eig_sq_sum } else { 1.0 }
    r = result_add(r, "effective_dimension", [eff_dim])
    // Variance explained by first "eigenvalue"
    let var_explained = if eig_sum > 0.001 { eigenvalues[0] / eig_sum } else { 0.0 }
    r = result_add(r, "variance_explained_pc1", [var_explained])
    r = result_add(r, "eigenvalue_spectrum", eigenvalues)
    r
}

// ─── (18) dimensional_bridge: 차원 간 브릿지 탐지 ───

fn scan_dimensional_bridge(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    let n = data.len()
    // Split data into "dimensions" (segments of 6)
    let seg_size = if n / 6 > 1 { n / 6 } else { 1 }
    let n_segs = if n / seg_size < 6 { n / seg_size } else { 6 }
    if n_segs < 2 { return r }
    let mut seg_means = []
    let mut seg_vars = []
    let mut si = 0
    while si < n_segs {
        let start = si * seg_size
        let end = if (si + 1) * seg_size < n { (si + 1) * seg_size } else { n }
        let seg = data[start..end]
        let sm = list_mean(seg)
        let sv = list_variance(seg, sm)
        seg_means = seg_means + [sm]
        seg_vars = seg_vars + [sv]
        si = si + 1
    }
    // Bridge strength: correlation between adjacent segments
    let mut bridge_strengths = []
    si = 0
    while si < n_segs - 1 {
        let s1_start = si * seg_size
        let s2_start = (si + 1) * seg_size
        let len = seg_size
        let m1 = seg_means[si]
        let m2 = seg_means[si + 1]
        let mut cov = 0.0
        let mut v1 = 0.0
        let mut v2 = 0.0
        let mut k = 0
        while k < len && s1_start + k < n && s2_start + k < n {
            let a = data[s1_start + k] - m1
            let b = data[s2_start + k] - m2
            cov = cov + a * b
            v1 = v1 + a * a
            v2 = v2 + b * b
            k = k + 1
        }
        let denom = sqrt_f(v1) * sqrt_f(v2)
        let strength = if denom > 0.001 { abs_f(cov / denom) } else { 0.0 }
        bridge_strengths = bridge_strengths + [strength]
        si = si + 1
    }
    r = result_add(r, "bridge_strengths", bridge_strengths)
    let mean_bridge = list_mean(bridge_strengths)
    r = result_add(r, "mean_bridge_strength", [mean_bridge])
    // n=6 resonance: check if segment means relate by n=6 constants
    let mut resonances = 0
    si = 0
    while si < n_segs {
        let mut sj = si + 1
        while sj < n_segs {
            if abs_f(seg_means[sj]) > 0.001 {
                let ratio = seg_means[si] / seg_means[sj]
                if abs_f(ratio - 2.0) < 0.1 || abs_f(ratio - 3.0) < 0.1 || abs_f(ratio - 6.0) < 0.1 {
                    resonances = resonances + 1
                }
            }
            sj = sj + 1
        }
        si = si + 1
    }
    if resonances > 0 {
        r = result_add(r, "n6_resonance", [to_float(resonances)])
    }
    r
}

// ─── (19) discrete_log: 이산 로그 패턴 ───

fn scan_discrete_log(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    let n = data.len()
    // Discrete logarithm structure: check if data[i] ~ g^i mod p
    // Test: are successive ratios approximately constant?
    let mut ratios = []
    let mut i = 1
    while i < n {
        if abs_f(data[i - 1]) > 0.001 {
            ratios = ratios + [data[i] / data[i - 1]]
        }
        i = i + 1
    }
    if ratios.len() < 2 { return r }
    let mean_ratio = list_mean(ratios)
    let ratio_var = list_variance(ratios, mean_ratio)
    // Geometric progression test
    let gp_score = if abs_f(mean_ratio) > 0.001 { 1.0 - sqrt_f(ratio_var) / abs_f(mean_ratio) } else { 0.0 }
    r = result_add(r, "gp_score", [max_f(0.0, gp_score)])
    r = result_add(r, "base_estimate", [mean_ratio])
    // Period detection: is there a cycle in ratios?
    let mut best_period = 0
    let mut best_match = 0.0
    let mut p = 2
    while p <= ratios.len() / 2 {
        let mut match_score = 0.0
        let mut mc = 0
        let mut ri = 0
        while ri + p < ratios.len() {
            if abs_f(ratios[ri] - ratios[ri + p]) < abs_f(mean_ratio) * 0.1 {
                match_score = match_score + 1.0
            }
            mc = mc + 1
            ri = ri + 1
        }
        if mc > 0 { match_score = match_score / to_float(mc) }
        if match_score > best_match {
            best_match = match_score
            best_period = p
        }
        p = p + 1
    }
    if best_period > 0 && best_match > 0.5 {
        r = result_add(r, "period", [to_float(best_period), best_match])
    }
    r
}

// ─── (20) dispersion_relation: 분산 관계 ───

fn scan_dispersion_relation(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    let n = data.len()
    // Dispersion: omega(k) relationship from data as time series
    // Compute simple DFT magnitudes
    let max_k = if n / 2 < 20 { n / 2 } else { 20 }
    let mut spectrum = []
    let mut k = 1
    while k <= max_k {
        let mut re = 0.0
        let mut im = 0.0
        let mut t = 0
        while t < n {
            let angle = 2.0 * pi * to_float(k) * to_float(t) / to_float(n)
            re = re + data[t] * cos_f(angle)
            im = im + data[t] * sin_f(angle)
            t = t + 1
        }
        let mag = sqrt_f(re * re + im * im) / to_float(n)
        spectrum = spectrum + [mag]
        k = k + 1
    }
    r = result_add(r, "frequency_spectrum", spectrum)
    // Dominant frequency
    let mut max_mag = 0.0
    let mut dom_k = 0
    let mut ki = 0
    while ki < spectrum.len() {
        if spectrum[ki] > max_mag {
            max_mag = spectrum[ki]
            dom_k = ki + 1
        }
        ki = ki + 1
    }
    r = result_add(r, "dominant_frequency", [to_float(dom_k), max_mag])
    // Dispersion type: linear (acoustic), quadratic (free particle), or flat (optical)
    // Fit omega ~ k^alpha by log-log regression
    if spectrum.len() >= 3 {
        let mut lk = []
        let mut lw = []
        ki = 0
        while ki < spectrum.len() {
            if spectrum[ki] > 0.001 {
                lk = lk + [ln_f(to_float(ki + 1))]
                lw = lw + [ln_f(spectrum[ki])]
            }
            ki = ki + 1
        }
        if lk.len() >= 2 {
            let mk = list_mean(lk)
            let mw = list_mean(lw)
            let mut cov = 0.0
            let mut vk = 0.0
            let mut li = 0
            while li < lk.len() {
                cov = cov + (lk[li] - mk) * (lw[li] - mw)
                vk = vk + (lk[li] - mk) * (lk[li] - mk)
                li = li + 1
            }
            let alpha = if vk > 0.001 { cov / vk } else { 0.0 }
            r = result_add(r, "dispersion_exponent", [alpha])
        }
    }
    r
}

// ─── (21) divergence: KL/JS 발산 ───

fn scan_divergence(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }
    let n = data.len()
    let mid = n / 2
    // Split into two distributions and measure divergence
    let p_data = data[0..mid]
    let q_data = data[mid..n]
    // Build histograms
    let all_min = list_min(data)
    let all_max = list_max(data)
    let range = all_max - all_min
    if range < 0.001 { return r }
    let n_bins = 8
    let bw = range / to_float(n_bins)
    let mut p_bins = []
    let mut q_bins = []
    let mut bi = 0
    while bi < n_bins {
        p_bins = p_bins + [0.001]
        q_bins = q_bins + [0.001]
        bi = bi + 1
    }
    let mut i = 0
    while i < p_data.len() {
        let mut b = to_int((p_data[i] - all_min) / bw)
        if b >= n_bins { b = n_bins - 1 }
        p_bins[b] = p_bins[b] + 1.0
        i = i + 1
    }
    i = 0
    while i < q_data.len() {
        let mut b = to_int((q_data[i] - all_min) / bw)
        if b >= n_bins { b = n_bins - 1 }
        q_bins[b] = q_bins[b] + 1.0
        i = i + 1
    }
    // Normalize
    let p_total = list_sum(p_bins)
    let q_total = list_sum(q_bins)
    bi = 0
    while bi < n_bins {
        p_bins[bi] = p_bins[bi] / p_total
        q_bins[bi] = q_bins[bi] / q_total
        bi = bi + 1
    }
    // KL(P||Q)
    let mut kl = 0.0
    bi = 0
    while bi < n_bins {
        if p_bins[bi] > 0.0001 {
            kl = kl + p_bins[bi] * ln_f(p_bins[bi] / q_bins[bi])
        }
        bi = bi + 1
    }
    r = result_add(r, "kl_divergence", [kl])
    // JS divergence: 0.5 * KL(P||M) + 0.5 * KL(Q||M) where M = (P+Q)/2
    let mut m_bins = []
    bi = 0
    while bi < n_bins {
        m_bins = m_bins + [(p_bins[bi] + q_bins[bi]) / 2.0]
        bi = bi + 1
    }
    let mut js = 0.0
    bi = 0
    while bi < n_bins {
        if p_bins[bi] > 0.0001 { js = js + 0.5 * p_bins[bi] * ln_f(p_bins[bi] / m_bins[bi]) }
        if q_bins[bi] > 0.0001 { js = js + 0.5 * q_bins[bi] * ln_f(q_bins[bi] / m_bins[bi]) }
        bi = bi + 1
    }
    r = result_add(r, "js_divergence", [js])
    r
}

// ─── (22) electromagnetic_wave: 전자기파 패턴 ───

fn scan_electromagnetic_wave(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    let n = data.len()
    // Wave detection: fit sinusoidal model
    // Find dominant frequency via DFT
    let max_k = if n / 2 < 15 { n / 2 } else { 15 }
    let mut best_k = 1
    let mut best_power = 0.0
    let mut k = 1
    while k <= max_k {
        let mut re = 0.0
        let mut im = 0.0
        let mut t = 0
        while t < n {
            let angle = 2.0 * pi * to_float(k) * to_float(t) / to_float(n)
            re = re + data[t] * cos_f(angle)
            im = im + data[t] * sin_f(angle)
            t = t + 1
        }
        let power = (re * re + im * im) / to_float(n * n)
        if power > best_power {
            best_power = power
            best_k = k
        }
        k = k + 1
    }
    let frequency = to_float(best_k) / to_float(n)
    let wavelength = if frequency > 0.001 { 1.0 / frequency } else { to_float(n) }
    r = result_add(r, "frequency", [frequency])
    r = result_add(r, "wavelength", [wavelength])
    r = result_add(r, "wave_power", [best_power])
    // Phase velocity: wavelength * frequency (should be ~1 in normalized units)
    r = result_add(r, "phase_velocity", [wavelength * frequency])
    // E-B field coupling: check if derivative correlates with original (E ~ dB/dt)
    let mean = list_mean(data)
    let mut deriv = []
    let mut i = 1
    while i < n {
        deriv = deriv + [data[i] - data[i - 1]]
        i = i + 1
    }
    let dm = list_mean(deriv)
    let mut cov = 0.0
    let mut v1 = 0.0
    let mut v2 = 0.0
    i = 0
    while i < deriv.len() {
        let a = data[i] - mean
        let b = deriv[i] - dm
        cov = cov + a * b
        v1 = v1 + a * a
        v2 = v2 + b * b
        i = i + 1
    }
    let coupling = if sqrt_f(v1) * sqrt_f(v2) > 0.001 { abs_f(cov / (sqrt_f(v1) * sqrt_f(v2))) } else { 0.0 }
    r = result_add(r, "eb_coupling", [coupling])
    r
}

// ─── (23) element_combination: 원소 조합 패턴 ───

fn scan_element_combination(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    let n = data.len()
    // Treat data values as "atomic numbers" or element properties
    // Check for combinations that produce known constants
    let mut combo_hits = 0
    let mut i = 0
    while i < n && i < 30 {
        let mut j = i + 1
        while j < n && j < 30 {
            let sum = data[i] + data[j]
            let prod = data[i] * data[j]
            // Check against n=6 constants
            if abs_f(sum - 6.0) < 0.1 || abs_f(sum - 12.0) < 0.1 || abs_f(sum - 24.0) < 0.1 {
                combo_hits = combo_hits + 1
                r = result_add(r, "element_sum_n6", [data[i], data[j], sum])
            }
            if abs_f(prod - 6.0) < 0.5 || abs_f(prod - 12.0) < 0.5 || abs_f(prod - 24.0) < 0.5 {
                combo_hits = combo_hits + 1
                r = result_add(r, "element_prod_n6", [data[i], data[j], prod])
            }
            j = j + 1
        }
        i = i + 1
    }
    // Stoichiometric ratios: integer ratios between pairs
    let mut int_ratios = 0
    i = 0
    while i < n && i < 20 {
        let mut j = i + 1
        while j < n && j < 20 {
            if abs_f(data[j]) > 0.1 {
                let ratio = data[i] / data[j]
                let rounded = to_float(to_int(ratio + 0.5))
                if abs_f(ratio - rounded) < 0.05 && rounded > 0.5 && rounded < 10.5 {
                    int_ratios = int_ratios + 1
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    r = result_add(r, "integer_ratio_pairs", [to_float(int_ratios)])
    r
}

// ─── (24) element: 원소 특성 매칭 ───

fn scan_element(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 1 { return r }
    // Match data values to atomic numbers, common element properties
    comptime const atomic_special = [1.0, 2.0, 6.0, 7.0, 8.0, 26.0, 29.0, 47.0, 79.0]
    comptime const atomic_names = ["H", "He", "C", "N", "O", "Fe", "Cu", "Ag", "Au"]
    let mut matches = 0
    let mut i = 0
    while i < data.len() {
        let v = data[i]
        let mut k = 0
        while k < atomic_special.len() {
            if abs_f(v - atomic_special[k]) < 0.5 {
                r = result_add(r, "element_" + atomic_names[k], [v])
                matches = matches + 1
            }
            k = k + 1
        }
        i = i + 1
    }
    if matches > 0 {
        r = result_add(r, "element_matches", [to_float(matches)])
    }
    r
}

// ─── (25) em: 전자기 필드 분석 ───

fn scan_em(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }
    let n = data.len()
    let mean = list_mean(data)
    // Maxwell-like: divergence (sum of differences) and curl (alternating differences)
    let mut div_sum = 0.0
    let mut curl_sum = 0.0
    let mut i = 1
    while i < n {
        let diff = data[i] - data[i - 1]
        div_sum = div_sum + diff
        curl_sum = curl_sum + diff * (if i % 2 == 0 { 1.0 } else { 0.0 - 1.0 })
        i = i + 1
    }
    r = result_add(r, "divergence", [div_sum / to_float(n)])
    r = result_add(r, "curl", [curl_sum / to_float(n)])
    // Field energy: sum of squares
    let mut energy = 0.0
    i = 0
    while i < n {
        energy = energy + data[i] * data[i]
        i = i + 1
    }
    energy = energy / to_float(n)
    r = result_add(r, "field_energy", [energy])
    // Fine structure check: alpha ~ 1/137 in ratios
    i = 0
    while i < n {
        if abs_f(data[i] - fine_structure_inv) < 1.0 {
            r = result_add(r, "fine_structure_match", [data[i]])
        }
        if abs_f(data[i]) > 0.001 && abs_f(1.0 / data[i] - fine_structure) < 0.001 {
            r = result_add(r, "alpha_match", [data[i]])
        }
        i = i + 1
    }
    r
}

// ─── (26) emergence: 창발 패턴 탐지 ───

fn scan_emergence(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    let n = data.len()
    let mean = list_mean(data)
    let var = list_variance(data, mean)
    let std = sqrt_f(var)
    // Phase transition detection: sudden change in running statistics
    let window = if n / 4 > 3 { n / 4 } else { 3 }
    let mut transitions = 0
    let mut max_jump = 0.0
    let mut i = window
    while i + window <= n {
        let m1 = list_mean(data[i - window..i])
        let m2 = list_mean(data[i..i + window])
        let jump = abs_f(m2 - m1)
        if jump > std * 1.5 {
            transitions = transitions + 1
            if jump > max_jump { max_jump = jump }
        }
        i = i + 1
    }
    r = result_add(r, "phase_transitions", [to_float(transitions)])
    r = result_add(r, "max_transition_jump", [max_jump])
    // Complexity measure: number of distinct patterns (unique rounded values)
    let mut unique = 0
    let mut seen = []
    let mut i = 0
    while i < n {
        let rounded = to_float(to_int(data[i] * 100.0)) / 100.0
        let mut found = false
        let mut j = 0
        while j < seen.len() {
            if abs_f(seen[j] - rounded) < 0.001 { found = true }
            j = j + 1
        }
        if !found {
            seen = seen + [rounded]
            unique = unique + 1
        }
        i = i + 1
    }
    let complexity = to_float(unique) / to_float(n)
    r = result_add(r, "complexity", [complexity])
    // Self-organization: auto-mutual information
    if var > 0.001 {
        let mut mi = 0.0
        let mut i = 0
        while i < n - 1 {
            let x = (data[i] - mean) / std
            let y = (data[i + 1] - mean) / std
            mi = mi + abs_f(x * y)
            i = i + 1
        }
        mi = mi / to_float(n - 1)
        r = result_add(r, "self_organization", [mi])
    }
    r
}

// ─── (27) engine_discovery: 엔진 발견 패턴 ───

fn scan_engine_discovery(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    let n = data.len()
    // Efficiency metric: output/input ratio patterns
    let mut efficiencies = []
    let mut i = 1
    while i < n {
        if abs_f(data[i - 1]) > 0.001 {
            efficiencies = efficiencies + [abs_f(data[i] / data[i - 1])]
        }
        i = i + 1
    }
    if efficiencies.len() > 0 {
        let eff_mean = list_mean(efficiencies)
        r = result_add(r, "mean_efficiency", [eff_mean])
        // Carnot limit check: max efficiency
        let eff_max = list_max(efficiencies)
        r = result_add(r, "max_efficiency", [eff_max])
    }
    // Power output pattern: energy * rate
    let mut power = []
    i = 1
    while i < n {
        power = power + [abs_f(data[i] * (data[i] - data[i - 1]))]
        i = i + 1
    }
    if power.len() > 0 {
        r = result_add(r, "mean_power", [list_mean(power)])
        r = result_add(r, "peak_power", [list_max(power)])
    }
    // Resonance detection: values near n=6 harmonics
    let mut resonances = 0
    i = 0
    while i < n {
        let v = abs_f(data[i])
        if v > 0.001 {
            let mod6 = v - to_float(to_int(v / 6.0)) * 6.0
            if mod6 < 0.5 || mod6 > 5.5 { resonances = resonances + 1 }
        }
        i = i + 1
    }
    if resonances > 0 {
        r = result_add(r, "n6_resonance", [to_float(resonances)])
    }
    r
}

// ─── (28) entropy: 엔트로피 분석 ───

fn scan_entropy(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    let n = data.len()
    // Shannon entropy
    let sorted = list_sort(data)
    let range = sorted[n - 1] - sorted[0]
    if range < 0.001 {
        r = result_add(r, "entropy", [0.0])
        return r
    }
    let n_bins = if n > 20 { 10 } else { 5 }
    let bw = range / to_float(n_bins)
    let mut bins = []
    let mut bi = 0
    while bi < n_bins {
        bins = bins + [0.0]
        bi = bi + 1
    }
    let mut i = 0
    while i < n {
        let mut b = to_int((data[i] - sorted[0]) / bw)
        if b >= n_bins { b = n_bins - 1 }
        bins[b] = bins[b] + 1.0
        i = i + 1
    }
    let mut entropy = 0.0
    bi = 0
    while bi < n_bins {
        let p = bins[bi] / to_float(n)
        if p > 0.0 { entropy = entropy - p * ln_f(p) }
        bi = bi + 1
    }
    r = result_add(r, "shannon_entropy", [entropy])
    // Relative entropy (vs uniform)
    let max_ent = ln_f(to_float(n_bins))
    r = result_add(r, "relative_entropy", [if max_ent > 0.0 { entropy / max_ent } else { 0.0 }])
    // Sample entropy (SampEn) approximation: count template matches
    let tol = sqrt_f(list_variance(data, list_mean(data))) * 0.2
    let m = 2
    let mut count_m = 0
    let mut count_m1 = 0
    i = 0
    while i < n - m {
        let mut j = i + 1
        while j < n - m {
            let mut match_m = true
            let mut k = 0
            while k < m {
                if abs_f(data[i + k] - data[j + k]) > tol { match_m = false }
                k = k + 1
            }
            if match_m {
                count_m = count_m + 1
                if i + m < n && j + m < n && abs_f(data[i + m] - data[j + m]) <= tol {
                    count_m1 = count_m1 + 1
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    let sampen = if count_m > 0 { 0.0 - ln_f(to_float(count_m1 + 1) / to_float(count_m + 1)) } else { 0.0 }
    r = result_add(r, "sample_entropy", [sampen])
    r
}

// ─── (29) environment: 환경 변수 탐지 ───

fn scan_environment(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    let n = data.len()
    // Stability: running variance
    let window = if n / 3 > 3 { n / 3 } else { 3 }
    let mut stability_scores = []
    let mut i = 0
    while i + window <= n {
        let chunk = data[i..i + window]
        let m = list_mean(chunk)
        let v = list_variance(chunk, m)
        stability_scores = stability_scores + [v]
        i = i + window
    }
    if stability_scores.len() > 0 {
        let mean_stab = list_mean(stability_scores)
        r = result_add(r, "mean_volatility", [mean_stab])
        // Regime changes: large changes in variance
        let mut regime_changes = 0
        let mut si = 1
        while si < stability_scores.len() {
            if stability_scores[si - 1] > 0.001 {
                let ratio = stability_scores[si] / stability_scores[si - 1]
                if ratio > 3.0 || ratio < 0.333 { regime_changes = regime_changes + 1 }
            }
            si = si + 1
        }
        r = result_add(r, "regime_changes", [to_float(regime_changes)])
    }
    // Noise level: high-frequency component
    let mut noise = 0.0
    let mut i = 1
    while i < n - 1 {
        let smooth = (data[i - 1] + data[i] + data[i + 1]) / 3.0
        noise = noise + (data[i] - smooth) * (data[i] - smooth)
        i = i + 1
    }
    noise = sqrt_f(noise / to_float(n - 2))
    r = result_add(r, "noise_level", [noise])
    r
}

// ─── (30) epigenetic: 후성유전학 패턴 ───

fn scan_epigenetic(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    let n = data.len()
    // Methylation-like: binary-ish pattern (values clustered at two levels)
    let sorted = list_sort(data)
    let median = sorted[n / 2]
    let mut low_count = 0
    let mut high_count = 0
    let mut i = 0
    while i < n {
        if data[i] < median { low_count = low_count + 1 } else { high_count = high_count + 1 }
        i = i + 1
    }
    let bimodality = to_float(if low_count < high_count { low_count } else { high_count }) / to_float(n)
    r = result_add(r, "bimodality", [bimodality])
    // Heredity: correlation between adjacent values (information inheritance)
    let mean = list_mean(data)
    let var = list_variance(data, mean)
    if var > 0.001 {
        let mut heredity = 0.0
        i = 0
        while i < n - 1 {
            heredity = heredity + (data[i] - mean) * (data[i + 1] - mean)
            i = i + 1
        }
        heredity = heredity / (to_float(n - 1) * var)
        r = result_add(r, "heredity", [heredity])
    }
    // Silencing: fraction of values near zero (gene silencing analog)
    let threshold = abs_f(list_max(data) - list_min(data)) * 0.05
    let mut silenced = 0
    i = 0
    while i < n {
        if abs_f(data[i] - list_min(data)) < threshold { silenced = silenced + 1 }
        i = i + 1
    }
    r = result_add(r, "silencing_fraction", [to_float(silenced) / to_float(n)])
    // Imprinting: asymmetric distribution
    let skewness = if var > 0.001 {
        let mut s3 = 0.0
        i = 0
        while i < n {
            let d = data[i] - mean
            s3 = s3 + d * d * d
            i = i + 1
        }
        s3 / (to_float(n) * var * sqrt_f(var))
    } else { 0.0 }
    r = result_add(r, "imprinting_skew", [skewness])
    r
}

// ─── (31) ergodicity_breaking: 에르고딕성 파괴 탐지 ───

fn scan_ergodicity_breaking(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 8 { return r }
    let n = data.len()
    let mean = list_mean(data)
    let var = list_variance(data, mean)
    let scale = if var > 0.0001 { sqrt_f(var) } else { 0.0001 }
    // Ergodic gap: |time_avg(t) - ensemble_avg| max
    let mut running = 0.0
    let mut max_gap = 0.0
    let mut i = 0
    while i < n {
        running = running + data[i]
        let time_avg = running / to_float(i + 1)
        let gap = abs_f(time_avg - mean) / scale
        if gap > max_gap { max_gap = gap }
        i = i + 1
    }
    r = result_add(r, "ergodic_gap", [max_gap])
    // Correlation decay: autocorrelation at increasing lags
    let max_lag = if n / 4 < 15 { n / 4 } else { 15 }
    let mut decay_rate = 0.0
    if var > 0.001 {
        let mut prev_ac = 1.0
        let mut lag = 1
        while lag <= max_lag {
            let mut ac = 0.0
            let mut j = 0
            while j < n - lag {
                ac = ac + (data[j] - mean) * (data[j + lag] - mean)
                j = j + 1
            }
            ac = ac / (to_float(n - lag) * var)
            if lag == 1 && abs_f(ac) > 0.01 {
                decay_rate = 0.0 - ln_f(abs_f(ac))
            }
            lag = lag + 1
        }
    }
    r = result_add(r, "correlation_decay", [decay_rate])
    // Recurrence: how often does the signal return near its initial value?
    let init = data[0]
    let mut recurrence = 0
    let tol = scale * 0.5
    i = 1
    while i < n {
        if abs_f(data[i] - init) < tol { recurrence = recurrence + 1 }
        i = i + 1
    }
    r = result_add(r, "recurrence_rate", [to_float(recurrence) / to_float(n)])
    // Weak ergodicity breaking: compare time-averaged variance to ensemble variance
    let half = n / 2
    let v1 = list_variance(data[0..half], list_mean(data[0..half]))
    let v2 = list_variance(data[half..n], list_mean(data[half..n]))
    let web = if var > 0.001 { abs_f(v1 - v2) / var } else { 0.0 }
    r = result_add(r, "web_param", [web])
    r
}

// ─── (32) event_horizon: 사건의 지평선 탐지 ───

fn scan_event_horizon(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    let n = data.len()
    // Compute centroid distance
    let mean = list_mean(data)
    let mut radii = []
    let mut i = 0
    while i < n {
        radii = radii + [abs_f(data[i] - mean)]
        i = i + 1
    }
    let sorted_r = list_sort(radii)
    let median_r = sorted_r[n / 2]
    // Horizon: radius containing 90% of data
    let h_idx = to_int(to_float(n) * 0.9)
    let horizon = if h_idx < n { sorted_r[h_idx] } else { sorted_r[n - 1] }
    // Escape fraction
    let mut beyond = 0
    i = 0
    while i < n {
        if radii[i] > horizon { beyond = beyond + 1 }
        i = i + 1
    }
    let escape_frac = to_float(beyond) / to_float(n)
    let norm_horizon = if median_r > 0.0001 { horizon / median_r } else { horizon }
    r = result_add(r, "horizon_radius", [norm_horizon])
    r = result_add(r, "escape_fraction", [escape_frac])
    // Information loss: entropy difference inner vs outer
    let mut inner = []
    let mut outer = []
    i = 0
    while i < n {
        if radii[i] <= horizon { inner = inner + [data[i]] } else { outer = outer + [data[i]] }
        i = i + 1
    }
    let ent_in = if inner.len() > 2 {
        let m = list_mean(inner)
        let v = list_variance(inner, m)
        if v > 0.0 { 0.5 * ln_f(2.0 * pi * e_const * v) } else { 0.0 }
    } else { 0.0 }
    let ent_out = if outer.len() > 2 {
        let m = list_mean(outer)
        let v = list_variance(outer, m)
        if v > 0.0 { 0.5 * ln_f(2.0 * pi * e_const * v) } else { 0.0 }
    } else { 0.0 }
    r = result_add(r, "information_loss", [abs_f(ent_out - ent_in)])
    // Hawking temperature: inverse density at horizon shell
    let shell = median_r * 0.2
    let mut near_h = 0
    i = 0
    while i < n {
        if abs_f(radii[i] - horizon) < shell { near_h = near_h + 1 }
        i = i + 1
    }
    let hawking = if near_h >= 2 { 1.0 / (to_float(near_h) / (2.0 * shell)) } else { 0.0 }
    r = result_add(r, "hawking_temperature", [hawking])
    r
}

// ─── (33) evolution: 진화 적합도 랜드스케이프 ───

fn scan_evolution(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }
    let n = data.len()
    // Fitness: local density (inverse of distance to nearest neighbor)
    let mut fitness = []
    let mut i = 0
    while i < n {
        let mut min_dist = 999999999.0
        let mut j = 0
        while j < n {
            if i != j {
                let d = abs_f(data[i] - data[j])
                if d < min_dist { min_dist = d }
            }
            j = j + 1
        }
        fitness = fitness + [if min_dist > 0.0001 { 1.0 / min_dist } else { 10000.0 }]
        i = i + 1
    }
    let fit_mean = list_mean(fitness)
    let fit_var = list_variance(fitness, fit_mean)
    r = result_add(r, "fitness_variance", [fit_var])
    // Pareto front: non-dominated points
    let mut dominated = []
    i = 0
    while i < n {
        dominated = dominated + [false]
        i = i + 1
    }
    let median_dist = list_mean(fitness)  // approximate
    i = 0
    while i < n {
        if !dominated[i] {
            let mut j = 0
            while j < n {
                if i != j && !dominated[j] && fitness[i] > fitness[j] && abs_f(data[i] - data[j]) < median_dist {
                    dominated[j] = true
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    let mut pareto = 0
    i = 0
    while i < n {
        if !dominated[i] { pareto = pareto + 1 }
        i = i + 1
    }
    r = result_add(r, "pareto_front_size", [to_float(pareto)])
    r
}

// ─── (34) exotic_matter: 이상 물질 탐지 ───

fn scan_exotic_matter(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    let n = data.len()
    let mean = list_mean(data)
    let var = list_variance(data, mean)
    let std = sqrt_f(var)
    // Negative curvature: second derivative negative
    let mut neg_curv = 0
    let mut total = 0
    let mut i = 1
    while i < n - 1 {
        let curv = data[i + 1] - 2.0 * data[i] + data[i - 1]
        total = total + 1
        if curv < 0.0 - 0.001 { neg_curv = neg_curv + 1 }
        i = i + 1
    }
    let neg_frac = if total > 0 { to_float(neg_curv) / to_float(total) } else { 0.0 }
    r = result_add(r, "negative_curvature_fraction", [neg_frac])
    // Anti-correlation: negative autocorrelation at lag 1
    if var > 0.001 {
        let mut ac = 0.0
        i = 0
        while i < n - 1 {
            ac = ac + (data[i] - mean) * (data[i + 1] - mean)
            i = i + 1
        }
        ac = ac / (to_float(n - 1) * var)
        if ac < 0.0 - 0.1 {
            r = result_add(r, "anti_correlation", [ac])
        }
    }
    // Energy violation: points far below local average (negative energy pockets)
    let mut violations = 0
    i = 1
    while i < n - 1 {
        let local_avg = (data[i - 1] + data[i + 1]) / 2.0
        if data[i] < local_avg - std * 2.0 { violations = violations + 1 }
        i = i + 1
    }
    r = result_add(r, "energy_violations", [to_float(violations)])
    let exotic_frac = to_float(violations) / to_float(n)
    r = result_add(r, "exotic_fraction", [exotic_frac])
    r
}

// ─── (35) expanding_scan: 확장 스캔 (다중 스케일) ───

fn scan_expanding_scan(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }
    let n = data.len()
    // Multi-scale analysis: k = 1, 2, 4, 8, ...
    let mut densities = []
    let mut entropies = []
    let mut scales = []
    let mut k = 1
    while k <= n / 2 {
        scales = scales + [to_float(k)]
        // Density at scale k: average inverse distance to k-th nearest point
        let sorted = list_sort(data)
        let mut dens = 0.0
        let mut i = 0
        while i < n {
            // k-th nearest distance approximation from sorted
            let pos = 0
            let mut min_d = 999999999.0
            let mut j = 0
            let mut count = 0
            while j < n {
                if i != j {
                    let d = abs_f(data[i] - data[j])
                    if count < k || d < min_d {
                        if d < min_d { min_d = d }
                        count = count + 1
                    }
                }
                j = j + 1
            }
            dens = dens + (if min_d > 0.0001 { 1.0 / min_d } else { 10000.0 })
            i = i + 1
        }
        densities = densities + [dens / to_float(n)]
        // Entropy at this scale
        let chunk_size = if k < n { k } else { n }
        let mut ent = 0.0
        let total = to_float(n)
        let p = 1.0 / total
        ent = 0.0 - to_float(n) * p * ln_f(p)
        entropies = entropies + [ent]
        k = k * 2
    }
    if densities.len() >= 2 {
        // Scale transition: max entropy change
        let mut max_change = 0.0
        let mut trans_idx = 0
        let mut i = 1
        while i < entropies.len() {
            let ch = abs_f(entropies[i] - entropies[i - 1])
            if ch > max_change {
                max_change = ch
                trans_idx = i
            }
            i = i + 1
        }
        r = result_add(r, "scale_transition", [scales[trans_idx]])
        // Expansion rate
        let first_d = densities[0]
        let last_d = densities[densities.len() - 1]
        let exp_rate = if first_d > 0.001 { abs_f(first_d - last_d) / first_d } else { 0.0 }
        r = result_add(r, "expansion_rate", [exp_rate])
    }
    r = result_add(r, "density_profile", densities)
    r
}

// ─── (36) extrapolation: 경계 외삽 ───

fn scan_extrapolation(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }
    let n = data.len()
    let mean = list_mean(data)
    // Linear regression: y = slope * t + intercept
    let tm = to_float(n - 1) / 2.0
    let mut cov = 0.0
    let mut tv = 0.0
    let mut i = 0
    while i < n {
        let t = to_float(i) - tm
        cov = cov + t * (data[i] - mean)
        tv = tv + t * t
        i = i + 1
    }
    let slope = if tv > 0.001 { cov / tv } else { 0.0 }
    let intercept = mean - slope * tm
    // R-squared
    let mut ss_res = 0.0
    let mut ss_tot = 0.0
    i = 0
    while i < n {
        let pred = slope * to_float(i) + intercept
        ss_res = ss_res + (data[i] - pred) * (data[i] - pred)
        ss_tot = ss_tot + (data[i] - mean) * (data[i] - mean)
        i = i + 1
    }
    let r2 = if ss_tot > 0.001 { max_f(0.0, 1.0 - ss_res / ss_tot) } else { 0.0 }
    r = result_add(r, "r_squared", [r2])
    r = result_add(r, "slope", [slope])
    // Extrapolation: project forward and backward by n/2
    let forward = slope * to_float(n + n / 2) + intercept
    let backward = slope * to_float(0 - n / 2) + intercept
    r = result_add(r, "forward_extrapolation", [forward])
    r = result_add(r, "backward_extrapolation", [backward])
    // Boundary expansion
    let obs_range = list_max(data) - list_min(data)
    let extrap_range = abs_f(forward - backward)
    let expansion = if obs_range > 0.001 { extrap_range / obs_range } else { 0.0 }
    r = result_add(r, "boundary_expansion", [expansion])
    // Divergence risk: high slope + low R2
    let divergence = abs_f(slope) * (1.0 - r2)
    r = result_add(r, "divergence_risk", [divergence])
    r
}

// ─── (37) faraday_induction: 패러데이 유도 탐지 ───

fn scan_faraday_induction(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }
    let n = data.len()
    // Flux: triangle area for consecutive triplets (proxy for magnetic flux)
    let mut flux = []
    let mut i = 0
    while i + 2 < n {
        // Area of triangle (i, data[i]), (i+1, data[i+1]), (i+2, data[i+2])
        // = 0.5 * |x1(y2-y3) + x2(y3-y1) + x3(y1-y2)| with x = index
        let area = abs_f( to_float(i) * (data[i + 1] - data[i + 2]) + to_float(i + 1) * (data[i + 2] - data[i]) + to_float(i + 2) * (data[i] - data[i + 1]) ) / 2.0
        flux = flux + [area]
        i = i + 1
    }
    if flux.len() < 2 { return r }
    // EMF = |dFlux/dt|
    let mut emf = []
    i = 0
    while i < flux.len() - 1 {
        emf = emf + [abs_f(flux[i + 1] - flux[i])]
        i = i + 1
    }
    let emf_mean = list_mean(emf)
    let emf_var = list_variance(emf, emf_mean)
    let emf_std = sqrt_f(emf_var)
    let emf_max = list_max(emf)
    r = result_add(r, "mean_emf", [emf_mean])
    r = result_add(r, "max_emf", [emf_max])
    // Induction peaks: EMF > mean + 1 sigma
    let threshold = emf_mean + emf_std
    let mut peak_count = 0
    let mut peak_vals = []
    i = 0
    while i < emf.len() {
        if emf[i] > threshold {
            peak_count = peak_count + 1
            peak_vals = peak_vals + [emf[i]]
        }
        i = i + 1
    }
    r = result_add(r, "induction_peaks", [to_float(peak_count)])
    // Coupling: correlation between flux change and value change
    let mut val_changes = []
    i = 0
    while i < emf.len() {
        val_changes = val_changes + [abs_f(data[i + 1] - data[i])]
        i = i + 1
    }
    let vm = list_mean(val_changes)
    let mut cov = 0.0
    let mut ve = 0.0
    let mut vv = 0.0
    i = 0
    while i < emf.len() {
        let de = emf[i] - emf_mean
        let dv = val_changes[i] - vm
        cov = cov + de * dv
        ve = ve + de * de
        vv = vv + dv * dv
        i = i + 1
    }
    let coupling = if sqrt_f(ve) * sqrt_f(vv) > 0.001 { cov / (sqrt_f(ve) * sqrt_f(vv)) } else { 0.0 }
    r = result_add(r, "flux_coupling", [coupling])
    r
}

