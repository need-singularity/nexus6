// ─── 검증 ───

let test_data = n6_vals + phys_vals
let entries = register_applied_lenses(test_data)
assert entries.len() == 34

println("=== lenses_applied: 34 lenses registered ===")
println("  scan functions: 34/34")
println("  test data: " + to_string(len(n6_vals)) + " n6 + " + to_string(len(phys_vals)) + " physics = " + to_string(test_data.len()) + " points")

let mut signal_count = 0
for e in entries {
    if result_nonempty(e.result) { signal_count = signal_count + 1 }
}
println("  signals detected: " + to_string(signal_count) + "/34 lenses")
println("=== lenses_applied verified ===")
