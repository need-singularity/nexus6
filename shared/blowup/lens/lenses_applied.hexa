    entries = entries + [ScanEntry { lens_name: "triangle", lens_category: "applied_T0", result: scan_triangle(data) }]
    entries = entries + [ScanEntry { lens_name: "triangulated_cat", lens_category: "applied_T2", result: scan_triangulated_cat(data) }]
    entries = entries + [ScanEntry { lens_name: "vc_dimension", lens_category: "applied_T2", result: scan_vc_dimension(data) }]
