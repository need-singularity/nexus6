    entries = entries + [ScanEntry { lens_name: "surprise", lens_category: "applied_anomaly", result: scan_surprise(data) }]
    entries = entries + [ScanEntry { lens_name: "symmetry_breaking", lens_category: "applied_T1", result: scan_symmetry_breaking(data) }]
