fn register_applied_lenses(data)  {
    let mut entries = []

    entries = entries + [ScanEntry { lens_name: "skyrmion", lens_category: "applied_T1", result: scan_skyrmion(data) }]
    entries = entries + [ScanEntry { lens_name: "solar_efficiency", lens_category: "applied_T1", result: scan_solar_efficiency(data) }]
    entries = entries + [ScanEntry { lens_name: "spacetime", lens_category: "applied_T1", result: scan_spacetime(data) }]
