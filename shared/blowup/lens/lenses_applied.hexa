// source: shared/blowup/lens/lens_common.hexa.inc

comptime const pi = 3.141592653589793
comptime const two_pi = 6.283185307179586

fn load_n6_consts() -> list {
    let home = exec("printenv HOME")
    let path = home + "/Dev/nexus/shared/n6/n6_constants.jsonl"
    let raw = try { read_file(path) } catch e { return [[], []] }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let trimmed = line.trim()
        if trimmed == "" { continue }
        let mut name = ""
        let mut value = 0.0
        if trimmed.contains("\"name\":\"") {
            let p = trimmed.split("\"name\":\"")
            if p.len() >= 2 { name = p[1].split("\"")[0] }
        }
        if trimmed.contains("\"value\":") {
            let p = trimmed.split("\"value\":")
            if p.len() >= 2 {
                let num_str = p[1].split(",")[0].split("}")[0].trim()
                value = to_float(num_str)
            }
        }
        if name != "" {
            names = names + [name]
            values = values + [value]
        }
    }
    [names, values]
}

fn n6_values(consts: list) -> list {
    consts[1]
}

pure fn min_f(a: float, b: float) -> float { if a < b { a } else { b } }
pure fn max_f(a: float, b: float) -> float { if a > b { a } else { b } }
pure fn clamp_f(v: float, lo: float, hi: float) -> float { min_f(max_f(v, lo), hi) }

pure fn exp_f(x: float) -> float {
    let cx = clamp_f(x, 0.0 - 20.0, 20.0)
    let mut sum = 1.0
    let mut term = 1.0
    let mut k = 1
    while k <= 20 {
        term = term * cx / to_float(k)
        sum = sum + term
        k = k + 1
    }
    sum
}

pure fn sin_f(x: float) -> float {
    let mut v = x
    while v > pi { v = v - two_pi }
    while v < 0.0 - pi { v = v + two_pi }
    let mut sum = 0.0
    let mut term = v
    let mut k = 1
    while k <= 12 {
        sum = sum + term
        term = 0.0 - term * v * v / to_float((2 * k) * (2 * k + 1))
        k = k + 1
    }
    sum
}

pure fn cos_f(x: float) -> float { sin_f(x + pi / 2.0) }

pure fn list_min(data) -> float {
    if data.len() == 0 { return 0.0 }
    let mut m = data[0]
    let mut i = 1
    while i < data.len() {
        if data[i] < m { m = data[i] }
        i = i + 1
    }
    m
}

pure fn list_max(data) -> float {
    if data.len() == 0 { return 0.0 }
    let mut m = data[0]
    let mut i = 1
    while i < data.len() {
        if data[i] > m { m = data[i] }
        i = i + 1
    }
    m
}

pure fn list_sum(data) -> float {
    let mut s = 0.0
    for v in data { s = s + v }
    s
}

// euclidean distance between two flat-data "rows" of width d
pure fn row_dist(data, d: int, i: int, j: int) -> float {
    let mut s = 0.0
    let mut k = 0
    while k < d {
        let diff = data[i * d + k] - data[j * d + k]
        s = s + diff * diff
        k = k + 1
    }
    sqrt_f(s)
}

// ─── n6 + 물리 상수 (load_jsonl_kv from lens_common.hexa.inc) ───

fn load_jsonl_kv(path: string) -> list {
    let raw = try { read_file(path) } catch e { return [[], []] }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let trimmed = line.trim()
        if trimmed == "" { continue }
        let mut name = ""
        let mut value = 0.0
        if trimmed.contains("\"name\":\"") {
            let p = trimmed.split("\"name\":\"")
            if p.len() >= 2 { name = p[1].split("\"")[0] }
        }
        if trimmed.contains("\"value\":") {
            let p = trimmed.split("\"value\":")
            if p.len() >= 2 {
                let num_str = p[1].split(",")[0].split("}")[0].trim()
                value = to_float(num_str)
            }
        }
        if name != "" {
            names = names + [name]
            values = values + [value]
        }
    }
    [names, values]
}

let _home = exec("printenv HOME")
let _n6c = load_n6_consts()
let _phc = load_jsonl_kv(_home + "/Dev/nexus/shared/n6/n6_physics.jsonl")
let n6_vals = _n6c[1]
let phys_vals = _phc[1]

comptime const solar_constants = [1.333, 0.33, 60.0, 72.0, 120.0, 144.0, 6.0, 12.0, 24.0, 48.0, 1.12, 1.5, 25.7]
comptime const transformer_constants = [12.0, 8.0, 24.0, 6.0, 128.0, 256.0, 512.0, 768.0, 1024.0, 2048.0, 4096.0, 2.667, 0.1, 0.288, 32.0, 16.0, 96.0, 48.0, 64.0]

// ════════════════════════════════════════════════════════════════
// 1. SKYRMION LENS — topological charge (winding number) from field config
// ════════════════════════════════════════════════════════════════
fn scan_skyrmion(data) -> LensResult {
    let mut r = empty_result()
    let n = data.len()
    if n < 9 { return r }

    // treat consecutive triples as 3-component field vectors, normalize
    let nv = n / 3
    if nv < 4 { return r }

    let mut charge = 0.0
    let grid = to_int(sqrt_f(to_float(nv)))
    if grid < 2 { return r }

    let mut idx = 0
    while idx < (grid - 1) * (grid - 1) {
        let row = idx / (grid - 1)
        let col = idx - row * (grid - 1)
        let i = row * grid + col
        let ir = i + 1
        let iu = i + grid
        if iu * 3 + 2 < n && ir * 3 + 2 < n {
            // partial derivatives of unit field
            let dx0 = data[ir * 3] - data[i * 3]
            let dx1 = data[ir * 3 + 1] - data[i * 3 + 1]
            let dx2 = data[ir * 3 + 2] - data[i * 3 + 2]
            let dy0 = data[iu * 3] - data[i * 3]
            let dy1 = data[iu * 3 + 1] - data[i * 3 + 1]
            let dy2 = data[iu * 3 + 2] - data[i * 3 + 2]
            // cross product dx x dy
            let cx = dx1 * dy2 - dx2 * dy1
            let cy = dx2 * dy0 - dx0 * dy2
            let cz = dx0 * dy1 - dx1 * dy0
            // dot with n
            let dot = data[i * 3] * cx + data[i * 3 + 1] * cy + data[i * 3 + 2] * cz
            charge = charge + dot
        }
        idx = idx + 1
    }
    charge = charge / (4.0 * pi)

    let radius = sqrt_f(to_float(nv)) / 2.0
    // 6-fold anisotropy: check modular pattern
    let mut aniso = 0.0
    let mut k = 0
    while k < nv && k * 3 + 2 < n {
        let angle = data[k * 3] * data[k * 3] + data[k * 3 + 1] * data[k * 3 + 1]
        let a6 = cos_f(6.0 * angle)
        aniso = aniso + a6
        k = k + 1
    }
    aniso = aniso / to_float(nv)

    r = result_add(r, "topological_charge", [abs_f(charge)])
    r = result_add(r, "skyrmion_radius", [radius])
    r = result_add(r, "anisotropy_6fold", [abs_f(aniso)])
    r
}

// ════════════════════════════════════════════════════════════════
// 2. SOLAR EFFICIENCY LENS — photovoltaic pattern detection
// ════════════════════════════════════════════════════════════════
fn scan_solar_efficiency(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }

    let mean = list_mean(data)
    // SQ bandgap proximity (4/3 eV)
    let sq_dist = abs_f(mean - 1.333)
    let sq_prox = exp_f(0.0 - sq_dist * 3.0)
    r = result_add(r, "sq_proximity", [sq_prox])

    // cell count matches
    let mut matches = 0
    for v in data {
        let mut k = 0
        while k < solar_constants.len() {
            let c = solar_constants[k]
            if c > 0.0 && abs_f(v - c) / c < 0.05 {
                matches = matches + 1
            }
            k = k + 1
        }
    }
    if matches > 0 { r = result_add(r, "solar_constant_matches", [to_float(matches)]) }

    // efficiency ratio: values in 0..0.5 range
    let mut eff_count = 0
    for v in data {
        if v > 0.0 && v < 0.5 { eff_count = eff_count + 1 }
    }
    let eff_frac = to_float(eff_count) / to_float(data.len())
    r = result_add(r, "efficiency_pattern", [eff_frac])
    r
}

// ════════════════════════════════════════════════════════════════
// 3. SPACETIME LENS — metric signature + causal structure
// ════════════════════════════════════════════════════════════════
fn scan_spacetime(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }

    let n = data.len()
    let mean = list_mean(data)

    // covariance diagonal approximation
    let mut pos = 0
    let mut neg = 0
    let mut i = 0
    while i < n {
        let d = data[i] - mean
        if d > 0.0 { pos = pos + 1 } else { neg = neg + 1 }
        i = i + 1
    }

    let total = to_float(pos + neg)
    let sig = to_float(pos) / max_f(total, 1.0)
    // Lorentzian: mixed signature (not all same sign)
    let lorentzian = 1.0 - abs_f(sig - 0.5) * 2.0
    r = result_add(r, "metric_signature", [sig])
    r = result_add(r, "lorentzian_score", [lorentzian])

    // causal ordering: fraction of consecutive pairs with monotone increase
    let mut ordered = 0
    i = 0
    while i < n - 1 {
        if data[i + 1] > data[i] { ordered = ordered + 1 }
        i = i + 1
    }
    let causal = to_float(ordered) / to_float(n - 1)
    r = result_add(r, "causal_ordering", [causal])

    // light cone width: std dev of differences
    let mut diff_sum = 0.0
    let mut diff_sq = 0.0
    i = 0
    while i < n - 1 {
        let d = data[i + 1] - data[i]
        diff_sum = diff_sum + d
        diff_sq = diff_sq + d * d
        i = i + 1
    }
    let nd = to_float(n - 1)
    let diff_mean = diff_sum / nd
    let lc_width = sqrt_f(diff_sq / nd - diff_mean * diff_mean)
    r = result_add(r, "light_cone_width", [lc_width])
    r
}

// ════════════════════════════════════════════════════════════════
// 4. SPECTRAL LENS — DFT frequency analysis
// ════════════════════════════════════════════════════════════════
fn scan_spectral(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 8 { return r }

    let n = data.len()
    let mean = list_mean(data)
    let half = n / 2

    // DFT power spectrum
    let mut max_pow = 0.0
    let mut max_k = 0
    let mut powers = []
    let mut k = 1
    while k <= half {
        let mut re = 0.0
        let mut im = 0.0
        let mut t = 0
        while t < n {
            let angle = two_pi * to_float(k) * to_float(t) / to_float(n)
            let x = data[t] - mean
            re = re + x * cos_f(angle)
            im = im - x * sin_f(angle)
            t = t + 1
        }
        let p = sqrt_f(re * re + im * im) / to_float(n)
        powers = powers + [p]
        if p > max_pow {
            max_pow = p
            max_k = k
        }
        k = k + 1
    }

    let dom_freq = to_float(max_k) / to_float(n)
    r = result_add(r, "dominant_frequency", [dom_freq])

    // spectral entropy
    let total = list_sum(powers)
    if total > 0.0001 {
        let mut se = 0.0
        for p in powers {
            if p > 0.0 {
                let np = p / total
                se = se - np * ln_f(np)
            }
        }
        let max_se = ln_f(to_float(powers.len()))
        let norm_se = if max_se > 0.0 { se / max_se } else { 0.0 }
        r = result_add(r, "spectral_entropy", [norm_se])
    }

    // harmonic ratio matches (n=6 fractions)
    let n6_ratios = [0.5, 0.333, 0.167, 0.667, 0.25]
    // skip if only 1 dominant frequency
    r
}

// ═���══════════════════════════════════════════════════════════════
// 5. SPECULATIVE DECODE LENS — sequential prediction error
// ════════════════════════════════════════════════════════════════
fn scan_speculative_decode(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }

    let n = data.len()

    // sequential prediction: extrapolate from i-2,i-1 to predict i
    let mut errors = []
    let mut i = 2
    while i < n {
        let predicted = 2.0 * data[i - 1] - data[i - 2]
        let err = abs_f(data[i] - predicted)
        errors = errors + [err]
        i = i + 1
    }
    if errors.len() == 0 { return r }

    let sorted_err = list_sort(errors)
    let median_err = sorted_err[sorted_err.len() / 2]

    // acceptance rate: fraction with error < median
    let mut accepted = 0
    for e in errors { if e < median_err { accepted = accepted + 1 } }
    let acc_rate = to_float(accepted) / to_float(errors.len())

    // smoothness: ratio of consecutive step sizes
    let mut smooth_sum = 0.0
    let mut smooth_n = 0
    i = 1
    while i < n - 1 {
        let d_prev = abs_f(data[i] - data[i - 1])
        let d_next = abs_f(data[i + 1] - data[i])
        if d_prev > 0.0001 {
            smooth_sum = smooth_sum + d_next / d_prev
            smooth_n = smooth_n + 1
        }
        i = i + 1
    }
    let mean_smooth = if smooth_n > 0 { smooth_sum / to_float(smooth_n) } else { 1.0 }

    // theoretical speedup
    let speedup = if acc_rate < 0.99 { 1.0 / (1.0 - acc_rate) } else { 100.0 }

    r = result_add(r, "acceptance_rate", [acc_rate])
    r = result_add(r, "mean_smoothness", [mean_smooth])
    r = result_add(r, "theoretical_speedup", [min_f(speedup, 100.0)])
    r = result_add(r, "median_pred_error", [median_err])
    r
}

// ════════════════════════════════════════════════════════════════
// 6. SPHERICAL LENS — sphericity + shell fraction
// ════════════════════════════════════════════════════════════════
fn scan_spherical(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }

    let mean = list_mean(data)

    // radii from centroid
    let mut radii = []
    for v in data {
        radii = radii + [abs_f(v - mean)]
    }
    let mean_r = list_mean(radii)
    let var_r = list_variance(radii, mean_r)

    // sphericity = 1 - CV(radii)
    let sphericity = if mean_r > 0.0001 {
        max_f(1.0 - sqrt_f(var_r) / mean_r, 0.0)
    } else { 0.0 }
    r = result_add(r, "sphericity", [sphericity])

    // shell fraction: points in outer 1/6 of radius range
    let max_r = list_max(radii)
    if max_r > 0.0001 {
        let shell_thresh = max_r * (1.0 - 1.0 / 6.0)
        let mut on_shell = 0
        for rad in radii { if rad >= shell_thresh { on_shell = on_shell + 1 } }
        r = result_add(r, "shell_fraction", [to_float(on_shell) / to_float(radii.len())])
    }

    // radial uniformity: max deviation from expected CDF
    let sorted_r = list_sort(radii)
    let mut max_dev = 0.0
    let mut i = 0
    while i < sorted_r.len() {
        let expected = if max_r > 0.0001 { sorted_r[i] / max_r } else { 0.0 }
        let actual = to_float(i + 1) / to_float(sorted_r.len())
        let dev = abs_f(expected - actual)
        if dev > max_dev { max_dev = dev }
        i = i + 1
    }
    r = result_add(r, "radial_uniformity", [1.0 - min_f(max_dev, 1.0)])
    r
}

// ════════════════════════════════════════════════════════════════
// 7. SPLINE INTERPOLATION LENS — smoothness + curvature energy
// ════════════════════════════════════════════════════════════════
fn scan_spline_interpolation(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 8 { return r }

    let n = data.len()
    // measure smoothness via finite differences up to 6th order
    // 2nd derivative energy (curvature)
    let mut curv_energy = 0.0
    let mut i = 1
    while i < n - 1 {
        let d2 = data[i + 1] - 2.0 * data[i] + data[i - 1]
        curv_energy = curv_energy + d2 * d2
        i = i + 1
    }
    curv_energy = curv_energy / to_float(n - 2)

    // smoothness: how continuous are higher derivatives
    // compare left vs right 1st derivative at each point
    let mut kink_sum = 0.0
    let mut kink_count = 0
    i = 1
    while i < n - 1 {
        let left = data[i] - data[i - 1]
        let right = data[i + 1] - data[i]
        let jump = abs_f(right - left)
        kink_sum = kink_sum + jump
        kink_count = kink_count + 1
        i = i + 1
    }
    let mean_kink = if kink_count > 0 { kink_sum / to_float(kink_count) } else { 0.0 }
    let smoothness = exp_f(0.0 - mean_kink)

    // knot uniformity (for uniform knots = 1.0)
    // leave-one-out CV error approximation
    let mut cv_err = 0.0
    i = 1
    while i < n - 1 {
        let interp = (data[i - 1] + data[i + 1]) / 2.0
        cv_err = cv_err + (data[i] - interp) * (data[i] - interp)
        i = i + 1
    }
    cv_err = sqrt_f(cv_err / to_float(n - 2))

    r = result_add(r, "spline_smoothness", [smoothness])
    r = result_add(r, "spline_curvature_energy", [curv_energy])
    r = result_add(r, "spline_cv_error", [cv_err])
    r
}

// ════════════════════════════════════════════════════════════════
// 8. STABILITY FILTER LENS — material stability patterns
// ════════════════════════════════════════════════════════════════
fn scan_stability_filter(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }

    let mean = list_mean(data)

    // formation energy proxy: negative mean = stable
    let mut neg_count = 0
    let mut neg_sum = 0.0
    for v in data {
        if v < 0.0 {
            neg_count = neg_count + 1
            neg_sum = neg_sum + v
        }
    }
    let neg_frac = to_float(neg_count) / to_float(data.len())
    let mean_neg = if neg_count > 0 { neg_sum / to_float(neg_count) } else { 0.0 }
    let formation = if mean_neg < 0.0 { min_f(abs_f(mean_neg) / 3.0, 1.0) } else { 0.0 }
    r = result_add(r, "formation_energy_proxy", [formation])
    r = result_add(r, "negative_fraction", [neg_frac])

    // Goldschmidt tolerance factor approximation
    // use first few values as proxy radii
    if data.len() >= 3 {
        let ra = abs_f(data[0])
        let rb = abs_f(data[1])
        let ro = 1.40
        let denom = 1.41421 * (rb + ro)
        let tf = if denom > 0.0 { (ra + ro) / denom } else { 0.0 }
        let is_perovskite = if tf > 0.8 && tf < 1.0 { 1.0 } else { 0.0 }
        r = result_add(r, "tolerance_factor", [tf])
        r = result_add(r, "perovskite_stable", [is_perovskite])
    }

    // stability score
    let score = (formation + neg_frac) / 2.0
    r = result_add(r, "stability_score", [score])
    r
}

// ════════════════════════════════════════════════════════════════
// 9. STABILITY LENS — Lyapunov exponent approximation
// ════════════════════════════════════════════════════════════════
fn scan_stability(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 8 { return r }

    let n = data.len()
    let min_sep = 3

    // for nearby pairs, track divergence
    let mut lyap_sum = 0.0
    let mut lyap_count = 0
    let mut max_lyap = 0.0 - 999.0
    let max_pairs = 50

    let mut i = 0
    while i < n - min_sep - 2 && lyap_count < max_pairs {
        let mut j = i + min_sep
        while j < n - 2 && lyap_count < max_pairs {
            let d0 = abs_f(data[i] - data[j])
            if d0 > 0.0001 {
                let d1 = abs_f(data[i + 1] - data[j + 1])
                if d1 > 0.0001 {
                    let lam = ln_f(d1 / d0)
                    lyap_sum = lyap_sum + lam
                    if lam > max_lyap { max_lyap = lam }
                    lyap_count = lyap_count + 1
                }
            }
            j = j + 1
        }
        i = i + 1
    }

    if lyap_count == 0 { return r }
    let lyapunov = lyap_sum / to_float(lyap_count)

    r = result_add(r, "lyapunov_exponent", [lyapunov])
    r = result_add(r, "max_lyapunov", [max_lyap])
    r = result_add(r, "stability_score", [clamp_f(lyapunov, 0.0, 1.0)])
    r
}

// ════════════════════════════════════════════════════════════════
// 10. STATE SPACE OBSERVABILITY LENS — 6-state DMD analysis
// ════════════════════════════════════════════════════════════════
fn scan_state_space_obs(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 12 { return r }

    let n = data.len()
    let sd = 6 // state dimension

    // build state transition via lag-1 covariance
    // A_approx[i,j] = cov(x_{t+1,i}, x_{ t: t, j}) / var(x_{ t: t, j})
    // simplified: use consecutive values as state vector elements
    let use_n = min_f(to_float(n), to_float(sd * 20))
    let un = to_int(use_n)
    if un < sd + 1 { return r }

    // observability rank proxy: count how many of first sd values are linearly independent
    // use variance of each lag as proxy for rank contribution
    let mut rank_proxy = 0
    let mut k = 0
    while k < sd {
        let mut var_k = 0.0
        let mut mean_k = 0.0
        let mut cnt = 0
        let mut i = k
        while i < un {
            mean_k = mean_k + data[i]
            cnt = cnt + 1
            i = i + sd
        }
        mean_k = mean_k / to_float(cnt)
        i = k
        while i < un {
            let d = data[i] - mean_k
            var_k = var_k + d * d
            i = i + sd
        }
        var_k = var_k / to_float(cnt)
        if var_k > 0.001 { rank_proxy = rank_proxy + 1 }
        k = k + 1
    }

    // pole magnitude proxy: lag-1 autocorrelation per component
    let mut max_pole = 0.0
    k = 0
    while k < sd && k < n - sd {
        let x0 = data[k]
        let x1 = if k + sd < n { data[k + sd] } else { x0 }
        let pole = if abs_f(x0) > 0.001 { abs_f(x1 / x0) } else { 0.0 }
        if pole > max_pole { max_pole = pole }
        k = k + 1
    }
    let is_stable = if max_pole < 1.001 { 1.0 } else { 0.0 }

    r = result_add(r, "ss_observability_rank", [to_float(rank_proxy)])
    r = result_add(r, "ss_max_pole", [max_pole])
    r = result_add(r, "ss_is_stable", [is_stable])
    r = result_add(r, "ss_state_dim", [6.0])
    r
}

// ════════════════════════════════════════════════════════════════
// 11. STATIONARITY LENS — regime change detection
// ════════════════════════════════════════════════════════════════
fn scan_stationarity(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 8 { return r }

    let n = data.len()
    let n_windows = 4
    let win = n / n_windows
    if win < 2 { return r }

    let overall_mean = list_mean(data)
    let overall_var = list_variance(data, overall_mean)

    // window means and variances
    let mut window_means = []
    let mut window_vars = []
    let mut w = 0
    while w < n_windows {
        let start = w * win
        let end = if w == n_windows - 1 { n } else { (w + 1) * win }
        let mut wm = 0.0
        let mut cnt = 0
        let mut i = start
        while i < end {
            wm = wm + data[i]
            cnt = cnt + 1
            i = i + 1
        }
        wm = wm / to_float(cnt)
        let mut wv = 0.0
        i = start
        while i < end {
            let d = data[i] - wm
            wv = wv + d * d
            i = i + 1
        }
        wv = wv / to_float(cnt)
        window_means = window_means + [wm]
        window_vars = window_vars + [wv]
        w = w + 1
    }

    // drift = variance of window means / overall variance
    let wm_mean = list_mean(window_means)
    let mean_drift = list_variance(window_means, wm_mean)
    let drift = if overall_var > 0.0001 { mean_drift / overall_var } else { 0.0 }

    // variance ratio
    let max_var = list_max(window_vars)
    let min_var = list_min(window_vars)
    let vr = if min_var > 0.0001 { min_f(max_var / min_var, 1000000.0) } else { min_f(max_var, 1000000.0) }

    let is_stat = if drift < 0.1 && vr < 3.0 { 1.0 } else { 0.0 }

    r = result_add(r, "mean_drift", [drift])
    r = result_add(r, "variance_ratio", [vr])
    r = result_add(r, "is_stationary", [is_stat])
    r
}

// ════════════════════════════════════════════════════════════════
// 12. STIMULUS LENS — neural burst detection
// ════════════════════════════════════════════════════════════════
fn scan_stimulus(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }

    let n = data.len()
    let mean = list_mean(data)
    let var = list_variance(data, mean)
    let std_dev = max_f(sqrt_f(var), 0.0001)
    let threshold = mean + 2.0 * std_dev

    // burst count
    let mut bursts = 0
    for v in data { if v > threshold { bursts = bursts + 1 } }
    let strength = to_float(bursts) / to_float(n)
    r = result_add(r, "stimulus_strength", [strength])

    // response latency: avg gap between bursts
    let mut burst_idx = []
    let mut i = 0
    while i < n {
        if data[i] > threshold { burst_idx = burst_idx + [to_float(i)] }
        i = i + 1
    }
    if burst_idx.len() >= 2 {
        let mut gap_sum = 0.0
        i = 1
        while i < burst_idx.len() {
            gap_sum = gap_sum + burst_idx[i] - burst_idx[i - 1]
            i = i + 1
        }
        r = result_add(r, "response_latency", [gap_sum / to_float(burst_idx.len() - 1)])
    }

    // habituation: first half energy vs second half
    let mid = n / 2
    let mut e1 = 0.0
    let mut e2 = 0.0
    i = 0
    while i < mid {
        e1 = e1 + abs_f(data[i] - mean)
        i = i + 1
    }
    i = mid
    while i < n {
        e2 = e2 + abs_f(data[i] - mean)
        i = i + 1
    }
    e1 = e1 / to_float(mid)
    e2 = e2 / to_float(n - mid)
    let hab = if e1 > 0.0001 { clamp_f((e1 - e2) / e1, -1.0, 1.0) } else { 0.0 }
    r = result_add(r, "habituation_rate", [hab])
    r = result_add(r, "score", [min_f(strength, 1.0)])
    r
}

// ════════════════════════════════════════════════════════════════
// 13. SUBDIFFERENTIAL LENS — non-smooth optimization analysis
// ════════════════════════════════════════════════════════════════
fn scan_subdifferential(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 8 { return r }

    let n = data.len()

    // kink detection: left vs right derivative mismatch
    let mut kink_count = 0
    let mut kink_sum = 0.0
    let mut i = 1
    while i < n - 1 {
        let left = data[i] - data[i - 1]
        let right = data[i + 1] - data[i]
        let jump = abs_f(right - left)
        if jump > 0.5 { kink_count = kink_count + 1 }
        kink_sum = kink_sum + jump
        i = i + 1
    }
    r = result_add(r, "subdiff_kink_count", [to_float(kink_count)])

    // non-smoothness: total variation of gradient
    let mean_jump = kink_sum / to_float(n - 2)
    r = result_add(r, "subdiff_nonsmoothness", [mean_jump])

    // proximity residual: ||x - (x_{i-1}+x_{i+1})/2|| let mut prox_res = 0.0
    i = 1
    while i < n - 1 {
        let mid = (data[i - 1] + data[i + 1]) / 2.0
        prox_res = prox_res + (data[i] - mid) * (data[i] - mid)
        i = i + 1
    }
    prox_res = sqrt_f(prox_res / to_float(n - 2))
    r = result_add(r, "subdiff_prox_residual", [prox_res])

    // subdifferential cardinality proxy at kinks
    let card = if kink_count > 0 { to_float(kink_count) / to_float(n) * 6.0 } else { 1.0 }
    r = result_add(r, "subdiff_cardinality", [card])
    r
}

// ════════════════════════════════════════════════════════════════
// 14. SUPERCONDUCTOR LENS — zero-resistance phase transition
// ════════════════════════════════════════════════════════════════
fn scan_superconductor(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }

    let n = data.len()

    // sort by energy (absolute value)
    let mut energies = []
    let mut i = 0
    while i < n {
        energies = energies + [abs_f(data[i])]
        i = i + 1
    }
    let sorted_e = list_sort(energies)

    // resistance proxy: running mean of distances to neighbors
    let mut resistance = []
    i = 0
    while i < n {
        let mut s = 0.0
        let mut c = 0
        let mut j = 0
        while j < n {
            if i != j {
                s = s + abs_f(data[i] - data[j])
                c = c + 1
            }
            j = j + 1
        }
        resistance = resistance + [if c > 0 { s / to_float(c) } else { 0.0 }]
        i = i + 1
    }

    // find critical transition: largest drop in sorted resistance
    let sorted_res = list_sort(resistance)
    let mut max_drop = 0.0
    let mut tc_idx = 0
    i = 1
    while i < sorted_res.len() {
        let drop_val = sorted_res[i] - sorted_res[i - 1]
        if drop_val > max_drop {
            max_drop = drop_val
            tc_idx = i
        }
        i = i + 1
    }
    let tc_frac = to_float(tc_idx) / to_float(n)

    // Meissner: variance of distances in low-resistance phase
    let mut sc_var = 0.0
    let mean_res = list_mean(resistance)
    let mut sc_count = 0
    for rv in resistance {
        if rv < mean_res {
            sc_var = sc_var + (rv - mean_res) * (rv - mean_res)
            sc_count = sc_count + 1
        }
    }
    let meissner = if sc_count > 0 { 1.0 - min_f(sqrt_f(sc_var / to_float(sc_count)) / max_f(mean_res, 0.001), 1.0) } else { 0.0 }

    // Cooper pair: count unusually close pairs
    let thresh = mean_res * 0.3
    let mut cooper = 0
    i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            if abs_f(data[i] - data[j]) < thresh { cooper = cooper + 1 }
            j = j + 1
        }
        i = i + 1
    }

    r = result_add(r, "tc_fraction", [tc_frac])
    r = result_add(r, "max_resistance_drop", [max_drop])
    r = result_add(r, "meissner_score", [meissner])
    r = result_add(r, "cooper_pair_count", [to_float(cooper)])
    r
}

// ════════════════════════════════════════════════════════════════
// 15. SURPRISE LENS — LOF-based anomaly detection
// ════════════════════════════════════════════════════════════════
fn scan_surprise(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }

    let n = data.len()
    let mean = list_mean(data)
    let var = list_variance(data, mean)
    let std = max_f(sqrt_f(var), 0.0001)

    // z-score per point
    let mut z_scores = []
    let mut max_surprise = 0.0
    let mut anomalous = 0
    for v in data {
        let z = abs_f(v - mean) / std
        z_scores = z_scores + [z]
        if z > max_surprise { max_surprise = z }
        if z > 2.0 { anomalous = anomalous + 1 }
    }
    let mean_surprise = list_mean(z_scores)
    let frac_anomalous = to_float(anomalous) / to_float(n)

    // dimension kurtosis: excess kurtosis (m4/m2^2 - 3)
    let mut m4 = 0.0
    for v in data {
        let d = v - mean
        m4 = m4 + d * d * d * d
    }
    m4 = m4 / to_float(n)
    let kurtosis = if var > 0.0001 { m4 / (var * var) - 3.0 } else { 0.0 }

    r = result_add(r, "mean_surprise", [mean_surprise])
    r = result_add(r, "max_surprise", [max_surprise])
    r = result_add(r, "fraction_anomalous", [frac_anomalous])
    r = result_add(r, "kurtosis", [kurtosis])
    r
}

// ════════════════════════════════════════════════════════════════
// 16. SYMMETRY BREAKING LENS — skewness + asymmetry
// ════════════════════════════════════════════════════════════════
fn scan_symmetry_breaking(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }

    let mean = list_mean(data)
    let var = list_variance(data, mean)
    let std = max_f(sqrt_f(var), 0.0001)

    // skewness (third moment)
    let mut m3 = 0.0
    for v in data {
        let z = (v - mean) / std
        m3 = m3 + z * z * z
    }
    let skewness = m3 / to_float(data.len())
    r = result_add(r, "skewness", [skewness])

    // left-right imbalance: count above vs below mean
    let mut above = 0
    let mut below = 0
    for v in data {
        if v > mean { above = above + 1 } else { below = below + 1 }
    }
    let imbalance = abs_f(to_float(above) - to_float(below)) / to_float(data.len())
    r = result_add(r, "lr_imbalance", [imbalance])

    // feature pair asymmetry: check f(x,y) != f(y,x) via consecutive pair ordering
    let mut asym_count = 0
    let mut i = 0
    while i < data.len() - 1 {
        if abs_f(data[i] - data[i + 1]) > 0.01 * std { asym_count = asym_count + 1 }
        i = i + 2
    }
    let pair_asym = to_float(asym_count) / to_float(data.len() / 2)
    r = result_add(r, "pair_asymmetry", [pair_asym])
    r = result_add(r, "breaking_score", [abs_f(skewness) * imbalance])
    r
}

// ════════════════════════════════════════════════════════════════
// 17. TACHYON LENS — superluminal anomaly detection
// ════════════════════════════════════════════════════════════════
fn scan_tachyon(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }

    let n = data.len()
    // tachyonic mode: imaginary mass => m^2 < 0
    // look for values whose squared form is negative in some combination
    let mean = list_mean(data)
    let var = list_variance(data, mean)

    // speed proxy: consecutive differences (velocity)
    let mut speeds = []
    let mut i = 0
    while i < n - 1 {
        speeds = speeds + [abs_f(data[i + 1] - data[i])]
        i = i + 1
    }
    let mean_speed = list_mean(speeds)
    let speed_std = max_f(sqrt_f(list_variance(speeds, mean_speed)), 0.0001)

    // tachyon count: points with superluminal speed (> 3 sigma)
    let mut tachyon_count = 0
    for s in speeds {
        if s > mean_speed + 3.0 * speed_std { tachyon_count = tachyon_count + 1 }
    }

    // imaginary mass proxy: negative second derivative (unstable potential)
    let mut neg_mass = 0
    i = 1
    while i < n - 1 {
        let d2 = data[i + 1] - 2.0 * data[i] + data[i - 1]
        if d2 < 0.0 { neg_mass = neg_mass + 1 }
        i = i + 1
    }

    r = result_add(r, "tachyon_count", [to_float(tachyon_count)])
    r = result_add(r, "superluminal_fraction", [to_float(tachyon_count) / to_float(speeds.len())])
    r = result_add(r, "negative_mass_fraction", [to_float(neg_mass) / to_float(n - 2)])
    r = result_add(r, "mean_speed", [mean_speed])
    r
}

// ════════════════════════════════════════════════════════════════
// 18. TELEPATHY LENS — distant correlation / non-local entanglement
// ════════════════════════════════════════════════════════════════
fn scan_telepathy(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }

    let n = data.len()
    let mean = list_mean(data)
    let var = list_variance(data, mean)
    let std = max_f(sqrt_f(var), 0.0001)

    // normalize data
    let mut normed = []
    for v in data { normed = normed + [(v - mean) / std] }

    // compare correlation of near vs far pairs
    let mid = n / 2
    let mut near_corr = 0.0
    let mut near_count = 0
    let mut far_corr = 0.0
    let mut far_count = 0

    let step = max_f(to_float(n / 30), 1.0)
    let si = to_int(step)
    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            let dist = abs_f(to_float(i) - to_float(j))
            let corr = abs_f(normed[i] * normed[j])
            if dist < to_float(mid) / 2.0 {
                near_corr = near_corr + corr
                near_count = near_count + 1
            } else {
                far_corr = far_corr + corr
                far_count = far_count + 1
            }
            j = j + si
        }
        i = i + si
    }

    let mean_near = if near_count > 0 { near_corr / to_float(near_count) } else { 0.0 }
    let mean_far = if far_count > 0 { far_corr / to_float(far_count) } else { 0.0 }

    // telepathy score: far correlation relative to near
    let telepathy = if mean_near > 0.0001 { mean_far / mean_near } else { 0.0 }

    // entanglement: high far correlation itself
    let mut max_ent = 0.0
    i = 0
    while i < n {
        let j = n - 1 - i
        if j > i {
            let ent = abs_f(normed[i] * normed[j])
            if ent > max_ent { max_ent = ent }
        }
        i = i + 1
    }

    r = result_add(r, "telepathy_score", [min_f(telepathy, 10.0)])
    r = result_add(r, "max_entanglement", [max_ent])
    r = result_add(r, "near_correlation", [mean_near])
    r = result_add(r, "far_correlation", [mean_far])
    r
}

// ════════════════════════════════════════════════════════════════
// 19. TENSION LENS — internal stress field detection
// ════════════════════════════════════════════════════════════════
fn scan_tension(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }

    let n = data.len()

    // tension per point: net force from k nearest neighbors
    let k = to_int(max_f(sqrt_f(to_float(n)), 3.0))
    let mut tensions = []

    let mut i = 0
    while i < n {
        let mut force = 0.0
        // use k nearest by index distance
        let lo = max_f(to_float(i - k / 2), 0.0)
        let hi = min_f(to_float(i + k / 2), to_float(n - 1))
        let mut j = to_int(lo)
        while j <= to_int(hi) {
            if j != i { force = force + (data[j] - data[i]) }
            j = j + 1
        }
        let tension = abs_f(force) / to_float(k)
        tensions = tensions + [tension]
        i = i + 1
    }

    let mean_tension = list_mean(tensions)
    let var_tension = list_variance(tensions, mean_tension)

    // anisotropy: max tension / mean
    let max_tension = list_max(tensions)
    let anisotropy = if mean_tension > 0.0001 { max_tension / mean_tension } else { 0.0 }

    // rupture risk: fraction near breaking (> 3 sigma)
    let std_t = max_f(sqrt_f(var_tension), 0.0001)
    let mut rupture = 0
    for t in tensions { if t > mean_tension + 3.0 * std_t { rupture = rupture + 1 } }

    r = result_add(r, "mean_tension", [mean_tension])
    r = result_add(r, "tension_anisotropy", [anisotropy])
    r = result_add(r, "rupture_risk", [to_float(rupture) / to_float(n)])
    r
}

// ════════════════════════════════════════════════════════════════
// 20. TENSION LINK LENS — stressed edge detection
// ════════════════════════════════════════════════════════════════
fn scan_tension_link(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }

    let n = data.len()

    // edge distances: consecutive pairs
    let mut edges = []
    let mut i = 0
    while i < n - 1 {
        edges = edges + [abs_f(data[i + 1] - data[i])]
        i = i + 1
    }
    if edges.len() == 0 { return r }

    let mean_edge = list_mean(edges)
    let var_edge = list_variance(edges, mean_edge)
    let std_edge = sqrt_f(var_edge)
    let tension_threshold = mean_edge + std_edge

    // count stressed links
    let mut link_count = 0
    let mut tension_sum = 0.0
    let mut max_tension = 0.0
    let mut elastic_energy = 0.0

    for e in edges {
        if e > tension_threshold {
            link_count = link_count + 1
            let stretch = e - mean_edge
            tension_sum = tension_sum + stretch
            if stretch > max_tension { max_tension = stretch }
            elastic_energy = elastic_energy + 0.5 * stretch * stretch
        }
    }

    let stress = to_float(link_count) / to_float(edges.len())
    r = result_add(r, "tension_link_count", [to_float(link_count)])
    r = result_add(r, "mean_link_tension", [if link_count > 0 { tension_sum / to_float(link_count) } else { 0.0 }])
    r = result_add(r, "max_link_tension", [max_tension])
    r = result_add(r, "elastic_energy", [elastic_energy])
    r = result_add(r, "network_stress", [stress])
    r
}

// ════════════════════════════════════════════════════════════════
// 21. THERMO LENS — entropy + free energy (extended version)
// ════════════════════════════════════════════════════════════════
fn scan_thermo_applied(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }

    let n = data.len()
    let num_bins = to_int(max_f(sqrt_f(to_float(n)), 2.0))
    let lo = list_min(data)
    let hi = list_max(data)
    let range = hi - lo
    if range < 0.0001 {
        r = result_add(r, "entropy", [0.0])
        return r
    }

    // histogram binning
    let mut bins = []
    let mut k = 0
    while k < num_bins {
        bins = bins + [0]
        k = k + 1
    }

    for v in data {
        let mut idx = to_int((v - lo) / range * to_float(num_bins - 1) + 0.5)
        if idx >= num_bins { idx = num_bins - 1 }
        if idx < 0 { idx = 0 }
        bins[idx] = bins[idx] + 1
    }

    // Shannon entropy
    let total = to_float(n)
    let mut entropy = 0.0
    for c in bins {
        if c > 0 {
            let p = to_float(c) / total
            entropy = entropy - p * ln_f(p)
        }
    }
    r = result_add(r, "entropy", [entropy])

    // free energy proxy: F = E - T*S, T=1
    let mean_dist = list_mean(data)
    let free_energy = abs_f(mean_dist) - entropy
    r = result_add(r, "free_energy", [free_energy])

    // energy barrier
    let mut max_barrier = 0.0
    let mut i = 1
    while i < n {
        let diff = abs_f(data[i] - data[i - 1])
        if diff > max_barrier { max_barrier = diff }
        i = i + 1
    }
    r = result_add(r, "energy_barrier", [max_barrier])
    r
}

// ════════════════════════════════════════════════════════════════
// 22. TIME REVERSAL LENS — T-symmetry analysis
// ════════════════════════════════════════════════════════════════
fn scan_time_reversal(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }

    let n = data.len()

    // T-symmetry score: correlation between forward and reversed signal
    let mean = list_mean(data)
    let mut cov = 0.0
    let mut var_f = 0.0
    let mut i = 0
    while i < n {
        let df = data[i] - mean
        let dr = data[n - 1 - i] - mean
        cov = cov + df * dr
        var_f = var_f + df * df
        i = i + 1
    }
    let t_sym = if var_f > 0.0001 { clamp_f(cov / var_f, -1.0, 1.0) } else { 1.0 }
    r = result_add(r, "t_symmetry_score", [t_sym])

    // irreversibility: entropy production from forward vs backward diffs
    let mut fwd_diffs = []
    let mut bwd_diffs = []
    i = 0
    while i < n - 1 {
        fwd_diffs = fwd_diffs + [data[i + 1] - data[i]]
        bwd_diffs = bwd_diffs + [data[n - 2 - i] - data[n - 1 - i]]
        i = i + 1
    }
    let fwd_var = list_variance(fwd_diffs, list_mean(fwd_diffs))
    let bwd_var = list_variance(bwd_diffs, list_mean(bwd_diffs))
    let irreversibility = abs_f(fwd_var - bwd_var) / max_f(fwd_var + bwd_var, 0.0001)
    r = result_add(r, "irreversibility", [irreversibility])

    // arrow of time: skewness of increments
    let diff_mean = list_mean(fwd_diffs)
    let diff_std = max_f(sqrt_f(list_variance(fwd_diffs, diff_mean)), 0.0001)
    let mut skew = 0.0
    for d in fwd_diffs {
        let z = (d - diff_mean) / diff_std
        skew = skew + z * z * z
    }
    skew = skew / to_float(fwd_diffs.len())
    r = result_add(r, "arrow_of_time", [abs_f(skew)])
    r
}

// ════════════════════════════════════════════════════════════════
// 23. TOPOLOGY LENS — persistent homology (Betti-0)
// ════════════════════════════════════════════════════════════════
fn scan_topology_applied(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }

    let n = data.len()

    // single-linkage filtration on sorted absolute differences
    let sorted = list_sort(data)
    let mut gaps = []
    let mut i = 1
    while i < sorted.len() {
        gaps = gaps + [sorted[i] - sorted[i - 1]]
        i = i + 1
    }
    if gaps.len() == 0 { return r }

    let sorted_gaps = list_sort(gaps)
    let median_gap = sorted_gaps[sorted_gaps.len() / 2]

    // Betti-0: number of components (large gaps = new component)
    let mut components = 1
    let threshold = median_gap * 2.0
    for g in gaps {
        if g > threshold { components = components + 1 }
    }
    r = result_add(r, "betti_0", [to_float(components)])

    // persistence: max gap / median gap
    let max_gap = list_max(gaps)
    let persistence = if median_gap > 0.0001 { max_gap / median_gap } else { 0.0 }
    r = result_add(r, "max_persistence", [persistence])

    // total persistence
    let mut total_pers = 0.0
    for g in gaps { if g > threshold { total_pers = total_pers + g } }
    r = result_add(r, "total_persistence", [total_pers])
    r
}

// ════════════════════════════════════════════════════════════════
// 24. TRANSFORMER ANATOMY LENS — architecture pattern matching
// ════════════════════════════════════════════════════════════════
fn scan_transformer_anatomy(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }

    let mean = list_mean(data)
    let var = list_variance(data, mean)

    // match against transformer constants
    let mut total_matches = 0
    for v in data {
        let mut k = 0
        while k < transformer_constants.len() {
            let c = transformer_constants[k]
            if c > 0.0 && abs_f(v - c) / c < 0.05 {
                total_matches = total_matches + 1
            }
            k = k + 1
        }
    }
    r = result_add(r, "transformer_constant_matches", [to_float(total_matches)])

    // head pattern: multiples of 8 (sigma-tau) or 12 (sigma)
    let mut head_matches = 0
    for v in data {
        let av = abs_f(v)
        if av > 0.5 {
            let mod8 = av - to_float(to_int(av / 8.0)) * 8.0
            let mod12 = av - to_float(to_int(av / 12.0)) * 12.0
            if abs_f(mod8) < 0.5 || abs_f(mod12) < 0.5 { head_matches = head_matches + 1 }
        }
    }
    r = result_add(r, "head_pattern_matches", [to_float(head_matches)])

    // dimension alignment: powers of 2
    let mut pow2_matches = 0
    for v in data {
        let av = abs_f(v)
        if av >= 64.0 && av <= 8192.0 {
            let log2 = ln_f(av) / ln_f(2.0)
            let frac = log2 - to_float(to_int(log2))
            if abs_f(frac) < 0.1 || abs_f(frac - 1.0) < 0.1 { pow2_matches = pow2_matches + 1 }
        }
    }
    r = result_add(r, "dimension_alignment", [to_float(pow2_matches)])

    // SwiGLU ratio check: values near 8/3 = 2.667
    let mut swiglu = 0
    for v in data {
        if abs_f(v - 2.667) < 0.15 { swiglu = swiglu + 1 }
    }
    if swiglu > 0 { r = result_add(r, "swiglu_ratio_matches", [to_float(swiglu)]) }

    let score = to_float(total_matches) / to_float(data.len())
    r = result_add(r, "transformer_score", [min_f(score, 1.0)])
    r
}

// ════════════════════════════════════════════════════════════════
// 25. TRIANGLE LENS — simple fraction matching in ratios
// ════════════════════════════════════════════════════════════════
fn scan_triangle(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }

    // generate fractions p/q for p,q in 1..6
    let mut fractions = []
    let mut p = 1
    while p <= 6 {
        let mut q = 1
        while q <= 6 {
            if p != q {
                let f = to_float(p) / to_float(q)
                // check not duplicate
                let mut dup = false
                for ff in fractions { if abs_f(ff - f) < 0.0001 { dup = true } }
                if !dup { fractions = fractions + [f] }
            }
            q = q + 1
        }
        p = p + 1
    }

    let tol = 0.05
    let mut match_count = 0
    let mut total_ratios = 0
    let max_n = min_f(to_float(data.len()), 50.0)
    let mn = to_int(max_n)

    let mut i = 0
    while i < mn {
        let mut j = i + 1
        while j < mn {
            if abs_f(data[j]) > 0.0001 {
                let ratio = data[i] / data[j]
                total_ratios = total_ratios + 1
                for f in fractions {
                    if abs_f(ratio - f) / max_f(f, 0.01) < tol {
                        match_count = match_count + 1
                    }
                }
            }
            j = j + 1
        }
        i = i + 1
    }

    let density = if total_ratios > 0 { to_float(match_count) / to_float(total_ratios) } else { 0.0 }
    r = result_add(r, "fraction_match_density", [density])
    r = result_add(r, "fraction_match_count", [to_float(match_count)])
    r
}

// ════════════════════════════════════════════════════════════════
// 26. TRIANGULATED CATEGORY LENS — distinguished triangles
// ════════════════════════════════════════════════════════════════
fn scan_triangulated_cat(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }

    let n = data.len()
    let max_n = min_f(to_float(n), 30.0)
    let mn = to_int(max_n)

    // triangle exactness: d(i,j) + d(j,k) ~= d(i,k)
    let mut tri_score = 0.0
    let mut tri_count = 0
    let mut i = 0
    while i < mn {
        let mut j = i + 1
        while j < mn {
            let mut k = j + 1
            while k < mn {
                let dij = abs_f(data[i] - data[j])
                let djk = abs_f(data[j] - data[k])
                let dik = abs_f(data[i] - data[k])
                let s = dij + djk
                if s > 0.0001 {
                    let exactness = max_f(1.0 - abs_f(s - dik) / s, 0.0)
                    tri_score = tri_score + exactness
                    tri_count = tri_count + 1
                }
                k = k + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    let avg_tri = if tri_count > 0 { tri_score / to_float(tri_count) } else { 0.0 }
    r = result_add(r, "distinguished_triangle_score", [avg_tri])

    // shift functor periodicity: check period-6 pattern
    let mut period_score = 0.0
    let mut period_count = 0
    i = 0
    while i + 6 < n {
        let diff = abs_f(data[i] - data[i + 6])
        let scale = max_f(abs_f(data[i]), 0.001)
        period_score = period_score + exp_f(0.0 - diff / scale)
        period_count = period_count + 1
        i = i + 1
    }
    let shift_period = if period_count > 0 { period_score / to_float(period_count) } else { 0.0 }
    r = result_add(r, "shift_periodicity_6", [shift_period])
    r
}

// ════════════════════════════════════════════════════════════════
// 27. VC DIMENSION LENS — shattering analysis
// ════════════════════════════════════════════════════════════════
fn scan_vc_dimension(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }

    let n = data.len()
    let test_size = min_f(to_float(n), 6.0)
    let ts = to_int(test_size)

    // estimate VC dimension via shattering with threshold classifiers
    // for 1D data, VC-dim of threshold = 1, interval = 2
    // count distinct dichotomies achievable

    let sorted = list_sort(data)
    let mut achieved = 0
    // try thresholds at each midpoint
    let mut t = 0
    while t < ts - 1 {
        let thresh = (sorted[t] + sorted[t + 1]) / 2.0
        // count above/below pattern — each threshold gives a unique labeling
        achieved = achieved + 1
        t = t + 1
    }
    achieved = achieved + 1 // all-below labeling

    let total_possible = 1
    let mut k = 0
    let mut tp = 1
    while k < ts {
        tp = tp * 2
        k = k + 1
    }

    let shattering_ratio = to_float(achieved) / to_float(tp)
    let vc_dim_estimate = if shattering_ratio > 0.99 { to_float(ts) } else { to_float(achieved) / 2.0 }

    // sample complexity: n >= (4/eps)(VC*log(12/eps) + log(2/delta))
    let sample_complexity = vc_dim_estimate * 10.0 + 20.0

    r = result_add(r, "vc_dimension", [vc_dim_estimate])
    r = result_add(r, "shattering_ratio", [shattering_ratio])
    r = result_add(r, "achieved_dichotomies", [to_float(achieved)])
    r = result_add(r, "sample_complexity", [sample_complexity])
    r
}

// ════════════════════════════════════════════════════════════════
// 28. VOID LENS — low-density void detection
// ════════════════════════════════════════════════════════════════
fn scan_void(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }

    let n = data.len()
    let sorted = list_sort(data)

    // density estimation via gap sizes (inverse of local spacing)
    let mut densities = []
    let mut i = 0
    while i < n {
        let left_gap = if i > 0 { abs_f(sorted[i] - sorted[i - 1]) } else { abs_f(sorted[1] - sorted[0]) }
        let right_gap = if i < n - 1 { abs_f(sorted[i + 1] - sorted[i]) } else { left_gap }
        let local_gap = (left_gap + right_gap) / 2.0
        let density = if local_gap > 0.0001 { 1.0 / local_gap } else { 10000.0 }
        densities = densities + [density]
        i = i + 1
    }

    let mean_density = list_mean(densities)
    let threshold = 0.3 * mean_density

    // void centers: low density with high-density neighbors
    let mut void_count = 0
    let mut void_scores = []
    i = 0
    while i < n {
        if densities[i] < threshold {
            let left_d = if i > 0 { densities[i - 1] } else { 0.0 }
            let right_d = if i < n - 1 { densities[i + 1] } else { 0.0 }
            let avg_neighbor = (left_d + right_d) / 2.0
            if avg_neighbor > mean_density {
                void_count = void_count + 1
                let score = if densities[i] > 0.0 { avg_neighbor / densities[i] } else { 0.0 }
                void_scores = void_scores + [score]
            }
        }
        i = i + 1
    }

    r = result_add(r, "void_count", [to_float(void_count)])
    r = result_add(r, "void_fraction", [to_float(void_count) / to_float(n)])
    if void_scores.len() > 0 {
        r = result_add(r, "mean_void_score", [list_mean(void_scores)])
    }
    r
}

// ════════════════════════════════════════════════════════════════
// 29. WALL INSPECTION LENS — barrier detection + bypass analysis
// ════════════════════════════════════════════════════════════════
fn scan_wall_inspection(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 10 { return r }

    let n = data.len()
    let sorted = list_sort(data)

    // density via gap sizes
    let mut gaps = []
    let mut i = 1
    while i < n {
        gaps = gaps + [sorted[i] - sorted[i - 1]]
        i = i + 1
    }
    let sorted_gaps = list_sort(gaps)
    let median_gap = sorted_gaps[sorted_gaps.len() / 2]

    // wall = large gaps (low density regions flanked by high density)
    let wall_threshold = median_gap * 5.0
    let mut wall_count = 0
    let mut wall_widths = []
    for g in gaps {
        if g > wall_threshold {
            wall_count = wall_count + 1
            wall_widths = wall_widths + [g]
        }
    }

    let wall_fraction = to_float(wall_count) / to_float(gaps.len())
    r = result_add(r, "wall_count", [to_float(wall_count)])
    r = result_add(r, "wall_fraction", [wall_fraction])

    if wall_widths.len() > 0 {
        r = result_add(r, "mean_wall_thickness", [list_mean(wall_widths)])
        r = result_add(r, "max_wall_thickness", [list_max(wall_widths)])
    }

    // impermeability: ratio of wall gap to non-wall gap
    let non_wall_mean = if gaps.len() > wall_count {
        let mut s = 0.0
        for g in gaps { if g <= wall_threshold { s = s + g } }
        s / to_float(gaps.len() - wall_count)
    } else { 0.001 }
    let impermeability = if non_wall_mean > 0.0001 { list_mean(wall_widths) / non_wall_mean } else { 0.0 }
    if wall_widths.len() > 0 { r = result_add(r, "impermeability", [impermeability]) }

    // bypass score: inverse of impermeability
    let bypass = if impermeability > 0.0 { 1.0 / impermeability } else { 1.0 }
    r = result_add(r, "bypass_score", [min_f(bypass, 1.0)])
    r
}

// ════════════════════════════════════════════════════════════════
// 30. WARP LENS — metric distortion (local vs global distance)
// ════════════════════════════════════════════════════════════════
fn scan_warp(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }

    let n = data.len()

    // global median distance
    let mut all_dists = []
    let step = max_f(to_float(n / 100), 1.0)
    let si = to_int(step)
    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            all_dists = all_dists + [abs_f(data[i] - data[j])]
            j = j + si
        }
        i = i + si
    }
    if all_dists.len() == 0 { return r }
    let sorted_dists = list_sort(all_dists)
    let global_median = sorted_dists[sorted_dists.len() / 2]
    if global_median < 0.0001 { return r }

    // per-point warp factor: local mean distance / global median
    let k = to_int(max_f(sqrt_f(to_float(n)), 2.0))
    let mut warp_factors = []
    i = 0
    while i < n {
        let lo = max_f(to_float(i - k), 0.0)
        let hi = min_f(to_float(i + k), to_float(n - 1))
        let mut local_sum = 0.0
        let mut cnt = 0
        let mut j = to_int(lo)
        while j <= to_int(hi) {
            if j != i {
                local_sum = local_sum + abs_f(data[i] - data[j])
                cnt = cnt + 1
            }
            j = j + 1
        }
        let local_mean = if cnt > 0 { local_sum / to_float(cnt) } else { 0.0 }
        warp_factors = warp_factors + [local_mean / global_median]
        i = i + 1
    }

    let mean_warp = list_mean(warp_factors)
    let var_warp = list_variance(warp_factors, mean_warp)

    // contraction fraction: warp < 1
    let mut contracted = 0
    for w in warp_factors { if w < 1.0 { contracted = contracted + 1 } }

    r = result_add(r, "mean_warp", [mean_warp])
    r = result_add(r, "warp_anisotropy", [var_warp])
    r = result_add(r, "contraction_fraction", [to_float(contracted) / to_float(warp_factors.len())])
    r
}

// ════════════════════════════════════════════════════════════════
// 31. WAVE LENS — DFT + peak detection
// ════════════════════════════════════════════════════════════════
fn scan_wave(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 4 { return r }

    let n = data.len()
    let mean = list_mean(data)
    let half = n / 2

    // naive DFT magnitudes
    let mut magnitudes = []
    let mut max_mag = 0.0
    let mut max_k = 1
    let mut k = 1
    while k <= half {
        let mut re = 0.0
        let mut im = 0.0
        let mut t = 0
        while t < n {
            let angle = two_pi * to_float(k) * to_float(t) / to_float(n)
            let x = data[t] - mean
            re = re + x * cos_f(angle)
            im = im - x * sin_f(angle)
            t = t + 1
        }
        let mag = sqrt_f(re * re + im * im) / to_float(n)
        magnitudes = magnitudes + [mag]
        if mag > max_mag {
            max_mag = mag
            max_k = k
        }
        k = k + 1
    }

    let dom_freq = to_float(max_k)
    r = result_add(r, "dominant_frequency", [dom_freq])
    r = result_add(r, "peak_magnitude", [max_mag])

    // spectral entropy
    let total = list_sum(magnitudes)
    if total > 0.0001 {
        let mut se = 0.0
        for m in magnitudes {
            if m > 0.0 {
                let p = m / total
                se = se - p * ln_f(p)
            }
        }
        let max_se = ln_f(to_float(magnitudes.len()))
        let norm_se = if max_se > 0.0 { se / max_se } else { 0.0 }
        r = result_add(r, "spectral_entropy", [norm_se])
    }

    // peak count (local maxima above mean magnitude)
    let mean_mag = list_mean(magnitudes)
    let mut peaks = 0
    let mut i = 1
    while i < magnitudes.len() - 1 {
        if magnitudes[i] > magnitudes[i - 1] && magnitudes[i] > magnitudes[i + 1] && magnitudes[i] > mean_mag {
            peaks = peaks + 1
        }
        i = i + 1
    }
    r = result_add(r, "spectral_peaks", [to_float(peaks)])
    r
}

// ════════════════════════════════════════════════════════════════
// 32. WEIGHT FEEDBACK LENS — weighted importance via n=6 constants
// ════════════════════════════════════════════════════════════════
fn scan_weight_feedback(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 3 { return r }

    let mean = list_mean(data)
    let var = list_variance(data, mean)

    // n=6 constant matching: which constants best match data values
    let _n6_data = load_n6_consts()
    let n6 = n6_values(_n6_data)
    let mut best_weight = 0.0
    let mut best_idx = 0
    let mut k = 0
    while k < n6.len() {
        let c = n6[k]
        let mut match_score = 0.0
        for v in data {
            if abs_f(v) > 0.001 {
                let ratio = abs_f(v) / c
                // close to integer multiple?
                let frac = ratio - to_float(to_int(ratio + 0.5))
                match_score = match_score + exp_f(0.0 - frac * frac * 10.0)
            }
        }
        match_score = match_score / to_float(data.len())
        if match_score > best_weight {
            best_weight = match_score
            best_idx = k
        }
        k = k + 1
    }

    // weighted phi: information integration adjusted by weight
    let phi = if var > 0.0001 { mean / sqrt_f(var) * best_weight } else { 0.0 }

    // coverage: fraction of data matching any n6 constant (within 10%)
    let mut coverage = 0
    for v in data {
        let mut matched = false
        for c in n6 { if c > 0.0 && abs_f(v - c) / c < 0.1 { matched = true } }
        if matched { coverage = coverage + 1 }
    }

    r = result_add(r, "weighted_phi", [phi])
    r = result_add(r, "weight_coverage", [to_float(coverage) / to_float(data.len())])
    r = result_add(r, "top_weighted_constant_idx", [to_float(best_idx)])
    r
}

// ════════════════════════════════════════════════════════════════
// 33. WEIGHT LEARNING LENS — feature importance + constant matching
// ════════════════════════════════════════════════════════════════
fn scan_weight_learning(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 6 { return r }

    let mean = list_mean(data)
    let var = list_variance(data, mean)

    // feature weight: variance-based importance
    r = result_add(r, "feature_variance", [var])

    // constant matching against n=6 family
    let _n6_data2 = load_n6_consts()
    let n6 = n6_values(_n6_data2)
    let mut constant_weights = []
    let mut k = 0
    while k < n6.len() {
        let c = n6[k]
        let mut score = 0.0
        for v in data {
            if abs_f(v) > 0.001 {
                let dist = abs_f(abs_f(v) - c) / c
                score = score + exp_f(0.0 - dist * dist * 5.0)
            }
        }
        constant_weights = constant_weights + [score / to_float(data.len())]
        k = k + 1
    }
    r = result_add(r, "constant_weights", constant_weights)

    // density-based weight: Shannon entropy
    let sorted = list_sort(data)
    let mut ent = 0.0
    let bins = 10
    let lo = sorted[0]
    let hi = sorted[sorted.len() - 1]
    let range = hi - lo
    if range > 0.0001 {
        let mut bin_counts = []
        let mut b = 0
        while b < bins {
            bin_counts = bin_counts + [0]
            b = b + 1
        }
        for v in data {
            let mut idx = to_int((v - lo) / range * to_float(bins - 1) + 0.5)
            if idx >= bins { idx = bins - 1 }
            if idx < 0 { idx = 0 }
            bin_counts[idx] = bin_counts[idx] + 1
        }
        for c in bin_counts {
            if c > 0 {
                let p = to_float(c) / to_float(data.len())
                ent = ent - p * ln_f(p)
            }
        }
    }
    r = result_add(r, "data_entropy", [ent])
    r
}

// ════════════════════════════════════════════════════════════════
// 34. WORMHOLE LENS — topological shortcut detection
// ════════════════════════════════════════════════════════════════
fn scan_wormhole(data) -> LensResult {
    let mut r = empty_result()
    if data.len() < 8 { return r }

    let n = data.len()
    let sorted = list_sort(data)

    // pairwise distances
    let mut all_dists = []
    let step = max_f(to_float(n / 50), 1.0)
    let si = to_int(step)
    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            all_dists = all_dists + [abs_f(data[i] - data[j])]
            j = j + si
        }
        i = i + si
    }
    if all_dists.len() < 4 { return r }
    let sorted_d = list_sort(all_dists)
    let median_dist = sorted_d[sorted_d.len() / 2]
    if median_dist < 0.0001 { return r }

    // distant pairs (> 75th percentile)
    let q75 = sorted_d[sorted_d.len() * 3 / 4]

    // wormhole: distant pairs in index space but close in value
    let mut wormhole_count = 0
    let mut shortcut_ratios = []
    i = 0
    while i < n {
        let mut j = i + n / 2
        while j < n {
            let index_dist = to_float(j - i)
            let value_dist = abs_f(data[i] - data[j])
            let expected_dist = index_dist / to_float(n) * (list_max(data) - list_min(data))
            if expected_dist > 0.001 && value_dist < expected_dist * 0.3 {
                wormhole_count = wormhole_count + 1
                shortcut_ratios = shortcut_ratios + [value_dist / expected_dist]
            }
            j = j + si
        }
        i = i + si
    }

    r = result_add(r, "wormhole_count", [to_float(wormhole_count)])
    if shortcut_ratios.len() > 0 {
        r = result_add(r, "mean_shortcut_ratio", [list_mean(shortcut_ratios)])
    }
    let tunnel_strength = to_float(wormhole_count) / max_f(to_float(n), 1.0)
    r = result_add(r, "tunnel_strength", [tunnel_strength])
    r
}

// ════════════════════════════════════════════════════════════════
