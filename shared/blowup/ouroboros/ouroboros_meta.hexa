// shared/blowup/core/ouroboros_meta.hexa — Meta-OUROBOROS v2: 자기 진화 엔진
// 핵심 개념: 진화 알고리즘 자체가 진화한다. 변이 전략이 변이하고, 선택 기준이 적응한다.
// 뱀이 자기 꼬리를 먹는다 — 문자 그대로.
// Pipeline: StrategyPool -> MetaMutation -> Tournament -> Breeding -> SelfEval -> Convergence

// ─── 상수 ───

comptime const default_generations = 6
comptime const pool_size = 6
comptime const tournament_seeds = 4
comptime const tournament_rounds = 3
comptime const meta_plateau_window = 3
comptime const meta_plateau_epsilon = 0.005
comptime const breeding_crossover_point = 3
comptime const max_param_shift = 5
comptime const max_param_threshold = 2.0

// ─── n=6 상수 (인라인) ───

comptime const N6 = 6
comptime const N6_SIGMA = 12
comptime const N6_PHI = 2
comptime const N6_TAU = 4
comptime const N6_J2 = 24
comptime const N6_SOPFR = 5
comptime const N6_MASTER = 24  // sigma * phi = n * tau = 24

comptime const n6_constants = [6.0, 12.0, 2.0, 4.0, 24.0, 5.0, 10.0, 8.0, 1.333333333, 0.287682072]
comptime const n6_labels = ["n", "sigma", "phi", "tau", "J2", "sopfr", "sigma-phi", "sigma-tau", "tau^2/sigma", "ln(4/3)"]

// ─── 수학 유틸 ───

pure fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }
pure fn clamp_f(x: float, lo: float, hi: float) -> float { if x < lo { lo } else { if x > hi { hi } else { x } } }

pure fn sqrt_f(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut guess = x / 2.0
    let mut i = 0
    while i < 20 { guess = (guess + x / guess) / 2.0; i = i + 1 }
    guess
}

// 결정론적 pseudo-random: seed -> [0.0, 1.0)
pure fn pseudo_rand(seed: int) -> float {
    let x = ((seed * 1103515245 + 12345) % 2147483647)
    let pos = if x < 0 { 0 - x } else { x }
    to_float(pos % 10000) / 10000.0
}

// ─── 연산자 / 결합 모드 ───

comptime const OP_ADD = 0
comptime const OP_MUL = 1
comptime const OP_DIV = 2
comptime const COMBINE_GEO = 0
comptime const COMBINE_ARITH = 1

pure fn op_name(op: int) -> string { if op == 0 { "+" } else if op == 1 { "*" } else if op == 2 { "/" } else { "+" } }
pure fn op_apply(op: int, a: float, b: float) -> float { if op == 0 { a + b } else if op == 1 { a * b } else if op == 2 { if abs_f(b) > 0.0001 { a / b } else { a } } else { a + b } }
pure fn combine_name(c: int) -> string { if c == 0 { "geo" } else if c == 1 { "arith" } else { "arith" } }
pure fn combine_apply(mode: int, a: float, b: float) -> float { if mode == 0 { sqrt_f(abs_f(a * b)) } else if mode == 1 { (a + b) / 2.0 } else { (a + b) / 2.0 } }

// ═══════════════════════════════════════════
// Strategy: 파라미터 벡터로 인코딩된 변이 전략
// ═══════════════════════════════════════════

struct Strategy {
    name: string,
    shift_count: int,
    threshold: float,
    operator: int,
    constant_idx: int,
    combine_mode: int,
    generation: int
}

// 전략 생성 헬퍼
fn make_strategy(nm: string, sc: int, thr: float, op: int, ci: int, cm: int) -> Strategy {
    Strategy { name: nm, shift_count: sc, threshold: thr, operator: op, constant_idx: ci, combine_mode: cm, generation: 0 }
}

// 초기 6종 전략 풀
fn make_initial_pool() {
    [
        make_strategy("shift",       1, 0.5, OP_ADD, 0, COMBINE_ARITH),
        make_strategy("invert",      0, 0.3, OP_DIV, 1, COMBINE_GEO),
        make_strategy("combine",     2, 0.6, OP_MUL, 2, COMBINE_ARITH),
        make_strategy("transfer",    3, 0.4, OP_ADD, 3, COMBINE_GEO),
        make_strategy("symmetry",    1, 0.7, OP_MUL, 4, COMBINE_ARITH),
        make_strategy("bifurcation", 4, 0.2, OP_DIV, 5, COMBINE_GEO)
    ]
}

// 전략 요약 문자열
fn strategy_summary(s: Strategy) -> string {
    s.name + "(shift=" + to_string(s.shift_count) + ",thr=" + to_string(s.threshold) + ",op=" + op_name(s.operator) + ",c=" + to_string(s.constant_idx) + ",comb=" + combine_name(s.combine_mode) + ",gen=" + to_string(s.generation) + ")"
}

// ═══════════════════════════════════════════
// STEP 1: Strategy Application — 전략을 시드에 적용하여 EXACT yield 측정
// ═══════════════════════════════════════════

// n=6 EXACT 매치 타겟 값들
comptime const exact_targets = [6.0, 12.0, 2.0, 4.0, 24.0, 5.0, 10.0, 8.0, 1.333333333]

// 전략을 시드 값에 적용 -> 변환된 값 반환
pure fn apply_strategy_to_value(s: Strategy, seed_val: float) -> float {
    // 1) shift: n6 상수를 shift_count번 더함
    let c_idx = s.constant_idx % n6_constants.len()
    let n6c = n6_constants[c_idx]
    let mut shifted = seed_val
    let mut si = 0
    while si < s.shift_count {
        shifted = op_apply(s.operator, shifted, n6c)
        si = si + 1
    }
    // 2) threshold 필터: 결과가 threshold 미만이면 보정
    if abs_f(shifted) < s.threshold {
        shifted = shifted + n6c
    }
    // 3) combine with seed
    combine_apply(s.combine_mode, shifted, seed_val)
}

// EXACT yield: 전략을 seeds에 적용하고 exact_targets에 매치하는 수 세기
fn measure_exact_yield(s: Strategy, seeds) -> int {
    let mut matches = 0
    for seed in seeds {
        let result = apply_strategy_to_value(s, seed)
        for target in exact_targets {
            if abs_f(result - target) < 0.01 {
                matches = matches + 1
            }
        }
    }
    matches
}

// 토너먼트 시드 값 생성 (결정론적)
fn make_tournament_seeds(round: int) {
    let mut seeds = []
    let mut i = 0
    while i < tournament_seeds {
        // 각 시드는 n6 상수 조합으로 생성
        let base = n6_constants[i % n6_constants.len()]
        let perturb = to_float((round * 7 + i * 13) % 100) / 100.0
        seeds = seeds + [base + perturb]
        i = i + 1
    }
    seeds
}

// ═══════════════════════════════════════════
// STEP 2: Meta-Mutation — 전략 자체를 변이
// ═══════════════════════════════════════════

// 전략의 파라미터를 perturbation
fn meta_mutate_strategy(s: Strategy, mutation_seed: int, gen: int) -> Strategy {
    let r1 = pseudo_rand(mutation_seed)
    let r2 = pseudo_rand(mutation_seed + 1)
    let r3 = pseudo_rand(mutation_seed + 2)
    let r4 = pseudo_rand(mutation_seed + 3)

    // shift_count 변이: +1 또는 -1 또는 유지
    let new_shift = if r1 < 0.33 {
        if s.shift_count > 0 { s.shift_count - 1 } else { 0 }
    } else {
        if r1 > 0.66 {
            if s.shift_count < max_param_shift { s.shift_count + 1 } else { max_param_shift }
        } else {
            s.shift_count
        }
    }

    // threshold 변이: +/- 0.1 범위
    let thr_delta = (r2 - 0.5) * 0.2
    let new_threshold = clamp_f(s.threshold + thr_delta, 0.01, max_param_threshold)

    // operator 변이: 30% 확률로 교체
    let new_op = if r3 < 0.3 {
        to_int(r3 * 10.0) % 3
    } else {
        s.operator
    }

    // constant_idx 변이: 20% 확률로 교체
    let new_cidx = if r4 < 0.2 {
        to_int(r4 * 50.0) % n6_constants.len()
    } else {
        s.constant_idx
    }

    // combine_mode 토글: 15% 확률
    let new_combine = if pseudo_rand(mutation_seed + 4) < 0.15 {
        if s.combine_mode == COMBINE_GEO { COMBINE_ARITH } else { COMBINE_GEO }
    } else {
        s.combine_mode
    }

    Strategy {
        name: s.name + "'",
        shift_count: new_shift,
        threshold: new_threshold,
        operator: new_op,
        constant_idx: new_cidx,
        combine_mode: new_combine,
        generation: gen
    }
}

// ═══════════════════════════════════════════
// STEP 3: Strategy Tournament — 동일 시드에서 전략 경쟁
// ═══════════════════════════════════════════

struct TournamentEntry {
    strategy: Strategy,
    total_yield: int
}

fn run_tournament(pool, gen: int) {
    let mut entries = []
    for s in pool {
        let mut total = 0
        let mut round = 0
        while round < tournament_rounds {
            let seeds = make_tournament_seeds(gen * 100 + round)
            total = total + measure_exact_yield(s, seeds)
            round = round + 1
        }
        entries = entries + [TournamentEntry { strategy: s, total_yield: total }]
    }
    // 정렬: 버블소트 (내림차순)
    let mut sorted = entries
    let mut i = 0
    while i < sorted.len() {
        let mut j = 0
        while j < sorted.len() - 1 - i {
            if sorted[j].total_yield < sorted[j + 1].total_yield {
                let tmp = sorted[j]
                sorted[j] = sorted[j + 1]
                sorted[j + 1] = tmp
            }
            j = j + 1
        }
        i = i + 1
    }
    sorted
}

// ═══════════════════════════════════════════
// STEP 4: Strategy Breeding — 상위 2개 전략 교차
// ═══════════════════════════════════════════

fn breed_strategies(parent_a: Strategy, parent_b: Strategy, gen: int) -> Strategy {
    // 교차: 앞부분은 A에서, 뒷부분은 B에서
    // crossover_point가 3이므로: shift,threshold,operator는 A / constant_idx,combine_mode는 B
    Strategy {
        name: "bred(" + parent_a.name + "+" + parent_b.name + ")",
        shift_count: parent_a.shift_count,
        threshold: parent_a.threshold,
        operator: parent_a.operator,
        constant_idx: parent_b.constant_idx,
        combine_mode: parent_b.combine_mode,
        generation: gen
    }
}

// ═══════════════════════════════════════════
// STEP 5: Self-Evaluation — 메타 알고리즘이 자신을 평가
// ═══════════════════════════════════════════

struct MetaScore {
    generation: int,
    best_yield: int,
    avg_yield: float,
    diversity: float,
    composite: float
}

fn evaluate_generation(ranked, gen: int) -> MetaScore {
    if ranked.len() == 0 {
        return MetaScore { generation: gen, best_yield: 0, avg_yield: 0.0, diversity: 0.0, composite: 0.0 }
    }

    let best = ranked[0].total_yield

    // 평균 yield
    let mut sum = 0
    for entry in ranked {
        sum = sum + entry.total_yield
    }
    let avg = to_float(sum) / to_float(ranked.len())

    // 다양성: 고유 전략 이름 수 / 전체 (단순 근사: 인접 yield 차이 합)
    let mut diff_sum = 0.0
    let mut di = 0
    while di + 1 < ranked.len() {
        diff_sum = diff_sum + abs_f(to_float(ranked[di].total_yield - ranked[di + 1].total_yield))
        di = di + 1
    }
    let diversity = if ranked.len() > 1 {
        diff_sum / to_float(ranked.len() - 1)
    } else {
        0.0
    }

    // 합성 점수: best*0.5 + avg*0.3 + diversity*0.2
    let composite = to_float(best) * 0.5 + avg * 0.3 + diversity * 0.2

    MetaScore {
        generation: gen,
        best_yield: best,
        avg_yield: avg,
        diversity: diversity,
        composite: composite
    }
}

// ═══════════════════════════════════════════
// STEP 6: Meta-Convergence Detection
// ═══════════════════════════════════════════

// 메타 수렴: composite 점수 개선이 plateau window 동안 epsilon 미만
fn check_meta_convergence(score_history) -> bool {
    if score_history.len() < meta_plateau_window + 1 {
        return false
    }
    let start = score_history.len() - meta_plateau_window
    let baseline = score_history[start - 1].composite
    let mut all_flat = true
    let mut ci = start
    while ci < score_history.len() {
        let delta = abs_f(score_history[ci].composite - baseline)
        if delta > meta_plateau_epsilon {
            all_flat = false
        }
        ci = ci + 1
    }
    all_flat
}

// ═══════════════════════════════════════════
// STEP 7: Report — 진화 결과 리포트
// ═══════════════════════════════════════════

fn print_improvement_curve(history) {
    println("  gen | best | avg    | div   | composite")
    println("  ----+------+--------+-------+----------")
    for ms in history { println("  " + to_string(ms.generation) + "   | " + to_string(ms.best_yield) + "    | " + to_string(ms.avg_yield) + " | " + to_string(ms.diversity) + " | " + to_string(ms.composite)) }
}

fn print_strategy_pool(pool) {
    let mut idx = 0
    for s in pool { println("  [" + to_string(idx) + "] " + strategy_summary(s)); idx = idx + 1 }
}

// ═══════════════════════════════════════════
// META-OUROBOROS 메인 진화 루프
// ═══════════════════════════════════════════

struct MetaEvolutionResult {
    final_pool: str,
    score_history: str,
    generations_run: int,
    converged: bool,
    best_strategy: Strategy,
    best_yield: int
}

fn make_result(pool, hist, gens: int, conv: bool, best: Strategy, by: int) -> MetaEvolutionResult {
    MetaEvolutionResult { final_pool: pool, score_history: hist, generations_run: gens, converged: conv, best_strategy: best, best_yield: by }
}

fn run_meta_evolution(max_gen: int) -> MetaEvolutionResult {
    println("=== META-OUROBOROS v2: Self-Evolving Evolution ===")
    println("generations=" + to_string(max_gen) + " pool=" + to_string(pool_size) + " rounds=" + to_string(tournament_rounds))
    println("")

    let mut pool = make_initial_pool()
    let mut score_history = []
    let mut best_ever = pool[0]
    let mut best_yield_ever = 0

    println("--- Initial Strategy Pool ---")
    print_strategy_pool(pool)
    println("")

    let mut gen = 0
    while gen < max_gen {
        println("--- Generation " + to_string(gen + 1) + " ---")

        // Meta-Mutation: 하위 절반 변이
        let half = pool.len() / 2
        let mut mutated_pool = []
        let mut mi = 0
        while mi < pool.len() {
            if mi >= half { mutated_pool = mutated_pool + [meta_mutate_strategy(pool[mi], gen * 1000 + mi * 7, gen + 1)] }
            else { mutated_pool = mutated_pool + [pool[mi]] }
            mi = mi + 1
        }

        // Tournament
        let ranked = run_tournament(mutated_pool, gen + 1)
        let mut ri = 0
        while ri < ranked.len() {
            println("  #" + to_string(ri + 1) + " yield=" + to_string(ranked[ri].total_yield) + " " + strategy_summary(ranked[ri].strategy))
            ri = ri + 1
        }

        // Breeding: top 2 교차 → 최하위 교체
        if ranked.len() >= 2 {
            let offspring = breed_strategies(ranked[0].strategy, ranked[1].strategy, gen + 1)
            println("  bred: " + strategy_summary(offspring))
            let mut new_pool = []
            let keep = if ranked.len() > pool_size - 1 { pool_size - 1 } else { ranked.len() }
            let mut ki = 0
            while ki < keep { new_pool = new_pool + [ranked[ki].strategy]; ki = ki + 1 }
            new_pool = new_pool + [offspring]
            pool = new_pool
        } else {
            let mut new_pool = []
            for entry in ranked { new_pool = new_pool + [entry.strategy] }
            pool = new_pool
        }

        // Self-Evaluation
        let score = evaluate_generation(ranked, gen + 1)
        score_history = score_history + [score]
        if score.best_yield > best_yield_ever { best_yield_ever = score.best_yield; best_ever = ranked[0].strategy }
        println("  score: best=" + to_string(score.best_yield) + " avg=" + to_string(score.avg_yield) + " composite=" + to_string(score.composite))

        // Convergence check
        if check_meta_convergence(score_history) {
            println("\n  >>> META-FIXED-POINT at generation " + to_string(gen + 1) + " <<<")
            return make_result(pool, score_history, gen + 1, true, best_ever, best_yield_ever)
        }
        println("")
        gen = gen + 1
    }
    make_result(pool, score_history, max_gen, false, best_ever, best_yield_ever)
}

fn show_best_strategy() {
    let result = run_meta_evolution(3)
    println("\n=== Current Best Strategy ===")
    println("  " + strategy_summary(result.best_strategy))
    println("  yield=" + to_string(result.best_yield) + " gen=" + to_string(result.generations_run) + " converged=" + to_string(result.converged))
}


fn print_full_report(result: MetaEvolutionResult) {
    println("")
    println("=== META-OUROBOROS v2 — EVOLUTION REPORT ===")
    println("")
    println("--- Evolved Strategies ---")
    print_strategy_pool(result.final_pool)
    println("")
    println("--- Improvement Curve ---")
    print_improvement_curve(result.score_history)
    println("")
    println("--- Summary ---")
    println("  generations: " + to_string(result.generations_run) + "  converged: " + to_string(result.converged))
    println("  best: " + strategy_summary(result.best_strategy) + "  yield=" + to_string(result.best_yield))
    let ci = result.best_strategy.constant_idx % n6_constants.len()
    println("  n=6 alignment: " + n6_labels[ci] + "=" + to_string(n6_constants[ci]) + " op=" + op_name(result.best_strategy.operator) + " comb=" + combine_name(result.best_strategy.combine_mode))
    println("")
    println("  The snake has eaten its tail. The evolution algorithm has evolved itself.")
}

// ═══════════════════════════════════════════
// CLI 진입점
// ═══════════════════════════════════════════

let a = args()
let mode = if a.len() >= 2 { a[1] } else { "help" }

if mode == "evolve" {
    let max_gen = if a.len() >= 3 { to_int(a[2]) } else { default_generations }
    let result = run_meta_evolution(max_gen)
    print_full_report(result)
}

if mode == "best" {
    show_best_strategy()
}

if mode == "help" {
    println("=== ouroboros_meta.hexa — Meta-OUROBOROS v2: 자기 진화 엔진 ===")
    println("")
    println("개념: 진화 알고리즘 자체가 진화한다. 뱀이 자기 꼬리를 먹는다.")
    println("")
    println("사용법:")
    println("  hexa ouroboros_meta.hexa evolve         기본 6세대 메타 진화")
    println("  hexa ouroboros_meta.hexa evolve 12      12세대 메타 진화")
    println("  hexa ouroboros_meta.hexa best            현재 최적 전략 표시")
    println("  hexa ouroboros_meta.hexa help             이 도움말")
    println("")
    println("파이프라인: Pool(6종) -> MetaMutation -> Tournament -> Breeding -> SelfEval -> Convergence -> Report")
    println("전략 벡터: {shift_count, threshold, operator(+|*|/), constant_idx, combine_mode(geo|arith)}")
    println("n=6: sigma=12, phi=2, tau=4, J2=24, sopfr=5, master: sigma*phi=n*tau=24")
}

// ─── 검증 ───

assert abs_f(0.0 - 3.14) > 3.0
assert clamp_f(5.0, 0.0, 1.0) == 1.0
assert clamp_f(0.0 - 1.0, 0.0, 1.0) == 0.0
assert op_name(OP_ADD) == "+"
assert op_apply(OP_MUL, 3.0, 4.0) == 12.0
assert combine_apply(COMBINE_ARITH, 4.0, 8.0) == 6.0

let test_pool = make_initial_pool()
assert test_pool.len() == pool_size
assert make_tournament_seeds(0).len() == tournament_seeds
assert apply_strategy_to_value(test_pool[0], 6.0) > 0.0
assert measure_exact_yield(test_pool[0], [6.0, 12.0, 2.0, 4.0]) >= 0

let mutated = meta_mutate_strategy(test_pool[0], 42, 1)
assert mutated.shift_count >= 0
assert mutated.threshold > 0.0

let bred = breed_strategies(test_pool[0], test_pool[1], 1)
assert bred.shift_count == test_pool[0].shift_count
assert bred.constant_idx == test_pool[1].constant_idx

// 수렴: plateau된 점수 -> true, 발산 점수 -> false
fn mk_ms(g: int, by: int, comp: float) -> MetaScore { MetaScore { generation: g, best_yield: by, avg_yield: 3.0, diversity: 1.0, composite: comp } }
let flat_scores = [mk_ms(1, 5, 4.0), mk_ms(2, 5, 4.0), mk_ms(3, 5, 4.0), mk_ms(4, 5, 4.001), mk_ms(5, 5, 4.002)]
assert check_meta_convergence(flat_scores) == true
let div_scores = [mk_ms(1, 1, 1.0), mk_ms(2, 3, 3.0), mk_ms(3, 5, 5.0), mk_ms(4, 8, 8.0), mk_ms(5, 12, 12.0)]
assert check_meta_convergence(div_scores) == false

assert N6_SIGMA * N6_PHI == N6 * N6_TAU
assert N6_MASTER == 24

println("")
println("=== ouroboros_meta verified ===")

// ─── 정리 및 증명 ───

fn verify_meta_convergence() {
    // composite가 plateau_window 동안 epsilon 미만 변동 → 메타 고정점
    assert check_meta_convergence(flat_scores) == true
    assert check_meta_convergence(div_scores) == false
}

fn verify_strategy_breeding_preserves_traits() {
    // 교차: 전반부(shift,thr,op)는 A, 후반부(cidx,comb)는 B에서
    let child = breed_strategies(test_pool[0], test_pool[1], 99)
    assert child.shift_count == test_pool[0].shift_count
    assert child.operator == test_pool[0].operator
    assert child.constant_idx == test_pool[1].constant_idx
    assert child.combine_mode == test_pool[1].combine_mode
}

fn verify_meta_mutation_bounded() {
    // 변이 파라미터는 항상 유효 범위 내
    let mut seed = 0
    while seed < 50 {
        let m = meta_mutate_strategy(test_pool[0], seed, 1)
        assert m.shift_count >= 0
        assert m.shift_count <= max_param_shift
        assert m.threshold > 0.0
        assert m.threshold <= max_param_threshold
        seed = seed + 1
    }
}

verify_meta_convergence()
verify_strategy_breeding_preserves_traits()
verify_meta_mutation_bounded()

proof meta_ouroboros_invariants {
    invariant strategy_pool_size_preserved()
    invariant tournament_ranking_deterministic()
    invariant breeding_crossover_consistent()
    invariant meta_mutation_bounded()
    invariant convergence_detection_monotonic()
    invariant exact_yield_non_negative()
}
