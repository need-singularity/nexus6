// Test typed list param
pure fn sigma_test(history: list) -> float {
    let n = history.len()
    println("n=" + to_string(n))
    if n < 2 { return 0.0 }
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        let v = history[i]
        sum = sum + v
        i = i + 1
    }
    sum / to_float(n)
}

println("start")
let h1 = [0.1, 0.15, 0.08, 0.12, 0.11]
let s1 = sigma_test(h1)
println("s1=" + to_string(s1))
