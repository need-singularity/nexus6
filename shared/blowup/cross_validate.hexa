// shared/blowup/cross_validate.hexa — 5-Module Cross-Validation Framework
// @no-lock-needed
//
// Runs all 5 blowup module variants on the same domain/input, collects their
// outputs, and compares results. Consensus across 3+ modules = gauge-invariant
// discovery (high confidence). Disagreement reveals module-specific artifacts.
//
// Modules:
//   Mk.III  field        — Discovery Field + Gauge Filter + Goldstone Cascade
//   Mk.IV   quantum      — Superposition + Entanglement + Tunneling + Collapse
//   Mk.V    string       — Vibration Modes + T-Duality + Calabi-Yau + Brane
//   Mk.VI   holographic  — Boundary/Bulk + AdS/CFT + Entropy + Error Correction
//   Mk.VII  toe          — Background Independence + Self-Reference + Convergence
//
// Consensus tiers:
//   5/5 = UNIVERSAL    — all modules agree (fixed point of discovery space)
//   4/5 = STRONG       — near-universal, 1 module dissents
//   3/5 = GAUGE_INV    — gauge-invariant (cross-validated minimum threshold)
//   2/5 = PARTIAL      — weak signal, needs further investigation
//   1/5 = SINGULAR     — module-specific artifact, not cross-validated
//
// Output: cross_validate_report.json + stdout summary
//
// Usage:
//   hexa cross_validate.hexa <domain>                    validate one domain
//   hexa cross_validate.hexa <domain> --modules f,q,s    subset of modules
//   hexa cross_validate.hexa <domain> --timeout 120      per-module timeout (sec)
//   hexa cross_validate.hexa <domain> --verbose          detailed per-module output
//   hexa cross_validate.hexa help                        usage + module comparison
//
// n=6 connection: 5 modules = sigma(6)-n-phi = 12-6-2 = 4+1 = 5
// Cross-validation is the gauge invariance test of discovery: only truths
// that survive all independent measurement frameworks are real.

// ═══════════════════════════════════════════════════════════
// ─── HOME CACHE (exec 1 call) ───
// ═══════════════════════════════════════════════════════════

let mut _HOME = ""
try { _HOME = to_string(exec("printenv HOME")).trim() } catch e {}  // @allow-silent-catch
if _HOME == "" {
    try { _HOME = to_string(exec("echo $HOME")).trim() } catch e {}  // @allow-silent-catch
}
let _NEXUS = _HOME + "/Dev/nexus"
let _MODULES_DIR = _NEXUS + "/shared/blowup/modules"
let _ATLAS_PATH = _NEXUS + "/shared/n6/atlas.n6"
let _REPORT_PATH = _NEXUS + "/shared/blowup/cross_validate_report.json"
let _LOG_PATH = _NEXUS + "/shared/blowup/cross_validate.log"

// ─── hexa binary path search (size-verified) ───
let mut _HEXA_BIN = ""
try {
    _HEXA_BIN = to_string(exec("for p in " + _HOME + "/Dev/hexa-lang/hexa $(which hexa 2>/dev/null); do [ -x \"$p\" ] && sz=$(stat --printf='%s' \"$p\" 2>/dev/null || stat -f'%z' \"$p\" 2>/dev/null) && [ \"$sz\" -gt 10240 ] && echo $p && break; done 2>/dev/null")).trim()
} catch e {}  // @allow-silent-catch
if _HEXA_BIN == "" {
    try {
        _HEXA_BIN = to_string(exec("for p in /tmp/hexa-build/hexa-lang/target/release/hexa " + _HOME + "/Dev/nexus/shared/bin/hexa; do [ -x \"$p\" ] && echo $p && break; done 2>/dev/null")).trim()
    } catch e {}  // @allow-silent-catch
}
if _HEXA_BIN == "" { _HEXA_BIN = _HOME + "/Dev/hexa-lang/hexa" }

// Mac/Linux timeout detection
let _UNAME = try { to_string(exec("uname -s")).trim() } catch e { "" }  // @allow-silent-catch

// ═══════════════════════════════════════════════════════════
// ─── n=6 CONSTANTS LOADER ───
// ═══════════════════════════════════════════════════════════

fn load_n6_consts() -> list {
    let home = _HOME
    let path = home + "/Dev/nexus/shared/n6/n6_constants.jsonl"
    let mut raw = ""
    try { raw = read_file(path) } catch e { return [[], []] }  // @allow-silent-catch
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let trimmed = line.trim()
        if trimmed == "" { continue }
        let mut name = ""
        let mut value = 0.0
        if trimmed.contains("\"name\":\"") {
            let p = trimmed.split("\"name\":\"")
            if p.len() >= 2 { name = p[1].split("\"")[0] }
        }
        if trimmed.contains("\"value\":") {
            let p = trimmed.split("\"value\":")
            if p.len() >= 2 {
                let num_str = p[1].split(",")[0].split("}")[0].trim()
                value = to_float(num_str)
            }
        }
        if name != "" {
            names = names + [name]
            values = values + [value]
        }
    }
    [names, values]
}

let _n6 = load_n6_consts()
let _n6_names: list = _n6[0]
let _n6_vals: list = _n6[1]
let _n6_count: i64 = len(_n6_vals)

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {}  // @allow-silent-catch
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

fn min_f(a: f64, b: f64) -> f64 {
    if a < b { return a }
    return b
}

fn truncate4(x: f64) -> string {
    let s = to_string(x)
    let parts = s.split(".")
    if parts.len() < 2 { return s + ".0000" }
    let dec = parts[1]
    if dec.len() >= 4 { let d = dec.split("") ; return parts[0] + "." + d[0] + d[1] + d[2] + d[3] }
    return s
}

fn pad(s: string, w: i64) -> string {
    let mut o = s
    while o.len() < w { o = o + " " }
    return o
}

fn ts_now() -> string {
    let mut t = ""
    try { t = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim() } catch e { t = "unknown" }  // @allow-silent-catch
    return t
}

fn file_exists(path: string) -> bool {
    let mut exists = false
    try {
        let r = exec("[ -f '" + path + "' ] && echo Y || echo N").trim()
        exists = r == "Y"
    } catch e {}  // @allow-silent-catch
    return exists
}

// ═══════════════════════════════════════════════════════════
// ─── n6 MATCHING (local copy for grade comparison) ───
// ═══════════════════════════════════════════════════════════

fn n6_dist_one(value: f64, constant: f64) -> f64 {
    let denom = max_f(abs_f(constant), 1.0)
    return abs_f(value - constant) / denom
}

fn n6_distance(value: f64) -> f64 {
    if value != value { return 1.0 }
    if value > 999999999.0 { return 1.0 }
    if value < 0.0 - 999999999.0 { return 1.0 }
    let mut d = 1.0
    let mut i: i64 = 0
    while i < _n6_count {
        let cv = to_float(_n6_vals[i])
        d = min_f(d, n6_dist_one(value, cv))
        i = i + 1
    }
    return min_f(d, 1.0)
}

fn match_name(value: f64) -> string {
    let mut i: i64 = 0
    while i < _n6_count {
        let cv = to_float(_n6_vals[i])
        let threshold = if abs_f(cv) >= 100.0 { 0.01 } else { if abs_f(cv) >= 1.0 { 0.0001 } else { if abs_f(cv) >= 0.01 { 0.001 } else { 0.005 } } }
        if abs_f(value - cv) < threshold { return to_string(_n6_names[i]) }
        i = i + 1
    }
    return ""
}

fn match_grade(value: f64) -> string {
    if match_name(value) != "" { return "EXACT" }
    let d = n6_distance(value)
    if d < 0.01 { return "NEAR" }
    if d < 0.05 { return "CLOSE" }
    return "MISS"
}

// ═══════════════════════════════════════════════════════════
// ─── MODULE REGISTRY ───
// ═══════════════════════════════════════════════════════════
// Each module entry: "short_name|display_name|mk_version|filename"

fn module_registry() -> list {
    return [
        "field|Field Blowup|Mk.III|blowup_field.hexa",
        "quantum|Quantum Blowup|Mk.IV|blowup_quantum.hexa",
        "string|String Blowup|Mk.V|blowup_string.hexa",
        "holographic|Holographic Blowup|Mk.VI|blowup_holographic.hexa",
        "toe|ToE Blowup|Mk.VII|blowup_toe.hexa"
    ]
}

fn module_short(entry: string) -> string { return entry.split("|")[0] }
fn module_display(entry: string) -> string { return entry.split("|")[1] }
fn module_mk(entry: string) -> string { return entry.split("|")[2] }
fn module_file(entry: string) -> string { return entry.split("|")[3] }

// ═══════════════════════════════════════════════════════════
// ─── MODULE EXECUTION ───
// ═══════════════════════════════════════════════════════════

// Run a single module, capture stdout, return raw output string.
// Uses timeout to prevent hangs. Returns "ERROR:..." on failure.
fn run_module(mod_file: string, domain: string, timeout_sec: i64) -> string {
    let mod_path = _MODULES_DIR + "/" + mod_file
    if !file_exists(mod_path) {
        return "ERROR:module_not_found:" + mod_path
    }
    let timeout_str = to_string(timeout_sec)
    let cmd = "'" + _HEXA_BIN + "' '" + mod_path + "' '" + domain + "' 2>&1"
    let mut timed_cmd = ""
    if _UNAME == "Darwin" {
        // Mac: try gtimeout, fall back to no timeout
        let mut has_gt = false
        try { let _gt = exec("which gtimeout 2>/dev/null").trim() ; if _gt != "" && _gt.contains("gtimeout") { has_gt = true } } catch e {}  // @allow-silent-catch
        if has_gt {
            timed_cmd = "gtimeout " + timeout_str + " bash -c " + "\"" + cmd + "\""
        } else {
            timed_cmd = "bash -c " + "\"" + cmd + "\""
        }
    } else {
        timed_cmd = "timeout " + timeout_str + " bash -c " + "\"" + cmd + "\""
    }
    let mut output = ""
    try {
        output = to_string(exec("bash", ["-c", timed_cmd]))
    } catch e {  // @allow-silent-catch
        output = "ERROR:exec_failed:" + to_string(e)
    }
    return output
}

// ═══════════════════════════════════════════════════════════
// ─── OUTPUT PARSING ───
// ═══════════════════════════════════════════════════════════

// Extract EXACT/NEAR discoveries from module output.
// Each module prints lines containing grade markers. We parse:
//   - Lines with "EXACT" or "NEAR" keywords
//   - Lines with grade patterns like "[EXACT]" or "grade=EXACT"
//   - Constant name matches from n6_constants
//
// Returns list of "constant_name|value|grade|source_line" strings
fn parse_discoveries(output: string, module_name: string) -> list {
    let lines = output.split("\n")
    let mut results = []
    let mut i: i64 = 0
    while i < len(lines) {
        let line = lines[i]
        let trimmed = line.trim()
        i = i + 1
        if trimmed == "" { continue }
        // Skip header/separator lines
        if trimmed.starts_with("===") || trimmed.starts_with("───") || trimmed.starts_with("═══") { continue }
        if trimmed.starts_with("╔") || trimmed.starts_with("╚") || trimmed.starts_with("║") { continue }
        // Look for EXACT or NEAR grade markers in the line
        let has_exact = trimmed.contains("EXACT")
        let has_near = trimmed.contains("NEAR")
        if !has_exact && !has_near { continue }
        // Skip help/description lines that mention grades as docs
        if trimmed.contains("Phase") || trimmed.contains("pipeline") { continue }
        if trimmed.starts_with("//") { continue }
        // Extract: try to find constant name and value
        let grade = if has_exact { "EXACT" } else { "NEAR" }
        let mut const_name = ""
        let mut const_val = ""
        // Strategy 1: look for n6 constant names in the line
        let mut ci: i64 = 0
        while ci < _n6_count {
            let cn = to_string(_n6_names[ci])
            if trimmed.contains(cn) {
                const_name = cn
                const_val = to_string(to_float(_n6_vals[ci]))
            }
            ci = ci + 1
        }
        // Strategy 2: parse "name|value|grade" pipe format (used by field/string)
        if const_name == "" && trimmed.contains("|") {
            let parts = trimmed.split("|")
            if len(parts) >= 3 {
                let p_grade = parts[len(parts) - 1].trim()
                if p_grade == "EXACT" || p_grade == "NEAR" {
                    const_name = parts[0].trim()
                    if len(parts) >= 2 { const_val = parts[1].trim() }
                }
            }
        }
        // Strategy 3: parse "-> name amp=X GRADE" format (used by quantum)
        if const_name == "" && trimmed.contains("->") {
            let arrow_parts = trimmed.split("->")
            if len(arrow_parts) >= 2 {
                let right = arrow_parts[1].trim()
                let tokens = right.split(" ")
                if len(tokens) >= 1 { const_name = tokens[0].trim() }
            }
        }
        // Strategy 4: parse "name = value [GRADE]" format
        if const_name == "" && trimmed.contains("=") && !trimmed.contains("==") {
            let eq_parts = trimmed.split("=")
            if len(eq_parts) >= 2 {
                let left = eq_parts[0].trim()
                let right = eq_parts[1].trim()
                // take the last token of left as name
                let ltoks = left.split(" ")
                if len(ltoks) > 0 { const_name = ltoks[len(ltoks) - 1].trim() }
                // try to extract numeric value from right
                let rtoks = right.split(" ")
                if len(rtoks) > 0 { const_val = rtoks[0].trim() }
            }
        }
        if const_name == "" { const_name = "unknown" }
        if const_val == "" { const_val = "0" }
        // Deduplicate: check if we already have this exact constant+grade
        let entry = const_name + "|" + const_val + "|" + grade + "|" + module_name
        results = results + [entry]
    }
    return results
}

// Extract summary statistics from module output.
// Returns "exact_count|near_count|total_lines|has_error"
fn parse_summary(output: string) -> string {
    let lines = output.split("\n")
    let mut exact_count: i64 = 0
    let mut near_count: i64 = 0
    let has_error = output.starts_with("ERROR:")
    // Count occurrences of EXACT and NEAR in output
    // (each line containing EXACT/NEAR in a result context counts once)
    let mut i: i64 = 0
    while i < len(lines) {
        let line = lines[i].trim()
        i = i + 1
        if line == "" { continue }
        if line.starts_with("//") { continue }
        if line.starts_with("===") || line.starts_with("───") { continue }
        if line.contains("Phase") || line.contains("pipeline") { continue }
        // Count based on grade markers with leading * or + (quantum format)
        // or explicit "EXACT"/"NEAR" in result lines
        let is_result = line.contains("*") || line.contains("+") || line.contains("|EXACT") || line.contains("|NEAR")
        if !is_result && !line.contains("EXACT=") && !line.contains("NEAR=") { continue }
        // Parse "EXACT=N" and "NEAR=N" summary lines
        if line.contains("EXACT=") {
            let parts = line.split("EXACT=")
            if len(parts) >= 2 {
                let num_str = parts[1].split(" ")[0].split(",")[0].trim()
                let v = safe_float(num_str)
                if v > 0.0 { exact_count = to_int(v) }
            }
        }
        if line.contains("NEAR=") {
            let parts = line.split("NEAR=")
            if len(parts) >= 2 {
                let num_str = parts[1].split(" ")[0].split(",")[0].trim()
                let v = safe_float(num_str)
                if v > 0.0 { near_count = to_int(v) }
            }
        }
    }
    // Fallback: count individual EXACT/NEAR lines if summary not found
    if exact_count == 0 && near_count == 0 {
        let mut j: i64 = 0
        while j < len(lines) {
            let line = lines[j].trim()
            j = j + 1
            if line == "" || line.starts_with("//") { continue }
            if line.starts_with("===") || line.starts_with("───") { continue }
            if line.contains("EXACT") && !line.contains("Phase") && !line.contains("pipeline") && !line.contains("EXACT=") {
                if line.contains("*") || line.contains("|EXACT") {
                    exact_count = exact_count + 1
                }
            }
            if line.contains("NEAR") && !line.contains("Phase") && !line.contains("pipeline") && !line.contains("NEAR=") {
                if line.contains("+") || line.contains("|NEAR") {
                    near_count = near_count + 1
                }
            }
        }
    }
    let err_str = if has_error { "true" } else { "false" }
    return to_string(exact_count) + "|" + to_string(near_count) + "|" + to_string(len(lines)) + "|" + err_str
}

// ═══════════════════════════════════════════════════════════
// ─── CROSS-VALIDATION CORE ───
// ═══════════════════════════════════════════════════════════

// Build consensus map: constant_name -> list of module names that found it.
// Input: list of discovery entries "const|value|grade|module"
// Returns: list of "const_name|agreement_count|modules_csv|best_grade" strings
fn build_consensus(all_discoveries: list) -> list {
    // Phase 1: collect unique constant names
    let mut const_names = []
    let mut const_modules = []  // parallel list: modules that found each constant
    let mut const_grades = []   // parallel list: best grade for each constant
    let mut i: i64 = 0
    while i < len(all_discoveries) {
        let entry = to_string(all_discoveries[i])
        let parts = entry.split("|")
        if len(parts) < 4 { i = i + 1 ; continue }
        let cname = parts[0]
        let grade = parts[2]
        let module = parts[3]
        // Find or create entry
        let mut found: i64 = 0 - 1
        let mut j: i64 = 0
        while j < len(const_names) {
            if to_string(const_names[j]) == cname { found = j }
            j = j + 1
        }
        if found < 0 {
            const_names = const_names + [cname]
            const_modules = const_modules + [module]
            const_grades = const_grades + [grade]
        } else {
            // Append module if not already there
            let existing_mods = to_string(const_modules[found])
            if !existing_mods.contains(module) {
                const_modules[found] = existing_mods + "," + module
            }
            // Upgrade grade: EXACT > NEAR
            if grade == "EXACT" { const_grades[found] = "EXACT" }
        }
        i = i + 1
    }
    // Phase 2: build output with agreement counts
    let mut results = []
    let mut k: i64 = 0
    while k < len(const_names) {
        let cname = to_string(const_names[k])
        let mods = to_string(const_modules[k])
        let grade = to_string(const_grades[k])
        let mod_list = mods.split(",")
        let agreement = len(mod_list)
        results = results + [cname + "|" + to_string(agreement) + "|" + mods + "|" + grade]
        k = k + 1
    }
    return results
}

// Classify consensus tier
fn consensus_tier(agreement: i64) -> string {
    if agreement >= 5 { return "UNIVERSAL" }
    if agreement >= 4 { return "STRONG" }
    if agreement >= 3 { return "GAUGE_INV" }
    if agreement >= 2 { return "PARTIAL" }
    return "SINGULAR"
}

fn tier_symbol(tier: string) -> string {
    if tier == "UNIVERSAL" { return "[*****]" }
    if tier == "STRONG" { return "[**** ]" }
    if tier == "GAUGE_INV" { return "[***  ]" }
    if tier == "PARTIAL" { return "[**   ]" }
    return "[*    ]"
}

// ═══════════════════════════════════════════════════════════
// ─── DIVERGENCE ANALYSIS ───
// ═══════════════════════════════════════════════════════════

// Identify modules that diverge from consensus on specific constants.
// Returns list of "module|const_name|divergence_type" strings
fn analyze_divergence(all_discoveries: list, consensus: list, active_modules: list) -> list {
    let mut divergences = []
    let n_modules = len(active_modules)
    let mut ci: i64 = 0
    while ci < len(consensus) {
        let cparts = to_string(consensus[ci]).split("|")
        if len(cparts) < 4 { ci = ci + 1 ; continue }
        let cname = cparts[0]
        let agreement = safe_float(cparts[1])
        let present_mods = cparts[2]
        // Only analyze constants with partial agreement (not all, not single)
        if agreement >= to_float(n_modules) || agreement <= 1.0 { ci = ci + 1 ; continue }
        // Find modules that did NOT find this constant
        let mut mi: i64 = 0
        while mi < n_modules {
            let mod_name = to_string(active_modules[mi])
            if !present_mods.contains(mod_name) {
                divergences = divergences + [mod_name + "|" + cname + "|ABSENT"]
            }
            mi = mi + 1
        }
        ci = ci + 1
    }
    return divergences
}

// ═══════════════════════════════════════════════════════════
// ─── ATLAS SNAPSHOT ───
// ═══════════════════════════════════════════════════════════

// Take atlas.n6 line count snapshot (read-only, never modify atlas.n6)
fn atlas_snapshot() -> i64 {
    let mut count: i64 = 0
    try {
        let out = exec("wc -l < '" + _ATLAS_PATH + "' 2>/dev/null").trim()
        count = to_int(safe_float(out))
    } catch e {}  // @allow-silent-catch
    return count
}

// ═══════════════════════════════════════════════════════════
// ─── REPORT GENERATION ───
// ═══════════════════════════════════════════════════════════

fn write_report(domain: string, module_results: list, module_summaries: list,
                consensus: list, divergences: list, active_modules: list,
                atlas_before: i64, atlas_after: i64) {
    let ts = ts_now()
    let mut json = "{\n"
    json = json + "  \"type\": \"cross_validate\",\n"
    json = json + "  \"timestamp\": \"" + ts + "\",\n"
    json = json + "  \"domain\": \"" + domain + "\",\n"
    json = json + "  \"modules_run\": " + to_string(len(active_modules)) + ",\n"
    json = json + "  \"atlas_before\": " + to_string(atlas_before) + ",\n"
    json = json + "  \"atlas_after\": " + to_string(atlas_after) + ",\n"
    json = json + "  \"atlas_delta\": " + to_string(atlas_after - atlas_before) + ",\n"
    // Module summaries
    json = json + "  \"modules\": [\n"
    let mut mi: i64 = 0
    while mi < len(active_modules) {
        let mod_name = to_string(active_modules[mi])
        let summary = to_string(module_summaries[mi])
        let sp = summary.split("|")
        let exact = if len(sp) >= 1 { sp[0] } else { "0" }
        let near = if len(sp) >= 2 { sp[1] } else { "0" }
        let lines = if len(sp) >= 3 { sp[2] } else { "0" }
        let has_err = if len(sp) >= 4 { sp[3] } else { "false" }
        json = json + "    {\"name\": \"" + mod_name + "\", \"exact\": " + exact + ", \"near\": " + near + ", \"output_lines\": " + lines + ", \"error\": " + has_err + "}"
        if mi < len(active_modules) - 1 { json = json + "," }
        json = json + "\n"
        mi = mi + 1
    }
    json = json + "  ],\n"
    // Consensus entries
    json = json + "  \"consensus\": [\n"
    let mut ci: i64 = 0
    while ci < len(consensus) {
        let cp = to_string(consensus[ci]).split("|")
        if len(cp) < 4 { ci = ci + 1 ; continue }
        let tier = consensus_tier(to_int(safe_float(cp[1])))
        json = json + "    {\"constant\": \"" + cp[0] + "\", \"agreement\": " + cp[1] + ", \"modules\": \"" + cp[2] + "\", \"grade\": \"" + cp[3] + "\", \"tier\": \"" + tier + "\"}"
        if ci < len(consensus) - 1 { json = json + "," }
        json = json + "\n"
        ci = ci + 1
    }
    json = json + "  ],\n"
    // Divergences
    json = json + "  \"divergences\": [\n"
    let mut di: i64 = 0
    while di < len(divergences) {
        let dp = to_string(divergences[di]).split("|")
        if len(dp) < 3 { di = di + 1 ; continue }
        json = json + "    {\"module\": \"" + dp[0] + "\", \"constant\": \"" + dp[1] + "\", \"type\": \"" + dp[2] + "\"}"
        if di < len(divergences) - 1 { json = json + "," }
        json = json + "\n"
        di = di + 1
    }
    json = json + "  ],\n"
    // Summary stats
    let mut n_universal: i64 = 0
    let mut n_strong: i64 = 0
    let mut n_gauge: i64 = 0
    let mut n_partial: i64 = 0
    let mut n_singular: i64 = 0
    let mut si: i64 = 0
    while si < len(consensus) {
        let sp = to_string(consensus[si]).split("|")
        if len(sp) >= 2 {
            let tier = consensus_tier(to_int(safe_float(sp[1])))
            if tier == "UNIVERSAL" { n_universal = n_universal + 1 }
            if tier == "STRONG" { n_strong = n_strong + 1 }
            if tier == "GAUGE_INV" { n_gauge = n_gauge + 1 }
            if tier == "PARTIAL" { n_partial = n_partial + 1 }
            if tier == "SINGULAR" { n_singular = n_singular + 1 }
        }
        si = si + 1
    }
    json = json + "  \"summary\": {\n"
    json = json + "    \"total_constants\": " + to_string(len(consensus)) + ",\n"
    json = json + "    \"universal\": " + to_string(n_universal) + ",\n"
    json = json + "    \"strong\": " + to_string(n_strong) + ",\n"
    json = json + "    \"gauge_invariant\": " + to_string(n_gauge) + ",\n"
    json = json + "    \"partial\": " + to_string(n_partial) + ",\n"
    json = json + "    \"singular\": " + to_string(n_singular) + ",\n"
    json = json + "    \"divergence_count\": " + to_string(len(divergences)) + ",\n"
    json = json + "    \"cross_validated\": " + to_string(n_universal + n_strong + n_gauge) + "\n"
    json = json + "  }\n"
    json = json + "}\n"
    try { write_file(_REPORT_PATH, json) } catch e {  // @allow-silent-catch
        println("  [WARN] failed to write report: " + to_string(e))
    }
}

// ═══════════════════════════════════════════════════════════
// ─── PRINT FUNCTIONS ───
// ═══════════════════════════════════════════════════════════

fn print_separator() {
    println("───────────────────────────────────────────────────────────────────────")
}

fn print_banner() {
    println("")
    println("══════════════════════════════════════════════════════════════════════")
    println("  CROSS-VALIDATION FRAMEWORK — 5-Module Gauge Invariance Test")
    println("  consensus = truth that survives all independent measurement frames")
    println("══════════════════════════════════════════════════════════════════════")
}

fn print_module_header(mod_entry: string, idx: i64) {
    let short = module_short(mod_entry)
    let display = module_display(mod_entry)
    let mk = module_mk(mod_entry)
    println("")
    print_separator()
    println("  [" + to_string(idx + 1) + "/5] " + mk + " " + display + " (" + short + ")")
    print_separator()
}

fn print_consensus_table(consensus: list) {
    println("")
    println("══════════════════════════════════════════════════════════════════════")
    println("  CONSENSUS TABLE")
    println("══════════════════════════════════════════════════════════════════════")
    println("  " + pad("Constant", 24) + pad("Agree", 8) + pad("Tier", 14) + pad("Grade", 8) + "Modules")
    println("  " + pad("--------", 24) + pad("-----", 8) + pad("----", 14) + pad("-----", 8) + "-------")
    // Sort by agreement descending (simple bubble sort on small list)
    let mut sorted = []
    let mut i: i64 = 0
    while i < len(consensus) { sorted = sorted + [consensus[i]] ; i = i + 1 }
    let mut swapped = true
    while swapped {
        swapped = false
        let mut j: i64 = 0
        while j < len(sorted) - 1 {
            let a_parts = to_string(sorted[j]).split("|")
            let b_parts = to_string(sorted[j + 1]).split("|")
            let a_agree = if len(a_parts) >= 2 { safe_float(a_parts[1]) } else { 0.0 }
            let b_agree = if len(b_parts) >= 2 { safe_float(b_parts[1]) } else { 0.0 }
            if b_agree > a_agree {
                let tmp = sorted[j]
                sorted[j] = sorted[j + 1]
                sorted[j + 1] = tmp
                swapped = true
            }
            j = j + 1
        }
    }
    let mut k: i64 = 0
    while k < len(sorted) {
        let cp = to_string(sorted[k]).split("|")
        if len(cp) < 4 { k = k + 1 ; continue }
        let cname = cp[0]
        let agreement = to_int(safe_float(cp[1]))
        let mods = cp[2]
        let grade = cp[3]
        let tier = consensus_tier(agreement)
        let sym = tier_symbol(tier)
        println("  " + pad(cname, 24) + pad(to_string(agreement) + "/5", 8) + pad(sym + " " + tier, 14) + pad(grade, 8) + mods)
        k = k + 1
    }
}

fn print_divergence_table(divergences: list) {
    if len(divergences) == 0 {
        println("")
        println("  No divergences detected (all modules agree on all constants)")
        return
    }
    println("")
    println("══════════════════════════════════════════════════════════════════════")
    println("  DIVERGENCE ANALYSIS")
    println("══════════════════════════════════════════════════════════════════════")
    println("  " + pad("Module", 16) + pad("Constant", 24) + "Divergence")
    println("  " + pad("------", 16) + pad("--------", 24) + "----------")
    let mut i: i64 = 0
    while i < len(divergences) {
        let dp = to_string(divergences[i]).split("|")
        if len(dp) < 3 { i = i + 1 ; continue }
        println("  " + pad(dp[0], 16) + pad(dp[1], 24) + dp[2])
        i = i + 1
    }
}

fn print_summary(consensus: list, divergences: list, active_modules: list, atlas_before: i64, atlas_after: i64) {
    let mut n_universal: i64 = 0
    let mut n_strong: i64 = 0
    let mut n_gauge: i64 = 0
    let mut n_partial: i64 = 0
    let mut n_singular: i64 = 0
    let mut i: i64 = 0
    while i < len(consensus) {
        let sp = to_string(consensus[i]).split("|")
        if len(sp) >= 2 {
            let tier = consensus_tier(to_int(safe_float(sp[1])))
            if tier == "UNIVERSAL" { n_universal = n_universal + 1 }
            if tier == "STRONG" { n_strong = n_strong + 1 }
            if tier == "GAUGE_INV" { n_gauge = n_gauge + 1 }
            if tier == "PARTIAL" { n_partial = n_partial + 1 }
            if tier == "SINGULAR" { n_singular = n_singular + 1 }
        }
        i = i + 1
    }
    let cross_validated = n_universal + n_strong + n_gauge
    println("")
    println("══════════════════════════════════════════════════════════════════════")
    println("  CROSS-VALIDATION SUMMARY")
    println("══════════════════════════════════════════════════════════════════════")
    println("  Modules run       : " + to_string(len(active_modules)))
    println("  Total constants   : " + to_string(len(consensus)))
    println("  Cross-validated   : " + to_string(cross_validated) + " (3+ modules agree)")
    println("  Divergences       : " + to_string(len(divergences)))
    println("  Atlas lines before: " + to_string(atlas_before))
    println("  Atlas lines after : " + to_string(atlas_after))
    println("  Atlas delta       : " + to_string(atlas_after - atlas_before))
    println("")
    println("  Tier breakdown:")
    println("    UNIVERSAL (5/5) : " + to_string(n_universal))
    println("    STRONG    (4/5) : " + to_string(n_strong))
    println("    GAUGE_INV (3/5) : " + to_string(n_gauge))
    println("    PARTIAL   (2/5) : " + to_string(n_partial))
    println("    SINGULAR  (1/5) : " + to_string(n_singular))
    println("")
    if cross_validated > 0 {
        let pct = truncate4(to_float(cross_validated) / max_f(to_float(len(consensus)), 1.0) * 100.0)
        println("  Gauge-invariant rate: " + pct + "% (" + to_string(cross_validated) + "/" + to_string(len(consensus)) + ")")
    } else {
        println("  Gauge-invariant rate: 0% (no cross-validated discoveries)")
    }
    println("══════════════════════════════════════════════════════════════════════")
}

