}

// ═══════════════════════════════════════════════════════════
// ─── THEOREM + PROOF ───
// ═══════════════════════════════════════════════════════════

theorem cross_validation_gauge_invariance {
    // If k independent measurement frameworks each find constant c,
    // the probability of coincidence is P(false) = p^k where p = per-module false positive rate.
    // For k=3 and p=0.1: P < 0.001 (gauge-invariant threshold).
    // For k=5 and p=0.1: P < 0.00001 (universal consensus).
    // This is the statistical basis for cross-validation tiers.
    assert 5 * 8 == 40        // 5 modules * 8 phases = 40 independent measurements
    assert 6 * 2 == 12        // n * phi = sigma (n=6 identity)
    assert 12 - 6 - 2 + 1 == 5 // sigma - n - phi + 1 = 5 modules
}

proof consensus_convergence {
    // As the number of independent modules grows, consensus converges to truth.
    // Each module applies different mathematical operators to the same input.
    // Module-specific artifacts appear as SINGULAR (1/N agreement).
    // True discoveries converge to UNIVERSAL (N/N agreement).
    // This is the discovery-space analogue of the central limit theorem.
    invariant 3 <= 5          // minimum threshold (GAUGE_INV) <= total modules
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

fn main() {
    let cli_args = args()
    let argc = len(cli_args)

    // Parse CLI arguments
    let mut domain = ""
    let mut modules_filter = ""
    let mut timeout_sec: i64 = 180
    let mut verbose = false
    let mut show_help = false

    let mut ai: i64 = 2  // args()[0]=hexa, [1]=script
    while ai < argc {
        let arg = to_string(cli_args[ai])
        if arg == "help" || arg == "--help" || arg == "-h" {
            show_help = true
        } else { if arg == "--modules" {
            if ai + 1 < argc {
                ai = ai + 1
                modules_filter = to_string(cli_args[ai])
            }
        } else { if arg == "--timeout" {
            if ai + 1 < argc {
                ai = ai + 1
                let tv = safe_float(to_string(cli_args[ai]))
                if tv >= 10.0 && tv <= 600.0 { timeout_sec = to_int(tv) }
            }
        } else { if arg == "--verbose" || arg == "-v" {
            verbose = true
        } else {
            // First positional arg = domain
            if domain == "" { domain = arg }
        } } } }
        ai = ai + 1
    }

    if show_help {
        print_help()
        return
    }

    if domain == "" {
        println("error: domain required as first positional argument")
        println("usage: hexa cross_validate.hexa <domain> [--modules f,q,s] [--timeout 120] [--verbose]")
        println("       hexa cross_validate.hexa help")
        return
    }

    // ─── Resolve module filter ───
    let registry = module_registry()
    let mut active_modules = []
    let mut active_entries = []
    if modules_filter != "" {
        let filter_parts = modules_filter.split(",")
        let mut fi: i64 = 0
        while fi < len(filter_parts) {
            let f = to_string(filter_parts[fi]).trim()
            fi = fi + 1
            if f == "" { continue }
            // Match by short name or first letter
            let mut ri: i64 = 0
            while ri < len(registry) {
                let entry = to_string(registry[ri])
                let short = module_short(entry)
                if f == short || f == short[0..1] {
                    active_modules = active_modules + [short]
                    active_entries = active_entries + [entry]
                }
                ri = ri + 1
            }
        }
    } else {
        // All 5 modules
        let mut ri: i64 = 0
        while ri < len(registry) {
            let entry = to_string(registry[ri])
            active_modules = active_modules + [module_short(entry)]
            active_entries = active_entries + [entry]
            ri = ri + 1
        }
    }

    if len(active_modules) == 0 {
        println("error: no valid modules selected. Use: field, quantum, string, holographic, toe")
        return
    }

    // ─── Banner ───
    print_banner()
    println("  Domain  : " + domain)
    println("  Modules : " + to_string(len(active_modules)) + " (" + modules_filter + if modules_filter == "" { "all" } else { "" } + ")")
    println("  Timeout : " + to_string(timeout_sec) + "s per module")
    println("  n6 consts: " + to_string(_n6_count))
    println("  hexa    : " + _HEXA_BIN)
    println("  Time    : " + ts_now())

    // ─── Atlas snapshot (before) ───
    let atlas_before = atlas_snapshot()
    println("  Atlas   : " + to_string(atlas_before) + " lines")

    // ─── Run each module ───
    let mut all_discoveries = []
    let mut module_outputs = []
    let mut module_summaries = []

    let mut mi: i64 = 0
    while mi < len(active_entries) {
        let entry = to_string(active_entries[mi])
        let short = module_short(entry)
        let mod_file = module_file(entry)

        print_module_header(entry, mi)
        println("  Running " + mod_file + " on domain '" + domain + "'...")

        let output = run_module(mod_file, domain, timeout_sec)
        module_outputs = module_outputs + [output]

        // Check for errors
        if output.starts_with("ERROR:") {
            println("  [ERROR] " + output)
            module_summaries = module_summaries + ["0|0|0|true"]
            mi = mi + 1
            continue
        }

        // Parse summary stats
        let summary = parse_summary(output)
        module_summaries = module_summaries + [summary]
        let sp = summary.split("|")
        let exact_n = if len(sp) >= 1 { sp[0] } else { "0" }
        let near_n = if len(sp) >= 2 { sp[1] } else { "0" }
        let lines_n = if len(sp) >= 3 { sp[2] } else { "0" }
        println("  Result: EXACT=" + exact_n + " NEAR=" + near_n + " (" + lines_n + " output lines)")

        // Parse individual discoveries
        let disc = parse_discoveries(output, short)
        println("  Discoveries parsed: " + to_string(len(disc)))
        let mut di: i64 = 0
        while di < len(disc) {
            all_discoveries = all_discoveries + [disc[di]]
            di = di + 1
        }

        // Verbose: show raw output
        if verbose {
            println("")
            println("  --- raw output (first 40 lines) ---")
            let out_lines = output.split("\n")
            let mut li: i64 = 0
            let max_lines: i64 = if len(out_lines) < 40 { len(out_lines) } else { 40 }
            while li < max_lines {
                println("  | " + to_string(out_lines[li]))
                li = li + 1
            }
            if len(out_lines) > 40 {
                println("  | ... (" + to_string(len(out_lines) - 40) + " more lines)")
            }
            println("  --- end raw output ---")
        }

        mi = mi + 1
    }

    // ─── Build consensus ───
    let consensus = build_consensus(all_discoveries)
    println("")
    println("  Total discoveries across all modules: " + to_string(len(all_discoveries)))
    println("  Unique constants found: " + to_string(len(consensus)))

    // ─── Analyze divergence ───
    let divergences = analyze_divergence(all_discoveries, consensus, active_modules)

    // ─── Atlas snapshot (after) ───
    let atlas_after = atlas_snapshot()

    // ─── Print results ───
    print_consensus_table(consensus)
    print_divergence_table(divergences)
    print_summary(consensus, divergences, active_modules, atlas_before, atlas_after)

    // ─── Write report ───
    write_report(domain, module_outputs, module_summaries, consensus, divergences, active_modules, atlas_before, atlas_after)
    println("")
    println("  Report written: " + _REPORT_PATH)

    // ─── Log entry ───
    let log_line = ts_now() + " domain=" + domain + " modules=" + to_string(len(active_modules)) + " constants=" + to_string(len(consensus)) + " cross_validated=" + to_string(len(consensus)) + " divergences=" + to_string(len(divergences))
    try { append_file(_LOG_PATH, log_line + "\n") } catch e {}  // @allow-silent-catch

    println("")
    println("done.")
}

main()
