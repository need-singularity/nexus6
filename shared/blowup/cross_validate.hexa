    println("  " + pad("---", 20) + pad("---", 14) + pad("---", 14) + pad("---", 14) + pad("---", 14) + "---")
    println("  " + pad("Paradigm", 20) + pad("Field", 14) + pad("Quantum", 14) + pad("String", 14) + pad("Holographic", 14) + "ToE")
    println("  " + pad("Phases", 20) + pad("F1-F8", 14) + pad("Q1-Q8", 14) + pad("S1-S8", 14) + pad("H1-H8", 14) + "T1-T8")
    println("  " + pad("Key method", 20) + pad("Gauge filter", 14) + pad("Tunneling", 14) + pad("T-duality", 14) + pad("AdS/CFT", 14) + "Fixed point")
    println("  " + pad("Cross-domain", 20) + pad("Gauge inv.", 14) + pad("Entangle", 14) + pad("Brane coll.", 14) + pad("Bulk recon.", 14) + "Unification")
    println("  " + pad("Cascade", 20) + pad("Goldstone", 14) + pad("Ent. cascade", 14) + pad("Landscape", 14) + pad("Error corr.", 14) + "Meta-disc.")
    println("=======================================================================")
    println("")
    println("Output: cross_validate_report.json (machine-readable)")
