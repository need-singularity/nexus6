// shared/harness/app_build.hexa — type=app 프로젝트 공통 build+deploy 하네스
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
//
// 책임:
//   1. projects.json 에서 <name>.type == "app" 확인 (강제 gate)
//   2. root + app.{build_script, app_output, applications_dir, bundle_name} 읽기
//   3. cd <root> && <build_script> 실행
//   4. app_output 산출물 검증 (Info.plist + MacOS/ 존재)
//   5. codesign ad-hoc (필요 시)
//   6. /Applications/<bundle_name> 교체 (rm -rf + cp -R)
//   7. xattr -cr (quarantine 제거)
//
// 사용:
//   hexa run shared/harness/app_build.hexa <project_name>
//   hexa run shared/harness/app_build.hexa airgenome
//   hexa run shared/harness/app_build.hexa void
//
// 강제 원칙:
//   - type != "app" 이면 즉시 에러 (다른 프로젝트 경로는 이 하네스를 쓰지 말 것)
//   - build_script 실패 시 /Applications 절대 건드리지 않음
//   - 산출물 검증 실패 시 배포 중단

fn exec_cmd(cmd: str) -> str {
    return exec(cmd)  // @allow-bare-exec
}

fn jq_field(expr: str, path: str) -> str {
    return exec("jq -r '" + expr + " // \"\"' '" + path + "' 2>/dev/null").trim()  // @allow-bare-exec
}

fn check_file(path: str) -> bool {
    return exec("[ -f '" + path + "' ] && echo y || echo n").trim() == "y"  // @allow-bare-exec
}

fn check_dir(path: str) -> bool {
    return exec("[ -d '" + path + "' ] && echo y || echo n").trim() == "y"  // @allow-bare-exec
}

fn check_exec(path: str) -> bool {  // @allow-bare-exec
    return exec("[ -x '" + path + "' ] && echo y || echo n").trim() == "y"  // @allow-bare-exec
}

fn die(msg: str) -> void {
    println("❌ " + msg)
    panic(msg)
}

fn main() -> void {
    let a = args()
    if len(a) < 3 {
        println("usage: hexa run app_build.hexa <project_name>")
        panic("missing project name")
    }
    let name = a[2]
    let home = env_var("HOME")
    let projects_json = home + "/Dev/nexus/shared/config/projects.json"
    let dev_dir_raw = jq_field(".dev_dir // \"Dev\"", projects_json)
    // dev_dir 이 "~/Dev" 처럼 ~ 포함 가능 — 확장
    let dev = exec("eval echo '" + dev_dir_raw + "'").trim()  // @allow-bare-exec

    println("⬡ app_build harness — " + name)

    // 1. type gate
    let ptype = jq_field(".projects." + name + ".type", projects_json)
    if ptype != "app" {
        die("project '" + name + "' type is not 'app' (got: '" + ptype + "'). app_build 하네스는 type=app 만 허용.")
    }

    let root_rel = jq_field(".projects." + name + ".root", projects_json)
    if root_rel == "" { die("project '" + name + "' has no .root") }
    let root = dev + "/" + root_rel

    let bundle = jq_field(".projects." + name + ".app.bundle_name", projects_json)
    let build_script_rel = jq_field(".projects." + name + ".app.build_script", projects_json)
    let app_output_rel = jq_field(".projects." + name + ".app.app_output", projects_json)
    let apps_dir = jq_field(".projects." + name + ".app.applications_dir", projects_json)
    let launcher_name = jq_field(".projects." + name + ".app.launcher_name", projects_json)
    let cli_entry = jq_field(".projects." + name + ".app.cli_entry", projects_json)

    if bundle == "" { die(".app.bundle_name 없음") }
    if build_script_rel == "" { die(".app.build_script 없음") }
    if app_output_rel == "" { die(".app.app_output 없음") }
    if apps_dir == "" { die(".app.applications_dir 없음") }
    // 강제: launcher_name 필수 (실행 shim 이름). cli_entry 는 옵션 — 비면 GUI 전용 런처.
    // void 같은 터미널/GUI 전용 앱은 cli_entry = "" 허용. airgenome 등 CLI 병용은 경로 필수.
    if launcher_name == "" { die(".app.launcher_name 없음 — type=app 은 launcher 필수") }
    let cli_path = ""
    if cli_entry != "" {
        cli_path = root + "/" + cli_entry
        if !check_file(cli_path) {
            die("cli_entry 지정됐으나 파일 없음: " + cli_path)
        }
    }

    let build_script = root + "/" + build_script_rel
    let app_output = root + "/" + app_output_rel
    let dest = apps_dir + "/" + bundle

    println("  root:         " + root)
    println("  build_script: " + build_script)
    println("  app_output:   " + app_output)
    println("  dest:         " + dest)
    println("")

    // 2. build script 존재 + 실행권한
    if !check_exec(build_script) {  // @allow-bare-exec
        // .sh 가 아닐 수도 있음 — .hexa 면 hexa 로 실행
        if !check_file(build_script) {
            die("build_script 파일 없음: " + build_script)
        }
    }

    // 3. build 실행 (.sh → bash, .hexa → hexa run)
    let is_hexa = exec("echo '" + build_script + "' | grep -c '\\.hexa$'").trim() != "0"  // @allow-bare-exec
    let cmd = if is_hexa {
        "cd '" + root + "' && '" + home + "/Dev/hexa-lang/hexa' run '" + build_script + "' 2>&1"
    } else {
        "cd '" + root + "' && bash '" + build_script + "' 2>&1"
    }
    println("[1/3] building — " + build_script)
    let out = exec(cmd)  // @allow-bare-exec
    print(out)

    // 4. 산출물 검증
    if !check_dir(app_output) {
        die("build 성공했지만 app_output 없음: " + app_output)
    }
    if !check_file(app_output + "/Contents/Info.plist") {
        die(".app 구조 잘못 — Info.plist 없음")
    }
    if !check_dir(app_output + "/Contents/MacOS") {
        die(".app 구조 잘못 — MacOS/ 없음")
    }
    println("[2/3] artifact 검증 OK — " + app_output)

    // 5. /Applications 교체 (rm + cp -R + xattr clear)
    let _ = exec("rm -rf '" + dest + "'")  // @allow-bare-exec
    let _ = exec("cp -R '" + app_output + "' '" + dest + "'")  // @allow-bare-exec
    let _ = exec("xattr -cr '" + dest + "' 2>/dev/null || true")  // @allow-bare-exec

    if !check_dir(dest) {
        die("/Applications 배포 실패: " + dest)
    }
    println("[3/3] deployed — " + dest)

    // 6. launcher shim 설치 (~/.hx/bin/<name> 이 PATH 첫번째라 appname 으로 실행됨)
    // launcher_name 필수, cli_entry 있으면 GUI+CLI 이중 모드, 비면 GUI 전용.
    let launcher_dir = home + "/.hx/bin"
    let _ = exec("mkdir -p '" + launcher_dir + "'")  // @allow-bare-exec
    let launcher = launcher_dir + "/" + launcher_name
    let header = "#!/usr/bin/env bash\n# Auto-generated by app_build harness — nx install " + name + "\n# 수정 금지 — projects.json app.launcher_name/cli_entry 로만 제어\n\n"
    let body = ""
    if cli_entry == "" {
        // GUI 전용 — 인자 유무 무시하고 바로 open
        body = "# GUI-only launcher (projects.json cli_entry 빈 값)\nexec open '" + dest + "'\n"
    } else {
        let gui = "if [ \"$#\" -eq 0 ]; then\n    exec open '" + dest + "'\nfi\n"
        let cli = "# CLI mode — hexa run <root>/" + cli_entry + " $@\nHEXA=\"${HEXA:-}\"\nfor c in \"$HOME/Dev/hexa-lang/hexa\" \"$HOME/.hx/bin/hexa\"; do\n    [ -x \"$c\" ] && HEXA=\"$c\" && break\ndone\n[ -n \"$HEXA\" ] || { echo 'fatal: hexa interpreter 없음' >&2; exit 1; }\nexec \"$HEXA\" run '" + cli_path + "' \"$@\"\n"
        body = gui + cli
    }
    write_file(launcher, header + body)
    let _ = exec("chmod +x '" + launcher + "'")  // @allow-bare-exec
    println("[4/5] launcher — " + launcher)

    // 7. plist single-instance gate (강제 — type=app 한 개 실행 원칙)
    //    binary 직접 호출 plist 만 wrapper 로 변경, 그 외(jq/sh/hexa run)는 건드리지 않음
    let patcher = home + "/Dev/nexus/shared/harness/app_singleton_patch_plists.sh"
    let patch_out = exec("bash '" + patcher + "' '" + name + "' '" + dest + "' 2>&1")  // @allow-bare-exec
    println("[5/5] singleton-gate plists:")
    print(patch_out)

    println("")
    println("✅ " + name + " built + deployed")
    println("   /Applications: " + dest)
    if cli_entry == "" {
        println("   실행: " + launcher_name + "   (GUI 전용 — open .app)")
    } else {
        println("   실행: " + launcher_name + "             (GUI 기본 — open .app)")
        println("         " + launcher_name + " <sub...>   (CLI — " + cli_entry + ")")
    }
}

main()
