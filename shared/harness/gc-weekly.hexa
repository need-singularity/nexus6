// ═══════════════════════════════════════════════════════════
// gc-weekly.hexa — 하네스 L3 주간 GC 래퍼
// cooldown 7일 기반. growth-tick 또는 cron 에서 무조건 호출해도
// 7일 간격 유지 (hooks-config.json 등록은 별도 승인 필요)
// Usage (interpreter args() 미지원 — env var 경유):
//   hexa shared/harness/gc-weekly.hexa                              (쿨다운 판정 후 필요 시 실행)
//   HARNESS_GC_WEEKLY_MODE=force  hexa shared/harness/gc-weekly.hexa (쿨다운 무시)
//   HARNESS_GC_WEEKLY_MODE=status hexa shared/harness/gc-weekly.hexa (마지막 실행 / 남은 시간)
// 성공 조용, 실행 시에만 stdout 요약
// ═══════════════════════════════════════════════════════════

let REPO_ROOT = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
let SHARED_DIR = REPO_ROOT + "/shared"
let GC = SHARED_DIR + "/harness/gc.hexa"
let COOLDOWN = SHARED_DIR + "/harness/.gc_weekly_cooldown"
let WEEK_SEC: i64 = 604800

// void-safe coercion (interpreter quirk — type_of 는 "str" 반환)
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn now_sec() -> i64 {
    let mut r: i64 = 0
    try { r = to_int(exec("date +%s").trim()) } catch e {}
    return r
}

fn read_last() -> i64 {
    if !file_exists(COOLDOWN) { return 0 }
    let mut r: i64 = 0
    try { r = to_int(exec("cat '" + COOLDOWN + "' 2>/dev/null").trim()) } catch e {}
    return r
}

fn write_last(ts: i64) {
    try { exec("echo " + to_string(ts) + " > '" + COOLDOWN + "'") } catch e {}
}

// args() 미지원 — env var 로 모드 선택
let mode = _str(env("HARNESS_GC_WEEKLY_MODE")).trim()
let force = mode == "force"
let status_only = mode == "status"

let now = now_sec()
let last = read_last()
let age = if last > 0 { now - last } else { -1 }
let remaining = WEEK_SEC - age

if status_only {
    if last == 0 { println("never run") }
    else {
        println("last_run_ts: " + to_string(last))
        println("age_sec:     " + to_string(age))
        if age >= WEEK_SEC { println("status:      due (쿨다운 만료)") }
        else { println("status:      cooldown (남은 " + to_string(remaining) + "s)") }
    }
    exit(0)
}

if !force && last > 0 && age < WEEK_SEC {
    // 쿨다운 중 — 조용히 통과
    exit(0)
}

if !file_exists(GC) {
    // gc.hexa 없음 — 조용히 skip
    exit(0)
}

println("gc-weekly: running gc.hexa --scan")
let HEXA_RESOLVER = REPO_ROOT + "/shared/scripts/bin/hexa"
let out = exec("'" + HEXA_RESOLVER + "' '" + GC + "' --scan 2>&1")
println(out)
write_last(now)
exit(0)
