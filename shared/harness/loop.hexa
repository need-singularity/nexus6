// loop.hexa — NEXUS-6 공용 7프로젝트 루프 엔진
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
// 역할: cwd → project 자동 감지 → projects.json.loop 읽기 → roadmap 현 phase 분석
//       → TODO 소스 병합 → 3트랙 × tasks 계획 출력 → Claude 가 읽고 bg agent 발사
// SSOT: shared/config/projects.json (.projects.<p>.loop)
//       shared/roadmaps/<p>.json (신 스키마 3-track × phase × gate)
//       shared/roadmaps/SCHEMA.json (스키마 정의)
//
// usage:
//   hexa shared/harness/loop.hexa               — 현 프로젝트 풀사이클 계획 출력
//   hexa shared/harness/loop.hexa list          — 표1 L1~L8 + 표2 L7 훅 + 표3 roadmap 진행
//   hexa shared/harness/loop.hexa dry           — 계획만 (발사 없음, agent 테이블 프리뷰)
//   hexa shared/harness/loop.hexa all           — 7프로젝트 순회 계획
//   hexa shared/harness/loop.hexa only <phase>  — 특정 phase 만 (guard/todo/report 등)
//   hexa shared/harness/loop.hexa add <text>    — loop-rules.json 에 L5 규칙 추가
//
// 출력 규약 (Claude가 파싱):
//   ===LOOP_BEGIN===<project>:<subcmd>===
//   PHASE: <phase_id> <phase_name> status=<status>
//   TRACKS: <T1>,<T2>,<T3>
//   TODOS: <json_array_of_tasks>
//   GUARD: L1,L2,...,L8
//   HOOKS: <hook_id>=<engine_path>,...
//   COMMIT_PREFIX: <prefix>
//   BRANCH: <branch_policy>
//   ===LOOP_END===
// 이 블록 안의 정보로 Claude가 bg agent 발사 + guard 실행 + commit/push.

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let CONF = NEXUS + "/shared/config/projects.json"
let ROADMAPS = NEXUS + "/shared/roadmaps"
let SCHEMA = ROADMAPS + "/SCHEMA.json"
let HARNESS = NEXUS + "/shared/harness"

fn main() {
    let argv = args()
    let mut subcmd = "loop"
    let mut rest = []
    if argv.len() >= 3 { subcmd = argv[2] }
    let mut i = 3
    while i < argv.len() {
        rest.push(argv[i])
        i = i + 1
    }

    if subcmd == "all" {
        run_all()
        return
    }

    let project = detect_project()
    if project == "" {
        eprintln("REJECT: cwd 가 7프로젝트 디렉토리 안이 아닙니다 — 진입 불가")
        exit(2)
    }

    // projects.json loop section 존재 확인
    let loop_cfg = jq_read(CONF, ".projects.\"" + project + "\".loop // empty")
    if loop_cfg == "" {
        eprintln("REJECT: projects.json 에 " + project + ".loop 섹션 없음")
        exit(2)
    }

    let roadmap = ROADMAPS + "/" + project + ".json"
    if file_exists(roadmap) == false {
        eprintln("REJECT: roadmap " + roadmap + " 없음")
        exit(2)
    }

    if subcmd == "loop" || subcmd == "dry" {
        plan_and_print(project, loop_cfg, roadmap, subcmd == "dry")
    } else if subcmd == "list" {
        list_tables(project, loop_cfg, roadmap)
    } else if subcmd == "only" {
        if rest.len() == 0 {
            eprintln("REJECT: only 는 phase 인자 필요 (scan|todo|fanout|guard|commit|push|report)")
            exit(2)
        }
        plan_only(project, loop_cfg, roadmap, rest[0])
    } else if subcmd == "add" {
        add_rule(project, rest)
    } else {
        eprintln("REJECT: 알 수 없는 서브커맨드 '" + subcmd + "' — loop|list|all|dry|only|add")
        exit(2)
    }
}

fn detect_project() -> str {
    let cwd = to_string(exec("pwd 2>&1")).trim()  // @allow-bare-exec
    let bn = to_string(exec("basename " + cwd + " 2>&1")).trim()  // @allow-bare-exec
    // 7프로젝트 whitelist
    let whitelist = ["nexus", "anima", "n6-architecture", "hexa-lang", "airgenome", "papers", "void"]
    for p in whitelist {
        if bn == p { return p }
    }
    // 프로젝트 서브디렉토리일 수 있음 — git toplevel 로 재시도
    let top = to_string(exec("git -C " + cwd + " rev-parse --show-toplevel 2>/dev/null")).trim()  // @allow-bare-exec
    if top != "" {
        let topbn = to_string(exec("basename " + top + " 2>&1")).trim()  // @allow-bare-exec
        for p in whitelist {
            if topbn == p { return p }
        }
    }
    return ""
}

fn jq_read(file: str, query: str) -> str {
    let cmd = "jq -r '" + query + "' " + file + " 2>/dev/null"
    return to_string(exec(cmd)).trim()  // @allow-bare-exec
}

fn jq_read_json(file: str, query: str) -> str {
    // jq -c 로 compact JSON 출력
    let cmd = "jq -c '" + query + "' " + file + " 2>/dev/null"
    return to_string(exec(cmd)).trim()  // @allow-bare-exec
}

fn current_phase_id(roadmap: str) -> str {
    let pid = jq_read(roadmap, ".phases[] | select(.status==\"in_progress\") | .id" )
    if pid == "" {
        // in_progress 없으면 첫 planned
        return jq_read(roadmap, "[.phases[] | select(.status==\"planned\")][0].id // .phases[0].id")
    }
    return pid
}

fn plan_and_print(project: str, loop_cfg: str, roadmap: str, dry: bool) {
    let phase_id = current_phase_id(roadmap)
    let phase_name = jq_read(roadmap, ".phases[] | select(.id==\"" + phase_id + "\") | .name")
    let phase_status = jq_read(roadmap, ".phases[] | select(.id==\"" + phase_id + "\") | .status")
    let tracks = jq_read(roadmap, ".tracks | keys | join(\",\")" )
    let commit_prefix = jq_read(CONF, ".projects.\"" + project + "\".loop.commit_prefix")
    let branch = jq_read(CONF, ".projects.\"" + project + "\".loop.branch_policy")
    let g_layers = jq_read(CONF, ".projects.\"" + project + "\".loop.guard_layers | join(\",\")" )
    let hooks = jq_read_json(CONF, "[.projects.\"" + project + "\".loop.custom_hooks[] | {id, engine}]" )
    let todos = collect_todos(project, roadmap, phase_id)

    println("===LOOP_BEGIN===" + project + ":" + (if dry { "dry" } else { "loop" }) + "===")
    println("PROJECT: " + project)
    println("PHASE: " + phase_id + " " + phase_name + " status=" + phase_status)
    println("TRACKS: " + tracks)
    println("TODOS: " + todos)
    println("GUARD: " + g_layers)
    println("HOOKS: " + hooks)
    println("COMMIT_PREFIX: " + commit_prefix)
    println("BRANCH: " + branch)
    println("ROADMAP: " + roadmap)
    println("DRY: " + (if dry { "true" } else { "false" }))
    println("===LOOP_END===")
}

fn collect_todos(project: str, roadmap: str, phase_id: str) -> str {
    // roadmap 현 phase 의 parallel[].tasks 중 status != "done" 만
    let q = ".phases[] | select(.id==\"" + phase_id + "\") | .parallel[] | {track, tasks: [.tasks[] | select(.status!=\"done\") | {id, task, depends_on, ssot_ref, done_criteria, status}]}"
    let by_track = to_string(exec("jq -c '[" + q + "]' " + roadmap + " 2>/dev/null")).trim()  // @allow-bare-exec
    return by_track
}

fn list_tables(project: str, loop_cfg: str, roadmap: str) {
    let phase_id = current_phase_id(roadmap)
    let total_phases = jq_read(roadmap, ".phases | length")
    let done_phases = jq_read(roadmap, "[.phases[] | select(.status==\"done\")] | length")
    let tracks = jq_read(roadmap, ".tracks | keys | join(\",\")" )
    let g_val = jq_read(CONF, ".projects.\"" + project + "\".loop.guard_layers | join(\",\")" )
    let hooks = jq_read(CONF, "[.projects.\"" + project + "\".loop.custom_hooks[] | .id] | join(\",\")" )

    println("┌──────────────────────────────────────────────────────────────────┐")
    println("│  loop list — " + project)
    println("├──────────────────────────────────────────────────────────────────┤")
    println("│  Phase      " + phase_id + "  (" + done_phases + "/" + total_phases + " done)")
    println("│  Tracks     " + tracks)
    println("│  Guard      " + g_val)
    println("│  Hooks      " + hooks)
    println("└──────────────────────────────────────────────────────────────────┘")
}

fn plan_only(project: str, loop_cfg: str, roadmap: str, sub: str) {
    if sub == "guards" {
        // run guard only — 훅 호출
        run_guards(project)
    } else if sub == "todo" {
        let phase_id = current_phase_id(roadmap)
        let todos = collect_todos(project, roadmap, phase_id)
        println(todos)
    } else {
        println("only " + sub + " — 아직 구현 안됨 (미래 확장)")
    }
}

fn run_guards(project: str) {
    let g_script = HOME + "/Dev/" + project + "/.shared/hooks/loop-guard.hexa"
    if file_exists(g_script) == false {
        eprintln("WARN: " + g_script + " 없음 — L1~L6 건너뜀")
    } else {
        println("─── L1~L6 loop-guard ───")
        exec("hexa " + g_script)  // @allow-bare-exec
    }
    // L7 hooks
    let hooks_query = ".projects.\"" + project + "\".loop.custom_hooks[].engine"
    let hook_engines = to_string(exec("jq -r '" + hooks_query + "' " + CONF + " 2>/dev/null")).trim()  // @allow-bare-exec
    if hook_engines != "" {
        println("─── L7 project hooks ───")
        for h in hook_engines.split("\n") {
            let full = NEXUS + "/" + h.trim()
            if file_exists(full) {
                exec("hexa " + full)  // @allow-bare-exec
            } else {
                eprintln("WARN: L7 hook not yet implemented: " + full)
            }
        }
    }
    // L8 gate_exit 체크 (roadmap 현 phase 의 criteria 충족 여부)
    println("─── L8 gate_exit ───")
    let roadmap = ROADMAPS + "/" + project + ".json"
    let phase_id = current_phase_id(roadmap)
    let crit = to_string(exec("jq -r '.phases[] | select(.id==\"" + phase_id + "\") | .gate_exit.criteria | to_entries[] | \"  - \" + .value' " + roadmap + " 2>/dev/null"))  // @allow-bare-exec
    println("PHASE " + phase_id + " gate_exit criteria (수동 확인):")
    println(crit)
}

fn run_all() {
    let projects = ["nexus", "anima", "n6-architecture", "hexa-lang", "airgenome", "papers", "void"]
    println("┌──────────────────────────────────────────────────────────────┐")
    println("│  loop all — 7프로젝트 순회 계획                             │")
    println("└──────────────────────────────────────────────────────────────┘")
    for p in projects {
        println("")
        println("═══ " + p + " ═══")
        let cmd = "cd " + HOME + "/Dev/" + p + " && hexa " + HARNESS + "/loop.hexa dry"
        let out = to_string(exec(cmd))  // @allow-bare-exec
        println(out)
    }
}

fn add_rule(project: str, rest: [str]) {
    let rules = HOME + "/Dev/" + project + "/loop-rules.json"
    if file_exists(rules) == false {
        eprintln("REJECT: " + rules + " 없음 — 이 프로젝트는 L5 규칙 미운영 (airgenome/papers/void)")
        exit(2)
    }
    if rest.len() == 0 {
        eprintln("REJECT: 추가할 규칙 텍스트 필요 (예: 'loop add 렌즈 수 README')")
        exit(2)
    }
    let mut text = rest[0]
    let mut i = 1
    while i < rest.len() {
        text = text + " " + rest[i]
        i = i + 1
    }
    println("TODO(add_rule): " + text + " — " + rules + " 에 추가 (loop-rules 스키마 기반 파싱 필요)")
}
