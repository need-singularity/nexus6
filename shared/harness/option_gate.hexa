// option_gate.hexa — 옵션 자동 선택 게이트 (argv 모드, 훅 없음)
// @allow-bare-exec
// @no-sandbox
//
// 역할
//   직전 어시스턴트가 A/B/C 또는 1/2/3 옵션을 제시한 상태에서
//   사용자가 "go" / "keep" / 단일 알파벳·숫자 / "첫번째" 등을 입력하면
//   option_ranker.py 를 실행해 점수가 가장 높은 옵션을 선택해
//   <user-prompt-submit-hook> 블록으로 stdout 에 출력한다.
//
//   훅이 아니라 cmd_gate.hexa / entry.hexa 같은 하네스 디스패처가
//   직접 호출하는 모듈. 옵션이 없거나 트리거 아님 → silent pass(빈 출력, exit 0).
//
// 호출
//   hexa run shared/harness/option_gate.hexa <prompt> [transcript_path]
//
//   transcript_path 가 비어있으면 ~/.claude/projects/<sanitized-cwd>/ 에서
//   가장 최근 .jsonl 파일을 자동 탐색.
//
// 출력
//   stdout = 컨텍스트 주입 블록 또는 빈 출력
//   exit 0 = 항상 (게이트는 절대 차단하지 않음 — H1 원칙)

let HOME = env("HOME")
let WORKER = HOME + "/Dev/nexus/shared/harness/option_ranker.py"

// ─── 트리거 후보 빠른 거름망 (python 호출 비용 회피) ───
fn maybe_trigger(p: str) -> bool {
    let t = p.trim().to_lower()
    if t.len() == 0 { return false }
    if t.len() > 40 { return false }

    let go_words = [
        "go", "가자", "ㄱㄱ",
        "keep", "keep going", "keep going no talking"
    ]
    for g in go_words {
        if t == g { return true }
    }

    if t.len() == 1 {
        let letters = ["a", "b", "c", "d", "e"]
        for l in letters {
            if t == l { return true }
        }
        let nums = ["1", "2", "3", "4", "5"]
        for n in nums {
            if t == n { return true }
        }
    }

    let kr = ["첫번째", "첫 번째", "두번째", "두 번째", "세번째", "세 번째", "네번째", "다섯번째", "일번", "이번", "삼번"]
    for k in kr {
        if t == k { return true }
    }

    if t.starts_with("option ") { return true }
    if t.len() <= 6 && t.contains("로 가자") { return true }
    if t.len() <= 4 && t.contains("번") { return true }

    return false
}

fn shell_quote(s: str) -> str {
    let escaped = s.replace("'", "'\\''")
    return "'" + escaped + "'"
}

// ─── cwd → <claude_config_dir>/projects/<sanitized> 디렉토리 변환 ───
//   <cwd> 의 "/" 를 "-" 로 치환 → sanitized 폴더명
//   CLAUDE_CONFIG_DIR (cl 활성 계정) 우선, 없으면 ~/.claude
fn claude_config_root() -> str {
    let env_dir = env("CLAUDE_CONFIG_DIR")
    if env_dir.len() > 0 { return env_dir }
    return HOME + "/.claude"
}

fn sanitized_cwd(cwd: str) -> str {
    let mut s = cwd
    s = s.replace("/", "-")
    return s
}

// ─── 가장 최근 transcript .jsonl 자동 탐색 ───
//   CLAUDE_CONFIG_DIR 활성 계정 + ~/.claude 양쪽 다 검색해서 mtime 최신 1개
fn auto_discover_transcript() -> str {
    let cwd = to_string(exec("pwd")).trim()  // @allow-bare-exec
    if cwd.len() == 0 { return "" }
    let sanitized = sanitized_cwd(cwd)

    // 후보 디렉토리들의 *.jsonl 글로브를 합쳐서 ls -t 한 번에 — 활성 계정 + 기본 ~/.claude
    let active = claude_config_root() + "/projects/" + sanitized
    let default_root = HOME + "/.claude/projects/" + sanitized
    let mut globs = ""
    if file_exists(active) {
        globs = shell_quote(active + "/") + "*.jsonl"
    }
    if active != default_root && file_exists(default_root) {
        if globs.len() > 0 { globs = globs + " " }
        globs = globs + shell_quote(default_root + "/") + "*.jsonl"
    }
    if globs.len() == 0 { return "" }

    let cmd = "ls -t " + globs + " 2>/dev/null | head -n 1"
    let path = to_string(exec(cmd)).trim()  // @allow-bare-exec
    return path
}

fn main() {
    let argv = args()
    if argv.len() < 3 {
        eprintln("usage: option_gate.hexa <prompt> [transcript_path]")
        exit(2)
    }

    let prompt = argv[2].trim()
    if prompt.len() == 0 { exit(0) }

    if maybe_trigger(prompt) == false { exit(0) }

    let mut transcript = ""
    if argv.len() >= 4 { transcript = argv[3].trim() }
    if transcript.len() == 0 {
        transcript = auto_discover_transcript()
    }
    if transcript.len() == 0 { exit(0) }
    if file_exists(transcript) == false { exit(0) }
    if file_exists(WORKER) == false { exit(0) }

    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    // Original: GATE_LOCAL=1 python3 shared/harness/option_ranker.py <prompt> <transcript>
    // The option_ranker.py worker was deleted 2026-04-18 (direct policy violation).
    // H1 원칙: 게이트는 절대 차단하지 않음 → silent pass until hexa-native replacement.
    let _ = prompt
    let _ = transcript
    panic("R37/AN13/L3-PY: python3 invocation blocked at option_gate.hexa:131. option_ranker.py deleted 2026-04-18. Escalate to user for hexa-native replacement.")
}

main()
