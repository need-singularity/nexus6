// cmd_gate.hexa — smash/todo/go/keep/free/loop/roi/lm/list/roadmap 진입 검증 gate
// 역할: commands.json execution.bash 앞에 래핑되어 seed 품질 검증 수행.
//       통과 시 stdout "OK:<cmd>:<validated_seed>", 거부 시 stderr "REJECT: <reason>" + exit 2.
// 호출: hexa run shared/harness/cmd_gate.hexa <cmd> "<seed>" [--context "<hint>"]
// SSOT: shared/config/commands.json (키워드/엔진 경로)

fn main() {
    // args(): [0]=binary [1]=script [2..]=user args
    let argv = args()
    if argv.len() < 3 {
        eprintln("REJECT: usage — cmd_gate <cmd> \"<seed>\" [--context \"...\"]")
        exit(2)
    }

    let cmd = argv[2].trim().to_lower()
    let mut seed = ""
    if argv.len() >= 4 { seed = argv[3].trim() }

    let mut context_hint = ""
    let mut i = 4
    while i < argv.len() {
        if argv[i] == "--context" && i + 1 < argv.len() {
            context_hint = argv[i + 1]
            i = i + 2
        } else {
            i = i + 1
        }
    }

    // ─── 명령별 규칙 ───
    if cmd == "smash" || cmd == "돌파" || cmd == "blowup" {
        check_smash(seed, context_hint)
    } else if cmd == "free" || cmd == "free_dfs" || cmd == "dfs" {
        check_free(seed, context_hint)
    } else if cmd == "todo" || cmd == "go" || cmd == "keep" || cmd == "loop" || cmd == "list" || cmd == "roi" || cmd == "lm" || cmd == "roadmap" || cmd == "로드맵" {
        // seed 검증 불필요 — 엔진 자체가 컨텍스트 활용
        // roadmap: seed = 서브커맨드 (next|extend|auto|list|verify|status|all) + flags, 엔진 내부에서 파싱
        println("OK:" + cmd + ":" + seed)
    } else {
        eprintln("REJECT: unknown cmd '" + cmd + "' — SSOT: shared/config/commands.json")
        exit(2)
    }
}

fn check_smash(seed: str, ctx: str) {
    // 1. 빈 seed — 컨텍스트 힌트 없으면 거부
    if seed.len() == 0 {
        if ctx.len() == 0 {
            eprintln("REJECT: smash seed 비어있음 — 현재 작업 맥락을 --context 로 전달하거나 구체 시드 제공 필요")
            eprintln("HINT: '검토 smash' 'P=NP smash' 같은 형태. 단독 'smash' 는 직전 대화 맥락을 seed로 합성해야 함")
            exit(2)
        }
        // context_hint 있으면 OK — Claude가 맥락 합성한 것
        println("OK:smash:" + ctx)
        return
    }

    // 2. 너무 짧음 (1자)
    if seed.len() < 2 {
        eprintln("REJECT: smash seed 너무 짧음 ('" + seed + "' 1자) — 최소 2자 이상 구체 시드")
        exit(2)
    }

    // 3. 추상 단독 토큰 차단 — 문맥 유실 주요 원인
    let abstract_blacklist = [
        "아이디어", "계획", "생각", "돌파", "개념", "방법", "뭐", "뭘", "어떻게",
        "idea", "plan", "concept", "thought", "thinking", "method",
        "stuff", "something", "thing", "it", "that"
    ]
    let seed_lower = seed.to_lower()
    for bad in abstract_blacklist {
        if seed_lower == bad {
            eprintln("REJECT: smash seed '" + seed + "' 는 추상 단독 토큰 — 구체화 또는 컨텍스트 결합 필요")
            eprintln("HINT: 현재 대화 맥락의 실체(파일명/개념명/문제)와 결합. 예: '아이디어' → 'hexa-lang split 버그 아이디어'")
            exit(2)
        }
    }

    // 4. 토큰 수 체크 — 단일 추상 토큰만 있고 ctx 없으면 경고
    let tokens = seed.split(" ")
    let mut non_blacklist_tokens = 0
    for t in tokens {
        let tl = t.trim().to_lower()
        if tl.len() == 0 { continue }
        let mut is_abstract = false
        for bad in abstract_blacklist {
            if tl == bad { is_abstract = true; break }
        }
        if is_abstract == false { non_blacklist_tokens = non_blacklist_tokens + 1 }
    }
    if non_blacklist_tokens == 0 && ctx.len() == 0 {
        eprintln("REJECT: smash seed '" + seed + "' 는 모두 추상 토큰 — 컨텍스트 결합 필요")
        exit(2)
    }

    // 5. 너무 장황 (200자+)
    if seed.len() > 200 {
        eprintln("REJECT: smash seed 과장 (" + to_string(seed.len()) + "자) — 핵심 키워드 추출 필요, 200자 이내")
        exit(2)
    }

    // 통과
    println("OK:smash:" + seed)
}

fn check_free(seed: str, ctx: str) {
    // free_dfs — 도메인 시드. 없거나 짧으면 warn 후 pass (엔진이 기본 도메인 사용)
    if seed.len() == 0 {
        if ctx.len() > 0 {
            println("OK:free_dfs:" + ctx)
            return
        }
        eprintln("WARN: free_dfs seed 비어있음 — 현재 프로젝트 컨텍스트 사용")
        println("OK:free_dfs:")
        return
    }

    if seed.len() > 300 {
        eprintln("REJECT: free_dfs seed 과장 (" + to_string(seed.len()) + "자) — 도메인/개념 짧게")
        exit(2)
    }

    println("OK:free_dfs:" + seed)
}

main()
