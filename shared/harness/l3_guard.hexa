// l3_guard.hexa — L3 meta-lockdown 가드 (LOCK-P8-1, 2026-04-16)
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
//
// 역할: rules/* 및 lockdown.json/enforcement_registry.json 자체 편집을 잠그는
//       메타-잠금 레이어. L0/L1/L2 가 "코드/로직/자유" 보호라면 L3 는
//       "룰 잠금 체계 자체의 잠금" — 즉 메타-메타.
//
// usage:
//   hexa l3_guard.hexa watch <file_path>          path → L3 여부 판정 → BLOCK|ALLOW
//   hexa l3_guard.hexa verify                     protected_paths 존재 + lockdown.json L3 블록 검증
//   hexa l3_guard.hexa unlock <signer> <reason>   현재 쉘 세션 해제 문자열 출력 (eval 용)
//   hexa l3_guard.hexa status                     현재 sentinel/해제 상태 요약
//   hexa l3_guard.hexa log [N]                    l3_unlock.jsonl tail
//
// 해제 절차:
//   NEXUS_L3_UNLOCK=<signer>:<reason> prefix — signer/reason 모두 비어있지 않아야 하고
//   reason 길이는 최소 8자. 형식 오류 시 잠금 유지 + stderr 경고.
//
// 감사 로그:
//   shared/logs/l3_unlock.jsonl — 해제 시도마다 {ts, path, signer, reason, tool, result} 기록.
//
// 원칙:
//   - hexa-lang only
//   - L0/L1/L2 기존 lockdown_gate.hexa 동작에는 관여하지 않음 (직교 레이어)
//   - exit() 미전파 대비, 결과는 stdout 마지막 라인 sentinel 로 표기
//     (BLOCK: ... / ALLOW: ... / UNLOCK_OK: ... / UNLOCK_REJECT: ...)

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let LOCKDOWN = NEXUS + "/shared/lockdown/lockdown.json"
let AUDIT_LOG = NEXUS + "/shared/logs/l3_unlock.jsonl"

// L3 protected paths SSOT — lockdown.json 의 levels.L3.protected_paths 미러.
// 편집 시 lockdown.json 과 동기화.
let L3_PROTECTED = [
    "shared/rules/",
    "shared/config/permissions_ssot.json",
    "shared/lockdown/lockdown.json",
    "shared/harness/enforcement_registry.json"
]

// ─── helpers ────────────────────────────────────────────────────────

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn sh(cmd: string) -> string {
    return _str(exec(cmd)).trim()  // @allow-bare-exec
}

fn iso_now() -> string {
    return sh("date -u +%Y-%m-%dT%H:%M:%SZ")
}

fn file_is(path: string) -> bool {
    let r = sh("test -f '" + path + "' && echo y || echo n")
    if r == "y" { return true }
    return false
}

fn dir_is(path: string) -> bool {
    let r = sh("test -d '" + path + "' && echo y || echo n")
    if r == "y" { return true }
    return false
}

// 경로가 L3 protected 집합에 해당하는지 판정.
// 규칙:
//   - protected_paths 원소가 "/" 로 끝나면 prefix 매칭
//   - 그 외에는 suffix 매칭 (path 끝이 원소로 끝나는지)
//   - 절대경로/상대경로 혼용 지원 — path 를 정규화 후 비교.
fn is_l3_protected(file_path: string) -> bool {
    if file_path.len() == 0 { return false }
    // 절대경로 → NEXUS 하위 상대 조각으로 축소 시도
    let mut rel = file_path
    if rel.starts_with(NEXUS + "/") {
        rel = rel.substr(NEXUS.len() + 1, rel.len())
    }
    for p in L3_PROTECTED {
        if p.ends_with("/") {
            // prefix 매칭 — 절대/상대 양쪽 허용
            if rel.starts_with(p) { return true }
            if file_path.contains("/" + p) { return true }
        } else {
            // suffix 매칭
            if rel == p { return true }
            if file_path.ends_with("/" + p) { return true }
        }
    }
    return false
}

// NEXUS_L3_UNLOCK sentinel 파싱. 형식: "<signer>:<reason>"
// 반환: ["", ""] 미설정/형식오류, ["signer", "reason"] 유효.
fn parse_unlock() -> [string] {
    let raw = env("NEXUS_L3_UNLOCK")
    if raw == "" { return ["", ""] }
    let idx = raw.index_of(":")
    if idx <= 0 { return ["", ""] }
    let signer = raw.substr(0, idx).trim()
    let reason = raw.substr(idx + 1, raw.len()).trim()
    if signer.len() == 0 { return ["", ""] }
    if reason.len() < 8 { return ["", ""] }
    return [signer, reason]
}

// 감사 로그 한 줄 append. JSON-like 단일 라인.
fn audit_append(path: string, signer: string, reason: string, tool: string, result: string) {
    // ensure parent dir
    let logdir = NEXUS + "/shared/logs"
    if dir_is(logdir) == false {
        let _ = sh("mkdir -p '" + logdir + "'")
    }
    let ts = iso_now()
    let line = "{\"ts\":\"" + ts + "\",\"path\":\"" + path.replace("\"", "\\\"")
        + "\",\"signer\":\"" + signer.replace("\"", "\\\"")
        + "\",\"reason\":\"" + reason.replace("\"", "\\\"")
        + "\",\"tool\":\"" + tool.replace("\"", "\\\"")
        + "\",\"result\":\"" + result + "\"}"
    // quote 이스케이프 — heredoc 사용으로 shell expansion 회피
    let tmp = "/tmp/l3_audit." + sh("date +%s%N")
    let _ = sh("cat > " + tmp + " <<'L3_AUDIT_EOF'\n" + line + "\nL3_AUDIT_EOF")
    let _ = sh("cat " + tmp + " >> '" + AUDIT_LOG + "' && rm -f " + tmp)
}

// ─── modes ──────────────────────────────────────────────────────────

// watch <path> [tool] — 편집 대상 분류.
//   BLOCK: ... (잠금, 해제 sentinel 없거나 유효하지 않음)
//   ALLOW: ... (비-L3 경로, 또는 유효 sentinel)
// stdout 마지막 라인 sentinel 패턴.
fn mode_watch(rest: [string]) {
    if rest.len() == 0 {
        println("usage: l3_guard.hexa watch <file_path> [tool]")
        println("BLOCK: missing file_path")
        return
    }
    let file_path = rest[0]
    let mut tool = "Write"
    if rest.len() >= 2 { tool = rest[1] }
    if is_l3_protected(file_path) == false {
        println("ALLOW: " + file_path + " (non-L3)")
        return
    }
    let u = parse_unlock()
    let signer = u[0]
    let reason = u[1]
    if signer.len() == 0 || reason.len() == 0 {
        audit_append(file_path, "", "", tool, "BLOCK")
        eprintln("[L3-BLOCK] " + file_path + " — L3 meta-lockdown. 해제: NEXUS_L3_UNLOCK=<signer>:<reason(>=8chars)> prefix")
        println("BLOCK: " + file_path + " — L3 meta-lockdown (rules/lockdown). 해제 env: NEXUS_L3_UNLOCK=<signer>:<reason>")
        return
    }
    audit_append(file_path, signer, reason, tool, "ALLOW")
    println("ALLOW: " + file_path + " (L3 unlocked by " + signer + ": " + reason + ")")
}

// verify — lockdown.json 에 L3 블록이 존재하고 protected_paths 가 일치하는지 확인.
fn mode_verify() {
    let mut pass = 0
    let mut fail = 0
    if file_is(LOCKDOWN) == false {
        eprintln("[L3-VERIFY] FAIL lockdown.json missing: " + LOCKDOWN)
        println("VERIFY: FAIL (lockdown.json missing)")
        return
    }
    let has_l3 = sh("grep -c '\"L3\"' '" + LOCKDOWN + "'")
    if has_l3 == "0" || has_l3 == "" {
        eprintln("[L3-VERIFY] FAIL lockdown.json missing L3 block")
        println("VERIFY: FAIL (no L3 block)")
        return
    }
    pass = pass + 1
    for p in L3_PROTECTED {
        let exists = sh("grep -F -c '" + p + "' '" + LOCKDOWN + "'")
        if exists == "0" || exists == "" {
            fail = fail + 1
            eprintln("[L3-VERIFY] FAIL protected_path not in lockdown.json: " + p)
        } else {
            pass = pass + 1
        }
    }
    // protected_paths 가 실제 filesystem 에 존재하는지 확인
    for p in L3_PROTECTED {
        let full = NEXUS + "/" + p
        if p.ends_with("/") {
            if dir_is(full) == false {
                fail = fail + 1
                eprintln("[L3-VERIFY] FAIL dir missing: " + full)
            } else {
                pass = pass + 1
            }
        } else {
            if file_is(full) == false {
                fail = fail + 1
                eprintln("[L3-VERIFY] FAIL file missing: " + full)
            } else {
                pass = pass + 1
            }
        }
    }
    if fail == 0 {
        println("VERIFY: PASS (" + to_string(pass) + " checks)")
    } else {
        println("VERIFY: FAIL (" + to_string(pass) + " pass, " + to_string(fail) + " fail)")
    }
}

// unlock <signer> <reason> — 쉘에서 eval 하기 좋은 export 문자열 출력 (편의용).
// 실제 해제는 환경변수 prefix 방식만 유효 — 본 명령은 문자열 생성기에 불과.
fn mode_unlock(rest: [string]) {
    if rest.len() < 2 {
        println("usage: l3_guard.hexa unlock <signer> <reason(>=8chars)>")
        println("UNLOCK_REJECT: missing args")
        return
    }
    let signer = rest[0].trim()
    let reason = rest[1].trim()
    if signer.len() == 0 {
        eprintln("[L3-UNLOCK] signer empty")
        println("UNLOCK_REJECT: signer empty")
        return
    }
    if reason.len() < 8 {
        eprintln("[L3-UNLOCK] reason too short (>=8 chars required)")
        println("UNLOCK_REJECT: reason too short")
        return
    }
    let value = signer + ":" + reason
    audit_append("(session)", signer, reason, "unlock_cmd", "ISSUED")
    println("# paste to enable L3 edits this shell:")
    println("export NEXUS_L3_UNLOCK='" + value + "'")
    println("UNLOCK_OK: " + signer)
}

// status — 현재 sentinel 상태 + protected 개수.
fn mode_status() {
    let u = parse_unlock()
    let mut state = "LOCKED"
    if u[0].len() > 0 && u[1].len() > 0 { state = "UNLOCKED" }
    println("L3 state: " + state)
    println("protected paths: " + to_string(L3_PROTECTED.len()))
    for p in L3_PROTECTED {
        println("  - " + p)
    }
    if state == "UNLOCKED" {
        println("signer: " + u[0])
        println("reason: " + u[1])
    }
    let audit_exists = "no"
    if file_is(AUDIT_LOG) { audit_exists = "yes" }
    println("audit log: " + AUDIT_LOG + " (exists=" + audit_exists + ")")
}

// log [N] — l3_unlock.jsonl tail.
fn mode_log(rest: [string]) {
    let mut n = "20"
    if rest.len() >= 1 { n = rest[0] }
    if file_is(AUDIT_LOG) == false {
        println("(audit log empty: " + AUDIT_LOG + ")")
        return
    }
    let out = sh("tail -n " + n + " '" + AUDIT_LOG + "'")
    println(out)
}

// ─── dispatcher ─────────────────────────────────────────────────────

fn main() {
    let argv = args()
    if argv.len() < 3 {
        eprintln("usage: l3_guard.hexa <watch|verify|unlock|status|log> [args...]")
        return
    }
    let mode = argv[2]
    let mut rest = []
    let mut i = 3
    while i < argv.len() {
        rest = rest.push(argv[i])
        i = i + 1
    }
    if mode == "watch" {
        mode_watch(rest)
    } else if mode == "verify" {
        mode_verify()
    } else if mode == "unlock" {
        mode_unlock(rest)
    } else if mode == "status" {
        mode_status()
    } else if mode == "log" {
        mode_log(rest)
    } else {
        eprintln("REJECT: unknown mode '" + mode + "' — watch|verify|unlock|status|log")
    }
}

main()
