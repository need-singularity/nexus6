// ═══════════════════════════════════════════════════════════
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
// reaper.hexa — H-NOZOMBIE 자동 청소기 (L4)
// SIGKILL 안 듣는 좀비/defunct 누적 차단. blowup/agent_ledger 등 정상
// long-running 은 PROTECT 화이트리스트로 보호.
// usage:
//   hexa run reaper.hexa                 — status (기본)
//   hexa run reaper.hexa sweep           — TERM + ledger 기록
//   hexa run reaper.hexa kill_old        — TERM → 5s wait → KILL
//   hexa run reaper.hexa status          — 현재 활성 hexa 목록
//   hexa run reaper.hexa force <pid>     — 수동 한 개 KILL
// SSOT: shared/harness/reaper_log.jsonl (append ts/action/pid/base/age/host)
// env: NEXUS_REAP_AGE=<sec>  (default 180s)
// ═══════════════════════════════════════════════════════════

let HOME = env("HOME")
let REAPER_LOG = HOME + "/Dev/nexus/shared/harness/reaper_log.jsonl"
let DEFAULT_AGE: i64 = 180

// reapable: 단명 모듈 (보통 5초 안에 종료 기대)
let REAPABLE = ["lint", "gc", "autofix", "gc-weekly", "bitter-gate",
                "hook_stdin_gate", "global_claude_guard", "cli_budget_gate",
                "health", "errors", "sync", "git_fresh", "broadcast",
                "prompt_scan", "pre_tool_guard", "post_bash", "post_edit",
                "cmd_gate", "entry", "forecast", "label", "reaper"]

// protect: 정상 long-running
let PROTECT  = ["blowup", "agent_ledger", "session_worktree", "session_lock",
                "session_registry", "handoff_write", "session_prompt_gen"]

// ─── 기본 유틸 ───

// void-safe coercion — "".split() 첫 원소 void 반환 우회
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    return to_int(first)
}

// last_index_of 미지원 우회 — 역방향 스캔
fn _rfind(s: string, ch: string) -> i64 {
    let n = len(s)
    let mut i: i64 = n - 1
    while i >= 0 {
        if s.substring(i, i + 1) == ch { return i }
        i = i - 1
    }
    return -1
}

// 연속 공백 split (ps 출력 파싱용)
fn split_ws(s: string) -> [string] {
    let mut out: [string] = []
    let mut buf: string = ""
    let n = len(s)
    let mut i: i64 = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == " " || c == "\t" {
            if len(buf) > 0 { out = out.push(buf); buf = "" }
        } else {
            buf = buf + c
        }
        i = i + 1
    }
    if len(buf) > 0 { out = out.push(buf) }
    return out
}

// etime "[[dd-]hh:]mm:ss" → seconds
fn parse_etime(raw: string) -> i64 {
    let s = _str(raw).trim()
    if s == "" { return 0 }
    let mut days: i64 = 0
    let mut hours: i64 = 0
    let mut mins: i64 = 0
    let mut secs: i64 = 0
    let mut rest = s
    if rest.index_of("-") >= 0 {
        let dparts = rest.split("-")
        days = _to_int0(_str(dparts[0]))
        rest = _str(dparts[1])
    }
    let cs = rest.split(":")
    let cn = len(cs)
    if cn == 3 {
        hours = _to_int0(_str(cs[0]))
        mins  = _to_int0(_str(cs[1]))
        secs  = _to_int0(_str(cs[2]))
    } else if cn == 2 {
        mins  = _to_int0(_str(cs[0]))
        secs  = _to_int0(_str(cs[1]))
    } else {
        secs  = _to_int0(_str(cs[0]))
    }
    return days * 86400 + hours * 3600 + mins * 60 + secs
}

// basename: "/a/b/foo.hexa" → "foo"
fn hexa_basename(path: string) -> string {
    let slash = _rfind(path, "/")
    let mut b = path
    if slash >= 0 { b = path.substring(slash + 1, len(path)) }
    if b.ends_with(".hexa") {
        b = b.substring(0, len(b) - 5)
    }
    return b
}

// ─── 프로세스 수집 ───

// [[pid, age_sec_str, basename], ...]
fn list_hexa_procs() -> [[string]] {
    let raw = _str(exec("ps -axo pid,etime,command 2>/dev/null"))  // @allow-bare-exec
    let lines = raw.split("\n")
    let mut out: [[string]] = []
    // 자기 자신 pid (reaper 자기 제외)
    let self_pid = _str(exec("echo $$")).trim()  // @allow-bare-exec
    for l in lines {
        let trimmed = _str(l).trim()
        if trimmed == "" { continue }
        // hexa.real 또는 'hexa run' 이 있는 라인만
        let has_real = trimmed.index_of("hexa.real") >= 0
        let has_run  = trimmed.index_of("hexa run") >= 0
        if has_real == false && has_run == false { continue }
        // 자기 자신 제외 (reaper.hexa 또는 reaper sweep 문자열)
        if trimmed.index_of("reaper.hexa") >= 0 { continue }
        if trimmed.index_of("reaper sweep") >= 0 { continue }
        if trimmed.index_of("reaper kill_old") >= 0 { continue }
        // 헤더 라인 스킵 (PID ELAPSED COMMAND)
        if trimmed.starts_with("PID ") { continue }
        // grep/awk 잡음 제외
        if trimmed.index_of("grep ") >= 0 && trimmed.index_of("hexa") >= 0 && trimmed.index_of("/hexa") < 0 { continue }
        let parts = split_ws(trimmed)
        if len(parts) < 3 { continue }
        let pid = parts[0]
        if pid == self_pid { continue }
        let etime = parts[1]
        // basename 추출: .hexa 로 끝나는 첫 토큰
        let mut base: string = ""
        let mut i: i64 = 2
        let np = len(parts)
        while i < np {
            let p = parts[i]
            if p.ends_with(".hexa") {
                base = hexa_basename(p)
                break
            }
            i = i + 1
        }
        if base == "" { continue }
        let age_sec = parse_etime(etime)
        let row: [string] = [pid, to_string(age_sec), base]
        out = out.push(row)
    }
    return out
}

// ─── 분류 ───

fn is_protected(base: string) -> bool {
    for p in PROTECT { if base == p { return true } }
    return false
}

fn is_reapable(base: string) -> bool {
    if is_protected(base) { return false }
    for r in REAPABLE { if base == r { return true } }
    return false  // unknown → 보수적 보호
}

// ─── 로그 ───

fn shell_escape_single(s: string) -> string {
    return s.replace("'", "")
}

fn log_action(action: string, pid: string, base: string, age: i64) {
    let host = _str(exec("hostname -s 2>/dev/null")).trim()  // @allow-bare-exec
    let ts = _str(exec("date +%s")).trim()  // @allow-bare-exec
    let esc_action = shell_escape_single(action)
    let esc_pid    = shell_escape_single(pid)
    let esc_base   = shell_escape_single(base)
    let esc_host   = shell_escape_single(host)
    let line = "{\"ts\":" + ts +
               ",\"action\":\"" + esc_action +
               "\",\"pid\":\"" + esc_pid +
               "\",\"base\":\"" + esc_base +
               "\",\"age\":" + to_string(age) +
               ",\"host\":\"" + esc_host + "\"}"
    // printf 로 안전 append
    let cmd = "printf '%s\\n' '" + line + "' >> '" + REAPER_LOG + "' 2>/dev/null"
    exec(cmd)  // @allow-bare-exec
}

// ─── 명령어 ───

fn cmd_status() {
    let procs = list_hexa_procs()
    println("PID      AGE(s)  STATE       MODULE")
    let age_env = env("NEXUS_REAP_AGE")
    let mut age_thresh: i64 = DEFAULT_AGE
    if len(age_env) > 0 { age_thresh = _to_int0(age_env) }
    for p in procs {
        let pid = p[0]
        let age = p[1]
        let base = p[2]
        let mut state: string = "PROTECTED"
        if is_protected(base) {
            state = "PROTECTED"
        } else if is_reapable(base) {
            let age_int = _to_int0(age)
            if age_int > age_thresh { state = "REAPABLE" }
            else { state = "OK" }
        } else {
            state = "UNKNOWN"
        }
        println(pid + "  " + age + "  " + state + "  " + base)
    }
}

fn cmd_sweep(do_kill: bool) {
    let age_env = env("NEXUS_REAP_AGE")
    let mut age_thresh: i64 = DEFAULT_AGE
    if len(age_env) > 0 { age_thresh = _to_int0(age_env) }
    let procs = list_hexa_procs()
    let mut termed: i64 = 0
    let mut killed: i64 = 0
    for p in procs {
        let pid = p[0]
        let age_int = _to_int0(p[1])
        let base = p[2]
        if is_reapable(base) == false { continue }
        if age_int < age_thresh { continue }
        log_action("term", pid, base, age_int)
        exec("kill -TERM " + pid + " 2>/dev/null")  // @allow-bare-exec
        termed = termed + 1
        if do_kill {
            exec("sleep 5")  // @allow-bare-exec
            let alive = _str(exec("kill -0 " + pid + " 2>/dev/null && echo y || echo n")).trim()  // @allow-bare-exec
            if alive == "y" {
                log_action("kill", pid, base, age_int)
                exec("kill -KILL " + pid + " 2>/dev/null")  // @allow-bare-exec
                killed = killed + 1
            }
        }
    }
    if termed > 0 || killed > 0 {
        eprintln("[reaper] termed=" + to_string(termed) + " killed=" + to_string(killed))
    }
}

fn cmd_force(pid: string) {
    if pid == "" {
        eprintln("usage: reaper.hexa force <pid>")
        return
    }
    log_action("force", pid, "manual", 0)
    exec("kill -KILL " + pid + " 2>/dev/null")  // @allow-bare-exec
}

// ─── main ───

fn main() {
    let argv = args()
    // argv[0]=hexa_bin, argv[1]=script path, argv[2]=mode, argv[3]=arg1 ...
    let an = len(argv)
    let mut mode: string = ""
    if an >= 3 { mode = argv[2] }
    if mode == "" { cmd_status(); return }
    if mode == "sweep" { cmd_sweep(false); return }
    if mode == "kill_old" { cmd_sweep(true); return }
    if mode == "status" { cmd_status(); return }
    if mode == "force" {
        let mut pid: string = ""
        if an >= 4 { pid = argv[3] }
        cmd_force(pid)
        return
    }
    eprintln("usage: reaper.hexa <sweep|kill_old|status|force PID>")
}

main()
