// breakthrough.hexa — gap-triggered minimal-path sub-roadmap generator
//
// 사용:
//   hexa breakthrough.hexa generate <gap_id_or_slug>   단일 gap sub-roadmap 생성
//   hexa breakthrough.hexa auto                         최근 blocking gap 전부 자동
//   hexa breakthrough.hexa list                         생성된 breakthrough 목록 (+ N/M done)
//   hexa breakthrough.hexa status <slug>                task 완료율 + 남은 task (auto refresh)
//   hexa breakthrough.hexa refresh [slug|all]           task.status 재계산 + JSON 저장
//
// 입력 SSOT:
//   shared/harness/roadmap_gaps.jsonl  (Phase A 산출)
//
// 출력 SSOT:
//   shared/roadmaps/breakthroughs/{slug}.json
//
// slug 포맷:  {project}__{source_short}__{file_basename_noext}__{kind}
//   예:  anima__projects__anima_psi__STUB
//
// 최소 알고리즘: 각 gap kind × source 조합별 템플릿 task tree 적용
//   - seq   순차 단계 (depends_on 체인)
//   - parallel  독립 실행 가능 단계
// 각 task: id / task / order / depends_on / artifact / done_criteria / exec_hint

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let GAPS_PATH = NEXUS + "/shared/harness/roadmap_gaps.jsonl"
let BT_DIR = NEXUS + "/shared/roadmaps/breakthroughs"
let BLOWUP_EMERGENCE = NEXUS + "/shared/blowup/modules/blowup_emergence.hexa"

fn print_usage() {
    println("breakthrough — gap 돌파 sub-roadmap 생성기")
    println("")
    println("  generate <gap_id_or_slug>   단일 sub-roadmap 생성")
    println("  auto                         blocking gap 전부 일괄 생성")
    println("  list                         breakthrough 목록 + N/M done 카운터")
    println("  status <slug>                task 완료율 (auto refresh)")
    println("  refresh [slug|all]           task.status 재계산 + 저장")
    println("  help                         사용법")
    println("")
    println("입력:  " + GAPS_PATH)
    println("출력:  " + BT_DIR + "/{slug}.json")
}

let mut _py_seq: i64 = 0

fn run_py(script: str) -> str {
    _py_seq = _py_seq + 1
    let tmp = "/tmp/breakthrough_" + to_string(_py_seq) + ".py"
    let _ = write_file(tmp, script)
    // @allow-bare-interp — 절대경로 python3 (R22 허용)
    let out = to_string(exec("/usr/bin/python3 " + tmp + " 2>&1"))
    let _ = exec("rm -f " + tmp)
    return out
}

// ─── 템플릿 JSON 헬퍼 (python 쪽) ──────────────────────────────
// 템플릿은 python 쪽에서 full JSON 조립. hexa 는 dispatch + 파일 I/O 만 담당.

fn generate_script(target: str) -> str {
    return "import json, os, re, hashlib, sys\n" +
        "from datetime import datetime, timezone\n" +
        "target = " + "\"" + target + "\"\n" +
        "GAPS = '" + GAPS_PATH + "'\n" +
        "BT_DIR = '" + BT_DIR + "'\n" +
        "BLOWUP = '" + BLOWUP_EMERGENCE + "'\n" +
        "NEXUS = '" + NEXUS + "'\n" +
        "\n" +
        "def mk_slug(g):\n" +
        "    base = os.path.basename(g.get('file','')).rsplit('.',1)[0]\n" +
        "    src = g.get('source','?').split('.')[0]\n" +
        "    return f\"{g['project']}__{src}__{base}__{g['kind']}\"\n" +
        "\n" +
        "def load_gaps():\n" +
        "    if not os.path.exists(GAPS): return []\n" +
        "    # dedup by (project, source, key, file, kind) — keep latest ts\n" +
        "    seen = {}\n" +
        "    for ln in open(GAPS, 'r', encoding='utf-8'):\n" +
        "        ln = ln.strip()\n" +
        "        if not ln: continue\n" +
        "        try: g = json.loads(ln)\n" +
        "        except: continue\n" +
        "        key = (g.get('project'), g.get('source'), g.get('key'), g.get('file'), g.get('kind'))\n" +
        "        seen[key] = g\n" +
        "    return list(seen.values())\n" +
        "\n" +
        "# ── 템플릿 매트릭스 ─────────────────────────────────────\n" +
        "# 각 템플릿 함수는 gap dict 를 받아 task list 반환\n" +
        "# task: {id, task, order: seq|parallel, depends_on, artifact, done_criteria, exec_hint}\n" +
        "\n" +
        "def tpl_loop_stub(g):\n" +
        "    \"\"\"loop hook 이 stub — baseline 측정 → 실구현 → ratchet commit\"\"\"\n" +
        "    art = g['file']\n" +
        "    hook_name = os.path.basename(art).rsplit('.',1)[0]\n" +
        "    return [\n" +
        "        {'id':'T1','order':'seq','depends_on':[],\n" +
        "         'task': f\"{hook_name} 관련 baseline evidence 생성 (JSON history / log 등)\",\n" +
        "         'artifact':'',\n" +
        "         'done_criteria':'baseline artifact 존재 + ≥1 entry — hook 비교 대상 확보',\n" +
        "         'exec_hint':'프로젝트별 baseline 스크립트 실행 (예: python3 anima-measurement/phi_auto_pipeline.hexa --measure <ckpt>)'},\n" +
        "        {'id':'T2','order':'seq','depends_on':['T1'],\n" +
        "         'task': f\"{art} 실구현 — baseline 로드 + 임계 검증(ratchet) + 결과 로그\",\n" +
        "         'artifact': art,\n" +
        "         'done_criteria':\"roadmap_guard gap --project \" + g['project'] + \" 재실행 시 해당 STUB 사라짐\",\n" +
        "         'exec_hint':'stub println 제거 + fn main() 본문: read baseline / compare / log-or-REJECT'},\n" +
        "        {'id':'T3','order':'seq','depends_on':['T2'],\n" +
        "         'task':'커밋 — (harness:) prefix 로 HARNESS-LOCK 통과',\n" +
        "         'artifact':'',\n" +
        "         'done_criteria':'git log HEAD 최근 커밋이 해당 파일 포함 + 프리픽스 통과',\n" +
        "         'exec_hint':'git add <file> && git commit -m \"(harness): ...\"'},\n" +
        "    ]\n" +
        "\n" +
        "def tpl_loop_missing(g):\n" +
        "    \"\"\"loop hook 파일 자체가 없음 — scaffold → impl → commit\"\"\"\n" +
        "    return [\n" +
        "        {'id':'T1','order':'seq','depends_on':[],\n" +
        "         'task': f\"sibling hook 패턴 조사 — shared/harness/loop_hooks/ 내 유사 구현 1개 참고 선정\",\n" +
        "         'artifact':'',\n" +
        "         'done_criteria':'참조 hook 경로 확정 (e.g., airgenome_v2.hexa, hx_fixpoint.hexa)',\n" +
        "         'exec_hint':'ls shared/harness/loop_hooks/ + diff 관점 가장 근접 케이스 1개 선정'},\n" +
        "        {'id':'T2','order':'seq','depends_on':['T1'],\n" +
        "         'task': f\"{g['file']} scaffold 작성 — sibling 구조 재사용\",\n" +
        "         'artifact': g['file'],\n" +
        "         'done_criteria':'파일 존재 + fn main() 실행 가능 (minimal)',\n" +
        "         'exec_hint':'cp sibling → 모듈명/로직 교체 → println + real op'},\n" +
        "        {'id':'T3','order':'seq','depends_on':['T2'],\n" +
        "         'task':'도메인 로직 실구현 — 해당 hook 이 책임지는 단일 측정/검증 1개만 완성',\n" +
        "         'artifact': g['file'],\n" +
        "         'done_criteria':'해당 loop phase 1회 호출 성공 + 로그 출력',\n" +
        "         'exec_hint':'hexa shared/harness/loop_hooks/{file} 직접 실행 smoke'},\n" +
        "        {'id':'T4','order':'seq','depends_on':['T3'],\n" +
        "         'task':'커밋 (harness:) prefix',\n" +
        "         'artifact':'',\n" +
        "         'done_criteria':'git log HEAD ↔ 파일 포함',\n" +
        "         'exec_hint':'git add + commit'},\n" +
        "    ]\n" +
        "\n" +
        "def tpl_roadmap_stub(g):\n" +
        "    \"\"\"로드맵 task.artifact 가 stub — done_criteria 평가 가능하게 실구현\"\"\"\n" +
        "    return [\n" +
        "        {'id':'T1','order':'seq','depends_on':[],\n" +
        "         'task': f\"{g['key']} done_criteria 재확인 — 평가 artifact 및 임계 확정\",\n" +
        "         'artifact':'',\n" +
        "         'done_criteria':'done_criteria 에서 측정 대상 + 숫자 기준 추출됨 (planning note)',\n" +
        "         'exec_hint':'shared/roadmaps/{project}.json 에서 해당 task 블록 열람'},\n" +
        "        {'id':'T2','order':'parallel','depends_on':['T1'],\n" +
        "         'task': f\"{g['file']} stub 제거 + 실구현 skeleton\",\n" +
        "         'artifact': g['file'],\n" +
        "         'done_criteria':'roadmap_guard gap 재실행 시 해당 STUB 사라짐',\n" +
        "         'exec_hint':'stub marker 제거 + 최소 기능 1개 구현'},\n" +
        "        {'id':'T3','order':'seq','depends_on':['T2'],\n" +
        "         'task':'done_criteria 측정 1회 실행',\n" +
        "         'artifact':'',\n" +
        "         'done_criteria':'측정 결과가 임계 충족',\n" +
        "         'exec_hint':'implementation 의 CLI 1회 + 결과 저장'},\n" +
        "        {'id':'T4','order':'seq','depends_on':['T3'],\n" +
        "         'task':'로드맵 task.status 업데이트 (todo → in_progress 또는 done)',\n" +
        "         'artifact':'',\n" +
        "         'done_criteria':'shared/roadmaps/{project}.json 해당 task.status 갱신',\n" +
        "         'exec_hint':'에디터로 status 필드 편집'},\n" +
        "    ]\n" +
        "\n" +
        "def tpl_roadmap_missing(g):\n" +
        "    \"\"\"로드맵 task.artifact 파일 없음 — scaffold → impl → measure → status\"\"\"\n" +
        "    return [\n" +
        "        {'id':'T1','order':'seq','depends_on':[],\n" +
        "         'task': f\"{g['file']} 디렉토리 + skeleton 파일 생성\",\n" +
        "         'artifact': g['file'],\n" +
        "         'done_criteria':'파일 존재 + fn main() 또는 기본 entry 있음',\n" +
        "         'exec_hint':'mkdir -p + cat > file with template'},\n" +
        "        {'id':'T2','order':'parallel','depends_on':['T1'],\n" +
        "         'task':'실구현 — 최소 기능 1개',\n" +
        "         'artifact': g['file'],\n" +
        "         'done_criteria':'hexa run <file> 시 에러 없음 + 의미있는 출력',\n" +
        "         'exec_hint':'도메인 로직 구현 + smoke test'},\n" +
        "        {'id':'T3','order':'seq','depends_on':['T2'],\n" +
        "         'task':'done_criteria 측정 1회',\n" +
        "         'artifact':'',\n" +
        "         'done_criteria':'측정값 임계 충족',\n" +
        "         'exec_hint':'구현 CLI 1회 실행'},\n" +
        "        {'id':'T4','order':'seq','depends_on':['T3'],\n" +
        "         'task':'커밋',\n" +
        "         'artifact':'',\n" +
        "         'done_criteria':'git log 반영',\n" +
        "         'exec_hint':'git add + commit'},\n" +
        "    ]\n" +
        "\n" +
        "def select_template(g):\n" +
        "    src = g.get('source','')\n" +
        "    kind = g.get('kind','')\n" +
        "    if src in ('projects.json','loop.json'):\n" +
        "        if kind == 'STUB': return 'loop_stub', tpl_loop_stub(g)\n" +
        "        if kind == 'MISSING': return 'loop_missing', tpl_loop_missing(g)\n" +
        "    if src == 'roadmap':\n" +
        "        if kind == 'STUB': return 'roadmap_stub', tpl_roadmap_stub(g)\n" +
        "        if kind == 'MISSING': return 'roadmap_missing', tpl_roadmap_missing(g)\n" +
        "    # fallback — generic 3-step\n" +
        "    return 'generic', [\n" +
        "        {'id':'T1','order':'seq','depends_on':[],'task':'진단 — gap 원인 확정','artifact':'','done_criteria':'원인 문서화','exec_hint':'읽고 분석'},\n" +
        "        {'id':'T2','order':'seq','depends_on':['T1'],'task':'수정','artifact':g.get('file',''),'done_criteria':'gap 사라짐','exec_hint':'구현'},\n" +
        "        {'id':'T3','order':'seq','depends_on':['T2'],'task':'검증','artifact':'','done_criteria':'roadmap_guard gap clean','exec_hint':'재스캔'},\n" +
        "    ]\n" +
        "\n" +
        "def emergence_seed(g):\n" +
        "    \"\"\"blowup_emergence 호출 — gap 해시 기반 seed. 창발 메타 JSON 반환 (없으면 빈 dict).\"\"\"\n" +
        "    if not os.path.exists(BLOWUP): return {}\n" +
        "    key = (g.get('project','') + g.get('source','') + g.get('file','') + g.get('kind','')).encode()\n" +
        "    h = int(hashlib.md5(key).hexdigest()[:6], 16)\n" +
        "    seed = (h % 100) / 10.0 + 1.0\n" +
        "    # emergence 모듈은 $HEXA shared/.../blowup_emergence.hexa <seed>\n" +
        "    hx = os.environ.get('HEXA_LANG', os.environ.get('HOME','') + '/Dev/hexa-lang') + '/hexa'\n" +
        "    if not os.path.exists(hx):\n" +
        "        return {'seed': seed, 'note':'hexa binary not found, seed only'}\n" +
        "    import subprocess\n" +
        "    try:\n" +
        "        r = subprocess.run([hx, BLOWUP, str(seed)], capture_output=True, text=True, timeout=10)\n" +
        "        out = (r.stdout or '').strip().splitlines()\n" +
        "        # 마지막 JSON 라인 파싱\n" +
        "        for ln in reversed(out):\n" +
        "            ln = ln.strip()\n" +
        "            if ln.startswith('{') and ln.endswith('}'):\n" +
        "                try: return json.loads(ln)\n" +
        "                except: pass\n" +
        "        return {'seed': seed, 'note':'no json emitted'}\n" +
        "    except Exception as e:\n" +
        "        return {'seed': seed, 'note': f'invoke fail: {e}'}\n" +
        "\n" +
        "def build_breakthrough(g):\n" +
        "    slug = mk_slug(g)\n" +
        "    tpl_name, tasks = select_template(g)\n" +
        "    # 기본 status 'todo' 부여 — refresh 가 나중에 derived status 로 갱신\n" +
        "    for t in tasks:\n" +
        "        if 'status' not in t: t['status'] = 'todo'\n" +
        "    emergence = emergence_seed(g)\n" +
        "    # critical path = depends_on 체인 최장\n" +
        "    def path_len(tid, memo={}):\n" +
        "        if tid in memo: return memo[tid]\n" +
        "        t = next((x for x in tasks if x['id']==tid), None)\n" +
        "        if not t: return 0\n" +
        "        deps = t.get('depends_on', [])\n" +
        "        if not deps:\n" +
        "            memo[tid] = 1; return 1\n" +
        "        memo[tid] = 1 + max(path_len(d) for d in deps)\n" +
        "        return memo[tid]\n" +
        "    cp = max((path_len(t['id']) for t in tasks), default=0)\n" +
        "    doc = {\n" +
        "        '_meta': {\n" +
        "            'name': f'breakthrough: {g[\"project\"]}/{os.path.basename(g[\"file\"])} ({g[\"kind\"]})',\n" +
        "            'schema': 'breakthrough-v1',\n" +
        "            'slug': slug,\n" +
        "            'project': g['project'],\n" +
        "            'parent_gap': g,\n" +
        "            'template': tpl_name,\n" +
        "            'strategy': 'minimal_path',\n" +
        "            'critical_path_len': cp,\n" +
        "            'created': datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ'),\n" +
        "            'emergence_seed': emergence,\n" +
        "        },\n" +
        "        'tasks': tasks,\n" +
        "    }\n" +
        "    return slug, doc\n" +
        "\n" +
        "gaps = load_gaps()\n" +
        "blocking = [g for g in gaps if g.get('blocking')]\n" +
        "if target == '__auto__':\n" +
        "    selected = blocking\n" +
        "elif target == '__list__':\n" +
        "    os.makedirs(BT_DIR, exist_ok=True)\n" +
        "    base_map = {'anima': os.environ.get('HOME','')+'/Dev/anima', 'nexus': NEXUS, 'n6-architecture': os.environ.get('HOME','')+'/Dev/n6-architecture', 'zeta-surpass': os.environ.get('HOME','')+'/Dev/anima', 'anima-train': os.environ.get('HOME','')+'/Dev/anima', 'hexa-lang': os.environ.get('HOME','')+'/Dev/hexa-lang', 'papers': os.environ.get('HOME','')+'/Dev/papers', 'void': os.environ.get('HOME','')+'/Dev/void', 'airgenome': os.environ.get('HOME','')+'/Dev/airgenome'}\n" +
        "    STUB_MARKERS = ['not yet implemented','stub only','TODO: implement','FIXME: implement','// PLACEHOLDER','// STUB']\n" +
        "    def cls(t, base):\n" +
        "        art = t.get('artifact','')\n" +
        "        if not art: return t.get('status','todo')\n" +
        "        full = os.path.join(base, art)\n" +
        "        if not os.path.exists(full): return 'todo'\n" +
        "        try: txt = open(full,'r',encoding='utf-8',errors='replace').read()\n" +
        "        except: return 'todo'\n" +
        "        for pat in STUB_MARKERS:\n" +
        "            if pat.lower() in txt.lower(): return 'in_progress'\n" +
        "        return 'done'\n" +
        "    files = sorted(os.listdir(BT_DIR)) if os.path.exists(BT_DIR) else []\n" +
        "    print(f'breakthroughs in {BT_DIR}: {len([f for f in files if f.endswith(\".json\")])}')\n" +
        "    total_done=0; total_n=0\n" +
        "    for f in files:\n" +
        "        if not f.endswith('.json'): continue\n" +
        "        try:\n" +
        "            d = json.load(open(os.path.join(BT_DIR, f)))\n" +
        "            m = d.get('_meta', {})\n" +
        "            base = base_map.get(m.get('project',''), '')\n" +
        "            tasks = d.get('tasks', [])\n" +
        "            done = sum(1 for t in tasks if cls(t, base) == 'done')\n" +
        "            n = len(tasks)\n" +
        "            total_done += done; total_n += n\n" +
        "            mark = ' OK ' if done == n and n > 0 else f'{done}/{n}'\n" +
        "            print(f\"  [{mark:>6}] {f[:-5]:<50} cp={m.get('critical_path_len','?')} tpl={m.get('template','?')}\")\n" +
        "        except Exception as e:\n" +
        "            print(f'  {f}  [read fail: {e}]')\n" +
        "    if total_n > 0:\n" +
        "        print(f'\\n  overall: {total_done}/{total_n} tasks done ({100*total_done//max(total_n,1)}%)')\n" +
        "    sys.exit(0)\n" +
        "else:\n" +
        "    selected = [g for g in gaps if mk_slug(g) == target or g.get('file','').endswith(target) or target in g.get('key','') or target in g.get('file','')]\n" +
        "    if not selected:\n" +
        "        print(f'no gap matches: {target}')\n" +
        "        print('available blocking gaps:')\n" +
        "        for g in blocking:\n" +
        "            print(f'  {mk_slug(g)}')\n" +
        "        sys.exit(2)\n" +
        "\n" +
        "os.makedirs(BT_DIR, exist_ok=True)\n" +
        "for g in selected:\n" +
        "    slug, doc = build_breakthrough(g)\n" +
        "    p = os.path.join(BT_DIR, slug + '.json')\n" +
        "    with open(p, 'w', encoding='utf-8') as f:\n" +
        "        json.dump(doc, f, ensure_ascii=False, indent=2)\n" +
        "    tpl = doc['_meta']['template']\n" +
        "    cp = doc['_meta']['critical_path_len']\n" +
        "    ntasks = len(doc['tasks'])\n" +
        "    print(f'WROTE  {slug}  tpl={tpl}  tasks={ntasks}  critical_path={cp}')\n" +
        "print(f'{len(selected)} breakthrough(s) generated')\n"
}

// base_map + classify_task 공통 helper (python block 재사용)
fn _common_helpers() -> str {
    return "HOME = '" + HOME + "'\n" +
        "NEXUS = '" + NEXUS + "'\n" +
        "BT_DIR = '" + BT_DIR + "'\n" +
        "base_map = {'anima': HOME+'/Dev/anima', 'nexus': NEXUS, 'n6-architecture': HOME+'/Dev/n6-architecture', 'zeta-surpass': HOME+'/Dev/anima', 'anima-train': HOME+'/Dev/anima', 'hexa-lang': HOME+'/Dev/hexa-lang', 'papers': HOME+'/Dev/papers', 'void': HOME+'/Dev/void', 'airgenome': HOME+'/Dev/airgenome'}\n" +
        "\n" +
        "STUB_MARKERS = ['not yet implemented','stub only','TODO: implement','FIXME: implement','// PLACEHOLDER','// STUB']\n" +
        "\n" +
        "def classify_task(t, base):\n" +
        "    \"\"\"Returns derived status: 'done' / 'in_progress' / 'todo'.\"\"\"\n" +
        "    art = t.get('artifact','')\n" +
        "    if not art:\n" +
        "        # artifact 비어있음 — T1 (evidence gen) / T3 (commit) 같이 관측 불가 tasks. 기존 상태 유지.\n" +
        "        return t.get('status','todo')\n" +
        "    full = os.path.join(base, art)\n" +
        "    if not os.path.exists(full):\n" +
        "        return 'todo'\n" +
        "    try:\n" +
        "        txt = open(full, 'r', encoding='utf-8', errors='replace').read()\n" +
        "    except Exception:\n" +
        "        return 'todo'\n" +
        "    # stub 마커 남아있으면 in_progress (artifact 있으나 미완)\n" +
        "    for pat in STUB_MARKERS:\n" +
        "        if pat.lower() in txt.lower():\n" +
        "            return 'in_progress'\n" +
        "    return 'done'\n" +
        "\n" +
        "def refresh_doc(doc):\n" +
        "    \"\"\"In-place task.status refresh. Returns (done, in_progress, todo) counts.\"\"\"\n" +
        "    project = doc.get('_meta',{}).get('project','?')\n" +
        "    base = base_map.get(project, '')\n" +
        "    counts = {'done':0,'in_progress':0,'todo':0}\n" +
        "    for t in doc.get('tasks', []):\n" +
        "        st = classify_task(t, base)\n" +
        "        t['status'] = st\n" +
        "        counts[st] = counts.get(st,0) + 1\n" +
        "    return counts\n"
}

fn status_script(slug: str) -> str {
    return "import json, os, sys\n" +
        _common_helpers() +
        "slug = \"" + slug + "\"\n" +
        "p = os.path.join(BT_DIR, slug + '.json')\n" +
        "if not os.path.exists(p):\n" +
        "    print(f'not found: {p}'); sys.exit(2)\n" +
        "d = json.load(open(p))\n" +
        "counts = refresh_doc(d)\n" +
        "# auto write-back\n" +
        "with open(p,'w',encoding='utf-8') as f:\n" +
        "    json.dump(d, f, ensure_ascii=False, indent=2)\n" +
        "\n" +
        "m = d.get('_meta', {})\n" +
        "project = m.get('project', '?')\n" +
        "base = base_map.get(project, '')\n" +
        "n_total = sum(counts.values())\n" +
        "print(f'=== {slug} ===')\n" +
        "print(f\"  project: {project}  template: {m.get('template','?')}  cp={m.get('critical_path_len','?')}\")\n" +
        "print(f\"  gap: {m.get('parent_gap',{}).get('kind','?')} @ {m.get('parent_gap',{}).get('file','?')}\")\n" +
        "print(f\"  progress: {counts['done']}/{n_total} done ({counts['in_progress']} in_progress, {counts['todo']} todo)\")\n" +
        "print('')\n" +
        "sym = {'done':'\\u2713','in_progress':'~','todo':'\\u00b7'}\n" +
        "for t in d.get('tasks', []):\n" +
        "    st = t.get('status','todo')\n" +
        "    mark = sym.get(st,'?')\n" +
        "    deps = ','.join(t.get('depends_on',[])) or '—'\n" +
        "    print(f\"  [{mark}] {t['id']:<4} [{st:<12}] [{t['order']:<8}] deps={deps:<10} {t['task'][:60]}\")\n" +
        "    if t.get('exec_hint'):\n" +
        "        print(f\"         exec: {t['exec_hint'][:80]}\")\n"
}

fn refresh_script(target: str) -> str {
    return "import json, os, sys\n" +
        _common_helpers() +
        "target = \"" + target + "\"\n" +
        "if not os.path.exists(BT_DIR):\n" +
        "    print('no breakthroughs dir'); sys.exit(0)\n" +
        "\n" +
        "files = sorted([f for f in os.listdir(BT_DIR) if f.endswith('.json')])\n" +
        "if target != 'all':\n" +
        "    files = [f for f in files if f == target + '.json' or f.startswith(target)]\n" +
        "    if not files:\n" +
        "        print(f'no match: {target}'); sys.exit(2)\n" +
        "\n" +
        "total_done = 0; total_ip = 0; total_todo = 0; total_tasks = 0\n" +
        "for f in files:\n" +
        "    p = os.path.join(BT_DIR, f)\n" +
        "    try:\n" +
        "        d = json.load(open(p))\n" +
        "    except Exception as e:\n" +
        "        print(f'  {f}  [read fail: {e}]'); continue\n" +
        "    counts = refresh_doc(d)\n" +
        "    with open(p,'w',encoding='utf-8') as fp:\n" +
        "        json.dump(d, fp, ensure_ascii=False, indent=2)\n" +
        "    n = sum(counts.values())\n" +
        "    total_done += counts['done']; total_ip += counts['in_progress']; total_todo += counts['todo']; total_tasks += n\n" +
        "    slug = f.rsplit('.',1)[0]\n" +
        "    print(f\"  REFRESH {slug:<60} {counts['done']}/{n} done ({counts['in_progress']} ip, {counts['todo']} todo)\")\n" +
        "print(f'\\n{len(files)} breakthrough(s) refreshed. total: {total_done}/{total_tasks} done, {total_ip} in_progress, {total_todo} todo')\n"
}

// ─── CLI ───────────────────────────────────────────────────────

fn main() {
    let a = args()
    if len(a) < 3 {
        print_usage()
        exit(2)
    }
    let cmd = a[2]

    if cmd == "help" || cmd == "--help" || cmd == "-h" {
        print_usage()
        exit(0)
    }

    if cmd == "list" {
        let out = run_py(generate_script("__list__")).trim()
        println(out)
        exit(0)
    }

    if cmd == "auto" {
        let out = run_py(generate_script("__auto__")).trim()
        println(out)
        exit(0)
    }

    if cmd == "generate" {
        if len(a) < 4 {
            eprintln("usage: breakthrough generate <gap_id_or_slug>")
            exit(2)
        }
        let target = a[3]
        let out = run_py(generate_script(target)).trim()
        println(out)
        exit(0)
    }

    if cmd == "status" {
        if len(a) < 4 {
            eprintln("usage: breakthrough status <slug>")
            exit(2)
        }
        let slug = a[3]
        let out = run_py(status_script(slug)).trim()
        println(out)
        exit(0)
    }

    if cmd == "refresh" {
        let target = if len(a) >= 4 { a[3] } else { "all" }
        let out = run_py(refresh_script(target)).trim()
        println(out)
        exit(0)
    }

    eprintln("unknown command: " + cmd)
    print_usage()
    exit(2)
}

main()
