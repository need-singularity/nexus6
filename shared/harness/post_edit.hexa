// post_edit.hexa — Write/Edit 후 sync (PostToolUse Write|Edit 훅 대체)
// 역할: nexus-post-edit + auto-sync + atlas-sync + atlas-health-guard 핵심 로직
// usage: hexa run shared/harness/post_edit.hexa <file_path>
// output: sync 액션 실행 결과 stdout. 문제 없으면 무출력.

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"

fn main() {
    let argv = args()
    if argv.len() < 3 { return }
    let file_path = argv[2]
    if file_path.len() == 0 { return }

    // 1. shared/project-claude/*.md 수정 시 — 프로젝트 CLAUDE.md로 복사 힌트
    if file_path.contains("/shared/project-claude/") && file_path.ends_with(".md") {
        println("[SYNC HINT] project-claude/*.md 수정 감지 — 해당 프로젝트 CLAUDE.md 에 반영 필요. sync_claude_md.hexa 실행 권장.")
    }

    // 2. shared/config/commands.json 수정 시 — dispatch 재로드 힌트
    if file_path.contains("/shared/config/commands.json") {
        println("[SYNC HINT] commands.json 변경 — 모든 프로젝트에 반영. 새 세션 권장.")
    }

    // 3. shared/n6/atlas.n6 수정 시 — 헬스체크 힌트
    if file_path.contains("/shared/n6/atlas.n6") {
        println("[ATLAS HINT] atlas.n6 변경 — atlas_health.hexa 실행 권장 (shared/n6/atlas_health.hexa)")
    }

    // 4. shared/harness/*.hexa 수정 시 — self_check 힌트
    if file_path.contains("/shared/harness/") && file_path.ends_with(".hexa") {
        println("[HARNESS HINT] harness/*.hexa 변경 — entry.hexa self_check 실행 권장")
    }

    // 5. R34: 로드맵 JSON 수정 시 — 확장 스키마 즉시 경고
    if file_path.ends_with(".json") {
        let base = to_string(exec("basename '" + file_path + "'")).trim()
        let is_roadmap = base.starts_with("roadmap") || base.ends_with(".roadmap.json") || file_path.contains("/roadmaps/")
        if is_roadmap {
            let legacy = to_string(exec("grep -c '\"_legacy\":[[:space:]]*true\\|@allow-roadmap-ext' '" + file_path + "' 2>/dev/null")).trim()
            if legacy == "0" || legacy == "" {
                let banned = "\"depends_on\"|\"deps\"|\"priority\"|\"weight\"|\"roi\"|\"est\"|\"val\"|\"phases\"|\"tracks\"|\"gate_exit\"|\"acceleration_options\"|\"cost_projection\"|\"decision_points\"|\"critical_path\""
                let hits = to_string(exec("grep -cE '" + banned + "' '" + file_path + "' 2>/dev/null")).trim()
                if hits != "0" && hits != "" {
                    println("[R34 WARN] " + file_path + " — 확장 스키마 " + hits + "건. 최소 경로 문법(순차/병렬/'>'/par_bg) 권장. 레거시면 `\"_legacy\": true` 추가")
                }
            }
        }
    }
}

main()
