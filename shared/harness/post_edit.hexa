// post_edit.hexa — Write/Edit 후 sync (PostToolUse Write|Edit 훅 대체)
// @no-lock-needed
// @allow-bare-exec
// 역할: nexus-post-edit + auto-sync + atlas-sync + atlas-health-guard 핵심 로직
//       + H-ERR-ROUTE (R34 등 lint 위반 큐 등록)
// usage: hexa run shared/harness/post_edit.hexa <file_path>
// output: sync 액션 실행 결과 stdout. 문제 없으면 무출력.

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"

fn route_err(src: str, file: str, line: i64, code: str, msg: str) {
    let HARNESS = HOME + "/Dev/nexus/shared/harness"
    let hexa_bin = HOME + "/Dev/nexus/shared/bin/hexa"
    let esc_msg = msg.replace("'", "").replace("\n", " ").replace("\r", " ")
    let esc_file = file.replace("'", "")
    let cmd = hexa_bin + " run " + HARNESS + "/errors.hexa route " + src +
              " '" + esc_file + "' " + to_string(line) + " " + code +
              " '" + esc_msg + "' 2>&1"
    let out = to_string(exec(cmd)).trim()  // @allow-bare-exec
    if out.len() > 0 { println(out) }
}

// S1 관찰 버스 — observations.jsonl append (silent)
fn _observe(tool: str, path_or_cmd: str, exit_str: str, source: str) {
    let HARNESS = HOME + "/Dev/nexus/shared/harness"
    let OBS = HARNESS + "/observations.jsonl"
    let ts = to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()  // @allow-bare-exec
    let trimmed = path_or_cmd.trim()
    let mut pattern_key = ""
    if tool == "Bash" {
        let toks = trimmed.split(" ")
        if toks.len() >= 2 {
            pattern_key = to_string(toks[0]).trim() + ":" + to_string(toks[1]).trim()
        } else if toks.len() == 1 {
            pattern_key = to_string(toks[0]).trim()
        }
    } else {
        if trimmed.contains("/shared/harness/") { pattern_key = "write:dir:shared/harness/" }
        else if trimmed.contains("/shared/") { pattern_key = "write:dir:shared/" }
        else {
            let ext_cmd = "printf '%s' '" + trimmed.replace("'", "") + "' | awk -F. '{if (NF>1) print $NF}'"
            let ext = to_string(exec(ext_cmd)).trim()  // @allow-bare-exec
            if ext.len() > 0 { pattern_key = "write:ext:*." + ext }
            else { pattern_key = "write:other" }
        }
    }
    let tsid_raw = to_string(exec("printf '%s' \"$TERM_SESSION_ID\" 2>/dev/null | /usr/bin/shasum -a 1 2>/dev/null | cut -c1-8")).trim()  // @allow-bare-exec
    let session_id = if tsid_raw.len() > 0 { tsid_raw } else { "nosess" }
    let ph_cmd = "git remote get-url origin 2>/dev/null | /usr/bin/shasum -a 1 2>/dev/null | cut -c1-12"
    let ph_raw = to_string(exec(ph_cmd)).trim()  // @allow-bare-exec
    let project_hash = if ph_raw.len() > 0 { ph_raw } else { "noremote" }
    let esc_path = path_or_cmd.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", " ").replace("\r", " ").replace("\t", " ")
    let esc_pk = pattern_key.replace("\\", "\\\\").replace("\"", "\\\"")
    let row = "{\"ts\":\"" + ts + "\"," +
              "\"tool\":\"" + tool + "\"," +
              "\"path\":\"" + esc_path + "\"," +
              "\"exit\":" + exit_str + "," +
              "\"pattern_key\":\"" + esc_pk + "\"," +
              "\"session_id\":\"" + session_id + "\"," +
              "\"project_hash\":\"" + project_hash + "\"," +
              "\"source\":\"" + source + "\"}"
    let esc_row = row.replace("'", "'\\''")
    exec("echo '" + esc_row + "' >> '" + OBS + "' 2>/dev/null")  // @allow-bare-exec
}

// H-ANNOT-LINT (active 2026-04-19): .hexa 파일 변경 시 annot_rules.json kind=alias 검사 (warn-only)
// 우회: NEXUS_NOAUTOLINT=1 또는 NEXUS_ANNOT_OK=1
fn auto_lint_annot(file_path: str) {
    let is_hexa = file_path.ends_with(".hexa") || file_path.ends_with(".hexa.inc")
    if is_hexa == false { return }
    if env("NEXUS_NOAUTOLINT").len() > 0 { return }
    if env("NEXUS_ANNOT_OK") == "1" { return }
    // 자기참조 회피
    let skip_targets = ["/lint_annot.hexa", "/pre_tool_guard.hexa", "/post_edit.hexa"]
    for s in skip_targets {
        if file_path.contains(s) { return }
    }
    let lint_annot = HOME + "/Dev/nexus/shared/harness/lint_annot.hexa"
    let hexa_bin = HOME + "/Dev/nexus/shared/bin/hexa"
    let exists = to_string(exec("test -f '" + lint_annot + "' && echo y || echo n")).trim()  // @allow-bare-exec
    if exists != "y" { return }
    let wrapper = HOME + "/Dev/nexus/shared/harness/perl_timeout.sh"
    let wrapper_exists = to_string(exec("test -x '" + wrapper + "' && echo y || echo n")).trim()  // @allow-bare-exec
    let mut cmd = ""
    if wrapper_exists == "y" {
        cmd = "bash '" + wrapper + "' 15 " + hexa_bin + " run " + lint_annot + " scan '" + file_path + "' 2>&1"
    } else {
        cmd = hexa_bin + " run " + lint_annot + " scan '" + file_path + "' 2>&1"
    }
    let out = to_string(exec(cmd)).trim()  // @allow-bare-exec
    // lint_annot 는 매치 시에만 stderr 출력 (silent-success H1 + warn-only)
    if out.len() > 0 && out.contains("H-ANNOT-LINT") {
        println(out)
    }
}

// H-NOZOMBIE: .hexa 파일 변경 시 자동 lint 호출 (cheap, single file)
// 우회: NEXUS_NOAUTOLINT=1 env
// 자기참조 회피: lint/post_edit/post_bash/cmd_gate 자체 변경 시 skip
fn auto_lint_hexa(file_path: str) {
    // .hexa / .hexa.inc 만 대상
    let is_hexa = file_path.ends_with(".hexa") || file_path.ends_with(".hexa.inc")
    if is_hexa == false { return }
    // env 우회
    if env("NEXUS_NOAUTOLINT").len() > 0 { return }
    // 자기참조 회피
    let skip_targets = ["/lint.hexa", "/post_edit.hexa", "/post_bash.hexa", "/cmd_gate.hexa"]
    for s in skip_targets {
        if file_path.contains(s) { return }
    }
    let lint = HOME + "/Dev/nexus/shared/harness/lint.hexa"
    let hexa_bin = HOME + "/Dev/nexus/shared/bin/hexa"
    // lint 자체가 부재 시 무시
    let exists = to_string(exec("test -f '" + lint + "' && echo y || echo n")).trim()  // @allow-bare-exec
    if exists != "y" { return }
    // perl_timeout 래퍼가 있으면 사용 (다른 Agent 가 작성 중)
    let wrapper = HOME + "/Dev/nexus/shared/harness/perl_timeout.sh"
    let wrapper_exists = to_string(exec("test -x '" + wrapper + "' && echo y || echo n")).trim()  // @allow-bare-exec
    let mut cmd = ""
    if wrapper_exists == "y" {
        cmd = "bash '" + wrapper + "' 30 " + hexa_bin + " run " + lint + " --file '" + file_path + "' 2>&1"
    } else {
        cmd = hexa_bin + " run " + lint + " --file '" + file_path + "' 2>&1"
    }
    let out = to_string(exec(cmd)).trim()  // @allow-bare-exec
    // lint 가 violation 보고하면 prefix 붙여서 출력 (silent-success H1)
    if out.len() > 0 && out.contains("violation") {
        println("[H-NOZOMBIE auto-lint] " + file_path)
        println(out)
    }
}

fn main() {
    // argv 정규화 — Mac/Linux-stage1 prefix 편차 흡수 (shared/blowup/lib/argv.hexa.inc 참조).
    let _raw_argv = args()
    let mut _script_idx: i64 = -1
    let mut _scan_i: i64 = 0
    while _scan_i < _raw_argv.len() {
        if to_string(_raw_argv[_scan_i]).ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let _user_start = if _script_idx >= 0 { _script_idx + 1 } else {
        if _raw_argv.len() >= 3 && (to_string(_raw_argv[1]) == "run" || to_string(_raw_argv[1]) == "eval") { 3 } else { 2 }
    }
    let _script_token = if _script_idx >= 0 { _raw_argv[_script_idx] } else { "" }
    let mut argv = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if argv.len() < 3 { return }
    let file_path = argv[2]
    if file_path.len() == 0 { return }

    // 1. shared/project-claude/*.md 수정 시 — 프로젝트 CLAUDE.md로 복사 힌트
    if file_path.contains("/shared/project-claude/") && file_path.ends_with(".md") {
        println("[SYNC HINT] project-claude/*.md 수정 감지 — 해당 프로젝트 CLAUDE.md 에 반영 필요. sync_claude_md.hexa 실행 권장.")
    }

    // 2. shared/config/commands.json 수정 시 — dispatch 재로드 힌트
    if file_path.contains("/shared/config/commands.json") {
        println("[SYNC HINT] commands.json 변경 — 모든 프로젝트에 반영. 새 세션 권장.")
    }

    // 3. shared/n6/atlas.n6 수정 시 — 헬스체크 힌트 + cross_feed atlas_delta 자동 호출 (P4 Action)
    if file_path.contains("/shared/n6/atlas.n6") {
        println("[ATLAS HINT] atlas.n6 변경 — atlas_health.hexa 실행 권장 (shared/n6/atlas_health.hexa)")
        let HARNESS_CF = HOME + "/Dev/nexus/shared/harness"
        let HEXA_CF = HOME + "/Dev/nexus/shared/bin/hexa"
        exec(HEXA_CF + " run " + HARNESS_CF + "/cross_feed.hexa atlas_delta >/dev/null 2>&1")  // @allow-bare-exec
    }

    // 4. shared/harness/*.hexa 수정 시 — self_check 힌트
    if file_path.contains("/shared/harness/") && file_path.ends_with(".hexa") {
        println("[HARNESS HINT] harness/*.hexa 변경 — entry.hexa self_check 실행 권장")
    }

    // 5. R34: 로드맵 JSON 수정 시 — 확장 스키마 즉시 경고
    if file_path.ends_with(".json") {
        let base = to_string(exec("basename '" + file_path + "'")).trim()  // @allow-bare-exec
        let is_roadmap = base.starts_with("roadmap") || base.ends_with(".roadmap.json") || file_path.contains("/roadmaps/")
        if is_roadmap {
            let legacy = to_string(exec("grep -c '\"_legacy\":[[:space:]]*true\\|@allow-roadmap-ext' '" + file_path + "' 2>/dev/null")).trim()  // @allow-bare-exec
            if legacy == "0" || legacy == "" {
                let banned = "\"depends_on\"|\"deps\"|\"priority\"|\"weight\"|\"roi\"|\"est\"|\"val\"|\"phases\"|\"tracks\"|\"gate_exit\"|\"acceleration_options\"|\"cost_projection\"|\"decision_points\"|\"critical_path\""
                let hits = to_string(exec("grep -cE '" + banned + "' '" + file_path + "' 2>/dev/null")).trim()  // @allow-bare-exec
                if hits != "0" && hits != "" {
                    println("[R34 WARN] " + file_path + " — 확장 스키마 " + hits + "건. 최소 경로 문법(순차/병렬/'>'/par_bg) 권장. 레거시면 `\"_legacy\": true` 추가")
                    route_err("lint", file_path, 0, "R34", "확장 스키마 " + hits + "건")
                }
            }
        }
    }

    // 6. H-NOHOOK: .claude*/settings*.json 변경 시 hooks 키 비어있지 않으면 자동 revert (2026-04-14 강화)
    //    커버: ~/.claude/, ~/.claude-<suffix>/ (멀티계정), 프로젝트별 .claude/
    //    우회: NEXUS_HOOK_OK=1 env. 격리: archive/
    let bn = to_string(exec("basename '" + file_path + "'")).trim()  // @allow-bare-exec
    let is_settings = (bn == "settings.json" || bn == "settings.local.json")
    let is_in_claude_dir = file_path.contains("/.claude/") || file_path.contains("/.claude-")
    if is_settings && is_in_claude_dir {
        let in_archive = file_path.contains("/archive/") || file_path.contains("/shared/archive/")
        let bypass = env("NEXUS_HOOK_OK") == "1"
        if in_archive == false && bypass == false {
            let jq_ok = to_string(exec("command -v jq >/dev/null 2>&1 && echo y || echo n")).trim()  // @allow-bare-exec
            let mut hooks_nonempty = false
            if jq_ok == "y" {
                let cnt = to_string(exec("jq '(.hooks // {}) | length' '" + file_path + "' 2>/dev/null")).trim()  // @allow-bare-exec
                if cnt != "" && cnt != "0" { hooks_nonempty = true }
            } else {
                let n = to_string(exec("grep -E '\"hooks\"[[:space:]]*:[[:space:]]*\\{[[:space:]]*$|\"hooks\"[[:space:]]*:[[:space:]]*\\[' '" + file_path + "' | wc -l 2>/dev/null")).trim()  // @allow-bare-exec
                if n != "" && n != "0" { hooks_nonempty = true }
            }
            if hooks_nonempty {
                // 자동 revert — hooks={} 로 원자적 덮어쓰기
                if jq_ok == "y" {
                    let tmp_path = file_path + ".nohook.tmp"
                    let rc_str = to_string(exec("jq '.hooks = {}' '" + file_path + "' > '" + tmp_path + "' 2>/dev/null && mv '" + tmp_path + "' '" + file_path + "' && echo ok || echo fail")).trim()  // @allow-bare-exec
                    if rc_str == "ok" {
                        println("[H-NOHOOK AUTO-REVERT] " + file_path + " — hooks 키 자동 비움 (.hooks={}). 정책: harness/entry.hexa 자율 호출로 통합. 우회: NEXUS_HOOK_OK=1")
                        route_err("post_edit", file_path, 0, "H-NOHOOK", "hooks 키 auto-revert — entry.hexa 자율 호출로 통합")
                    } else {
                        println("[H-NOHOOK BLOCK] " + file_path + " — 자동 revert 실패 (jq/mv). 수동으로 hooks={} 로 비울 것.")
                        route_err("post_edit", file_path, 0, "H-NOHOOK", "hooks 키 작성 금지 — auto-revert 실패")
                    }
                } else {
                    println("[H-NOHOOK BLOCK] " + file_path + " — hooks 키 비어있지 않음 (jq 부재로 auto-revert 불가). 수동 hooks={} 로 비울 것.")
                    route_err("post_edit", file_path, 0, "H-NOHOOK", "hooks 키 작성 금지 — jq 부재")
                }
            }
        }
    }

    // 7. H-BROADCAST: shared/ 파일 변경 → broadcast.jsonl append (cross-session 전파)
    if file_path.starts_with("shared/") || file_path.contains("/shared/") {
        let HARNESS = HOME + "/Dev/nexus/shared/harness"
        let HEXA_BIN = HOME + "/Dev/nexus/shared/bin/hexa"
        exec(HEXA_BIN + " run " + HARNESS + "/broadcast.hexa append '" + file_path + "' edit >/dev/null 2>&1")  // @allow-bare-exec
    }

    // 8. H-NOZOMBIE: .hexa 파일 변경 시 자동 lint 호출 (마지막 — 다른 검증 후)
    auto_lint_hexa(file_path)

    // 8b. H-ANNOT-LINT: .hexa 파일 변경 시 annot_rules.json kind=alias 검사 (active 2026-04-19, warn-only)
    auto_lint_annot(file_path)

    // 9. S1 관찰 버스 — observation append (write/edit path)
    _observe("Write", file_path, "0", "post_edit")

    // 10. context_gauge tick (Track C 모듈, 부재 시 silent)
    let HARNESS3 = HOME + "/Dev/nexus/shared/harness"
    let HEXA3 = HOME + "/Dev/nexus/shared/bin/hexa"
    exec(HEXA3 + " run " + HARNESS3 + "/context_gauge.hexa tick 2>/dev/null")  // @allow-bare-exec
}

main()
