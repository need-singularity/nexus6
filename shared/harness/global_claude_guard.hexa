// global_claude_guard.hexa — ~/.claude/ 외부 설정 오염 감지
// 원칙: 공용 규칙 강제는 프로젝트별 .claude/settings.json 에서만.
//       ~/.claude/ 에 hooks/CLAUDE.md/스크립트 생성되면 하네스가 loud 보고.
// 허용: ~/.claude/settings.json (Claude Code 기본 설정)
// 실행: 성공 조용 / 실패 시 mistakes.jsonl 기록 + stderr

let HOME = env("HOME")
let GLOBAL_DIR = HOME + "/.claude"
let MISTAKES = HOME + "/Dev/nexus/shared/harness/mistakes.jsonl"

fn scan() -> list {
    let mut v = []
    if file_exists(GLOBAL_DIR) == false { return v }

    let claudemd = GLOBAL_DIR + "/CLAUDE.md"
    if file_exists(claudemd) { v = v + [claudemd] }

    let hooks_dir = GLOBAL_DIR + "/hooks"
    if file_exists(hooks_dir) {
        let listing = to_string(exec("find '" + hooks_dir + "' -type f 2>/dev/null")).trim()
        if len(listing) > 0 {
            for line in listing.split("\n") {
                let trimmed = line.trim()
                if len(trimmed) > 0 { v = v + [trimmed] }
            }
        }
    }

    let settings = GLOBAL_DIR + "/settings.json"
    if file_exists(settings) {
        let raw = read_file(settings)
        if raw.contains("\"hooks\"") {
            let after = raw.split("\"hooks\"")[1]
            let parts = after.split(":")
            if parts.len() >= 2 {
                let body = parts[1].trim()
                let empty = body.starts_with("{}") || body.starts_with("{ }")
                if empty == false { v = v + [settings + " (hooks 키 비어있어야 함)"] }
            }
        }
    }
    return v
}

let violations = scan()
if len(violations) == 0 { exit(0) }

let ts = to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
for item in violations {
    let safe = item.replace("\\", "\\\\").replace("\"", "\\\"")
    let entry = "{\"ts\":\"" + ts + "\",\"gate\":\"global_claude\",\"violation\":\"" + safe + "\"}\n"
    append_file(MISTAKES, entry)
    eprintln("GLOBAL-CLAUDE-GUARD FAIL: " + item)
}
exit(2)
