// session_registry.hexa — H-SESSION-REGISTRY 하네스 룰
// @no-lock-needed
// @no-sandbox
// 역할: 다중 Claude Code 세션 상호 가시화. 매 prompt 마다 session 단위 manifest broadcast.
// 배경: nexus 다중 세션 + 다중 프로젝트 세션이 서로 보이지 않아 중복 작업 빈번.
//       agent_ledger 는 Agent 호출 단위 / 이건 세션 자체 단위 (매 prompt heartbeat).
// SSOT: shared/harness/session_registry.jsonl (append-only, gc 가 status 갱신)
// 우회: NEXUS_SESSION_OK=1 (silent skip)
//
// modes:
//   register <project> <area> [intent]  — upsert. 있으면 heartbeat+area+intent 갱신. stdout=session_id
//   heartbeat                           — ts_heartbeat 만 갱신 (register 선행 시). 없으면 silent no-op
//   list                                — active 세션 JSONL stdout
//   peers                               — 내 pid 외 활성(stale 아닌) 세션 stderr 주입 (있을 때만)
//   gc                                  — 120초 heartbeat 없는 세션 status="stale". stdout="gc: N stale"
//   self                                — 내 세션 row stdout (디버그)
//
// 성공 조용, 실패 시끄럽게 (H1).

let HOME = env("HOME")
let HARNESS = HOME + "/Dev/nexus/shared/harness"
let REGISTRY = HARNESS + "/session_registry.jsonl"
let STALE_AFTER: i64 = 120  // 120초 heartbeat 없으면 stale

// void-safe coercion — "".split() 첫 원소 void 반환 우회
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    return to_int(first)
}

fn now_unix() -> i64 {
    return _to_int0(_str(exec("date +%s")).trim())
}

fn get_session_key() -> string {
    // 세션 안정 키 우선순위:
    //   1) TERM_SESSION_ID (Apple Terminal — 터미널 세션 수명 동안 고정)
    //   2) CLAUDE_CODE_EXECPATH + "|" + 최상위 parent pid
    //   3) $PPID (fallback — 동일 프로세스 내에서만 안정)
    let tsid = env("TERM_SESSION_ID")
    if tsid != "" { return tsid }
    let cce = env("CLAUDE_CODE_EXECPATH")
    if cce != "" {
        // ancestor pid — 현재 hexa 의 부모의 부모 (세션 shell)
        let ancestor = _str(exec("ps -o ppid= -p $PPID 2>/dev/null")).trim()
        if ancestor != "" { return cce + "|" + ancestor }
    }
    let p = _str(exec("echo $PPID")).trim()
    if p == "" || p == "0" {
        return _str(exec("echo $$")).trim()
    }
    return p
}

fn get_pid_for_row() -> string {
    // row 의 pid 필드 — 가능한 한 실제 parent pid
    let p = _str(exec("echo $PPID")).trim()
    if p == "" { return "0" }
    return p
}

fn _ensure() {
    if file_exists(REGISTRY) == false {
        try { write_file(REGISTRY, "") } catch e {}
    }
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", " ")
    r = r.replace("\r", " ")
    r = r.replace("\t", " ")
    return r
}

// ─── session_id: session_key 기반 캐시 재사용 ───
// key 가 길거나 특수문자 포함 가능 → 캐시 파일명은 key 의 sha1 8자
fn cache_tag(key: string) -> string {
    let esc = key.replace("'", "")
    let cmd = "printf '%s' '" + esc + "' | /usr/bin/shasum -a 256 2>/dev/null | cut -c1-12"
    let r = _str(exec(cmd)).trim()
    if r == "" { return "fallback" }
    return r
}

fn cache_path_for(key: string) -> string {
    return HARNESS + "/.session_id_" + cache_tag(key)
}

fn make_session_id(key: string) -> string {
    let ts = to_string(now_unix())
    let raw = key + "|" + ts
    let esc = raw.replace("'", "")
    let cmd = "printf '%s' '" + esc + "' | /usr/bin/shasum -a 256 2>/dev/null | cut -c1-8"
    let r = _str(exec(cmd)).trim()
    if r == "" {
        // fallback: ts 끝 8자
        let l = ts.len()
        if l >= 8 { return "s" + ts.substring(l - 8, l) }
        return "s" + ts
    }
    return "s" + r
}

fn get_or_make_session_id(key: string) -> string {
    let cpath = cache_path_for(key)
    if file_exists(cpath) {
        let cached = _str(read_file(cpath)).trim()
        if cached.len() > 0 { return cached }
    }
    let sid = make_session_id(key)
    try { write_file(cpath, sid + "\n") } catch e {}
    return sid
}

fn peek_session_id(key: string) -> string {
    let cpath = cache_path_for(key)
    if file_exists(cpath) == false { return "" }
    let cached = _str(read_file(cpath)).trim()
    return cached
}

// ─── 활성 row 존재 체크 ───
fn has_active_row(session_id: string) -> bool {
    _ensure()
    let esc = session_id.replace("'", "")
    let cmd = "grep -c '\"session_id\":\"" + esc + "\".*\"status\":\"active\"' '" + REGISTRY + "' 2>/dev/null"
    let n = _to_int0(_str(exec(cmd)).trim())
    return n > 0
}

// ─── row 직렬화 ───
fn build_row(sid: string, pid: string, project: string, area: string, itt: string, ts_start: i64, ts_heartbeat: i64) -> string {
    return "{\"session_id\":\"" + sid + "\"," +
           "\"pid\":" + pid + "," +
           "\"project\":\"" + json_escape(project) + "\"," +
           "\"area\":\"" + json_escape(area) + "\"," +
           "\"intent\":\"" + json_escape(itt) + "\"," +
           "\"ts_start\":" + to_string(ts_start) + "," +
           "\"ts_heartbeat\":" + to_string(ts_heartbeat) + "," +
           "\"status\":\"active\"}"
}

// ─── register (upsert) ───
fn cmd_register(argv: [string]) {
    if env("NEXUS_SESSION_OK") == "1" { return }
    if argv.len() < 5 {
        eprintln("usage: register <project> <area> [intent]")
        exit(2)
    }
    let project = argv[3].trim()
    let area = argv[4].trim()
    let mut itt = ""
    if argv.len() >= 6 { itt = argv[5].trim() }
    if project.len() == 0 || area.len() == 0 {
        eprintln("REJECT: project/area 비어있음")
        exit(2)
    }

    _ensure()
    let skey = get_session_key()
    let sid = get_or_make_session_id(skey)
    let row_pid = get_pid_for_row()
    let ts = now_unix()

    if has_active_row(sid) {
        // 기존 row: ts_heartbeat + area + intent sed 교체
        let esc_sid = sid.replace("'", "")
        let esc_area = json_escape(area).replace("'", "")
        let esc_intent = json_escape(itt).replace("'", "")
        // ts_heartbeat
        let c1 = "/usr/bin/sed -i.bak -E '/\"session_id\":\"" + esc_sid + "\"/ s/\"ts_heartbeat\":[0-9]+/\"ts_heartbeat\":" + to_string(ts) + "/' '" + REGISTRY + "' && rm -f '" + REGISTRY + ".bak'"
        exec(c1)
        // area
        let c2 = "/usr/bin/sed -i.bak -E '/\"session_id\":\"" + esc_sid + "\"/ s/\"area\":\"[^\"]*\"/\"area\":\"" + esc_area + "\"/' '" + REGISTRY + "' && rm -f '" + REGISTRY + ".bak'"
        exec(c2)
        // intent
        let c3 = "/usr/bin/sed -i.bak -E '/\"session_id\":\"" + esc_sid + "\"/ s/\"intent\":\"[^\"]*\"/\"intent\":\"" + esc_intent + "\"/' '" + REGISTRY + "' && rm -f '" + REGISTRY + ".bak'"
        exec(c3)
    } else {
        // 신규 append
        let row = build_row(sid, row_pid, project, area, itt, ts, ts)
        try { append_file(REGISTRY, row + "\n") } catch e {
            eprintln("FAIL: append_file 실패 — " + REGISTRY)
            exit(1)
        }
    }
    println(sid)
}

// ─── heartbeat ───
fn cmd_heartbeat(argv: [string]) {
    if env("NEXUS_SESSION_OK") == "1" { return }
    _ensure()
    let skey = get_session_key()
    let sid = peek_session_id(skey)
    if sid == "" { return }  // register 선행 안 됨 — silent no-op
    if has_active_row(sid) == false { return }
    let ts = now_unix()
    let esc_sid = sid.replace("'", "")
    let cmd = "/usr/bin/sed -i.bak -E '/\"session_id\":\"" + esc_sid + "\"/ s/\"ts_heartbeat\":[0-9]+/\"ts_heartbeat\":" + to_string(ts) + "/' '" + REGISTRY + "' && rm -f '" + REGISTRY + ".bak'"
    exec(cmd)
}

// ─── list ───
fn cmd_list(argv: [string]) {
    _ensure()
    let out = _str(exec("grep '\"status\":\"active\"' '" + REGISTRY + "' 2>/dev/null")).trim()
    if out == "" {
        println("(no active sessions)")
        return
    }
    println(out)
}

// ─── peers (stale 제외, 나 제외) ───
fn cmd_peers(argv: [string]) {
    if env("NEXUS_SESSION_OK") == "1" { return }
    _ensure()
    let now = now_unix()
    let cutoff = now - STALE_AFTER
    let skey = get_session_key()
    let my_sid = peek_session_id(skey)

    // awk: active + ts_heartbeat >= cutoff + session_id != my_sid
    // 필드 파싱 단순화: 각 row 에서 session_id/project/area/intent/ts_heartbeat 추출
    // 오프셋: 문자열 값은 "key":"val" 래퍼 제거, 숫자 값은 "key":val 의 key+colon 제거
    // session_id key_wrapper="session_id":" → 14 chars, trailing " → 1, len=RLENGTH-15
    // ts_heartbeat key_prefix="ts_heartbeat": → 15 chars, len=RLENGTH-15
    let awk_cmd = "awk -v cut=" + to_string(cutoff) + " -v me='" + my_sid + "'" +
                  " '/\"status\":\"active\"/ {" +
                  "   sid=\"\"; proj=\"\"; ar=\"\"; it=\"\"; hb=0;" +
                  "   n=split($0, parts, \",\");" +
                  "   for(i=1;i<=n;i++){" +
                  "     p=parts[i];" +
                  "     if(match(p, /\"session_id\":\"[^\"]+\"/)){ v=substr(p, RSTART+14, RLENGTH-15); sid=v }" +
                  "     else if(match(p, /\"project\":\"[^\"]*\"/)){ v=substr(p, RSTART+11, RLENGTH-12); proj=v }" +
                  "     else if(match(p, /\"area\":\"[^\"]*\"/)){ v=substr(p, RSTART+8, RLENGTH-9); ar=v }" +
                  "     else if(match(p, /\"intent\":\"[^\"]*\"/)){ v=substr(p, RSTART+10, RLENGTH-11); it=v }" +
                  "     else if(match(p, /\"ts_heartbeat\":[0-9]+/)){ v=substr(p, RSTART+15, RLENGTH-15); hb=v+0 }" +
                  "   }" +
                  "   if(hb>=cut && sid!=me && sid!=\"\") print sid \"|\" proj \"|\" ar \"|\" it \"|\" hb" +
                  " }' '" + REGISTRY + "' 2>/dev/null"
    let out = _str(exec(awk_cmd)).trim()
    if out == "" { return }  // silent — peers 없음

    // 카운트
    let lines = out.split("\n")
    let mut total: i64 = 0
    for ln in lines {
        let s = _str(ln).trim()
        if s.len() > 0 { total = total + 1 }
    }
    if total == 0 { return }

    // 나 포함 전체 활성 카운트 (제외 전)
    let all_cmd = "awk -v cut=" + to_string(cutoff) +
                  " '/\"status\":\"active\"/ {" +
                  "   hb=0;" +
                  "   if(match($0, /\"ts_heartbeat\":[0-9]+/)){ v=substr($0, RSTART+15, RLENGTH-15); hb=v+0 }" +
                  "   if(hb>=cut) c++" +
                  " } END{ print c+0 }' '" + REGISTRY + "' 2>/dev/null"
    let all_n = _to_int0(_str(exec(all_cmd)).trim())

    eprintln("[H-SESSION-REGISTRY] 활성 세션 " + to_string(all_n) + " (나 제외 " + to_string(total) + "):")
    for ln in lines {
        let s = _str(ln).trim()
        if s.len() == 0 { continue }
        let f = s.split("|")
        if f.len() < 5 { continue }
        let sid = _str(f[0])
        let proj = _str(f[1])
        let ar = _str(f[2])
        let it = _str(f[3])
        let hb = _to_int0(_str(f[4]))
        let age = now - hb
        let mut it_part = ""
        if it.len() > 0 { it_part = " intent=" + it }
        eprintln("  " + sid + " " + proj + "/" + ar + it_part + " age=" + to_string(age) + "s")
    }
}

// ─── gc — stale 마감 ───
fn cmd_gc(argv: [string]) {
    _ensure()
    let now = now_unix()
    let cutoff = now - STALE_AFTER
    // ts_heartbeat < cutoff AND status=active → stale 대상 session_id 추출
    let awk_cmd = "awk -v c=" + to_string(cutoff) +
                  " '/\"status\":\"active\"/ {" +
                  "   sid=\"\"; hb=0;" +
                  "   if(match($0, /\"session_id\":\"[^\"]+\"/)){ v=substr($0, RSTART+14, RLENGTH-15); sid=v }" +
                  "   if(match($0, /\"ts_heartbeat\":[0-9]+/)){ v=substr($0, RSTART+15, RLENGTH-15); hb=v+0 }" +
                  "   if(sid!=\"\" && hb>0 && hb<c) print sid" +
                  " }' '" + REGISTRY + "' 2>/dev/null"
    let stale_ids = _str(exec(awk_cmd)).trim()
    if stale_ids == "" {
        println("gc: 0 stale")
        return
    }
    let mut count: i64 = 0
    for sid in stale_ids.split("\n") {
        let id = _str(sid).trim()
        if id.len() == 0 { continue }
        let esc_id = id.replace("'", "")
        // status → stale
        let cmd1 = "/usr/bin/sed -i.bak '/\"session_id\":\"" + esc_id + "\"/ s/\"status\":\"active\"/\"status\":\"stale\"/' '" + REGISTRY + "' && rm -f '" + REGISTRY + ".bak'"
        exec(cmd1)
        // 캐시 파일 정리: session_id → ppid 를 직접 얻기 어려움. 대신 .session_id_* 를 스캔하여
        // 내용이 id 와 일치하면 삭제.
        let scan = "grep -l '^" + esc_id + "$' '" + HARNESS + "'/.session_id_* 2>/dev/null"
        let hits = _str(exec(scan)).trim()
        if hits.len() > 0 {
            for fp in hits.split("\n") {
                let f = _str(fp).trim()
                if f.len() > 0 {
                    exec("rm -f '" + f.replace("'", "") + "'")
                }
            }
        }
        count = count + 1
    }
    println("gc: " + to_string(count) + " stale")
}

// ─── self ───
fn cmd_self(argv: [string]) {
    _ensure()
    let skey = get_session_key()
    let sid = peek_session_id(skey)
    if sid == "" {
        println("(no session — register 먼저)")
        return
    }
    let esc = sid.replace("'", "")
    let out = _str(exec("grep '\"session_id\":\"" + esc + "\"' '" + REGISTRY + "' 2>/dev/null")).trim()
    if out == "" {
        println("(session_id=" + sid + " row 없음)")
        return
    }
    println(out)
}

fn main() {
    let argv = args()
    if argv.len() < 3 {
        eprintln("usage: session_registry <register|heartbeat|list|peers|gc|self> [args...]")
        exit(2)
    }
    let mode = argv[2].trim()
    if mode == "register" { cmd_register(argv) }
    else if mode == "heartbeat" { cmd_heartbeat(argv) }
    else if mode == "list" { cmd_list(argv) }
    else if mode == "peers" { cmd_peers(argv) }
    else if mode == "gc" { cmd_gc(argv) }
    else if mode == "self" { cmd_self(argv) }
    else {
        eprintln("REJECT: unknown mode '" + mode + "' — modes: register|heartbeat|list|peers|gc|self")
        exit(2)
    }
}

main()
