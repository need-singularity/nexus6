// prompt_scan.hexa — 사용자 프롬프트 명령 키워드 감지 (UserPromptSubmit 훅 대체)
// 역할: cmd-dispatch + go-parallel + nexus-prompt-scan 로직 통합
// usage: hexa run shared/harness/prompt_scan.hexa "<user_text>"
// output: 키워드 매칭 시 systemMessage/알림 stdout. 미매칭이면 무출력.

let HOME = env("HOME")
let HEXA = HOME + "/Dev/nexus/shared/bin/hexa"
let HARNESS = HOME + "/Dev/nexus/shared/harness"

fn main() {
    let argv = args()
    if argv.len() < 3 { return }
    let user_text = argv[2]
    let lower = user_text.trim().to_lower()
    if lower.len() == 0 { return }

    // 명령 키워드 레지스트리 (commands.json SSOT 미러)
    let cmds = [
        ["smash",    "smash|부셔|돌파|breakthrough|블로업|blowup"],
        ["go",       "go|가자"],
        ["keep",     "keep|계속|이어|continue|keepgoing"],
        ["todo",     "todo|할일"],
        ["free_dfs", "free|dfs|자유|탐색"],
        ["loop",     "loop|루프|정합"],
        ["roi",      "roi|투자수익|개선목록"],
        ["list",     "list|목록"],
        ["lm",       "lm|듀얼|dual"]
    ]

    let mut matched = ""
    let mut matched_kw = ""
    for cmd in cmds {
        let kws = cmd[1].split("|")
        for kw in kws {
            if lower.contains(kw) {
                matched = cmd[0]
                matched_kw = kw
                break
            }
        }
        if matched.len() > 0 { break }
    }

    if matched == "" { return }

    // seed 추출 (키워드 제거)
    let mut seed = ""
    let parts = user_text.split(matched_kw)
    let mut s = ""
    for p in parts {
        let tr = p.trim()
        if tr.len() > 0 {
            if s.len() > 0 { s = s + " " }
            s = s + tr
        }
    }
    seed = s

    // 출력 — Claude에게 힌트 전달
    let mut msg = "[CMD] " + matched
    if seed.len() > 0 { msg = msg + " | seed='" + seed + "'" }
    msg = msg + " | SSOT: shared/config/commands.json | gate: shared/harness/cmd_gate.hexa"

    // cmd_gate 사전 실행 (seed 품질 힌트)
    if matched == "smash" || matched == "free_dfs" {
        let cmd_name = matched
        let gate_cmd = HEXA + " run " + HARNESS + "/cmd_gate.hexa " + cmd_name + " '" + seed.replace("'", "") + "' 2>&1"
        let gate_out = to_string(exec(gate_cmd)).trim()
        if gate_out.contains("REJECT") {
            msg = msg + "\n[GATE HINT] " + gate_out
        }
    }

    println(msg)
}

main()
