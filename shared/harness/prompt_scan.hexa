// prompt_scan.hexa — 사용자 프롬프트 명령 키워드 감지 (UserPromptSubmit 훅 대체)
// 역할: cmd-dispatch + go-parallel + nexus-prompt-scan 로직 통합
// usage: hexa run shared/harness/prompt_scan.hexa "<user_text>"
// output: 키워드 매칭 시 systemMessage/알림 stdout. 미매칭이면 무출력.

let HOME = env("HOME")
let HEXA = HOME + "/Dev/nexus/shared/bin/hexa"
let HARNESS = HOME + "/Dev/nexus/shared/harness"
let CMDS_JSON = HOME + "/Dev/nexus/shared/config/commands.json"

// commands.json SSOT 동적 로드 — 공용 + project_specific[git basename] 머지.
// 하드코딩 미러 금지 (R36 후보, drift 0).
fn load_cmds_from_ssot() {
    let mut cmds = []

    // 공용 commands
    let q1 = "/usr/bin/jq -r '.commands | to_entries[] | \"\\(.key)\\t\\(.value.keywords | join(\"|\"))\"' '" + CMDS_JSON + "' 2>/dev/null"
    let out1 = to_string(exec(q1)).trim()
    for line in out1.split("\n") {
        if line.len() == 0 { continue }
        let parts = line.split("\t")
        if parts.len() >= 2 {
            cmds = cmds.push([parts[0], parts[1]])
        }
    }

    // 프로젝트별 (git basename 기반)
    let proj = to_string(exec("basename \"$(git rev-parse --show-toplevel 2>/dev/null)\" 2>/dev/null")).trim()
    if proj.len() > 0 {
        let q2 = "/usr/bin/jq -r --arg p '" + proj + "' '.project_specific[$p] // {} | to_entries[] | \"\\(.key)\\t\\(.value.keywords | join(\"|\"))\"' '" + CMDS_JSON + "' 2>/dev/null"
        let out2 = to_string(exec(q2)).trim()
        for line in out2.split("\n") {
            if line.len() == 0 { continue }
            let parts = line.split("\t")
            if parts.len() >= 2 {
                cmds = cmds.push([parts[0], parts[1]])
            }
        }
    }

    return cmds
}

// H-PROJ-ALL — 전체/모든 프로젝트 맥락 발화 시 projects.json SSOT 참조 힌트
fn check_proj_all(lower: str) {
    let kws = [
        "전체 프로젝트",
        "모든 프로젝트",
        "프로젝트 전부",
        "프로젝트 목록",
        "all projects",
        "every project",
        "project list"
    ]
    for k in kws {
        if lower.contains(k) {
            println("[H-PROJ-ALL] 프로젝트 목록/전체 적용은 shared/config/projects.json (.projects) SSOT 참조 강제")
            return
        }
    }
}

// H-NOHOOK — 사용자 발화에 훅/hook/settings hooks 등 키워드 감지 시 사전 경고
// 정책: hook 신규 작성 금지, 모든 자동 강제는 shared/harness/entry.hexa 자율 호출로.
// 우회: NEXUS_HOOK_OK=1 env 또는 경로/텍스트에 '@allow-hook' 토큰.
// SSOT: shared/harness/enforcement_registry.json (rules[] .id=="H-NOHOOK")
fn check_no_hook_keyword(lower: str) {
    if env("NEXUS_HOOK_OK") == "1" { return }
    if lower.contains("@allow-hook") { return }
    let kws = [
        "훅 ",
        " 훅",
        "훅을",
        "훅에",
        "훅으로",
        "훅 시스템",
        "훅 만",
        "훅 추가",
        "훅 생성",
        " hook ",
        " hook을",
        " hook으로",
        "hook 추가",
        "hook 생성",
        "claude code cli hook",
        "settings.json hooks",
        "settings hooks",
        "pre-commit hook",
        "post-commit hook",
        "pretooluse",
        "posttooluse",
        "userpromptsubmit",
        "stop hook",
        "precompact hook",
        "core.hookspath"
    ]
    for k in kws {
        if lower.contains(k) {
            println("[H-NOHOOK] 훅 관련 발화 감지 — 정책: hook 신규 작성 금지. 모든 자동 강제는 shared/harness/entry.hexa 자율 호출로 대체 (공용, 전 프로젝트). 기존 강제 레이어 조회: jq '.rules[] | select(.id==\"H-NOHOOK\")' shared/harness/enforcement_registry.json | 우회: NEXUS_HOOK_OK=1")
            return
        }
    }
}

fn main() {
    let argv = args()
    if argv.len() < 3 { return }
    let user_text = argv[2]
    let lower = user_text.trim().to_lower()
    if lower.len() == 0 { return }

    // H-ERR-DRAIN — errors.jsonl open 카운트 임계치 초과 시 drain 경고
    if env("NEXUS_DRAIN_OK") != "1" {
        let drain_cmd = HEXA + " run " + HARNESS + "/errors.hexa drain_check 10 2>&1"
        let drain_out = to_string(exec(drain_cmd)).trim()
        if drain_out.len() > 0 { println(drain_out) }
    }

    // H-GIT-FRESH — 30분 stale 시 fetch + origin drift alert (세션 간 commit 중복 방지)
    let gf_cmd = HEXA + " run " + HARNESS + "/git_fresh.hexa check 2>&1"
    let gf_out = to_string(exec(gf_cmd)).trim()
    if gf_out.len() > 0 { println(gf_out) }

    // H-SESSION-REGISTRY — 세션 manifest 갱신 + 다른 활성 세션 노출
    exec(HEXA + " run " + HARNESS + "/session_registry.hexa register nexus harness prompt_in >/dev/null 2>&1")
    let peers_cmd = HEXA + " run " + HARNESS + "/session_registry.hexa peers 2>&1 1>/dev/null"
    let peers_out = to_string(exec(peers_cmd)).trim()
    if peers_out.len() > 0 { println(peers_out) }

    // H-BROADCAST — 최근 5분 shared/ 변경 tail (cross-project 가시화)
    let bc_cmd = HEXA + " run " + HARNESS + "/broadcast.hexa tail 300 2>&1"
    let bc_out = to_string(exec(bc_cmd)).trim()
    if bc_out.len() > 0 { println(bc_out) }

    // H-SECURITY — passive secret/path 스캔 (실패 무시, 본체 영향 X)
    let sec_text = user_text.replace("\"", "\\\"")
    exec(HEXA + " run " + HARNESS + "/security_scan.hexa prompt \"" + sec_text + "\" 2>/dev/null")

    // H-PROJ-ALL 힌트 (info, 비블로킹, 1회만)
    check_proj_all(lower)

    // H-NOHOOK 키워드 감지 (info, pre_tool_guard 가 실제 차단 담당)
    check_no_hook_keyword(lower)

    let cmds = load_cmds_from_ssot()
    if cmds.len() == 0 { return }  // SSOT 로드 실패 시 silent (jq 누락 등)

    let mut matched = ""
    let mut matched_kw = ""
    for cmd in cmds {
        let kws = cmd[1].split("|")
        for kw in kws {
            if lower.contains(kw) {
                matched = cmd[0]
                matched_kw = kw
                break
            }
        }
        if matched.len() > 0 { break }
    }

    if matched == "" { return }

    // seed 추출 (키워드 제거)
    let mut seed = ""
    let parts = user_text.split(matched_kw)
    let mut s = ""
    for p in parts {
        let tr = p.trim()
        if tr.len() > 0 {
            if s.len() > 0 { s = s + " " }
            s = s + tr
        }
    }
    seed = s

    // 출력 — Claude에게 힌트 전달
    let mut msg = "[CMD] " + matched
    if seed.len() > 0 { msg = msg + " | seed='" + seed + "'" }
    msg = msg + " | SSOT: shared/config/commands.json | gate: shared/harness/cmd_gate.hexa"

    // cmd_gate 사전 실행 (seed 품질 힌트)
    if matched == "smash" || matched == "free_dfs" {
        let cmd_name = matched
        let gate_cmd = HEXA + " run " + HARNESS + "/cmd_gate.hexa " + cmd_name + " '" + seed.replace("'", "") + "' 2>&1"
        let gate_out = to_string(exec(gate_cmd)).trim()
        if gate_out.contains("REJECT") {
            msg = msg + "\n[GATE HINT] " + gate_out
        }
    }

    println(msg)

    // R35 H-MINPATH: 'go'/'가자'/'진행' 감지 시 최소 경로 SSOT 적용 hint
    if matched == "go" || matched == "keep" {
        println("[H-MINPATH] 최소 경로 SSOT 적용 — 직전 옵션 중 decision_order(blocker=0 → steps↑min → loc↑min → 첫번째) 자동 픽 + 즉시 실행. 추가 확인/재질문 금지. SSOT: shared/harness/minimal_path.json")
    }
}

main()
