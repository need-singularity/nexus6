// py_ban_guard.hexa — R37/AN13/L3-PY staged .py 차단
// (2026-04-18 BG 에이전트 pod2 위반 사고 재발 방지)
//
// Usage:
//   hexa $NEXUS/shared/harness/py_ban_guard.hexa check-staged
//     → staged 에 .py 있으면 exit 1 + 사유 출력
//   hexa $NEXUS/shared/harness/py_ban_guard.hexa check-cmd '<bash cmd>'
//     → 명령어에 python/.py 실행·전송·원격실행 패턴 있으면 exit 1
//
// 연동:
//   .git/hooks/pre-commit — check-staged 호출
//   .claude/settings.json PreToolUse Bash — check-cmd 백업 (인라인 grep 이 1차)
//   shared/agent_templates/no_py_guardrail.md — 에이전트 프롬프트 연결

use std::process
use std::string

fn main() {
  let args = process::args()
  if args.len() < 2 {
    println("usage: py_ban_guard.hexa <check-staged|check-cmd> [arg]")
    process::exit(2)
  }

  let mode = args[1]

  if mode == "check-staged" {
    check_staged()
  } else if mode == "check-cmd" {
    if args.len() < 3 {
      println("check-cmd needs command string")
      process::exit(2)
    }
    check_cmd(args[2])
  } else {
    println("unknown mode: " + mode)
    process::exit(2)
  }
}

// git diff --cached --name-only 에서 .py 탐지
fn check_staged() {
  let out = process::exec("git", ["diff", "--cached", "--name-only", "--diff-filter=ACM"])
  let lines = string::split(out, "\n")
  let mut violations = []
  for line in lines {
    if string::ends_with(line, ".py") && line != "" {
      violations = violations + [line]
    }
  }
  if violations.len() > 0 {
    println("[py_ban_guard] BLOCK — R37/AN13/L3-PY: staged .py 발견")
    for v in violations {
      println("    " + v)
    }
    println("")
    println("  fix: git reset HEAD <file> 로 unstage + .hexa 재작성")
    println("  refs: CLAUDE.md / common.json#R37 / anima.json#AN13 / lockdown.json#L3-PY")
    process::exit(1)
  }
  process::exit(0)
}

// 명령어 패턴 검사 — 훅 백업 로직 (hexa fallback)
fn check_cmd(cmd string) {
  // 단순 조회는 허용
  let allow_prefix = ["which ", "type ", "command -v ", "ls ", "grep ", "rg ", "find ", "wc ", "stat ", "file ", "head ", "tail ", "cat "]
  for p in allow_prefix {
    if string::starts_with(string::trim(cmd), p) {
      process::exit(0)
    }
  }

  // 금지 패턴 — string::contains 기반 (정규식 부재 fallback)
  // python 실행
  if contains_token(cmd, "python3") || contains_token(cmd, "python") || contains_token(cmd, "pypy") {
    deny(cmd, "python 실행 금지")
  }
  // .py 직접
  if string::contains(cmd, ".py ") || string::ends_with(cmd, ".py") {
    deny(cmd, ".py 실행/전송 금지")
  }
  // scp/rsync/runpodctl
  if string::contains(cmd, "scp ") && string::contains(cmd, ".py") {
    deny(cmd, "scp .py 전송 금지")
  }
  if string::contains(cmd, "rsync ") && string::contains(cmd, ".py") {
    deny(cmd, "rsync .py 전송 금지")
  }
  if string::contains(cmd, "runpodctl") && (string::contains(cmd, ".py") || string::contains(cmd, "python")) {
    deny(cmd, "runpodctl .py/python 금지")
  }
  // ssh 원격 python
  if string::starts_with(string::trim(cmd), "ssh ") && (string::contains(cmd, "python") || string::contains(cmd, ".py")) {
    deny(cmd, "ssh 원격 python 금지")
  }
  // git add .py
  if string::contains(cmd, "git add") && string::contains(cmd, ".py") {
    deny(cmd, ".py git add 금지")
  }
  process::exit(0)
}

fn contains_token(haystack string, token string) -> bool {
  // 간단 토큰 매치 — 앞뒤 공백/파이프/세미콜론 경계
  let padded = " " + haystack + " "
  let candidates = [" " + token + " ", " " + token + "\n", ";" + token + " ", "|" + token + " ", "&" + token + " "]
  for c in candidates {
    if string::contains(padded, c) {
      return true
    }
  }
  return false
}

fn deny(cmd string, reason string) {
  println("[py_ban_guard] BLOCK — R37/AN13/L3-PY: " + reason)
  println("    cmd: " + cmd)
  println("    refs: .claude/settings.json PreToolUse Bash + common.json#R37 + anima.json#AN13")
  process::exit(1)
}
