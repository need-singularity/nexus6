{
  "id": "enforcement-registry",
  "description": "하네스 강제 레이어 SSOT — 각 H-룰이 어디서 어떻게 강제되는지 ai-native 인덱스. 공용/프로젝트별 스코프 + layer × file:line × action.",
  "version": "1.0.0",
  "updated": "2026-04-14",
  "scope_default": "all_projects",
  "layers_order": [
    "prompt",
    "pre_write",
    "pre_bash",
    "pre_agent",
    "post_bash",
    "post_edit",
    "lint",
    "permissions_deny",
    "commit_msg"
  ],
  "actions": {
    "warn": "stdout 메시지, 차단 없음 (정보성)",
    "reject": "pre_tool_guard 에서 stdout REJECT + stderr — Write/Edit/Bash 호출 차단",
    "error": "lint.hexa 가 error level 로 기록 + pre-commit 차단",
    "deny": "Claude Code permissions.deny 패턴 매칭 — tool 호출 자체 거부",
    "block": "commit-msg 훅이 커밋 메시지 검증 실패 → commit abort"
  },
  "rules": [
    {
      "id": "H-NOHOOK",
      "desc": "hook 시스템 신규 작성 금지 — 모든 자동 강제는 shared/harness/entry.hexa 자율 호출로",
      "scope": "global",
      "bypass": ["env:NEXUS_HOOK_OK=1", "path:@allow-hook"],
      "triggers": [
        "훅 ",
        " 훅",
        "훅을",
        "훅에",
        "훅 시스템",
        " hook",
        "hook ",
        "hook을",
        "claude code cli hook",
        "settings.json hooks",
        "pre-commit hook",
        "pretooluse",
        "posttooluse",
        "userpromptsubmit",
        "stop hook",
        "precompact"
      ],
      "layers": {
        "prompt": {
          "file": "shared/harness/prompt_scan.hexa",
          "fn": "check_no_hook_keyword",
          "action": "warn"
        },
        "pre_write": {
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_no_hook_file",
          "line": 254,
          "action": "reject"
        },
        "pre_bash": {
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_no_hook_cmd",
          "line": 507,
          "action": "reject"
        },
        "lint": {
          "file": "shared/harness/lint.hexa",
          "fn": "check_h_nohook",
          "line": 1676,
          "action": "error"
        },
        "permissions_deny": {
          "file": "shared/config/permissions_ssot.json",
          "categories": ["global_claude_protect", "shared_hooks_archive"],
          "action": "deny"
        }
      },
      "exempt_paths": [
        ".git/hooks/commit-msg",
        ".git/hooks/pre-commit",
        ".git/hooks/post-commit",
        ".git/hooks/pre-push",
        ".githooks/commit-msg",
        ".githooks/pre-commit",
        "*.sample",
        "shared/archive/",
        "/archive/superseded-",
        "/archive/deprecated_"
      ]
    },
    {
      "id": "H-NOARCHIVE",
      "desc": "*.bak / backup/ / archive/ 폴더·파일 신규 작성 금지 — git commit 이 버전관리 SSOT",
      "scope": "global",
      "bypass": ["env:NEXUS_ARCHIVE_OK=1"],
      "triggers": ["백업 생성", "archive 폴더 만", "bak 파일", "백업해"],
      "layers": {
        "pre_write": {
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_no_archive_path",
          "line": 159,
          "action": "reject"
        },
        "pre_bash": {
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_no_archive_cmd",
          "line": 459,
          "action": "reject"
        },
        "lint": {
          "file": "shared/harness/lint.hexa",
          "fn": "check_h_noarchive",
          "action": "error"
        }
      }
    },
    {
      "id": "H-NONAME-V",
      "desc": "파일/폴더명 버전 suffix 금지 (_v2/_mk3/.v4/_new/_copy 등) — git commit/branch/tag SSOT",
      "scope": "global",
      "bypass": [],
      "layers": {
        "pre_write": {
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_no_version_name",
          "action": "reject"
        },
        "lint": {
          "file": "shared/harness/lint.hexa",
          "fn": "check_h_noname_v",
          "action": "error"
        }
      }
    },
    {
      "id": "H-MD2PDF",
      "desc": "MD→PDF 변환은 md-to-pdf 전용. pandoc/xelatex/pdflatex/lualatex 금지",
      "scope": "global",
      "bypass": ["env:NEXUS_PDF_OK=1"],
      "triggers": ["pdf 로 변환", "md to pdf", "pandoc"],
      "layers": {
        "pre_bash": {
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_md_to_pdf_cmd",
          "line": 332,
          "action": "reject"
        }
      }
    },
    {
      "id": "H-SEND-GUARD",
      "desc": "외부 발송/등록 사용자 명시 요청 전 금지 — gh issue/PR, 이메일, slack/discord webhook 차단",
      "scope": "global",
      "bypass": ["env:NEXUS_SEND_OK=1"],
      "triggers": ["이슈 만들", "pr 올", "slack 으로", "discord 로", "이메일 보내"],
      "layers": {
        "pre_bash": {
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_external_send_cmd",
          "action": "reject"
        }
      }
    },
    {
      "id": "H-NOBLOCK",
      "desc": "세션 채팅 블로킹 금지 — read -p/wait/fg/sleep>=10/while+sleep 차단. ScheduleWakeup/Monitor/run_in_background 강제",
      "scope": "global",
      "bypass": ["env:NEXUS_BLOCK_OK=1"],
      "layers": {
        "pre_bash": {
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_blocking_cmd",
          "action": "reject"
        }
      }
    },
    {
      "id": "H-HEXA-FIRST",
      "desc": "R1 — .py/.rs/.sh 신규 작성 금지 (기존 편집은 Edit 가능)",
      "scope": "global",
      "bypass": [],
      "layers": {
        "pre_write": {
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_forbidden_ext",
          "action": "reject"
        },
        "permissions_deny": {
          "file": "shared/config/permissions_ssot.json",
          "categories": ["hexa_first"],
          "action": "deny"
        },
        "lint": {
          "file": "shared/harness/lint.hexa",
          "fn": "check_r1_hexa_first",
          "action": "error"
        }
      }
    },
    {
      "id": "H-L0-PROTECT",
      "desc": "shared/config/ L0 파일 직접 수정 금지 — absolute_rules/core/core-lockdown",
      "scope": "global",
      "bypass": [],
      "layers": {
        "pre_write": {
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_shared_protected",
          "action": "reject"
        },
        "permissions_deny": {
          "file": "shared/config/permissions_ssot.json",
          "categories": ["shared_l0_protect"],
          "action": "deny"
        }
      }
    },
    {
      "id": "H-GLOBAL-CLAUDE",
      "desc": "~/.claude/ 글로벌 내부 직접 수정 금지 (settings.json 만 허용)",
      "scope": "global",
      "bypass": [],
      "layers": {
        "pre_write": {
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_global_claude",
          "action": "reject"
        },
        "permissions_deny": {
          "file": "shared/config/permissions_ssot.json",
          "categories": ["global_claude_protect"],
          "action": "deny"
        },
        "audit": {
          "file": "shared/harness/global_claude_guard.hexa",
          "action": "warn"
        }
      }
    },
    {
      "id": "H-COMMIT",
      "desc": "commit.hexa 544줄 + .githooks wrapper + 8단계 검증 체인 — pre-commit/commit-msg/post-commit/pre-push",
      "scope": "global",
      "bypass": [],
      "layers": {
        "commit_msg": {
          "file": ".git/hooks/commit-msg",
          "chain": "HARNESS-LOCK / L0 / N6-JSONPAIR",
          "action": "block"
        },
        "pre_write": {
          "file": "shared/harness/commit.hexa",
          "action": "verify"
        }
      }
    },
    {
      "id": "H-SESSION-LOCK",
      "desc": "파일 area 기반 advisory lockdir — 멀티세션 race 방지 (WARN only)",
      "scope": "global",
      "bypass": ["env:NEXUS_LOCK_OK=1"],
      "layers": {
        "pre_write": {
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_session_lock",
          "action": "warn"
        }
      }
    },
    {
      "id": "H-NOZOMBIE",
      "desc": "좀비 프로세스 차단 5층 — perl_timeout/lock_gate/budget_gate/reaper + lib helpers",
      "scope": "global",
      "bypass": ["env:NEXUS_NO_TIMEOUT_OK=1", "env:NEXUS_LOCK_OK=1", "env:NEXUS_BUDGET_OK=1"],
      "layers": {
        "pre_bash": {
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_hexa_budget",
          "action": "reject"
        }
      }
    },
    {
      "id": "H-GIT-FRESH",
      "desc": "30분 stale 시 fetch + origin drift alert — 세션 간 commit 중복 방지",
      "scope": "global",
      "bypass": [],
      "layers": {
        "prompt": {
          "file": "shared/harness/git_fresh.hexa",
          "fn": "check",
          "action": "warn"
        }
      }
    },
    {
      "id": "H-PROJ-ALL",
      "desc": "전체/모든 프로젝트 맥락 발화 시 projects.json SSOT 참조 힌트",
      "scope": "global",
      "bypass": [],
      "layers": {
        "prompt": {
          "file": "shared/harness/prompt_scan.hexa",
          "fn": "check_proj_all",
          "action": "warn"
        }
      }
    },
    {
      "id": "H-MINPATH",
      "desc": "R35 — go/가자/진행 감지 시 최소 경로 SSOT 자동 픽 + 즉시 실행",
      "scope": "global",
      "bypass": [],
      "layers": {
        "prompt": {
          "file": "shared/harness/prompt_scan.hexa",
          "action": "warn"
        }
      }
    },
    {
      "id": "H-ERR-DRAIN",
      "desc": "errors.jsonl open 카운트 임계치 초과 시 drain 경고",
      "scope": "global",
      "bypass": ["env:NEXUS_DRAIN_OK=1"],
      "layers": {
        "prompt": {
          "file": "shared/harness/errors.hexa",
          "fn": "drain_check",
          "action": "warn"
        }
      }
    },
    {
      "id": "H-AGENT-PLACEHOLDER",
      "desc": "Agent 프롬프트에 placeholder 토큰 포함 시 차단",
      "scope": "global",
      "bypass": [],
      "layers": {
        "pre_agent": {
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_agent_placeholder",
          "action": "reject"
        }
      }
    }
  ],
  "project_specific_scopes": {
    "nexus": {
      "description": "nexus 리포 고유 강제 — atlas.n6 guard, discovery/reality_map 경로 등",
      "rules": [
        {
          "id": "H-ATLAS-GUARD",
          "desc": "atlas.n6 전체 쓰기 가드 L0 — shared/blowup/lib/atlas_guard.hexa.inc _guarded_append_atlas()",
          "file": "shared/blowup/lib/atlas_guard.hexa.inc",
          "layer": "runtime"
        },
        {
          "id": "H-DISCOVERY-JSON",
          "desc": "R29 — shared/discovery/*.json 경로 검증",
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_discovery_json_path",
          "layer": "pre_write"
        },
        {
          "id": "H-CALCULATOR-SSOT",
          "desc": "R34 — calculators.json SSOT 검증",
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_calculator_ssot",
          "layer": "pre_write"
        },
        {
          "id": "H-ROADMAP-MIN",
          "desc": "최소 로드맵 필드 검증",
          "file": "shared/harness/pre_tool_guard.hexa",
          "fn": "check_roadmap_min",
          "layer": "pre_write"
        }
      ]
    },
    "void": {
      "description": "void 터미널 고유 강제 — sys_* 접두 C/ObjC 파일 제한",
      "rules": []
    },
    "anima": {
      "description": "anima 고유 — 감정 factions / 6-phase reflection 정책",
      "rules": []
    },
    "n6-architecture": {
      "description": "n6 arch 고유 — §7 python 10섹션 진화, canonical v2 품질 게이트",
      "rules": []
    }
  },
  "query_examples": {
    "list_all_rules": "jq -r '.rules[].id' shared/harness/enforcement_registry.json",
    "show_rule_detail": "jq '.rules[] | select(.id==\"H-NOHOOK\")' shared/harness/enforcement_registry.json",
    "list_prompt_layer": "jq '.rules[] | select(.layers.prompt) | {id, fn: .layers.prompt.fn}' shared/harness/enforcement_registry.json",
    "list_reject_actions": "jq '[.rules[] | {id, rejects: [.layers | to_entries[] | select(.value.action==\"reject\") | .key]}] | map(select(.rejects | length > 0))' shared/harness/enforcement_registry.json",
    "list_by_file": "jq '[.rules[] | {id, files: [.layers | to_entries[].value.file] | unique}]' shared/harness/enforcement_registry.json",
    "list_triggers": "jq '[.rules[] | select(.triggers) | {id, triggers}]' shared/harness/enforcement_registry.json",
    "list_bypasses": "jq '[.rules[] | select(.bypass and (.bypass | length > 0)) | {id, bypass}]' shared/harness/enforcement_registry.json",
    "project_specific": "jq '.project_specific_scopes.nexus.rules' shared/harness/enforcement_registry.json"
  },
  "note": "추가/수정 시 반드시 실제 file:fn:line 정확히 기재 (drift 방지). 새 H-룰 추가 시 pre_tool_guard/lint/prompt_scan 중 적어도 하나에 실제 코드 존재해야 함."
}
