// ═══════════════════════════════════════════════════════════
// gc.hexa — 하네스 P3 가비지 컬렉션
// 3 스캔: drift (문서↔실제) / dead (미참조) / violation (규칙 위반)
// Usage:
//   hexa shared/harness/gc.hexa --scan          (3 전부)
//   hexa shared/harness/gc.hexa --drift         (drift 만)
//   hexa shared/harness/gc.hexa --violation     (violation 만)
//   hexa shared/harness/gc.hexa --dead          (dead 만, 느림)
//   hexa shared/harness/gc.hexa --rotate        (대용량 jsonl 회전, keep 10000)
//   hexa shared/harness/gc.hexa --report        (최근 로그 요약)
// 출력: shared/harness/gc_log.jsonl (append), stdout 요약
// ═══════════════════════════════════════════════════════════

let REPO_ROOT = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
let SHARED_DIR = REPO_ROOT + "/shared"
let GC_LOG = SHARED_DIR + "/harness/gc_log.jsonl"
let MISTAKES_LOG = SHARED_DIR + "/harness/mistakes.jsonl"

fn now_iso() -> string {
    return exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    return r
}

// void-safe coercion (hexa "".split() 첫 원소 void 반환 이슈)
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

// last_index_of 미지원 우회
fn _rfind(s: string, ch: string) -> i64 {
    let n = len(s)
    let mut i: i64 = n - 1
    while i >= 0 {
        if s.substring(i, i + 1) == ch { return i }
        i = i - 1
    }
    return -1
}

// ─── Scan 1: DRIFT — CLAUDE.md 에 언급된 경로가 실제 존재하는가 ───

fn scan_drift() -> [string] {
    let mut findings: [string] = []
    // 대상 CLAUDE.md 목록
    let cmd = "find " + REPO_ROOT + " -maxdepth 4 -name 'CLAUDE.md' -not -path '*/node_modules/*' -not -path '*/.git/*' -not -path '*/.claude/worktrees/*' -not -path '*/archive/*' -not -path '*/_archive/*' 2>/dev/null"
    let claude_files_raw = _str(exec(cmd)).trim()
    if claude_files_raw == "" { return findings }

    for cf in claude_files_raw.split("\n") {
        let cfp = _str(cf).trim()
        if cfp == "" { continue }
        // 경로 후보 추출: "shared/xxx/yyy.ext" 패턴
        // python3 한 줄로 추출 (regex)
        // alternation 우선순위: 긴 확장자 먼저 (hexa.inc/jsonl) → .hexa.inc 와 .jsonl 정확 매칭
        let ext_cmd = "python3 -c \"import re,sys; t=open('" + cfp + "').read(); [print(m) for m in sorted(set(re.findall(r'(shared/[A-Za-z0-9._/\\-]+\\.(?:hexa\\.inc|jsonl|hexa|json|md|txt|html))', t)))]\" 2>/dev/null"
        let refs_raw = _str(exec(ext_cmd)).trim()
        if refs_raw == "" { continue }
        for r in refs_raw.split("\n") {
            let rel = _str(r).trim()
            if rel == "" { continue }
            // glob 패턴 (*) 제외 — 존재 검증 불가능
            if rel.index_of("*") >= 0 { continue }
            let abs = REPO_ROOT + "/" + rel
            if !file_exists(abs) {
                findings = findings.push("drift|warn|" + cfp.replace(REPO_ROOT + "/", "") + "|" + rel + "|missing")
            }
        }
    }
    return findings
}

// ─── Scan 2: VIOLATION — 규칙 위반 grep ───

fn scan_violations() -> [string] {
    let mut findings: [string] = []
    // R1: shared/ 아래 .rs/.py/.sh (exceptions: shared/scripts/, shared/bin/)
    let cmd1 = "find " + SHARED_DIR + " -type f \\( -name '*.py' -o -name '*.sh' -o -name '*.rs' \\) -not -path '*/scripts/*' -not -path '*/bin/*' -not -path '*/.git/*' -not -path '*/.claude/worktrees/*' -not -path '*/archive/*' -not -path '*/_archive/*' 2>/dev/null"
    let r1_raw = _str(exec(cmd1)).trim()
    if r1_raw != "" {
        for f in r1_raw.split("\n") {
            let fp = _str(f).trim()
            if fp == "" { continue }
            let rel = fp.replace(REPO_ROOT + "/", "")
            findings = findings.push("violation|error|" + rel + "|R1|HEXA-FIRST 위반: ai-native algorism 으로 재작성")
        }
    }
    // R14: shared/rules/ 아래 .md 파일 (CLAUDE.md 제외). .claude/worktrees/ 제외 방어.
    let cmd2 = "find " + SHARED_DIR + "/rules -type f -name '*.md' -not -path '*/.claude/worktrees/*' 2>/dev/null"
    let r2_raw = _str(exec(cmd2)).trim()
    if r2_raw != "" {
        for f in r2_raw.split("\n") {
            let fp = _str(f).trim()
            if fp == "" { continue }
            let bn = fp.substring(_rfind(fp, "/") + 1, len(fp))
            if bn == "CLAUDE.md" { continue }
            let rel = fp.replace(REPO_ROOT + "/", "")
            findings = findings.push("violation|warn|" + rel + "|R14|rules SSOT 는 JSON 만")
        }
    }
    return findings
}

// ─── Scan 3: DEAD — shared/ 파일 중 어디서도 참조되지 않는 것 ───

fn scan_dead() -> [string] {
    let mut findings: [string] = []
    // 대상: shared/ 아래 .hexa / .json 중 90일 이상 미변경
    let cmd = "find " + SHARED_DIR + " -type f \\( -name '*.hexa' -o -name '*.json' \\) -mtime +90 -not -path '*/.git/*' -not -path '*/.claude/worktrees/*' -not -path '*/archive/*' -not -path '*/_archive/*' -not -path '*/backups/*' -not -path '*/archive/*' 2>/dev/null"
    let files_raw = _str(exec(cmd)).trim()
    if files_raw == "" { return findings }

    for f in files_raw.split("\n") {
        let fp = _str(f).trim()
        if fp == "" { continue }
        let bn = fp.substring(_rfind(fp, "/") + 1, len(fp))
        // 자기자신 제외 grep — shared/ 전체에서 basename 참조 개수
        let cnt_cmd = "grep -r --include='*.hexa' --include='*.json' --include='*.jsonl' --include='*.md' -l '" + bn + "' " + SHARED_DIR + " 2>/dev/null | grep -v '" + fp + "' | head -1"
        let has_ref = _str(exec(cnt_cmd)).trim()
        if has_ref == "" {
            let rel = fp.replace(REPO_ROOT + "/", "")
            findings = findings.push("dead|info|" + rel + "|unreferenced|90일+ 미변경, 타 파일 참조 0")
        }
    }
    return findings
}

// ─── Scan 4: ROTATE — 대용량 jsonl 회전 (keep last N lines, in-place) ───

fn rotate_one(path: string, keep: i64) -> [i64] {
    // 라인 수 조사 (wc -l)
    let wc_raw = _str(exec("wc -l < '" + path + "' 2>/dev/null")).trim()
    if wc_raw == "" { return [0, 0] }
    let mut total: i64 = 0
    try { total = to_int(wc_raw) } catch e { total = 0 }
    if total <= keep { return [0, total] }
    // tail -n keep > tmp && mv tmp path (in-place)
    let tmp = path + ".tmp"
    exec("tail -n " + to_string(keep) + " '" + path + "' > '" + tmp + "' && mv '" + tmp + "' '" + path + "' 2>/dev/null")
    let removed = total - keep
    return [removed, keep]
}

fn scan_rotate() -> [string] {
    let mut findings: [string] = []
    let keep: i64 = 10000
    // 대상 jsonl 목록 (harness/ 아래)
    let targets = [
        "lint_log.jsonl",
        "mistakes.jsonl",
        "gc_log.jsonl",
        "rules_usage.jsonl",
        "broadcast.jsonl",
        "errors.jsonl",
        "sync_log.jsonl",
        "cleanup_log.jsonl",
        "commit_log.jsonl",
        "lint_baseline.jsonl",
        "work_registry.jsonl",
        "autofix_proposals.jsonl",
        "session_registry.jsonl"
    ]
    for name in targets {
        let bn = _str(name)
        if bn == "" { continue }
        let fp = SHARED_DIR + "/harness/" + bn
        if !file_exists(fp) { continue }
        let r = rotate_one(fp, keep)
        let removed = r[0]
        let kept = r[1]
        if removed <= 0 { continue }
        let before = removed + kept
        println("rotated: " + bn + " " + to_string(before) + "→" + to_string(kept) + " (-" + to_string(removed) + ")")
        findings = findings.push("rotate|warn|shared/harness/" + bn + "|rotate|" + to_string(before) + "→" + to_string(kept) + " (-" + to_string(removed) + ")")
    }
    return findings
}

// ─── Scan 5: PROMPT-GC — session-handoff-*.md 7일+ 파일 정리 ───
// 대상: ~/.claude-claude10/projects/*/memory/session-handoff-*.md (latest 제외, 7일+)
// cli_budget_gate 가 세션별로 생성하는 프롬프트 파일 — 이어받기 완료 후 누적 방지

fn scan_stale_session_prompts() -> [string] {
    let mut findings: [string] = []
    let home = _str(exec("printf %s \"$HOME\"")).trim()
    if home == "" { return findings }
    let base = home + "/.claude-claude10/projects"
    if !file_exists(base) { return findings }
    let cmd = "find '" + base + "' -type f -name 'session-handoff-*.md' -not -name 'session-handoff-latest.md' -mtime +7 2>/dev/null"
    let raw = _str(exec(cmd)).trim()
    if raw == "" { return findings }
    for f in raw.split("\n") {
        let fp = _str(f).trim()
        if fp == "" { continue }
        exec("rm -f '" + fp + "' 2>/dev/null")
        let rel = fp.replace(home, "~")
        findings = findings.push("stale|info|" + rel + "|session-handoff-gc|7일+ 프롬프트 삭제")
    }
    return findings
}

// ─── Append findings to gc_log.jsonl + mistakes.jsonl ───

fn log_findings(scan_type: string, findings: [string]) {
    let ts = now_iso()
    let mut items_json = "["
    let mut i: i64 = 0
    for f in findings {
        let fs = _str(f)
        if fs == "" { continue }
        let parts = fs.split("|")
        if len(parts) < 5 { continue }
        if i > 0 { items_json = items_json + "," }
        items_json = items_json + "{\"kind\":\"" + _str(parts[0]) + "\",\"severity\":\"" + _str(parts[1]) + "\",\"file\":\"" + json_escape(_str(parts[2])) + "\",\"rule\":\"" + json_escape(_str(parts[3])) + "\",\"hint\":\"" + json_escape(_str(parts[4])) + "\"}"
        i = i + 1
    }
    items_json = items_json + "]"
    let line = "{\"ts\":\"" + ts + "\",\"scan\":\"" + scan_type + "\",\"count\":" + to_string(len(findings)) + ",\"findings\":" + items_json + "}"
    try { exec("echo '" + line.replace("'", "'\\''") + "' >> '" + GC_LOG + "'") } catch e {}

    // mistakes.jsonl 에도 가끔 append (warn/error 만)
    for f in findings {
        let fs = _str(f)
        if fs == "" { continue }
        let parts = fs.split("|")
        if len(parts) < 5 { continue }
        let sev = _str(parts[1])
        if sev == "info" { continue }
        let m = "{\"ts\":\"" + ts + "\",\"kind\":\"gc_" + _str(parts[0]) + "\",\"file\":\"" + json_escape(_str(parts[2])) + "\",\"rule\":\"" + json_escape(_str(parts[3])) + "\",\"fix\":\"" + json_escape(_str(parts[4])) + "\"}"
        try { exec("echo '" + m.replace("'", "'\\''") + "' >> '" + MISTAKES_LOG + "'") } catch e {}
    }
}

// ─── Main ───

let a = args()
let mut do_drift = false
let mut do_violation = false
let mut do_dead = false
let mut do_rotate = false
let mut do_report = false
let mut do_prompt_gc = false
let mut ai: i64 = 2
while ai < len(a) {
    let t = a[ai]
    if t == "--scan" { do_drift = true; do_violation = true; do_dead = true; do_prompt_gc = true }
    else if t == "--drift" { do_drift = true }
    else if t == "--violation" { do_violation = true }
    else if t == "--dead" { do_dead = true }
    else if t == "--rotate" { do_rotate = true }
    else if t == "--report" { do_report = true }
    else if t == "--prompt-gc" { do_prompt_gc = true }
    ai = ai + 1
}

if !do_drift && !do_violation && !do_dead && !do_rotate && !do_report && !do_prompt_gc {
    // no-arg default = --scan (args() forwarding 이슈 우회)
    do_drift = true
    do_violation = true
    do_dead = true
    do_prompt_gc = true
}

if do_report {
    let last = exec("tail -5 '" + GC_LOG + "' 2>/dev/null").trim()
    if last == "" { println("(gc_log.jsonl empty)") } else { println(last) }
    exit(0)
}

let mut total: i64 = 0

if do_drift {
    let f = scan_drift()
    log_findings("drift", f)
    println("drift:     " + to_string(len(f)) + " findings")
    total = total + len(f)
}

if do_violation {
    let f = scan_violations()
    log_findings("violation", f)
    println("violation: " + to_string(len(f)) + " findings")
    total = total + len(f)
}

if do_dead {
    let f = scan_dead()
    log_findings("dead", f)
    println("dead:      " + to_string(len(f)) + " findings")
    total = total + len(f)
}

if do_rotate {
    // rotate 는 gc_log.jsonl 자체도 truncate 하므로 log_findings 가 그 후 1줄만 append
    let f = scan_rotate()
    log_findings("rotate", f)
    println("rotate:    " + to_string(len(f)) + " files")
    total = total + len(f)
}

if do_prompt_gc {
    let f = scan_stale_session_prompts()
    log_findings("prompt_gc", f)
    println("prompt_gc: " + to_string(len(f)) + " files")
    total = total + len(f)
}

// ─── Agent ledger gc — 3600s+ 활성 → stale 마감 (H-AGENT-LEDGER) ───
let ledger = SHARED_DIR + "/harness/agent_ledger.hexa"
if file_exists(ledger) {
    let hexa_bin = REPO_ROOT + "/shared/bin/hexa"
    let out = _str(exec(hexa_bin + " run '" + ledger + "' gc 2>&1")).trim()
    if out.len() > 0 { println("ledger:    " + out) }
}

println("total:     " + to_string(total))
println("log:       " + GC_LOG.replace(REPO_ROOT + "/", ""))
exit(0)
