// ═══════════════════════════════════════════════════════════
// gc.hexa — 하네스 P3 가비지 컬렉션 단일 라우터
// (gc-weekly + cleanup 흡수, 2026-04-14)
// 모드:
//   --scan          drift + violation + dead + prompt_gc (기본)
//   --drift         CLAUDE.md 경로 ↔ 실제 존재 불일치
//   --violation     규칙 위반 (R1 HEXA-FIRST, R14 rules SSOT)
//   --dead          shared/ 90일+ 미참조 파일 (느림)
//   --rotate        대용량 jsonl 회전 (keep 10000)
//   --prompt-gc     ~/.claude-claude10/** session-handoff-*.md 7일+
//   --report        최근 gc_log.jsonl tail 5
//   --weekly        7일 쿨다운 후 scan 실행 (gc-weekly 흡수)
//                   env HARNESS_GC_WEEKLY_MODE=force|status 대응
//   --cleanup       shared_survey.json 폐기 후보 실행 (cleanup 흡수)
//                   env HARNESS_CLEANUP_MODE=apply|force 대응
// 출력: shared/harness/gc_log.jsonl + cleanup_log.jsonl + stdout 요약
// ═══════════════════════════════════════════════════════════

let REPO_ROOT = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
let SHARED_DIR = REPO_ROOT + "/shared"
let GC_LOG = SHARED_DIR + "/harness/gc_log.jsonl"
let MISTAKES_LOG = SHARED_DIR + "/harness/mistakes.jsonl"
let WEEKLY_COOLDOWN = SHARED_DIR + "/harness/.gc_weekly_cooldown"
let WEEK_SEC: i64 = 604800
let SURVEY = SHARED_DIR + "/harness/shared_survey.json"
let CLEANUP_LOG = SHARED_DIR + "/harness/cleanup_log.jsonl"

fn now_iso() -> string {
    return exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn now_sec() -> i64 {
    let mut r: i64 = 0
    try { r = to_int(exec("date +%s").trim()) } catch e {}
    return r
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    return r
}

// void-safe coercion (hexa "".split() 첫 원소 void 반환 이슈)
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

// last_index_of 미지원 우회
fn _rfind(s: string, ch: string) -> i64 {
    let n = len(s)
    let mut i: i64 = n - 1
    while i >= 0 {
        if s.substring(i, i + 1) == ch { return i }
        i = i - 1
    }
    return -1
}

fn basename(path: string) -> string {
    let slash = _rfind(path, "/")
    if slash < 0 { return path }
    return path.substring(slash + 1, len(path))
}

// ─── Scan 1: DRIFT — CLAUDE.md 에 언급된 경로가 실제 존재하는가 ───

fn scan_drift() -> [string] {
    let mut findings: [string] = []
    let cmd = "find " + REPO_ROOT + " -maxdepth 4 -name 'CLAUDE.md' -not -path '*/node_modules/*' -not -path '*/.git/*' -not -path '*/.claude/worktrees/*' -not -path '*/archive/*' -not -path '*/_archive/*' 2>/dev/null"
    let claude_files_raw = _str(exec(cmd)).trim()
    if claude_files_raw == "" { return findings }

    for cf in claude_files_raw.split("\n") {
        let cfp = _str(cf).trim()
        if cfp == "" { continue }
        let ext_cmd = "python3 -c \"import re,sys; t=open('" + cfp + "').read(); [print(m) for m in sorted(set(re.findall(r'(shared/[A-Za-z0-9._/\\-]+\\.(?:hexa\\.inc|jsonl|hexa|json|md|txt|html))', t)))]\" 2>/dev/null"
        let refs_raw = _str(exec(ext_cmd)).trim()
        if refs_raw == "" { continue }
        for r in refs_raw.split("\n") {
            let rel = _str(r).trim()
            if rel == "" { continue }
            if rel.index_of("*") >= 0 { continue }
            let abs = REPO_ROOT + "/" + rel
            if !file_exists(abs) {
                findings = findings.push("drift|warn|" + cfp.replace(REPO_ROOT + "/", "") + "|" + rel + "|missing")
            }
        }
    }
    return findings
}

// ─── Scan 2: VIOLATION — 규칙 위반 grep ───

fn scan_violations() -> [string] {
    let mut findings: [string] = []
    let cmd1 = "find " + SHARED_DIR + " -type f \\( -name '*.py' -o -name '*.sh' -o -name '*.rs' \\) -not -path '*/scripts/*' -not -path '*/bin/*' -not -path '*/.git/*' -not -path '*/.claude/worktrees/*' -not -path '*/archive/*' -not -path '*/_archive/*' 2>/dev/null"
    let r1_raw = _str(exec(cmd1)).trim()
    if r1_raw != "" {
        for f in r1_raw.split("\n") {
            let fp = _str(f).trim()
            if fp == "" { continue }
            let rel = fp.replace(REPO_ROOT + "/", "")
            findings = findings.push("violation|error|" + rel + "|R1|HEXA-FIRST 위반: ai-native algorism 으로 재작성")
        }
    }
    let cmd2 = "find " + SHARED_DIR + "/rules -type f -name '*.md' -not -path '*/.claude/worktrees/*' 2>/dev/null"
    let r2_raw = _str(exec(cmd2)).trim()
    if r2_raw != "" {
        for f in r2_raw.split("\n") {
            let fp = _str(f).trim()
            if fp == "" { continue }
            let bn = fp.substring(_rfind(fp, "/") + 1, len(fp))
            if bn == "CLAUDE.md" { continue }
            let rel = fp.replace(REPO_ROOT + "/", "")
            findings = findings.push("violation|warn|" + rel + "|R14|rules SSOT 는 JSON 만")
        }
    }
    return findings
}

// ─── Scan 3: DEAD — shared/ 파일 중 어디서도 참조되지 않는 것 ───

fn scan_dead() -> [string] {
    let mut findings: [string] = []
    let cmd = "find " + SHARED_DIR + " -type f \\( -name '*.hexa' -o -name '*.json' \\) -mtime +90 -not -path '*/.git/*' -not -path '*/.claude/worktrees/*' -not -path '*/archive/*' -not -path '*/_archive/*' -not -path '*/backups/*' -not -path '*/archive/*' 2>/dev/null"
    let files_raw = _str(exec(cmd)).trim()
    if files_raw == "" { return findings }

    for f in files_raw.split("\n") {
        let fp = _str(f).trim()
        if fp == "" { continue }
        let bn = fp.substring(_rfind(fp, "/") + 1, len(fp))
        let cnt_cmd = "grep -r --include='*.hexa' --include='*.json' --include='*.jsonl' --include='*.md' -l '" + bn + "' " + SHARED_DIR + " 2>/dev/null | grep -v '" + fp + "' | head -1"
        let has_ref = _str(exec(cnt_cmd)).trim()
        if has_ref == "" {
            let rel = fp.replace(REPO_ROOT + "/", "")
            findings = findings.push("dead|info|" + rel + "|unreferenced|90일+ 미변경, 타 파일 참조 0")
        }
    }
    return findings
}

// ─── Scan 4: ROTATE — 대용량 jsonl 회전 (keep last N lines, in-place) ───

fn rotate_one(path: string, keep: i64) -> [i64] {
    let wc_raw = _str(exec("wc -l < '" + path + "' 2>/dev/null")).trim()
    if wc_raw == "" { return [0, 0] }
    let mut total: i64 = 0
    try { total = to_int(wc_raw) } catch e { total = 0 }
    if total <= keep { return [0, total] }
    let tmp = path + ".tmp"
    exec("tail -n " + to_string(keep) + " '" + path + "' > '" + tmp + "' && mv '" + tmp + "' '" + path + "' 2>/dev/null")
    let removed = total - keep
    return [removed, keep]
}

fn scan_rotate() -> [string] {
    let mut findings: [string] = []
    let keep: i64 = 10000
    let targets = [
        "lint_log.jsonl",
        "mistakes.jsonl",
        "gc_log.jsonl",
        "rules_usage.jsonl",
        "broadcast.jsonl",
        "errors.jsonl",
        "sync_log.jsonl",
        "cleanup_log.jsonl",
        "commit_log.jsonl",
        "lint_baseline.jsonl",
        "work_registry.jsonl",
        "autofix_proposals.jsonl",
        "session_registry.jsonl"
    ]
    for name in targets {
        let bn = _str(name)
        if bn == "" { continue }
        let fp = SHARED_DIR + "/harness/" + bn
        if !file_exists(fp) { continue }
        let r = rotate_one(fp, keep)
        let removed = r[0]
        let kept = r[1]
        if removed <= 0 { continue }
        let before = removed + kept
        println("rotated: " + bn + " " + to_string(before) + "→" + to_string(kept) + " (-" + to_string(removed) + ")")
        findings = findings.push("rotate|warn|shared/harness/" + bn + "|rotate|" + to_string(before) + "→" + to_string(kept) + " (-" + to_string(removed) + ")")
    }
    return findings
}

// ─── Scan 5: PROMPT-GC — session-handoff-*.md 7일+ 파일 정리 ───

fn scan_stale_session_prompts() -> [string] {
    let mut findings: [string] = []
    let home = _str(exec("printf %s \"$HOME\"")).trim()
    if home == "" { return findings }
    let base = home + "/.claude-claude10/projects"
    if !file_exists(base) { return findings }
    let cmd = "find '" + base + "' -type f -name 'session-handoff-*.md' -not -name 'session-handoff-latest.md' -mtime +7 2>/dev/null"
    let raw = _str(exec(cmd)).trim()
    if raw == "" { return findings }
    for f in raw.split("\n") {
        let fp = _str(f).trim()
        if fp == "" { continue }
        exec("rm -f '" + fp + "' 2>/dev/null")
        let rel = fp.replace(home, "~")
        findings = findings.push("stale|info|" + rel + "|session-handoff-gc|7일+ 프롬프트 삭제")
    }
    return findings
}

// ─── Append findings to gc_log.jsonl + mistakes.jsonl ───

fn log_findings(scan_type: string, findings: [string]) {
    let ts = now_iso()
    let mut items_json = "["
    let mut i: i64 = 0
    for f in findings {
        let fs = _str(f)
        if fs == "" { continue }
        let parts = fs.split("|")
        if len(parts) < 5 { continue }
        if i > 0 { items_json = items_json + "," }
        items_json = items_json + "{\"kind\":\"" + _str(parts[0]) + "\",\"severity\":\"" + _str(parts[1]) + "\",\"file\":\"" + json_escape(_str(parts[2])) + "\",\"rule\":\"" + json_escape(_str(parts[3])) + "\",\"hint\":\"" + json_escape(_str(parts[4])) + "\"}"
        i = i + 1
    }
    items_json = items_json + "]"
    let line = "{\"ts\":\"" + ts + "\",\"scan\":\"" + scan_type + "\",\"count\":" + to_string(len(findings)) + ",\"findings\":" + items_json + "}"
    try { exec("echo '" + line.replace("'", "'\\''") + "' >> '" + GC_LOG + "'") } catch e {}

    for f in findings {
        let fs = _str(f)
        if fs == "" { continue }
        let parts = fs.split("|")
        if len(parts) < 5 { continue }
        let sev = _str(parts[1])
        if sev == "info" { continue }
        let m = "{\"ts\":\"" + ts + "\",\"kind\":\"gc_" + _str(parts[0]) + "\",\"file\":\"" + json_escape(_str(parts[2])) + "\",\"rule\":\"" + json_escape(_str(parts[3])) + "\",\"fix\":\"" + json_escape(_str(parts[4])) + "\"}"
        try { exec("echo '" + m.replace("'", "'\\''") + "' >> '" + MISTAKES_LOG + "'") } catch e {}
    }
}

// ─── Cleanup 모드 (cleanup.hexa 흡수) ───

fn cleanup_extract_discard_paths() -> [string] {
    let mut paths: [string] = []
    if !file_exists(SURVEY) { return paths }
    let cmd = "awk '/\"high_confidence\"/{flag=1;next} flag && /\\],$|\\]$/{flag=0} flag' '" + SURVEY + "' | grep -oE '\"path\":[[:space:]]*\"[^\"]+\"' | sed 's/.*\"path\":[[:space:]]*\"//; s/\"$//'"
    let raw = _str(exec(cmd)).trim()
    if raw == "" { return paths }
    for ln in raw.split("\n") {
        let p = _str(ln).trim()
        if p == "" { continue }
        paths = paths.push(p)
    }
    return paths
}

fn cleanup_ref_count(path: string) -> i64 {
    let bn = basename(path)
    if bn == "" { return 0 }
    let excl = " | grep -v 'shared_survey.json' | grep -v 'shared/harness/archive/' | grep -v 'archive/survey_pending_review.json' | grep -v 'archive/full_cleanup_list.json' | grep -v 'shared/harness/lint_log.jsonl' | grep -v 'shared/harness/gc_log.jsonl' | grep -v 'shared/harness/mistakes.jsonl' | grep -v 'shared/harness/autofix_proposals.jsonl' | grep -v 'shared/harness/cleanup_log.jsonl' | grep -v 'shared/harness/rules_usage.jsonl'"
    let cmd = "grep -rl '" + bn + "' --include='*.hexa' --include='*.json' --include='*.jsonl' --include='*.md' '" + SHARED_DIR + "' '" + REPO_ROOT + "/archive' 2>/dev/null" + excl + " | grep -v '/" + bn + "$' | wc -l"
    let mut r: i64 = 0
    try { r = to_int(_str(exec(cmd)).trim()) } catch e { r = 0 }
    return r
}

fn cleanup_path_exists(path: string) -> bool {
    let full = REPO_ROOT + "/" + path
    return file_exists(full)
}

fn cleanup_delete_file(path: string) -> bool {
    let full = REPO_ROOT + "/" + path
    try { exec("git -C '" + REPO_ROOT + "' rm -f '" + path + "' 2>/dev/null || rm -f '" + full + "'") } catch e { return false }
    return !file_exists(full)
}

fn run_cleanup() -> i64 {
    let mode = _str(env("HARNESS_CLEANUP_MODE")).trim()
    let force = mode == "force"
    let apply = mode == "apply" || force

    let paths = cleanup_extract_discard_paths()
    if len(paths) == 0 {
        println("cleanup:   폐기 후보 없음 (shared_survey.json 파싱 실패 가능)")
        return 0
    }

    let ts = now_iso()
    let mut safe_count: i64 = 0
    let mut skip_count: i64 = 0
    let mut deleted: i64 = 0
    let mut missing: i64 = 0

    println("== cleanup " + mode + " (" + to_string(len(paths)) + " 후보) ==")

    for p in paths {
        let path = _str(p).trim()
        if path == "" { continue }
        if path.index_of("*") >= 0 { continue }
        if !cleanup_path_exists(path) {
            missing = missing + 1
            println("  MISSING  " + path)
            continue
        }
        let refs = cleanup_ref_count(path)
        let safe = refs == 0
        let action = if apply && (safe || force) { "DELETE" } else { if safe { "READY" } else { "SKIP" } }
        let line = "{\"ts\":\"" + ts + "\",\"mode\":\"" + mode + "\",\"path\":\"" + json_escape(path) + "\",\"refs\":" + to_string(refs) + ",\"action\":\"" + action + "\"}"
        try { exec("echo '" + line.replace("'", "'\\''") + "' >> '" + CLEANUP_LOG + "'") } catch e {}

        if safe {
            safe_count = safe_count + 1
            if apply {
                if cleanup_delete_file(path) {
                    deleted = deleted + 1
                    println("  DELETED  " + path)
                } else {
                    println("  FAIL     " + path)
                }
            } else {
                println("  READY    " + path + " (refs=0)")
            }
        } else {
            if force && apply {
                if cleanup_delete_file(path) {
                    deleted = deleted + 1
                    println("  FORCED   " + path + " (refs=" + to_string(refs) + ")")
                }
            } else {
                skip_count = skip_count + 1
                println("  SKIP     " + path + " (refs=" + to_string(refs) + ")")
            }
        }
    }

    println("")
    println("safe:    " + to_string(safe_count))
    println("skip:    " + to_string(skip_count) + " (live refs — force 필요)")
    println("deleted: " + to_string(deleted))
    println("missing: " + to_string(missing))
    println("log:     shared/harness/cleanup_log.jsonl")
    if !apply {
        println("")
        println("실제 삭제: HARNESS_CLEANUP_MODE=apply hexa shared/harness/gc.hexa --cleanup")
        println("참조 있는 것도 강제: HARNESS_CLEANUP_MODE=force hexa shared/harness/gc.hexa --cleanup")
    }
    return safe_count + skip_count + deleted + missing
}

// ─── Weekly 모드 (gc-weekly.hexa 흡수) ───

fn weekly_read_last() -> i64 {
    if !file_exists(WEEKLY_COOLDOWN) { return 0 }
    let mut r: i64 = 0
    try { r = to_int(exec("cat '" + WEEKLY_COOLDOWN + "' 2>/dev/null").trim()) } catch e {}
    return r
}

fn weekly_write_last(ts: i64) {
    try { exec("echo " + to_string(ts) + " > '" + WEEKLY_COOLDOWN + "'") } catch e {}
}

// ─── Main ───

let a = args()
let mut do_drift = false
let mut do_violation = false
let mut do_dead = false
let mut do_rotate = false
let mut do_report = false
let mut do_prompt_gc = false
let mut do_weekly = false
let mut do_cleanup = false
let mut ai: i64 = 2
while ai < len(a) {
    let t = a[ai]
    if t == "--scan" { do_drift = true; do_violation = true; do_dead = true; do_prompt_gc = true }
    else if t == "--drift" { do_drift = true }
    else if t == "--violation" { do_violation = true }
    else if t == "--dead" { do_dead = true }
    else if t == "--rotate" { do_rotate = true }
    else if t == "--report" { do_report = true }
    else if t == "--prompt-gc" { do_prompt_gc = true }
    else if t == "--weekly" { do_weekly = true }
    else if t == "--cleanup" { do_cleanup = true }
    ai = ai + 1
}

if !do_drift && !do_violation && !do_dead && !do_rotate && !do_report && !do_prompt_gc && !do_weekly && !do_cleanup {
    // no-arg default = --scan (args() forwarding 이슈 우회)
    do_drift = true
    do_violation = true
    do_dead = true
    do_prompt_gc = true
}

if do_report {
    let last = exec("tail -5 '" + GC_LOG + "' 2>/dev/null").trim()
    if last == "" { println("(gc_log.jsonl empty)") } else { println(last) }
    exit(0)
}

// Weekly 모드 단독 처리 — 쿨다운 판정 후 scan 체인 실행
if do_weekly {
    let mode = _str(env("HARNESS_GC_WEEKLY_MODE")).trim()
    let force = mode == "force"
    let status_only = mode == "status"

    let now = now_sec()
    let last = weekly_read_last()
    let age = if last > 0 { now - last } else { -1 }
    let remaining = WEEK_SEC - age

    if status_only {
        if last == 0 { println("never run") }
        else {
            println("last_run_ts: " + to_string(last))
            println("age_sec:     " + to_string(age))
            if age >= WEEK_SEC { println("status:      due (쿨다운 만료)") }
            else { println("status:      cooldown (남은 " + to_string(remaining) + "s)") }
        }
        exit(0)
    }

    if !force && last > 0 && age < WEEK_SEC {
        // 쿨다운 중 — 조용히 통과
        exit(0)
    }

    println("gc-weekly: running scan chain")
    // 쿨다운 통과 시 do_drift/violation/dead/prompt_gc 활성화
    do_drift = true
    do_violation = true
    do_dead = true
    do_prompt_gc = true
    weekly_write_last(now)
}

// Cleanup 모드 단독 처리 — 다른 scan 과 독립적으로 돌아도 무방
if do_cleanup {
    let _cnt = run_cleanup()
    // cleanup 만 요청 시 다른 scan 없으면 종료
    if !do_drift && !do_violation && !do_dead && !do_rotate && !do_prompt_gc {
        exit(0)
    }
}

let mut total: i64 = 0

if do_drift {
    let f = scan_drift()
    log_findings("drift", f)
    println("drift:     " + to_string(len(f)) + " findings")
    total = total + len(f)
}

if do_violation {
    let f = scan_violations()
    log_findings("violation", f)
    println("violation: " + to_string(len(f)) + " findings")
    total = total + len(f)
}

if do_dead {
    let f = scan_dead()
    log_findings("dead", f)
    println("dead:      " + to_string(len(f)) + " findings")
    total = total + len(f)
}

if do_rotate {
    let f = scan_rotate()
    log_findings("rotate", f)
    println("rotate:    " + to_string(len(f)) + " files")
    total = total + len(f)
}

if do_prompt_gc {
    let f = scan_stale_session_prompts()
    log_findings("prompt_gc", f)
    println("prompt_gc: " + to_string(len(f)) + " files")
    total = total + len(f)
}

// ─── Agent ledger gc — 3600s+ 활성 → stale 마감 (H-AGENT-LEDGER) ───
let ledger = SHARED_DIR + "/harness/agent_ledger.hexa"
if file_exists(ledger) {
    let hexa_bin = REPO_ROOT + "/shared/bin/hexa"
    let out = _str(exec(hexa_bin + " run '" + ledger + "' gc 2>&1")).trim()
    if out.len() > 0 { println("ledger:    " + out) }
}

println("total:     " + to_string(total))
println("log:       " + GC_LOG.replace(REPO_ROOT + "/", ""))
exit(0)
