// pre_tool_guard.hexa — Tool 호출 전 가드 (PreToolUse 훅 대체)
// dispatcher: tool ∈ {Write, Edit, Bash, Agent} → 카테고리별 check 리스트 실행
//
// 카테고리 SSOT (canonical source, copy-paste 소스):
//   lib/pre_tool_common.hexa.inc   공용 헬퍼 (_guard_noname_v_match)
//   lib/pre_tool_write.hexa.inc    Write/Edit 파일 경로 가드 11개
//   lib/pre_tool_bash.hexa.inc     Bash 명령 가드 8개
//   lib/pre_tool_agent.hexa.inc    Agent 가드 (현재 스텁)
//
// 본 파일은 inc 미러 (hexa stage1 native include 미지원 — 자체 copy 보유).
// inc 변경 시 본 파일도 동기 갱신. drift 방지는 lint.hexa 로 추가 가능.
//
// usage: hexa run shared/harness/pre_tool_guard.hexa <tool> <file_path_or_cmd>
// output: REJECT: 메시지 stdout + stderr (exec_validated 호환)

let HOME = env("HOME")

// ═══════════════════════════════════════════════════════════
// [COMMON] — lib/pre_tool_common.hexa.inc 미러
// ═══════════════════════════════════════════════════════════

// H-NONAME-V 버전 suffix 매칭 — basename stem 또는 dir segment 에 대해
fn _guard_noname_v_match(s: str) -> str {
    if s.len() == 0 { return "" }
    let suffixes = [
        "_v1", "_v2", "_v3", "_v4", "_v5", "_v6", "_v7", "_v8", "_v9",
        "_v10", "_v11", "_v12", "_v13", "_v14", "_v15",
        "_V1", "_V2", "_V3", "_V4", "_V5",
        "_mk1", "_mk2", "_mk3", "_mk4", "_mk5", "_mk6", "_mk7", "_mk8", "_mk9",
        "_Mk1", "_Mk2", "_Mk3", "_Mk4", "_Mk5", "_Mk6", "_Mk7", "_Mk8", "_Mk9",
        "_MK1", "_MK2", "_MK3",
        ".v1", ".v2", ".v3", ".v4", ".v5", ".v6", ".v7", ".v8", ".v9",
        ".V1", ".V2", ".V3",
        ".mk1", ".mk2", ".mk3", ".mk4", ".mk5",
        ".Mk1", ".Mk2", ".Mk3", ".Mk4", ".Mk5",
        "_Mk.II", "_Mk.III", "_Mk.IV", "_Mk.V", "_Mk.VI", "_Mk.VII", "_Mk.VIII", "_Mk.IX", "_Mk.X",
        "_mk.II", "_mk.III", "_mk.IV", "_mk.V", "_mk.VI", "_mk.VII",
        "_new", "_final", "_copy", "-new", "-final", "-copy",
        " copy", " (1)", " (2)", " (3)", " (4)", " (5)", " (6)", " (7)", " (8)", " (9)",
        " copy 2", " copy 3", " copy 4", " copy 5"
    ]
    for sfx in suffixes {
        if s.ends_with(sfx) { return sfx }
    }
    return ""
}

// ═══════════════════════════════════════════════════════════
// [WRITE/EDIT] — lib/pre_tool_write.hexa.inc 미러 (11개)
// R1 HEXA-FIRST / L0 / R28 / R29 / R34 / H-NOARCHIVE / H-NONAME-V / H-NOHOOK / H-SESSION-LOCK
// ═══════════════════════════════════════════════════════════

// R1 HEXA-FIRST: .py/.rs/.sh 신규 파일 차단
fn check_forbidden_ext(tool: str, file_path: str) -> str {
    if tool != "Write" { return "" }
    let ext_blocked = file_path.ends_with(".py") || file_path.ends_with(".rs") || file_path.ends_with(".sh")
    if ext_blocked == false { return "" }
    let exists = to_string(exec("test -f '" + file_path + "' && echo y || echo n")).trim()
    if exists == "y" { return "" }
    return "REJECT: " + file_path + " — .py/.rs/.sh 신규 작성 금지 (HEXA-FIRST R1). .hexa로 작성하세요."
}

// L0: ~/.claude/ 및 ~/.claude-<suffix>/ 글로벌 수정 차단 (settings.json 제외)
//     멀티계정 .claude-claude11/.claude-claude12/ 등도 커버 (2026-04-14)
fn check_global_claude(tool: str, file_path: str) -> str {
    if tool != "Write" && tool != "Edit" { return "" }
    let h = env("HOME")
    let in_main = file_path.starts_with(h + "/.claude/")
    let in_multi = file_path.starts_with(h + "/.claude-")
    if in_main == false && in_multi == false { return "" }
    let base = to_string(exec("basename '" + file_path + "'")).trim()
    if base == "settings.json" { return "" }
    return "REJECT: " + file_path + " — 글로벌 ~/.claude*/ 내부 파일 수정 금지 (settings.json 제외). 프로젝트별 .claude/settings.json 경로 사용."
}

// L0: shared/hooks/, shared/config/ L0 파일 직접 수정 차단
fn check_shared_protected(tool: str, file_path: str) -> str {
    if tool != "Write" && tool != "Edit" { return "" }
    let protected = [
        "/shared/hooks/hooks-config.json",
        "/shared/config/absolute_rules.json",
        "/shared/config/core-lockdown.json"
    ]
    for p in protected {
        if file_path.contains(p) {
            return "REJECT: " + file_path + " — 공용 L0 설정 직접 수정 금지. sync 스크립트 또는 사용자 명시 승인 후."
        }
    }
    if file_path.contains("/shared/hooks/") {
        if file_path.ends_with(".hexa") || file_path.ends_with(".sh") || file_path.ends_with(".py") {
            return "REJECT: " + file_path + " — 공용 훅 직접 수정 금지. harness/ 로 이관 중 — shared/harness/ 사용."
        }
    }
    return ""
}

// R28: 폐기된 JSON 발견 저장소 신규 생성 금지 — atlas.n6 단일 SSOT
fn check_discovery_json_path(tool: str, file_path: str) -> str {
    if tool != "Write" { return "" }
    let exists = to_string(exec("test -f '" + file_path + "' && echo y || echo n")).trim()
    if exists == "y" { return "" }
    if file_path.contains("/archive/deprecated_json/") { return "" }
    let banned = [
        "discovery_graph.json",
        "discovery_log.jsonl",
        "growth_bus.json",
        "verified_constants.json",
        "module_candidates.json",
        "reality_map.json"
    ]
    let base = to_string(exec("basename '" + file_path + "'")).trim()
    for b in banned {
        if base == b {
            return "REJECT: 폐기 JSON '" + b + "' 신규 생성 금지 (R28) — atlas.n6 단일 SSOT. archive/deprecated_json/ 외 생성 불가"
        }
    }
    return ""
}

// R29: 계산기/검증/스캐너 .hexa 는 shared/n6/scripts/ 단일 SSOT
fn check_calculator_ssot(tool: str, file_path: str) -> str {
    if tool != "Write" { return "" }
    if file_path.ends_with(".hexa") == false { return "" }
    let exists = to_string(exec("test -f '" + file_path + "' && echo y || echo n")).trim()
    if exists == "y" { return "" }
    if file_path.contains("/shared/n6/scripts/") { return "" }
    let banned_segments = [
        "/theory/",
        "/predictions/",
        "/proofs/",
        "/breakthroughs/",
        "/papers/",
        "/hexa-lang/docs/"
    ]
    for s in banned_segments {
        if file_path.contains(s) {
            return "REJECT: 계산기/검증 .hexa 는 shared/n6/scripts/ 단일 SSOT (R29) — '" + s + "' 하위 신규 작성 금지. 이론 repo 는 .md 전용"
        }
    }
    return ""
}

// R34: 로드맵 최소 경로 문법 강제 — 신규 roadmap*.json Write 시 금지 키 차단
fn check_roadmap_min(tool: str, file_path: str) -> str {
    if tool != "Write" { return "" }
    if file_path.ends_with(".json") == false { return "" }
    let base = to_string(exec("basename '" + file_path + "'")).trim()
    let is_roadmap = base.starts_with("roadmap") || base.ends_with(".roadmap.json") || file_path.contains("/roadmaps/")
    if is_roadmap == false { return "" }
    let exists = to_string(exec("test -f '" + file_path + "' && echo y || echo n")).trim()
    if exists == "y" {
        let legacy = to_string(exec("grep -c '\"_legacy\":[[:space:]]*true\\|@allow-roadmap-ext' '" + file_path + "' 2>/dev/null")).trim()
        if legacy != "0" && legacy != "" { return "" }
    }
    return "REJECT: 로드맵 최소 경로 문법 필수 (R34) — 순차 배열 + 병렬 중첩 + '>' 서브순차 + par_bg 만 허용. phases/tracks/depends_on/priority/est/roi 등 확장 금지. 우회: `\"_legacy\": true` (기존 재배치)"
}

// H-NOARCHIVE: 신규 archive/backup 파일·폴더 생성 금지 — git commit 으로 변경 이력 보존.
// 격리 예외: /shared/backups/, /shared/archive/, /shared/discovery/archive/, /archive/deprecated_json/
// 우회: NEXUS_ARCHIVE_OK=1 prefix 또는 @allow-archive 토큰.
fn check_no_archive_path(tool: str, file_path: str) -> str {
    if tool != "Write" { return "" }
    if file_path.len() == 0 { return "" }
    if file_path.contains("@allow-archive") { return "" }
    if file_path.contains("shared/backups/") { return "" }
    if file_path.contains("shared/archive/") { return "" }
    if file_path.contains("shared/discovery/archive/") { return "" }
    if file_path.contains("archive/deprecated_json/") { return "" }

    let base = to_string(exec("basename '" + file_path + "'")).trim()

    let banned_suffix = [
        [".bak", "*.bak"],
        [".backup", "*.backup"],
        [".old", "*.old"],
        [".orig", "*.orig"],
        [".archived", "*.archived"]
    ]
    for s in banned_suffix {
        if base.ends_with(s[0]) {
            return "REJECT: " + file_path + " — " + s[1] + " 백업 파일 생성 금지 (H-NOARCHIVE). git commit/diff 사용. 우회: NEXUS_ARCHIVE_OK=1 prefix"
        }
    }
    if base.contains(".bak.") {
        return "REJECT: " + file_path + " — *.bak.* 백업 파일 금지 (H-NOARCHIVE). git diff/log 사용. 우회: NEXUS_ARCHIVE_OK=1"
    }

    let banned_infix = ["_backup.", "_archive.", "_old."]
    for s in banned_infix {
        if base.contains(s) {
            return "REJECT: " + file_path + " — '" + s + "' suffix 금지 (H-NOARCHIVE). git history 가 SSOT. 우회: NEXUS_ARCHIVE_OK=1"
        }
    }

    let banned_dir = [
        ["/backup/", "/backup/"],
        ["/backups/", "/backups/"],
        ["/.backup/", "/.backup/"],
        ["/.archive/", "/.archive/"],
        ["/_backup/", "/_backup/"],
        ["/_archive/", "/_archive/"],
        ["/archive/", "/archive/"],
        ["/archives/", "/archives/"]
    ]
    for d in banned_dir {
        if file_path.contains(d[0]) {
            return "REJECT: " + file_path + " — '" + d[1] + "' 폴더 신규 생성 금지 (H-NOARCHIVE). git branch/tag 사용. 격리 예외: shared/backups/, shared/archive/, shared/discovery/archive/, archive/deprecated_json/. 우회: NEXUS_ARCHIVE_OK=1"
        }
    }

    return ""
}

// H-NONAME-V: 파일/폴더명 버전 suffix 금지 — git commit/branch/tag 이 유일 SSOT.
// 의존: _guard_noname_v_match() (COMMON 섹션)
fn check_no_version_name(tool: str, file_path: str) -> str {
    if tool != "Write" { return "" }
    if file_path.len() == 0 { return "" }
    if file_path.contains("@allow-version-name") { return "" }
    if file_path.contains("shared/backups/") { return "" }
    if file_path.contains("shared/archive/") { return "" }
    if file_path.contains("shared/discovery/archive/") { return "" }
    if file_path.contains("archive/deprecated_json/") { return "" }
    let exists = to_string(exec("test -f '" + file_path + "' && echo y || echo n")).trim()
    if exists == "y" { return "" }

    let base = to_string(exec("basename '" + file_path + "'")).trim()
    let stem = to_string(exec("echo '" + base + "' | sed 's/\\.[^.]*$//'")).trim()
    let h1 = _guard_noname_v_match(stem)
    if h1 != "" {
        return "REJECT: " + file_path + " — 파일명 '" + base + "' 에 버전 suffix '" + h1 + "' 금지 (H-NONAME-V). git commit/branch/tag 로 버전관리. 우회: path 에 @allow-version-name 토큰"
    }
    let dirname = to_string(exec("dirname '" + file_path + "'")).trim()
    if dirname.len() > 0 && dirname != "." && dirname != "/" {
        let segs_raw = to_string(exec("echo '" + dirname + "' | tr '/' '\\n'"))
        let segs = segs_raw.split("\n")
        for seg in segs {
            let s = to_string(seg).trim()
            if s.len() == 0 { continue }
            if s == "." { continue }
            if s == ".." { continue }
            let h2 = _guard_noname_v_match(s)
            if h2 != "" {
                return "REJECT: " + file_path + " — 폴더명 '" + s + "' 에 버전 suffix '" + h2 + "' 금지 (H-NONAME-V). git commit/branch/tag 로 버전관리. 우회: path 에 @allow-version-name 토큰"
            }
        }
    }
    return ""
}

// H-NOHOOK: hook 파일·설정 신규 작성 금지 — 모든 자동 강제는 harness/entry.hexa 자율 호출로.
// 격리 예외: shared/archive/, /archive/superseded-, /archive/deprecated_,
//            .git/hooks/{commit-msg,pre-commit,post-commit,pre-push} + .githooks/{commit-msg,pre-commit} (H-COMMIT),
//            .git/hooks/*.sample (git default)
// 우회: NEXUS_HOOK_OK=1 prefix 또는 path 에 @allow-hook 토큰.
fn check_no_hook_file(tool: str, file_path: str) -> str {
    if tool != "Write" && tool != "Edit" { return "" }
    if file_path.len() == 0 { return "" }
    if env("NEXUS_HOOK_OK") == "1" { return "" }
    if file_path.contains("@allow-hook") { return "" }
    if file_path.contains("shared/archive/") { return "" }
    if file_path.contains("/archive/superseded-") { return "" }
    if file_path.contains("/archive/deprecated_") { return "" }
    // 자기참조
    if file_path.contains("shared/harness/pre_tool_guard.hexa") { return "" }
    if file_path.contains("shared/harness/lint.hexa") { return "" }
    if file_path.contains("shared/harness/severity_map.json") { return "" }
    if file_path.contains("shared/harness/post_edit.hexa") { return "" }

    let base = to_string(exec("basename '" + file_path + "'")).trim()

    if file_path.contains("/.git/hooks/") {
        if base.ends_with(".sample") { return "" }
        let h_commit_allowed = (base == "commit-msg" || base == "pre-commit" || base == "post-commit" || base == "pre-push")
        if h_commit_allowed { return "" }
        return "REJECT: " + file_path + " — .git/hooks/ 신규 hook 작성 금지 (H-NOHOOK). harness/entry.hexa 자율 호출로 통합. 허용: commit-msg/pre-commit/post-commit/pre-push (H-COMMIT). 우회: NEXUS_HOOK_OK=1"
    }

    if file_path.contains("/.githooks/") {
        let h_commit_allowed = (base == "commit-msg" || base == "pre-commit")
        if h_commit_allowed { return "" }
        return "REJECT: " + file_path + " — .githooks/ 신규 hook wrapper 금지 (H-NOHOOK). H-COMMIT 외 추가 wrapper 불가. 우회: NEXUS_HOOK_OK=1"
    }

    if file_path.contains("/.claude/hooks/") {
        return "REJECT: " + file_path + " — .claude/hooks/ 스크립트 신규 작성 금지 (H-NOHOOK). 모든 자동 행동은 harness/entry.hexa 호출로. 우회: NEXUS_HOOK_OK=1"
    }

    if file_path.contains("/shared/hooks/") {
        return "REJECT: " + file_path + " — shared/hooks/ deprecated (H-NOHOOK). shared/harness/ 사용. 우회: NEXUS_HOOK_OK=1"
    }

    return ""
}

// L0: lockdown_gate watch 위임. BLOCK=L0, WARN=L1, ALLOW=L2/NONE.
fn check_lockdown_tier(tool: str, file_path: str) -> str {
    if tool != "Write" && tool != "Edit" { return "" }
    if file_path.len() == 0 { return "" }
    let h = env("HOME")
    let hexa = h + "/Dev/hexa-lang/hexa"
    let gate = h + "/Dev/nexus/shared/harness/lockdown_gate.hexa"
    let result = to_string(exec(hexa + " " + gate + " watch '" + file_path + "' 2>/dev/null")).trim()
    if result.starts_with("BLOCK") {
        return "REJECT: " + file_path + " — L0 보호 파일 (lockdown_gate watch). 사용자 명시 승인 필요"
    }
    return ""
}

// H-SESSION-LOCK: 파일 area 기반 advisory lock — 다중 세션 동시 편집 race 방지.
// WARN-only (exit 미전파 제약 + 기존 워크플로우 보존). 우회: NEXUS_LOCK_OK=1
fn check_session_lock(tool: str, file_path: str) -> str {
    if tool != "Write" && tool != "Edit" { return "" }
    if file_path.len() == 0 { return "" }
    if env("NEXUS_LOCK_OK") == "1" { return "" }
    let h = env("HOME")
    let HEXA_BIN = h + "/Dev/nexus/shared/bin/hexa"
    let LOCK = h + "/Dev/nexus/shared/harness/session_lock.hexa"
    let area = to_string(exec(HEXA_BIN + " run " + LOCK + " derive '" + file_path + "' 2>/dev/null")).trim()
    if area == "" || area == "misc" { return "" }
    let out = to_string(exec(HEXA_BIN + " run " + LOCK + " acquire '" + area + "' 600 2>&1")).trim()
    if out.contains("BLOCK") {
        eprintln("[H-SESSION-LOCK WARN] " + out)
    }
    return ""
}

// ═══════════════════════════════════════════════════════════
// [BASH] — lib/pre_tool_bash.hexa.inc 미러 (8개)
// H-MD2PDF / H-SEND-GUARD / H-NOBLOCK / R20 / R22 / H-NOARCHIVE / H-NOHOOK / H-NOZOMBIE
// ═══════════════════════════════════════════════════════════

// H-MD2PDF: MD→PDF 변환은 md-to-pdf 전용. pandoc/xelatex 호출 차단.
fn check_md_to_pdf_cmd(tool: str, arg: str) -> str {
    if tool != "Bash" { return "" }
    if arg.len() == 0 { return "" }
    if arg.contains("NEXUS_PDF_OK=1") { return "" }

    let has_pandoc = arg.contains("pandoc")
    let has_xelatex = arg.contains("xelatex") || arg.contains("pdflatex") || arg.contains("lualatex")
    if has_pandoc == false && has_xelatex == false { return "" }

    if has_pandoc {
        let to_pdf = arg.contains(".pdf") || arg.contains("--to=pdf") || arg.contains("-t pdf") || arg.contains("--to pdf")
        if to_pdf == false { return "" }
        return "REJECT: pandoc PDF 변환 금지 (H-MD2PDF) — `md-to-pdf <file.md>` 사용. 우회: NEXUS_PDF_OK=1 prefix"
    }

    return "REJECT: xelatex/pdflatex/lualatex 금지 (H-MD2PDF) — MD→PDF 는 `md-to-pdf` 사용. 우회: NEXUS_PDF_OK=1 prefix"
}

// H-SEND-GUARD: 외부 발송/등록 — 사용자 명시 요청 전 차단.
fn check_external_send_cmd(tool: str, arg: str) -> str {
    if tool != "Bash" { return "" }
    if arg.len() == 0 { return "" }
    if arg.contains("NEXUS_SEND_OK=1") { return "" }

    let patterns = [
        ["gh issue create", "github issue 등록"],
        ["gh issue comment", "github issue 댓글"],
        ["gh issue close", "github issue 종료"],
        ["gh issue reopen", "github issue 재오픈"],
        ["gh pr create", "github PR 생성"],
        ["gh pr comment", "github PR 댓글"],
        ["gh pr merge", "github PR 머지"],
        ["gh pr close", "github PR 종료"],
        ["gh pr review", "github PR 리뷰"],
        ["gh release create", "github release 발행"],
        ["gh gist create", "github gist 발행"],
        ["sendmail ", "이메일 발송 (sendmail)"],
        ["msmtp ", "이메일 발송 (msmtp)"],
        ["swaks ", "이메일 발송 (swaks)"],
        ["mutt -s", "이메일 발송 (mutt)"],
        ["mail -s", "이메일 발송 (mail)"],
        ["hooks.slack.com", "slack webhook"],
        ["discord.com/api/webhooks", "discord webhook"],
        ["discordapp.com/api/webhooks", "discord webhook"]
    ]
    for p in patterns {
        if arg.contains(p[0]) {
            return "REJECT: 외부 발송/등록 차단 (H-SEND-GUARD) — " + p[1] + ". 사용자 명시 요청 필요. 우회: NEXUS_SEND_OK=1 prefix"
        }
    }
    return ""
}

// H-NOBLOCK: 세션 채팅 블로킹 금지 — read -p / wait / fg / sleep N>=10 / while+sleep 차단.
// 우회: NEXUS_BLOCK_OK=1 prefix.
fn check_blocking_cmd(tool: str, arg: str) -> str {
    if tool != "Bash" { return "" }
    if arg.len() == 0 { return "" }
    if arg.contains("NEXUS_BLOCK_OK=1") { return "" }
    if arg.contains("@allow-block") { return "" }

    if arg.contains("read -p ") || arg.contains("read -rp ") || arg.contains("read -sp ") {
        return "REJECT: read -p/-rp/-sp 입력 대기 금지 (H-NOBLOCK) — 세션 블로킹. 우회: NEXUS_BLOCK_OK=1 prefix"
    }
    if arg.contains(" fg ") || arg.starts_with("fg ") || arg == "fg" || arg.contains(";fg") || arg.contains("&& fg") {
        return "REJECT: fg 포그라운드 복귀 금지 (H-NOBLOCK) — 세션 블로킹. 우회: NEXUS_BLOCK_OK=1"
    }
    if (arg.contains("while ") || arg.contains("until ")) && arg.contains("sleep ") && arg.contains("done") {
        return "REJECT: while/until + sleep 폴링 루프 금지 (H-NOBLOCK) — Monitor 또는 run_in_background 사용. 우회: NEXUS_BLOCK_OK=1"
    }

    let tmp = "/tmp/h_noblock_arg." + to_string(exec("date +%s%N")).trim()
    let _ = exec("cat > " + tmp + " <<'NOBLOCK_EOF'\n" + arg + "\nNOBLOCK_EOF")

    let wait_hits = to_string(exec("awk '/wait[[:space:]]+(\\$|%|[0-9])/{c++} END{print c+0}' " + tmp + " 2>/dev/null")).trim()
    if wait_hits != "0" && wait_hits != "" {
        let _ = exec("rm -f " + tmp)
        return "REJECT: wait PID/%/숫자 합류 대기 금지 (H-NOBLOCK) — run_in_background + Monitor 사용. 우회: NEXUS_BLOCK_OK=1"
    }

    let sl_hits = to_string(exec("awk '/sleep[[:space:]]+([1-9][0-9]+|[1-9][0-9][0-9]+)/{c++} END{print c+0}' " + tmp + " 2>/dev/null")).trim()
    if sl_hits != "0" && sl_hits != "" {
        let _ = exec("rm -f " + tmp)
        return "REJECT: sleep N>=10s 장시간 대기 금지 (H-NOBLOCK) — ScheduleWakeup/Monitor 사용. 우회: NEXUS_BLOCK_OK=1"
    }

    let _ = exec("rm -f " + tmp)
    return ""
}

// R20: pkill/pgrep -f substring 금지 — -xf 정확매칭 또는 PID 파일 기반만 허용
fn check_pkill_f_cmd(tool: str, arg: str) -> str {
    if tool != "Bash" { return "" }
    if arg.len() == 0 { return "" }
    if arg.contains("@allow-pkill-f") { return "" }
    if arg.contains("-xf") { return "" }

    let has_pkill_f = arg.contains("pkill -f") || arg.contains("pgrep -f")
    if has_pkill_f == false { return "" }
    return "REJECT: pkill/pgrep -f substring 금지 (R20) — 무고한 프로세스 silent kill 위험. -xf 정확매칭 / PID 파일 / pgrep -x <basename> 사용. 우회: @allow-pkill-f 주석"
}

// R22: 스크립트 인터프리터 절대경로 강제 — bare python3/ruby/node 금지
fn check_bare_interpreter_cmd(tool: str, arg: str) -> str {
    if tool != "Bash" { return "" }
    if arg.len() == 0 { return "" }
    if arg.contains("NEXUS_INTERP_OK=1") { return "" }

    let patterns = [
        ["python3 ", "python3 (R22) — /usr/bin/python3 절대경로 필수 (hetzner 라우팅 회피)"],
        ["ruby ", "ruby (R22) — 절대경로 필수"],
        ["node ", "node (R22) — 절대경로 필수"]
    ]
    for p in patterns {
        let idx = arg.index_of(p[0])
        if idx < 0 { continue }
        if idx > 0 {
            let prev = arg.substring(idx - 1, idx)
            if prev == "/" { continue }
            if prev == "=" { continue }
        }
        return "REJECT: bare interpreter 호출 금지 — " + p[1] + ". 우회: NEXUS_INTERP_OK=1 prefix"
    }
    return ""
}

// H-NOARCHIVE Bash: mkdir archive/backup, cp/mv/rsync to .bak/.backup/.old, tar.gz 백업 생성 차단.
fn check_no_archive_cmd(tool: str, arg: str) -> str {
    if tool != "Bash" { return "" }
    if arg.len() == 0 { return "" }
    if arg.contains("NEXUS_ARCHIVE_OK=1") { return "" }
    if arg.contains("@allow-archive") { return "" }

    let in_safe_zone = arg.contains("shared/backups/") || arg.contains("shared/archive/") || arg.contains("shared/discovery/archive/") || arg.contains("archive/deprecated_json/")

    let mkdir_patterns = [
        "mkdir backup", "mkdir backups", "mkdir archive", "mkdir archives",
        "mkdir -p backup", "mkdir -p backups", "mkdir -p archive", "mkdir -p archives",
        "mkdir .backup", "mkdir .archive", "mkdir _backup", "mkdir _archive"
    ]
    if in_safe_zone { return "" }

    for p in mkdir_patterns {
        if arg.contains(p) {
            return "REJECT: '" + p + "' 신규 폴더 생성 금지 (H-NOARCHIVE). archive 는 git commit/branch/tag 로. 격리 예외: shared/backups/, shared/archive/. 우회: NEXUS_ARCHIVE_OK=1"
        }
    }

    let starts_cp_mv = arg.contains("cp ") || arg.contains("mv ") || arg.contains("rsync ")
    if starts_cp_mv {
        let sfx_patterns = [".bak ", ".bak'", ".bak\"", ".backup ", ".backup'", ".backup\"", ".old ", ".old'", ".old\"", ".orig ", ".orig'", ".orig\""]
        for s in sfx_patterns {
            if arg.contains(s) {
                return "REJECT: cp/mv/rsync → '*" + s.trim() + "' 백업 사본 금지 (H-NOARCHIVE). git stash/commit 으로 보존. 우회: NEXUS_ARCHIVE_OK=1"
            }
        }
        let end_patterns = [".bak", ".backup", ".old", ".orig"]
        for s in end_patterns {
            if arg.ends_with(s) {
                return "REJECT: cp/mv/rsync → '*" + s + "' 백업 사본 금지 (H-NOARCHIVE). git stash/commit 으로 보존. 우회: NEXUS_ARCHIVE_OK=1"
            }
        }
    }

    let tar_patterns = ["backup.tar", "backup.tgz", "backup.zip", "_backup.tar", "_backup.zip", "archive.tar", "archive.tgz", "archive.zip"]
    for t in tar_patterns {
        if arg.contains(t) {
            return "REJECT: '" + t + "' 백업 아카이브 생성 금지 (H-NOARCHIVE). git bundle/tag 사용. 우회: NEXUS_ARCHIVE_OK=1"
        }
    }

    return ""
}

// H-NOHOOK Bash: git config core.hooksPath 변경 / claude hooks add 차단.
fn check_no_hook_cmd(tool: str, arg: str) -> str {
    if tool != "Bash" { return "" }
    if arg.len() == 0 { return "" }
    if arg.contains("NEXUS_HOOK_OK=1") { return "" }
    if arg.contains("@allow-hook") { return "" }

    if arg.contains("git config core.hooksPath") || arg.contains("git config --global core.hooksPath") {
        return "REJECT: git config core.hooksPath 변경 금지 (H-NOHOOK) — H-COMMIT .githooks/ 가 SSOT. 우회: NEXUS_HOOK_OK=1"
    }
    if arg.contains("claude hooks add") || arg.contains("claude config hooks") {
        return "REJECT: claude hooks add 금지 (H-NOHOOK) — settings.json hooks={} SSOT. harness/entry.hexa 자율 호출로 대체. 우회: NEXUS_HOOK_OK=1"
    }
    return ""
}

// H-NOZOMBIE: hexa 프로세스 예산 게이트 — 동시 활성 hexa N개 초과 시 BLOCK.
// host: mac=8, hetzner/ubu/vast=32, 기타=12
// 우회: NEXUS_BUDGET_OK=1 prefix 또는 @allow-many-hexa 토큰
fn check_hexa_budget(tool: str, arg: str) -> str {
    if tool != "Bash" { return "" }
    if arg.len() == 0 { return "" }
    if arg.contains("NEXUS_BUDGET_OK=1") { return "" }
    if arg.contains("@allow-many-hexa") { return "" }
    if arg.contains("hexa") == false { return "" }

    let host = to_string(exec("hostname -s 2>/dev/null || echo unknown")).trim()
    let mut budget = 12
    if host == "Mac" || host == "mac" { budget = 8 }
    else if host.contains("hetzner") || host.contains("ubu") || host.contains("vast") { budget = 32 }

    let count_str = to_string(exec(
        "ps -axo command 2>/dev/null | " +
        "awk '/\\/hexa[[:space:]]run|hexa\\.real/ && !/awk/ && !/\\/bin\\/zsh/ && !/pre_tool_guard\\.hexa/{n++} END{print n+0}'"
    )).trim()
    let count = to_int(count_str)
    if count < budget { return "" }

    return "REJECT: hexa 프로세스 예산 초과 (활성=" + count_str + "/임계=" + to_string(budget) +
           " host=" + host + ") H-NOZOMBIE — 잠시 후 재시도. 우회: NEXUS_BUDGET_OK=1 prefix 또는 @allow-many-hexa 주석"
}

// ═══════════════════════════════════════════════════════════
// [AGENT] — lib/pre_tool_agent.hexa.inc 미러 (placeholder)
// Agent 가드는 entry.hexa `guard` → agent_ledger.hexa 에서 담당.
// 본 가드 레벨은 현재 룰 없음.
// ═══════════════════════════════════════════════════════════

fn check_agent_placeholder(tool: str, arg: str) -> str {
    return ""
}

// ═══════════════════════════════════════════════════════════
// [DISPATCHER] — tool 분기 + category 별 check 리스트 실행
// ═══════════════════════════════════════════════════════════

fn _run_write_checks(tool: str, file_path: str) -> str {
    let checks = [
        check_forbidden_ext(tool, file_path),
        check_global_claude(tool, file_path),
        check_shared_protected(tool, file_path),
        check_discovery_json_path(tool, file_path),
        check_calculator_ssot(tool, file_path),
        check_roadmap_min(tool, file_path),
        check_no_archive_path(tool, file_path),
        check_no_version_name(tool, file_path),
        check_no_hook_file(tool, file_path),
        check_lockdown_tier(tool, file_path),
        check_session_lock(tool, file_path)
    ]
    for c in checks {
        if c.len() > 0 { return c }
    }
    return ""
}

fn _run_bash_checks(tool: str, arg: str) -> str {
    let checks = [
        check_md_to_pdf_cmd(tool, arg),
        check_external_send_cmd(tool, arg),
        check_blocking_cmd(tool, arg),
        check_pkill_f_cmd(tool, arg),
        check_bare_interpreter_cmd(tool, arg),
        check_no_archive_cmd(tool, arg),
        check_no_hook_cmd(tool, arg),
        check_hexa_budget(tool, arg)
    ]
    for c in checks {
        if c.len() > 0 { return c }
    }
    return ""
}

fn _run_agent_checks(tool: str, arg: str) -> str {
    let checks = [
        check_agent_placeholder(tool, arg)
    ]
    for c in checks {
        if c.len() > 0 { return c }
    }
    return ""
}

fn main() {
    let argv = args()
    if argv.len() < 4 { return }
    let tool = argv[2]
    let arg = argv[3]
    if arg.len() == 0 { return }

    let mut hit = ""
    if tool == "Write" || tool == "Edit" {
        hit = _run_write_checks(tool, arg)
    } else if tool == "Bash" {
        hit = _run_bash_checks(tool, arg)
    } else if tool == "Agent" || tool == "Task" {
        hit = _run_agent_checks(tool, arg)
    }

    if hit.len() > 0 {
        eprintln(hit)
        println(hit)
    }
}

main()
