    if cmd == "--help" || cmd == "-h" || cmd == "help" { usage(); exit(0) }

    if cmd == "why" {
        if a.len() < 3 { eprintln("REJECT: why <roadmap> <node_id>"); exit(2) }
        let path = _str(a[1])
        let nid = _str(a[2])
        let rm = load_roadmap(path)
        cmd_why(rm, nid)
    }

    if cmd == "what-if" {
        if a.len() < 3 { eprintln("REJECT: what-if <roadmap> --drop=<edge>|--drop-soft"); exit(2) }
        let path = _str(a[1])
        let rm = load_roadmap(path)
        let mut k: i64 = 2
        while k < a.len() {
            let arg = _str(a[k])
            if arg == "--drop-soft" { cmd_what_if_drop_soft(rm) }
            if arg.starts_with("--drop=") {
                let edge = arg.substring(7, arg.len())
                cmd_what_if_drop(rm, edge)
            }
            k = k + 1
        }
        eprintln("REJECT: what-if needs --drop=<edge> or --drop-soft")
        exit(2)
    }

    if cmd == "compare" {
        if a.len() < 3 { eprintln("REJECT: compare <rmA> <rmB>"); exit(2) }
        let rmA = load_roadmap(_str(a[1]))
        let rmB = load_roadmap(_str(a[2]))
        cmd_compare(rmA, rmB)
    }

    if cmd == "critical" {
        if a.len() < 2 { eprintln("REJECT: critical <roadmap>"); exit(2) }
        let rm = load_roadmap(_str(a[1]))
        cmd_critical(rm)
    }

    eprintln("REJECT: unknown subcommand: " + cmd)
    usage()
    exit(2)
}

main()
