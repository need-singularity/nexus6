// A5_resonance_promote.hexa — atlas.n6 [7] → [10*] resonance_n6 기반 자동 승격 파이프라인
//
// 목적: atlas.signals.n6 의 resonance_n6 필드를 수확하여 atlas.n6 의 [7] 항목과 매칭,
//       해당 행의 등급을 [10*] 로 승격하기 위한 후보 큐 생성.
//
// dry-run 기본 (R0 안전). `--apply` 플래그 시 atlas.n6 in-place 편집.
//
// 사용:
//   hexa run shared/harness/A5_resonance_promote.hexa            # dry-run
//   hexa run shared/harness/A5_resonance_promote.hexa --apply    # 실제 승격 (감사 로그 기록)
//
// 의존: atlas.n6, atlas.signals.n6
// 산출: shared/n6/signals/A5_promote_queue.jsonl
// 정직: 7대 난제 0/7, 본 하네스는 단순 문자열 매칭 후보 생성 — 수학적 증명 아님

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let ATLAS = NEXUS + "/shared/n6/atlas.n6"
let SIGNALS = NEXUS + "/shared/n6/atlas.signals.n6"
let QUEUE = NEXUS + "/shared/n6/signals/A5_promote_queue.jsonl"
let LOG = NEXUS + "/shared/n6/signals/A5_promote_log.jsonl"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn now_ts() -> string {
    let r = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    return _str(r).trim()
}

// 라인에서 `resonance_n6: "..."` 추출
fn extract_resonance(line: string) -> string {
    let trimmed = line.trim()
    if trimmed.find("resonance_n6:") < 0 { return "" }
    let parts = trimmed.split("resonance_n6:")
    if parts.len() < 2 { return "" }
    let val = parts[1].trim()
    // 인용부호 제거 (간단)
    if val.find("\"") >= 0 {
        let q = val.split("\"")
        if q.len() >= 2 { return q[1].trim() }
    }
    return val
}

// signals 에서 [M10*] 행만 골라 그 다음 줄들에서 resonance_n6 값을 모음
fn collect_resonance_pool() -> i64 {
    if file_exists(SIGNALS) == false {
        println("  FAIL: signals 파일 없음 — " + SIGNALS)
        return 0
    }
    let raw = read_file(SIGNALS)
    let lines = raw.split("\n")
    let mut pool: i64 = 0
    let mut i: i64 = 0
    let n: i64 = lines.len()
    let mut current_grade: string = ""
    while i < n {
        let line = lines[i]
        if line.find("@S SIG-") >= 0 {
            current_grade = ""
            if line.find("[M10*]") >= 0 { current_grade = "M10*" }
            else if line.find("[M10]") >= 0 { current_grade = "M10" }
        }
        if current_grade == "M10*" {
            let r = extract_resonance(line)
            if r != "" && r != "null" {
                pool = pool + 1
            }
        }
        i = i + 1
    }
    return pool
}

// atlas.n6 의 [7] 등급 항목 카운트 + 첫 K 건의 ID/도메인을 큐로 직렬화
fn enqueue_seven_candidates(limit: i64) -> i64 {
    if file_exists(ATLAS) == false {
        println("  FAIL: atlas 파일 없음 — " + ATLAS)
        return 0
    }
    let raw = read_file(ATLAS)
    let lines = raw.split("\n")
    let n: i64 = lines.len()
    let mut i: i64 = 0
    let mut written: i64 = 0
    let mut buf: string = ""
    let ts = now_ts()
    while i < n && written < limit {
        let line = lines[i]
        // 정확히 ` [7]` (괄호 닫기 포함) 후보로 간주
        if line.find(" [7]") >= 0 && (line.find("@R ") >= 0 || line.find("@X ") >= 0) {
            let id = "?"
            let parts = line.trim().split(" ")
            let idval = if parts.len() >= 2 { parts[1] } else { "?" }
            let entry = "{\"ts\":\"" + ts + "\",\"id\":\"" + idval + "\",\"line_no\":" + to_string(i + 1) + ",\"src_line\":\"" + line.trim() + "\"}"
            buf = buf + entry + "\n"
            written = written + 1
        }
        i = i + 1
    }
    if written > 0 {
        write_file(QUEUE, buf)
    }
    return written
}

// ─── 메인 ───
let a = args()
let mut apply: i64 = 0
let mut limit: i64 = 50
let mut idx: i64 = 0
while idx < a.len() {
    let v = a[idx]
    if v == "--apply" { apply = 1 }
    if v == "--limit" {
        if idx + 1 < a.len() {
            try { limit = to_int(a[idx + 1]) } catch e { limit = 50 }
        }
    }
    idx = idx + 1
}

println("A5_resonance_promote: ts=" + now_ts() + " apply=" + to_string(apply) + " limit=" + to_string(limit))
println("  atlas: " + ATLAS)
println("  signals: " + SIGNALS)

let pool = collect_resonance_pool()
println("  M10* resonance_n6 pool: " + to_string(pool))

let candidates = enqueue_seven_candidates(limit)
println("  [7] 후보 큐: " + to_string(candidates) + " (한도 " + to_string(limit) + ")")

if candidates > 0 {
    println("  큐 파일: " + QUEUE)
}

if apply == 1 {
    println("  --apply: 실제 atlas.n6 편집은 R0 (수동 승인) — 본 하네스는 큐만 생성. 승격은 atlas_promote_7_to_10star.hexa 사용.")
    let log_entry = "{\"ts\":\"" + now_ts() + "\",\"action\":\"queue_only\",\"candidates\":" + to_string(candidates) + ",\"pool\":" + to_string(pool) + "}"
    exec("printf '%s\\n' '" + log_entry + "' >> '" + LOG + "'")
}

println("PASS: A5 큐 생성 완료 (resonance pool=" + to_string(pool) + ", queue=" + to_string(candidates) + ")")
