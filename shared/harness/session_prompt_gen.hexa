// ═══════════════════════════════════════════════════════════
// session_prompt_gen.hexa — 새 세션용 이어받기 프롬프트 자동 생성
// Usage: hexa shared/harness/session_prompt_gen.hexa [out_path] [session_id]
// 기본 출력:
//   session_id 있음 → memory/session-handoff-<session_id>.md (다중 세션 대응)
//   session_id 없음 → memory/session-handoff-latest.md (역호환)
//   out_path 명시   → 그 경로 우선
//
// Why: CLI budget 임계치 도달 시 cli_budget_gate.hexa 가 session_id 와 함께 호출.
//      세션별 독립 파일 → 한 계정 여러 세션이 동시에 한계 도달해도 덮어쓰기 없음.
//      MEMORY.md 등록은 제거됨 (사용자 지시: 메모리 저장 대신 프롬프트만 남김).
// ═══════════════════════════════════════════════════════════

let HOME = env("HOME")
let NEXUS = env("NEXUS")
let N6_ARCH = env("N6_ARCH")
let REPO_ROOT = exec("git rev-parse --show-toplevel 2>/dev/null").trim()

fn now_iso() -> string {
    return exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

// cwd → dashed path (memory dir 규칙)
fn cwd_to_dash(cwd: string) -> string {
    let mut s = ""
    let mut i: i64 = 0
    while i < len(cwd) {
        let ch = cwd.substring(i, i + 1)
        if ch == "/" { s = s + "-" } else { s = s + ch }
        i = i + 1
    }
    return s
}

// 동적 데이터 수집 helpers
fn git_head_short() -> string {
    return _str(exec("git rev-parse --short HEAD 2>/dev/null")).trim()
}

fn git_branch() -> string {
    return _str(exec("git branch --show-current 2>/dev/null")).trim()
}

fn git_recent_commits(n: i64) -> string {
    return _str(exec("git log --oneline -" + to_string(n) + " 2>/dev/null")).trim()
}

fn git_status_count() -> string {
    return _str(exec("git status --short 2>/dev/null | wc -l")).trim()
}

// progress tracker 요약
fn read_progress_json() -> string {
    let p = NEXUS + "/shared/harness/lint_progress.json"
    return _str(exec("cat '" + p + "' 2>/dev/null | head -80")).trim()
}

fn baseline_stats() -> string {
    let p = NEXUS + "/shared/harness/lint_baseline.jsonl"
    let total = _str(exec("awk 'END{print NR+0}' '" + p + "' 2>/dev/null")).trim()
    let completed = _str(exec("grep -c '\"status\":\"completed\"' '" + p + "' 2>/dev/null")).trim()
    let pending = _str(exec("grep -c '\"status\":\"pending\"' '" + p + "' 2>/dev/null")).trim()
    return "total=" + total + " / completed=" + completed + " / pending=" + pending
}

// 다른 프로젝트 HEAD (n6-architecture)
fn other_repo_head(path: string) -> string {
    return _str(exec("cd '" + path + "' 2>/dev/null && git log --oneline -1 2>/dev/null")).trim()
}

// JSONL 에서 user prompt tail N 개 추출 (handoff_write 에서 이식, P4)
fn get_tail_messages(jsonl_path: string, n: i64) -> string {
    if len(jsonl_path) == 0 { return "" }
    let raw = _str(exec("tail -n 200 '" + jsonl_path + "' 2>/dev/null")).trim()
    if len(raw) == 0 { return "" }
    let lines = raw.split("\n")
    let mut user_prompts = []
    let mut i: i64 = 0
    while i < len(lines) {
        let ln = lines[i]
        if ln.contains("\"type\":\"user\"") && ln.contains("\"content\"") {
            let c_idx = ln.split("\"content\":")
            if len(c_idx) >= 2 {
                let raw_c = c_idx[1]
                if raw_c.starts_with("\"") {
                    let inner = raw_c.split("\"")
                    if len(inner) >= 2 {
                        let text = inner[1]
                        if len(text) > 0 && len(text) < 500 {
                            user_prompts = user_prompts + [text]
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    let total: i64 = len(user_prompts)
    let start: i64 = if total > n { total - n } else { 0 }
    let mut out = ""
    let mut j: i64 = start
    while j < total {
        out = out + "- " + user_prompts[j] + "\n"
        j = j + 1
    }
    return out
}

// markdown 본문 빌드
fn build_prompt(session_id: string, jsonl_path: string) -> string {
    let ts = now_iso()
    let head = git_head_short()
    let branch = git_branch()
    let recent = git_recent_commits(5)
    let dirty = git_status_count()
    let baseline = baseline_stats()
    let n6_head = other_repo_head(N6_ARCH)

    let mut s = ""
    s = s + "# 세션 이어받기 — 자동 생성 (" + ts + ")\n\n"
    s = s + "## 현재 상태\n\n"
    s = s + "- **nexus**: branch=`" + branch + "` HEAD=`" + head + "` dirty=" + dirty + " files\n"
    s = s + "- **n6-architecture HEAD**: " + n6_head + "\n"
    s = s + "- **lint baseline**: " + baseline + "\n\n"
    s = s + "## 최근 commits (nexus)\n\n```\n" + recent + "\n```\n\n"
    s = s + "## Gold Standard\n\n"
    s = s + "- 경로: `shared/harness/sample.md` (nexus)\n"
    s = s + "- 구조: §1 WHY / §2 COMPARE / §3 REQUIRES / §4 STRUCT / §5 FLOW / §7 VERIFY (10 서브섹션) / §6 EVOLVE\n"
    s = s + "- §7 python: stdlib only, 10 카테고리 정직성 검증 → `12/12 PASS (n=6 정직성 검증)`\n"
    s = s + "- 첫 실제 파생: `domains/sf-ufo/sf/sf.md` (n6-arch)\n\n"
    s = s + "## 하네스 룰 (등록됨)\n\n"
    s = s + "| ID | severity | scope | 역할 |\n"
    s = s + "|----|----------|-------|------|\n"
    s = s + "| N61-V3 | error | sample.md | §7.0~§7.10 10 서브섹션 + COUNTER/FALSIFIERS |\n"
    s = s + "| N61-V4 | error | sample.md | PASS 정직성 라벨 |\n"
    s = s + "| N61-F1 | error | canonical 전체 | frontmatter alien_index_* 금지 |\n"
    s = s + "| N61-NEW | error | untracked canonical | sample.md 템플릿 복사 강제 |\n"
    s = s + "| N61-GOLD-REF | warn | canonical 전체 | gold-standard 마커 권장 |\n"
    s = s + "| H-GRC | warn | .hexa | `\\|\\| echo 0` 안티패턴 |\n"
    s = s + "| H-DEFER | warn | md/hexa/jsonl | '다음 세션에서 수정' 회피 금지 |\n"
    s = s + "| H-NOBLOCK | warn/REJECT | .hexa/.sh/Bash | 세션 블로킹 (read -p/wait $/fg/sleep>=10/while+sleep) |\n\n"
    s = s + "## 남은 작업 (phase)\n\n"
    s = s + "- **P1-b** VP-M1 3건: MISSING DATA 콘텐츠 수작업\n"
    s = s + "- **P1-c** N61-P1 192건: python 블록 중복 제거 (자동 70%)\n"
    s = s + "- **P2-a** N12 423건: 수론 유래 `← σ(6)=12` 주석 주입\n"
    s = s + "- **P2-b** OEIS ref 427건: `A\\d{6}` 링크 주입\n"
    s = s + "- **P3-a** N1 421건: 표 유도/적합 컬럼 분류\n"
    s = s + "- **P3-b** N3 408건: fudge factor 치환\n"
    s = s + "- **P4** C2 158건: @allow-paper-canonical 블랭킷 제거\n"
    s = s + "- **P5** regression monotonic gate + warn→error 자동 승격\n\n"
    s = s + "## 실행 전략 — 8 Agent 병렬\n\n"
    s = s + "| Agent | 범위 | 파일 수 |\n"
    s = s + "|-------|------|---------|\n"
    s = s + "| A | domains/cognitive/ | ~22 |\n"
    s = s + "| B | domains/infra/ | ~55 |\n"
    s = s + "| C | domains/materials/ | ~20 |\n"
    s = s + "| D | domains/energy/ | ~20 |\n"
    s = s + "| E | domains/life/ | ~20 |\n"
    s = s + "| F | domains/compute/ | ~50 |\n"
    s = s + "| G | domains/sf-ufo/ + physics/ | ~35 |\n"
    s = s + "| H | papers/* + 잔여 | ~200 |\n\n"
    s = s + "**Agent 공통 지시**:\n"
    s = s + "1. `shared/harness/sample.md` 템플릿 로드\n"
    s = s + "2. 각 파일 §1~§7 재구성 + §7 도메인 맞춤 python 10섹션 (stdlib, X/N PASS 라벨)\n"
    s = s + "3. `<!-- gold-standard: shared/harness/sample.md -->` 첫 줄 마커\n"
    s = s + "4. COUNTER_EXAMPLES ≥3 + FALSIFIERS ≥3\n"
    s = s + "5. 수론 유래 `← σ(6)=12, τ(6)=4, OEIS A000203` 주석\n"
    s = s + "6. 완료 시 `lint_progress.jsonl` append: `{status:completed, agent:A-H}`\n"
    s = s + "7. 카테고리별 commit: `docs(n6-arch): {category} canonical v2 재작성`\n"
    s = s + "8. push 전 `hexa $NEXUS/shared/harness/lint.hexa --all` → V3/V4 통과 확인\n\n"
    s = s + "## 제약 (필수)\n\n"
    s = s + "- **HARNESS-LOCK**: nexus/shared/harness/ 수정 시 커밋 메시지 `(harness):` prefix 또는 `harness-approved` 포함\n"
    s = s + "- **bitter-gate**: 새 룰 추가 전 `hexa shared/harness/bitter-gate.hexa --audit` 필수\n"
    s = s + "- **H-DEFER**: 발견 즉시 룰화, '다음 세션에서' 회피 금지\n"
    s = s + "- **GO 모드**: 독립 작업 배경 병렬 Agent (memory: f-go-mode-parallel-agents)\n"
    s = s + "- **AI-native**: 상태는 JSONL append, 산문 금지\n\n"
    s = s + "## 참조 경로\n\n"
    s = s + "- gold standard: `$NEXUS/shared/harness/sample.md`\n"
    s = s + "- 하네스 lint: `$NEXUS/shared/harness/lint.hexa`\n"
    s = s + "- 진행 tracker: `$NEXUS/shared/harness/lint_progress.json` + `lint_baseline.jsonl`\n"
    s = s + "- 첫 파생: `$N6_ARCH/domains/sf-ufo/sf/sf.md`\n"
    s = s + "- memory: `~/.claude-claude10/projects/-Users-ghost-Dev-nexus/memory/`\n\n"
    s = s + "## 시작 명령\n\n"
    s = s + "```bash\n"
    s = s + "cd $N6_ARCH\n"
    s = s + "wc -l $NEXUS/shared/harness/lint_baseline.jsonl  # 427 예상\n"
    s = s + "# 8 Agent 병렬 발사 (background=true). 완료 시 카테고리별 commit + push\n"
    s = s + "```\n\n"
    s = s + "**원칙**: 안 물어보고 진행. 확인 질문 최소화. 완료까지 자동.\n"

    // 세션별 tail user prompts + 메타 (P4)
    if len(session_id) > 0 {
        s = s + "\n## 이 세션 메타\n\n"
        s = s + "- session_id: `" + session_id + "`\n"
        if len(jsonl_path) > 0 { s = s + "- jsonl: `" + jsonl_path + "`\n" }
        let tail = get_tail_messages(jsonl_path, 5)
        if len(tail) > 0 {
            s = s + "\n## 이 세션 최근 user 발화 (tail 5)\n\n" + tail
        }
    }
    return s
}

// 실행
let cwd = exec("pwd").trim()
let dashed = cwd_to_dash(cwd)
let proj_dir = HOME + "/.claude-claude10/projects/" + dashed
let mem_dir = proj_dir + "/memory"
exec("mkdir -p '" + mem_dir + "' 2>/dev/null")

// argv: [hexa_bin, script_path, out_path?, session_id?]
let a = args()
let mut out_path_arg = ""
let mut session_id = ""
if len(a) >= 3 { out_path_arg = a[2] }
if len(a) >= 4 { session_id = a[3] }

// out_path 결정: 명시 인자 > session_id 기반 > latest fallback
let mut out_path = mem_dir + "/session-handoff-latest.md"
if len(session_id) > 0 { out_path = mem_dir + "/session-handoff-" + session_id + ".md" }
if len(out_path_arg) > 0 { out_path = out_path_arg }

// jsonl_path 추론 (session_id 기반)
let mut jsonl_path = ""
if len(session_id) > 0 { jsonl_path = proj_dir + "/" + session_id + ".jsonl" }

let content = build_prompt(session_id, jsonl_path)
write_file(out_path, content)
println("session handoff prompt 생성: " + out_path)
println("bytes=" + to_string(len(content)))
// MEMORY.md 등록 제거됨 — 세션별 파일이라 인덱스 오염 방지
