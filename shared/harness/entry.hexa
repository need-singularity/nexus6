// entry.hexa — 하네스 단일 진입점 (훅 대체)
// 역할: 훅 시스템 제거 후, Claude가 매 턴 자율 호출하는 dispatcher.
//       CLAUDE.md 에 "매 <event> 후 hexa run shared/harness/entry.hexa <mode> ..." 규칙 명시 → Claude 준수.
//
// usage:
//   hexa run shared/harness/entry.hexa prompt "<user_text>"    — UserPromptSubmit 대체 (키워드 감지)
//   hexa run shared/harness/entry.hexa pre_tool <tool> <path>  — PreToolUse 대체 (차단 검증)
//   hexa run shared/harness/entry.hexa post_bash <exit_code>   — PostToolUse Bash 대체
//   hexa run shared/harness/entry.hexa post_edit <file_path>   — PostToolUse Write|Edit 대체
//   hexa run shared/harness/entry.hexa gate <cmd> <seed>       — cmd_gate 라우팅 (alias)
//   hexa run shared/harness/entry.hexa self_check              — 하네스 자가 진단
//
// 성공 조용, 실패 시끄럽게 (하네스 H1 원칙).

let HOME = env("HOME")
let HARNESS = HOME + "/Dev/nexus/shared/harness"
let HEXA = HOME + "/Dev/nexus/shared/bin/hexa"

fn route(mode: str, rest: [str]) {
    if mode == "prompt" {
        dispatch_file(HARNESS + "/prompt_scan.hexa", rest)
    } else if mode == "pre_tool" {
        dispatch_file(HARNESS + "/pre_tool_guard.hexa", rest)
    } else if mode == "post_bash" {
        dispatch_file(HARNESS + "/post_bash.hexa", rest)
    } else if mode == "post_edit" {
        dispatch_file(HARNESS + "/post_edit.hexa", rest)
    } else if mode == "gate" {
        dispatch_file(HARNESS + "/cmd_gate.hexa", rest)
    } else if mode == "self_check" {
        self_check()
    } else {
        eprintln("REJECT: unknown mode '" + mode + "' — modes: prompt|pre_tool|post_bash|post_edit|gate|self_check")
    }
}

fn dispatch_file(script: str, rest: [str]) {
    if file_exists(script) == false {
        // silent pass — sub-module 아직 미구현 단계
        return
    }
    let mut cmd = HEXA + " run " + script
    for a in rest {
        let safe = a.replace("\"", "\\\"")
        cmd = cmd + " \"" + safe + "\""
    }
    let out = to_string(exec(cmd + " 2>&1"))
    if out.trim().len() > 0 {
        print(out)
    }
}

fn self_check() {
    let modules = [
        ["cmd_gate", HARNESS + "/cmd_gate.hexa"],
        ["prompt_scan", HARNESS + "/prompt_scan.hexa"],
        ["pre_tool_guard", HARNESS + "/pre_tool_guard.hexa"],
        ["post_bash", HARNESS + "/post_bash.hexa"],
        ["post_edit", HARNESS + "/post_edit.hexa"]
    ]
    let mut present = 0
    let mut missing = []
    for m in modules {
        if file_exists(m[1]) {
            present = present + 1
        } else {
            missing.push(m[0])
        }
    }
    println("harness modules: " + to_string(present) + "/" + to_string(modules.len()) + " present")
    if missing.len() > 0 {
        let mut names = ""
        for n in missing {
            if names.len() > 0 { names = names + ", " }
            names = names + n
        }
        println("missing: " + names)
    }
    // cmd_gate 기본 동작 확인
    let gate_out = to_string(exec(HEXA + " run " + HARNESS + "/cmd_gate.hexa smash '아이디어' 2>&1")).trim()
    if gate_out.contains("REJECT") {
        println("gate reject test: PASS (abstract token rejected)")
    } else {
        println("gate reject test: FAIL — expected REJECT, got: " + gate_out)
    }
}

fn main() {
    let argv = args()
    if argv.len() < 3 {
        eprintln("usage: entry.hexa <mode> [args...]  — modes: prompt|pre_tool|post_bash|post_edit|gate|self_check")
        return
    }
    let mode = argv[2]
    let mut rest = []
    let mut i = 3
    while i < argv.len() {
        rest.push(argv[i])
        i = i + 1
    }
    route(mode, rest)
}

main()
