// entry.hexa — 하네스 단일 진입점 (훅 대체)
// 역할: 훅 시스템 제거 후, Claude가 매 턴 자율 호출하는 dispatcher.
//       CLAUDE.md 에 "매 <event> 후 hexa run shared/harness/entry.hexa <mode> ..." 규칙 명시 → Claude 준수.
//
// usage:
//   hexa run shared/harness/entry.hexa prompt "<user_text>"    — UserPromptSubmit 대체 (키워드 감지)
//   hexa run shared/harness/entry.hexa pre_tool <tool> <path>  — PreToolUse 대체 (차단 검증)
//   hexa run shared/harness/entry.hexa post_bash <exit_code>   — PostToolUse Bash 대체
//   hexa run shared/harness/entry.hexa post_edit <file_path>   — PostToolUse Write|Edit 대체
//   hexa run shared/harness/entry.hexa gate <cmd> <seed>       — cmd_gate 라우팅 (alias)
//   hexa run shared/harness/entry.hexa health [mode] [flags]   — health 라우터 (atlas|nexus|all|list)
//   hexa run shared/harness/entry.hexa git_fresh [check|force|state] — H-GIT-FRESH 수동 실행
//   hexa run shared/harness/entry.hexa sync <list|diff|all|id>   — sync 라우터 위임
//   hexa run shared/harness/entry.hexa errors <route|drain_check|count_open|promote|mark_fixed> ... — H-ERR 라우팅
//   hexa run shared/harness/entry.hexa agent_ledger <register|complete|list|gc|dup_check> ... — H-AGENT-LEDGER 직접 호출
//   hexa run shared/harness/entry.hexa broadcast <append|tail|...> ... — H-BROADCAST 전파
//   hexa run shared/harness/entry.hexa session_lock <acquire|release|status> ... — H-SESSION-LOCK
//   hexa run shared/harness/entry.hexa session_registry <register|heartbeat|list|peers> ... — H-SESSION-REGISTRY
//   hexa run shared/harness/entry.hexa session_worktree <init|list|status|merge|prune|gc_branches> ... — H-SESSION-WORKTREE
//   hexa run shared/harness/entry.hexa session_prompt_gen [args]  — 세션 이어받기 프롬프트 생성
//   hexa run shared/harness/entry.hexa session <lock|registry|worktree|prompt_gen> [args] — session 통합 라우터
//   hexa run shared/harness/entry.hexa verify <v-const|sync-diff|atlas|all|list> — verify 통합 검증 라우터
//   hexa run shared/harness/entry.hexa gauge <tick|status|reset>  — 컨텍스트 게이지 (tool-call 카운터)
//   hexa run shared/harness/entry.hexa instinct <scan|score|promote|prune|status> — 인스팅트 파이프라인
//   hexa run shared/harness/entry.hexa audit [full|json|summary]   — 하네스 스코어카드 7 카테고리
//   hexa run shared/harness/entry.hexa self_check              — 하네스 자가 진단
//
// 성공 조용, 실패 시끄럽게 (하네스 H1 원칙).

let HOME = env("HOME")
let HARNESS = HOME + "/Dev/nexus/shared/harness"
let HEXA = HOME + "/Dev/nexus/shared/bin/hexa"

// L1 좀비 차단 — sub-module dispatch 기본 timeout (초). 우회: NEXUS_NO_TIMEOUT=1
let WRAPPER = HARNESS + "/perl_timeout.sh"
let DISPATCH_TIMEOUT_SEC = 45

// long-running 모듈 화이트리스트 — timeout 면제
let LONG_RUN_MODULES = ["agent_ledger", "session_worktree", "blowup", "session_prompt_gen", "handoff_write"]

fn needs_timeout(script: str) -> bool {
    for m in LONG_RUN_MODULES {
        if script.contains("/" + m + ".hexa") { return false }
    }
    return true
}

fn wrap_prefix(script: str) -> str {
    // perl_timeout.sh 가 없으면 fallback to plain (좀비 방지보다 가용성 우선)
    if file_exists(WRAPPER) == false { return "" }
    if needs_timeout(script) == false { return "" }
    return "bash " + WRAPPER + " " + to_string(DISPATCH_TIMEOUT_SEC) + " "
}

fn route(mode: str, rest: [str]) {
    if mode == "prompt" {
        // H-GIT-FRESH — 사용자 입력 시 30분 stale 감지 + origin drift alert (silent on sync)
        dispatch_file(HARNESS + "/git_fresh.hexa", ["check"])
        dispatch_file(HARNESS + "/prompt_scan.hexa", rest)
    } else if mode == "git_fresh" {
        // 명시적 호출: entry.hexa git_fresh [check|force|state]
        dispatch_file(HARNESS + "/git_fresh.hexa", rest)
    } else if mode == "pre_tool" {
        dispatch_file(HARNESS + "/pre_tool_guard.hexa", rest)
    } else if mode == "post_bash" {
        dispatch_file(HARNESS + "/post_bash.hexa", rest)
    } else if mode == "post_edit" {
        dispatch_file(HARNESS + "/post_edit.hexa", rest)
    } else if mode == "gate" {
        dispatch_file(HARNESS + "/cmd_gate.hexa", rest)
    } else if mode == "guard" {
        // Agent 호출 전 — agent_ledger.register 위임 (H-AGENT-LEDGER)
        // rest = [area, prompt_hash]
        dispatch_agent_guard(rest)
    } else if mode == "health" {
        dispatch_file(HARNESS + "/health.hexa", rest)
    } else if mode == "sync" {
        dispatch_file(HARNESS + "/sync.hexa", rest)
    } else if mode == "errors" {
        dispatch_file(HARNESS + "/errors.hexa", rest)
    } else if mode == "agent_ledger" {
        dispatch_file(HARNESS + "/agent_ledger.hexa", rest)
    } else if mode == "broadcast" {
        dispatch_file(HARNESS + "/broadcast.hexa", rest)
    } else if mode == "session_lock" {
        dispatch_file(HARNESS + "/session_lock.hexa", rest)
    } else if mode == "session_registry" {
        dispatch_file(HARNESS + "/session_registry.hexa", rest)
    } else if mode == "session_worktree" {
        dispatch_file(HARNESS + "/session_worktree.hexa", rest)
    } else if mode == "session_prompt_gen" {
        dispatch_file(HARNESS + "/session_prompt_gen.hexa", rest)
    } else if mode == "session" {
        dispatch_file(HARNESS + "/session.hexa", rest)
    } else if mode == "verify" {
        dispatch_file(HARNESS + "/verify.hexa", rest)
    } else if mode == "gauge" {
        dispatch_file(HARNESS + "/context_gauge.hexa", rest)
    } else if mode == "instinct" {
        dispatch_file(HARNESS + "/instinct.hexa", rest)
    } else if mode == "audit" {
        dispatch_file(HARNESS + "/harness_audit.hexa", rest)
    } else if mode == "sensor" {
        dispatch_file(HARNESS + "/sensor.hexa", rest)
    } else if mode == "growth_tick" {
        dispatch_file(HARNESS + "/growth_tick.hexa", rest)
    } else if mode == "cross_feed" {
        dispatch_file(HARNESS + "/cross_feed.hexa", rest)
    } else if mode == "thinking" {
        dispatch_file(HARNESS + "/thinking_engine.hexa", rest)
    } else if mode == "self_check" {
        self_check()
    } else {
        eprintln("REJECT: unknown mode '" + mode + "' — modes: prompt|pre_tool|post_bash|post_edit|gate|guard|health|git_fresh|sync|errors|agent_ledger|broadcast|session_lock|session_registry|session_worktree|session_prompt_gen|gauge|instinct|audit|self_check")
    }
}

fn dispatch_agent_guard(rest: [str]) {
    // usage: entry.hexa guard <area> [prompt_hash]
    //        entry.hexa guard complete <agent_id>    — 완료 마감
    if rest.len() == 0 { return }
    let script = HARNESS + "/agent_ledger.hexa"
    if file_exists(script) == false { return }
    let mut sub = "register"
    let mut area = rest[0]
    let mut hash = "na"
    if rest.len() >= 2 {
        // complete <agent_id> 특수 라우팅
        if rest[0] == "complete" {
            sub = "complete"
            area = rest[1]
            hash = ""
        } else {
            hash = rest[1]
        }
    }
    let prefix = wrap_prefix(script)
    let mut cmd = prefix + HEXA + " run " + script + " " + sub + " \"" + area.replace("\"", "\\\"") + "\""
    if hash.len() > 0 { cmd = cmd + " \"" + hash.replace("\"", "\\\"") + "\"" }
    let out = to_string(exec(cmd + " 2>&1"))
    if out.trim().len() > 0 { print(out) }
}

fn dispatch_file(script: str, rest: [str]) {
    if file_exists(script) == false {
        // silent pass — sub-module 아직 미구현 단계
        return
    }
    let prefix = wrap_prefix(script)
    let mut cmd = prefix + HEXA + " run " + script
    for a in rest {
        let safe = a.replace("\"", "\\\"")
        cmd = cmd + " \"" + safe + "\""
    }
    let out = to_string(exec(cmd + " 2>&1"))
    if out.trim().len() > 0 {
        print(out)
    }
}

fn self_check() {
    let modules = [
        ["cmd_gate", HARNESS + "/cmd_gate.hexa"],
        ["prompt_scan", HARNESS + "/prompt_scan.hexa"],
        ["pre_tool_guard", HARNESS + "/pre_tool_guard.hexa"],
        ["post_bash", HARNESS + "/post_bash.hexa"],
        ["post_edit", HARNESS + "/post_edit.hexa"],
        ["agent_ledger", HARNESS + "/agent_ledger.hexa"],
        ["git_fresh", HARNESS + "/git_fresh.hexa"],
        ["sync", HARNESS + "/sync.hexa"],
        ["errors", HARNESS + "/errors.hexa"],
        ["broadcast", HARNESS + "/broadcast.hexa"],
        ["session_lock", HARNESS + "/session_lock.hexa"],
        ["session_registry", HARNESS + "/session_registry.hexa"],
        ["session_worktree", HARNESS + "/session_worktree.hexa"],
        ["session_prompt_gen", HARNESS + "/session_prompt_gen.hexa"],
        ["session", HARNESS + "/session.hexa"],
        ["verify", HARNESS + "/verify.hexa"],
        ["context_gauge", HARNESS + "/context_gauge.hexa"],
        ["instinct", HARNESS + "/instinct.hexa"],
        ["harness_audit", HARNESS + "/harness_audit.hexa"],
        ["sensor", HARNESS + "/sensor.hexa"],
        ["growth_tick", HARNESS + "/growth_tick.hexa"],
        ["cross_feed", HARNESS + "/cross_feed.hexa"],
        ["thinking_engine", HARNESS + "/thinking_engine.hexa"]
    ]
    let mut present = 0
    let mut missing = []
    for m in modules {
        if file_exists(m[1]) {
            present = present + 1
        } else {
            missing.push(m[0])
        }
    }
    println("harness modules: " + to_string(present) + "/" + to_string(modules.len()) + " present")
    if missing.len() > 0 {
        let mut names = ""
        for n in missing {
            if names.len() > 0 { names = names + ", " }
            names = names + n
        }
        println("missing: " + names)
    }
    // cmd_gate 기본 동작 확인
    let gate_out = to_string(exec(HEXA + " run " + HARNESS + "/cmd_gate.hexa smash '아이디어' 2>&1")).trim()
    if gate_out.contains("REJECT") {
        println("gate reject test: PASS (abstract token rejected)")
    } else {
        println("gate reject test: FAIL — expected REJECT, got: " + gate_out)
    }
    // harness_audit 스코어 요약 (옵셔널 — 매 self_check 마다 점수 표시)
    let audit_out = to_string(exec(HEXA + " run " + HARNESS + "/harness_audit.hexa summary 2>/dev/null")).trim()
    if audit_out.len() > 0 { println(audit_out) }
}

fn main() {
    let argv = args()
    if argv.len() < 3 {
        eprintln("usage: entry.hexa <mode> [args...]  — modes: prompt|pre_tool|post_bash|post_edit|gate|guard|health|git_fresh|sync|errors|agent_ledger|broadcast|session_lock|session_registry|session_worktree|session_prompt_gen|gauge|instinct|audit|self_check")
        return
    }
    let mode = argv[2]
    let mut rest = []
    let mut i = 3
    while i < argv.len() {
        rest.push(argv[i])
        i = i + 1
    }
    route(mode, rest)
}

main()
