{
  "id": "nexus-severity-map",
  "version": "1.0.0",
  "updated": "2026-04-14",
  "description": "오류 신호 → severity (block/defer/warn) 분류 SSOT — H-ERR-ROUTE 가 참조. block=즉시 fix 모드, defer=errors.jsonl 큐 누적, warn=보고만",
  "fallback": "defer",
  "unknown_threshold": 30,
  "notes": {
    "block": "작업 흐름 차단 필수 — L0/R1/R14 위반, 빌드·테스트 실패, parse error, critical lint",
    "defer": "누적 처리 — gc_drift, dead code, 비L0 lint warn, dormant, missing reference",
    "warn": "보고만, 큐 제외 — cosmetic/format/일시 race",
    "promotion": "동일 rule/kind 가 unknown_threshold(30) 회 이상 fallback 으로 흐르면 H-ERR-PROMOTE 가 분류 강제"
  },
  "rules": {
    "lint_rule": {
      "L0": "block",
      "R1": "block",
      "R14": "block",
      "R19": "defer",
      "R22": "block",
      "R34": "defer",
      "HARNESS-LOCK": "block",
      "H-GRC": "defer",
      "H-ROOT": "block",
      "H-MD2PDF": "block",
      "H-SEND-GUARD": "block",
      "H-NOBLOCK": "block",
      "H-NOARCHIVE": "block",
      "H-ERR-ROUTE": "block",
      "H-ERR-DRAIN": "block",
      "H-ERR-PROMOTE": "defer",
      "H9": "block",
      "HEXA-ALGO": "defer",
      "V-PARSE": "block",
      "CMDS-DRIFT": "block",
      "ABSPATH": "defer",
      "PATH": "defer",
      "BLOW1": "block",
      "BLOW3": "defer",
      "BLOW6": "defer",
      "ATLAS-GUARD-L1": "block",
      "ATLAS-GUARD-L2": "defer",
      "AG5-N1": "defer",
      "AG5-N3": "defer",
      "AG6-S1": "defer",
      "AN1": "defer",
      "AN3": "defer",
      "AN7": "defer",
      "AN-LOG-2": "defer",
      "AN-LOG-3": "defer",
      "AN-LOG-4": "defer",
      "AN-LOG-5": "defer",
      "AN-LOG-7": "defer",
      "N6-DAG-CYCLE": "block",
      "N6-DAG-DANGLE": "block",
      "N6-DAG-SYNC": "block",
      "N6-JSONPAIR": "defer",
      "N61-A1": "defer",
      "N61-B1": "defer",
      "N61-B2": "defer",
      "N61-B3": "defer",
      "N61-B4": "defer",
      "N61-C1": "defer",
      "N61-E1": "defer",
      "N61-Mk1": "defer",
      "N61-Mk3": "defer",
      "N61-Mk4": "defer",
      "N61-P1": "defer",
      "N61-R1": "defer",
      "N61-R2": "defer",
      "N61-R3": "defer",
      "N61-V1": "defer",
      "N61-W1": "defer",
      "N62-A": "defer",
      "NX4-L1": "defer",
      "NX4-L2": "defer",
      "HX4": "defer",
      "HX4-L3": "defer",
      "HX4-L5": "defer",
      "VD1": "defer",
      "VD2-C1": "defer",
      "VD2-C3": "defer",
      "VP-M1": "defer",
      "VP-M2": "defer",
      "VP-M7": "defer",
      "VP-M9": "defer",
      "VP-M10": "defer",
      "PP1": "defer",
      "PP2": "defer"
    },
    "gc_kind": {
      "gc_drift": "defer",
      "gc_violation": "block",
      "drift": "defer",
      "violation": "block",
      "dead": "defer",
      "dormant": "defer",
      "void": "warn",
      "lint_fail": "defer",
      "orphan": "defer",
      "missing": "defer"
    },
    "exit_signal": {
      "build_fail": "block",
      "test_fail": "block",
      "parse_error": "block",
      "syntax_error": "block",
      "hexa_parse_error": "block",
      "lint_critical": "block",
      "lint_error": "block",
      "lint_warn": "defer",
      "lint_info": "warn",
      "format_diff": "warn",
      "cosmetic": "warn",
      "timeout": "defer",
      "race": "warn",
      "oom": "block",
      "permission_denied": "block",
      "network_fail": "defer",
      "exit_nonzero_unknown": "defer"
    },
    "source_default": {
      "user": "block",
      "gate": "block",
      "l0_guard": "block",
      "lockdown_gate": "block",
      "pre_tool_guard": "block",
      "cmd_gate": "block",
      "lint": "defer",
      "post_bash": "defer",
      "post_edit": "defer",
      "gc": "defer",
      "sync": "defer",
      "build": "block",
      "test": "block",
      "prompt_scan": "warn"
    }
  }
}
