// sensor.hexa — 자율 성장 P1 센서 레이어
// 역할: atlas.n6.stats 를 1h 주기로 읽어 emerge_baseline.json 갱신.
//       무성장 연속 카운트 (consecutive_stale) 가 lint H-EMERGE-COMMIT 의 게이트.
// 호출: launchd com.nexus.sensor (1h interval) 또는 수동
// usage: hexa run shared/harness/sensor.hexa [atlas_stats|perf_bench|think|all]
// 성공 조용, 실패만 stderr.

let HOME = env("HOME")
let NEXUS = "/Users/ghost/Dev/nexus"
let HARNESS = NEXUS + "/shared/harness"
let EMERGE = HARNESS + "/emerge_baseline.json"
let PERF = HARNESS + "/perf_baseline.json"
let THINK = HARNESS + "/think_baseline.json"
let ATLAS_STATS = NEXUS + "/shared/n6/atlas.n6.stats"

// ─── void-safe coercion (cross_feed.hexa 패턴) ───
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    return to_int(first)
}

fn now_unix() -> i64 {
    return _to_int0(_str(exec("date +%s")).trim())
}

fn json_field(line: string, key: string) -> string {
    let tag = "\"" + key + "\""
    if line.contains(tag) == false { return "" }
    let after = line.split(tag)[1]
    let parts = after.split(":")
    if parts.len() < 2 { return "" }
    let mut rest = parts[1]
    let mut i = 2
    while i < parts.len() {
        rest = rest + ":" + parts[i]
        i = i + 1
    }
    let s = rest.trim()
    if s.len() == 0 { return "" }
    if s.substring(0, 1) == "\"" {
        let inner = s.substring(1, s.len())
        let ep = inner.split("\"")
        if ep.len() < 1 { return "" }
        return ep[0]
    }
    let mut end = 0
    while end < s.len() {
        let c = s.substring(end, end + 1)
        if c == "," || c == "}" || c == "\n" || c == " " { break }
        end = end + 1
    }
    return s.substring(0, end).trim()
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", " ")
    r = r.replace("\r", " ")
    r = r.replace("\t", " ")
    return r
}

fn atlas_stats_tick() {
    if file_exists(ATLAS_STATS) == false {
        eprintln("sensor: atlas.n6.stats not found — " + ATLAS_STATS)
        return
    }
    let cur = _str(read_file(ATLAS_STATS))
    let cur_nodes = _to_int0(json_field(cur, "nodes"))
    let cur_edges = _to_int0(json_field(cur, "edges"))
    let cur_hubs = _to_int0(json_field(cur, "hubs"))
    let ts = now_unix()

    let mut last_nodes: i64 = 0
    let mut last_edges: i64 = 0
    let mut last_hubs: i64 = 0
    let mut stale: i64 = 0
    if file_exists(EMERGE) {
        let body = _str(read_file(EMERGE))
        last_nodes = _to_int0(json_field(body, "last_nodes"))
        last_edges = _to_int0(json_field(body, "last_edges"))
        last_hubs = _to_int0(json_field(body, "last_hubs"))
        stale = _to_int0(json_field(body, "consecutive_stale"))
    }

    let same = (cur_nodes == last_nodes) && (cur_edges == last_edges) && (cur_hubs == last_hubs)
    let mut new_stale: i64 = 0
    if same { new_stale = stale + 1 } else { new_stale = 0 }

    let entry = "{\"ts\":" + to_string(ts) + ",\"nodes\":" + to_string(cur_nodes) + ",\"edges\":" + to_string(cur_edges) + ",\"hubs\":" + to_string(cur_hubs) + ",\"stale\":" + to_string(new_stale) + "}"

    let mut j = "{\n"
    j = j + "  \"schema\": 1,\n"
    j = j + "  \"updated\": " + to_string(ts) + ",\n"
    j = j + "  \"last_nodes\": " + to_string(cur_nodes) + ",\n"
    j = j + "  \"last_edges\": " + to_string(cur_edges) + ",\n"
    j = j + "  \"last_hubs\": " + to_string(cur_hubs) + ",\n"
    j = j + "  \"consecutive_stale\": " + to_string(new_stale) + ",\n"
    j = j + "  \"history\": [" + entry + "],\n"
    j = j + "  \"note\": \"sensor.hexa 1h tick. lint H-EMERGE-COMMIT/H-NOREGRESS 참조.\"\n"
    j = j + "}\n"
    try { write_file(EMERGE, j) } catch e {}

    if new_stale >= 3 {
        eprintln("sensor: atlas " + to_string(new_stale) + " tick 연속 무성장 (nodes=" + to_string(cur_nodes) + " edges=" + to_string(cur_edges) + " hubs=" + to_string(cur_hubs) + ")")
    }
}

fn perf_bench_tick() {
    // 실측 bench 는 blowup 실행비 커서 별도 수동/weekly. 여기선 placeholder.
    let _ = PERF
}

fn think_stats_tick() {
    // thinking_engine.hexa 가 자체 갱신하므로 여기선 존재 여부만 확인
    if file_exists(THINK) == false { return }
    let body = _str(read_file(THINK))
    let last = _to_int0(json_field(body, "last_ts"))
    let ts = now_unix()
    let age = ts - last
    // 24h+ stale 이면 stderr (H-THINK-EVOLVE 용)
    if last > 0 && age > 86400 {
        eprintln("sensor: thinking 24h+ stale (age=" + to_string(age) + "s). NEXUS_AUTO_EVOLVE=1 이면 growth_tick 이 자율 reflect 발사")
    }
}

fn main() {
    let argv = args()
    let mut mode = "all"
    if argv.len() >= 3 { mode = argv[2] }
    if mode == "atlas_stats" || mode == "all" {
        atlas_stats_tick()
    }
    if mode == "perf_bench" || mode == "all" {
        perf_bench_tick()
    }
    if mode == "think" || mode == "all" {
        think_stats_tick()
    }
}

main()
