// mcp_health.hexa — H-MCP-HEALTH 하네스 룰
// 역할: MCP 서버 reachability 체크 (TTL + exponential backoff).
//       실제 핸드셰이크/통신 X — command 실행파일 존재 또는 url 응답코드만.
// SSOT: shared/harness/mcp_health.json
//       { "servers": { "<name>": { "status":"healthy|unhealthy|unknown",
//                                   "last_check":"ISO", "ttl_until":"ISO",
//                                   "failure_count":N, "backoff_sec":N } } }
//
// usage:
//   hexa run shared/harness/mcp_health.hexa check    — TTL 미만이면 캐시 재사용, 아니면 재체크
//   hexa run shared/harness/mcp_health.hexa status   — 캐시 상태 요약
//   hexa run shared/harness/mcp_health.hexa reset    — 캐시 무효화
//
// 서버 소스 우선순위:
//   1) <repo>/.mcp.json (있으면)
//   2) shared/config/mcp_servers.json (있으면)
//   3) 없으면 stdout "no servers configured" + exit 0
//
// TTL: 120s. 실패 backoff: 30→60→120→240→480→600s (max).
// 성공 조용 (H1), sentinel 마지막 라인 __HARNESS_MCP_RESULT__ PASS|FAIL.
// PASS = 실행 완료 (unhealthy 서버 존재해도 PASS).
// @no-lock-needed — 단일 세션 캐시, race 무영향
// @allow-bare-exec — exec wrapper 의존 회피 (silent skip 패턴)

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let HARNESS = NEXUS + "/shared/harness"
let STATE = HARNESS + "/mcp_health.json"
let MCP_REPO = NEXUS + "/.mcp.json"
let MCP_SHARED = NEXUS + "/shared/config/mcp_servers.json"
let TTL_SEC: i64 = 120
let BACKOFF_INIT: i64 = 30
let BACKOFF_MAX: i64 = 600

// ─── void-safe coercion ───
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    return to_int(first)
}

fn now_unix() -> i64 {
    return _to_int0(_str(exec("date +%s")).trim())
}

fn now_iso() -> string {
    return _str(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
}

fn iso_plus(secs: i64) -> string {
    let cmd = "date -u -r $(($(date +%s) + " + to_string(secs) + ")) +%Y-%m-%dT%H:%M:%SZ"
    let r = _str(exec(cmd)).trim()
    if r.len() > 0 { return r }
    return now_iso()
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", " ")
    r = r.replace("\r", " ")
    r = r.replace("\t", " ")
    return r
}

// ─── source pick ───
fn pick_source() -> string {
    if file_exists(MCP_REPO) { return MCP_REPO }
    if file_exists(MCP_SHARED) { return MCP_SHARED }
    return ""
}

// ─── MCP servers 파서 ───
// 두 포맷 지원:
//   {"mcpServers": {"name": {"command":"...","args":[...]}}}
//   {"servers": [{"name":"...","url":"https://..."}, ...]}
// 단순 brace-matching — context_gauge 패턴 차용.
//
// 반환: [[name, command, url], ...]  (command 와 url 중 하나는 비어있음)
fn parse_servers(path: string) -> [[string]] {
    let mut out = []
    if file_exists(path) == false { return out }
    let raw = read_file(path)
    // mcpServers 우선 (Claude Code .mcp.json 표준)
    let body1 = extract_object_body(raw, "mcpServers")
    if body1.len() > 0 {
        let entries = split_top_entries(body1)
        for e in entries {
            let t = _str(e).trim()
            if t.len() == 0 { continue }
            let kv = split_key_value(t)
            if kv.len() < 2 { continue }
            let name = kv[0]
            let inner = kv[1]
            let cmd = field_str(inner, "command")
            let url = field_str(inner, "url")
            out = out.push([name, cmd, url])
        }
        return out
    }
    // fallback: servers (자체 정의 포맷, list)
    let body2 = extract_object_body(raw, "servers")
    if body2.len() > 0 {
        let entries = split_top_entries(body2)
        for e in entries {
            let t = _str(e).trim()
            if t.len() == 0 { continue }
            let kv = split_key_value(t)
            if kv.len() < 2 { continue }
            let name = kv[0]
            let inner = kv[1]
            let cmd = field_str(inner, "command")
            let url = field_str(inner, "url")
            out = out.push([name, cmd, url])
        }
    }
    return out
}

// "mcpServers" 같은 key 의 body 부분만 (객체 내부 {...}) 반환
fn extract_object_body(raw: string, key: string) -> string {
    let tag = "\"" + key + "\""
    if raw.contains(tag) == false { return "" }
    let after = raw.split(tag)[1]
    let mut i = 0
    while i < after.len() {
        if after.substring(i, i + 1) == ":" { break }
        i = i + 1
    }
    if i >= after.len() { return "" }
    while i < after.len() {
        let c = after.substring(i, i + 1)
        if c == "{" || c == "[" { break }
        i = i + 1
    }
    if i >= after.len() { return "" }
    let open_c = after.substring(i, i + 1)
    let close_c = if open_c == "{" { "}" } else { "]" }
    let inner_start = i + 1
    let mut depth = 1
    let mut j = inner_start
    let mut in_str = false
    let mut escape = false
    while j < after.len() {
        let c = after.substring(j, j + 1)
        if escape { escape = false; j = j + 1; continue }
        if in_str {
            if c == "\\" { escape = true }
            else if c == "\"" { in_str = false }
        } else {
            if c == "\"" { in_str = true }
            else if c == open_c { depth = depth + 1 }
            else if c == close_c {
                depth = depth - 1
                if depth == 0 { break }
            }
        }
        j = j + 1
    }
    if j > inner_start {
        return after.substring(inner_start, j).trim()
    }
    return ""
}

// body 를 최상위 쉼표로 쪼갠 엔트리 배열
fn split_top_entries(body: string) -> [string] {
    let mut out = []
    let mut buf = ""
    let mut depth = 0
    let mut in_str = false
    let mut escape = false
    let mut k = 0
    while k < body.len() {
        let c = body.substring(k, k + 1)
        if escape { buf = buf + c; escape = false; k = k + 1; continue }
        if in_str {
            if c == "\\" { escape = true; buf = buf + c }
            else if c == "\"" { in_str = false; buf = buf + c }
            else { buf = buf + c }
        } else {
            if c == "\"" { in_str = true; buf = buf + c }
            else if c == "{" || c == "[" { depth = depth + 1; buf = buf + c }
            else if c == "}" || c == "]" { depth = depth - 1; buf = buf + c }
            else if c == "," && depth == 0 {
                if buf.trim().len() > 0 { out = out.push(buf.trim()) }
                buf = ""
            } else {
                buf = buf + c
            }
        }
        k = k + 1
    }
    if buf.trim().len() > 0 { out = out.push(buf.trim()) }
    return out
}

// "key":{...}  →  ["key", "{...} 내부"]
// 또는 {...}  →  ["", "{...} 내부"]  (이름 없는 list 엔트리)
fn split_key_value(entry: string) -> [string] {
    let t = entry.trim()
    if t.len() == 0 { return [] }
    // case 1: "key":{...}
    if t.substring(0, 1) == "\"" {
        let rest = t.substring(1, t.len())
        let mut k = 0
        while k < rest.len() {
            if rest.substring(k, k + 1) == "\"" { break }
            k = k + 1
        }
        if k >= rest.len() { return [] }
        let name = rest.substring(0, k)
        let after = rest.substring(k + 1, rest.len())
        // 첫 ':' 까지 스킵 후 '{' 시작
        let mut i = 0
        while i < after.len() {
            if after.substring(i, i + 1) == "{" { break }
            i = i + 1
        }
        if i >= after.len() { return [name, ""] }
        let inner_start = i + 1
        let mut depth = 1
        let mut j = inner_start
        let mut in_str = false
        let mut escape = false
        while j < after.len() {
            let c = after.substring(j, j + 1)
            if escape { escape = false; j = j + 1; continue }
            if in_str {
                if c == "\\" { escape = true }
                else if c == "\"" { in_str = false }
            } else {
                if c == "\"" { in_str = true }
                else if c == "{" { depth = depth + 1 }
                else if c == "}" {
                    depth = depth - 1
                    if depth == 0 { break }
                }
            }
            j = j + 1
        }
        if j > inner_start {
            return [name, after.substring(inner_start, j)]
        }
        return [name, ""]
    }
    // case 2: 그냥 {...}  — name 필드 직접 찾기
    if t.substring(0, 1) == "{" {
        let inner = t.substring(1, t.len())
        // closing brace 찾기
        let mut depth = 1
        let mut j = 0
        let mut in_str = false
        let mut escape = false
        while j < inner.len() {
            let c = inner.substring(j, j + 1)
            if escape { escape = false; j = j + 1; continue }
            if in_str {
                if c == "\\" { escape = true }
                else if c == "\"" { in_str = false }
            } else {
                if c == "\"" { in_str = true }
                else if c == "{" { depth = depth + 1 }
                else if c == "}" {
                    depth = depth - 1
                    if depth == 0 { break }
                }
            }
            j = j + 1
        }
        let body = inner.substring(0, j)
        let nm = field_str(body, "name")
        return [nm, body]
    }
    return []
}

// 객체 body 에서 string field 값 추출 (이스케이프 단순)
fn field_str(block: string, key: string) -> string {
    let tag = "\"" + key + "\""
    if block.contains(tag) == false { return "" }
    let after = block.split(tag)[1]
    let mut i = 0
    while i < after.len() {
        if after.substring(i, i + 1) == ":" { break }
        i = i + 1
    }
    if i >= after.len() { return "" }
    let s = after.substring(i + 1, after.len()).trim_start()
    if s.len() == 0 { return "" }
    if s.substring(0, 1) == "\"" {
        let rest = s.substring(1, s.len())
        let mut j = 0
        while j < rest.len() {
            if rest.substring(j, j + 1) == "\"" { break }
            j = j + 1
        }
        return rest.substring(0, j)
    }
    let mut end = 0
    while end < s.len() {
        let c = s.substring(end, end + 1)
        if c == "," || c == "}" || c == "\n" || c == " " { break }
        end = end + 1
    }
    return s.substring(0, end).trim()
}

fn field_int(block: string, key: string, fallback: i64) -> i64 {
    let v = field_str(block, key)
    if v == "" { return fallback }
    return _to_int0(v)
}

// ─── reachability check ───
// returns "healthy" | "unhealthy" | "unknown"
fn check_one(cmd: string, url: string) -> string {
    if url.len() > 0 {
        // http reachability — 5xx/timeout 만 unhealthy
        let safe = url.replace("'", "")
        let c = "curl -s -o /dev/null -w '%{http_code}' --max-time 5 '" + safe + "' 2>/dev/null"
        let code = _str(exec(c)).trim()
        if code == "" || code == "000" { return "unhealthy" }
        // 5xx → unhealthy, 그 외 → healthy
        if code.substring(0, 1) == "5" { return "unhealthy" }
        return "healthy"
    }
    if cmd.len() > 0 {
        // 1) absolute path → file_exists
        if cmd.substring(0, 1) == "/" {
            if file_exists(cmd) { return "healthy" }
            return "unhealthy"
        }
        // 2) PATH 검색 — which 호출
        let safe = cmd.replace("'", "")
        let r = _str(exec("command -v '" + safe + "' 2>/dev/null")).trim()
        if r.len() > 0 { return "healthy" }
        return "unhealthy"
    }
    return "unknown"
}

// ─── cache read/write ───
// returns [last_check_iso, ttl_until_iso, failure_count, backoff_sec, status]
fn read_cached(name: string) -> [string] {
    if file_exists(STATE) == false {
        return ["", "", "0", to_string(BACKOFF_INIT), "unknown"]
    }
    let raw = read_file(STATE)
    let body = extract_object_body(raw, "servers")
    if body.len() == 0 {
        return ["", "", "0", to_string(BACKOFF_INIT), "unknown"]
    }
    let entries = split_top_entries(body)
    let prefix = "\"" + name + "\""
    for e in entries {
        let t = _str(e).trim()
        if t.len() == 0 { continue }
        if t.substring(0, prefix.len()) != prefix { continue }
        let kv = split_key_value(t)
        if kv.len() < 2 { continue }
        let inner = kv[1]
        let lc = field_str(inner, "last_check")
        let tu = field_str(inner, "ttl_until")
        let fc = to_string(field_int(inner, "failure_count", 0))
        let bo = to_string(field_int(inner, "backoff_sec", BACKOFF_INIT))
        let st = field_str(inner, "status")
        return [lc, tu, fc, bo, st]
    }
    return ["", "", "0", to_string(BACKOFF_INIT), "unknown"]
}

// 캐시 갱신 — 다른 서버 블록은 보존
fn write_cache_all(servers: [[string]]) {
    // servers = [[name, status, last_check, ttl_until, fc, bo], ...]
    let mut inner = ""
    for s in servers {
        let nm = s[0]
        let st = s[1]
        let lc = s[2]
        let tu = s[3]
        let fc = s[4]
        let bo = s[5]
        if inner.len() > 0 { inner = inner + "," }
        inner = inner + "\"" + json_escape(nm) + "\":{" +
                "\"status\":\"" + st + "\"," +
                "\"last_check\":\"" + lc + "\"," +
                "\"ttl_until\":\"" + tu + "\"," +
                "\"failure_count\":" + fc + "," +
                "\"backoff_sec\":" + bo +
                "}"
    }
    let content = "{\"servers\":{" + inner + "}}\n"
    let tmp = STATE + ".tmp"
    try { write_file(tmp, content) } catch e {
        eprintln("FAIL: write_file " + tmp)
        return
    }
    exec("mv '" + tmp + "' '" + STATE + "'")
}

// iso 시각이 now 이전이면 true (TTL 만료)
fn is_expired(ttl_iso: string) -> bool {
    if ttl_iso == "" { return true }
    let safe = ttl_iso.replace("'", "")
    // GNU date -d 시도 (ubuntu/linux)
    let r1 = _str(exec("date -u -d '" + safe + "' +%s 2>/dev/null")).trim()
    let mut ttl_ts: i64 = 0
    if r1.len() > 0 {
        ttl_ts = _to_int0(r1)
    } else {
        // BSD date (macOS) — -j -f
        let r2 = _str(exec("date -u -j -f '%Y-%m-%dT%H:%M:%SZ' '" + safe + "' +%s 2>/dev/null")).trim()
        if r2.len() > 0 { ttl_ts = _to_int0(r2) }
    }
    if ttl_ts == 0 { return true }
    let now = now_unix()
    return now >= ttl_ts
}

fn next_backoff(prev: i64) -> i64 {
    let n = prev * 2
    if n > BACKOFF_MAX { return BACKOFF_MAX }
    if n < BACKOFF_INIT { return BACKOFF_INIT }
    return n
}

fn age_secs(iso: string) -> i64 {
    if iso == "" { return 0 }
    let safe = iso.replace("'", "")
    let r1 = _str(exec("date -u -d '" + safe + "' +%s 2>/dev/null")).trim()
    let mut ts: i64 = 0
    if r1.len() > 0 {
        ts = _to_int0(r1)
    } else {
        let r2 = _str(exec("date -u -j -f '%Y-%m-%dT%H:%M:%SZ' '" + safe + "' +%s 2>/dev/null")).trim()
        if r2.len() > 0 { ts = _to_int0(r2) }
    }
    if ts == 0 { return 0 }
    return now_unix() - ts
}

// ─── cmd: check ───
fn cmd_check() {
    let src = pick_source()
    if src == "" {
        println("mcp_health: no servers configured")
        println("__HARNESS_MCP_RESULT__ PASS")
        return
    }
    let parsed = parse_servers(src)
    if parsed.len() == 0 {
        println("mcp_health: source " + src + " has no parseable server entries")
        println("__HARNESS_MCP_RESULT__ PASS")
        return
    }

    let mut updated = []
    let mut healthy = 0
    let mut unhealthy = 0
    let mut unknown = 0
    let mut cached = 0

    for srv in parsed {
        let name = srv[0]
        let cmd = srv[1]
        let url = srv[2]
        if name == "" { continue }
        let prev = read_cached(name)
        let prev_lc = prev[0]
        let prev_tu = prev[1]
        let prev_fc = _to_int0(prev[2])
        let prev_bo = _to_int0(prev[3])
        let prev_st = prev[4]

        // TTL 미만이면 캐시 그대로 사용
        if is_expired(prev_tu) == false {
            cached = cached + 1
            updated = updated.push([name, prev_st, prev_lc, prev_tu, to_string(prev_fc), to_string(prev_bo)])
            if prev_st == "healthy" { healthy = healthy + 1 }
            else if prev_st == "unhealthy" { unhealthy = unhealthy + 1 }
            else { unknown = unknown + 1 }
            continue
        }

        // 재체크
        let st = check_one(cmd, url)
        let lc = now_iso()
        let mut fc = 0
        let mut bo = BACKOFF_INIT
        let mut ttl: i64 = TTL_SEC
        if st == "healthy" {
            fc = 0
            bo = BACKOFF_INIT
            ttl = TTL_SEC
            healthy = healthy + 1
        } else if st == "unhealthy" {
            fc = prev_fc + 1
            bo = if prev_fc == 0 { BACKOFF_INIT } else { next_backoff(prev_bo) }
            ttl = bo
            unhealthy = unhealthy + 1
        } else {
            fc = prev_fc
            bo = prev_bo
            ttl = TTL_SEC
            unknown = unknown + 1
        }
        let tu = iso_plus(ttl)
        updated = updated.push([name, st, lc, tu, to_string(fc), to_string(bo)])
    }

    write_cache_all(updated)

    // 1줄 요약 (silent 가 아닌 경우만)
    println("mcp_health: " + to_string(updated.len()) + " servers | healthy=" + to_string(healthy) +
            " unhealthy=" + to_string(unhealthy) + " unknown=" + to_string(unknown) +
            " cached=" + to_string(cached))
    println("__HARNESS_MCP_RESULT__ PASS")
}

// ─── cmd: status ───
fn cmd_status() {
    let src = pick_source()
    if src == "" {
        println("mcp_health: no servers configured")
        return
    }
    if file_exists(STATE) == false {
        println("mcp_health: cache empty (run 'check' first)")
        return
    }
    let raw = read_file(STATE)
    let body = extract_object_body(raw, "servers")
    if body.len() == 0 {
        println("mcp_health: cache empty")
        return
    }
    let entries = split_top_entries(body)
    let mut healthy = 0
    let mut unhealthy = 0
    let mut unknown = 0
    let mut lines = []
    for e in entries {
        let t = _str(e).trim()
        if t.len() == 0 { continue }
        let kv = split_key_value(t)
        if kv.len() < 2 { continue }
        let name = kv[0]
        let inner = kv[1]
        let st = field_str(inner, "status")
        let lc = field_str(inner, "last_check")
        let fc = field_int(inner, "failure_count", 0)
        let bo = field_int(inner, "backoff_sec", BACKOFF_INIT)
        if st == "healthy" { healthy = healthy + 1 }
        else if st == "unhealthy" { unhealthy = unhealthy + 1 }
        else { unknown = unknown + 1 }
        let age = age_secs(lc)
        let mut line = "  " + name + ": " + st + " (checked " + to_string(age) + "s ago"
        if fc > 0 { line = line + ", fail_count=" + to_string(fc) + " backoff=" + to_string(bo) + "s" }
        line = line + ")"
        lines = lines.push(line)
    }
    let total = healthy + unhealthy + unknown
    println("mcp_health: " + to_string(total) + " servers | healthy=" + to_string(healthy) +
            " unhealthy=" + to_string(unhealthy) + " unknown=" + to_string(unknown))
    for ln in lines { println(ln) }
}

// ─── cmd: reset ───
fn cmd_reset() {
    let content = "{\"servers\":{}}\n"
    let tmp = STATE + ".tmp"
    try { write_file(tmp, content) } catch e {
        eprintln("FAIL: write_file " + tmp)
        return
    }
    exec("mv '" + tmp + "' '" + STATE + "'")
    println("mcp_health: cache reset")
}

fn main() {
    let argv = args()
    let mut mode = "check"
    if argv.len() >= 3 {
        let m = argv[2].trim().to_lower()
        if m == "check" || m == "status" || m == "reset" { mode = m }
    } else {
        // env var fallback (args() void 케이스)
        let e = _str(env("MCP_HEALTH_MODE")).trim().to_lower()
        if e == "status" || e == "reset" || e == "check" { mode = e }
    }
    if mode == "check" { cmd_check() }
    else if mode == "status" { cmd_status() }
    else if mode == "reset" { cmd_reset() }
    else {
        eprintln("REJECT: unknown mode '" + mode + "' — modes: check|status|reset")
        println("__HARNESS_MCP_RESULT__ FAIL")
    }
}

main()
