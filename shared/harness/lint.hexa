// ═══════════════════════════════════════════════════════════
// lint.hexa — 하네스 P2 자동 강제 린터
// AI-native, .hexa-only (R1), 성공 조용/실패 시끄럽게
// Usage:
//   hexa shared/harness/lint.hexa --staged     (git staged files)
//   hexa shared/harness/lint.hexa --all        (전체 shared/ 트리)
//   hexa shared/harness/lint.hexa --file PATH  (단일 파일)
// 실패 시 stderr JSON 라인 + exit 1, lint_log.jsonl 에 결과 append
// ═══════════════════════════════════════════════════════════

let HOME = env("HOME")
let REPO_ROOT = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
let SHARED_DIR = REPO_ROOT + "/shared"
// 로그는 nexus SSOT 에 집중 — 타 리포에서 실행돼도 nexus 경로로 append
let NEXUS_HARNESS = HOME + "/Dev/nexus/shared/harness"
let LINT_LOG = NEXUS_HARNESS + "/lint_log.jsonl"
let MISTAKES_LOG = NEXUS_HARNESS + "/mistakes.jsonl"

fn now_ts() {
    return exec("date +%s").trim()
}

fn now_iso() {
    return exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "\\r")
    r = r.replace("\t", "\\t")
    return r
}

// ─── File classification ───

fn is_under_shared(path: string) -> bool {
    return path.starts_with("shared/")
}

// void-safe coercion ("".split() 첫 원소 void 이슈 우회)
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

// 근본 해결 (R33 + H-ROOT): `grep -c PATTERN file 2>/dev/null || echo 0` 안티패턴이
// 매치 0 인 경우 grep stdout "0" + exit 1 → `|| echo 0` 추가 "0" → "0\n0" 이중출력.
// to_int 은 이 문자열에 invalid integer literal error. 첫 줄만 파싱하는 safe wrapper.
fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = s.split("\n")[0].trim()
    if first == "" { return 0 }
    return to_int(first)
}

// last_index_of 미지원 우회 — 수동 스캔
fn _rfind(s: string, ch: string) -> i64 {
    let n = len(s)
    let mut i: i64 = n - 1
    while i >= 0 {
        if s.substring(i, i + 1) == ch { return i }
        i = i - 1
    }
    return -1
}

fn ext_of(path: string) -> string {
    let dot = _rfind(path, ".")
    if dot < 0 { return "" }
    return path.substring(dot, len(path))
}

fn basename_of(path: string) -> string {
    let slash = _rfind(path, "/")
    if slash < 0 { return path }
    return path.substring(slash + 1, len(path))
}

// ─── Check 1: R1 HEXA-FIRST (no new .py/.sh under shared/) ───
// exception: shared/scripts/ (기존 bootstrap bin 포함), shared/bin/ (C helper)

fn is_hexa_only_exception(path: string) -> bool {
    if path.starts_with("shared/scripts/") { return true }
    if path.starts_with("shared/bin/") { return true }
    return false
}

// 시스템콜 wrapper — .hexa 포팅 불가능 (perl alarm / mkdir-atomic 요구)
// 하드코드 화이트리스트: 경로 contains 매칭 (절대/상대 양쪽 커버)
fn r1_is_exempt(path: string) -> bool {
    if path.index_of("shared/harness/perl_timeout.sh") >= 0 { return true }
    if path.index_of("shared/harness/lock_gate.sh") >= 0 { return true }
    return false
}

// marker 기반 exempt — 파일 첫 5줄 안에 '@hexa-first-exempt' 또는 '# system-call wrapper'
fn r1_marker_exempt(path: string) -> bool {
    let full = REPO_ROOT + "/" + path
    if !file_exists(full) { return false }
    let head = _str(exec("head -n 5 '" + full + "' 2>/dev/null"))
    if head.index_of("@hexa-first-exempt") >= 0 { return true }
    if head.index_of("# system-call wrapper") >= 0 { return true }
    return false
}

fn check_hexa_only(path: string) -> string {
    let e = ext_of(path)
    if e != ".py" && e != ".sh" && e != ".rs" { return "" }
    if !is_under_shared(path) { return "" }
    if is_hexa_only_exception(path) { return "" }
    if r1_is_exempt(path) { return "" }
    if r1_marker_exempt(path) { return "" }
    return "R1|error|HEXA-FIRST — shared/ 아래 .rs/.py/.sh 금지. ai-native algorism 으로 재작성"
}

// ─── Check 2: AI-native (R14) — prose .md in rules/config ───

fn check_ai_native(path: string) -> string {
    let e = ext_of(path)
    if e != ".md" { return "" }
    let bn = basename_of(path)
    // CLAUDE.md 는 프로젝트 지도로 허용
    if bn == "CLAUDE.md" { return "" }
    if bn == "SECRET.md" { return "" }
    if path.starts_with("shared/rules/") {
        return "R14|warn|rules SSOT 는 JSON 만. prose .md 금지"
    }
    if path.starts_with("shared/config/") {
        return "R14|warn|config SSOT 는 JSON/JSONL 만. prose .md 금지"
    }
    return ""
}

// ─── Check 3: L0 lockdown — L0 보호 영역 수정 감지 (pure hexa, no python) ───
// python3 호출은 hetzner 라우팅 위험 — grep + 순수 hexa 파싱

// lockdown.json 에서 "path":"..." 값 전체 라인 추출 (한 번만 호출)
fn _l0_path_lines() -> string {
    let LOCKDOWN = REPO_ROOT + "/shared/lockdown/lockdown.json"
    if !file_exists(LOCKDOWN) { return "" }
    // "path": "..." 또는 "path":"..." 형태 라인 전부 grep. L0/L1 구분은 단순화 —
    // L1 entries 도 포함되지만 warn 수준이라 안전 (L0 전용 정확도는 l0_guard 가 담당)
    return exec("grep -oE '\"path\"[[:space:]]*:[[:space:]]*\"[^\"]+\"' '" + LOCKDOWN + "' 2>/dev/null").trim()
}

// 한 라인에서 path 값만 추출: "path": "xxx" → xxx
fn _extract_path_value(line: string) -> string {
    // 마지막 따옴표 쌍 사이 값 찾기: 패턴은 "path":...,"<value>"
    // 뒤에서부터 두 번째 " 와 마지막 " 사이
    let last_q = _rfind(line, "\"")
    if last_q < 0 { return "" }
    let before = line.substring(0, last_q)
    let prev_q = _rfind(before, "\"")
    if prev_q < 0 { return "" }
    return line.substring(prev_q + 1, last_q)
}

fn path_in_l0(path: string) -> bool {
    let raw = _l0_path_lines()
    if raw == "" { return false }
    let lines = raw.split("\n")
    for ln in lines {
        let l = _str(ln).trim()
        if l == "" { continue }
        let entry = _extract_path_value(l)
        if entry == "" { continue }
        // prefix 매칭: "xxx/*" → path.starts_with("xxx/")
        let e_len = len(entry)
        if e_len >= 2 && entry.substring(e_len - 2, e_len) == "/*" {
            let prefix = entry.substring(0, e_len - 2) + "/"
            if path.starts_with(prefix) { return true }
            continue
        }
        // 디렉터리 엔트리 ("xxx/" 로 끝나면 prefix 매칭)
        if e_len >= 1 && entry.substring(e_len - 1, e_len) == "/" {
            if path.starts_with(entry) { return true }
            continue
        }
        // exact
        if path == entry { return true }
    }
    return false
}

fn check_l0_lockdown(path: string) -> string {
    if !path_in_l0(path) { return "" }
    // msg_check 는 commit-msg 훅 단계에서 commit.hexa msg_check 가 최종 검증
    // pre-commit 단계의 COMMIT_EDITMSG 는 N-1 메시지라 구조적 오탐 원인
    return "L0|warn|L0 보호 영역 staged — commit msg 에 'chore(lockdown):' 또는 'L0-approved' 권장 (commit-msg 단계 최종 검증)"
}

// ─── Check 4: pitfalls grep ───

fn check_pitfalls(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    let full = REPO_ROOT + "/" + path
    // Python sys 의존 탐지
    let py_call = _to_int0(_str(exec("grep -c 'python3 -c' '" + full + "' 2>/dev/null || echo 0")).trim())
    if py_call > 10 {
        return "P-PY-HEAVY|info|.hexa 내 python3 -c 호출 >10회. 순수 hexa 함수로 추출 고려"
    }
    return ""
}

// ─── Check 5: AI-native — CLAUDE.md line cap + prose detection ───
fn check_claude_md(path: string) -> string {
    let bn = basename_of(path)
    if bn != "CLAUDE.md" { return "" }
    let full = REPO_ROOT + "/" + path
    let lines_cnt = _to_int0(_str(exec("wc -l < '" + full + "' 2>/dev/null || echo 0")).trim())
    if lines_cnt > 250 {
        return "AI-NATIVE|warn|CLAUDE.md > 250 라인 (" + to_string(lines_cnt) + ") — ai-native 간결화 필요"
    }
    // prose detection: 80자+ 마침표 끝 비-리스트/헤더/테이블/코드 라인 3+ 연속
    let prose_cmd = "awk 'BEGIN{run=0;max=0} { if (length($0)>=80 && ($0 ~ /[.]$/ || $0 ~ /다\\.$/ || $0 ~ /요\\.$/) && $0 !~ /^[|\\-*#`]/ && $0 !~ /^[[:space:]]*[a-zA-Z_][a-zA-Z0-9_]*:/) { run++; if(run>max) max=run } else run=0 } END{print max}' '" + full + "' 2>/dev/null"
    let prose_run = _to_int0(_str(exec(prose_cmd)).trim())
    if prose_run >= 3 {
        return "AI-NATIVE|warn|CLAUDE.md 연속 prose " + to_string(prose_run) + "줄 — key:value/표/리스트로 재작성"
    }
    return ""
}

// ─── Check 6: AI-native — JSON/JSONL 포맷 ───
fn check_json(path: string) -> string {
    let e = ext_of(path)
    if e != ".json" && e != ".jsonl" { return "" }
    let full = REPO_ROOT + "/" + path
    // JSONL: 모든 비-빈 라인이 { 또는 [ 로 시작해야 함
    if e == ".jsonl" {
        let bad = _to_int0(_str(exec("awk 'NF>0 && $0 !~ /^[{\\[]/' '" + full + "' 2>/dev/null | wc -l")).trim())
        if bad > 0 {
            return "AI-NATIVE|error|JSONL 에 비-JSON 라인 " + to_string(bad) + "건 — 각 라인 { 또는 [ 로 시작"
        }
    }
    // JSON: 단일 string 값 2000자+ (prose 누출)
    if e == ".json" {
        let long_val = _to_int0(_str(exec("grep -oE '\"[^\"]{2000,}\"' '" + full + "' 2>/dev/null | wc -l")).trim())
        if long_val > 0 {
            return "AI-NATIVE|warn|JSON string 값 2000자+ — prose 누출, 별도 파일 또는 배열 분할"
        }
    }
    return ""
}

// ─── Check R20: pkill/pgrep -f substring 금지 ───
// -f substring 은 무고한 프로세스 silent kill 위험. -xf 정확매칭 또는 PID 파일 기반 사용.
fn check_pkill_substring(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" { return "" }
    // 하네스 자신/lockdown 은 이미 검증됨
    if path.starts_with("shared/harness/") { return "" }
    let full = REPO_ROOT + "/" + path
    // pkill -f 또는 pgrep -f 매칭. -xf 는 제외 (정확매칭 = 안전)
    let cmd = "grep -nE '\\b(pkill|pgrep)[[:space:]]+-f\\b' '" + full + "' 2>/dev/null | grep -v '\\-xf' | grep -v '@allow-pkill-f' | wc -l"
    let hits = _to_int0(_str(exec(cmd)).trim())
    if hits > 0 {
        return "R20|error|pkill/pgrep -f substring " + to_string(hits) + "건 — 무고한 프로세스 kill 위험. -xf 정확매칭 또는 PID 파일 사용 (// @allow-pkill-f)"
    }
    return ""
}

// ─── Check R22: 스크립트 인터프리터 bare 호출 금지 ───
// .hexa/.sh 코드 안에서 python3/ruby/node 를 절대경로 없이 호출하는지 감지.
// /usr/bin/python3 등 절대경로 앞선 호출은 통과. 변수 대입(VAR=python3 ...)은 제외.
// 예외 토큰: // @allow-bare-interp
fn check_bare_interpreter(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" { return "" }
    if path.starts_with("shared/harness/") { return "" }
    let full = REPO_ROOT + "/" + path
    // 패턴: (행시작|공백|세미콜론|파이프|&|괄호) 바로 뒤 python3|ruby|node + 공백
    // 단, 직전이 '/' 또는 '=' 이면 제외 (절대경로/변수대입)
    let cmd = "grep -nE '(^|[[:space:]]|;|\\||&|\\()(python3|ruby|node)[[:space:]]' '" + full + "' 2>/dev/null | grep -vE '/(python3|ruby|node)[[:space:]]' | grep -vE '=(python3|ruby|node)[[:space:]]' | grep -v '@allow-bare-interp' | wc -l"
    let hits = _to_int0(_str(exec(cmd)).trim())
    if hits > 0 {
        return "R22|error|bare interpreter 호출 " + to_string(hits) + "건 — /usr/bin/python3 등 절대경로 필수 (hetzner 라우팅 회피). // @allow-bare-interp 예외"
    }
    return ""
}

// ─── Check R29: 계산기/검증 .hexa 단일 SSOT (shared/n6/scripts/) ───
// 금지 경로: */theory/**/*.hexa, */predictions/*.hexa, */proofs/*.hexa,
//           */breakthroughs/*.hexa, papers/**/*.hexa, hexa-lang/docs/*.hexa
// 예외: archive/, _archive/, shared/harness/, shared/rules/, // @allow-project-hexa 주석 포함 파일
fn check_calculator_ssot_path(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    if path.starts_with("shared/") { return "" }
    if path.starts_with("archive/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }

    let banned = ["/theory/", "/predictions/", "/proofs/", "/breakthroughs/", "/papers/", "/hexa-lang/docs/"]
    let mut hit_seg = ""
    for s in banned {
        if path.index_of(s) >= 0 { hit_seg = s; break }
    }
    if hit_seg == "" { return "" }

    // 예외 토큰 — 개별 파일 승인
    let full = REPO_ROOT + "/" + path
    let marker = _str(exec("grep -c '@allow-project-hexa' '" + full + "' 2>/dev/null")).trim()
    if _to_int0(marker) > 0 { return "" }

    return "R29|error|계산기/검증 .hexa 는 shared/n6/scripts/ 단일 SSOT — '" + hit_seg + "' 하위 금지 (// @allow-project-hexa 예외)"
}

// ─── Check CMDS-DRIFT: commands.json 키워드 하드코딩 매칭 ───
// 대상: .hexa 중 prompt_scan/cmd_gate/lint 외
// 패턴: (cmd|matched|keyword|kw|name) == "(smash|go|todo|keep|loop|list|roi|lm|free_dfs|free)" 3+ 회
// 우회: // @allow-cmds-hardcode 토큰
fn check_cmds_hardcoded(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }

    let base = _str(exec("basename '" + path + "' 2>/dev/null")).trim()
    // 화이트리스트: SSOT 동적 로드 또는 정책 분기
    if base == "prompt_scan.hexa" { return "" }
    if base == "cmd_gate.hexa" { return "" }
    if base == "lint.hexa" { return "" }
    if base == "entry.hexa" { return "" }

    let full = REPO_ROOT + "/" + path

    // 우회 마커
    let bypass = _to_int0(_str(exec("grep -c '@allow-cmds-hardcode' '" + full + "' 2>/dev/null")).trim())
    if bypass > 0 { return "" }

    let pattern = "(cmd|matched|keyword|kw|name)[[:space:]]*==[[:space:]]*\"(smash|go|todo|keep|loop|list|roi|lm|free_dfs|free)\""
    let hits = _to_int0(_str(exec("grep -cE '" + pattern + "' '" + full + "' 2>/dev/null")).trim())
    if hits >= 3 {
        return "CMDS-DRIFT|warn|commands.json 키워드 매칭 " + to_string(hits) + "건 — SSOT 동적 로드 필요. shared/harness/prompt_scan.hexa load_cmds_from_ssot() 패턴 참조 (jq + commands.json)"
    }
    return ""
}

// ─── H-CMD-DRIFT / H-CMD-SCHEMA / H-CMD-DEAD — commands.json SSOT 드리프트 ───
// 트리거: 대상 파일 목록에 shared/config/commands.json 포함 시 1회만 호출.
// 비용 절감: jq 가용 시만 동작 (없으면 silent skip).
// 반환: "rule|severity|message" 라인을 \n 으로 join (0~N건). 없으면 "".

fn _hcmd_jq_available() -> bool {
    let has_jq = _str(exec("command -v jq >/dev/null 2>&1 && echo y || echo n")).trim()
    if has_jq == "y" { return true }
    return false
}

// commands[*] 키 목록 (한 줄 당 1개). commands 없으면 "".
fn _hcmd_keys(cj: string) -> string {
    return _str(exec("jq -r '.commands | keys[]' '" + cj + "' 2>/dev/null")).trim()
}

// H-CMD-DRIFT: 키워드 교집합 > 0 검출
fn check_cmd_drift(cj: string) -> string {
    if !_hcmd_jq_available() { return "" }
    // "cmd|keyword" 라인 전체 추출 후 awk 로 중복 keyword 집계
    let cmd = "jq -r '.commands | to_entries[] | .key as $k | (.value.keywords // []) | .[] | \"\\($k)|\\(.)\"' '" + cj + "' 2>/dev/null | awk -F'|' '{cnt[$2]++; if(cnt[$2]==1) owners[$2]=$1; else owners[$2]=owners[$2]\",\"$1} END{for(k in cnt) if(cnt[k]>1) print k\"|\"owners[k]}'"
    let raw = _str(exec(cmd)).trim()
    if raw == "" { return "" }
    let mut out = ""
    let lines = raw.split("\n")
    for ln in lines {
        let l = _str(ln).trim()
        if l == "" { continue }
        let bar = l.index_of("|")
        if bar < 0 { continue }
        let kw = l.substring(0, bar)
        let owners = l.substring(bar + 1, len(l))
        if out != "" { out = out + "\n" }
        out = out + "H-CMD-DRIFT|error|H-CMD-DRIFT: keyword \"" + kw + "\" duplicated in [" + owners + "]"
    }
    return out
}

// H-CMD-SCHEMA: 필수 필드 description/action/keywords + format_preset 참조 유효성
fn check_cmd_schema(cj: string) -> string {
    if !_hcmd_jq_available() { return "" }
    let keys = _hcmd_keys(cj)
    if keys == "" { return "" }
    let mut out = ""
    let names = keys.split("\n")
    for nm in names {
        let k = _str(nm).trim()
        if k == "" { continue }
        let cmd = "jq -r --arg k '" + k + "' '.commands[$k] | \"\\(if has(\"description\") then 1 else 0 end)|\\(if has(\"action\") then 1 else 0 end)|\\(if has(\"keywords\") then 1 else 0 end)|\\(.format_preset // \"\")\"' '" + cj + "' 2>/dev/null"
        let r = _str(exec(cmd)).trim()
        if r == "" { continue }
        let parts = r.split("|")
        if len(parts) < 4 { continue }
        let has_desc = _str(parts[0])
        let has_action = _str(parts[1])
        let has_kw = _str(parts[2])
        let fp = _str(parts[3])
        if has_desc == "0" {
            if out != "" { out = out + "\n" }
            out = out + "H-CMD-SCHEMA|error|H-CMD-SCHEMA: command \"" + k + "\" missing field \"description\""
        }
        if has_action == "0" {
            if out != "" { out = out + "\n" }
            out = out + "H-CMD-SCHEMA|error|H-CMD-SCHEMA: command \"" + k + "\" missing field \"action\""
        }
        if has_kw == "0" {
            if out != "" { out = out + "\n" }
            out = out + "H-CMD-SCHEMA|error|H-CMD-SCHEMA: command \"" + k + "\" missing field \"keywords\""
        }
        if fp != "" && fp != "null" {
            let exist = _str(exec("jq -r --arg p '" + fp + "' '(.format_presets // {}) | has($p) | tostring' '" + cj + "' 2>/dev/null")).trim()
            if exist != "true" {
                if out != "" { out = out + "\n" }
                out = out + "H-CMD-SCHEMA|error|H-CMD-SCHEMA: command \"" + k + "\" format_preset \"" + fp + "\" not defined in format_presets"
            }
        }
    }
    return out
}

// H-CMD-DEAD: auto.hit_count==0 이고 updated 로부터 30일 경과 (file mtime 또는 .updated)
// rules_usage.jsonl 미존재 시 skip (silent).
fn check_cmd_dead(cj: string) -> string {
    if !_hcmd_jq_available() { return "" }
    let usage = NEXUS_HARNESS + "/rules_usage.jsonl"
    if !file_exists(usage) { return "" }
    // 기준 시각: commands.json .updated 필드 (YYYY-MM-DD) 또는 file mtime
    let now_s = _str(exec("date +%s")).trim()
    let now = _to_int0(now_s)
    let upd = _str(exec("jq -r '.updated // \"\"' '" + cj + "' 2>/dev/null")).trim()
    let mut base_ts: i64 = 0
    if upd != "" {
        let ts_s = _str(exec("date -j -f '%Y-%m-%d' '" + upd + "' +%s 2>/dev/null || date -d '" + upd + "' +%s 2>/dev/null")).trim()
        base_ts = _to_int0(ts_s)
    }
    if base_ts == 0 {
        let mt_s = _str(exec("stat -f '%m' '" + cj + "' 2>/dev/null || stat -c '%Y' '" + cj + "' 2>/dev/null")).trim()
        base_ts = _to_int0(mt_s)
    }
    if base_ts == 0 { return "" }
    let elapsed = now - base_ts
    let thirty_days: i64 = 2592000
    if elapsed < thirty_days { return "" }
    // hit_count==0 명령 목록
    let cmd = "jq -r '.commands | to_entries[] | select((.value.auto.hit_count // -1) == 0) | .key' '" + cj + "' 2>/dev/null"
    let raw = _str(exec(cmd)).trim()
    if raw == "" { return "" }
    let mut out = ""
    let names = raw.split("\n")
    for nm in names {
        let k = _str(nm).trim()
        if k == "" { continue }
        if out != "" { out = out + "\n" }
        out = out + "H-CMD-DEAD|warn|H-CMD-DEAD: command \"" + k + "\" dormant 0 hit for 30+ days → bitter-gate audit 후보"
    }
    return out
}

// 통합: 3 룰 실행 후 멀티라인 합치기 (violations push 에 사용)
fn run_cmd_checks(cj_rel: string) -> string {
    let cj = REPO_ROOT + "/" + cj_rel
    if !file_exists(cj) { return "" }
    let a = check_cmd_drift(cj)
    let b = check_cmd_schema(cj)
    let c = check_cmd_dead(cj)
    let mut out = ""
    if a != "" { out = a }
    if b != "" { if out != "" { out = out + "\n" }; out = out + b }
    if c != "" { if out != "" { out = out + "\n" }; out = out + c }
    return out
}

// ─── H-PROJ-HARDCODE (warn) — projects.json SSOT 프로젝트 이름 하드코딩 검출 ───
// Why: 프로젝트 이름 5개 이상 동시 하드코딩 시 projects.json 드리프트. SSOT 동적 로드 강제.
// 대상 확장자: .json/.jsonl/.md/.hexa. 제외: projects.json/nexus-projects.json 본체.
// 동적 추출: `jq '.projects | keys'` — 룰 자체가 프로젝트 이름 하드코딩이면 irony.

fn _hproj_available() -> bool {
    let has_jq = _str(exec("command -v jq >/dev/null 2>&1 && echo y || echo n")).trim()
    if has_jq == "y" { return true }
    return false
}

// projects.json 에서 프로젝트 이름 개행 구분 리스트 (실패 시 "").
fn _hproj_names() -> string {
    if !_hproj_available() { return "" }
    let pj = REPO_ROOT + "/shared/config/projects.json"
    if !file_exists(pj) { return "" }
    return _str(exec("jq -r '.projects | keys | .[]' '" + pj + "' 2>/dev/null")).trim()
}

fn check_proj_hardcode(path: string) -> string {
    let e = ext_of(path)
    if e != ".json" && e != ".jsonl" && e != ".md" && e != ".hexa" { return "" }
    // SSOT 본체 skip
    if path == "shared/config/projects.json" { return "" }
    if path == "shared/config/nexus-projects.json" { return "" }
    let names = _hproj_names()
    if names == "" { return "" }
    let full = REPO_ROOT + "/" + path
    if !file_exists(full) { return "" }
    let mut content = ""
    try { content = read_file(full) } catch e {}
    if content == "" { return "" }
    // 룰 자기참조 skip (lint.hexa 자체 등)
    if content.index_of("H-PROJ-HARDCODE") >= 0 { return "" }
    let mut hits = 0
    let mut matched = ""
    let plist = names.split("\n")
    for nm in plist {
        let n = _str(nm).trim()
        if n == "" { continue }
        if content.index_of(n) >= 0 {
            hits = hits + 1
            if matched == "" { matched = n } else { matched = matched + "," + n }
            if hits >= 5 {
                // 짧은 파일 최적화: 5+ 즉시 반환
                return "H-PROJ-HARDCODE|warn|H-PROJ-HARDCODE: " + path + " contains 5+ project names hardcoded [" + matched + "] → reference shared/config/projects.json"
            }
        }
    }
    return ""
}

// ─── Check R34: 로드맵 최소 경로 문법 ───
// 대상: roadmap*.json | */roadmaps/*.json | *.roadmap.json
// 금지 키: depends_on/deps/priority/weight/roi/est/val/phases/tracks/gate_exit/
//          acceleration_options/cost_projection/decision_points/critical_path
// 우회: 파일 내 `"_legacy": true` 또는 `@allow-roadmap-ext` 토큰
fn check_r34(path: string) -> string {
    let e = ext_of(path)
    if e != ".json" { return "" }
    let base = _str(exec("basename '" + path + "' 2>/dev/null")).trim()
    let is_roadmap = base.starts_with("roadmap") || base.ends_with(".roadmap.json") || path.index_of("/roadmaps/") >= 0
    if is_roadmap == false { return "" }

    let full = REPO_ROOT + "/" + path
    let legacy = _to_int0(_str(exec("grep -c '\"_legacy\":[[:space:]]*true\\|@allow-roadmap-ext' '" + full + "' 2>/dev/null")).trim())
    if legacy > 0 { return "" }

    let banned = "\"depends_on\"|\"deps\"|\"priority\"|\"weight\"|\"roi\"|\"est\"|\"val\"|\"phases\"|\"tracks\"|\"gate_exit\"|\"acceleration_options\"|\"cost_projection\"|\"decision_points\"|\"critical_path\""
    let hits = _to_int0(_str(exec("grep -cE '" + banned + "' '" + full + "' 2>/dev/null")).trim())
    if hits > 0 {
        return "R34|warn|로드맵 확장 스키마 " + to_string(hits) + "건 — 최소 경로 문법(순차/병렬/>/par_bg) 권장. 레거시면 `\"_legacy\": true` 추가 또는 재작성"
    }
    return ""
}

// ─── 프로젝트 감지 ───
fn _project_name() -> string {
    let root = _str(exec("git rev-parse --show-toplevel 2>/dev/null")).trim()
    if root == "" { return "" }
    return _str(exec("basename '" + root + "' 2>/dev/null")).trim()
}

// ─── HX4 (hexa-lang 전용) SELF-HOST 공리 ───
// L0 (공리): hexa-lang 은 hexa-lang 으로 작성된다.
// L1: 신규 소스 확장자 = .hexa only (.c syscall helper, 허용 확장자 whitelist 외 error)
// L2: 외부 컴파일러 언급 (rust/cargo/rustc) 금지 — 이전 v4+v5 grep 유지
// 예외: archive/, _archive/, self/docs/, build/ (생성물), 하네스 자신
fn _hx4_is_exempt(path: string) -> bool {
    if path.starts_with("archive/") { return true }
    if path.index_of("/_archive/") >= 0 { return true }
    if path.index_of("hexa_pitfalls_log") >= 0 { return true }
    if path.starts_with("self/docs/") { return true }
    if path.starts_with("build/") { return true }
    if path.starts_with("shared/harness/") { return true }
    if path.starts_with("shared/rules/") { return true }
    // editors/playground/docs-website: 외부 도구 필수 (IntelliJ Java, web assets)
    if path.starts_with("editors/") { return true }
    if path.starts_with("playground/") { return true }
    if path.starts_with("docs/website/") { return true }
    // AI 메모리/worktree/growth 캐시
    if path.starts_with(".claude") { return true }
    if path.starts_with(".growth") { return true }
    if path.starts_with(".superpowers") { return true }
    // 역사 문서 (레거시 테스트/빌드 언급 포함)
    if path.starts_with("docs/superpowers/") { return true }
    if path.starts_with("docs/history/") { return true }
    // log 파일
    if path.index_of(".log") >= 0 { return true }
    return false
}

// L1 허용 확장자: self-host 공리 준수 파일 종류
fn _is_self_host_ext(ext: string) -> bool {
    if ext == ".hexa" { return true }
    if ext == ".c" { return true }
    if ext == ".h" { return true }
    if ext == ".md" { return true }
    if ext == ".json" { return true }
    if ext == ".jsonl" { return true }
    if ext == ".yaml" { return true }
    if ext == ".yml" { return true }
    if ext == ".toml" { return true }
    if ext == ".txt" { return true }
    if ext == ".sh" { return true }
    return false
}

// 확장자 없는 허용 파일명
fn _is_self_host_bare(bn: string) -> bool {
    if bn == "Makefile" { return true }
    if bn == "README" { return true }
    if bn == "LICENSE" { return true }
    if bn == "CODEOWNERS" { return true }
    if bn == "Dockerfile" { return true }
    if bn == "hexa" { return true }
    if bn == "hexa-build" { return true }
    if bn.starts_with(".") { return true }
    return false
}

// L1 확장자/파일명 whitelist
fn _hx4_l1_ext(path: string) -> string {
    let e = ext_of(path)
    let bn = basename_of(path)
    if e == "" {
        if !_is_self_host_bare(bn) {
            return "HX4-L1|error|SELF-HOST — 허용되지 않은 파일 '" + bn + "'"
        }
    } else {
        if !_is_self_host_ext(e) {
            return "HX4-L1|error|SELF-HOST — 소스 확장자 '" + e + "' 금지. .hexa 로 재작성"
        }
    }
    return ""
}

// L2 외부 툴체인 언급 grep
fn _hx4_l2_toolchain(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".md" && e != ".json" && e != ".jsonl" && e != ".sh" && e != ".yaml" && e != ".yml" && e != ".toml" { return "" }
    let full = REPO_ROOT + "/" + path
    let cmd = "grep -E '\\brust\\b|\\bRust\\b|\\bRUST\\b|\\bcargo\\b|\\bCargo\\b|\\brustc\\b|\\brustup\\b|target/(debug|release)' '" + full + "' 2>/dev/null | grep -v '@allow-rust-mention' | wc -l"
    let hits = _to_int0(_str(exec(cmd)).trim())
    if hits > 0 {
        return "HX4-L2|error|외부 툴체인 언급 " + to_string(hits) + "건 (// @allow-rust-mention)"
    }
    return ""
}

// L3 런타임 FFI/dlopen 금지 — self/runtime.c 내부 API 만
// 예외: self/ 컴파일러 내부 (ffi 생성기는 self-host 본질), self/ml/ FFI 인프라
fn _hx4_l3_runtime(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    // self/ 컴파일러는 ffi 코드 생성기라 예외
    if path.starts_with("self/") { return "" }
    let full = REPO_ROOT + "/" + path
    let cmd = "grep -E '\\b(dlopen|dlsym|ffi_call|ffi_new|FFI\\.)' '" + full + "' 2>/dev/null | grep -v '@allow-ffi' | wc -l"
    let hits = _to_int0(_str(exec(cmd)).trim())
    if hits > 0 {
        return "HX4-L3|error|런타임 외부 FFI/dlopen " + to_string(hits) + "건 (// @allow-ffi)"
    }
    return ""
}

// L4 문서 = hexa 실행 가능 예제 — 언어 명세/튜토리얼 .md 에 ```hexa 블록 필수
// 대상 패턴: spec/reference/grammar/syntax/tutorial/quickstart/guide/getting-started/intro
fn _hx4_l4_docs(path: string) -> string {
    let e = ext_of(path)
    if e != ".md" { return "" }
    if !path.starts_with("docs/") { return "" }
    // 문서 하위 카테고리 예외
    if path.starts_with("docs/paper/") { return "" }
    if path.starts_with("docs/history/") { return "" }
    if path.starts_with("docs/superpowers/") { return "" }
    if path.starts_with("docs/breakthroughs/") { return "" }
    if path.starts_with("docs/victories/") { return "" }
    let bn = basename_of(path)
    if bn == "README.md" || bn == "CHANGELOG.md" { return "" }
    let bn_lo = bn.to_lower()
    let is_spec = bn_lo.index_of("spec") >= 0 || bn_lo.index_of("reference") >= 0 || bn_lo.index_of("grammar") >= 0 || bn_lo.index_of("syntax") >= 0 || bn_lo.index_of("tutorial") >= 0 || bn_lo.index_of("quickstart") >= 0 || bn_lo.index_of("guide") >= 0 || bn_lo.index_of("getting-started") >= 0 || bn_lo.index_of("intro") >= 0 || bn_lo.index_of("manual") >= 0
    if !is_spec { return "" }
    let full = REPO_ROOT + "/" + path
    let has_hexa = _to_int0(_str(exec("grep -c '```hexa' '" + full + "' 2>/dev/null || echo 0")).trim())
    if has_hexa == 0 {
        return "HX4-L4|warn|언어 문서(spec/reference/grammar/tutorial/guide) 에 ```hexa 실행 예제 없음 (// @allow-non-executable-doc)"
    }
    return ""
}

// L5 테스트 프레임워크 외부 의존 금지 — hexa 자체 테스트 사용
fn _hx4_l5_tests(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" && e != ".yaml" && e != ".yml" && e != ".json" && e != ".jsonl" && e != ".md" && e != ".toml" { return "" }
    let full = REPO_ROOT + "/" + path
    let cmd = "grep -E '\\b(pytest|cargo test|jest|mocha|phpunit|go test|rspec|junit)\\b' '" + full + "' 2>/dev/null | grep -v '@allow-ext-test' | wc -l"
    let hits = _to_int0(_str(exec(cmd)).trim())
    if hits > 0 {
        return "HX4-L5|error|외부 테스트 프레임워크 " + to_string(hits) + "건 (// @allow-ext-test)"
    }
    return ""
}

// L6 CI = hexa — .github/workflows run: 스텝이 hexa 기반이어야
fn _hx4_l6_ci(path: string) -> string {
    if !path.starts_with(".github/workflows/") { return "" }
    let e = ext_of(path)
    if e != ".yml" && e != ".yaml" { return "" }
    let full = REPO_ROOT + "/" + path
    // run: 으로 시작하는 라인 중 hexa/./hexa 로 이어지지 않는 것 + uses:/setup-*/checkout 예외
    let cmd = "grep -E '^[[:space:]]+run:[[:space:]]' '" + full + "' 2>/dev/null | grep -vE 'run:[[:space:]]*(hexa|\\./hexa|\\$\\{|echo |true$)|@allow-non-hexa-step' | wc -l"
    let hits = _to_int0(_str(exec(cmd)).trim())
    if hits > 0 {
        return "HX4-L6|warn|CI run: 스텝 " + to_string(hits) + "건 비-hexa (// @allow-non-hexa-step)"
    }
    return ""
}

// L7 빌드 재귀 — 체인 파일 존재 + 최소 크기 + SSOT↔산출물 일치
fn _hx4_l7_build_chain(path: string) -> string {
    if path != "build_hexa.hexa" && path != "self/main.hexa" && path != "self/hexa_full.hexa" && path != "scripts/build/build_hexa.hexa" && path != "self/hexa_full.json" { return "" }
    let stage0 = REPO_ROOT + "/build/hexa_stage0"
    if !file_exists(stage0) {
        return "HX4-L7|error|build/hexa_stage0 부재 — 빌드 체인 깨짐"
    }
    // stage0 바이너리 최소 크기 100KB (codesign 된 실행파일 하한)
    let sz = _to_int0(_str(exec("stat -f '%z' '" + stage0 + "' 2>/dev/null || stat -c '%s' '" + stage0 + "' 2>/dev/null || echo 0")).trim())
    if sz < 102400 {
        return "HX4-L7|error|build/hexa_stage0 크기 " + to_string(sz) + " 바이트 < 100KB — 빌드 산출물 의심"
    }
    if !file_exists(REPO_ROOT + "/self/main.hexa") {
        return "HX4-L7|error|self/main.hexa 부재"
    }
    if !file_exists(REPO_ROOT + "/self/hexa_full.hexa") {
        return "HX4-L7|error|self/hexa_full.hexa 부재"
    }
    // hexa_full.hexa mtime > hexa_stage0 mtime 이면 재빌드 필요 — warn
    let src_mt = _to_int0(_str(exec("stat -f '%m' '" + REPO_ROOT + "/self/hexa_full.hexa' 2>/dev/null || stat -c '%Y' '" + REPO_ROOT + "/self/hexa_full.hexa' 2>/dev/null || echo 0")).trim())
    let bin_mt = _to_int0(_str(exec("stat -f '%m' '" + stage0 + "' 2>/dev/null || stat -c '%Y' '" + stage0 + "' 2>/dev/null || echo 0")).trim())
    if src_mt > bin_mt {
        return "HX4-L7|warn|self/hexa_full.hexa (mtime " + to_string(src_mt) + ") > build/hexa_stage0 (mtime " + to_string(bin_mt) + ") — 재빌드 필요"
    }
    return ""
}

// L8 메타 = hexa AST transform — sed/awk 로 .hexa 조작 금지
fn _hx4_l8_meta(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" { return "" }
    let full = REPO_ROOT + "/" + path
    let cmd = "grep -E 'exec\\([^)]*\"(sed|awk)[^\"]*\\.hexa' '" + full + "' 2>/dev/null | grep -v '@allow-meta-scripting' | wc -l"
    let hits = _to_int0(_str(exec(cmd)).trim())
    if hits > 0 {
        return "HX4-L8|error|sed/awk .hexa 조작 " + to_string(hits) + "건. AST transform 은 hexa 로만 (// @allow-meta-scripting)"
    }
    return ""
}

// ─── VD1 (void 전용) — Terminal.app 단일 참조 강제 (타 터미널 에뮬레이터 언급 금지) ───
fn check_vd1(path: string) -> string {
    if _project_name() != "void" { return "" }
    let e = ext_of(path)
    if e != ".hexa" && e != ".c" && e != ".m" && e != ".h" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.starts_with("docs/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    if path.starts_with("shared/harness/") { return "" }
    if path.starts_with("shared/rules/") { return "" }
    if path.index_of("CLAUDE.md") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    let cmd = "grep -E '\\b(iTerm2|kitty|Warp|Ghostty|Alacritty|WezTerm|Hyper)\\b' '" + full + "' 2>/dev/null | grep -v '@allow-terminal-mention' | wc -l"
    let hits = _to_int0(_str(exec(cmd)).trim())
    if hits > 0 {
        return "VD1|error|외부 터미널 에뮬레이터 언급 " + to_string(hits) + "건 — Terminal.app 단일 참조 원칙 (// @allow-terminal-mention)"
    }
    return ""
}

// ─── VD2 (void 전용) — 복잡도 동결 (monotonic complexity gate) ───
// 원칙: 기능 추가 OK, 기존 기능의 복잡도 증가 금지.
//       감소/유지 → silent pass. 증가 → error + 마커 요구.
// 지표:
//   C1: 함수 파라미터 합계 (fn NAME(...) arity 총합)
//   C3: CLI 플래그 개수 ("--flag" 유니크 수)
// 비교: git show HEAD:<path>  vs  working copy
// 예외: // @allow-complexity-growth, archive/, docs/, tests/, shared/harness|rules/
fn check_vd2(path: string) -> string {
    if _project_name() != "void" { return "" }
    let e = ext_of(path)
    if e != ".hexa" && e != ".c" && e != ".h" && e != ".m" && e != ".swift" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.starts_with("docs/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    if path.starts_with("shared/harness/") { return "" }
    if path.starts_with("shared/rules/") { return "" }
    if path.starts_with("tests/") { return "" }
    if path.index_of("/test/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    // 파일 전체에 예외 마커 있으면 스킵
    let marker = _to_int0(_str(exec("grep -c '@allow-complexity-growth' '" + full + "' 2>/dev/null || echo 0")).trim())
    if marker > 0 { return "" }
    // HEAD 에 파일 없으면 신규 파일 — 복잡도 비교 대상 아님 (신규 기능은 허용)
    let exists_head = _str(exec("git cat-file -e HEAD:'" + path + "' 2>/dev/null && echo y || echo n")).trim()
    if exists_head == "n" { return "" }

    // C1: fn 시그니처 파라미터 합계 — comma 수 + nonempty 1
    let awk = " | awk -F'[(),]' '{ n=0; for(i=2;i<=NF;i++) if($i ~ /[[:alnum:]]/) n++; sum+=n } END { print sum+0 }'"
    let c1_after  = _to_int0(_str(exec("grep -oE 'fn [a-zA-Z_][a-zA-Z0-9_]*\\([^)]*\\)' '" + full + "' 2>/dev/null" + awk)).trim())
    let c1_before = _to_int0(_str(exec("git show HEAD:'" + path + "' 2>/dev/null | grep -oE 'fn [a-zA-Z_][a-zA-Z0-9_]*\\([^)]*\\)' 2>/dev/null" + awk)).trim())
    if c1_after > c1_before {
        return "VD2-C1|error|함수 파라미터 합계 " + to_string(c1_before) + " → " + to_string(c1_after) + " 증가 — 복잡도 동결 위반 (// @allow-complexity-growth)"
    }
    // C3: CLI 플래그 유니크 수 (--flag 리터럴)
    let c3_after  = _to_int0(_str(exec("grep -oE '\"--[a-z][a-z0-9-]*\"' '" + full + "' 2>/dev/null | sort -u | wc -l")).trim())
    let c3_before = _to_int0(_str(exec("git show HEAD:'" + path + "' 2>/dev/null | grep -oE '\"--[a-z][a-z0-9-]*\"' 2>/dev/null | sort -u | wc -l")).trim())
    if c3_after > c3_before {
        return "VD2-C3|error|CLI 플래그 유니크 수 " + to_string(c3_before) + " → " + to_string(c3_after) + " 증가 — 복잡도 동결 위반 (// @allow-complexity-growth)"
    }
    return ""
}

// ─── PP2 (papers 전용) — 논문 .md 에 검증코드 ```python 블록 필수 ───
fn check_pp2(path: string) -> string {
    if _project_name() != "papers" { return "" }
    let e = ext_of(path)
    if e != ".md" { return "" }
    let bn = basename_of(path)
    // CLAUDE.md/README/LICENSE 는 논문 아님
    if bn == "CLAUDE.md" || bn == "README.md" || bn == "LICENSE.md" { return "" }
    // archive/_archive 예외
    if path.starts_with("archive/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    // 코드 블록 존재 확인 — python 또는 hexa 실행 블록
    let has = _to_int0(_str(exec("grep -cE '^\\`\\`\\`(python|hexa)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if has == 0 {
        return "PP2|warn|논문 .md 에 ```python 또는 ```hexa 검증코드 블록 없음 (// @allow-unverified-paper)"
    }
    return ""
}

// ─── PP1 (papers 전용) — CC-BY 4.0 라이선스 통일 ───
// 공리: papers/ 내 논문 .md 는 헤더 30줄 내 CC-BY 4.0 라이선스 선언 필수.
// 허용 표현: "CC-BY 4.0", "CC-BY-4.0", "Creative Commons Attribution 4.0", "CC BY 4.0"
// 예외: CLAUDE.md, README.md, LICENSE.md, CHANGELOG.md, archive/, // @allow-no-license
fn check_pp1(path: string) -> string {
    if _project_name() != "papers" { return "" }
    let e = ext_of(path)
    if e != ".md" { return "" }
    let bn = basename_of(path)
    if bn == "CLAUDE.md" || bn == "README.md" || bn == "LICENSE.md" || bn == "CHANGELOG.md" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    let marker = _to_int0(_str(exec("grep -c '@allow-no-license' '" + full + "' 2>/dev/null || echo 0")).trim())
    if marker > 0 { return "" }
    // 헤더 30줄 내 CC-BY 4.0 라이선스 선언
    let has = _to_int0(_str(exec("head -30 '" + full + "' 2>/dev/null | grep -ciE '(CC[- ]?BY[- ]?4\\.0|Creative Commons Attribution 4\\.0)' || echo 0")).trim())
    if has == 0 {
        return "PP1|error|논문 '" + bn + "' 헤더에 CC-BY 4.0 라이선스 선언 없음 (// @allow-no-license)"
    }
    return ""
}

// ─── AG4 (airgenome 전용) — Hetzner launcher cap ≤8 강제 ───
fn check_ag4(path: string) -> string {
    if _project_name() != "airgenome" { return "" }
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" && e != ".json" && e != ".jsonl" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.starts_with("shared/harness/") { return "" }
    let full = REPO_ROOT + "/" + path
    // launcher_max 또는 LAUNCHER_MAX 상수가 9+ 로 설정된 경우 error
    let cmd = "grep -nE '(launcher_max|LAUNCHER_MAX|hetzner_launcher_cap)[[:space:]]*[=:][[:space:]]*([9-9]|[1-9][0-9]+)\\b' '" + full + "' 2>/dev/null | grep -v '@allow-launcher-cap' | wc -l"
    let hits = _to_int0(_str(exec(cmd)).trim())
    if hits > 0 {
        return "AG4|error|launcher cap > 8 설정 " + to_string(hits) + "건 — Hetzner 동시 실행 ≤8 강제 (// @allow-launcher-cap)"
    }
    return ""
}

// ─── AG5 (airgenome 전용) — 'filter' 네이밍 규율 ───
// 공리 (L0 골화 2026-04-12): filter = raw bytes → 다른 byte 표현 transform.
//       hot path 속도/메모리/IO 개선. cleanup/dedup/gzip/cron/sync/watcher/
//       throttle/kickstart 는 filter 아님 (별도 이름 사용).
// L1 (AG5-N1): 파일명에 'filter' 포함 → 헤더 주석에 raw + byte + (round-trip|latency|encode|decode) 키워드 필수
// L3 (AG5-N3): 파일명에 'filter' 와 금지 보조작업 키워드가 동시 포함 → rename
// 예외: // @allow-non-filter, archive/, shared/harness/, docs/
fn check_ag5(path: string) -> string {
    if _project_name() != "airgenome" { return "" }
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.starts_with("shared/harness/") { return "" }
    if path.starts_with("docs/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    let bn = basename_of(path)
    // filter 미포함 파일은 무관
    if bn.index_of("filter") < 0 { return "" }
    let full = REPO_ROOT + "/" + path
    // 예외 마커
    let marker = _to_int0(_str(exec("grep -c '@allow-non-filter' '" + full + "' 2>/dev/null || echo 0")).trim())
    if marker > 0 { return "" }
    // AG5-N3: filter + 보조작업 키워드 동시 파일명 금지
    let bad = _to_int0(_str(exec("echo '" + bn + "' | grep -cE '(cleanup|dedup|gzip|cron|sync|watcher|throttle|kickstart)'")).trim())
    if bad > 0 {
        return "AG5-N3|error|파일명 '" + bn + "' 에 filter + 보조작업 키워드 공존 — rename 필요 (// @allow-non-filter)"
    }
    // AG5-N1: 헤더(상위 40줄) 주석에 raw + byte + (round-trip|latency|encode|decode) 필수
    let head_has_raw  = _to_int0(_str(exec("head -40 '" + full + "' 2>/dev/null | grep -ciE '\\braw\\b' || echo 0")).trim())
    let head_has_byte = _to_int0(_str(exec("head -40 '" + full + "' 2>/dev/null | grep -ciE '\\bbytes?\\b' || echo 0")).trim())
    let head_has_rt   = _to_int0(_str(exec("head -40 '" + full + "' 2>/dev/null | grep -ciE '(round-?trip|latency|encode|decode)' || echo 0")).trim())
    if head_has_raw == 0 || head_has_byte == 0 || head_has_rt == 0 {
        return "AG5-N1|error|'" + bn + "' filter 헤더 주석 부적합 — raw + byte + (round-trip/latency/encode/decode) 키워드 필수 (// @allow-non-filter)"
    }
    return ""
}

// ─── N62-A (n6-architecture 전용) — 논문 md 에 ```python 검증코드 블록 필수 ───
// 원칙: 논문 = 검증 .py 코드를 ```python 코드블록으로 직접 embed. hexa 블록은 무관.
// Scope: papers/*.md, domains/*/paper/*.md
// 예외: CLAUDE/README, _index 계열, archive/, // @allow-no-verify
fn check_n62a(path: string) -> string {
    if _project_name() != "n6-architecture" { return "" }
    let e = ext_of(path)
    if e != ".md" { return "" }
    let bn = basename_of(path)
    if bn == "CLAUDE.md" || bn == "README.md" || bn == "LICENSE.md" || bn == "CHANGELOG.md" { return "" }
    if bn.starts_with("_") { return "" }
    let is_paper = path.starts_with("papers/") || (path.starts_with("domains/") && path.index_of("/paper/") >= 0)
    if !is_paper { return "" }
    if path.starts_with("archive/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    let marker = _to_int0(_str(exec("grep -c '@allow-no-verify' '" + full + "' 2>/dev/null || echo 0")).trim())
    if marker > 0 { return "" }
    // ```python 블록 (python만, hexa 제외)
    let has = _to_int0(_str(exec("grep -cE '^\\`\\`\\`python(\\b|$)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if has == 0 {
        return "N62-A|error|논문 '" + bn + "' 에 \\`\\`\\`python 검증코드 블록 없음 — .py 코드 직접 embed 필수 (// @allow-no-verify)"
    }
    return ""
}

// ─── N6 논문 canonical 양식 공통 scope 헬퍼 ───
// True 이면 n6 canonical 검사 대상 (papers/* 또는 domains/* 의 .md, _archive 제외)
fn _n6_canonical_in_scope(path: string) -> bool {
    if _project_name() != "n6-architecture" { return false }
    let e = ext_of(path)
    if e != ".md" { return false }
    let bn = basename_of(path)
    if bn == "CLAUDE.md" || bn == "README.md" || bn == "LICENSE.md" || bn == "CHANGELOG.md" { return false }
    if bn.starts_with("_") { return false }
    if path.starts_with("archive/") { return false }
    if path.index_of("/_archive/") >= 0 { return false }
    if path.index_of("/archive/") >= 0 { return false }
    let in_papers = path.starts_with("papers/")
    let in_domains = path.starts_with("domains/")
    if !in_papers && !in_domains { return false }
    return true
}

// 파일 전체에 canonical 양식 면제 마커가 있으면 true
fn _n6_canonical_exempt(full: string) -> bool {
    let m = _to_int0(_str(exec("grep -c '@allow-paper-canonical' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return true }
    return false
}

// ─── N61-C1 (n6-architecture) — 7 섹션 헤더 모두 존재 ───
// §1 WHY / §2 COMPARE / §3 REQUIRES / §4 STRUCT / §5 FLOW / §6 EVOLVE / §7 VERIFY
fn check_n61_c1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let mut missing = ""
    let mut miss_count: i64 = 0
    // §1 WHY: 당신의 삶 / Real-world / 실생활 효과
    let s1 = _to_int0(_str(exec("grep -cE '당신의 삶|Real-world|실생활 효과' '" + full + "' 2>/dev/null || echo 0")).trim())
    if s1 == 0 { missing = missing + " WHY"; miss_count = miss_count + 1 }
    // §2 COMPARE: (성능 비교 OR Comparison) AND ASCII
    let s2a = _to_int0(_str(exec("grep -cE '성능 비교|Comparison' '" + full + "' 2>/dev/null || echo 0")).trim())
    let s2b = _to_int0(_str(exec("grep -cE 'ASCII' '" + full + "' 2>/dev/null || echo 0")).trim())
    if s2a == 0 || s2b == 0 { missing = missing + " COMPARE"; miss_count = miss_count + 1 }
    // §3 REQUIRES: 필요한 요소 OR Requires OR 선행.*도메인
    let s3r = _to_int0(_str(exec("grep -cE '필요한 요소|Requires|선행.*도메인' '" + full + "' 2>/dev/null || echo 0")).trim())
    if s3r == 0 { missing = missing + " REQUIRES"; miss_count = miss_count + 1 }
    // §4 STRUCT: (시스템 구조 OR System.*Architecture OR 구조도) AND ASCII
    let s3a = _to_int0(_str(exec("grep -cE '시스템 구조|System.*Architecture|구조도' '" + full + "' 2>/dev/null || echo 0")).trim())
    if s3a == 0 || s2b == 0 { missing = missing + " STRUCT"; miss_count = miss_count + 1 }
    // §5 FLOW: (플로우 OR Flow OR 데이터.*에너지) AND ASCII
    let s4a = _to_int0(_str(exec("grep -cE '플로우|Flow|데이터.*에너지' '" + full + "' 2>/dev/null || echo 0")).trim())
    if s4a == 0 || s2b == 0 { missing = missing + " FLOW"; miss_count = miss_count + 1 }
    // §6 EVOLVE: Mk.I OR 진화 OR Evolution
    let s5 = _to_int0(_str(exec("grep -cE 'Mk\\.?I|진화|Evolution' '" + full + "' 2>/dev/null || echo 0")).trim())
    if s5 == 0 { missing = missing + " EVOLVE"; miss_count = miss_count + 1 }
    // §7 VERIFY: Python 검증 OR ```python
    let s6 = _to_int0(_str(exec("grep -cE 'Python 검증|^\\`\\`\\`python' '" + full + "' 2>/dev/null || echo 0")).trim())
    if s6 == 0 { missing = missing + " VERIFY"; miss_count = miss_count + 1 }
    if miss_count == 0 { return "" }
    return "N61-C1|error|논문 7섹션 누락 " + to_string(miss_count) + "건 (WHY/COMPARE/REQUIRES/STRUCT/FLOW/EVOLVE/VERIFY 중" + missing + ") (// @allow-paper-canonical)"
}

// ─── N61-A1 (n6-architecture) — 모든 ## 섹션 body 비어있지 않음 ───
// 각 ## 헤더 후 다음 ## 전까지: 비어있지 않은 줄 ≥ 3 OR 코드/리스트/표/details ≥ 1
fn check_n61_a1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    // 라인 단위 마커는 awk 가 검출
    let awk = "awk 'BEGIN{title=\"\";line=0;ne=0;blk=0;empty=0;empty_line=0;empty_title=\"\"} /^## / { if(title!=\"\" && ne<3 && blk==0 && skip==0){empty=1; empty_title=title; empty_line=line; exit} title=substr($0,4); line=NR; ne=0; blk=0; skip=0; next } /@allow-empty-section/ { skip=1 } /^\\`\\`\\`/ || /^[[:space:]]*[-*+] / || /^[[:space:]]*[0-9]+\\. / || /^\\|/ || /^<details/ { blk++ } NF>0 && !/^## / { ne++ } END { if(empty){print empty_line\"|\"empty_title} else if(title!=\"\" && ne<3 && blk==0 && skip==0){print line\"|\"title} }' '" + full + "' 2>/dev/null"
    let res = _str(exec(awk)).trim()
    if res == "" { return "" }
    let bar = res.index_of("|")
    if bar < 0 { return "" }
    let lnum = res.substring(0, bar)
    let title = res.substring(bar + 1, len(res))
    return "N61-A1|error|섹션 '" + title + "' (line " + lnum + ") 비어있음 — 3줄 또는 블록/리스트/표 필수 (// @allow-empty-section)"
}

// ─── N61-B1 (n6-architecture) — ASCII 코드블록에 박스 경계 필수 ───
// 코드블록 (``` ... ```) 전체에서 ┌└ 또는 ╭╰ 경계가 한 코드블록 단위로 있어야
// 단순화: ASCII 섹션 (§2/§3/§4) 영역 내 코드블록 ≥1 + 박스 경계 ≥1
fn check_n61_b1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let m = _to_int0(_str(exec("grep -c '@allow-ascii-freeform' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    // 각 코드블록 단위로 box 경계 검증 — ascii 의도가 보이는 코드블록만 (─/│/┌/└/╭/╰/├/┼ 등 박스문자 1+)
    // index() 사용 — BSD awk 의 [...] 멀티바이트 false positive 우회
    let awk = "awk 'BEGIN{inblk=0;has_top=0;has_bot=0;has_box=0;bad=0;blkline=0} /^\\`\\`\\`/ { if(inblk){ if(has_box && (has_top==0 || has_bot==0)){bad=blkline; exit}; inblk=0; has_top=0; has_bot=0; has_box=0 } else { inblk=1; blkline=NR; has_top=0; has_bot=0; has_box=0 }; next } inblk { if(index($0,\"┌\")||index($0,\"╭\")) has_top=1; if(index($0,\"└\")||index($0,\"╰\")) has_bot=1; if(index($0,\"┌\")||index($0,\"└\")||index($0,\"╭\")||index($0,\"╰\")||index($0,\"├\")||index($0,\"┼\")||index($0,\"│\")||index($0,\"─\")) has_box=1 } END{print bad+0}' '" + full + "' 2>/dev/null"
    let bad = _to_int0(_str(exec(awk)).trim())
    if bad > 0 {
        return "N61-B1|error|ASCII 코드블록 (line " + to_string(bad) + ") 박스 경계(┌└ or ╭╰) 없음 (// @allow-ascii-freeform)"
    }
    return ""
}

// ─── N61-B2 (n6-architecture) — §2 COMPARE 에 █ 바 차트 ≥3줄 ───
fn check_n61_b2(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    // §2 = '성능 비교' 또는 'Comparison' 헤더
    // 헤더부터 다음 ## 까지에서 █ 포함 라인 카운트
    let awk = "awk '/^## .*(성능 비교|Comparison)/ { in_s=1; next } /^## / { in_s=0 } in_s && /█/ { c++ } END{print c+0}' '" + full + "' 2>/dev/null"
    let bars = _to_int0(_str(exec(awk)).trim())
    // §2 자체가 없으면 N61-C1 가 잡음 — 여기는 있는 경우만
    let has_s2 = _to_int0(_str(exec("grep -cE '^## .*(성능 비교|Comparison)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if has_s2 == 0 { return "" }
    if bars < 3 {
        return "N61-B2|error|§2 COMPARE 에 █ 바 차트 < 3줄 (현재 " + to_string(bars) + ") (// @allow-paper-canonical)"
    }
    return ""
}

// ─── N61-B3 (n6-architecture) — §3 STRUCT 에 ├ 또는 ┼ ≥1 ───
fn check_n61_b3(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let has_s3 = _to_int0(_str(exec("grep -cE '^## .*(시스템 구조|System.*Architecture|구조도)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if has_s3 == 0 { return "" }
    let awk = "awk '/^## .*(시스템 구조|System.*Architecture|구조도)/ { in_s=1; next } /^## / { in_s=0 } in_s && (index($0,\"├\") || index($0,\"┼\")) { c++ } END{print c+0}' '" + full + "' 2>/dev/null"
    let cnt = _to_int0(_str(exec(awk)).trim())
    if cnt == 0 {
        return "N61-B3|error|§3 STRUCT 에 ├ 또는 ┼ 분할 없음 (// @allow-paper-canonical)"
    }
    return ""
}

// ─── N61-B4 (n6-architecture) — §4 FLOW 에 ▼ 또는 → ≥3건 ───
fn check_n61_b4(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let has_s4 = _to_int0(_str(exec("grep -cE '^## .*(플로우|Flow|데이터.*에너지)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if has_s4 == 0 { return "" }
    let awk = "awk '/^## .*(플로우|Flow|데이터.*에너지)/ { in_s=1; next } /^## / { in_s=0 } in_s { n1=gsub(/▼/,\"X\"); n2=gsub(/→/,\"X\"); c+=n1+n2 } END{print c+0}' '" + full + "' 2>/dev/null"
    let cnt = _to_int0(_str(exec(awk)).trim())
    if cnt < 3 {
        return "N61-B4|error|§4 FLOW 에 ▼ 또는 → < 3건 (현재 " + to_string(cnt) + ") (// @allow-paper-canonical)"
    }
    return ""
}

// ─── N61-Mk1 (n6-architecture) — Mk 진화 섹션 존재 ───
fn check_n61_mk1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let has = _to_int0(_str(exec("grep -cE '^## .*(Mk\\.?I.*진화|Evolution|Mk[[:space:]]*진화)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if has == 0 {
        return "N61-Mk1|error|Mk 진화 섹션(## .*Mk.I.*진화 OR Evolution) 없음 (// @allow-paper-canonical)"
    }
    return ""
}

// ─── N61-Mk3 (n6-architecture) — Mk 진화 §5 내 <details> 래핑 + open 정확 1개 ───
fn check_n61_mk3(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let m = _to_int0(_str(exec("grep -c '@allow-mk-freeform' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    // §5 영역에서 details 와 mk 헤더 카운트
    let awk = "awk '/^## .*(Mk\\.?I.*진화|Evolution|Mk[[:space:]]*진화)/ { in_s=1; next } /^## / { in_s=0 } in_s { if(/<details/) det++; if(/<details[^>]*open/) opn++; if(/^### .*Mk\\.?[IVX0-9]+/) mk++ } END{print det+0\"|\"opn+0\"|\"mk+0}' '" + full + "' 2>/dev/null"
    let res = _str(exec(awk)).trim()
    if res == "" { return "" }
    let parts = res.split("|")
    if len(parts) < 3 { return "" }
    let det = to_int(_str(parts[0]))
    let opn = to_int(_str(parts[1]))
    let mk = to_int(_str(parts[2]))
    // mk 헤더가 0 이면 §5 자체가 비어 — N61-Mk1/A1 에서 잡음
    if mk == 0 { return "" }
    if det != mk {
        return "N61-Mk3|error|Mk 헤더 " + to_string(mk) + "개 vs <details> " + to_string(det) + "개 — 모든 Mk 는 <details> 래핑 필수 (// @allow-mk-freeform)"
    }
    if opn != 1 {
        return "N61-Mk3|error|<details open> 개수 " + to_string(opn) + " (정확히 1개 필요 — 최신 Mk 만 펼침) (// @allow-mk-freeform)"
    }
    return ""
}

// ─── N61-Mk4 (n6-architecture) — 첫 <details> 가 open 이어야 (최신이 맨 위) ───
fn check_n61_mk4(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let m = _to_int0(_str(exec("grep -c '@allow-mk-freeform' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    // §5 안에서 첫 번째 <details> 라인 추출
    let awk = "awk '/^## .*(Mk\\.?I.*진화|Evolution|Mk[[:space:]]*진화)/ { in_s=1; next } /^## / { in_s=0 } in_s && /<details/ { print; exit }' '" + full + "' 2>/dev/null"
    let first = _str(exec(awk)).trim()
    if first == "" { return "" }
    if first.index_of("open") < 0 {
        return "N61-Mk4|error|Mk 진화 순서 위반 — 첫 <details> 에 open 속성 없음 (최신 Mk 가 맨 위) (// @allow-mk-freeform)"
    }
    return ""
}

// ─── N61-R1 (n6-architecture) — §3 REQUIRES body 에 🛸 지수 ≥2 + 도메인 링크 ≥1 ───
fn check_n61_r1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let m = _to_int0(_str(exec("grep -c '@allow-no-requires' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    // §3 REQUIRES 헤더 있을 때만 body 검증 (헤더 없음은 N61-C1 가 잡음)
    let has = _to_int0(_str(exec("grep -cE '^## .*(필요한 요소|Requires|선행.*도메인)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if has == 0 { return "" }
    // body: 헤더 직후 ~ 다음 ## 전까지
    // 🛸N 패턴 카운트 (🛸 다음 숫자 1자 이상)
    let awk_ufo = "awk '/^## .*(필요한 요소|Requires|선행.*도메인)/ { in_s=1; next } /^## / { in_s=0 } in_s { n=gsub(/🛸[0-9]/,\"X\"); c+=n } END{print c+0}' '" + full + "' 2>/dev/null"
    let ufo_cnt = _to_int0(_str(exec(awk_ufo)).trim())
    if ufo_cnt < 2 {
        return "N61-R1|error|§3 REQUIRES 에 🛸 지수 ≥2건 없음 (현재 " + to_string(ufo_cnt) + ") / '🛸N → 🛸M' 형식 필수 (// @allow-no-requires)"
    }
    // 링크 또는 table row 카운트 — 둘 중 하나라도 ≥1
    // 링크: [text](path.md) — body 내
    let awk_lnk = "awk '/^## .*(필요한 요소|Requires|선행.*도메인)/ { in_s=1; next } /^## / { in_s=0 } in_s && /\\[[^]]*\\]\\([^)]*\\.md[^)]*\\)/ { c++ } END{print c+0}' '" + full + "' 2>/dev/null"
    let lnk_cnt = _to_int0(_str(exec(awk_lnk)).trim())
    // table row with 🛸: ^|...🛸...|
    let awk_row = "awk '/^## .*(필요한 요소|Requires|선행.*도메인)/ { in_s=1; next } /^## / { in_s=0 } in_s && /^\\|/ && /🛸/ { c++ } END{print c+0}' '" + full + "' 2>/dev/null"
    let row_cnt = _to_int0(_str(exec(awk_row)).trim())
    if lnk_cnt == 0 && row_cnt == 0 {
        return "N61-R1|error|§3 REQUIRES 에 도메인 링크 ≥1 없음 / [domain](../path/to.md) 필수 (// @allow-no-requires)"
    }
    return ""
}

// ─── N61-R2 (n6-architecture) — frontmatter requires ↔ §3 REQUIRES 표 sync ───
fn check_n61_r2(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let m = _to_int0(_str(exec("grep -c '@allow-no-requires-sync' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    // 1. frontmatter 블록 (---...---) 안 'to:' 라인 카운트 + 이름 추출
    // awk: 첫 ---  ~  두번째 --- 사이에서만 ^[[:space:]]*-?[[:space:]]*to:[[:space:]]*<name>
    let awk_to = "awk 'NR==1 && /^---[[:space:]]*$/ { in_fm=1; next } in_fm && /^---[[:space:]]*$/ { in_fm=0; exit } in_fm && /^[[:space:]]*-?[[:space:]]*to:[[:space:]]*/ { sub(/^[[:space:]]*-?[[:space:]]*to:[[:space:]]*/,\"\"); sub(/[[:space:]]*#.*$/,\"\"); sub(/[[:space:]]+$/,\"\"); gsub(/^[\"\\x27]|[\"\\x27]$/,\"\"); print }' '" + full + "' 2>/dev/null"
    let to_raw = _str(exec(awk_to)).trim()
    if to_raw == "" {
        // frontmatter 자체가 없거나 requires 없음 — skip pass
        return ""
    }
    let to_lines = to_raw.split("\n")
    let mut fm_count: i64 = 0
    let mut name_idx: i64 = 0
    for tn in to_lines {
        let s = _str(tn).trim()
        if s == "" { continue }
        fm_count = fm_count + 1
        name_idx = name_idx + 1
    }
    if fm_count == 0 { return "" }
    // 2. §3 REQUIRES body 내 테이블 행 카운트 (헤더/구분선 제외)
    // 구분선: ^\|[\s\-:|]+$
    let awk_rows = "awk '/^## .*(필요한 요소|Requires|선행.*도메인)/ { in_s=1; next } /^## / { in_s=0 } in_s && /^\\|/ { if($0 ~ /^\\|[[:space:]\\-:|]+$/) next; c++ } END{print c+0}' '" + full + "' 2>/dev/null"
    let row_cnt = _to_int0(_str(exec(awk_rows)).trim())
    // 데이터 행 = 전체 행 - 헤더 1줄
    let mut data_rows = row_cnt - 1
    if data_rows < 0 { data_rows = 0 }
    if data_rows != fm_count {
        return "N61-R2|error|frontmatter requires (" + to_string(fm_count) + "개) ≠ §3 REQUIRES 표 (" + to_string(data_rows) + "개) sync 실패 (// @allow-no-requires-sync)"
    }
    // 3. 각 to: 이름이 §3 body 에 문자열로 ≥1회 등장
    // §3 body 추출
    let awk_body = "awk '/^## .*(필요한 요소|Requires|선행.*도메인)/ { in_s=1; next } /^## / { in_s=0 } in_s { print }' '" + full + "' 2>/dev/null"
    let body = _str(exec(awk_body))
    for tn in to_lines {
        let nm = _str(tn).trim()
        if nm == "" { continue }
        if body.index_of(nm) < 0 {
            return "N61-R2|error|frontmatter 'to: " + nm + "' 이 §3 REQUIRES 에 없음 (// @allow-no-requires-sync)"
        }
    }
    return ""
}

// ─── N6-DAG-SYNC (n6-architecture) — frontmatter requires(to:) ↔ _dag.json edges sync ───
// scope: papers/* or domains/* .md (canonical scope)
// _dag.json 없으면 skip pass (build_dag 미실행 상태). 해당 도메인 노드가 없으면 error.
fn check_n6_dag_sync(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let mk = _to_int0(_str(exec("grep -c '@allow-dag-sync' '" + full + "' 2>/dev/null || echo 0")).trim())
    if mk > 0 { return "" }
    let dag_path = REPO_ROOT + "/papers/_dag.json"
    let dag_exists = _str(exec("[ -f '" + dag_path + "' ] && echo y || echo n")).trim()
    if dag_exists != "y" { return "" }
    // jq 가용성 확인
    let has_jq = _str(exec("command -v jq >/dev/null 2>&1 && echo y || echo n")).trim()
    if has_jq != "y" {
        return "N6-DAG-SYNC|warn|jq 미설치 — DAG sync 검증 스킵 (// @allow-dag-sync)"
    }
    // 1. frontmatter domain 추출
    let awk_dom = "awk 'NR==1 && /^---[[:space:]]*$/ { in_fm=1; next } in_fm && /^---[[:space:]]*$/ { exit } in_fm && /^[[:space:]]*domain:[[:space:]]*/ { sub(/^[[:space:]]*domain:[[:space:]]*/,\"\"); sub(/[[:space:]]*#.*$/,\"\"); sub(/[[:space:]]+$/,\"\"); gsub(/^[\"\\x27]|[\"\\x27]$/,\"\"); print; exit }' '" + full + "' 2>/dev/null"
    let domain = _str(exec(awk_dom)).trim()
    if domain == "" { return "" }
    // 2. frontmatter to: 집합 (정렬 unique)
    let awk_to = "awk 'NR==1 && /^---[[:space:]]*$/ { in_fm=1; next } in_fm && /^---[[:space:]]*$/ { exit } in_fm && /^[[:space:]]*-?[[:space:]]*to:[[:space:]]*/ { sub(/^[[:space:]]*-?[[:space:]]*to:[[:space:]]*/,\"\"); sub(/[[:space:]]*#.*$/,\"\"); sub(/[[:space:]]+$/,\"\"); gsub(/^[\"\\x27]|[\"\\x27]$/,\"\"); print }' '" + full + "' 2>/dev/null | sort -u"
    let fm_to = _str(exec(awk_to)).trim()
    // 3. _dag.json 에서 해당 domain 의 outgoing edges to 집합
    let dag_to = _str(exec("jq -r --arg d '" + domain + "' '.edges[] | select(.from==$d) | .to' '" + dag_path + "' 2>/dev/null | sort -u")).trim()
    // 4. nodes 에 domain 자체 존재 여부 — 양쪽 다 비어있을 때 노드 없음 판단에 사용
    let node_exists = _str(exec("jq -r --arg d '" + domain + "' '[.nodes[] | select(.id==$d)] | length' '" + dag_path + "' 2>/dev/null")).trim()
    if node_exists == "" || node_exists == "0" {
        // 노드 없음. fm_to 도 비어있으면 양쪽 일치 (둘다 없음) → pass
        if fm_to == "" { return "" }
        return "N6-DAG-SYNC|error|" + domain + ": _dag.json nodes 에 노드 없음 / frontmatter requires 존재 → build_dag.hexa 재실행 필요 (// @allow-dag-sync)"
    }
    if fm_to == dag_to { return "" }
    let fm_disp = fm_to.replace("\n", ",")
    let dag_disp = dag_to.replace("\n", ",")
    return "N6-DAG-SYNC|error|" + domain + ": frontmatter requires [" + fm_disp + "] ≠ _dag.json edges [" + dag_disp + "] — build_dag.hexa 재실행 필요 (// @allow-dag-sync)"
}

// ─── N6-DAG-DANGLE (n6-architecture) — _dag.json edges.to 가 실재 paper 로 resolve ───
// scope: papers/_dag.json 이 staged 일 때만
fn check_n6_dag_dangle(path: string) -> string {
    if _project_name() != "n6-architecture" { return "" }
    if path != "papers/_dag.json" { return "" }
    let full = REPO_ROOT + "/" + path
    let mk = _to_int0(_str(exec("grep -c '@allow-dag-dangle' '" + full + "' 2>/dev/null || echo 0")).trim())
    if mk > 0 { return "" }
    let has_jq = _str(exec("command -v jq >/dev/null 2>&1 && echo y || echo n")).trim()
    if has_jq != "y" {
        return "N6-DAG-DANGLE|warn|jq 미설치 — DAG dangle 검증 스킵 (// @allow-dag-dangle)"
    }
    // 모든 edges.to (unique)
    let to_list = _str(exec("jq -r '.edges[].to' '" + full + "' 2>/dev/null | sort -u")).trim()
    if to_list == "" { return "" }
    let targets = to_list.split("\n")
    let mut dangling: [string] = []
    for t in targets {
        let nm = _str(t).trim()
        if nm == "" { continue }
        // node id 매칭
        let in_nodes = _str(exec("jq -r --arg d '" + nm + "' '[.nodes[] | select(.id==$d)] | length' '" + full + "' 2>/dev/null")).trim()
        if in_nodes != "" && in_nodes != "0" { continue }
        // papers/n6-<to>.md 존재
        let p1 = REPO_ROOT + "/papers/n6-" + nm + ".md"
        let e1 = _str(exec("[ -f '" + p1 + "' ] && echo y || echo n")).trim()
        if e1 == "y" { continue }
        // domains/**/<to>/<to>.md 존재
        let p2_check = _str(exec("ls " + REPO_ROOT + "/domains/*/" + nm + "/" + nm + ".md 2>/dev/null | head -1")).trim()
        if p2_check != "" { continue }
        // domains/**/<to>.md 일반 매칭
        let p3_check = _str(exec("find " + REPO_ROOT + "/domains -type f -name '" + nm + ".md' 2>/dev/null | head -1")).trim()
        if p3_check != "" { continue }
        dangling = dangling.push(nm)
    }
    if len(dangling) == 0 { return "" }
    let mut disp = ""
    let mut di: i64 = 0
    for d in dangling {
        if di > 0 { disp = disp + "," }
        disp = disp + _str(d)
        di = di + 1
    }
    return "N6-DAG-DANGLE|error|_dag.json: " + to_string(len(dangling)) + "개 dangling edge → " + disp + " (파일 없음 또는 nodes 누락) (// @allow-dag-dangle)"
}

// ─── N6-DAG-CYCLE (n6-architecture) — _dag.json edges 에 cycle 금지 ───
fn check_n6_dag_cycle(path: string) -> string {
    if _project_name() != "n6-architecture" { return "" }
    if path != "papers/_dag.json" { return "" }
    let full = REPO_ROOT + "/" + path
    let mk = _to_int0(_str(exec("grep -c '@allow-dag-cycle' '" + full + "' 2>/dev/null || echo 0")).trim())
    if mk > 0 { return "" }
    let has_jq = _str(exec("command -v jq >/dev/null 2>&1 && echo y || echo n")).trim()
    if has_jq != "y" {
        return "N6-DAG-CYCLE|warn|jq 미설치 — DAG cycle 검증 스킵 (// @allow-dag-cycle)"
    }
    // 1) _meta.cycles 우선 사용 (build_dag 가 미리 계산)
    let meta_cnt = _str(exec("jq -r '._meta.cycles | length // 0' '" + full + "' 2>/dev/null")).trim()
    if meta_cnt != "" && meta_cnt != "0" {
        // cycle 디스플레이 — 첫 3개
        let disp = _str(exec("jq -r '._meta.cycles | .[0:3] | map(if type==\"array\" then join(\"→\") else tostring end) | join(\" / \")' '" + full + "' 2>/dev/null")).trim()
        return "N6-DAG-CYCLE|error|_dag.json: cycle " + meta_cnt + "개 발견 → " + disp + " — 의존성 순환 불가 (// @allow-dag-cycle)"
    }
    // 2) _meta.cycles 없거나 비어있으면 직접 DFS — jq 로 토폴로지 시도
    // tsort 가용 시 사용 (BSD/macOS 기본 포함)
    let has_tsort = _str(exec("command -v tsort >/dev/null 2>&1 && echo y || echo n")).trim()
    if has_tsort != "y" { return "" }
    // edges 를 "from to\n" 페어로 출력
    let pair_out = _str(exec("jq -r '.edges[] | \"\\(.from) \\(.to)\"' '" + full + "' 2>/dev/null | tsort 2>&1 1>/dev/null | head -3")).trim()
    if pair_out == "" { return "" }
    // tsort 의 cycle 메시지: "tsort: cycle in data"
    if pair_out.index_of("cycle") < 0 { return "" }
    return "N6-DAG-CYCLE|error|_dag.json: cycle 발견 → " + pair_out.replace("\n", " / ") + " — 의존성 순환 불가 (// @allow-dag-cycle)"
}

// ─── N61-P1 (n6-architecture) — ```python 블록 SSOT (≥2 금지) ───
// 중복 검증 블록은 drift 유발. 도메인당 1개로 제한.
fn check_n61_p1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    let m = _to_int0(_str(exec("grep -c '@allow-dup-python' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    let cnt = _to_int0(_str(exec("grep -cE '^\\`\\`\\`python(\\b|$)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if cnt >= 2 {
        return "N61-P1|error|python 블록 " + to_string(cnt) + "개 — SSOT 위반, 도메인당 1개만 허용 (// @allow-dup-python)"
    }
    return ""
}

// ─── N61-R3 (n6-architecture) — §3 REQUIRES 제너릭 템플릿 금지 ───
// n6-core + cross-domain 만 있는 placeholder → 도메인 특정 선행 관계 기입 필요
fn check_n61_r3(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    let m = _to_int0(_str(exec("grep -c '@allow-generic-requires' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    // §3 REQUIRES body 내 데이터 row 수 (헤더+구분선 제외)
    let awk_rows = "awk '/^## .*(필요한 요소|Requires|선행.*도메인)/ { in_s=1; next } /^## / { in_s=0 } in_s && /^\\|/ { if($0 ~ /^\\|[[:space:]\\-:|]+$/) next; c++ } END{print c+0}' '" + full + "' 2>/dev/null"
    let rows = _to_int0(_str(exec(awk_rows)).trim())
    let mut data_rows = rows - 1
    if data_rows < 0 { data_rows = 0 }
    // 제너릭 마커: n6-core + cross-domain 양쪽 row 존재
    let has_core = _to_int0(_str(exec("awk '/^## .*(필요한 요소|Requires|선행.*도메인)/ { in_s=1; next } /^## / { in_s=0 } in_s && /^\\|[[:space:]]*n6-core[[:space:]]*\\|/' '" + full + "' 2>/dev/null | wc -l")).trim())
    let has_cross = _to_int0(_str(exec("awk '/^## .*(필요한 요소|Requires|선행.*도메인)/ { in_s=1; next } /^## / { in_s=0 } in_s && /^\\|[[:space:]]*cross-domain[[:space:]]*\\|/' '" + full + "' 2>/dev/null | wc -l")).trim())
    if has_core > 0 && has_cross > 0 && data_rows <= 2 {
        return "N61-R3|error|§3 REQUIRES 가 제너릭 템플릿 (n6-core + cross-domain 만, " + to_string(data_rows) + " rows) — 도메인 특정 선행 관계 필요 (// @allow-generic-requires)"
    }
    return ""
}

// ─── N61-W1 (n6-architecture) — §1 WHY body < 10줄 경고 ───
fn check_n61_w1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    let m = _to_int0(_str(exec("grep -c '@allow-thin-why' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    let awk = "awk '/^## §1 WHY/ { in_s=1; next } /^## §2/ { in_s=0 } in_s && NF > 0 { c++ } END{print c+0}' '" + full + "' 2>/dev/null"
    let cnt = _to_int0(_str(exec(awk)).trim())
    if cnt > 0 && cnt < 10 {
        return "N61-W1|warn|§1 WHY body " + to_string(cnt) + "줄 (< 10) — 도메인 영향 설명 확장 필요 (// @allow-thin-why)"
    }
    return ""
}

// ─── N61-E1 (n6-architecture) — §6 EVOLVE Mk.V boilerplate 금지 ───
// 'retrofit 단계' + 'lint 전 규칙 PASS' + 'atlas-promotion 자동 승급 후보' 3가지 문구 동시 출현 → template
fn check_n61_e1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    let m = _to_int0(_str(exec("grep -c '@allow-mk-boilerplate' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    let awk = "awk '/^## §6 EVOLVE/ { in_s=1; next } /^## §7/ { in_s=0 } in_s' '" + full + "' 2>/dev/null"
    let body = _str(exec(awk))
    let has1 = body.index_of("본 retrofit 단계") >= 0
    let has2 = body.index_of("하네스 lint 전 규칙 PASS") >= 0
    let has3 = body.index_of("atlas-promotion 자동 승급 후보") >= 0
    if has1 && has2 && has3 {
        return "N61-E1|error|§6 EVOLVE Mk.V 가 generic boilerplate — 도메인별 실제 Mk 진화 history 필요 (// @allow-mk-boilerplate)"
    }
    return ""
}

// ─── N61-V2 (n6-architecture) — §7 python 이 물리/수학 검증 0건 경고 ───
// sqrt/pi/log/exp/mu_0/mu0/m_e/m_p 등 물리상수/수학함수 0건 → tautological
fn check_n61_v2(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    let m = _to_int0(_str(exec("grep -c '@allow-tautological-verify' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    let cmd = "awk '/^## §7 VERIFY/ { in_s=1 } in_s && /^\\`\\`\\`python/ { in_p=1; next } in_p && /^\\`\\`\\`/ { in_p=0; exit } in_p' '" + full + "' 2>/dev/null | grep -cE '\\bsqrt\\(|\\bpi\\b|\\bexp\\(|\\blog\\(|\\bsin\\(|\\bcos\\(|\\bmu_0|\\bmu0|\\be_charge|\\bplanck|9\\.81|9\\.8[0-9]|2\\.998e|6\\.626e|1\\.602e' 2>/dev/null | head -1"
    let hits = _to_int0(_str(exec(cmd)).trim())
    if hits == 0 {
        return "N61-V2|warn|§7 python 에 물리상수/수학함수 0건 — 산술 tautology 우려, 물리/수학 first-principles 검증 권장 (// @allow-tautological-verify)"
    }
    return ""
}

// ─── N61-V3 (n6-architecture) — gold standard §7 10 서브섹션 + 반례/falsifier ───
// sf.md 전용 strict — §7.0~§7.10 10 서브섹션 헤딩 + COUNTER_EXAMPLES/FALSIFIERS ≥3
// Why: n=6 끼워맞춤 의심 차단. 수론 유도 + 반례 + χ² 다층 증명 구조 강제.
fn check_n61_v3(path: string) -> string {
    if path != "shared/harness/sample.md" { return "" }
    let full = REPO_ROOT + "/" + path
    // awk 사용 — grep -c 는 매치 0건시 "0\n"+echo "0" = "0\n0" to_int 실패 (N61-GRC 룰)
    let sub = _to_int0(_str(exec("awk '/^### §7\\.[0-9]+/{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    if sub < 10 {
        return "N61-V3|error|§7 서브섹션 < 10 (현재 " + to_string(sub) + ") — §7.0~§7.10 n=6 정직성 10 카테고리 필수"
    }
    let counter = _to_int0(_str(exec("awk '/COUNTER_EXAMPLES/{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    let falsif = _to_int0(_str(exec("awk '/FALSIFIERS/{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    if counter == 0 || falsif == 0 {
        return "N61-V3|error|§7 에 COUNTER_EXAMPLES 또는 FALSIFIERS 리스트 누락 — 반례/반증조건 정직성 필수"
    }
    return ""
}

// ─── N61-V4 (n6-architecture) — gold standard §7 정직성 집계 라벨 ───
// 끝에 "X/N PASS (...정직성...)" 라벨 출력 강제
fn check_n61_v4(path: string) -> string {
    if path != "shared/harness/sample.md" { return "" }
    let full = REPO_ROOT + "/" + path
    let hits = _to_int0(_str(exec("awk '/PASS \\(.*정직성/{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    if hits == 0 {
        return "N61-V4|error|§7 python 에 'X/N PASS (...정직성...)' 집계 라벨 누락"
    }
    return ""
}

// ─── H-GRC (공통) — `grep -c ... || echo 0` 안티패턴 금지 ───
// Why: 매치 0건시 grep="0" + rc=1 → || echo 0 추가 → "0\n0" to_int 실패.
// How: awk '/pat/{c++} END{print c+0}' 로 대체 — 항상 단일 숫자 출력.
fn check_h_grc(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    let full = REPO_ROOT + "/" + path
    let hits = _to_int0(_str(exec("awk '/\\|\\| echo 0/{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    if hits > 0 {
        return "H-GRC|warn|`|| echo 0` 안티패턴 " + to_string(hits) + "건 — awk '/pat/{c++} END{print c+0}' 로 전환 권장 (to_int 실패 방지)"
    }
    return ""
}

// ─── H-DEFER (공통) — '다음 세션에서' 회피 문구 금지 ───
// Why: 사용자 정책 — 버그/개선 발견 시 자동으로 하네스 룰 등록해서 강제. 연기 금지.
fn check_h_defer(path: string) -> string {
    let e = ext_of(path)
    if e != ".md" && e != ".hexa" && e != ".jsonl" { return "" }
    let full = REPO_ROOT + "/" + path
    let bn = basename_of(path)
    if bn == "CLAUDE.md" || bn == "README.md" { return "" }
    if path.index_of("/memory/") >= 0 { return "" }
    let hits = _to_int0(_str(exec("awk '/다음 세션에서 수정|다음 세션에서 처리|defer.*next.*session/{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    if hits > 0 {
        return "H-DEFER|warn|회피 문구 '다음 세션에서 수정' " + to_string(hits) + "건 — 지금 하네스 룰화 (deletion-first)"
    }
    return ""
}

// ─── H-ROOT (공통, R33) — 근본원인 우선, workaround/symptom patch 금지 ───
// Why: cl cache stale incident — ccmon launchd 미등록 + nexus cache orphan.
// symptom patch (수동갱신 안내) 대신 파이프라인 자체 복원 강제.
// 14 키워드: workaround/땜빵/일단 이렇게/수동으로 갱신/수동으로 fix/우회해서/symptom patch/stopgap/band-aid
//           + 우회 가능/완화책/운영 관찰/regen 복구/α 완화 (2026-04-14 passive-defer 표현 추가)
// allow 토큰 파일 내 존재 시 스킵: @allow-workaround (명시 예외), check_h_root / H-ROOT (self-reference)
fn check_h_root(path: string) -> string {
    let e = ext_of(path)
    if e != ".md" && e != ".hexa" && e != ".jsonl" { return "" }
    let bn = basename_of(path)
    if bn == "CLAUDE.md" || bn == "README.md" { return "" }
    if path.index_of("/memory/") >= 0 { return "" }
    if path.index_of("/archive/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    if !file_exists(full) { return "" }
    let mut content = ""
    try { content = read_file(full) } catch e {}
    if content == "" { return "" }
    if content.index_of("@allow-workaround") >= 0 { return "" }
    if content.index_of("check_h_root") >= 0 { return "" }
    if content.index_of("H-ROOT") >= 0 { return "" }
    let mut hits = 0
    if content.index_of("workaround") >= 0 { hits = hits + 1 }
    if content.index_of("땜빵") >= 0 { hits = hits + 1 }
    if content.index_of("일단 이렇게") >= 0 { hits = hits + 1 }
    if content.index_of("수동으로 갱신") >= 0 { hits = hits + 1 }
    if content.index_of("수동으로 fix") >= 0 { hits = hits + 1 }
    if content.index_of("우회해서") >= 0 { hits = hits + 1 }
    if content.index_of("symptom patch") >= 0 { hits = hits + 1 }
    if content.index_of("stopgap") >= 0 { hits = hits + 1 }
    if content.index_of("band-aid") >= 0 { hits = hits + 1 }
    if content.index_of("우회 가능") >= 0 { hits = hits + 1 }
    if content.index_of("완화책") >= 0 { hits = hits + 1 }
    if content.index_of("운영 관찰") >= 0 { hits = hits + 1 }
    if content.index_of("regen 복구") >= 0 { hits = hits + 1 }
    if content.index_of("α 완화") >= 0 { hits = hits + 1 }
    if hits > 0 {
        return "H-ROOT|warn|근본원인 회피 키워드 " + to_string(hits) + "종 감지 — R33: 파이프라인/launchd/orphan 경로 복원 필수, workaround/완화책/passive-defer 금지. 명시 예외 시 '// @allow-workaround'"
    }
    return ""
}

// ─── H-NOBLOCK (공통) — 세션 채팅 블로킹 금지 (read -p / wait $ / fg / sleep>=10 / while+sleep) ───
// Why: cron/auto/loop 트리거에서 동기 대기 명령은 사용자 입력 채널을 막아 hang. ScheduleWakeup/Monitor/run_in_background 강제.
// 우회: 파일에 '@allow-block' 토큰 또는 'NEXUS_BLOCK_OK=1' envvar prefix.
fn check_h_noblock(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" { return "" }
    let full = REPO_ROOT + "/" + path
    if !file_exists(full) { return "" }
    let mut content = ""
    try { content = read_file(full) } catch e {}
    if content == "" { return "" }
    if content.index_of("@allow-block") >= 0 { return "" }
    if content.index_of("NEXUS_BLOCK_OK=1") >= 0 { return "" }
    if content.index_of("check_h_noblock") >= 0 { return "" }
    if content.index_of("check_blocking_cmd") >= 0 { return "" }
    if content.index_of("H-NOBLOCK") >= 0 { return "" }

    let mut hits = 0
    let mut kinds = ""
    if content.index_of("read -p ") >= 0 || content.index_of("read -rp ") >= 0 || content.index_of("read -sp ") >= 0 {
        hits = hits + 1; kinds = kinds + "read-p "
    }
    if content.index_of("wait $") >= 0 || content.index_of("wait %") >= 0 {
        hits = hits + 1; kinds = kinds + "wait-pid "
    }
    let sl_hits = _to_int0(_str(exec("awk '/sleep[[:space:]]+([1-9][0-9]+|[1-9][0-9][0-9]+)/{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    if sl_hits > 0 { hits = hits + 1; kinds = kinds + "sleep>=10(" + to_string(sl_hits) + ") " }
    let wl_hits = _to_int0(_str(exec("awk '/while.*sleep|until.*sleep/{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    if wl_hits > 0 { hits = hits + 1; kinds = kinds + "while+sleep " }
    if hits > 0 {
        return "H-NOBLOCK|warn|세션 블로킹 패턴 감지: " + kinds.trim() + "— ScheduleWakeup/Monitor/run_in_background 사용. 우회: '// @allow-block' 또는 NEXUS_BLOCK_OK=1 prefix"
    }
    return ""
}

// ─── H-NOARCHIVE (공통) — 신규 archive/backup 파일·폴더 생성 금지 ───
// Why: 사용자 정책 — *.bak / *.backup / *.old / archive/ / backup/ 별도 사본 금지.
//      git history/branch/tag 가 단일 진실. 별도 사본은 drift 원인.
// 우회: '@allow-archive' 토큰 또는 'NEXUS_ARCHIVE_OK=1' envvar prefix.
// 격리 예외: shared/backups/, shared/archive/, shared/discovery/archive/, archive/deprecated_json/
fn check_h_noarchive(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" { return "" }
    if path.index_of("shared/backups/") >= 0 { return "" }
    if path.index_of("shared/archive/") >= 0 { return "" }
    if path.index_of("shared/discovery/archive/") >= 0 { return "" }
    if path.index_of("archive/deprecated_json/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    if !file_exists(full) { return "" }
    let mut content = ""
    try { content = read_file(full) } catch e {}
    if content == "" { return "" }
    if content.index_of("@allow-archive") >= 0 { return "" }
    if content.index_of("NEXUS_ARCHIVE_OK=1") >= 0 { return "" }
    if content.index_of("check_h_noarchive") >= 0 { return "" }
    if content.index_of("check_no_archive_") >= 0 { return "" }
    if content.index_of("H-NOARCHIVE") >= 0 { return "" }

    let mut hits = 0
    let mut kinds = ""
    let mk_hits = _to_int0(_str(exec("awk '/mkdir[[:space:]]+(-p[[:space:]]+)?(backup|backups|archive|archives)([[:space:]]|$|\\/)/{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    if mk_hits > 0 { hits = hits + 1; kinds = kinds + "mkdir-archive(" + to_string(mk_hits) + ") " }
    let cp_hits = _to_int0(_str(exec("awk '/(cp|mv|rsync)[[:space:]]+[^|;&]+[.](bak|backup|old|orig)([[:space:]]|$)/{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    if cp_hits > 0 { hits = hits + 1; kinds = kinds + "cp-bak(" + to_string(cp_hits) + ") " }
    let wf_hits = _to_int0(_str(exec("awk '/(write_file|append_file)\\([^,]*[.](bak|backup|old|orig)/{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    if wf_hits > 0 { hits = hits + 1; kinds = kinds + "write-bak(" + to_string(wf_hits) + ") " }
    let tar_hits = _to_int0(_str(exec("awk '/(backup|archive)[._-](tar|tgz|zip)/{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    if tar_hits > 0 { hits = hits + 1; kinds = kinds + "tar-archive(" + to_string(tar_hits) + ") " }
    if hits > 0 {
        return "H-NOARCHIVE|warn|archive/backup 파일·폴더 생성 패턴 감지: " + kinds.trim() + "— git commit/branch/tag 사용. 격리 예외: shared/backups/, shared/archive/. 우회: '// @allow-archive' 또는 NEXUS_ARCHIVE_OK=1 prefix"
    }
    return ""
}

// ─── H-NONAME-V (공통) — 파일/폴더명 버전 suffix 금지 ───
// Why: 사용자 정책 — git commit/branch/tag 이 유일 버전관리 SSOT.
//      파일명 _v<N>/_mk<N>/.v<N>/_Mk.<ROMAN>/_new/_final/_copy/ copy/(N) 접미는 drift 원인.
// 격리 예외: shared/backups/, shared/archive/, shared/discovery/archive/, archive/deprecated_json/
// 우회: 파일 내용 또는 path 에 '@allow-version-name' 토큰.
fn _noname_v_match(s: string) -> string {
    if len(s) == 0 { return "" }
    let suffixes = [
        "_v1", "_v2", "_v3", "_v4", "_v5", "_v6", "_v7", "_v8", "_v9",
        "_v10", "_v11", "_v12", "_v13", "_v14", "_v15",
        "_V1", "_V2", "_V3", "_V4", "_V5",
        "_mk1", "_mk2", "_mk3", "_mk4", "_mk5", "_mk6", "_mk7", "_mk8", "_mk9",
        "_Mk1", "_Mk2", "_Mk3", "_Mk4", "_Mk5", "_Mk6", "_Mk7", "_Mk8", "_Mk9",
        "_MK1", "_MK2", "_MK3",
        ".v1", ".v2", ".v3", ".v4", ".v5", ".v6", ".v7", ".v8", ".v9",
        ".V1", ".V2", ".V3",
        ".mk1", ".mk2", ".mk3", ".mk4", ".mk5",
        ".Mk1", ".Mk2", ".Mk3", ".Mk4", ".Mk5",
        "_Mk.II", "_Mk.III", "_Mk.IV", "_Mk.V", "_Mk.VI", "_Mk.VII", "_Mk.VIII", "_Mk.IX", "_Mk.X",
        "_mk.II", "_mk.III", "_mk.IV", "_mk.V", "_mk.VI", "_mk.VII",
        "_new", "_final", "_copy", "-new", "-final", "-copy",
        " copy", " (1)", " (2)", " (3)", " (4)", " (5)", " (6)", " (7)", " (8)", " (9)",
        " copy 2", " copy 3", " copy 4", " copy 5"
    ]
    for sfx in suffixes {
        if s.ends_with(sfx) { return sfx }
    }
    return ""
}

fn check_h_noname_v(path: string) -> string {
    if len(path) == 0 { return "" }
    if path.index_of("@allow-version-name") >= 0 { return "" }
    if path.index_of("shared/backups/") >= 0 { return "" }
    if path.index_of("shared/archive/") >= 0 { return "" }
    if path.index_of("shared/discovery/archive/") >= 0 { return "" }
    if path.index_of("archive/deprecated_json/") >= 0 { return "" }
    // 하네스 규칙 자체 구현 파일은 패턴 언급 불가피 → 스킵
    if path.index_of("shared/harness/lint.hexa") >= 0 { return "" }
    if path.index_of("shared/harness/pre_tool_guard.hexa") >= 0 { return "" }
    if path.index_of("shared/harness/severity_map.json") >= 0 { return "" }
    // 파일 내용에 @allow-version-name 명시 시 통과 (legacy grandfather)
    let full = REPO_ROOT + "/" + path
    if file_exists(full) {
        let mut content = ""
        try { content = read_file(full) } catch e {}
        if content.index_of("@allow-version-name") >= 0 { return "" }
        if content.index_of("check_h_noname_v") >= 0 { return "" }
        if content.index_of("H-NONAME-V") >= 0 { return "" }
    }

    // 1) basename stem (last '.' 앞)
    let base = basename_of(path)
    let dot = _rfind(base, ".")
    let stem = if dot > 0 { base.substring(0, dot) } else { base }
    let h1 = _noname_v_match(stem)
    if h1 != "" {
        return "H-NONAME-V|warn|H-NONAME-V: 파일명 '" + base + "' 에 버전 suffix '" + h1 + "' 금지 — git commit/branch/tag 로 버전관리. 우회: 파일 내 '@allow-version-name' 토큰"
    }
    // 2) dirname segment 검사 (basename 제외)
    let slash = _rfind(path, "/")
    if slash <= 0 { return "" }
    let dir = path.substring(0, slash)
    let dsegs = dir.split("/")
    for seg in dsegs {
        let s = _str(seg)
        if s == "" || s == "." || s == ".." { continue }
        let h2 = _noname_v_match(s)
        if h2 != "" {
            return "H-NONAME-V|warn|H-NONAME-V: 폴더명 '" + s + "' 에 버전 suffix '" + h2 + "' 금지 — git commit/branch/tag 로 버전관리. 우회: 동일 토큰"
        }
    }
    return ""
}

// ─── H-NOHOOK (공통) — hook 시스템 신규 작성 금지 ───
// Why: 사용자 정책 — 공용 규칙 코드 강제 부분에 hook 작성 자체 금지.
//      모든 자동 강제는 harness/entry.hexa 자율 호출로 통합. settings.json hooks={} 고정.
// 대상:
//   - .claude/settings*.json — hooks 키 비어있지 않으면 위반
//   - .claude/hooks/ 하위 신규 스크립트
//   - .git/hooks/ 신규 hook (sample/H-COMMIT 4종 외)
//   - .githooks/ H-COMMIT wrapper 외 신규
//   - shared/hooks/ (deprecated symlink) 하위 신규
// 격리 예외: shared/archive/, /archive/superseded-, /archive/deprecated_
// 우회: 파일 내 '@allow-hook' 토큰
fn check_h_nohook(path: string) -> string {
    if len(path) == 0 { return "" }
    // 자기참조
    if path.index_of("shared/harness/lint.hexa") >= 0 { return "" }
    if path.index_of("shared/harness/pre_tool_guard.hexa") >= 0 { return "" }
    if path.index_of("shared/harness/post_edit.hexa") >= 0 { return "" }
    if path.index_of("shared/harness/severity_map.json") >= 0 { return "" }
    // archaeological 격리
    if path.index_of("shared/archive/") >= 0 { return "" }
    if path.index_of("/archive/superseded-") >= 0 { return "" }
    if path.index_of("/archive/deprecated_") >= 0 { return "" }
    // staged 삭제 (D) 는 정책 만족 — 파일 부재 시 통과
    let full_for_existence = REPO_ROOT + "/" + path
    if !file_exists(full_for_existence) { return "" }

    let base = basename_of(path)

    // 1) 경로 기반 — repo-relative 와 absolute 양쪽 매칭 (앞 '/' 유무)
    let has_claude_hooks = path.index_of("/.claude/hooks/") >= 0 || path.starts_with(".claude/hooks/")
    if has_claude_hooks {
        return "H-NOHOOK|error|H-NOHOOK: .claude/hooks/ 스크립트 금지 — harness/entry.hexa 자율 호출로 대체. 우회: '@allow-hook' 토큰"
    }
    let has_shared_hooks = path.index_of("/shared/hooks/") >= 0 || path.starts_with("shared/hooks/")
    if has_shared_hooks {
        return "H-NOHOOK|error|H-NOHOOK: shared/hooks/ deprecated — shared/harness/ 사용. 우회: '@allow-hook' 토큰"
    }
    let has_git_hooks = path.index_of("/.git/hooks/") >= 0 || path.starts_with(".git/hooks/")
    if has_git_hooks {
        if base.ends_with(".sample") { return "" }
        let h_commit_ok = (base == "commit-msg" || base == "pre-commit" || base == "post-commit" || base == "pre-push")
        if h_commit_ok == false {
            return "H-NOHOOK|error|H-NOHOOK: .git/hooks/" + base + " 신규 금지 — H-COMMIT 4종 외 추가 hook 불가. 우회: '@allow-hook'"
        }
    }
    let has_githooks = path.index_of("/.githooks/") >= 0 || path.starts_with(".githooks/")
    if has_githooks {
        let h_commit_ok = (base == "commit-msg" || base == "pre-commit")
        if h_commit_ok == false {
            return "H-NOHOOK|error|H-NOHOOK: .githooks/" + base + " 신규 wrapper 금지 — H-COMMIT 외 추가 불가. 우회: '@allow-hook'"
        }
    }

    // 2) settings.json / settings.local.json — hooks 키 비어있지 않으면 위반
    let in_claude_dir = path.index_of("/.claude/") >= 0 || path.starts_with(".claude/")
    if in_claude_dir {
        if base == "settings.json" || base == "settings.local.json" {
            let full = REPO_ROOT + "/" + path
            if file_exists(full) {
                let mut content = ""
                try { content = read_file(full) } catch e {}
                if content == "" { return "" }
                if content.index_of("@allow-hook") >= 0 { return "" }
                // 비어있지 않은 hooks 키 — `"hooks": {` 다음에 `}` 가 즉시 오지 않거나 `[` 가 오면 위반
                // 단순 패턴: `"hooks": {}` / `"hooks":{}` / `"hooks": null` 만 통과
                let empty_a = content.index_of("\"hooks\": {}") >= 0
                let empty_b = content.index_of("\"hooks\":{}") >= 0
                let empty_c = content.index_of("\"hooks\": null") >= 0
                let no_hooks_key = content.index_of("\"hooks\"") < 0
                if no_hooks_key { return "" }
                if empty_a || empty_b || empty_c { return "" }
                return "H-NOHOOK|error|H-NOHOOK: " + path + " — settings hooks 키 비어있지 않음. 정책: hooks={} + harness/entry.hexa 자율 호출. 우회: '@allow-hook'"
            }
        }
    }

    return ""
}

// ─── H-HEXA-EXIT (공통) — hexa 호출의 exit() 가 부모로 전파 안 됨 ───
// Why: hexa 런타임 한계로 child script 의 exit(N) 이 부모 exec() 결과에 N 으로 전파되지 않음.
// 예: health.hexa atlas → atlas_health.hexa 의 exit(1) WARN 이 0 으로 관측됨.
// Fix: stdout 마커 또는 stderr 패턴 검사로 우회. exit code 단독 의존 금지.
// 감지: exec(... .hexa ...) 또는 dispatch_file(... .hexa ...) + 같은 파일 내 exit_code/$?/__RC= 식 exit code 의존 키워드
// 우회: '@allow-hexa-exit' 토큰 또는 본 규칙 자기참조 (self-reference)
fn check_hexa_exit(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    let full = REPO_ROOT + "/" + path
    if !file_exists(full) { return "" }
    let mut content = ""
    try { content = read_file(full) } catch e {}
    if content == "" { return "" }
    if content.index_of("@allow-hexa-exit") >= 0 { return "" }
    if content.index_of("check_hexa_exit") >= 0 { return "" }
    if content.index_of("H-HEXA-EXIT") >= 0 { return "" }
    // 1단계: hexa 자식 호출 흔적 (주석 라인 제외)
    let call_hits = _to_int0(_str(exec("awk '/exec\\([^)]*\\.hexa|dispatch_file\\([^)]*\\.hexa/ && !/^[[:space:]]*\\/\\//{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    if call_hits == 0 { return "" }
    // 2단계: exit code 의존 키워드 (같은 파일 어디든 — 간이 휴리스틱, 주석 라인 제외)
    let mut dep_hits = 0
    let mut kinds = ""
    let rc_hits = _to_int0(_str(exec("awk '/__RC=\\$\\?|echo \\$\\?|exit_code|exit_status/ && !/^[[:space:]]*\\/\\//{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    if rc_hits > 0 { dep_hits = dep_hits + rc_hits; kinds = kinds + "exit_code/$?(" + to_string(rc_hits) + ") " }
    if dep_hits == 0 { return "" }
    return "H-HEXA-EXIT|warn|hexa 자식 호출 " + to_string(call_hits) + "건 + exit code 의존 패턴 " + kinds.trim() + "— hexa 런타임은 child exit(N) 을 부모 exec() 로 전파 안 함. stdout marker 검사 권장 (mistakes.jsonl H-HEXA-EXIT). 명시 예외: '// @allow-hexa-exit'"
}

// ─── H-MD2PDF (공통) — MD→PDF 는 md-to-pdf 전용. pandoc/xelatex 호출 차단 ───
// Why: 사용자 정책 — MD→PDF 변환은 md-to-pdf 만 사용. pandoc/xelatex/pdflatex/lualatex 결과물 스타일 깨짐.
// 우회: 파일에 '@allow-pandoc' 토큰 또는 'NEXUS_PDF_OK=1' envvar prefix 있으면 스킵.
fn check_md2pdf(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" { return "" }
    let full = REPO_ROOT + "/" + path
    if !file_exists(full) { return "" }
    let mut content = ""
    try { content = read_file(full) } catch e {}
    if content == "" { return "" }
    if content.index_of("@allow-pandoc") >= 0 { return "" }
    if content.index_of("NEXUS_PDF_OK=1") >= 0 { return "" }
    if content.index_of("check_md2pdf") >= 0 { return "" }
    if content.index_of("H-MD2PDF") >= 0 { return "" }

    let mut hits = 0
    let mut tools = ""
    if content.index_of("xelatex") >= 0 { hits = hits + 1; tools = tools + "xelatex " }
    if content.index_of("pdflatex") >= 0 { hits = hits + 1; tools = tools + "pdflatex " }
    if content.index_of("lualatex") >= 0 { hits = hits + 1; tools = tools + "lualatex " }
    if content.index_of("pandoc") >= 0 {
        if content.index_of(".pdf") >= 0 || content.index_of("--to=pdf") >= 0 || content.index_of("-t pdf") >= 0 || content.index_of("--to pdf") >= 0 {
            hits = hits + 1
            tools = tools + "pandoc(->pdf) "
        }
    }
    if hits > 0 {
        return "H-MD2PDF|error|MD->PDF 도구 위반: " + tools.trim() + "— `md-to-pdf <file.md>` 사용. 명시 예외: '// @allow-pandoc'"
    }
    return ""
}

// ─── H-SEND-GUARD (공통) — 외부 발송/등록 (이메일/github issue·PR/webhook) 코드 감지 ───
// Why: 사용자 명시 요청 전 외부 발송/등록 금지. 코드 정적으로 박혀있으면 cron/auto 트리거에서 의도치 않은 발송 위험.
// 우회: 파일에 '@allow-send' 토큰 또는 'NEXUS_SEND_OK=1' envvar prefix 있으면 스킵.
fn check_send_guard(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" { return "" }
    let full = REPO_ROOT + "/" + path
    if !file_exists(full) { return "" }
    let mut content = ""
    try { content = read_file(full) } catch e {}
    if content == "" { return "" }
    if content.index_of("@allow-send") >= 0 { return "" }
    if content.index_of("NEXUS_SEND_OK=1") >= 0 { return "" }
    if content.index_of("check_send_guard") >= 0 { return "" }
    if content.index_of("H-SEND-GUARD") >= 0 { return "" }

    let mut hits = 0
    let mut kinds = ""
    if content.index_of("gh issue create") >= 0 { hits = hits + 1; kinds = kinds + "gh-issue " }
    if content.index_of("gh issue comment") >= 0 { hits = hits + 1; kinds = kinds + "gh-issue-cmt " }
    if content.index_of("gh pr create") >= 0 { hits = hits + 1; kinds = kinds + "gh-pr " }
    if content.index_of("gh pr comment") >= 0 { hits = hits + 1; kinds = kinds + "gh-pr-cmt " }
    if content.index_of("gh pr merge") >= 0 { hits = hits + 1; kinds = kinds + "gh-pr-merge " }
    if content.index_of("gh release create") >= 0 { hits = hits + 1; kinds = kinds + "gh-release " }
    if content.index_of("gh gist create") >= 0 { hits = hits + 1; kinds = kinds + "gh-gist " }
    if content.index_of("sendmail ") >= 0 { hits = hits + 1; kinds = kinds + "sendmail " }
    if content.index_of("msmtp ") >= 0 { hits = hits + 1; kinds = kinds + "msmtp " }
    if content.index_of("swaks ") >= 0 { hits = hits + 1; kinds = kinds + "swaks " }
    if content.index_of("hooks.slack.com") >= 0 { hits = hits + 1; kinds = kinds + "slack-webhook " }
    if content.index_of("discord.com/api/webhooks") >= 0 { hits = hits + 1; kinds = kinds + "discord-webhook " }
    if hits > 0 {
        return "H-SEND-GUARD|warn|외부 발송 코드 감지: " + kinds.trim() + "— 사용자 명시 요청 전 금지. 명시 예외: '// @allow-send' 또는 NEXUS_SEND_OK=1 prefix"
    }
    return ""
}

// ─── N61-NEW (n6-architecture) — 신규 canonical 은 sample.md gold standard 필수 ───
// git untracked .md (domains/ 또는 papers/) 감지 시 V3/V4 수준 strict
fn check_n61_new(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let tracked = _to_int0(_str(exec("awk 'END{print NR+0}' <(git ls-files --error-unmatch '" + path + "' 2>/dev/null)")).trim())
    if tracked > 0 { return "" }
    let full = REPO_ROOT + "/" + path
    let sub = _to_int0(_str(exec("awk '/^### §7\\.[0-9]+/{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    if sub < 10 {
        return "N61-NEW|error|신규 canonical — shared/harness/sample.md 템플릿 복사 필수 (§7.0~§7.10 10 서브섹션, 현재 " + to_string(sub) + ")"
    }
    return ""
}

// ─── N61-GOLD-REF (n6-architecture) — sample.md 참조 마커 권장 ───
fn check_n61_gold_ref(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    let hits = _to_int0(_str(exec("awk '/gold-standard:.*sample\\.md|shared\\/harness\\/sample\\.md/{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    if hits == 0 {
        return "N61-GOLD-REF|warn|gold standard 참조 없음 — '<!-- gold-standard: shared/harness/sample.md -->' 마커 권장"
    }
    return ""
}

// ─── N61-F1 (n6-architecture) — frontmatter alien_index_* 금지 ───
// 전체 canonical 스코프. lint 미사용 키 (alien_index_current/target) 제거 강제.
// Why: alien_index 는 본문 표기에만 사용. frontmatter 에 두면 machine-parse 오해 + 중복.
fn check_n61_f1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    let hits = _to_int0(_str(exec("awk 'NR==1 && /^---[[:space:]]*$/{in_fm=1; next} in_fm && /^---[[:space:]]*$/{exit} in_fm && /^alien_index_(current|target):/{c++} END{print c+0}' '" + full + "' 2>/dev/null")).trim())
    if hits > 0 {
        return "N61-F1|error|frontmatter alien_index_current/target 금지 (" + to_string(hits) + "건) — lint 미사용 키, 본문에서만 사용"
    }
    return ""
}

// ─── N61-V1 (n6-architecture) — §7 python 에 도메인 키워드 없음 경고 ───
// frontmatter domain: <name> 이 §7 python 블록 body 내 출현 없음 → canonical 제너릭
fn check_n61_v1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    let m = _to_int0(_str(exec("grep -c '@allow-generic-verify' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    let awk_dom = "awk 'NR==1 && /^---[[:space:]]*$/ { in_fm=1; next } in_fm && /^---[[:space:]]*$/ { in_fm=0; exit } in_fm && /^[[:space:]]*domain:[[:space:]]*/ { sub(/^[[:space:]]*domain:[[:space:]]*/,\"\"); sub(/[[:space:]]*#.*$/,\"\"); gsub(/[[:space:]]+$/,\"\"); gsub(/^[\"\\x27]|[\"\\x27]$/,\"\"); print }' '" + full + "' 2>/dev/null"
    let domain = _str(exec(awk_dom)).trim()
    if domain == "" || len(domain) < 3 { return "" }
    let cmd = "awk '/^## §7 VERIFY/ { in_s=1 } in_s && /^\\`\\`\\`python/ { in_p=1; next } in_p && /^\\`\\`\\`/ { in_p=0; exit } in_p' '" + full + "' 2>/dev/null | grep -ciF '" + domain + "' || echo 0"
    let hits = _to_int0(_str(exec(cmd)).trim())
    if hits == 0 {
        return "N61-V1|warn|§7 python 에 domain '" + domain + "' 키워드 없음 — 제너릭 canonical 만 (// @allow-generic-verify)"
    }
    return ""
}

// ─── VP-M1 (n6-architecture) — ```python 블록에 'MISSING DATA' 금지 ───
fn check_vp_m1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    let m = _to_int0(_str(exec("grep -c '@allow-missing-data' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    let awk = "awk '/^\\`\\`\\`python/{in_p=1;next} /^\\`\\`\\`/{in_p=0} in_p && /MISSING DATA/{c++} END{print c+0}' '" + full + "' 2>/dev/null"
    let cnt = _to_int0(_str(exec(awk)).trim())
    if cnt > 0 {
        return "VP-M1|error|python 블록에 'MISSING DATA' 플레이스홀더 " + to_string(cnt) + "건 — 실제 검증 필수 (// @allow-missing-data)"
    }
    return ""
}

// ─── VP-M2 (n6-architecture) — ```python 블록에 (_, None, None, None) 튜플 금지 ───
fn check_vp_m2(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    let m = _to_int0(_str(exec("grep -c '@allow-missing-data' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    let awk = "awk '/^\\`\\`\\`python/{in_p=1;next} /^\\`\\`\\`/{in_p=0} in_p && /,[[:space:]]*None[[:space:]]*,[[:space:]]*None[[:space:]]*,[[:space:]]*None/{c++} END{print c+0}' '" + full + "' 2>/dev/null"
    let cnt = _to_int0(_str(exec(awk)).trim())
    if cnt > 0 {
        return "VP-M2|error|python 블록에 (_, None, None, None) 플레이스홀더 " + to_string(cnt) + "건 — 실제 값 필수 (// @allow-missing-data)"
    }
    return ""
}

// ─── VP runtime helper — paper.md 의 ```python 블록 추출 → /usr/bin/python3 실행 ───
// 반환: "<rc>|<stdout_b64>|<stderr_b64>" 또는 "" (블록 없음/python3 없음/skip)
// 블록 없으면 "" 반환 (skip pass), python3 미설치 시 "missing" 반환
fn _vp_python_path() -> string {
    // /usr/bin/python3 우선 (hetzner 라우팅 회피 — feedback_python_wrapper_gotcha)
    let p1 = _str(exec("[ -x /usr/bin/python3 ] && echo y || echo n")).trim()
    if p1 == "y" { return "/usr/bin/python3" }
    return ""
}

fn _vp_sha1(path: string) -> string {
    let r = _str(exec("printf '%s' '" + path + "' | shasum -a 1 2>/dev/null | cut -c1-12")).trim()
    if r == "" { return "fallback" }
    return r
}

// ```python 블록 1개 이상 존재 시 임시 .py 작성 + 실행
// 결과: "missing" / "noblock" / "<rc>|<stdout>|<stderr>"
// stdout/stderr 는 줄바꿈을 '\\n' literal 로 인코딩
fn _vp_run_blocks(path: string) -> string {
    let py = _vp_python_path()
    if py == "" { return "missing" }
    let full = REPO_ROOT + "/" + path
    // 블록 카운트 확인
    let cnt = _to_int0(_str(exec("grep -cE '^\\`\\`\\`python' '" + full + "' 2>/dev/null || echo 0")).trim())
    if cnt == 0 { return "noblock" }
    // 임시 디렉토리 — N6_VERIFY_DIR 또는 /tmp
    let env_dir = env("N6_VERIFY_DIR")
    let mut base = env_dir
    if base == "" { base = "/tmp" }
    let sha = _vp_sha1(path)
    let work = base + "/n6-verify-" + sha
    let bn = basename_of(path)
    // .md → .py 확장자 교체
    let dot = _rfind(bn, ".")
    let mut stem = bn
    if dot > 0 { stem = bn.substring(0, dot) }
    let py_file = work + "/" + stem + ".py"
    exec("mkdir -p '" + work + "' 2>/dev/null")
    // awk 로 ```python ... ``` 블록 본문만 추출 (시작/끝 펜스 제외)
    let awk = "awk '/^\\`\\`\\`python/{in_p=1;next} /^\\`\\`\\`/{if(in_p){in_p=0;print \"\"}} in_p{print}' '" + full + "' > '" + py_file + "' 2>/dev/null"
    exec(awk)
    // 실행 (timeout 30s, stdout/stderr 분리)
    let out_file = work + "/" + stem + ".out"
    let err_file = work + "/" + stem + ".err"
    let rc_file = work + "/" + stem + ".rc"
    let cmd = "( cd '" + work + "' && /usr/bin/env -i HOME='" + env("HOME") + "' PATH=/usr/bin:/bin '" + py + "' -W ignore '" + py_file + "' > '" + out_file + "' 2> '" + err_file + "' ); echo $? > '" + rc_file + "'"
    // 로컬 timeout (gtimeout 또는 perl 폴백)
    let has_timeout = _str(exec("command -v timeout >/dev/null 2>&1 && echo y || command -v gtimeout >/dev/null 2>&1 && echo y || echo n")).trim()
    if has_timeout == "y" {
        let to_bin = _str(exec("command -v timeout 2>/dev/null || command -v gtimeout 2>/dev/null")).trim()
        let cmd2 = "( cd '" + work + "' && '" + to_bin + "' 30 '" + py + "' -W ignore '" + py_file + "' > '" + out_file + "' 2> '" + err_file + "' ); echo $? > '" + rc_file + "'"
        exec(cmd2)
    } else {
        exec(cmd)
    }
    let rc = _str(exec("cat '" + rc_file + "' 2>/dev/null")).trim()
    let out_raw = _str(exec("cat '" + out_file + "' 2>/dev/null"))
    let err_raw = _str(exec("cat '" + err_file + "' 2>/dev/null"))
    // 줄바꿈 → '\n' literal (split 충돌 방지). 임시 파일은 디버깅 위해 보존.
    let out_enc = out_raw.replace("\n", "\\n").replace("|", "/")
    let err_enc = err_raw.replace("\n", "\\n").replace("|", "/")
    return rc + "|" + out_enc + "|" + err_enc
}

// 결과 파싱 헬퍼 — index 0=rc, 1=stdout, 2=stderr
fn _vp_part(res: string, idx: i64) -> string {
    if res == "" || res == "missing" || res == "noblock" { return "" }
    let parts = res.split("|")
    if len(parts) < 3 { return "" }
    if idx == 0 { return _str(parts[0]) }
    if idx == 1 { return _str(parts[1]) }
    if idx == 2 { return _str(parts[2]) }
    return ""
}

// ─── VP-M7 (n6-architecture) — python 검증 코드 exit 0 ───
fn check_vp_m7(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    let m = _to_int0(_str(exec("grep -c '@allow-no-runtime' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    let res = _vp_run_blocks(path)
    if res == "noblock" { return "" }
    if res == "missing" {
        return "VP-M7|warn|/usr/bin/python3 미설치 — 런타임 검증 스킵 (// @allow-no-runtime)"
    }
    let rc = _vp_part(res, 0)
    let err = _vp_part(res, 2)
    if rc == "0" && err == "" { return "" }
    if rc == "0" { return "" }
    // stderr 첫 줄 추출
    let err_first = err.split("\\n")[0]
    return "VP-M7|error|python 검증 코드 실행 실패 (exit " + rc + ") / stderr: " + _str(err_first) + " (// @allow-no-runtime)"
}

// ─── VP-M9 (n6-architecture) — python stdout 에 'SKIP' 단어 차단 ───
fn check_vp_m9(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    let m = _to_int0(_str(exec("grep -c '@allow-no-runtime' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    let res = _vp_run_blocks(path)
    if res == "noblock" || res == "missing" { return "" }
    let rc = _vp_part(res, 0)
    if rc != "0" { return "" }  // VP-M7 가 잡음
    let out = _vp_part(res, 1)
    // SKIP 단어 카운트 — 줄바꿈 디코딩 후 grep
    let lines = out.split("\\n")
    let mut skip_cnt: i64 = 0
    for ln in lines {
        let s = _str(ln)
        if s == "" { continue }
        if s.index_of("SKIP") >= 0 { skip_cnt = skip_cnt + 1 }
    }
    if skip_cnt == 0 { return "" }
    return "VP-M9|error|python 실행 결과에 'SKIP' 단어 " + to_string(skip_cnt) + "건 / MISSING DATA 잔존 (// @allow-no-runtime)"
}

// ─── VP-M10 (n6-architecture) — python stdout 에 N/N PASS 형식 요약 필수 ───
fn check_vp_m10(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    let m = _to_int0(_str(exec("grep -c '@allow-no-runtime' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    let res = _vp_run_blocks(path)
    if res == "noblock" || res == "missing" { return "" }
    let rc = _vp_part(res, 0)
    if rc != "0" { return "" }  // VP-M7 가 잡음
    let out = _vp_part(res, 1)
    // 디코딩 후 임시 파일에 써서 grep — 단순화: hexa 내에서 직접 패턴 매칭
    // 패턴 1: [0-9]+/[0-9]+ PASS  /  패턴 2: All N PASS  /  패턴 3: N/N PASS
    let lines = out.split("\\n")
    let mut found = false
    for ln in lines {
        let s = _str(ln)
        if s == "" { continue }
        // 'PASS' 가 있고 / 또는 'All' 동반
        if s.index_of("PASS") < 0 { continue }
        // X/Y PASS 매칭: 슬래시 앞뒤 숫자
        let slash = s.index_of("/")
        if slash > 0 {
            // slash 직전·직후 숫자 검사
            let before = s.substring(0, slash)
            let after = s.substring(slash + 1, len(s))
            // before 끝이 숫자, after 시작이 숫자
            let bn_len = len(before)
            if bn_len > 0 {
                let bc = before.substring(bn_len - 1, bn_len)
                if bc >= "0" && bc <= "9" {
                    if len(after) > 0 {
                        let ac = after.substring(0, 1)
                        if ac >= "0" && ac <= "9" { found = true }
                    }
                }
            }
        }
        if !found && s.index_of("All ") >= 0 && s.index_of(" PASS") >= 0 { found = true }
    }
    if found { return "" }
    return "VP-M10|error|python 실행 결과에 'N/N PASS' 형식 요약 누락 (// @allow-no-runtime)"
}

// ─── N6-JSONPAIR (n6-architecture) — 신규 도메인 문서 추가 시 papers/_registry.json 동반 ───
// staged 에 papers/n6-*.md 또는 domains/*/*.md (status=A) + papers/_registry.json 미변경 → error
// 파일별 호출이라 매번 같은 staged 상태를 검사. path 는 트리거 매칭에 사용.
fn check_n6_jsonpair(path: string) -> string {
    if _project_name() != "n6-architecture" { return "" }
    // 트리거: 이 파일이 staged 신규 문서일 때만 한 번 검사
    let bn = basename_of(path)
    if ext_of(path) != ".md" { return "" }
    let is_paper_md = path.starts_with("papers/n6-") && bn != "_registry.json"
    let is_domain_md = path.starts_with("domains/") && path.index_of("/_archive/") < 0
    if !is_paper_md && !is_domain_md { return "" }
    // 이 파일이 added 상태인지 확인
    let st = _str(exec("git diff --cached --name-status -- '" + path + "' 2>/dev/null | head -1")).trim()
    if !st.starts_with("A") { return "" }
    // papers/_registry.json 이 staged 변경 목록에 있는지 (M 또는 A)
    let reg = _str(exec("git diff --cached --name-only 2>/dev/null | grep -E '^papers/_registry\\.json$' | head -1")).trim()
    if reg != "" { return "" }
    // msg_check (@allow-no-registry-update) 은 commit.hexa msg_check (commit-msg 훅) 최종 검증
    // pre-commit 단계 COMMIT_EDITMSG 는 N-1 메시지라 구조적 오탐 원인 — path 기반 error 유지
    return "N6-JSONPAIR|error|신규 도메인 문서 '" + path + "' 추가 시 papers/_registry.json 업데이트 필수 (// @allow-no-registry-update) — commit-msg 단계 최종 검증"
}

// ─── AG6-S1 (airgenome 전용) — Mac 로컬 heavy compute 실행 전 원격 가드 필수 ───
// 원칙: 원격(ubu/htz/hetzner) 자원 가용 시 Mac heavy compute 0. Mac은 오케스트레이션 전용.
// 정적 탐지: heavy compute 호출(blowup/seed_engine/ouroboros) 이 파일에 존재하면
//          같은 파일에 원격 가드 참조(dispatch_state/infra_state/ssh ubu|htz|hetzner/
//          auto_dispatch/resource_ceiling/BLOWUP_LOCAL) 필수.
// 예외: archive/, shared/harness/, docs/, tests/, // @allow-local-heavy
fn check_ag6(path: string) -> string {
    if _project_name() != "airgenome" { return "" }
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.starts_with("shared/harness/") { return "" }
    if path.starts_with("docs/") { return "" }
    if path.starts_with("tests/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    if path.index_of("/test/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    let marker = _to_int0(_str(exec("grep -c '@allow-local-heavy' '" + full + "' 2>/dev/null || echo 0")).trim())
    if marker > 0 { return "" }
    // heavy compute 호출 패턴
    let heavy = _to_int0(_str(exec("grep -cE '(exec|spawn|system|sh|bash)[[:space:]]*\\([^)]*(blowup|seed_engine|ouroboros)|\\./blowup|hexa[^\"'\\''`]*blowup' '" + full + "' 2>/dev/null || echo 0")).trim())
    if heavy == 0 { return "" }
    // 원격 가드 참조 필수 (변수명 'guard' 는 hexa 예약어 — _remote_guard 사용)
    let _remote_guard = _to_int0(_str(exec("grep -cE '(dispatch_state|infra_state|ssh[^\"]*@(ubu|htz|hetzner)|auto_dispatch|resource_ceiling|BLOWUP_LOCAL)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if _remote_guard == 0 {
        return "AG6-S1|error|Mac 로컬 heavy compute 호출 " + to_string(heavy) + "건 — 원격 가드(dispatch_state/infra_state/ssh ubu+htz+hetzner) 참조 없음 (// @allow-local-heavy)"
    }
    return ""
}

// ─── 프로젝트별 규칙 JSONL 자동 로드 엔진 ───
// 파일: shared/rules/<project>.lint.jsonl (한 줄 = 한 규칙)
// 지원 kind: grep, grep_combo, grep_any, ext_blacklist, ext_blacklist_in_path,
//           ext_whitelist, filename, require_entry
// 규칙 추가/변경은 JSONL 파일만 편집 (엔진 코드 불변)

fn _pr_field(line: string, key: string) -> string {
    let marker = "\"" + key + "\":\""
    let idx = line.index_of(marker)
    if idx < 0 { return "" }
    let after = line.substring(idx + len(marker), len(line))
    let end = after.index_of("\"")
    if end < 0 { return "" }
    return after.substring(0, end)
}

// "key":[...] 배열 값 추출 — 각 원소를 " 로 감싼 문자열로 반환
fn _pr_array(line: string, key: string) -> [string] {
    let mut arr: [string] = []
    let marker = "\"" + key + "\":["
    let idx = line.index_of(marker)
    if idx < 0 { return arr }
    let after = line.substring(idx + len(marker), len(line))
    let end = after.index_of("]")
    if end < 0 { return arr }
    let body = after.substring(0, end)
    // body 안의 "..." 추출
    let mut i: i64 = 0
    while i < len(body) {
        let q1 = body.index_of("\"")
        if q1 < 0 { break }
        let rest = body.substring(q1 + 1, len(body))
        let q2 = rest.index_of("\"")
        if q2 < 0 { break }
        let val = rest.substring(0, q2)
        arr = arr.push(val)
        let consumed = q1 + 1 + q2 + 1
        if consumed >= len(body) { break }
        // 진행: body 를 자르는 대신 local slicing
        let new_body = body.substring(consumed, len(body))
        return _pr_array_continue(new_body, arr)
    }
    return arr
}

fn _pr_array_continue(body: string, acc: [string]) -> [string] {
    let mut arr = acc
    let q1 = body.index_of("\"")
    if q1 < 0 { return arr }
    let rest = body.substring(q1 + 1, len(body))
    let q2 = rest.index_of("\"")
    if q2 < 0 { return arr }
    let val = rest.substring(0, q2)
    arr = arr.push(val)
    let consumed = q1 + 1 + q2 + 1
    if consumed >= len(body) { return arr }
    let next_body = body.substring(consumed, len(body))
    return _pr_array_continue(next_body, arr)
}

fn _ext_in(ext: string, list: [string]) -> bool {
    for e in list {
        if _str(e) == ext { return true }
    }
    return false
}

fn _any_in_path(path: string, parts: [string]) -> bool {
    for p in parts {
        let s = _str(p)
        if s != "" && path.index_of(s) >= 0 { return true }
    }
    return false
}

fn _any_excluded(path: string, exclude: [string]) -> bool {
    for e in exclude {
        let s = _str(e)
        if s != "" && path.index_of(s) >= 0 { return true }
    }
    return false
}

// kind=grep_combo: all[] 패턴이 전부 파일에 나타나면 위반
fn _match_grep_combo(full: string, patterns: [string], allow: string) -> bool {
    for p in patterns {
        let pat = _str(p)
        if pat == "" { continue }
        let cmd = "grep -E '" + pat + "' '" + full + "' 2>/dev/null | grep -v '" + allow + "' | head -1"
        let r = _str(exec(cmd)).trim()
        if r == "" { return false }
    }
    return true
}

// kind=grep_any: any[] 패턴이 하나라도 나타나면 위반
fn _match_grep_any(full: string, patterns: [string], allow: string) -> bool {
    for p in patterns {
        let pat = _str(p)
        if pat == "" { continue }
        let cmd = "grep -E '" + pat + "' '" + full + "' 2>/dev/null | grep -v '" + allow + "' | head -1"
        let r = _str(exec(cmd)).trim()
        if r != "" { return true }
    }
    return false
}

// kind=require_entry: entry_patterns 중 하나는 있어야 함 (없으면 위반)
fn _match_require_entry(full: string, patterns: [string]) -> bool {
    for p in patterns {
        let pat = _str(p)
        if pat == "" { continue }
        let cmd = "grep -cE '" + pat + "' '" + full + "' 2>/dev/null || echo 0"
        let c = _to_int0(_str(exec(cmd)).trim())
        if c > 0 { return false }
    }
    return true
}

fn check_project_rules(path: string) -> string {
    let project = _project_name()
    if project == "" { return "" }
    let rulefile = REPO_ROOT + "/shared/rules/" + project + ".lint.jsonl"
    if !file_exists(rulefile) { return "" }
    let raw = _str(exec("cat '" + rulefile + "' 2>/dev/null")).trim()
    if raw == "" { return "" }
    let full = REPO_ROOT + "/" + path
    let e = ext_of(path)
    for ln in raw.split("\n") {
        let line = _str(ln).trim()
        if line == "" { continue }
        if line.starts_with("//") { continue }
        let id = _pr_field(line, "id")
        let kind = _pr_field(line, "kind")
        let severity = _pr_field(line, "severity")
        let fix = _pr_field(line, "fix")
        let allow = _pr_field(line, "allow")
        if id == "" || kind == "" { continue }
        let exts = _pr_array(line, "ext")
        if len(exts) > 0 && !_ext_in(e, exts) { continue }
        let exclude = _pr_array(line, "exclude")
        if _any_excluded(path, exclude) { continue }
        let prefix = _pr_field(line, "path_prefix")
        if prefix != "" && !path.starts_with(prefix) { continue }
        let path_any = _pr_array(line, "path_any")
        if len(path_any) > 0 && !_any_in_path(path, path_any) { continue }
        let mut violated = false
        if kind == "grep_combo" {
            let pats = _pr_array(line, "all")
            if _match_grep_combo(full, pats, allow) { violated = true }
        }
        else if kind == "grep_any" {
            let pats = _pr_array(line, "any")
            if _match_grep_any(full, pats, allow) { violated = true }
        }
        else if kind == "ext_blacklist_in_path" {
            // 확장자 목록 + 경로 any 둘 다 매칭 시 위반 (path_any 이미 매칭됨 + 확장자 blacklist)
            let bl = _pr_array(line, "ext")
            if _ext_in(e, bl) { violated = true }
        }
        else if kind == "ext_blacklist" {
            let bl = _pr_array(line, "ext")
            if _ext_in(e, bl) { violated = true }
        }
        else if kind == "filename" {
            let deny = _pr_array(line, "deny")
            let bn = basename_of(path)
            for d in deny {
                if _str(d) == bn { violated = true; break }
            }
        }
        else if kind == "require_entry" {
            let pats = _pr_array(line, "entry_patterns")
            if _match_require_entry(full, pats) { violated = true }
        }
        if violated {
            return id + "|" + severity + "|" + fix
        }
    }
    return ""
}

// ─── BLOW1 (공통) — BLOWUP_LOCAL=1 절대 금지 ───
// Mac 로컬 blowup 우회 금지. hetzner 원격 강제.
// 예외: archive/, shared/harness/, // @allow-local-blowup
fn check_blow1(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" && e != ".json" && e != ".jsonl" && e != ".md" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.starts_with("shared/harness/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    let hit = _to_int0(_str(exec("grep -cE 'BLOWUP_LOCAL[[:space:]]*=[[:space:]]*1' '" + full + "' 2>/dev/null || echo 0")).trim())
    if hit > 0 {
        let filtered = _to_int0(_str(exec("grep -E 'BLOWUP_LOCAL[[:space:]]*=[[:space:]]*1' '" + full + "' 2>/dev/null | grep -v '@allow-local-blowup' | wc -l")).trim())
        if filtered > 0 {
            return "BLOW1|error|BLOWUP_LOCAL=1 절대 금지 " + to_string(filtered) + "건 — hetzner 원격 강제 (// @allow-local-blowup)"
        }
    }
    return ""
}

// ─── BLOW3 (공통) — blowup 신규 파일은 서브폴더 하위만 ───
// shared/blowup/ 루트에 .hexa 신규 금지. core/modules/guard/lens/ouroboros/seed/lib 중 하나만.
fn check_blow3(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    if !path.starts_with("shared/blowup/") { return "" }
    // core/modules/guard/lens/ouroboros/seed/lib 의 하위인지 확인
    if path.starts_with("shared/blowup/core/") { return "" }
    if path.starts_with("shared/blowup/modules/") { return "" }
    if path.starts_with("shared/blowup/guard/") { return "" }
    if path.starts_with("shared/blowup/lens/") { return "" }
    if path.starts_with("shared/blowup/ouroboros/") { return "" }
    if path.starts_with("shared/blowup/seed/") { return "" }
    if path.starts_with("shared/blowup/lib/") { return "" }
    // 예외: commands.hexa, todo.hexa (기존 루트 허용 파일)
    let bn = basename_of(path)
    if bn == "commands.hexa" { return "" }
    if bn == "todo.hexa" { return "" }
    return "BLOW3|error|blowup 신규 파일 '" + bn + "' 은 core/modules/guard/lens/ouroboros/seed/lib 하위만"
}

// ─── BLOW6 (공통) — blowup 결과 R28 준수 (폐기된 JSON 발견 저장소 신규 쓰기 금지) ───
// discovery_graph.json / discovery_log.jsonl / growth_bus.jsonl 는 2026-04-11 폐기.
// blowup 엔진은 atlas.n6 만 사용.
// verified_constants.jsonl 은 V-CONST 룰 (별도 빌더 경유) 에서 처리.
fn check_blow6(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    if !path.starts_with("shared/blowup/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    // write_file / append_file / shell redirect 대상에 금지 파일명 포함
    let cmd = "grep -nE '(write_file|append_file|>>|>)[[:space:]]*[^[:space:]]*(discovery_graph|discovery_log|growth_bus)' '" + full + "' 2>/dev/null | grep -v '@allow-deprecated-json' | wc -l"
    let hits = _to_int0(_str(exec(cmd)).trim())
    if hits > 0 {
        return "BLOW6|error|폐기 JSON 발견 저장소 쓰기 " + to_string(hits) + "건 — atlas.n6 만 사용 (R28, // @allow-deprecated-json)"
    }
    return ""
}

// ─── V-CONST (공통) — verified_constants.jsonl 직접 write 금지 ───
// 공리: verified_constants.jsonl 은 shared/scripts/index_verified_constants.hexa 빌더 경유만.
//       직접 write_file/append_file/shell redirect 는 인덱스 drift 유발.
// 예외: index_verified_constants.hexa (빌더 본체), shared/harness/, archive/, // @allow-deprecated-json
fn check_v_const(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" { return "" }
    let bn = basename_of(path)
    if bn == "index_verified_constants.hexa" { return "" }
    if path.starts_with("shared/harness/") { return "" }
    if path.starts_with("archive/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    let cmd = "grep -nE '(write_file|append_file|>>|>)[[:space:]]*[^[:space:]]*verified_constants' '" + full + "' 2>/dev/null | grep -v '@allow-deprecated-json' | wc -l"
    let hits = _to_int0(_str(exec(cmd)).trim())
    if hits > 0 {
        return "V-CONST|warn|verified_constants.jsonl 직접 쓰기 금지 " + to_string(hits) + "건 — shared/scripts/index_verified_constants.hexa 빌더 경유 (// @allow-deprecated-json)"
    }
    return ""
}


// ─── ATLAS-GUARD (공통) — atlas.n6 직접 편집 금지 (Phase 1 진입 차단) ───
// 공리: atlas.n6 은 전 프로젝트 단일 진리 (nexus/anima/n6-architecture/void 등 공용).
//       편집은 _guarded_append_atlas() 또는 atlas_guard 경유만.
// L1: .hexa 에서 write_file/append_file 로 atlas.n6 직접 호출
// L2: shell redirect (>> atlas.n6, > atlas.n6)
// L3: 간접 shell (echo/cat/printf → atlas.n6)
// 예외: atlas_guard.hexa.inc, atlas_health.hexa, archive/, // @allow-atlas-direct
fn _atlas_is_exempt(path: string) -> bool {
    let bn = basename_of(path)
    if bn == "atlas_guard.hexa.inc" { return true }
    if bn == "atlas_health.hexa" { return true }
    if path.starts_with("shared/harness/") { return true }
    if path.starts_with("archive/") { return true }
    if path.index_of("/_archive/") >= 0 { return true }
    if path.starts_with(".claude/") { return true }
    return false
}

fn check_atlas_guard(path: string) -> string {
    if _atlas_is_exempt(path) { return "" }
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" { return "" }
    let full = REPO_ROOT + "/" + path
    // L1: write_file/append_file 가 atlas.n6 경로 인자 포함
    let l1 = _to_int0(_str(exec("grep -nE '(write_file|append_file)[[:space:]]*\\([^)]*atlas\\.n6' '" + full + "' 2>/dev/null | grep -v '@allow-atlas-direct' | wc -l")).trim())
    if l1 > 0 {
        return "ATLAS-GUARD-L1|error|atlas.n6 직접 write_file/append_file " + to_string(l1) + "건. _guarded_append_atlas() 경유 (// @allow-atlas-direct)"
    }
    // L2: shell redirect
    let l2 = _to_int0(_str(exec("grep -nE '(>>|>)[[:space:]]*[\"'\\'']?[^[:space:]\"'\\'']*atlas\\.n6' '" + full + "' 2>/dev/null | grep -v '@allow-atlas-direct' | wc -l")).trim())
    if l2 > 0 {
        return "ATLAS-GUARD-L2|error|atlas.n6 shell redirect " + to_string(l2) + "건 (// @allow-atlas-direct)"
    }
    // L3: echo/cat/printf → atlas.n6 한 줄 내 조합
    let l3 = _to_int0(_str(exec("grep -nE '(echo|cat|printf)[^|]*atlas\\.n6' '" + full + "' 2>/dev/null | grep -E '>>|>' | grep -v '@allow-atlas-direct' | wc -l")).trim())
    if l3 > 0 {
        return "ATLAS-GUARD-L3|error|atlas.n6 간접 shell 편집 " + to_string(l3) + "건 (// @allow-atlas-direct)"
    }
    return ""
}

// ─── AN2 (anima 전용) localStorage/sessionStorage 금지 — MemoryStore SQLite 전용 ───
fn check_an2(path: string) -> string {
    if _project_name() != "anima" { return "" }
    let e = ext_of(path)
    if e != ".ts" && e != ".tsx" && e != ".js" && e != ".jsx" && e != ".hexa" { return "" }
    // 하네스/archive 예외
    if path.starts_with("shared/harness/") { return "" }
    if path.starts_with("archive/") { return "" }
    let full = REPO_ROOT + "/" + path
    let cmd = "grep -nE '\\b(localStorage|sessionStorage)\\b' '" + full + "' 2>/dev/null | grep -v '@allow-webstorage' | wc -l"
    let hits = _to_int0(_str(exec(cmd)).trim())
    if hits > 0 {
        return "AN2|error|localStorage/sessionStorage " + to_string(hits) + "건 — MemoryStore(SQLite) 전용 (// @allow-webstorage)"
    }
    return ""
}

// ─── AN-LOG: anima 학습 진입점 파일 감지 ───
// scope: training/**/*.{py,hexa} OR core/train_*.{py,hexa} OR core/training/**/*.{py,hexa}
//        OR basename train_*|trainer_*|*_trainer.*
// 예외: archive/, tests/, fixtures/, // @allow-no-log
fn _an_log_in_scope(path: string) -> bool {
    if _project_name() != "anima" { return false }
    let e = ext_of(path)
    if e != ".py" && e != ".hexa" { return false }
    if path.starts_with("archive/") { return false }
    if path.index_of("/_archive/") >= 0 { return false }
    if path.index_of("/archive/") >= 0 { return false }
    if path.index_of("/tests/") >= 0 { return false }
    if path.starts_with("tests/") { return false }
    if path.index_of("/fixtures/") >= 0 { return false }
    if path.starts_with("fixtures/") { return false }
    if path.starts_with("shared/harness/") { return false }
    let bn = basename_of(path)
    // 디렉터리 패턴
    if path.starts_with("training/") { return true }
    if path.starts_with("core/training/") { return true }
    // basename 패턴: train_*, trainer_*, *_trainer.*
    if bn.starts_with("train_") { return true }
    if bn.starts_with("trainer_") { return true }
    // *_trainer.<ext>
    let dot = _rfind(bn, ".")
    if dot > 0 {
        let stem = bn.substring(0, dot)
        let st_len = len(stem)
        if st_len >= 8 {
            let suf = stem.substring(st_len - 8, st_len)
            if suf == "_trainer" { return true }
        }
    }
    return false
}

fn _an_log_exempt(full: string) -> bool {
    let m = _to_int0(_str(exec("grep -c '@allow-no-log' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return true }
    return false
}

// ─── AN-LOG-2 — 학습 루프 안 주기 출력 (% N == 0 + log) ───
fn check_an_log_2(path: string) -> string {
    if !_an_log_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _an_log_exempt(full) { return "" }
    let bn = basename_of(path)
    // 단순화: 파일에 % [0-9]+ == 0 패턴 ≥1 AND 로깅 호출 ≥1
    let mod_cnt = _to_int0(_str(exec("grep -cE '%[[:space:]]*[0-9]+[[:space:]]*==[[:space:]]*0' '" + full + "' 2>/dev/null || echo 0")).trim())
    let log_cnt = _to_int0(_str(exec("grep -cE '\\b(print|logger|wandb|tb|tensorboard|writer\\.add)\\b' '" + full + "' 2>/dev/null || echo 0")).trim())
    if mod_cnt >= 1 && log_cnt >= 1 { return "" }
    return "AN-LOG-2|error|학습 파일 '" + bn + "' 에 주기 출력 (% N == 0 + log) 패턴 없음 (// @allow-no-log)"
}

// ─── AN-LOG-3 — 필수 메트릭 키워드 (loss / step|epoch / throughput) ───
fn check_an_log_3(path: string) -> string {
    if !_an_log_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _an_log_exempt(full) { return "" }
    let bn = basename_of(path)
    let l = _to_int0(_str(exec("grep -ciE '\\bloss\\b' '" + full + "' 2>/dev/null || echo 0")).trim())
    let s = _to_int0(_str(exec("grep -ciE '\\b(step|epoch)\\b' '" + full + "' 2>/dev/null || echo 0")).trim())
    let t = _to_int0(_str(exec("grep -ciE '\\b(throughput|tps|samples/sec|samples_per_sec)\\b' '" + full + "' 2>/dev/null || echo 0")).trim())
    if l >= 1 && s >= 1 && t >= 1 { return "" }
    return "AN-LOG-3|error|학습 파일 '" + bn + "' 필수 메트릭 누락 (loss/step/throughput) (// @allow-no-log)"
}

// ─── AN-LOG-4 — 시작 metadata dump (model_size/batch_size/lr) ≥3 + log 동반 ───
fn check_an_log_4(path: string) -> string {
    if !_an_log_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _an_log_exempt(full) { return "" }
    let bn = basename_of(path)
    let meta = _to_int0(_str(exec("grep -cE '\\b(model_size|batch_size|lr|learning_rate)\\b' '" + full + "' 2>/dev/null || echo 0")).trim())
    if meta < 3 {
        return "AN-LOG-4|error|학습 파일 '" + bn + "' 시작 metadata (model_size/batch_size/lr) 누락 (// @allow-no-log)"
    }
    // 로깅 호출 동반 — 단순화: 파일 어딘가에 print/logger 호출 존재
    let log_cnt = _to_int0(_str(exec("grep -cE '\\b(print|logger|wandb|tb|tensorboard|writer\\.add)\\b' '" + full + "' 2>/dev/null || echo 0")).trim())
    if log_cnt < 1 {
        return "AN-LOG-4|error|학습 파일 '" + bn + "' 시작 metadata (model_size/batch_size/lr) 누락 (// @allow-no-log)"
    }
    return ""
}

// ─── AN-LOG-5 — 종료/체크포인트 final report (best_loss/total_steps/wall_time) ≥2 ───
fn check_an_log_5(path: string) -> string {
    if !_an_log_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _an_log_exempt(full) { return "" }
    let bn = basename_of(path)
    let cnt = _to_int0(_str(exec("grep -cE '\\b(best_loss|total_steps|wall_time|elapsed|final_)\\w*' '" + full + "' 2>/dev/null || echo 0")).trim())
    if cnt < 2 {
        return "AN-LOG-5|error|학습 파일 '" + bn + "' 종료 final report (best_loss/total_steps/wall_time) 누락 (// @allow-no-log)"
    }
    return ""
}

// ─── AN-LOG-7 — 로그 SSOT 경로 (anima/logs/training/ 또는 logs/training/ 또는 LOG_DIR=) ───
fn check_an_log_7(path: string) -> string {
    if !_an_log_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _an_log_exempt(full) { return "" }
    let bn = basename_of(path)
    // 임의 경로 직접 사용 차단
    let bad = _to_int0(_str(exec("grep -cE '\"(/tmp/log|\\./out|\\./training_log|/var/log/train|~/log)' '" + full + "' 2>/dev/null || echo 0")).trim())
    let good = _to_int0(_str(exec("grep -cE '(anima/logs/training/|logs/training/|LOG_DIR[[:space:]]*=)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if bad > 0 && good == 0 {
        return "AN-LOG-7|error|학습 파일 '" + bn + "' 로그 경로가 SSOT (anima/logs/training/) 아님 (// @allow-no-log)"
    }
    // 파일에 로그 출력 패턴 (open(.*log/ , logging.FileHandler 등) 있는데 SSOT 키워드 없으면
    let log_open = _to_int0(_str(exec("grep -cE '(open\\([^)]*log|FileHandler\\(|to_csv\\(|json\\.dump.*log)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if log_open >= 1 && good == 0 {
        return "AN-LOG-7|error|학습 파일 '" + bn + "' 로그 경로가 SSOT (anima/logs/training/) 아님 (// @allow-no-log)"
    }
    return ""
}

fn check_hx4(path: string) -> string {
    if _project_name() != "hexa-lang" { return "" }
    if _hx4_is_exempt(path) { return "" }
    let v1 = _hx4_l1_ext(path)
    if v1 != "" { return v1 }
    let v2 = _hx4_l2_toolchain(path)
    if v2 != "" { return v2 }
    let v3 = _hx4_l3_runtime(path)
    if v3 != "" { return v3 }
    let v4 = _hx4_l4_docs(path)
    if v4 != "" { return v4 }
    let v5 = _hx4_l5_tests(path)
    if v5 != "" { return v5 }
    let v6 = _hx4_l6_ci(path)
    if v6 != "" { return v6 }
    let v7 = _hx4_l7_build_chain(path)
    if v7 != "" { return v7 }
    let v8 = _hx4_l8_meta(path)
    if v8 != "" { return v8 }
    return ""
}

// ─── Check R19: SILENT EXIT 금지 — exit(1) 전 stderr 출력 필수 + catch 로그 필수 ───
// 탐지 2종:
//   (1) exit(1) 직전 5줄에 println/eprintln/>&2/stderr 없음
//   (2) catch 블록 body 에 print/e.* 참조 없음 (silent swallow)
// 예외: 라인 주석 // @allow-silent-exit 또는 // @allow-silent-catch
fn check_silent_exit(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" && e != ".py" && e != ".ts" && e != ".js" { return "" }
    // 하네스 자신은 exec 폴백 의도적 silent — 스킵
    if path.starts_with("shared/harness/") { return "" }
    let full = REPO_ROOT + "/" + path
    // (1) exit(1) silent
    let awk1 = "awk '/exit[[:space:]]*\\([[:space:]]*1[[:space:]]*\\)/ && $0 !~ /@allow-silent-exit/ { has=0; for(i=NR-5;i<NR;i++){if(lines[i] ~ /println|eprintln|>&2|stderr|fprintf[[:space:]]*\\(stderr/) has=1}; if(!has) c++ } { lines[NR]=$0 } END{print c+0}'"
    let silent_exits = _to_int0(_str(exec(awk1 + " '" + full + "' 2>/dev/null || echo 0")).trim())
    // (2) silent catch — block 안에 print 또는 error var 참조 없음
    let awk2 = "awk '/catch[[:space:]]+[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*\\{/ && $0 !~ /@allow-silent-catch/ { start=NR; depth=0; buf=\"\"; for(i=1;i<=length($0);i++){c=substr($0,i,1); if(c==\"{\")depth++; else if(c==\"}\")depth--}; buf=$0; if(depth==0){ if(buf !~ /println|eprintln|>&2|stderr/) n++ ; next } in_b=1; next } in_b { buf=buf $0; for(i=1;i<=length($0);i++){c=substr($0,i,1); if(c==\"{\")depth++; else if(c==\"}\")depth--}; if(depth==0){ if(buf !~ /println|eprintln|>&2|stderr/) n++; in_b=0 } } END{print n+0}'"
    let silent_catches = _to_int0(_str(exec(awk2 + " '" + full + "' 2>/dev/null || echo 0")).trim())
    let total = silent_exits + silent_catches
    if total == 0 { return "" }
    return "R19|error|SILENT EXIT — exit(1) 앞 stderr 없음 " + to_string(silent_exits) + "건 + silent catch " + to_string(silent_catches) + "건 (// @allow-silent-exit/catch 로 예외)"
}

// ─── Check 9: harness 수정 가드 — commit 메시지 승인 마커 필수 ───
// shared/harness/ 아래 .hexa/.json/.jsonl/.md 수정 시 commit 메시지에
//   "(harness):" prefix 또는 "harness-approved" 포함 필요.
// 로그 파일 (*_log.jsonl, mistakes/proposals/usage/cooldown) 은 예외.
fn _is_harness_log(path: string) -> bool {
    if path.index_of("_log.jsonl") >= 0 { return true }
    if path == "shared/harness/mistakes.jsonl" { return true }
    if path == "shared/harness/autofix_proposals.jsonl" { return true }
    if path == "shared/harness/rules_usage.jsonl" { return true }
    if path == "shared/harness/.gc_weekly_cooldown" { return true }
    return false
}

fn check_harness_modification(path: string) -> string {
    if !path.starts_with("shared/harness/") { return "" }
    if _is_harness_log(path) { return "" }
    // msg_check 는 commit.hexa msg_check (commit-msg 훅) 최종 검증
    // pre-commit 단계 COMMIT_EDITMSG 는 N-1 메시지라 구조적 오탐 원인 — warn-only 로 완화
    return "HARNESS-LOCK|warn|staged shared/harness/ — commit msg '(harness):' prefix 또는 'harness-approved' 필요 (commit-msg 단계 최종 검증)"
}

// ─── Check 8 (공통): 홈 디렉토리 절대경로 하드코딩 금지 (error) ───
// 원칙: /Users/<u>/, /home/<u>/, /root/ 리터럴 금지. env("HOME") 또는 $HOME 사용.
// 시스템 경로 /usr /opt /bin /sbin /tmp /dev /var 는 허용.
// 예외: .md 문서, archive/, harness 자신, append-only 로그 파일, // @allow-abspath (라인 단위)
fn check_hardcoded_path(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" && e != ".json" && e != ".jsonl" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    // harness 자신 스킵 (메타 grep 사용)
    if path == "shared/harness/lint.hexa" { return "" }
    if path == "shared/harness/shared_survey.json" { return "" }
    // append-only 로그 기록물 — 과거 절대경로 유지
    let bn = basename_of(path)
    if bn == "mistakes.jsonl" || bn == "lint_log.jsonl" || bn == "gc_log.jsonl" { return "" }
    if bn == "rules_usage.jsonl" || bn == "autofix_proposals.jsonl" || bn == "cleanup_log.jsonl" { return "" }
    // hexa 바이너리 resolver 부트스트랩 (hexa 찾기 전 실행)
    if path.index_of("shared/scripts/bin/hexa") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    // 리터럴: /Users/<name>/, /home/<name>/, /root/ (따옴표·공백 경계 뒤)
    // 주의: /usr/, /opt/, /bin/, /sbin/, /tmp/, /dev/, /var/ 는 시스템 경로 허용
    let cmd = "grep -nE '[\"'\\'' ](/(Users|home|root)/[A-Za-z0-9_.-]+/)' '" + full + "' 2>/dev/null | grep -v '@allow-abspath' | wc -l"
    let hit = _to_int0(_str(exec(cmd)).trim())
    if hit > 0 {
        return "ABSPATH|error|홈 디렉토리 절대경로 하드코딩 " + to_string(hit) + "건 — env(\"HOME\") 또는 $HOME 사용 (// @allow-abspath)"
    }
    return ""
}

// ─── Check 8a (opt-in + auto-suggest): launchd sandbox enforce (warn) ───
// 원칙: `// @enforce-sandbox` 마커가 있는 .hexa 는 반드시 ensure_launchd_sandbox() 호출.
//        마커 없는 harness entry 도 (hook-excluded 아니면) 추가 제안.
// Why:  raw hexa = jetsam=180 (Terminal 동급) → OOM 시 Terminal 동반 사망.
//        shim(1st) + enforce(2nd) + 이 lint(3rd-line, PR 시점).
// 2 모드:
//   (a) 마커 있음 + ensure 호출 없음        → H-ENFORCE-SANDBOX (compliance)
//   (b) 마커 없음 + entry + non-hook-path   → H-ENFORCE-SANDBOX-SUGGEST (자동 제안)
// hook-excluded: commit/post_edit/cross_feed/broadcast (자주 호출 — wrap 지연 전역 영향)
// self-excluded: lint/autofix/gc*/safe_hexa_*/bitter-gate/triage
// 우회: // @no-sandbox
fn check_enforce_sandbox(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    let full = REPO_ROOT + "/" + path
    let has_marker = _to_int0(_str(exec("grep -c '@enforce-sandbox' '" + full + "' 2>/dev/null")).trim())
    let ensured = _to_int0(_str(exec("grep -c 'ensure_launchd_sandbox()' '" + full + "' 2>/dev/null")).trim())

    // (a) compliance check: 마커 있음 + 호출 없음
    if has_marker > 0 && ensured == 0 {
        return "H-ENFORCE-SANDBOX|warn|@enforce-sandbox 마커 있으나 ensure_launchd_sandbox() 호출 없음 — import safe_hexa_enforce.hexa + main() 최상단 호출"
    }
    if has_marker > 0 { return "" }

    // (b) auto-suggest: 마커 없음 → 후보 판정
    if path.starts_with("shared/harness/") == false { return "" }
    // 직속만 (subdir 제외)
    let sub = path.substring(15, path.len())
    if sub.index_of("/") >= 0 { return "" }
    // self-excluded
    if path == "shared/harness/lint.hexa" { return "" }
    if path == "shared/harness/autofix.hexa" { return "" }
    if path == "shared/harness/gc.hexa" { return "" }
    if path == "shared/harness/gc-weekly.hexa" { return "" }
    if path == "shared/harness/safe_hexa_enforce.hexa" { return "" }
    if path == "shared/harness/safe_hexa_check.hexa" { return "" }
    if path == "shared/harness/bitter-gate.hexa" { return "" }
    if path == "shared/harness/triage.hexa" { return "" }
    // hook-excluded (wrap 지연 피해)
    if path == "shared/harness/commit.hexa" { return "" }
    if path == "shared/harness/post_edit.hexa" { return "" }
    if path == "shared/harness/cross_feed.hexa" { return "" }
    if path == "shared/harness/broadcast.hexa" { return "" }
    // @no-sandbox 우회
    let bypass = _to_int0(_str(exec("grep -c '@no-sandbox' '" + full + "' 2>/dev/null")).trim())
    if bypass > 0 { return "" }
    // entry 판정 (fn main + main())
    let has_fn = _to_int0(_str(exec("grep -cE '^fn main\\(\\)' '" + full + "' 2>/dev/null")).trim())
    if has_fn == 0 { return "" }
    let has_call = _to_int0(_str(exec("grep -cE '^main\\(\\)[[:space:]]*$' '" + full + "' 2>/dev/null")).trim())
    if has_call == 0 { return "" }
    return "H-ENFORCE-SANDBOX-SUGGEST|warn|하네스 entry — // @enforce-sandbox 마커 추가 고려 (jetsam=40 보호). 불필요 시 // @no-sandbox"
}

// ─── Check 8b (공통): hardcoded dev path 금지 (warn) ───
// 원칙: ~/Dev/<proj>/, /Users/<u>/Dev/<proj>/, /home/<u>/Dev/<proj>/, $HOME/Dev/<proj>/ 리터럴 금지.
//        프로젝트 변수 사용: $NEXUS / $ANIMA / $HEXA_LANG / $N6_ARCH / $AIRGENOME / $VOID / $PAPERS
//        (~/.zshrc 정의, hexa 자식 프로세스에 환경 상속됨)
// 적용: .json / .jsonl / .md / .hexa / .sh (데이터/문서/코드 string literal).
//        .hexa 코드의 `env("HOME") + "/Dev/<proj>"` 패턴도 string literal "/Dev/<proj>" 로 검출됨.
// Why: 사용자 지시 2026-04-14 — 데이터/문서/코드 모두 ~/Dev/ 노출 회피, 프로젝트 변수 강제.
// 예외: archive/, lint.hexa 자신, append-only 로그, // @allow-devpath, .zshrc 정의 라인
fn check_devpath(path: string) -> string {
    let e = ext_of(path)
    if e != ".json" && e != ".jsonl" && e != ".md" && e != ".hexa" && e != ".sh" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    if path.index_of("/archive/") >= 0 { return "" }
    if path == "shared/harness/lint.hexa" { return "" }
    // Claude Code SSOT settings require literal paths (additionalDirectories/Bash pattern/hook cmd 등)
    if path == ".claude/settings.json" || path == ".claude/settings.local.json" { return "" }
    if path.starts_with(".claude/hooks/") { return "" }
    let bn = basename_of(path)
    if bn == "mistakes.jsonl" || bn == "lint_log.jsonl" || bn == "gc_log.jsonl" { return "" }
    if bn == "rules_usage.jsonl" || bn == "autofix_proposals.jsonl" || bn == "cleanup_log.jsonl" { return "" }
    if bn == "lockdown_log.jsonl" || bn == "errors.jsonl" || bn == "sync_log.jsonl" { return "" }
    if bn == "hexa_pitfalls_log.jsonl" || bn == "porting_log.jsonl" { return "" }
    if bn == "topology_mk2.jsonl" || bn == "pitfalls.jsonl" { return "" }
    if bn == "work_registry.jsonl" || bn == "genomes.index.jsonl" { return "" }
    let full = REPO_ROOT + "/" + path
    // 검출: (~|$HOME|${HOME}|/Users/<u>|/home/<u>)/Dev/(화이트리스트 프로젝트)
    //   .hexa 코드의 `"/Dev/nexus/"` string literal 도 /Dev/nexus 로 잡힘
    let cmd = "grep -nE '(~|/Users/[A-Za-z0-9_.-]+|/home/[A-Za-z0-9_.-]+|\\$HOME|\\$\\{HOME\\})/Dev/(nexus|anima|hexa-lang|n6-architecture|airgenome|void|papers)' '" + full + "' 2>/dev/null | grep -v '@allow-devpath' | wc -l"
    let hit = _to_int0(_str(exec(cmd)).trim())
    if hit > 0 {
        return "H-DEVPATH|warn|hardcoded dev path " + to_string(hit) + "건 — $NEXUS / $ANIMA / $HEXA_LANG / $N6_ARCH / $AIRGENOME / $VOID / $PAPERS 변수 사용 (// @allow-devpath)"
    }
    return ""
}

// ─── Check 7: AI-native — .hexa 알고리즘 함정 ───
// 메타 사용 (grep/exec 내부 문자열) 제외 — 자기 자신 false positive 방지
fn check_hexa_algorithm(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    // lint/autofix/gc/bitter-gate/gc-weekly 자신은 스킵 — 메타 grep 사용함
    if path == "shared/harness/lint.hexa" { return "" }
    if path == "shared/harness/autofix.hexa" { return "" }
    if path == "shared/harness/gc.hexa" { return "" }
    if path == "shared/harness/gc-weekly.hexa" { return "" }
    if path == "shared/harness/bitter-gate.hexa" { return "" }
    if path == "shared/harness/triage.hexa" { return "" }
    let full = REPO_ROOT + "/" + path
    // 코멘트(//) 제거 후 grep 하도록 sed 전처리 + grep/exec 메타 라인 제외
    let sed_clean = "sed 's|//.*||' '" + full + "' | grep -v 'grep ' | grep -v 'exec('"
    // R0 위반: `xs.push(` 앞에 `=` 없으면 silent no-op
    let noop_push = _to_int0(_str(exec(sed_clean + " | grep -nE '^[[:space:]]+[a-z_][a-zA-Z0-9_]*\\.push\\(' | wc -l")).trim())
    if noop_push > 0 {
        return "HEXA-ALGO|error|R0 pass-by-value — xs.push(v) " + to_string(noop_push) + "건 silent no-op (xs = xs.push(v) 패턴)"
    }
    let lio = _to_int0(_str(exec(sed_clean + " | grep -c '\\.last_index_of('")).trim())
    if lio > 0 {
        return "HEXA-ALGO|error|.last_index_of() 미지원 — _rfind(s, ch) 수동 구현 사용"
    }
    let ac = _to_int0(_str(exec(sed_clean + " | grep -c 'args()'")).trim())
    if ac > 0 {
        // 면제: 같은 파일 내 argv.len() / a.len() / args.len() / `< N` 가드 존재 시 args() 사용 정상
        // 주의: 'guard' 는 hexa 예약어 — _len_guard 사용
        let _len_guard = _to_int0(_str(exec("grep -cE '(argv|args|a)\\.len\\(\\)|< *[0-9]+' '" + full + "' 2>/dev/null || echo 0")).trim())
        if _len_guard == 0 {
            return "HEXA-ALGO|warn|args() 빈 배열 반환 — env var 또는 기본 모드 사용 권장"
        }
    }
    return ""
}

// ─── H9: hook stdin round-trip contract (one-shot gate) ───
// 원칙: 어떤 hook 이 commit 에 포함되어 있는데 `hexa` 래퍼가 stdin 을
//   자식 stage0 까지 전달하지 못하면(systemMessage 사일런트) 커밋 차단.
// 배경: hexa-lang self/main.hexa cmd_run 의 `( stage0 ) &` background
//   서브셸은 POSIX asynchronous_list 규칙상 자식 stdin 을 /dev/null 로
//   재지정 → Claude Code UserPromptSubmit hook 전체 조용한 실패.
//   fix: exec 3<&0; ... <&3 (rt 35).
// 동작: hook 파일이 없으면 무비용 스킵. 있으면 SSOT gate 위임.
// SSOT: shared/harness/hook_stdin_gate.hexa (probe 로직 단일 소스)
fn check_h9_hook_stdin_gate(all_files: string) -> string {
    let mut has_hook = false
    let paths = all_files.split("\n")
    for p in paths {
        let ps = _str(p).trim()
        if ps == "" { continue }
        if ps.index_of("/hooks/") >= 0 && ps.ends_with(".hexa") {
            has_hook = true
        }
    }
    if !has_hook { return "" }

    // delegate to hook_stdin_gate.hexa — probe + mistakes.jsonl + stderr 는 거기서 처리
    // popen("r") 은 stdout 만 캡처하므로 gate 의 stderr(eprintln) 는 lint 의 stderr
    // 로 자연스럽게 전달 → pre-commit 이 사용자 터미널에 HOOK-STDIN-GATE FAIL 표시.
    let gate = HOME + "/Dev/nexus/shared/harness/hook_stdin_gate.hexa"
    let raw = _str(exec("hexa '" + gate + "' >/dev/null; echo __RC=$?")).trim()
    let mark = "__RC="
    let idx = raw.index_of(mark)
    if idx < 0 { return "" }
    let rc = raw.substring(idx + 5, len(raw)).trim()
    if rc == "0" { return "" }
    return "H9|error|hook_stdin_gate FAIL (rc=" + rc + ") — hexa read_stdin() 회귀. 상단 HOOK-STDIN-GATE 메시지 + shared/harness/mistakes.jsonl 참조"
}

// ─── V-PARSE (공통, verify) — L0 .hexa 파일 Parse error 0건 검증 ───
// SSOT: shared/lockdown/lockdown.json → projects.{cwd_basename}.L0[].path
// 대상: L0 경로 중 `.hexa` 로 끝나는 파일만 (디렉토리/JSON/MD 제외)
// 동작: 각 파일에 대해 `~/Dev/hexa-lang/hexa <abs> 2>&1 < /dev/null | grep -c 'Parse error'`
//       결과 0 → PASS, ≥1 → FAIL
// 이유: 파일 존재만으로 L0 자격 유지되면 dead code 진입. 파싱 가능성 = L0 최소 조건.
// 비용: 모든 L0 .hexa 파일에 hexa 런타임 1회 spawn. 현재 nexus 27건 → ~수초.
//       per-file 검사가 아닌 session-level one-shot (H9 패턴)으로 비용 제한.
// 트리거: mode=all 항상 / staged에 L0 .hexa 포함 시 / file 모드에서 target 이 L0 .hexa 일 때.
// 이식원본: shared/harness/l0_guard.hexa §4 (line 194~227, 과거 shared/lockdown 이동 전) — 해당 섹션은 lockdown_gate 신설 시 제거.
// 예외: L0G_LOCKDIR 등 mkdir 잠금 없음 (lint 자체가 빈번 실행이므로 유저에게 즉시 시각 피드백 필요).

fn _vparse_l0_hexa_paths(project: string) -> string {
    let LOCKDOWN = REPO_ROOT + "/shared/lockdown/lockdown.json"
    if !file_exists(LOCKDOWN) { return "" }
    // awk 로 projects.<project>.L0 블록 내 "path":"*.hexa" 만 추출. L1 진입 시 종료.
    // R22 회피: bare interpreter 없음. R33/H-GRC 회피: `|| echo 0` 없음.
    let cmd = "awk '/\"projects\"[[:space:]]*:/,0' '" + LOCKDOWN + "' | awk '/\"" + project + "\"[[:space:]]*:/{p=1} p && /\"L0\"[[:space:]]*:/{l=1} l && /\"path\"[[:space:]]*:/{gsub(/^[^\"]*\"path\"[[:space:]]*:[[:space:]]*\"/,\"\"); gsub(/\".*$/,\"\"); print} l && /\"L1\"[[:space:]]*:/{exit}' | awk '/\\.hexa$/'"
    return _str(exec(cmd)).trim()
}

// 단일 L0 .hexa 파일 parse 검사. 반환: (rel_path, pe_count) — pe>0 이면 실패.
// `// @allow-parse-fail` 마커가 파일 앞쪽(head 5줄)에 있으면 PASS 로 처리 (archive/폐기 경로).
fn _vparse_one(rel: string) -> string {
    let abs = REPO_ROOT + "/" + rel
    if !file_exists(abs) { return rel + "|MISSING" }
    // Self-skip: harness/ 자체는 V-PARSE 검사 제외 (lint engine 이 자기 자신을 exec → 재귀 fan-out 방지).
    // 과거 사고: 2026-04-14 lint.hexa 가 L0 리스트 내 자기 자신에 대해 `hexa <abs>` 호출 → 자식 lint.hexa 가 또
    // check_v_parse 실행 → 트리 fan-out → 12분+ 블로킹 (H-COMMIT NEXUS_COMMIT_OK=1 bypass 강제).
    // 하네스 파일 자체 검증은 별도 경로(`hexa parse shared/harness/*.hexa` 수동, 또는 @allow-parse-fail 마커)로.
    if rel.starts_with("shared/harness/") { return rel + "|0" }
    // shared/hooks/ → archive/hooks-20260414/ symlink (deprecated 2026-04-14, H-NOHOOK).
    // archive/superseded-/, archive/deprecated_/ 도 격리 — V-PARSE 검사 의미 없음 (archaeological).
    if rel.starts_with("shared/hooks/") { return rel + "|0" }
    if rel.contains("/archive/") { return rel + "|0" }
    if rel.contains("/superseded-") { return rel + "|0" }
    if rel.contains("/deprecated_") { return rel + "|0" }
    let head5 = _str(exec("head -5 '" + abs + "' 2>/dev/null"))
    if head5.contains("@allow-parse-fail") { return rel + "|0" }
    let HEXA = HOME + "/Dev/hexa-lang/hexa"
    // V-PARSE: `hexa parse` 서브커맨드 사용 — parse-only, no exec. 0.09s/file (lint.hexa 183KB 기준).
    // 과거 사고: `hexa <file>` (subcommand 없음) 은 인터프리터가 파일을 실행 → lint.hexa 자기재귀 fan-out.
    // `hexa parse` 는 codegen 도 안 하고 파서만 돌므로 재귀 vector 원천 차단.
    // 5s alarm 은 자식 hexa 가 parse-only 라도 혹시 모를 파서 무한루프 대비 (belt-and-suspenders).
    // `grep -c 'Parse error'` — _to_int0 로 첫 줄만 파싱 (안전)
    let pe_raw = _str(exec("perl -e 'alarm 5; exec @ARGV' '" + HEXA + "' parse '" + abs + "' 2>&1 < /dev/null | awk '/Parse error/{c++} END{print c+0}'")).trim()
    let pe = _to_int0(pe_raw)
    return rel + "|" + to_string(pe)
}

// staged/file 리스트에 L0 .hexa 경로가 하나라도 포함되면 true
fn _vparse_should_trigger(files_raw: string, mode: string, l0_list: string) -> bool {
    if mode == "all" { return true }
    if l0_list == "" { return false }
    let l0_lines = l0_list.split("\n")
    let files = files_raw.split("\n")
    for f in files {
        let fp = _str(f).trim()
        if fp == "" { continue }
        for lp in l0_lines {
            let lps = _str(lp).trim()
            if lps == "" { continue }
            if fp == lps { return true }
        }
    }
    return false
}

// V-PARSE gate — 성공 시 "", 실패 시 aggregate 메시지 + 각 실패건 violations 에 push
fn check_v_parse(files_raw: string, mode: string) -> string {
    let project = _project_name()
    if project == "" { return "" }
    let LOCKDOWN = REPO_ROOT + "/shared/lockdown/lockdown.json"
    if !file_exists(LOCKDOWN) { return "" }
    let l0_list = _vparse_l0_hexa_paths(project)
    if l0_list == "" { return "" }
    if !_vparse_should_trigger(files_raw, mode, l0_list) { return "" }

    let lines = l0_list.split("\n")
    let mut fail = 0
    let mut pass = 0
    let mut detail = ""
    for ln in lines {
        let rel = _str(ln).trim()
        if rel == "" { continue }
        let r = _vparse_one(rel)
        let parts = r.split("|")
        if len(parts) < 2 { continue }
        let rp = _str(parts[0])
        let cnt_s = _str(parts[1])
        if cnt_s == "MISSING" { continue }
        let cnt = _to_int0(cnt_s)
        if cnt == 0 {
            pass = pass + 1
        } else {
            fail = fail + 1
            if detail != "" { detail = detail + " / " }
            detail = detail + rp + "(" + to_string(cnt) + ")"
        }
    }
    if fail == 0 { return "" }
    return "V-PARSE|error|L0 .hexa 파싱 실패 " + to_string(fail) + "건 / " + to_string(pass) + " PASS — " + detail + " — `hexa <path>` 로 로컬 재현 후 수정 (// @allow-parse-fail)"
}

// ─── 3-project autonomous growth surveillance checkers (7종) ───
// nexus/n6-architecture/anima 통합 자율 성장 감시 — blowup.hexa + atlas.n6 지속 창발/성능/자원
// baseline/feed 파일 미존재 시 silent pass (MVP 안전장치)

// JSON 값 추출: '"key":<digits>' 패턴에서 정수 추출. 미존재 시 -1 반환.
// key 는 따옴표 없이 전달 (예: "nodes"), 문자열값은 "\"key\":\"val\"" 형태라 별도 함수 필요.
fn _grab_json_int(content: string, key: string) -> i64 {
    if content == "" { return -1 }
    let needle = "\"" + key + "\""
    let k = content.index_of(needle)
    if k < 0 { return -1 }
    // key 뒤 ':' 위치 찾기
    let after_key = k + len(needle)
    let rest = content.substring(after_key, len(content))
    let colon = rest.index_of(":")
    if colon < 0 { return -1 }
    // 숫자 시작 위치 — colon 뒤 whitespace 스킵
    let mut pos = colon + 1
    while pos < len(rest) {
        let ch = rest.substring(pos, pos + 1)
        if ch == " " || ch == "\t" || ch == "\n" { pos = pos + 1 }
        else { break }
    }
    // 숫자/음수 끝까지
    let mut end = pos
    while end < len(rest) {
        let ch = rest.substring(end, end + 1)
        if ch == "-" || (ch >= "0" && ch <= "9") { end = end + 1 }
        else { break }
    }
    if end == pos { return -1 }
    let num_s = rest.substring(pos, end)
    if num_s == "" || num_s == "-" { return -1 }
    return _to_int0(num_s)
}

// ── Check: H-EMERGE-COMMIT — atlas 3 commit 연속 무성장 ──
fn check_emerge_commit(path: string) -> string {
    let e = ext_of(path)
    let is_atlas = path.index_of("/shared/n6/atlas.n6") >= 0 || path.ends_with("shared/n6/atlas.n6")
    if !is_atlas && e != ".hexa" { return "" }
    let bl_path = NEXUS_HARNESS + "/emerge_baseline.json"
    let stats_path = REPO_ROOT + "/shared/n6/atlas.n6.stats"
    if !file_exists(bl_path) { return "" }
    if !file_exists(stats_path) { return "" }
    let mut bl = ""
    try { bl = read_file(bl_path) } catch e {}
    if bl == "" { return "" }
    let mut stats = ""
    try { stats = read_file(stats_path) } catch e {}
    if stats == "" { return "" }
    let last_nodes = _grab_json_int(bl, "last_nodes")
    let last_edges = _grab_json_int(bl, "last_edges")
    let last_hubs = _grab_json_int(bl, "last_hubs")
    let stale = _grab_json_int(bl, "consecutive_stale")
    if last_nodes < 0 || stale < 0 { return "" }
    let cur_nodes = _grab_json_int(stats, "nodes")
    let cur_edges = _grab_json_int(stats, "edges")
    let cur_hubs = _grab_json_int(stats, "hubs")
    if cur_nodes < 0 { return "" }
    if cur_nodes == last_nodes && cur_edges == last_edges && cur_hubs == last_hubs && stale >= 3 {
        return "H-EMERGE-COMMIT|warn|H-EMERGE-COMMIT: atlas " + to_string(stale) + " commit 연속 무성장 (nodes=" + to_string(cur_nodes) + ")"
    }
    return ""
}

// ── Check: H-NOREGRESS — atlas 역행 차단 (NEXUS_GC_OK=1 우회) ──
fn check_no_regress(path: string) -> string {
    let is_atlas = path.index_of("/shared/n6/atlas.n6") >= 0 || path.ends_with("shared/n6/atlas.n6")
    if !is_atlas { return "" }
    if path.ends_with(".stats") || path.ends_with(".deg") { return "" }
    let bl_path = NEXUS_HARNESS + "/emerge_baseline.json"
    let stats_path = REPO_ROOT + "/shared/n6/atlas.n6.stats"
    if !file_exists(bl_path) { return "" }
    if !file_exists(stats_path) { return "" }
    if env("NEXUS_GC_OK") == "1" { return "" }
    let mut bl = ""
    try { bl = read_file(bl_path) } catch e {}
    if bl == "" { return "" }
    let mut stats = ""
    try { stats = read_file(stats_path) } catch e {}
    if stats == "" { return "" }
    let last_nodes = _grab_json_int(bl, "last_nodes")
    let last_edges = _grab_json_int(bl, "last_edges")
    let cur_nodes = _grab_json_int(stats, "nodes")
    let cur_edges = _grab_json_int(stats, "edges")
    if last_nodes < 0 || cur_nodes < 0 { return "" }
    if cur_nodes < last_nodes {
        return "H-NOREGRESS|error|H-NOREGRESS: atlas 역행 nodes " + to_string(last_nodes) + "→" + to_string(cur_nodes) + " (NEXUS_GC_OK=1 우회)"
    }
    if last_edges >= 0 && cur_edges >= 0 && cur_edges < last_edges {
        return "H-NOREGRESS|error|H-NOREGRESS: atlas 역행 edges " + to_string(last_edges) + "→" + to_string(cur_edges) + " (NEXUS_GC_OK=1 우회)"
    }
    return ""
}

// ── Check: H-PERF-BASELINE — blowup 성능 회귀 (1.2x baseline) ──
fn check_perf_baseline(path: string) -> string {
    let is_blowup_core = path.index_of("/shared/blowup/core/blowup.hexa") >= 0 || path.ends_with("shared/blowup/core/blowup.hexa")
    let is_blowup_mod = path.index_of("/shared/blowup/modules/") >= 0 || path.starts_with("shared/blowup/modules/")
    if !is_blowup_core && !is_blowup_mod { return "" }
    let pb_path = NEXUS_HARNESS + "/perf_baseline.json"
    if !file_exists(pb_path) { return "" }
    let mut pb = ""
    try { pb = read_file(pb_path) } catch e {}
    if pb == "" { return "" }
    let last_ms = _grab_json_int(pb, "last_bench_ms")
    let sample_n = _grab_json_int(pb, "sample_n")
    if last_ms <= 0 || sample_n <= 0 { return "" }
    // phase_ms.{p0..p8} 합산 → baseline 평균 ms
    let mut total: i64 = 0
    let mut phases: i64 = 0
    let mut pi: i64 = 0
    while pi <= 8 {
        let key = "p" + to_string(pi)
        let v = _grab_json_int(pb, key)
        if v > 0 { total = total + v; phases = phases + 1 }
        pi = pi + 1
    }
    if phases == 0 || total <= 0 { return "" }
    let baseline_ms = total
    let threshold = (baseline_ms * 12) / 10
    if last_ms > threshold {
        return "H-PERF-BASELINE|warn|H-PERF-BASELINE: blowup " + to_string(last_ms) + "ms > " + to_string(baseline_ms) + "ms*1.2"
    }
    return ""
}

// ── Check: H-CROSS-NEXUS-N6 — blowup→atlas pending 5+ ──
fn check_cross_nexus_n6(path: string) -> string {
    let in_blowup = path.index_of("/shared/blowup/") >= 0 || path.starts_with("shared/blowup/")
    if !in_blowup { return "" }
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    let cf = NEXUS_HARNESS + "/cross_feed.jsonl"
    if !file_exists(cf) { return "" }
    let tail = exec("tail -n 100 '" + cf + "' 2>/dev/null").trim()
    if tail == "" { return "" }
    let lines = tail.split("\n")
    let mut n: i64 = 0
    for ln in lines {
        let s = _str(ln).trim()
        if s == "" { continue }
        if s.index_of("\"direction\":\"blowup→atlas\"") < 0 { continue }
        if s.index_of("\"status\":\"pending\"") < 0 { continue }
        n = n + 1
    }
    if n >= 5 {
        return "H-CROSS-NEXUS-N6|warn|H-CROSS-NEXUS-N6: " + to_string(n) + " blowup→atlas 미반영. cross_feed.hexa flush 필요"
    }
    return ""
}

// ── Check: H-CROSS-N6-ANIMA — atlas→anima pending 3+ ──
fn check_cross_n6_anima(path: string) -> string {
    let is_atlas = path.index_of("/shared/n6/atlas.n6") >= 0 || path.ends_with("shared/n6/atlas.n6")
    if !is_atlas { return "" }
    if path.ends_with(".stats") || path.ends_with(".deg") { return "" }
    let cf = NEXUS_HARNESS + "/cross_feed.jsonl"
    if !file_exists(cf) { return "" }
    let tail = exec("tail -n 100 '" + cf + "' 2>/dev/null").trim()
    if tail == "" { return "" }
    let lines = tail.split("\n")
    let mut n: i64 = 0
    for ln in lines {
        let s = _str(ln).trim()
        if s == "" { continue }
        if s.index_of("\"direction\":\"atlas→anima\"") < 0 { continue }
        if s.index_of("\"status\":\"pending\"") < 0 { continue }
        n = n + 1
    }
    if n >= 3 {
        return "H-CROSS-N6-ANIMA|warn|H-CROSS-N6-ANIMA: " + to_string(n) + " atlas→anima 미전파"
    }
    return ""
}

// ── Check: H-RES-OOM — 최근 OOM 기록 감지 (글로벌 게이트) ──
fn check_res_oom(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    if !file_exists(MISTAKES_LOG) { return "" }
    let tail = exec("tail -n 20 '" + MISTAKES_LOG + "' 2>/dev/null").trim()
    if tail == "" { return "" }
    let lines = tail.split("\n")
    for ln in lines {
        let s = _str(ln).trim()
        if s == "" { continue }
        if s.index_of("\"kind\":\"oom\"") >= 0 {
            return "H-RES-OOM|warn|H-RES-OOM: 최근 OOM 기록 감지. 메모리 패치 필요"
        }
    }
    return ""
}

// ── Check: H-EVOLVE-CRON — growth-tick 6h stale ──
fn check_evolve_cron(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    let gt = NEXUS_HARNESS + "/growth_tick_log.jsonl"
    if !file_exists(gt) { return "" }
    let tail = exec("tail -n 1 '" + gt + "' 2>/dev/null").trim()
    if tail == "" { return "" }
    let last_ts = _grab_json_int(tail, "ts")
    if last_ts <= 0 { return "" }
    let now_s = exec("date +%s").trim()
    if now_s == "" { return "" }
    let now_ep = _to_int0(now_s)
    if now_ep <= 0 { return "" }
    let diff = now_ep - last_ts
    if diff > 21600 {
        return "H-EVOLVE-CRON|warn|H-EVOLVE-CRON: growth-tick " + to_string(diff) + "s stale (>6h)"
    }
    return ""
}

// ─── P5 Thinking 엔진 가드 (H-THINK-*) ───

fn check_think_shallow(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    let tb = NEXUS_HARNESS + "/think_baseline.json"
    if !file_exists(tb) { return "" }
    let body = exec("cat '" + tb + "' 2>/dev/null").trim()
    if body == "" { return "" }
    let sessions = _grab_json_int(body, "session_count")
    if sessions < 3 { return "" }
    let avg_depth_str = exec("grep -o '\"avg_depth\":[0-9.]*' '" + tb + "' 2>/dev/null | head -1 | sed 's/.*://'").trim()
    if avg_depth_str == "" { return "" }
    let avg_int = _to_int0(avg_depth_str)
    if avg_int > 0 && avg_int < 3 {
        return "H-THINK-SHALLOW|warn|H-THINK-SHALLOW: thinking avg_depth=" + avg_depth_str + " < 3 (설익은 사고)"
    }
    return ""
}

fn check_think_loop(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    let tl = NEXUS_HARNESS + "/thinking_log.jsonl"
    if !file_exists(tl) { return "" }
    let dup_max_str = exec("tail -n 200 '" + tl + "' 2>/dev/null | grep -o '\"duplicate_count\":[0-9]*' | sed 's/.*://' | sort -n | tail -1").trim()
    if dup_max_str == "" { return "" }
    let dup_max = _to_int0(dup_max_str)
    if dup_max >= 5 {
        return "H-THINK-LOOP|block|H-THINK-LOOP: 동일 prompt " + to_string(dup_max) + "회+ 재사고 감지"
    }
    return ""
}

fn check_think_cross(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    let tl = NEXUS_HARNESS + "/thinking_log.jsonl"
    if !file_exists(tl) { return "" }
    let zero_touch = exec("tail -n 50 '" + tl + "' 2>/dev/null | grep -c '\"atlas_touches\":0' ").trim()
    if zero_touch == "" { return "" }
    let n = _to_int0(zero_touch)
    if n >= 10 {
        return "H-THINK-CROSS|block|H-THINK-CROSS: 최근 50 세션 중 atlas_touches=0 " + to_string(n) + "건 (atlas 미등록)"
    }
    return ""
}

fn check_think_evolve(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    let tb = NEXUS_HARNESS + "/think_baseline.json"
    if !file_exists(tb) { return "" }
    let body = exec("cat '" + tb + "' 2>/dev/null").trim()
    if body == "" { return "" }
    let last_ts = _grab_json_int(body, "last_ts")
    if last_ts <= 0 { return "" }
    let now_s = exec("date +%s").trim()
    if now_s == "" { return "" }
    let now_ep = _to_int0(now_s)
    let diff = now_ep - last_ts
    if diff > 86400 {
        return "H-THINK-EVOLVE|warn|H-THINK-EVOLVE: thinking " + to_string(diff) + "s stale (>24h)"
    }
    return ""
}

fn check_think_diverge(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    let tl = NEXUS_HARNESS + "/thinking_log.jsonl"
    if !file_exists(tl) { return "" }
    let rej = exec("tail -n 100 '" + tl + "' 2>/dev/null | grep -c '\"rejected\":true' ").trim()
    if rej == "" { return "" }
    let n = _to_int0(rej)
    if n >= 5 {
        return "H-THINK-DIVERGE|defer|H-THINK-DIVERGE: 최근 100 세션 중 rejected " + to_string(n) + "건 (anima 룰 충돌)"
    }
    return ""
}

// ─── H-NOZOMBIE 정적 룰 3종 (R-NOZ-*) — 2026-04-14 Phase 3-G ───
// Phase 1+2 체계 사전방지: exec() bare timeout 없음 / while true 가드 없음 / 장기모듈 lock 선언 없음
// 모두 warn. 우회 마커: @allow-bare-exec / @allow-unbounded-loop / @no-lock-needed

// ─── R-NOZ-EXEC-TIMEOUT (warn) — exec() bare 호출에 timeout wrap 권장 ───
// 대상: shared/harness/ 또는 shared/blowup/ 아래 .hexa
// fast 명령 (kill/test/cat/date/hostname/printf/mkdir/rm/basename/dirname/wc/head/tail/echo/pwd/stat/ls/touch/chmod/grep/awk/sed/ln) 만 포함된 exec 은 timeout 불필요
// LONG_RUN 화이트리스트: agent_ledger/blowup/session_/handoff_write/reaper
fn _noz_is_long_run_module(path: string) -> bool {
    if path.index_of("/agent_ledger.hexa") >= 0 { return true }
    if path.index_of("/blowup.hexa") >= 0 { return true }
    if path.index_of("shared/blowup/") >= 0 { return true }
    if path.index_of("/session_") >= 0 { return true }
    if path.index_of("/handoff_write.hexa") >= 0 { return true }
    if path.index_of("/reaper.hexa") >= 0 { return true }
    return false
}

fn check_nozombie_exec_timeout(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    let in_scope = path.starts_with("shared/harness/") || path.starts_with("shared/blowup/")
    if !in_scope { return "" }
    // 자기참조 및 helper 파일 제외
    if path.index_of("shared/harness/lint.hexa") >= 0 { return "" }
    if path.index_of("shared/harness/lib/safe_exec.hexa.inc") >= 0 { return "" }
    if path.index_of("shared/harness/lib/loop_guard.hexa.inc") >= 0 { return "" }
    if path.index_of("shared/harness/lib/lock_acquire.hexa.inc") >= 0 { return "" }
    if _noz_is_long_run_module(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if !file_exists(full) { return "" }

    // 면제: 파일에 wrap_prefix( 정의 또는 호출 존재하면 exec(cmd + ...) 변수형은 이미 wrap 된 것으로 간주
    let wp_count = _to_int0(_str(exec("grep -c 'wrap_prefix(' '" + full + "' 2>/dev/null || echo 0")).trim())
    // awk 한 번에 카운트: exec( 라인 중 다음 모두 위반
    //   1) safe_exec / _safe_exec_wrap / perl_timeout 토큰 없음
    //   2) @allow-bare-exec 주석 없음
    //   3) fast 명령만 포함하지 않음 (kill|test|cat|date|hostname|printf|mkdir|rm|basename|dirname|wc|head|tail|echo|pwd|stat|ls|touch|chmod|grep|awk|sed|ln)
    //   4) wrap_prefix( 존재 시 `exec(cmd` 변수형 (문자열 literal 아님) 은 면제
    // 간단 휴리스틱: exec("... 로 시작하는 라인에서 fast cmd prefix 검사
    let cmd = "awk -v WP=" + to_string(wp_count) + " 'BEGIN{c=0}" +
              "/exec\\(/ && !/safe_exec/ && !/_safe_exec_wrap/ && !/perl_timeout/ && !/@allow-bare-exec/ {" +
              // WP>0 인데 exec(cmd 변수형이면 면제
              " if (WP>0 && /exec\\(cmd/) next;" +
              " line=$0;" +
              // 첫 인자 문자열 추출: exec(" 뒤 ~ 다음 " 까지
              " sub(/.*exec\\(\"/, \"\", line); sub(/\".*/, \"\", line);" +
              // fast 명령 prefix: 문자열 시작이 fast cmd 중 하나로 시작하고 bash/sh -c 같은 shell nesting 없음
              " if (line ~ /^(kill|test|cat|date|hostname|printf|mkdir|rm[[:space:]]|rm$|basename|dirname|wc|head|tail|echo|pwd|stat|ls|touch|chmod|grep|awk|sed|ln|true|false|:)/) next;" +
              // 공백만이거나 비어있으면 스킵
              " if (line == \"\" || line ~ /^[[:space:]]*$/) next;" +
              " c++" +
              "} END{print c+0}' '" + full + "' 2>/dev/null"
    let hits = _to_int0(_str(exec(cmd)).trim())
    if hits > 0 {
        return "R-NOZ-EXEC-TIMEOUT|warn|exec() bare 호출 " + to_string(hits) + "건 — safe_exec 또는 perl_timeout.sh wrap 권장. 우회: '// @allow-bare-exec' 또는 LONG_RUN 모듈"
    }
    return ""
}

// ─── R-NOZ-WHILE-GUARD (warn) — while true 루프 가드 미비 ───
// 대상: shared/harness/, shared/blowup/, shared/n6/ 아래 .hexa
// 통과 조건: 파일 안에 (iter|count|loop_check|bounded_loop|max_iter) 토큰 존재 OR @allow-unbounded-loop
// 보수적 파일-수준 검사 (같은 함수 scope 는 hexa AST 분석 필요 — 복잡도 과잉)
fn check_nozombie_while_guard(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    let in_scope = path.starts_with("shared/harness/") || path.starts_with("shared/blowup/") || path.starts_with("shared/n6/")
    if !in_scope { return "" }
    // 자기참조 및 helper
    if path.index_of("shared/harness/lint.hexa") >= 0 { return "" }
    if path.index_of("shared/harness/lib/loop_guard.hexa.inc") >= 0 { return "" }
    if path.index_of("shared/harness/lib/safe_exec.hexa.inc") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    if !file_exists(full) { return "" }

    let mut content = ""
    try { content = read_file(full) } catch e {}
    if content == "" { return "" }
    if content.index_of("@allow-unbounded-loop") >= 0 { return "" }
    if content.index_of("R-NOZ-WHILE-GUARD") >= 0 { return "" }

    // while true 또는 loop { 발생 횟수
    let wc_cmd = "grep -cE '(while[[:space:]]+true|^[[:space:]]*loop[[:space:]]*\\{|[[:space:]]loop[[:space:]]*\\{)' '" + full + "' 2>/dev/null"
    let wc_hits = _to_int0(_str(exec(wc_cmd)).trim())
    if wc_hits == 0 { return "" }

    // 가드 토큰 존재 여부: iter / loop_check / bounded_loop / max_iter / loop_max_iter / iter_count
    if content.index_of("loop_check(") >= 0 { return "" }
    if content.index_of("bounded_loop") >= 0 { return "" }
    if content.index_of("max_iter") >= 0 { return "" }
    if content.index_of("loop_max_iter") >= 0 { return "" }
    if content.index_of("iter_count") >= 0 { return "" }
    // break + 단순 카운터 (iter = iter + 1 / count = count + 1) 존재 — 보수적 통과
    let has_break = content.index_of("break") >= 0
    let has_iter = content.index_of("iter = iter +") >= 0 || content.index_of("count = count +") >= 0
    if has_break && has_iter { return "" }

    return "R-NOZ-WHILE-GUARD|warn|while true/loop 블록 " + to_string(wc_hits) + "건 — max_iter 가드 없음. lib/loop_guard.hexa.inc `loop_check()` 적용 권장. 우회: '// @allow-unbounded-loop'"
}

// ─── R-NOZ-LOCK-DECL (warn) — 장기 실행 모듈 lock 선언 없음 ───
// 대상: shared/harness/, shared/blowup/ 아래 .hexa
// 휴리스틱: 파일 크기 > 8KB 또는 `for ` 토큰 30+ 회
// 통과 조건: 파일 첫 50줄 안에 '// lock:' 또는 'try_acquire_self_lock' 호출 OR '@no-lock-needed'
fn check_nozombie_lock_decl(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    let in_scope = path.starts_with("shared/harness/") || path.starts_with("shared/blowup/")
    if !in_scope { return "" }
    // 자기참조 및 helper / 테스트
    if path.index_of("shared/harness/lint.hexa") >= 0 { return "" }
    if path.index_of("/lib/") >= 0 { return "" }
    if path.index_of(".inc") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    if !file_exists(full) { return "" }

    let sz = _to_int0(_str(exec("stat -f '%z' '" + full + "' 2>/dev/null || stat -c '%s' '" + full + "' 2>/dev/null || echo 0")).trim())
    let for_cnt = _to_int0(_str(exec("grep -cE '^[[:space:]]*for[[:space:]]+' '" + full + "' 2>/dev/null")).trim())
    let long_run = sz > 8192 || for_cnt > 30
    if !long_run { return "" }

    let head50 = _str(exec("head -n 50 '" + full + "' 2>/dev/null"))
    if head50.index_of("@no-lock-needed") >= 0 { return "" }
    if head50.index_of("// lock:") >= 0 { return "" }
    if head50.index_of("try_acquire_self_lock") >= 0 { return "" }
    // 파일 전체에 try_acquire_self_lock 호출 있어도 통과 (헤더 강제는 너무 엄격)
    let mut content = ""
    try { content = read_file(full) } catch e {}
    if content.index_of("try_acquire_self_lock") >= 0 { return "" }
    if content.index_of("R-NOZ-LOCK-DECL") >= 0 { return "" }

    return "R-NOZ-LOCK-DECL|warn|장기 실행 모듈 (size=" + to_string(sz) + "B, for=" + to_string(for_cnt) + ") — lock 선언 없음. lib/lock_acquire.hexa.inc `try_acquire_self_lock()` 또는 '// lock: <name>' 헤더. 우회: '// @no-lock-needed'"
}

// ─── R-MIRROR-PTG (drift) — pre_tool_guard.hexa <-> lib/pre_tool_*.hexa.inc 4종 미러 검증 ───
// Why: hexa stage1 native include 미지원으로 본체가 inc 4개 fn body 를 copy-paste 미러.
//      inc 만 수정하고 본체 반영 누락 시 silent drift 발생.
// 검증: 각 inc 의 `fn NAME(SIG)` 시그니처 라인 + `return "REJECT:` 메시지 라인이
//      본체 pre_tool_guard.hexa 에 substring 으로 모두 존재하는지.
// scope: path == "shared/harness/pre_tool_guard.hexa" 일 때만 트리거 (inc 측은 자체 lint).
// 우회: 본체 또는 inc 에 '@allow-mirror-drift' 토큰 (정당한 일시적 불일치).
fn check_mirror_ptg(path: string) -> string {
    if path != "shared/harness/pre_tool_guard.hexa" { return "" }
    let main_full = REPO_ROOT + "/" + path
    if !file_exists(main_full) { return "" }
    let mut main_content = ""
    try { main_content = read_file(main_full) } catch e {}
    if main_content == "" { return "" }
    if main_content.index_of("@allow-mirror-drift") >= 0 { return "" }

    let inc_names = ["common", "write", "bash", "agent"]
    let mut missing = ""
    let mut miss_count: i64 = 0
    for nm in inc_names {
        let inc_rel = "shared/harness/lib/pre_tool_" + nm + ".hexa.inc"
        let inc_full = REPO_ROOT + "/" + inc_rel
        if !file_exists(inc_full) { continue }
        // fn 시그니처 라인 추출 — `^fn NAME(...)` 형식
        let sigs_raw = _str(exec("awk '/^fn [A-Za-z_]+\\(/{print}' '" + inc_full + "' 2>/dev/null")).trim()
        if sigs_raw != "" {
            let sigs = sigs_raw.split("\n")
            for s in sigs {
                let sig = _str(s).trim()
                if sig == "" { continue }
                if main_content.index_of(sig) < 0 {
                    if missing != "" { missing = missing + "; " }
                    missing = missing + "[" + nm + "] sig: " + sig
                    miss_count = miss_count + 1
                }
            }
        }
        // REJECT 메시지 라인 추출 — `return "REJECT:` 로 시작하는 거의 유일한 메시지
        let rej_raw = _str(exec("awk '/return \"REJECT:/{print}' '" + inc_full + "' 2>/dev/null")).trim()
        if rej_raw != "" {
            let rejs = rej_raw.split("\n")
            for r in rejs {
                let rej = _str(r).trim()
                if rej == "" { continue }
                if main_content.index_of(rej) < 0 {
                    if missing != "" { missing = missing + "; " }
                    missing = missing + "[" + nm + "] reject: " + rej
                    miss_count = miss_count + 1
                }
            }
        }
    }

    if miss_count == 0 { return "" }
    return "R-MIRROR-PTG|error|pre_tool_guard.hexa <-> lib/pre_tool_*.hexa.inc drift " + to_string(miss_count) + "건 — inc 변경 후 본체 미러 갱신 누락. 우회: '@allow-mirror-drift' 토큰. 상세: " + missing
}

// ─── Gather files to lint ───

fn get_staged_files() -> string {
    return exec("git diff --cached --name-only 2>/dev/null").trim()
}

fn get_all_shared_files() -> string {
    return exec("find " + SHARED_DIR + " -type f \\( -name '*.hexa' -o -name '*.py' -o -name '*.sh' -o -name '*.md' -o -name '*.json' -o -name '*.jsonl' \\) 2>/dev/null | sed 's|" + REPO_ROOT + "/||'").trim()
}

// ─── Main ───

// ─── Mode dispatch: env var (primary, args() 인터프리터 버그 우회) + args() fallback ───
let mut mode = "staged"
let mut single = ""

// Primary: env var — HARNESS_LINT_MODE=staged|all|file, HARNESS_LINT_FILE=<path>
let env_mode = env("HARNESS_LINT_MODE")
if env_mode == "all" { mode = "all" }
else if env_mode == "file" {
    mode = "file"
    single = env("HARNESS_LINT_FILE")
}
else if env_mode == "staged" { mode = "staged" }
// (unset → "staged" default, 기존 동작)

// Fallback: args() — 인터프리터가 수정되면 우선 적용
let a = args()
let mut ai: i64 = 2
while ai < len(a) {
    let tok = a[ai]
    if tok == "--staged" { mode = "staged" }
    else if tok == "--all" { mode = "all" }
    else if tok == "--file" {
        mode = "file"
        if ai + 1 < len(a) { single = a[ai + 1]; ai = ai + 1 }
    }
    ai = ai + 1
}

let mut files_raw = ""
if mode == "staged" { files_raw = get_staged_files() }
else if mode == "all" { files_raw = get_all_shared_files() }
else if mode == "file" { files_raw = single }

if files_raw == "" {
    // 검사할 파일 없음 — 조용히 통과
    let log = "{\"ts\":\"" + now_iso() + "\",\"mode\":\"" + mode + "\",\"files\":[],\"pass\":true,\"violations\":[]}"
    try { exec("echo '" + log + "' >> '" + LINT_LOG + "'") } catch e {}
    exit(0)
}

let files = files_raw.split("\n")
let mut violations: [string] = []
let mut checked: i64 = 0

// ─── H9 one-shot gate: hook stdin round-trip 회귀 감지 ───
// hooks/*.hexa 가 스코프에 있으면 1회만 실행. 없으면 조용히 스킵.
// gate 실패 시 lint 의 후속 check 에서 runtime 에러가 나도 확실히 차단하도록
// 즉시 log + exit 1. hook_stdin_gate 는 이미 stderr + mistakes.jsonl 기록함.
let h9 = check_h9_hook_stdin_gate(files_raw)
if h9 != "" {
    violations = violations.push("shared/hooks/*.hexa|" + h9)
    let log_line = "{\"ts\":\"" + now_iso() + "\",\"mode\":\"" + mode + "\",\"checked\":0,\"pass\":false,\"gate\":\"H9\",\"violation\":\"" + json_escape(h9) + "\"}"
    try { exec("echo '" + log_line.replace("'", "'\\''") + "' >> '" + LINT_LOG + "'") } catch e {}
    try { exec("echo '{\"ts\":\"" + now_iso() + "\",\"kind\":\"lint_fail\",\"rule\":\"H9\",\"fix\":\"" + json_escape(h9) + "\"}' >> '" + MISTAKES_LOG + "'") } catch e {}
    exit(1)
}

// ─── V-PARSE one-shot gate: L0 .hexa Parse error 0건 검증 ───
// H9 와 달리 즉시 exit 하지 않고 violations 에 push — 다른 체크도 함께 보고되도록.
// error 가 누적되면 loop 끝에서 has_error=true → exit(1) 로 차단.
let vp = check_v_parse(files_raw, mode)
if vp != "" {
    violations = violations.push("shared/lockdown/L0-hexa-paths|" + vp)
}

// ─── H-CMD-{DRIFT,SCHEMA,DEAD} one-shot gate ───
// commands.json 이 대상 파일 목록에 포함될 때만 1회 실행. 비용: jq 몇 호출.
let _cj_rel = "shared/config/commands.json"
let mut _cj_in_scope = false
for _cf in files {
    let _cp = _str(_cf).trim()
    if _cp == "" { continue }
    if _cp == _cj_rel { _cj_in_scope = true }
}
if _cj_in_scope {
    let _cmd_res = run_cmd_checks(_cj_rel)
    if _cmd_res != "" {
        let _cmd_lines = _cmd_res.split("\n")
        for _cl in _cmd_lines {
            let _cls = _str(_cl).trim()
            if _cls == "" { continue }
            violations = violations.push(_cj_rel + "|" + _cls)
        }
    }
}

for f in files {
    let path = _str(f).trim()
    if path == "" { continue }
    checked = checked + 1

    // Fast prefilter: skip checks that obviously don't apply by ext/path
    let e = ext_of(path)
    let under_shared = is_under_shared(path)

    // check_hexa_only: only .rs/.py/.sh under shared/
    if (e == ".py" || e == ".sh" || e == ".rs") && under_shared {
        let v1 = check_hexa_only(path)
        if v1 != "" { violations = violations.push(path + "|" + v1) }
    }

    // check_ai_native: only .md under rules/ or config/
    if e == ".md" && (path.starts_with("shared/rules/") || path.starts_with("shared/config/")) {
        let v2 = check_ai_native(path)
        if v2 != "" { violations = violations.push(path + "|" + v2) }
    }

    // check_l0_lockdown: only shared/ files
    if under_shared {
        let v3 = check_l0_lockdown(path)
        if v3 != "" { violations = violations.push(path + "|" + v3) }
    }

    // check_pitfalls: only .hexa files
    if e == ".hexa" {
        let v4 = check_pitfalls(path)
        if v4 != "" { violations = violations.push(path + "|" + v4) }
    }

    // check_claude_md: only CLAUDE.md files
    if e == ".md" {
        let v5 = check_claude_md(path)
        if v5 != "" { violations = violations.push(path + "|" + v5) }
    }

    // check_json: .json / .jsonl
    if e == ".json" || e == ".jsonl" {
        let v6 = check_json(path)
        if v6 != "" { violations = violations.push(path + "|" + v6) }
    }

    // check_hexa_algorithm: .hexa ai-native 알고리즘 강제
    if e == ".hexa" {
        let v7 = check_hexa_algorithm(path)
        if v7 != "" { violations = violations.push(path + "|" + v7) }
    }

    // check_hardcoded_path: /Users/ghost 하드코딩 금지
    let v8 = check_hardcoded_path(path)
    if v8 != "" { violations = violations.push(path + "|" + v8) }

    // check_enforce_sandbox (H-ENFORCE-SANDBOX): 하네스 entry 는 ensure_launchd_sandbox() 권장
    let v8a = check_enforce_sandbox(path)
    if v8a != "" { violations = violations.push(path + "|" + v8a) }

    // check_devpath (H-DEVPATH): hardcoded ~/Dev/ 금지 (.json/.md 만, $HOME/Dev/ 권장)
    let v8b = check_devpath(path)
    if v8b != "" { violations = violations.push(path + "|" + v8b) }

    // check_harness_modification: shared/harness/ 수정 시 승인 마커 필요
    let v9 = check_harness_modification(path)
    if v9 != "" { violations = violations.push(path + "|" + v9) }

    // check_silent_exit (R19): .hexa/.sh/.py/.ts/.js 대상
    if e == ".hexa" || e == ".sh" || e == ".py" || e == ".ts" || e == ".js" {
        let v10 = check_silent_exit(path)
        if v10 != "" { violations = violations.push(path + "|" + v10) }
    }

    // check_hx4 (hexa-lang 프로젝트 전용): Rust 언급조차 금지
    let v11 = check_hx4(path)
    if v11 != "" { violations = violations.push(path + "|" + v11) }

    // check_pkill_substring (R20): pkill/pgrep -f substring 금지
    if e == ".hexa" || e == ".sh" {
        let v12 = check_pkill_substring(path)
        if v12 != "" { violations = violations.push(path + "|" + v12) }
    }

    // check_bare_interpreter (R22): .hexa/.sh 에서 bare python3/ruby/node 금지
    if e == ".hexa" || e == ".sh" {
        let v12b = check_bare_interpreter(path)
        if v12b != "" { violations = violations.push(path + "|" + v12b) }
    }

    // check_calculator_ssot_path (R29): 계산기 .hexa 단일 SSOT
    if e == ".hexa" {
        let v12c = check_calculator_ssot_path(path)
        if v12c != "" { violations = violations.push(path + "|" + v12c) }
    }

    // check_r34: 로드맵 JSON 최소 경로 문법
    if e == ".json" {
        let v12d = check_r34(path)
        if v12d != "" { violations = violations.push(path + "|" + v12d) }
    }

    // check_cmds_hardcoded: commands.json 키워드 SSOT 강제
    if e == ".hexa" {
        let v12e = check_cmds_hardcoded(path)
        if v12e != "" { violations = violations.push(path + "|" + v12e) }
    }

    // check_proj_hardcode (H-PROJ-HARDCODE): projects.json 이름 5+ 하드코딩 감지
    if e == ".json" || e == ".jsonl" || e == ".md" || e == ".hexa" {
        let v12f = check_proj_hardcode(path)
        if v12f != "" { violations = violations.push(path + "|" + v12f) }
    }

    // check_an2 (anima 프로젝트 전용): localStorage/sessionStorage 금지
    let v13 = check_an2(path)
    if v13 != "" { violations = violations.push(path + "|" + v13) }

    // check_an_log_2/3/4/5/7 (anima 학습 진입점 .py/.hexa): 학습 로그 강제
    if e == ".py" || e == ".hexa" {
        let v13a = check_an_log_2(path)
        if v13a != "" { violations = violations.push(path + "|" + v13a) }
        let v13b = check_an_log_3(path)
        if v13b != "" { violations = violations.push(path + "|" + v13b) }
        let v13c = check_an_log_4(path)
        if v13c != "" { violations = violations.push(path + "|" + v13c) }
        let v13d = check_an_log_5(path)
        if v13d != "" { violations = violations.push(path + "|" + v13d) }
        let v13e = check_an_log_7(path)
        if v13e != "" { violations = violations.push(path + "|" + v13e) }
    }

    // check_vd1 (void 프로젝트 전용): Terminal.app 단일 참조
    let v14 = check_vd1(path)
    if v14 != "" { violations = violations.push(path + "|" + v14) }

    // check_vd2 (void 프로젝트 전용): 복잡도 동결 (C1 arity 합계, C3 CLI 플래그)
    let v14b = check_vd2(path)
    if v14b != "" { violations = violations.push(path + "|" + v14b) }

    // check_pp1 (papers 프로젝트 전용): CC-BY 4.0 라이선스 선언 필수
    let v15a = check_pp1(path)
    if v15a != "" { violations = violations.push(path + "|" + v15a) }

    // check_pp2 (papers 프로젝트 전용): 논문 md 에 검증코드 블록
    let v15 = check_pp2(path)
    if v15 != "" { violations = violations.push(path + "|" + v15) }

    // check_ag4 (airgenome 프로젝트 전용): launcher cap ≤8
    let v16 = check_ag4(path)
    if v16 != "" { violations = violations.push(path + "|" + v16) }

    // check_ag5 (airgenome 프로젝트 전용): 'filter' 네이밍 규율
    let v16b = check_ag5(path)
    if v16b != "" { violations = violations.push(path + "|" + v16b) }

    // check_ag6 (airgenome 프로젝트 전용): Mac 로컬 heavy compute 원격 가드 필수
    let v16c = check_ag6(path)
    if v16c != "" { violations = violations.push(path + "|" + v16c) }

    // check_n62a (n6-architecture 전용): 논문 md 에 ```python 블록 필수
    let v16d = check_n62a(path)
    if v16d != "" { violations = violations.push(path + "|" + v16d) }

    // ─── n6 논문 canonical 양식 12 규칙 (n6-architecture 전용) ───
    if e == ".md" {
        let n_c1 = check_n61_c1(path)
        if n_c1 != "" { violations = violations.push(path + "|" + n_c1) }
        let n_a1 = check_n61_a1(path)
        if n_a1 != "" { violations = violations.push(path + "|" + n_a1) }
        let n_b1 = check_n61_b1(path)
        if n_b1 != "" { violations = violations.push(path + "|" + n_b1) }
        let n_b2 = check_n61_b2(path)
        if n_b2 != "" { violations = violations.push(path + "|" + n_b2) }
        let n_b3 = check_n61_b3(path)
        if n_b3 != "" { violations = violations.push(path + "|" + n_b3) }
        let n_b4 = check_n61_b4(path)
        if n_b4 != "" { violations = violations.push(path + "|" + n_b4) }
        let n_mk1 = check_n61_mk1(path)
        if n_mk1 != "" { violations = violations.push(path + "|" + n_mk1) }
        let n_mk3 = check_n61_mk3(path)
        if n_mk3 != "" { violations = violations.push(path + "|" + n_mk3) }
        let n_mk4 = check_n61_mk4(path)
        if n_mk4 != "" { violations = violations.push(path + "|" + n_mk4) }
        let n_r1 = check_n61_r1(path)
        if n_r1 != "" { violations = violations.push(path + "|" + n_r1) }
        let n_r2 = check_n61_r2(path)
        if n_r2 != "" { violations = violations.push(path + "|" + n_r2) }
        let n_p1 = check_n61_p1(path)
        if n_p1 != "" { violations = violations.push(path + "|" + n_p1) }
        let n_r3 = check_n61_r3(path)
        if n_r3 != "" { violations = violations.push(path + "|" + n_r3) }
        let n_w1 = check_n61_w1(path)
        if n_w1 != "" { violations = violations.push(path + "|" + n_w1) }
        let n_e1 = check_n61_e1(path)
        if n_e1 != "" { violations = violations.push(path + "|" + n_e1) }
        let n_v1 = check_n61_v1(path)
        if n_v1 != "" { violations = violations.push(path + "|" + n_v1) }
        let n_v2 = check_n61_v2(path)
        if n_v2 != "" { violations = violations.push(path + "|" + n_v2) }
        let n_v3 = check_n61_v3(path)
        if n_v3 != "" { violations = violations.push(path + "|" + n_v3) }
        let n_v4 = check_n61_v4(path)
        if n_v4 != "" { violations = violations.push(path + "|" + n_v4) }
        let n_f1 = check_n61_f1(path)
        if n_f1 != "" { violations = violations.push(path + "|" + n_f1) }
        let n_new = check_n61_new(path)
        if n_new != "" { violations = violations.push(path + "|" + n_new) }
        let n_gref = check_n61_gold_ref(path)
        if n_gref != "" { violations = violations.push(path + "|" + n_gref) }
        let h_defer = check_h_defer(path)
        if h_defer != "" { violations = violations.push(path + "|" + h_defer) }
        let h_root = check_h_root(path)
        if h_root != "" { violations = violations.push(path + "|" + h_root) }
        let n_dsync = check_n6_dag_sync(path)
        if n_dsync != "" { violations = violations.push(path + "|" + n_dsync) }
        let n_vm1 = check_vp_m1(path)
        if n_vm1 != "" { violations = violations.push(path + "|" + n_vm1) }
        let n_vm2 = check_vp_m2(path)
        if n_vm2 != "" { violations = violations.push(path + "|" + n_vm2) }
        let n_vm7 = check_vp_m7(path)
        if n_vm7 != "" { violations = violations.push(path + "|" + n_vm7) }
        let n_vm9 = check_vp_m9(path)
        if n_vm9 != "" { violations = violations.push(path + "|" + n_vm9) }
        let n_vm10 = check_vp_m10(path)
        if n_vm10 != "" { violations = violations.push(path + "|" + n_vm10) }
        let n_jp = check_n6_jsonpair(path)
        if n_jp != "" { violations = violations.push(path + "|" + n_jp) }
    }

    // ─── n6 DAG 무결성 (papers/_dag.json 전용) ───
    let n_ddang = check_n6_dag_dangle(path)
    if n_ddang != "" { violations = violations.push(path + "|" + n_ddang) }
    let n_dcyc = check_n6_dag_cycle(path)
    if n_dcyc != "" { violations = violations.push(path + "|" + n_dcyc) }

    // check_project_rules: shared/rules/<project>.lint.jsonl 자동 로드 + 디스패치
    let v17 = check_project_rules(path)
    if v17 != "" { violations = violations.push(path + "|" + v17) }

    // check_atlas_guard (공통): atlas.n6 직접 편집 금지 — L1/L2/L3 진입 차단
    if e == ".hexa" || e == ".sh" {
        let v18 = check_atlas_guard(path)
        if v18 != "" { violations = violations.push(path + "|" + v18) }
    }

    // check_blow1 (공통): BLOWUP_LOCAL=1 금지
    let v19 = check_blow1(path)
    if v19 != "" { violations = violations.push(path + "|" + v19) }

    // check_h_grc (공통): grep -c ... || echo 0 안티패턴 (hexa 파일만)
    let v20 = check_h_grc(path)
    if v20 != "" { violations = violations.push(path + "|" + v20) }

    // check_md2pdf (공통, H-MD2PDF): pandoc/xelatex/pdflatex/lualatex 호출 차단 (.hexa/.sh)
    let v22 = check_md2pdf(path)
    if v22 != "" { violations = violations.push(path + "|" + v22) }

    // check_send_guard (공통, H-SEND-GUARD): 외부 발송/등록 코드 감지 (.hexa/.sh)
    let v23 = check_send_guard(path)
    if v23 != "" { violations = violations.push(path + "|" + v23) }

    // check_h_noblock (공통, H-NOBLOCK): 세션 채팅 블로킹 패턴 감지 (.hexa/.sh)
    let v24 = check_h_noblock(path)
    if v24 != "" { violations = violations.push(path + "|" + v24) }

    // check_h_noarchive (공통, H-NOARCHIVE): archive/backup 파일·폴더 생성 패턴 감지 (.hexa/.sh)
    let v26 = check_h_noarchive(path)
    if v26 != "" { violations = violations.push(path + "|" + v26) }

    // check_h_noname_v (공통, H-NONAME-V): 파일/폴더명 버전 suffix 금지 (_v2/_mk3/_Mk.V/_new/_copy/Finder dup)
    let v_nnv = check_h_noname_v(path)
    if v_nnv != "" { violations = violations.push(path + "|" + v_nnv) }

    // check_h_nohook (공통, H-NOHOOK): hook 시스템 신규 작성 금지 — settings hooks/.claude·.git hooks 신규
    let v_nh = check_h_nohook(path)
    if v_nh != "" { violations = violations.push(path + "|" + v_nh) }

    // check_emerge_commit (H-EMERGE-COMMIT): atlas 3 commit 연속 무성장 감지
    let v_ec = check_emerge_commit(path)
    if v_ec != "" { violations = violations.push(path + "|" + v_ec) }

    // check_no_regress (H-NOREGRESS): atlas nodes/edges 역행 차단 (NEXUS_GC_OK=1 우회)
    let v_nr = check_no_regress(path)
    if v_nr != "" { violations = violations.push(path + "|" + v_nr) }

    // check_perf_baseline (H-PERF-BASELINE): blowup 성능 1.2x 회귀 감지
    let v_pb = check_perf_baseline(path)
    if v_pb != "" { violations = violations.push(path + "|" + v_pb) }

    // check_cross_nexus_n6 (H-CROSS-NEXUS-N6): blowup→atlas pending 5+ 감지
    let v_cx1 = check_cross_nexus_n6(path)
    if v_cx1 != "" { violations = violations.push(path + "|" + v_cx1) }

    // check_cross_n6_anima (H-CROSS-N6-ANIMA): atlas→anima pending 3+ 감지
    let v_cx2 = check_cross_n6_anima(path)
    if v_cx2 != "" { violations = violations.push(path + "|" + v_cx2) }

    // check_res_oom (H-RES-OOM): 최근 mistakes.jsonl OOM 기록 글로벌 게이트
    let v_oom = check_res_oom(path)
    if v_oom != "" { violations = violations.push(path + "|" + v_oom) }

    // check_evolve_cron (H-EVOLVE-CRON): growth-tick 6h stale 감지
    let v_ev = check_evolve_cron(path)
    if v_ev != "" { violations = violations.push(path + "|" + v_ev) }

    // ─── P5 Thinking 엔진 가드 (H-THINK-*) ───
    let v_ts = check_think_shallow(path)
    if v_ts != "" { violations = violations.push(path + "|" + v_ts) }
    let v_tl = check_think_loop(path)
    if v_tl != "" { violations = violations.push(path + "|" + v_tl) }
    let v_tc = check_think_cross(path)
    if v_tc != "" { violations = violations.push(path + "|" + v_tc) }
    let v_te = check_think_evolve(path)
    if v_te != "" { violations = violations.push(path + "|" + v_te) }
    let v_td = check_think_diverge(path)
    if v_td != "" { violations = violations.push(path + "|" + v_td) }

    // check_hexa_exit (공통, H-HEXA-EXIT): hexa child exit() 비전파 — stdout 마커 검사 권장 (.hexa)
    if e == ".hexa" {
        let v25 = check_hexa_exit(path)
        if v25 != "" { violations = violations.push(path + "|" + v25) }
    }

    // check_blow3 (공통): blowup 신규 파일 서브폴더 강제
    if e == ".hexa" {
        let v20 = check_blow3(path)
        if v20 != "" { violations = violations.push(path + "|" + v20) }
    }

    // check_blow6 (공통): 폐기 JSON 발견 저장소 쓰기 금지 (R28)
    if e == ".hexa" {
        let v21 = check_blow6(path)
        if v21 != "" { violations = violations.push(path + "|" + v21) }
    }

    // check_v_const (공통, V-CONST): verified_constants.jsonl 직접 쓰기 금지
    if e == ".hexa" || e == ".sh" {
        let v_vc = check_v_const(path)
        if v_vc != "" { violations = violations.push(path + "|" + v_vc) }
    }

    // ─── H-NOZOMBIE 정적 룰 3종 (2026-04-14 Phase 3-G) ───
    // R-NOZ-EXEC-TIMEOUT (warn): exec() bare timeout wrap 권장
    if e == ".hexa" {
        let v_noz1 = check_nozombie_exec_timeout(path)
        if v_noz1 != "" { violations = violations.push(path + "|" + v_noz1) }
    }
    // R-NOZ-WHILE-GUARD (warn): while true max_iter 가드 권장
    if e == ".hexa" {
        let v_noz2 = check_nozombie_while_guard(path)
        if v_noz2 != "" { violations = violations.push(path + "|" + v_noz2) }
    }
    // R-NOZ-LOCK-DECL (warn): 장기 실행 모듈 lock 선언 권장
    if e == ".hexa" {
        let v_noz3 = check_nozombie_lock_decl(path)
        if v_noz3 != "" { violations = violations.push(path + "|" + v_noz3) }
    }

    // R-MIRROR-PTG (error): pre_tool_guard.hexa <-> lib/pre_tool_*.hexa.inc 미러 drift
    if e == ".hexa" {
        let v_mptg = check_mirror_ptg(path)
        if v_mptg != "" { violations = violations.push(path + "|" + v_mptg) }
    }

}

let pass = len(violations) == 0

// ─── Log append (lint_log.jsonl) ───

let mut files_json = "["
let mut fi: i64 = 0
for f in files {
    let p = _str(f).trim()
    if p == "" { continue }
    if fi > 0 { files_json = files_json + "," }
    files_json = files_json + "\"" + json_escape(p) + "\""
    fi = fi + 1
}
files_json = files_json + "]"

let mut viol_json = "["
let mut vi: i64 = 0
let mut has_error = false
for v in violations {
    let vs = _str(v)
    if vs == "" { continue }
    let parts = vs.split("|")
    if len(parts) < 4 { continue }
    let vfile = _str(parts[0])
    let vrule = _str(parts[1])
    let vsev = _str(parts[2])
    let vhint = _str(parts[3])
    if vsev == "error" { has_error = true }
    if vi > 0 { viol_json = viol_json + "," }
    viol_json = viol_json + "{\"file\":\"" + json_escape(vfile) + "\",\"rule\":\"" + vrule + "\",\"severity\":\"" + vsev + "\",\"fix_hint\":\"" + json_escape(vhint) + "\"}"
    vi = vi + 1
}
viol_json = viol_json + "]"

let log_line = "{\"ts\":\"" + now_iso() + "\",\"mode\":\"" + mode + "\",\"checked\":" + to_string(checked) + ",\"pass\":" + (if pass { "true" } else { "false" }) + ",\"files\":" + files_json + ",\"violations\":" + viol_json + "}"
try { exec("echo '" + log_line.replace("'", "'\\''") + "' >> '" + LINT_LOG + "'") } catch e {}

// ─── Output: pass = silent, fail = loud ───

if pass { exit(0) }

// 실패는 시끄럽게 — stderr 에 JSON 라인 per violation
for v in violations {
    let vs = _str(v)
    if vs == "" { continue }
    let parts = vs.split("|")
    if len(parts) < 4 { continue }
    let vfile = _str(parts[0])
    let vrule = _str(parts[1])
    let vsev = _str(parts[2])
    let vhint = _str(parts[3])
    let line = "{\"file\":\"" + json_escape(vfile) + "\",\"rule\":\"" + vrule + "\",\"severity\":\"" + vsev + "\",\"fix_hint\":\"" + json_escape(vhint) + "\"}"
    // stderr 로
    try { exec("echo '" + line.replace("'", "'\\''") + "' >&2") } catch e {}
    // mistakes.jsonl 누적
    let m = "{\"ts\":\"" + now_iso() + "\",\"kind\":\"lint_fail\",\"file\":\"" + json_escape(vfile) + "\",\"rule\":\"" + vrule + "\",\"fix\":\"" + json_escape(vhint) + "\"}"
    try { exec("echo '" + m.replace("'", "'\\''") + "' >> '" + MISTAKES_LOG + "'") } catch e {}
}

// error 가 있으면 차단, warn/info 만이면 통과
if has_error { exit(1) }
exit(0)
