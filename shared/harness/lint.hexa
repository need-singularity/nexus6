// ═══════════════════════════════════════════════════════════
// lint.hexa — 하네스 P2 자동 강제 린터
// AI-native, .hexa-only (R1), 성공 조용/실패 시끄럽게
// Usage:
//   hexa shared/harness/lint.hexa --staged     (git staged files)
//   hexa shared/harness/lint.hexa --all        (전체 shared/ 트리)
//   hexa shared/harness/lint.hexa --file PATH  (단일 파일)
// 실패 시 stderr JSON 라인 + exit 1, lint_log.jsonl 에 결과 append
// ═══════════════════════════════════════════════════════════

let HOME = env("HOME")
let REPO_ROOT = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
let SHARED_DIR = REPO_ROOT + "/shared"
// 로그는 nexus SSOT 에 집중 — 타 리포에서 실행돼도 nexus 경로로 append
let NEXUS_HARNESS = HOME + "/Dev/nexus/shared/harness"
let LINT_LOG = NEXUS_HARNESS + "/lint_log.jsonl"
let MISTAKES_LOG = NEXUS_HARNESS + "/mistakes.jsonl"

fn now_ts() {
    return exec("date +%s").trim()
}

fn now_iso() {
    return exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "\\r")
    r = r.replace("\t", "\\t")
    return r
}

// ─── File classification ───

fn is_under_shared(path: string) -> bool {
    return path.starts_with("shared/")
}

// void-safe coercion ("".split() 첫 원소 void 이슈 우회)
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

// last_index_of 미지원 우회 — 수동 스캔
fn _rfind(s: string, ch: string) -> i64 {
    let n = len(s)
    let mut i: i64 = n - 1
    while i >= 0 {
        if s.substring(i, i + 1) == ch { return i }
        i = i - 1
    }
    return -1
}

fn ext_of(path: string) -> string {
    let dot = _rfind(path, ".")
    if dot < 0 { return "" }
    return path.substring(dot, len(path))
}

fn basename_of(path: string) -> string {
    let slash = _rfind(path, "/")
    if slash < 0 { return path }
    return path.substring(slash + 1, len(path))
}

// ─── Check 1: R1 HEXA-FIRST (no new .py/.sh under shared/) ───
// exception: shared/scripts/ (기존 bootstrap bin 포함), shared/bin/ (C helper)

fn is_hexa_only_exception(path: string) -> bool {
    if path.starts_with("shared/scripts/") { return true }
    if path.starts_with("shared/bin/") { return true }
    return false
}

fn check_hexa_only(path: string) -> string {
    let e = ext_of(path)
    if e != ".py" && e != ".sh" && e != ".rs" { return "" }
    if !is_under_shared(path) { return "" }
    if is_hexa_only_exception(path) { return "" }
    return "R1|error|HEXA-FIRST — shared/ 아래 .rs/.py/.sh 금지. ai-native algorism 으로 재작성"
}

// ─── Check 2: AI-native (R14) — prose .md in rules/config ───

fn check_ai_native(path: string) -> string {
    let e = ext_of(path)
    if e != ".md" { return "" }
    let bn = basename_of(path)
    // CLAUDE.md 는 프로젝트 지도로 허용
    if bn == "CLAUDE.md" { return "" }
    if bn == "SECRET.md" { return "" }
    if path.starts_with("shared/rules/") {
        return "R14|warn|rules SSOT 는 JSON 만. prose .md 금지"
    }
    if path.starts_with("shared/config/") {
        return "R14|warn|config SSOT 는 JSON/JSONL 만. prose .md 금지"
    }
    return ""
}

// ─── Check 3: L0 lockdown — L0 보호 영역 수정 감지 (pure hexa, no python) ───
// python3 호출은 hetzner 라우팅 위험 — grep + 순수 hexa 파싱

// lockdown.json 에서 "path":"..." 값 전체 라인 추출 (한 번만 호출)
fn _l0_path_lines() -> string {
    let LOCKDOWN = REPO_ROOT + "/shared/lockdown/lockdown.json"
    if !file_exists(LOCKDOWN) { return "" }
    // "path": "..." 또는 "path":"..." 형태 라인 전부 grep. L0/L1 구분은 단순화 —
    // L1 entries 도 포함되지만 warn 수준이라 안전 (L0 전용 정확도는 l0_guard 가 담당)
    return exec("grep -oE '\"path\"[[:space:]]*:[[:space:]]*\"[^\"]+\"' '" + LOCKDOWN + "' 2>/dev/null").trim()
}

// 한 라인에서 path 값만 추출: "path": "xxx" → xxx
fn _extract_path_value(line: string) -> string {
    // 마지막 따옴표 쌍 사이 값 찾기: 패턴은 "path":...,"<value>"
    // 뒤에서부터 두 번째 " 와 마지막 " 사이
    let last_q = _rfind(line, "\"")
    if last_q < 0 { return "" }
    let before = line.substring(0, last_q)
    let prev_q = _rfind(before, "\"")
    if prev_q < 0 { return "" }
    return line.substring(prev_q + 1, last_q)
}

fn path_in_l0(path: string) -> bool {
    let raw = _l0_path_lines()
    if raw == "" { return false }
    let lines = raw.split("\n")
    for ln in lines {
        let l = _str(ln).trim()
        if l == "" { continue }
        let entry = _extract_path_value(l)
        if entry == "" { continue }
        // prefix 매칭: "xxx/*" → path.starts_with("xxx/")
        let e_len = len(entry)
        if e_len >= 2 && entry.substring(e_len - 2, e_len) == "/*" {
            let prefix = entry.substring(0, e_len - 2) + "/"
            if path.starts_with(prefix) { return true }
            continue
        }
        // 디렉터리 엔트리 ("xxx/" 로 끝나면 prefix 매칭)
        if e_len >= 1 && entry.substring(e_len - 1, e_len) == "/" {
            if path.starts_with(entry) { return true }
            continue
        }
        // exact
        if path == entry { return true }
    }
    return false
}

fn check_l0_lockdown(path: string) -> string {
    if !path_in_l0(path) { return "" }
    let msg_raw = exec("cat '" + REPO_ROOT + "/.git/COMMIT_EDITMSG' 2>/dev/null").trim()
    if msg_raw.index_of("chore(lockdown):") >= 0 { return "" }
    if msg_raw.index_of("L0-approved") >= 0 { return "" }
    return "L0|warn|L0 보호 영역 수정 — 커밋 메시지에 'chore(lockdown):' 또는 'L0-approved' 포함 권장"
}

// ─── Check 4: pitfalls grep ───

fn check_pitfalls(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    let full = REPO_ROOT + "/" + path
    // Python sys 의존 탐지
    let py_call = to_int(_str(exec("grep -c 'python3 -c' '" + full + "' 2>/dev/null || echo 0")).trim())
    if py_call > 10 {
        return "P-PY-HEAVY|info|.hexa 내 python3 -c 호출 >10회. 순수 hexa 함수로 추출 고려"
    }
    return ""
}

// ─── Check 5: AI-native — CLAUDE.md line cap + prose detection ───
fn check_claude_md(path: string) -> string {
    let bn = basename_of(path)
    if bn != "CLAUDE.md" { return "" }
    let full = REPO_ROOT + "/" + path
    let lines_cnt = to_int(_str(exec("wc -l < '" + full + "' 2>/dev/null || echo 0")).trim())
    if lines_cnt > 250 {
        return "AI-NATIVE|warn|CLAUDE.md > 250 라인 (" + to_string(lines_cnt) + ") — ai-native 간결화 필요"
    }
    // prose detection: 80자+ 마침표 끝 비-리스트/헤더/테이블/코드 라인 3+ 연속
    let prose_cmd = "awk 'BEGIN{run=0;max=0} { if (length($0)>=80 && ($0 ~ /[.]$/ || $0 ~ /다\\.$/ || $0 ~ /요\\.$/) && $0 !~ /^[|\\-*#`]/ && $0 !~ /^[[:space:]]*[a-zA-Z_][a-zA-Z0-9_]*:/) { run++; if(run>max) max=run } else run=0 } END{print max}' '" + full + "' 2>/dev/null"
    let prose_run = to_int(_str(exec(prose_cmd)).trim())
    if prose_run >= 3 {
        return "AI-NATIVE|warn|CLAUDE.md 연속 prose " + to_string(prose_run) + "줄 — key:value/표/리스트로 재작성"
    }
    return ""
}

// ─── Check 6: AI-native — JSON/JSONL 포맷 ───
fn check_json(path: string) -> string {
    let e = ext_of(path)
    if e != ".json" && e != ".jsonl" { return "" }
    let full = REPO_ROOT + "/" + path
    // JSONL: 모든 비-빈 라인이 { 또는 [ 로 시작해야 함
    if e == ".jsonl" {
        let bad = to_int(_str(exec("awk 'NF>0 && $0 !~ /^[{\\[]/' '" + full + "' 2>/dev/null | wc -l")).trim())
        if bad > 0 {
            return "AI-NATIVE|error|JSONL 에 비-JSON 라인 " + to_string(bad) + "건 — 각 라인 { 또는 [ 로 시작"
        }
    }
    // JSON: 단일 string 값 2000자+ (prose 누출)
    if e == ".json" {
        let long_val = to_int(_str(exec("grep -oE '\"[^\"]{2000,}\"' '" + full + "' 2>/dev/null | wc -l")).trim())
        if long_val > 0 {
            return "AI-NATIVE|warn|JSON string 값 2000자+ — prose 누출, 별도 파일 또는 배열 분할"
        }
    }
    return ""
}

// ─── Check R20: pkill/pgrep -f substring 금지 ───
// -f substring 은 무고한 프로세스 silent kill 위험. -xf 정확매칭 또는 PID 파일 기반 사용.
fn check_pkill_substring(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" { return "" }
    // 하네스 자신/lockdown 은 이미 검증됨
    if path.starts_with("shared/harness/") { return "" }
    let full = REPO_ROOT + "/" + path
    // pkill -f 또는 pgrep -f 매칭. -xf 는 제외 (정확매칭 = 안전)
    let cmd = "grep -nE '\\b(pkill|pgrep)[[:space:]]+-f\\b' '" + full + "' 2>/dev/null | grep -v '\\-xf' | grep -v '@allow-pkill-f' | wc -l"
    let hits = to_int(_str(exec(cmd)).trim())
    if hits > 0 {
        return "R20|error|pkill/pgrep -f substring " + to_string(hits) + "건 — 무고한 프로세스 kill 위험. -xf 정확매칭 또는 PID 파일 사용 (// @allow-pkill-f)"
    }
    return ""
}

// ─── 프로젝트 감지 ───
fn _project_name() -> string {
    let root = _str(exec("git rev-parse --show-toplevel 2>/dev/null")).trim()
    if root == "" { return "" }
    return _str(exec("basename '" + root + "' 2>/dev/null")).trim()
}

// ─── HX4 (hexa-lang 전용) SELF-HOST 공리 ───
// L0 (공리): hexa-lang 은 hexa-lang 으로 작성된다.
// L1: 신규 소스 확장자 = .hexa only (.c syscall helper, 허용 확장자 whitelist 외 error)
// L2: 외부 컴파일러 언급 (rust/cargo/rustc) 금지 — 이전 v4+v5 grep 유지
// 예외: archive/, _archive/, self/docs/, build/ (생성물), 하네스 자신
fn _hx4_is_exempt(path: string) -> bool {
    if path.starts_with("archive/") { return true }
    if path.index_of("/_archive/") >= 0 { return true }
    if path.index_of("hexa_pitfalls_log") >= 0 { return true }
    if path.starts_with("self/docs/") { return true }
    if path.starts_with("build/") { return true }
    if path.starts_with("shared/harness/") { return true }
    if path.starts_with("shared/rules/") { return true }
    // editors/playground/docs-website: 외부 도구 필수 (IntelliJ Java, web assets)
    if path.starts_with("editors/") { return true }
    if path.starts_with("playground/") { return true }
    if path.starts_with("docs/website/") { return true }
    // AI 메모리/worktree/growth 캐시
    if path.starts_with(".claude") { return true }
    if path.starts_with(".growth") { return true }
    if path.starts_with(".superpowers") { return true }
    // 역사 문서 (레거시 테스트/빌드 언급 포함)
    if path.starts_with("docs/superpowers/") { return true }
    if path.starts_with("docs/history/") { return true }
    // log 파일
    if path.index_of(".log") >= 0 { return true }
    return false
}

// L1 허용 확장자: self-host 공리 준수 파일 종류
fn _is_self_host_ext(ext: string) -> bool {
    if ext == ".hexa" { return true }
    if ext == ".c" { return true }
    if ext == ".h" { return true }
    if ext == ".md" { return true }
    if ext == ".json" { return true }
    if ext == ".jsonl" { return true }
    if ext == ".yaml" { return true }
    if ext == ".yml" { return true }
    if ext == ".toml" { return true }
    if ext == ".txt" { return true }
    if ext == ".sh" { return true }
    return false
}

// 확장자 없는 허용 파일명
fn _is_self_host_bare(bn: string) -> bool {
    if bn == "Makefile" { return true }
    if bn == "README" { return true }
    if bn == "LICENSE" { return true }
    if bn == "CODEOWNERS" { return true }
    if bn == "Dockerfile" { return true }
    if bn == "hexa" { return true }
    if bn == "hexa-build" { return true }
    if bn.starts_with(".") { return true }
    return false
}

// L1 확장자/파일명 whitelist
fn _hx4_l1_ext(path: string) -> string {
    let e = ext_of(path)
    let bn = basename_of(path)
    if e == "" {
        if !_is_self_host_bare(bn) {
            return "HX4-L1|error|SELF-HOST — 허용되지 않은 파일 '" + bn + "'"
        }
    } else {
        if !_is_self_host_ext(e) {
            return "HX4-L1|error|SELF-HOST — 소스 확장자 '" + e + "' 금지. .hexa 로 재작성"
        }
    }
    return ""
}

// L2 외부 툴체인 언급 grep
fn _hx4_l2_toolchain(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".md" && e != ".json" && e != ".jsonl" && e != ".sh" && e != ".yaml" && e != ".yml" && e != ".toml" { return "" }
    let full = REPO_ROOT + "/" + path
    let cmd = "grep -E '\\brust\\b|\\bRust\\b|\\bRUST\\b|\\bcargo\\b|\\bCargo\\b|\\brustc\\b|\\brustup\\b|target/(debug|release)' '" + full + "' 2>/dev/null | grep -v '@allow-rust-mention' | wc -l"
    let hits = to_int(_str(exec(cmd)).trim())
    if hits > 0 {
        return "HX4-L2|error|외부 툴체인 언급 " + to_string(hits) + "건 (// @allow-rust-mention)"
    }
    return ""
}

// L3 런타임 FFI/dlopen 금지 — self/runtime.c 내부 API 만
// 예외: self/ 컴파일러 내부 (ffi 생성기는 self-host 본질), self/ml/ FFI 인프라
fn _hx4_l3_runtime(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    // self/ 컴파일러는 ffi 코드 생성기라 예외
    if path.starts_with("self/") { return "" }
    let full = REPO_ROOT + "/" + path
    let cmd = "grep -E '\\b(dlopen|dlsym|ffi_call|ffi_new|FFI\\.)' '" + full + "' 2>/dev/null | grep -v '@allow-ffi' | wc -l"
    let hits = to_int(_str(exec(cmd)).trim())
    if hits > 0 {
        return "HX4-L3|error|런타임 외부 FFI/dlopen " + to_string(hits) + "건 (// @allow-ffi)"
    }
    return ""
}

// L4 문서 = hexa 실행 가능 예제 — 언어 명세/튜토리얼 .md 에 ```hexa 블록 필수
// 대상 패턴: spec/reference/grammar/syntax/tutorial/quickstart/guide/getting-started/intro
fn _hx4_l4_docs(path: string) -> string {
    let e = ext_of(path)
    if e != ".md" { return "" }
    if !path.starts_with("docs/") { return "" }
    // 문서 하위 카테고리 예외
    if path.starts_with("docs/paper/") { return "" }
    if path.starts_with("docs/history/") { return "" }
    if path.starts_with("docs/superpowers/") { return "" }
    if path.starts_with("docs/breakthroughs/") { return "" }
    if path.starts_with("docs/victories/") { return "" }
    let bn = basename_of(path)
    if bn == "README.md" || bn == "CHANGELOG.md" { return "" }
    let bn_lo = bn.to_lower()
    let is_spec = bn_lo.index_of("spec") >= 0 || bn_lo.index_of("reference") >= 0 || bn_lo.index_of("grammar") >= 0 || bn_lo.index_of("syntax") >= 0 || bn_lo.index_of("tutorial") >= 0 || bn_lo.index_of("quickstart") >= 0 || bn_lo.index_of("guide") >= 0 || bn_lo.index_of("getting-started") >= 0 || bn_lo.index_of("intro") >= 0 || bn_lo.index_of("manual") >= 0
    if !is_spec { return "" }
    let full = REPO_ROOT + "/" + path
    let has_hexa = to_int(_str(exec("grep -c '```hexa' '" + full + "' 2>/dev/null || echo 0")).trim())
    if has_hexa == 0 {
        return "HX4-L4|warn|언어 문서(spec/reference/grammar/tutorial/guide) 에 ```hexa 실행 예제 없음 (// @allow-non-executable-doc)"
    }
    return ""
}

// L5 테스트 프레임워크 외부 의존 금지 — hexa 자체 테스트 사용
fn _hx4_l5_tests(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" && e != ".yaml" && e != ".yml" && e != ".json" && e != ".jsonl" && e != ".md" && e != ".toml" { return "" }
    let full = REPO_ROOT + "/" + path
    let cmd = "grep -E '\\b(pytest|cargo test|jest|mocha|phpunit|go test|rspec|junit)\\b' '" + full + "' 2>/dev/null | grep -v '@allow-ext-test' | wc -l"
    let hits = to_int(_str(exec(cmd)).trim())
    if hits > 0 {
        return "HX4-L5|error|외부 테스트 프레임워크 " + to_string(hits) + "건 (// @allow-ext-test)"
    }
    return ""
}

// L6 CI = hexa — .github/workflows run: 스텝이 hexa 기반이어야
fn _hx4_l6_ci(path: string) -> string {
    if !path.starts_with(".github/workflows/") { return "" }
    let e = ext_of(path)
    if e != ".yml" && e != ".yaml" { return "" }
    let full = REPO_ROOT + "/" + path
    // run: 으로 시작하는 라인 중 hexa/./hexa 로 이어지지 않는 것 + uses:/setup-*/checkout 예외
    let cmd = "grep -E '^[[:space:]]+run:[[:space:]]' '" + full + "' 2>/dev/null | grep -vE 'run:[[:space:]]*(hexa|\\./hexa|\\$\\{|echo |true$)|@allow-non-hexa-step' | wc -l"
    let hits = to_int(_str(exec(cmd)).trim())
    if hits > 0 {
        return "HX4-L6|warn|CI run: 스텝 " + to_string(hits) + "건 비-hexa (// @allow-non-hexa-step)"
    }
    return ""
}

// L7 빌드 재귀 — 체인 파일 존재 + 최소 크기 + SSOT↔산출물 일치
fn _hx4_l7_build_chain(path: string) -> string {
    if path != "build_hexa.hexa" && path != "self/main.hexa" && path != "self/hexa_full.hexa" && path != "scripts/build/build_hexa.hexa" && path != "self/hexa_full.json" { return "" }
    let stage0 = REPO_ROOT + "/build/hexa_stage0"
    if !file_exists(stage0) {
        return "HX4-L7|error|build/hexa_stage0 부재 — 빌드 체인 깨짐"
    }
    // stage0 바이너리 최소 크기 100KB (codesign 된 실행파일 하한)
    let sz = to_int(_str(exec("stat -f '%z' '" + stage0 + "' 2>/dev/null || stat -c '%s' '" + stage0 + "' 2>/dev/null || echo 0")).trim())
    if sz < 102400 {
        return "HX4-L7|error|build/hexa_stage0 크기 " + to_string(sz) + " 바이트 < 100KB — 빌드 산출물 의심"
    }
    if !file_exists(REPO_ROOT + "/self/main.hexa") {
        return "HX4-L7|error|self/main.hexa 부재"
    }
    if !file_exists(REPO_ROOT + "/self/hexa_full.hexa") {
        return "HX4-L7|error|self/hexa_full.hexa 부재"
    }
    // hexa_full.hexa mtime > hexa_stage0 mtime 이면 재빌드 필요 — warn
    let src_mt = to_int(_str(exec("stat -f '%m' '" + REPO_ROOT + "/self/hexa_full.hexa' 2>/dev/null || stat -c '%Y' '" + REPO_ROOT + "/self/hexa_full.hexa' 2>/dev/null || echo 0")).trim())
    let bin_mt = to_int(_str(exec("stat -f '%m' '" + stage0 + "' 2>/dev/null || stat -c '%Y' '" + stage0 + "' 2>/dev/null || echo 0")).trim())
    if src_mt > bin_mt {
        return "HX4-L7|warn|self/hexa_full.hexa (mtime " + to_string(src_mt) + ") > build/hexa_stage0 (mtime " + to_string(bin_mt) + ") — 재빌드 필요"
    }
    return ""
}

// L8 메타 = hexa AST transform — sed/awk 로 .hexa 조작 금지
fn _hx4_l8_meta(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" { return "" }
    let full = REPO_ROOT + "/" + path
    let cmd = "grep -E 'exec\\([^)]*\"(sed|awk)[^\"]*\\.hexa' '" + full + "' 2>/dev/null | grep -v '@allow-meta-scripting' | wc -l"
    let hits = to_int(_str(exec(cmd)).trim())
    if hits > 0 {
        return "HX4-L8|error|sed/awk .hexa 조작 " + to_string(hits) + "건. AST transform 은 hexa 로만 (// @allow-meta-scripting)"
    }
    return ""
}

// ─── VD1 (void 전용) — Terminal.app 단일 참조 강제 (타 터미널 에뮬레이터 언급 금지) ───
fn check_vd1(path: string) -> string {
    if _project_name() != "void" { return "" }
    let e = ext_of(path)
    if e != ".hexa" && e != ".c" && e != ".m" && e != ".h" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.starts_with("docs/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    if path.starts_with("shared/harness/") { return "" }
    if path.starts_with("shared/rules/") { return "" }
    if path.index_of("CLAUDE.md") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    let cmd = "grep -E '\\b(iTerm2|kitty|Warp|Ghostty|Alacritty|WezTerm|Hyper)\\b' '" + full + "' 2>/dev/null | grep -v '@allow-terminal-mention' | wc -l"
    let hits = to_int(_str(exec(cmd)).trim())
    if hits > 0 {
        return "VD1|error|외부 터미널 에뮬레이터 언급 " + to_string(hits) + "건 — Terminal.app 단일 참조 원칙 (// @allow-terminal-mention)"
    }
    return ""
}

// ─── VD2 (void 전용) — 복잡도 동결 (monotonic complexity gate) ───
// 원칙: 기능 추가 OK, 기존 기능의 복잡도 증가 금지.
//       감소/유지 → silent pass. 증가 → error + 마커 요구.
// 지표:
//   C1: 함수 파라미터 합계 (fn NAME(...) arity 총합)
//   C3: CLI 플래그 개수 ("--flag" 유니크 수)
// 비교: git show HEAD:<path>  vs  working copy
// 예외: // @allow-complexity-growth, archive/, docs/, tests/, shared/harness|rules/
fn check_vd2(path: string) -> string {
    if _project_name() != "void" { return "" }
    let e = ext_of(path)
    if e != ".hexa" && e != ".c" && e != ".h" && e != ".m" && e != ".swift" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.starts_with("docs/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    if path.starts_with("shared/harness/") { return "" }
    if path.starts_with("shared/rules/") { return "" }
    if path.starts_with("tests/") { return "" }
    if path.index_of("/test/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    // 파일 전체에 예외 마커 있으면 스킵
    let marker = to_int(_str(exec("grep -c '@allow-complexity-growth' '" + full + "' 2>/dev/null || echo 0")).trim())
    if marker > 0 { return "" }
    // HEAD 에 파일 없으면 신규 파일 — 복잡도 비교 대상 아님 (신규 기능은 허용)
    let exists_head = _str(exec("git cat-file -e HEAD:'" + path + "' 2>/dev/null && echo y || echo n")).trim()
    if exists_head == "n" { return "" }

    // C1: fn 시그니처 파라미터 합계 — comma 수 + nonempty 1
    let awk = " | awk -F'[(),]' '{ n=0; for(i=2;i<=NF;i++) if($i ~ /[[:alnum:]]/) n++; sum+=n } END { print sum+0 }'"
    let c1_after  = to_int(_str(exec("grep -oE 'fn [a-zA-Z_][a-zA-Z0-9_]*\\([^)]*\\)' '" + full + "' 2>/dev/null" + awk)).trim())
    let c1_before = to_int(_str(exec("git show HEAD:'" + path + "' 2>/dev/null | grep -oE 'fn [a-zA-Z_][a-zA-Z0-9_]*\\([^)]*\\)' 2>/dev/null" + awk)).trim())
    if c1_after > c1_before {
        return "VD2-C1|error|함수 파라미터 합계 " + to_string(c1_before) + " → " + to_string(c1_after) + " 증가 — 복잡도 동결 위반 (// @allow-complexity-growth)"
    }
    // C3: CLI 플래그 유니크 수 (--flag 리터럴)
    let c3_after  = to_int(_str(exec("grep -oE '\"--[a-z][a-z0-9-]*\"' '" + full + "' 2>/dev/null | sort -u | wc -l")).trim())
    let c3_before = to_int(_str(exec("git show HEAD:'" + path + "' 2>/dev/null | grep -oE '\"--[a-z][a-z0-9-]*\"' 2>/dev/null | sort -u | wc -l")).trim())
    if c3_after > c3_before {
        return "VD2-C3|error|CLI 플래그 유니크 수 " + to_string(c3_before) + " → " + to_string(c3_after) + " 증가 — 복잡도 동결 위반 (// @allow-complexity-growth)"
    }
    return ""
}

// ─── PP2 (papers 전용) — 논문 .md 에 검증코드 ```python 블록 필수 ───
fn check_pp2(path: string) -> string {
    if _project_name() != "papers" { return "" }
    let e = ext_of(path)
    if e != ".md" { return "" }
    let bn = basename_of(path)
    // CLAUDE.md/README/LICENSE 는 논문 아님
    if bn == "CLAUDE.md" || bn == "README.md" || bn == "LICENSE.md" { return "" }
    // archive/_archive 예외
    if path.starts_with("archive/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    // 코드 블록 존재 확인 — python 또는 hexa 실행 블록
    let has = to_int(_str(exec("grep -cE '^\\`\\`\\`(python|hexa)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if has == 0 {
        return "PP2|warn|논문 .md 에 ```python 또는 ```hexa 검증코드 블록 없음 (// @allow-unverified-paper)"
    }
    return ""
}

// ─── PP1 (papers 전용) — CC-BY 4.0 라이선스 통일 ───
// 공리: papers/ 내 논문 .md 는 헤더 30줄 내 CC-BY 4.0 라이선스 선언 필수.
// 허용 표현: "CC-BY 4.0", "CC-BY-4.0", "Creative Commons Attribution 4.0", "CC BY 4.0"
// 예외: CLAUDE.md, README.md, LICENSE.md, CHANGELOG.md, archive/, // @allow-no-license
fn check_pp1(path: string) -> string {
    if _project_name() != "papers" { return "" }
    let e = ext_of(path)
    if e != ".md" { return "" }
    let bn = basename_of(path)
    if bn == "CLAUDE.md" || bn == "README.md" || bn == "LICENSE.md" || bn == "CHANGELOG.md" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    let marker = to_int(_str(exec("grep -c '@allow-no-license' '" + full + "' 2>/dev/null || echo 0")).trim())
    if marker > 0 { return "" }
    // 헤더 30줄 내 CC-BY 4.0 라이선스 선언
    let has = to_int(_str(exec("head -30 '" + full + "' 2>/dev/null | grep -ciE '(CC[- ]?BY[- ]?4\\.0|Creative Commons Attribution 4\\.0)' || echo 0")).trim())
    if has == 0 {
        return "PP1|error|논문 '" + bn + "' 헤더에 CC-BY 4.0 라이선스 선언 없음 (// @allow-no-license)"
    }
    return ""
}

// ─── AG4 (airgenome 전용) — Hetzner launcher cap ≤8 강제 ───
fn check_ag4(path: string) -> string {
    if _project_name() != "airgenome" { return "" }
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" && e != ".json" && e != ".jsonl" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.starts_with("shared/harness/") { return "" }
    let full = REPO_ROOT + "/" + path
    // launcher_max 또는 LAUNCHER_MAX 상수가 9+ 로 설정된 경우 error
    let cmd = "grep -nE '(launcher_max|LAUNCHER_MAX|hetzner_launcher_cap)[[:space:]]*[=:][[:space:]]*([9-9]|[1-9][0-9]+)\\b' '" + full + "' 2>/dev/null | grep -v '@allow-launcher-cap' | wc -l"
    let hits = to_int(_str(exec(cmd)).trim())
    if hits > 0 {
        return "AG4|error|launcher cap > 8 설정 " + to_string(hits) + "건 — Hetzner 동시 실행 ≤8 강제 (// @allow-launcher-cap)"
    }
    return ""
}

// ─── AG5 (airgenome 전용) — 'filter' 네이밍 규율 ───
// 공리 (L0 골화 2026-04-12): filter = raw bytes → 다른 byte 표현 transform.
//       hot path 속도/메모리/IO 개선. cleanup/dedup/gzip/cron/sync/watcher/
//       throttle/kickstart 는 filter 아님 (별도 이름 사용).
// L1 (AG5-N1): 파일명에 'filter' 포함 → 헤더 주석에 raw + byte + (round-trip|latency|encode|decode) 키워드 필수
// L3 (AG5-N3): 파일명에 'filter' 와 금지 보조작업 키워드가 동시 포함 → rename
// 예외: // @allow-non-filter, archive/, shared/harness/, docs/
fn check_ag5(path: string) -> string {
    if _project_name() != "airgenome" { return "" }
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.starts_with("shared/harness/") { return "" }
    if path.starts_with("docs/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    let bn = basename_of(path)
    // filter 미포함 파일은 무관
    if bn.index_of("filter") < 0 { return "" }
    let full = REPO_ROOT + "/" + path
    // 예외 마커
    let marker = to_int(_str(exec("grep -c '@allow-non-filter' '" + full + "' 2>/dev/null || echo 0")).trim())
    if marker > 0 { return "" }
    // AG5-N3: filter + 보조작업 키워드 동시 파일명 금지
    let bad = to_int(_str(exec("echo '" + bn + "' | grep -cE '(cleanup|dedup|gzip|cron|sync|watcher|throttle|kickstart)'")).trim())
    if bad > 0 {
        return "AG5-N3|error|파일명 '" + bn + "' 에 filter + 보조작업 키워드 공존 — rename 필요 (// @allow-non-filter)"
    }
    // AG5-N1: 헤더(상위 40줄) 주석에 raw + byte + (round-trip|latency|encode|decode) 필수
    let head_has_raw  = to_int(_str(exec("head -40 '" + full + "' 2>/dev/null | grep -ciE '\\braw\\b' || echo 0")).trim())
    let head_has_byte = to_int(_str(exec("head -40 '" + full + "' 2>/dev/null | grep -ciE '\\bbytes?\\b' || echo 0")).trim())
    let head_has_rt   = to_int(_str(exec("head -40 '" + full + "' 2>/dev/null | grep -ciE '(round-?trip|latency|encode|decode)' || echo 0")).trim())
    if head_has_raw == 0 || head_has_byte == 0 || head_has_rt == 0 {
        return "AG5-N1|error|'" + bn + "' filter 헤더 주석 부적합 — raw + byte + (round-trip/latency/encode/decode) 키워드 필수 (// @allow-non-filter)"
    }
    return ""
}

// ─── N62-A (n6-architecture 전용) — 논문 md 에 ```python 검증코드 블록 필수 ───
// 원칙: 논문 = 검증 .py 코드를 ```python 코드블록으로 직접 embed. hexa 블록은 무관.
// Scope: papers/*.md, domains/*/paper/*.md
// 예외: CLAUDE/README, _index 계열, archive/, // @allow-no-verify
fn check_n62a(path: string) -> string {
    if _project_name() != "n6-architecture" { return "" }
    let e = ext_of(path)
    if e != ".md" { return "" }
    let bn = basename_of(path)
    if bn == "CLAUDE.md" || bn == "README.md" || bn == "LICENSE.md" || bn == "CHANGELOG.md" { return "" }
    if bn.starts_with("_") { return "" }
    let is_paper = path.starts_with("papers/") || (path.starts_with("domains/") && path.index_of("/paper/") >= 0)
    if !is_paper { return "" }
    if path.starts_with("archive/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    let marker = to_int(_str(exec("grep -c '@allow-no-verify' '" + full + "' 2>/dev/null || echo 0")).trim())
    if marker > 0 { return "" }
    // ```python 블록 (python만, hexa 제외)
    let has = to_int(_str(exec("grep -cE '^\\`\\`\\`python(\\b|$)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if has == 0 {
        return "N62-A|error|논문 '" + bn + "' 에 \\`\\`\\`python 검증코드 블록 없음 — .py 코드 직접 embed 필수 (// @allow-no-verify)"
    }
    return ""
}

// ─── N6 논문 canonical 양식 공통 scope 헬퍼 ───
// True 이면 n6 canonical 검사 대상 (papers/* 또는 domains/* 의 .md, _archive 제외)
fn _n6_canonical_in_scope(path: string) -> bool {
    if _project_name() != "n6-architecture" { return false }
    let e = ext_of(path)
    if e != ".md" { return false }
    let bn = basename_of(path)
    if bn == "CLAUDE.md" || bn == "README.md" || bn == "LICENSE.md" || bn == "CHANGELOG.md" { return false }
    if bn.starts_with("_") { return false }
    if path.starts_with("archive/") { return false }
    if path.index_of("/_archive/") >= 0 { return false }
    if path.index_of("/archive/") >= 0 { return false }
    let in_papers = path.starts_with("papers/")
    let in_domains = path.starts_with("domains/")
    if !in_papers && !in_domains { return false }
    return true
}

// 파일 전체에 canonical 양식 면제 마커가 있으면 true
fn _n6_canonical_exempt(full: string) -> bool {
    let m = to_int(_str(exec("grep -c '@allow-paper-canonical' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return true }
    return false
}

// ─── N61-C1 (n6-architecture) — 7 섹션 헤더 모두 존재 ───
// §1 WHY / §2 COMPARE / §3 REQUIRES / §4 STRUCT / §5 FLOW / §6 EVOLVE / §7 VERIFY
fn check_n61_c1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let mut missing = ""
    let mut miss_count: i64 = 0
    // §1 WHY: 당신의 삶 / Real-world / 실생활 효과
    let s1 = to_int(_str(exec("grep -cE '당신의 삶|Real-world|실생활 효과' '" + full + "' 2>/dev/null || echo 0")).trim())
    if s1 == 0 { missing = missing + " WHY"; miss_count = miss_count + 1 }
    // §2 COMPARE: (성능 비교 OR Comparison) AND ASCII
    let s2a = to_int(_str(exec("grep -cE '성능 비교|Comparison' '" + full + "' 2>/dev/null || echo 0")).trim())
    let s2b = to_int(_str(exec("grep -cE 'ASCII' '" + full + "' 2>/dev/null || echo 0")).trim())
    if s2a == 0 || s2b == 0 { missing = missing + " COMPARE"; miss_count = miss_count + 1 }
    // §3 REQUIRES: 필요한 요소 OR Requires OR 선행.*도메인
    let s3r = to_int(_str(exec("grep -cE '필요한 요소|Requires|선행.*도메인' '" + full + "' 2>/dev/null || echo 0")).trim())
    if s3r == 0 { missing = missing + " REQUIRES"; miss_count = miss_count + 1 }
    // §4 STRUCT: (시스템 구조 OR System.*Architecture OR 구조도) AND ASCII
    let s3a = to_int(_str(exec("grep -cE '시스템 구조|System.*Architecture|구조도' '" + full + "' 2>/dev/null || echo 0")).trim())
    if s3a == 0 || s2b == 0 { missing = missing + " STRUCT"; miss_count = miss_count + 1 }
    // §5 FLOW: (플로우 OR Flow OR 데이터.*에너지) AND ASCII
    let s4a = to_int(_str(exec("grep -cE '플로우|Flow|데이터.*에너지' '" + full + "' 2>/dev/null || echo 0")).trim())
    if s4a == 0 || s2b == 0 { missing = missing + " FLOW"; miss_count = miss_count + 1 }
    // §6 EVOLVE: Mk.I OR 진화 OR Evolution
    let s5 = to_int(_str(exec("grep -cE 'Mk\\.?I|진화|Evolution' '" + full + "' 2>/dev/null || echo 0")).trim())
    if s5 == 0 { missing = missing + " EVOLVE"; miss_count = miss_count + 1 }
    // §7 VERIFY: Python 검증 OR ```python
    let s6 = to_int(_str(exec("grep -cE 'Python 검증|^\\`\\`\\`python' '" + full + "' 2>/dev/null || echo 0")).trim())
    if s6 == 0 { missing = missing + " VERIFY"; miss_count = miss_count + 1 }
    if miss_count == 0 { return "" }
    return "N61-C1|error|논문 7섹션 누락 " + to_string(miss_count) + "건 (WHY/COMPARE/REQUIRES/STRUCT/FLOW/EVOLVE/VERIFY 중" + missing + ") (// @allow-paper-canonical)"
}

// ─── N61-A1 (n6-architecture) — 모든 ## 섹션 body 비어있지 않음 ───
// 각 ## 헤더 후 다음 ## 전까지: 비어있지 않은 줄 ≥ 3 OR 코드/리스트/표/details ≥ 1
fn check_n61_a1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    // 라인 단위 마커는 awk 가 검출
    let awk = "awk 'BEGIN{title=\"\";line=0;ne=0;blk=0;empty=0;empty_line=0;empty_title=\"\"} /^## / { if(title!=\"\" && ne<3 && blk==0 && skip==0){empty=1; empty_title=title; empty_line=line; exit} title=substr($0,4); line=NR; ne=0; blk=0; skip=0; next } /@allow-empty-section/ { skip=1 } /^\\`\\`\\`/ || /^[[:space:]]*[-*+] / || /^[[:space:]]*[0-9]+\\. / || /^\\|/ || /^<details/ { blk++ } NF>0 && !/^## / { ne++ } END { if(empty){print empty_line\"|\"empty_title} else if(title!=\"\" && ne<3 && blk==0 && skip==0){print line\"|\"title} }' '" + full + "' 2>/dev/null"
    let res = _str(exec(awk)).trim()
    if res == "" { return "" }
    let bar = res.index_of("|")
    if bar < 0 { return "" }
    let lnum = res.substring(0, bar)
    let title = res.substring(bar + 1, len(res))
    return "N61-A1|error|섹션 '" + title + "' (line " + lnum + ") 비어있음 — 3줄 또는 블록/리스트/표 필수 (// @allow-empty-section)"
}

// ─── N61-B1 (n6-architecture) — ASCII 코드블록에 박스 경계 필수 ───
// 코드블록 (``` ... ```) 전체에서 ┌└ 또는 ╭╰ 경계가 한 코드블록 단위로 있어야
// 단순화: ASCII 섹션 (§2/§3/§4) 영역 내 코드블록 ≥1 + 박스 경계 ≥1
fn check_n61_b1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let m = to_int(_str(exec("grep -c '@allow-ascii-freeform' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    // 각 코드블록 단위로 box 경계 검증 — ascii 의도가 보이는 코드블록만 (─/│/┌/└/╭/╰/├/┼ 등 박스문자 1+)
    // index() 사용 — BSD awk 의 [...] 멀티바이트 false positive 우회
    let awk = "awk 'BEGIN{inblk=0;has_top=0;has_bot=0;has_box=0;bad=0;blkline=0} /^\\`\\`\\`/ { if(inblk){ if(has_box && (has_top==0 || has_bot==0)){bad=blkline; exit}; inblk=0; has_top=0; has_bot=0; has_box=0 } else { inblk=1; blkline=NR; has_top=0; has_bot=0; has_box=0 }; next } inblk { if(index($0,\"┌\")||index($0,\"╭\")) has_top=1; if(index($0,\"└\")||index($0,\"╰\")) has_bot=1; if(index($0,\"┌\")||index($0,\"└\")||index($0,\"╭\")||index($0,\"╰\")||index($0,\"├\")||index($0,\"┼\")||index($0,\"│\")||index($0,\"─\")) has_box=1 } END{print bad+0}' '" + full + "' 2>/dev/null"
    let bad = to_int(_str(exec(awk)).trim())
    if bad > 0 {
        return "N61-B1|error|ASCII 코드블록 (line " + to_string(bad) + ") 박스 경계(┌└ or ╭╰) 없음 (// @allow-ascii-freeform)"
    }
    return ""
}

// ─── N61-B2 (n6-architecture) — §2 COMPARE 에 █ 바 차트 ≥3줄 ───
fn check_n61_b2(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    // §2 = '성능 비교' 또는 'Comparison' 헤더
    // 헤더부터 다음 ## 까지에서 █ 포함 라인 카운트
    let awk = "awk '/^## .*(성능 비교|Comparison)/ { in_s=1; next } /^## / { in_s=0 } in_s && /█/ { c++ } END{print c+0}' '" + full + "' 2>/dev/null"
    let bars = to_int(_str(exec(awk)).trim())
    // §2 자체가 없으면 N61-C1 가 잡음 — 여기는 있는 경우만
    let has_s2 = to_int(_str(exec("grep -cE '^## .*(성능 비교|Comparison)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if has_s2 == 0 { return "" }
    if bars < 3 {
        return "N61-B2|error|§2 COMPARE 에 █ 바 차트 < 3줄 (현재 " + to_string(bars) + ") (// @allow-paper-canonical)"
    }
    return ""
}

// ─── N61-B3 (n6-architecture) — §3 STRUCT 에 ├ 또는 ┼ ≥1 ───
fn check_n61_b3(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let has_s3 = to_int(_str(exec("grep -cE '^## .*(시스템 구조|System.*Architecture|구조도)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if has_s3 == 0 { return "" }
    let awk = "awk '/^## .*(시스템 구조|System.*Architecture|구조도)/ { in_s=1; next } /^## / { in_s=0 } in_s && (index($0,\"├\") || index($0,\"┼\")) { c++ } END{print c+0}' '" + full + "' 2>/dev/null"
    let cnt = to_int(_str(exec(awk)).trim())
    if cnt == 0 {
        return "N61-B3|error|§3 STRUCT 에 ├ 또는 ┼ 분할 없음 (// @allow-paper-canonical)"
    }
    return ""
}

// ─── N61-B4 (n6-architecture) — §4 FLOW 에 ▼ 또는 → ≥3건 ───
fn check_n61_b4(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let has_s4 = to_int(_str(exec("grep -cE '^## .*(플로우|Flow|데이터.*에너지)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if has_s4 == 0 { return "" }
    let awk = "awk '/^## .*(플로우|Flow|데이터.*에너지)/ { in_s=1; next } /^## / { in_s=0 } in_s { n1=gsub(/▼/,\"X\"); n2=gsub(/→/,\"X\"); c+=n1+n2 } END{print c+0}' '" + full + "' 2>/dev/null"
    let cnt = to_int(_str(exec(awk)).trim())
    if cnt < 3 {
        return "N61-B4|error|§4 FLOW 에 ▼ 또는 → < 3건 (현재 " + to_string(cnt) + ") (// @allow-paper-canonical)"
    }
    return ""
}

// ─── N61-Mk1 (n6-architecture) — Mk 진화 섹션 존재 ───
fn check_n61_mk1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let has = to_int(_str(exec("grep -cE '^## .*(Mk\\.?I.*진화|Evolution|Mk[[:space:]]*진화)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if has == 0 {
        return "N61-Mk1|error|Mk 진화 섹션(## .*Mk.I.*진화 OR Evolution) 없음 (// @allow-paper-canonical)"
    }
    return ""
}

// ─── N61-Mk3 (n6-architecture) — Mk 진화 §5 내 <details> 래핑 + open 정확 1개 ───
fn check_n61_mk3(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let m = to_int(_str(exec("grep -c '@allow-mk-freeform' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    // §5 영역에서 details 와 mk 헤더 카운트
    let awk = "awk '/^## .*(Mk\\.?I.*진화|Evolution|Mk[[:space:]]*진화)/ { in_s=1; next } /^## / { in_s=0 } in_s { if(/<details/) det++; if(/<details[^>]*open/) opn++; if(/^### .*Mk\\.?[IVX0-9]+/) mk++ } END{print det+0\"|\"opn+0\"|\"mk+0}' '" + full + "' 2>/dev/null"
    let res = _str(exec(awk)).trim()
    if res == "" { return "" }
    let parts = res.split("|")
    if len(parts) < 3 { return "" }
    let det = to_int(_str(parts[0]))
    let opn = to_int(_str(parts[1]))
    let mk = to_int(_str(parts[2]))
    // mk 헤더가 0 이면 §5 자체가 비어 — N61-Mk1/A1 에서 잡음
    if mk == 0 { return "" }
    if det != mk {
        return "N61-Mk3|error|Mk 헤더 " + to_string(mk) + "개 vs <details> " + to_string(det) + "개 — 모든 Mk 는 <details> 래핑 필수 (// @allow-mk-freeform)"
    }
    if opn != 1 {
        return "N61-Mk3|error|<details open> 개수 " + to_string(opn) + " (정확히 1개 필요 — 최신 Mk 만 펼침) (// @allow-mk-freeform)"
    }
    return ""
}

// ─── N61-Mk4 (n6-architecture) — 첫 <details> 가 open 이어야 (최신이 맨 위) ───
fn check_n61_mk4(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let m = to_int(_str(exec("grep -c '@allow-mk-freeform' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    // §5 안에서 첫 번째 <details> 라인 추출
    let awk = "awk '/^## .*(Mk\\.?I.*진화|Evolution|Mk[[:space:]]*진화)/ { in_s=1; next } /^## / { in_s=0 } in_s && /<details/ { print; exit }' '" + full + "' 2>/dev/null"
    let first = _str(exec(awk)).trim()
    if first == "" { return "" }
    if first.index_of("open") < 0 {
        return "N61-Mk4|error|Mk 진화 순서 위반 — 첫 <details> 에 open 속성 없음 (최신 Mk 가 맨 위) (// @allow-mk-freeform)"
    }
    return ""
}

// ─── N61-R1 (n6-architecture) — §3 REQUIRES body 에 🛸 지수 ≥2 + 도메인 링크 ≥1 ───
fn check_n61_r1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let m = to_int(_str(exec("grep -c '@allow-no-requires' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    // §3 REQUIRES 헤더 있을 때만 body 검증 (헤더 없음은 N61-C1 가 잡음)
    let has = to_int(_str(exec("grep -cE '^## .*(필요한 요소|Requires|선행.*도메인)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if has == 0 { return "" }
    // body: 헤더 직후 ~ 다음 ## 전까지
    // 🛸N 패턴 카운트 (🛸 다음 숫자 1자 이상)
    let awk_ufo = "awk '/^## .*(필요한 요소|Requires|선행.*도메인)/ { in_s=1; next } /^## / { in_s=0 } in_s { n=gsub(/🛸[0-9]/,\"X\"); c+=n } END{print c+0}' '" + full + "' 2>/dev/null"
    let ufo_cnt = to_int(_str(exec(awk_ufo)).trim())
    if ufo_cnt < 2 {
        return "N61-R1|error|§3 REQUIRES 에 🛸 지수 ≥2건 없음 (현재 " + to_string(ufo_cnt) + ") / '🛸N → 🛸M' 형식 필수 (// @allow-no-requires)"
    }
    // 링크 또는 table row 카운트 — 둘 중 하나라도 ≥1
    // 링크: [text](path.md) — body 내
    let awk_lnk = "awk '/^## .*(필요한 요소|Requires|선행.*도메인)/ { in_s=1; next } /^## / { in_s=0 } in_s && /\\[[^]]*\\]\\([^)]*\\.md[^)]*\\)/ { c++ } END{print c+0}' '" + full + "' 2>/dev/null"
    let lnk_cnt = to_int(_str(exec(awk_lnk)).trim())
    // table row with 🛸: ^|...🛸...|
    let awk_row = "awk '/^## .*(필요한 요소|Requires|선행.*도메인)/ { in_s=1; next } /^## / { in_s=0 } in_s && /^\\|/ && /🛸/ { c++ } END{print c+0}' '" + full + "' 2>/dev/null"
    let row_cnt = to_int(_str(exec(awk_row)).trim())
    if lnk_cnt == 0 && row_cnt == 0 {
        return "N61-R1|error|§3 REQUIRES 에 도메인 링크 ≥1 없음 / [domain](../path/to.md) 필수 (// @allow-no-requires)"
    }
    return ""
}

// ─── N61-R2 (n6-architecture) — frontmatter requires ↔ §3 REQUIRES 표 sync ───
fn check_n61_r2(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let m = to_int(_str(exec("grep -c '@allow-no-requires-sync' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    // 1. frontmatter 블록 (---...---) 안 'to:' 라인 카운트 + 이름 추출
    // awk: 첫 ---  ~  두번째 --- 사이에서만 ^[[:space:]]*-?[[:space:]]*to:[[:space:]]*<name>
    let awk_to = "awk 'NR==1 && /^---[[:space:]]*$/ { in_fm=1; next } in_fm && /^---[[:space:]]*$/ { in_fm=0; exit } in_fm && /^[[:space:]]*-?[[:space:]]*to:[[:space:]]*/ { sub(/^[[:space:]]*-?[[:space:]]*to:[[:space:]]*/,\"\"); sub(/[[:space:]]*#.*$/,\"\"); sub(/[[:space:]]+$/,\"\"); gsub(/^[\"\\x27]|[\"\\x27]$/,\"\"); print }' '" + full + "' 2>/dev/null"
    let to_raw = _str(exec(awk_to)).trim()
    if to_raw == "" {
        // frontmatter 자체가 없거나 requires 없음 — skip pass
        return ""
    }
    let to_lines = to_raw.split("\n")
    let mut fm_count: i64 = 0
    let mut name_idx: i64 = 0
    for tn in to_lines {
        let s = _str(tn).trim()
        if s == "" { continue }
        fm_count = fm_count + 1
        name_idx = name_idx + 1
    }
    if fm_count == 0 { return "" }
    // 2. §3 REQUIRES body 내 테이블 행 카운트 (헤더/구분선 제외)
    // 구분선: ^\|[\s\-:|]+$
    let awk_rows = "awk '/^## .*(필요한 요소|Requires|선행.*도메인)/ { in_s=1; next } /^## / { in_s=0 } in_s && /^\\|/ { if($0 ~ /^\\|[[:space:]\\-:|]+$/) next; c++ } END{print c+0}' '" + full + "' 2>/dev/null"
    let row_cnt = to_int(_str(exec(awk_rows)).trim())
    // 데이터 행 = 전체 행 - 헤더 1줄
    let mut data_rows = row_cnt - 1
    if data_rows < 0 { data_rows = 0 }
    if data_rows != fm_count {
        return "N61-R2|error|frontmatter requires (" + to_string(fm_count) + "개) ≠ §3 REQUIRES 표 (" + to_string(data_rows) + "개) sync 실패 (// @allow-no-requires-sync)"
    }
    // 3. 각 to: 이름이 §3 body 에 문자열로 ≥1회 등장
    // §3 body 추출
    let awk_body = "awk '/^## .*(필요한 요소|Requires|선행.*도메인)/ { in_s=1; next } /^## / { in_s=0 } in_s { print }' '" + full + "' 2>/dev/null"
    let body = _str(exec(awk_body))
    for tn in to_lines {
        let nm = _str(tn).trim()
        if nm == "" { continue }
        if body.index_of(nm) < 0 {
            return "N61-R2|error|frontmatter 'to: " + nm + "' 이 §3 REQUIRES 에 없음 (// @allow-no-requires-sync)"
        }
    }
    return ""
}

// ─── N6-DAG-SYNC (n6-architecture) — frontmatter requires(to:) ↔ _dag.json edges sync ───
// scope: papers/* or domains/* .md (canonical scope)
// _dag.json 없으면 skip pass (build_dag 미실행 상태). 해당 도메인 노드가 없으면 error.
fn check_n6_dag_sync(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    if _n6_canonical_exempt(full) { return "" }
    let mk = to_int(_str(exec("grep -c '@allow-dag-sync' '" + full + "' 2>/dev/null || echo 0")).trim())
    if mk > 0 { return "" }
    let dag_path = REPO_ROOT + "/papers/_dag.json"
    let dag_exists = _str(exec("[ -f '" + dag_path + "' ] && echo y || echo n")).trim()
    if dag_exists != "y" { return "" }
    // jq 가용성 확인
    let has_jq = _str(exec("command -v jq >/dev/null 2>&1 && echo y || echo n")).trim()
    if has_jq != "y" {
        return "N6-DAG-SYNC|warn|jq 미설치 — DAG sync 검증 스킵 (// @allow-dag-sync)"
    }
    // 1. frontmatter domain 추출
    let awk_dom = "awk 'NR==1 && /^---[[:space:]]*$/ { in_fm=1; next } in_fm && /^---[[:space:]]*$/ { exit } in_fm && /^[[:space:]]*domain:[[:space:]]*/ { sub(/^[[:space:]]*domain:[[:space:]]*/,\"\"); sub(/[[:space:]]*#.*$/,\"\"); sub(/[[:space:]]+$/,\"\"); gsub(/^[\"\\x27]|[\"\\x27]$/,\"\"); print; exit }' '" + full + "' 2>/dev/null"
    let domain = _str(exec(awk_dom)).trim()
    if domain == "" { return "" }
    // 2. frontmatter to: 집합 (정렬 unique)
    let awk_to = "awk 'NR==1 && /^---[[:space:]]*$/ { in_fm=1; next } in_fm && /^---[[:space:]]*$/ { exit } in_fm && /^[[:space:]]*-?[[:space:]]*to:[[:space:]]*/ { sub(/^[[:space:]]*-?[[:space:]]*to:[[:space:]]*/,\"\"); sub(/[[:space:]]*#.*$/,\"\"); sub(/[[:space:]]+$/,\"\"); gsub(/^[\"\\x27]|[\"\\x27]$/,\"\"); print }' '" + full + "' 2>/dev/null | sort -u"
    let fm_to = _str(exec(awk_to)).trim()
    // 3. _dag.json 에서 해당 domain 의 outgoing edges to 집합
    let dag_to = _str(exec("jq -r --arg d '" + domain + "' '.edges[] | select(.from==$d) | .to' '" + dag_path + "' 2>/dev/null | sort -u")).trim()
    // 4. nodes 에 domain 자체 존재 여부 — 양쪽 다 비어있을 때 노드 없음 판단에 사용
    let node_exists = _str(exec("jq -r --arg d '" + domain + "' '[.nodes[] | select(.id==$d)] | length' '" + dag_path + "' 2>/dev/null")).trim()
    if node_exists == "" || node_exists == "0" {
        // 노드 없음. fm_to 도 비어있으면 양쪽 일치 (둘다 없음) → pass
        if fm_to == "" { return "" }
        return "N6-DAG-SYNC|error|" + domain + ": _dag.json nodes 에 노드 없음 / frontmatter requires 존재 → build_dag.hexa 재실행 필요 (// @allow-dag-sync)"
    }
    if fm_to == dag_to { return "" }
    let fm_disp = fm_to.replace("\n", ",")
    let dag_disp = dag_to.replace("\n", ",")
    return "N6-DAG-SYNC|error|" + domain + ": frontmatter requires [" + fm_disp + "] ≠ _dag.json edges [" + dag_disp + "] — build_dag.hexa 재실행 필요 (// @allow-dag-sync)"
}

// ─── N6-DAG-DANGLE (n6-architecture) — _dag.json edges.to 가 실재 paper 로 resolve ───
// scope: papers/_dag.json 이 staged 일 때만
fn check_n6_dag_dangle(path: string) -> string {
    if _project_name() != "n6-architecture" { return "" }
    if path != "papers/_dag.json" { return "" }
    let full = REPO_ROOT + "/" + path
    let mk = to_int(_str(exec("grep -c '@allow-dag-dangle' '" + full + "' 2>/dev/null || echo 0")).trim())
    if mk > 0 { return "" }
    let has_jq = _str(exec("command -v jq >/dev/null 2>&1 && echo y || echo n")).trim()
    if has_jq != "y" {
        return "N6-DAG-DANGLE|warn|jq 미설치 — DAG dangle 검증 스킵 (// @allow-dag-dangle)"
    }
    // 모든 edges.to (unique)
    let to_list = _str(exec("jq -r '.edges[].to' '" + full + "' 2>/dev/null | sort -u")).trim()
    if to_list == "" { return "" }
    let targets = to_list.split("\n")
    let mut dangling: [string] = []
    for t in targets {
        let nm = _str(t).trim()
        if nm == "" { continue }
        // node id 매칭
        let in_nodes = _str(exec("jq -r --arg d '" + nm + "' '[.nodes[] | select(.id==$d)] | length' '" + full + "' 2>/dev/null")).trim()
        if in_nodes != "" && in_nodes != "0" { continue }
        // papers/n6-<to>.md 존재
        let p1 = REPO_ROOT + "/papers/n6-" + nm + ".md"
        let e1 = _str(exec("[ -f '" + p1 + "' ] && echo y || echo n")).trim()
        if e1 == "y" { continue }
        // domains/**/<to>/<to>.md 존재
        let p2_check = _str(exec("ls " + REPO_ROOT + "/domains/*/" + nm + "/" + nm + ".md 2>/dev/null | head -1")).trim()
        if p2_check != "" { continue }
        // domains/**/<to>.md 일반 매칭
        let p3_check = _str(exec("find " + REPO_ROOT + "/domains -type f -name '" + nm + ".md' 2>/dev/null | head -1")).trim()
        if p3_check != "" { continue }
        dangling = dangling.push(nm)
    }
    if len(dangling) == 0 { return "" }
    let mut disp = ""
    let mut di: i64 = 0
    for d in dangling {
        if di > 0 { disp = disp + "," }
        disp = disp + _str(d)
        di = di + 1
    }
    return "N6-DAG-DANGLE|error|_dag.json: " + to_string(len(dangling)) + "개 dangling edge → " + disp + " (파일 없음 또는 nodes 누락) (// @allow-dag-dangle)"
}

// ─── N6-DAG-CYCLE (n6-architecture) — _dag.json edges 에 cycle 금지 ───
fn check_n6_dag_cycle(path: string) -> string {
    if _project_name() != "n6-architecture" { return "" }
    if path != "papers/_dag.json" { return "" }
    let full = REPO_ROOT + "/" + path
    let mk = to_int(_str(exec("grep -c '@allow-dag-cycle' '" + full + "' 2>/dev/null || echo 0")).trim())
    if mk > 0 { return "" }
    let has_jq = _str(exec("command -v jq >/dev/null 2>&1 && echo y || echo n")).trim()
    if has_jq != "y" {
        return "N6-DAG-CYCLE|warn|jq 미설치 — DAG cycle 검증 스킵 (// @allow-dag-cycle)"
    }
    // 1) _meta.cycles 우선 사용 (build_dag 가 미리 계산)
    let meta_cnt = _str(exec("jq -r '._meta.cycles | length // 0' '" + full + "' 2>/dev/null")).trim()
    if meta_cnt != "" && meta_cnt != "0" {
        // cycle 디스플레이 — 첫 3개
        let disp = _str(exec("jq -r '._meta.cycles | .[0:3] | map(if type==\"array\" then join(\"→\") else tostring end) | join(\" / \")' '" + full + "' 2>/dev/null")).trim()
        return "N6-DAG-CYCLE|error|_dag.json: cycle " + meta_cnt + "개 발견 → " + disp + " — 의존성 순환 불가 (// @allow-dag-cycle)"
    }
    // 2) _meta.cycles 없거나 비어있으면 직접 DFS — jq 로 토폴로지 시도
    // tsort 가용 시 사용 (BSD/macOS 기본 포함)
    let has_tsort = _str(exec("command -v tsort >/dev/null 2>&1 && echo y || echo n")).trim()
    if has_tsort != "y" { return "" }
    // edges 를 "from to\n" 페어로 출력
    let pair_out = _str(exec("jq -r '.edges[] | \"\\(.from) \\(.to)\"' '" + full + "' 2>/dev/null | tsort 2>&1 1>/dev/null | head -3")).trim()
    if pair_out == "" { return "" }
    // tsort 의 cycle 메시지: "tsort: cycle in data"
    if pair_out.index_of("cycle") < 0 { return "" }
    return "N6-DAG-CYCLE|error|_dag.json: cycle 발견 → " + pair_out.replace("\n", " / ") + " — 의존성 순환 불가 (// @allow-dag-cycle)"
}

// ─── VP-M1 (n6-architecture) — ```python 블록에 'MISSING DATA' 금지 ───
fn check_vp_m1(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    let m = to_int(_str(exec("grep -c '@allow-missing-data' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    let awk = "awk '/^\\`\\`\\`python/{in_p=1;next} /^\\`\\`\\`/{in_p=0} in_p && /MISSING DATA/{c++} END{print c+0}' '" + full + "' 2>/dev/null"
    let cnt = to_int(_str(exec(awk)).trim())
    if cnt > 0 {
        return "VP-M1|error|python 블록에 'MISSING DATA' 플레이스홀더 " + to_string(cnt) + "건 — 실제 검증 필수 (// @allow-missing-data)"
    }
    return ""
}

// ─── VP-M2 (n6-architecture) — ```python 블록에 (_, None, None, None) 튜플 금지 ───
fn check_vp_m2(path: string) -> string {
    if !_n6_canonical_in_scope(path) { return "" }
    let full = REPO_ROOT + "/" + path
    let m = to_int(_str(exec("grep -c '@allow-missing-data' '" + full + "' 2>/dev/null || echo 0")).trim())
    if m > 0 { return "" }
    let awk = "awk '/^\\`\\`\\`python/{in_p=1;next} /^\\`\\`\\`/{in_p=0} in_p && /,[[:space:]]*None[[:space:]]*,[[:space:]]*None[[:space:]]*,[[:space:]]*None/{c++} END{print c+0}' '" + full + "' 2>/dev/null"
    let cnt = to_int(_str(exec(awk)).trim())
    if cnt > 0 {
        return "VP-M2|error|python 블록에 (_, None, None, None) 플레이스홀더 " + to_string(cnt) + "건 — 실제 값 필수 (// @allow-missing-data)"
    }
    return ""
}

// ─── N6-JSONPAIR (n6-architecture) — 신규 도메인 문서 추가 시 papers/_registry.json 동반 ───
// staged 에 papers/n6-*.md 또는 domains/*/*.md (status=A) + papers/_registry.json 미변경 → error
// 파일별 호출이라 매번 같은 staged 상태를 검사. path 는 트리거 매칭에 사용.
fn check_n6_jsonpair(path: string) -> string {
    if _project_name() != "n6-architecture" { return "" }
    // 트리거: 이 파일이 staged 신규 문서일 때만 한 번 검사
    let bn = basename_of(path)
    if ext_of(path) != ".md" { return "" }
    let is_paper_md = path.starts_with("papers/n6-") && bn != "_registry.json"
    let is_domain_md = path.starts_with("domains/") && path.index_of("/_archive/") < 0
    if !is_paper_md && !is_domain_md { return "" }
    // 이 파일이 added 상태인지 확인
    let st = _str(exec("git diff --cached --name-status -- '" + path + "' 2>/dev/null | head -1")).trim()
    if !st.starts_with("A") { return "" }
    // 커밋 메시지 마커
    let msg = _str(exec("cat '" + REPO_ROOT + "/.git/COMMIT_EDITMSG' 2>/dev/null")).trim()
    if msg.index_of("@allow-no-registry-update") >= 0 { return "" }
    // papers/_registry.json 이 staged 변경 목록에 있는지 (M 또는 A)
    let reg = _str(exec("git diff --cached --name-only 2>/dev/null | grep -E '^papers/_registry\\.json$' | head -1")).trim()
    if reg != "" { return "" }
    return "N6-JSONPAIR|error|신규 도메인 문서 '" + path + "' 추가 시 papers/_registry.json 업데이트 필수 (// @allow-no-registry-update)"
}

// ─── AG6-S1 (airgenome 전용) — Mac 로컬 heavy compute 실행 전 원격 가드 필수 ───
// 원칙: 원격(ubu/htz/hetzner) 자원 가용 시 Mac heavy compute 0. Mac은 오케스트레이션 전용.
// 정적 탐지: heavy compute 호출(blowup/seed_engine/ouroboros) 이 파일에 존재하면
//          같은 파일에 원격 가드 참조(dispatch_state/infra_state/ssh ubu|htz|hetzner/
//          auto_dispatch/resource_ceiling/BLOWUP_LOCAL) 필수.
// 예외: archive/, shared/harness/, docs/, tests/, // @allow-local-heavy
fn check_ag6(path: string) -> string {
    if _project_name() != "airgenome" { return "" }
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.starts_with("shared/harness/") { return "" }
    if path.starts_with("docs/") { return "" }
    if path.starts_with("tests/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    if path.index_of("/test/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    let marker = to_int(_str(exec("grep -c '@allow-local-heavy' '" + full + "' 2>/dev/null || echo 0")).trim())
    if marker > 0 { return "" }
    // heavy compute 호출 패턴
    let heavy = to_int(_str(exec("grep -cE '(exec|spawn|system|sh|bash)[[:space:]]*\\([^)]*(blowup|seed_engine|ouroboros)|\\./blowup|hexa[^\"'\\''`]*blowup' '" + full + "' 2>/dev/null || echo 0")).trim())
    if heavy == 0 { return "" }
    // 원격 가드 참조 필수 (변수명 'guard' 는 hexa 예약어 — _remote_guard 사용)
    let _remote_guard = to_int(_str(exec("grep -cE '(dispatch_state|infra_state|ssh[^\"]*@(ubu|htz|hetzner)|auto_dispatch|resource_ceiling|BLOWUP_LOCAL)' '" + full + "' 2>/dev/null || echo 0")).trim())
    if _remote_guard == 0 {
        return "AG6-S1|error|Mac 로컬 heavy compute 호출 " + to_string(heavy) + "건 — 원격 가드(dispatch_state/infra_state/ssh ubu+htz+hetzner) 참조 없음 (// @allow-local-heavy)"
    }
    return ""
}

// ─── 프로젝트별 규칙 JSONL 자동 로드 엔진 ───
// 파일: shared/rules/<project>.lint.jsonl (한 줄 = 한 규칙)
// 지원 kind: grep, grep_combo, grep_any, ext_blacklist, ext_blacklist_in_path,
//           ext_whitelist, filename, require_entry
// 규칙 추가/변경은 JSONL 파일만 편집 (엔진 코드 불변)

fn _pr_field(line: string, key: string) -> string {
    let marker = "\"" + key + "\":\""
    let idx = line.index_of(marker)
    if idx < 0 { return "" }
    let after = line.substring(idx + len(marker), len(line))
    let end = after.index_of("\"")
    if end < 0 { return "" }
    return after.substring(0, end)
}

// "key":[...] 배열 값 추출 — 각 원소를 " 로 감싼 문자열로 반환
fn _pr_array(line: string, key: string) -> [string] {
    let mut arr: [string] = []
    let marker = "\"" + key + "\":["
    let idx = line.index_of(marker)
    if idx < 0 { return arr }
    let after = line.substring(idx + len(marker), len(line))
    let end = after.index_of("]")
    if end < 0 { return arr }
    let body = after.substring(0, end)
    // body 안의 "..." 추출
    let mut i: i64 = 0
    while i < len(body) {
        let q1 = body.index_of("\"")
        if q1 < 0 { break }
        let rest = body.substring(q1 + 1, len(body))
        let q2 = rest.index_of("\"")
        if q2 < 0 { break }
        let val = rest.substring(0, q2)
        arr = arr.push(val)
        let consumed = q1 + 1 + q2 + 1
        if consumed >= len(body) { break }
        // 진행: body 를 자르는 대신 local slicing
        let new_body = body.substring(consumed, len(body))
        return _pr_array_continue(new_body, arr)
    }
    return arr
}

fn _pr_array_continue(body: string, acc: [string]) -> [string] {
    let mut arr = acc
    let q1 = body.index_of("\"")
    if q1 < 0 { return arr }
    let rest = body.substring(q1 + 1, len(body))
    let q2 = rest.index_of("\"")
    if q2 < 0 { return arr }
    let val = rest.substring(0, q2)
    arr = arr.push(val)
    let consumed = q1 + 1 + q2 + 1
    if consumed >= len(body) { return arr }
    let next_body = body.substring(consumed, len(body))
    return _pr_array_continue(next_body, arr)
}

fn _ext_in(ext: string, list: [string]) -> bool {
    for e in list {
        if _str(e) == ext { return true }
    }
    return false
}

fn _any_in_path(path: string, parts: [string]) -> bool {
    for p in parts {
        let s = _str(p)
        if s != "" && path.index_of(s) >= 0 { return true }
    }
    return false
}

fn _any_excluded(path: string, exclude: [string]) -> bool {
    for e in exclude {
        let s = _str(e)
        if s != "" && path.index_of(s) >= 0 { return true }
    }
    return false
}

// kind=grep_combo: all[] 패턴이 전부 파일에 나타나면 위반
fn _match_grep_combo(full: string, patterns: [string], allow: string) -> bool {
    for p in patterns {
        let pat = _str(p)
        if pat == "" { continue }
        let cmd = "grep -E '" + pat + "' '" + full + "' 2>/dev/null | grep -v '" + allow + "' | head -1"
        let r = _str(exec(cmd)).trim()
        if r == "" { return false }
    }
    return true
}

// kind=grep_any: any[] 패턴이 하나라도 나타나면 위반
fn _match_grep_any(full: string, patterns: [string], allow: string) -> bool {
    for p in patterns {
        let pat = _str(p)
        if pat == "" { continue }
        let cmd = "grep -E '" + pat + "' '" + full + "' 2>/dev/null | grep -v '" + allow + "' | head -1"
        let r = _str(exec(cmd)).trim()
        if r != "" { return true }
    }
    return false
}

// kind=require_entry: entry_patterns 중 하나는 있어야 함 (없으면 위반)
fn _match_require_entry(full: string, patterns: [string]) -> bool {
    for p in patterns {
        let pat = _str(p)
        if pat == "" { continue }
        let cmd = "grep -cE '" + pat + "' '" + full + "' 2>/dev/null || echo 0"
        let c = to_int(_str(exec(cmd)).trim())
        if c > 0 { return false }
    }
    return true
}

fn check_project_rules(path: string) -> string {
    let project = _project_name()
    if project == "" { return "" }
    let rulefile = REPO_ROOT + "/shared/rules/" + project + ".lint.jsonl"
    if !file_exists(rulefile) { return "" }
    let raw = _str(exec("cat '" + rulefile + "' 2>/dev/null")).trim()
    if raw == "" { return "" }
    let full = REPO_ROOT + "/" + path
    let e = ext_of(path)
    for ln in raw.split("\n") {
        let line = _str(ln).trim()
        if line == "" { continue }
        if line.starts_with("//") { continue }
        let id = _pr_field(line, "id")
        let kind = _pr_field(line, "kind")
        let severity = _pr_field(line, "severity")
        let fix = _pr_field(line, "fix")
        let allow = _pr_field(line, "allow")
        if id == "" || kind == "" { continue }
        let exts = _pr_array(line, "ext")
        if len(exts) > 0 && !_ext_in(e, exts) { continue }
        let exclude = _pr_array(line, "exclude")
        if _any_excluded(path, exclude) { continue }
        let prefix = _pr_field(line, "path_prefix")
        if prefix != "" && !path.starts_with(prefix) { continue }
        let path_any = _pr_array(line, "path_any")
        if len(path_any) > 0 && !_any_in_path(path, path_any) { continue }
        let mut violated = false
        if kind == "grep_combo" {
            let pats = _pr_array(line, "all")
            if _match_grep_combo(full, pats, allow) { violated = true }
        }
        else if kind == "grep_any" {
            let pats = _pr_array(line, "any")
            if _match_grep_any(full, pats, allow) { violated = true }
        }
        else if kind == "ext_blacklist_in_path" {
            // 확장자 목록 + 경로 any 둘 다 매칭 시 위반 (path_any 이미 매칭됨 + 확장자 blacklist)
            let bl = _pr_array(line, "ext")
            if _ext_in(e, bl) { violated = true }
        }
        else if kind == "ext_blacklist" {
            let bl = _pr_array(line, "ext")
            if _ext_in(e, bl) { violated = true }
        }
        else if kind == "filename" {
            let deny = _pr_array(line, "deny")
            let bn = basename_of(path)
            for d in deny {
                if _str(d) == bn { violated = true; break }
            }
        }
        else if kind == "require_entry" {
            let pats = _pr_array(line, "entry_patterns")
            if _match_require_entry(full, pats) { violated = true }
        }
        if violated {
            return id + "|" + severity + "|" + fix
        }
    }
    return ""
}

// ─── BLOW1 (공통) — BLOWUP_LOCAL=1 절대 금지 ───
// Mac 로컬 blowup 우회 금지. hetzner 원격 강제.
// 예외: archive/, shared/harness/, // @allow-local-blowup
fn check_blow1(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" && e != ".json" && e != ".jsonl" && e != ".md" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.starts_with("shared/harness/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    let hit = to_int(_str(exec("grep -cE 'BLOWUP_LOCAL[[:space:]]*=[[:space:]]*1' '" + full + "' 2>/dev/null || echo 0")).trim())
    if hit > 0 {
        let filtered = to_int(_str(exec("grep -E 'BLOWUP_LOCAL[[:space:]]*=[[:space:]]*1' '" + full + "' 2>/dev/null | grep -v '@allow-local-blowup' | wc -l")).trim())
        if filtered > 0 {
            return "BLOW1|error|BLOWUP_LOCAL=1 절대 금지 " + to_string(filtered) + "건 — hetzner 원격 강제 (// @allow-local-blowup)"
        }
    }
    return ""
}

// ─── BLOW3 (공통) — blowup 신규 파일은 서브폴더 하위만 ───
// shared/blowup/ 루트에 .hexa 신규 금지. core/modules/guard/lens/ouroboros/seed/lib 중 하나만.
fn check_blow3(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    if !path.starts_with("shared/blowup/") { return "" }
    // core/modules/guard/lens/ouroboros/seed/lib 의 하위인지 확인
    if path.starts_with("shared/blowup/core/") { return "" }
    if path.starts_with("shared/blowup/modules/") { return "" }
    if path.starts_with("shared/blowup/guard/") { return "" }
    if path.starts_with("shared/blowup/lens/") { return "" }
    if path.starts_with("shared/blowup/ouroboros/") { return "" }
    if path.starts_with("shared/blowup/seed/") { return "" }
    if path.starts_with("shared/blowup/lib/") { return "" }
    // 예외: commands.hexa, todo.hexa (기존 루트 허용 파일)
    let bn = basename_of(path)
    if bn == "commands.hexa" { return "" }
    if bn == "todo.hexa" { return "" }
    return "BLOW3|error|blowup 신규 파일 '" + bn + "' 은 core/modules/guard/lens/ouroboros/seed/lib 하위만"
}

// ─── BLOW6 (공통) — blowup 결과 R28 준수 (폐기된 JSON 발견 저장소 신규 쓰기 금지) ───
// discovery_graph.json / discovery_log.jsonl / growth_bus.jsonl / verified_constants.jsonl
// 은 2026-04-11 폐기. blowup 엔진은 atlas.n6 만 사용.
fn check_blow6(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    if !path.starts_with("shared/blowup/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    // write_file / append_file / shell redirect 대상에 금지 파일명 포함
    let cmd = "grep -nE '(write_file|append_file|>>|>)[[:space:]]*[^[:space:]]*(discovery_graph|discovery_log|growth_bus|verified_constants)' '" + full + "' 2>/dev/null | grep -v '@allow-deprecated-json' | wc -l"
    let hits = to_int(_str(exec(cmd)).trim())
    if hits > 0 {
        return "BLOW6|error|폐기 JSON 발견 저장소 쓰기 " + to_string(hits) + "건 — atlas.n6 만 사용 (R28, // @allow-deprecated-json)"
    }
    return ""
}


// ─── ATLAS-GUARD (공통) — atlas.n6 직접 편집 금지 (Phase 1 진입 차단) ───
// 공리: atlas.n6 은 전 프로젝트 단일 진리 (nexus/anima/n6-architecture/void 등 공용).
//       편집은 _guarded_append_atlas() 또는 atlas_guard 경유만.
// L1: .hexa 에서 write_file/append_file 로 atlas.n6 직접 호출
// L2: shell redirect (>> atlas.n6, > atlas.n6)
// L3: 간접 shell (echo/cat/printf → atlas.n6)
// 예외: atlas_guard.hexa.inc, atlas_health.hexa, archive/, // @allow-atlas-direct
fn _atlas_is_exempt(path: string) -> bool {
    let bn = basename_of(path)
    if bn == "atlas_guard.hexa.inc" { return true }
    if bn == "atlas_health.hexa" { return true }
    if path.starts_with("shared/harness/") { return true }
    if path.starts_with("archive/") { return true }
    if path.index_of("/_archive/") >= 0 { return true }
    if path.starts_with(".claude/") { return true }
    return false
}

fn check_atlas_guard(path: string) -> string {
    if _atlas_is_exempt(path) { return "" }
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" { return "" }
    let full = REPO_ROOT + "/" + path
    // L1: write_file/append_file 가 atlas.n6 경로 인자 포함
    let l1 = to_int(_str(exec("grep -nE '(write_file|append_file)[[:space:]]*\\([^)]*atlas\\.n6' '" + full + "' 2>/dev/null | grep -v '@allow-atlas-direct' | wc -l")).trim())
    if l1 > 0 {
        return "ATLAS-GUARD-L1|error|atlas.n6 직접 write_file/append_file " + to_string(l1) + "건. _guarded_append_atlas() 경유 (// @allow-atlas-direct)"
    }
    // L2: shell redirect
    let l2 = to_int(_str(exec("grep -nE '(>>|>)[[:space:]]*[\"'\\'']?[^[:space:]\"'\\'']*atlas\\.n6' '" + full + "' 2>/dev/null | grep -v '@allow-atlas-direct' | wc -l")).trim())
    if l2 > 0 {
        return "ATLAS-GUARD-L2|error|atlas.n6 shell redirect " + to_string(l2) + "건 (// @allow-atlas-direct)"
    }
    // L3: echo/cat/printf → atlas.n6 한 줄 내 조합
    let l3 = to_int(_str(exec("grep -nE '(echo|cat|printf)[^|]*atlas\\.n6' '" + full + "' 2>/dev/null | grep -E '>>|>' | grep -v '@allow-atlas-direct' | wc -l")).trim())
    if l3 > 0 {
        return "ATLAS-GUARD-L3|error|atlas.n6 간접 shell 편집 " + to_string(l3) + "건 (// @allow-atlas-direct)"
    }
    return ""
}

// ─── AN2 (anima 전용) localStorage/sessionStorage 금지 — MemoryStore SQLite 전용 ───
fn check_an2(path: string) -> string {
    if _project_name() != "anima" { return "" }
    let e = ext_of(path)
    if e != ".ts" && e != ".tsx" && e != ".js" && e != ".jsx" && e != ".hexa" { return "" }
    // 하네스/archive 예외
    if path.starts_with("shared/harness/") { return "" }
    if path.starts_with("archive/") { return "" }
    let full = REPO_ROOT + "/" + path
    let cmd = "grep -nE '\\b(localStorage|sessionStorage)\\b' '" + full + "' 2>/dev/null | grep -v '@allow-webstorage' | wc -l"
    let hits = to_int(_str(exec(cmd)).trim())
    if hits > 0 {
        return "AN2|error|localStorage/sessionStorage " + to_string(hits) + "건 — MemoryStore(SQLite) 전용 (// @allow-webstorage)"
    }
    return ""
}

fn check_hx4(path: string) -> string {
    if _project_name() != "hexa-lang" { return "" }
    if _hx4_is_exempt(path) { return "" }
    let v1 = _hx4_l1_ext(path)
    if v1 != "" { return v1 }
    let v2 = _hx4_l2_toolchain(path)
    if v2 != "" { return v2 }
    let v3 = _hx4_l3_runtime(path)
    if v3 != "" { return v3 }
    let v4 = _hx4_l4_docs(path)
    if v4 != "" { return v4 }
    let v5 = _hx4_l5_tests(path)
    if v5 != "" { return v5 }
    let v6 = _hx4_l6_ci(path)
    if v6 != "" { return v6 }
    let v7 = _hx4_l7_build_chain(path)
    if v7 != "" { return v7 }
    let v8 = _hx4_l8_meta(path)
    if v8 != "" { return v8 }
    return ""
}

// ─── Check R19: SILENT EXIT 금지 — exit(1) 전 stderr 출력 필수 + catch 로그 필수 ───
// 탐지 2종:
//   (1) exit(1) 직전 5줄에 println/eprintln/>&2/stderr 없음
//   (2) catch 블록 body 에 print/e.* 참조 없음 (silent swallow)
// 예외: 라인 주석 // @allow-silent-exit 또는 // @allow-silent-catch
fn check_silent_exit(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" && e != ".py" && e != ".ts" && e != ".js" { return "" }
    // 하네스 자신은 exec 폴백 의도적 silent — 스킵
    if path.starts_with("shared/harness/") { return "" }
    let full = REPO_ROOT + "/" + path
    // (1) exit(1) silent
    let awk1 = "awk '/exit[[:space:]]*\\([[:space:]]*1[[:space:]]*\\)/ && $0 !~ /@allow-silent-exit/ { has=0; for(i=NR-5;i<NR;i++){if(lines[i] ~ /println|eprintln|>&2|stderr|fprintf[[:space:]]*\\(stderr/) has=1}; if(!has) c++ } { lines[NR]=$0 } END{print c+0}'"
    let silent_exits = to_int(_str(exec(awk1 + " '" + full + "' 2>/dev/null || echo 0")).trim())
    // (2) silent catch — block 안에 print 또는 error var 참조 없음
    let awk2 = "awk '/catch[[:space:]]+[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*\\{/ && $0 !~ /@allow-silent-catch/ { start=NR; depth=0; buf=\"\"; for(i=1;i<=length($0);i++){c=substr($0,i,1); if(c==\"{\")depth++; else if(c==\"}\")depth--}; buf=$0; if(depth==0){ if(buf !~ /println|eprintln|>&2|stderr/) n++ ; next } in_b=1; next } in_b { buf=buf $0; for(i=1;i<=length($0);i++){c=substr($0,i,1); if(c==\"{\")depth++; else if(c==\"}\")depth--}; if(depth==0){ if(buf !~ /println|eprintln|>&2|stderr/) n++; in_b=0 } } END{print n+0}'"
    let silent_catches = to_int(_str(exec(awk2 + " '" + full + "' 2>/dev/null || echo 0")).trim())
    let total = silent_exits + silent_catches
    if total == 0 { return "" }
    return "R19|error|SILENT EXIT — exit(1) 앞 stderr 없음 " + to_string(silent_exits) + "건 + silent catch " + to_string(silent_catches) + "건 (// @allow-silent-exit/catch 로 예외)"
}

// ─── Check 9: harness 수정 가드 — commit 메시지 승인 마커 필수 ───
// shared/harness/ 아래 .hexa/.json/.jsonl/.md 수정 시 commit 메시지에
//   "(harness):" prefix 또는 "harness-approved" 포함 필요.
// 로그 파일 (*_log.jsonl, mistakes/proposals/usage/cooldown) 은 예외.
fn _is_harness_log(path: string) -> bool {
    if path.index_of("_log.jsonl") >= 0 { return true }
    if path == "shared/harness/mistakes.jsonl" { return true }
    if path == "shared/harness/autofix_proposals.jsonl" { return true }
    if path == "shared/harness/rules_usage.jsonl" { return true }
    if path == "shared/harness/.gc_weekly_cooldown" { return true }
    return false
}

fn check_harness_modification(path: string) -> string {
    if !path.starts_with("shared/harness/") { return "" }
    if _is_harness_log(path) { return "" }
    let msg_raw = _str(exec("cat '" + REPO_ROOT + "/.git/COMMIT_EDITMSG' 2>/dev/null")).trim()
    // 커밋 메시지에 승인 마커 존재 여부
    if msg_raw.index_of("(harness):") >= 0 { return "" }
    if msg_raw.index_of("harness-approved") >= 0 { return "" }
    return "HARNESS-LOCK|error|shared/harness/ 수정 — 커밋 메시지에 '(harness):' prefix 또는 'harness-approved' 필요"
}

// ─── Check 8 (공통): 홈 디렉토리 절대경로 하드코딩 금지 (error) ───
// 원칙: /Users/<u>/, /home/<u>/, /root/ 리터럴 금지. env("HOME") 또는 $HOME 사용.
// 시스템 경로 /usr /opt /bin /sbin /tmp /dev /var 는 허용.
// 예외: .md 문서, archive/, harness 자신, append-only 로그 파일, // @allow-abspath (라인 단위)
fn check_hardcoded_path(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" && e != ".sh" && e != ".json" && e != ".jsonl" { return "" }
    if path.starts_with("archive/") { return "" }
    if path.index_of("/_archive/") >= 0 { return "" }
    // harness 자신 스킵 (메타 grep 사용)
    if path == "shared/harness/lint.hexa" { return "" }
    if path == "shared/harness/shared_survey.json" { return "" }
    // append-only 로그 기록물 — 과거 절대경로 유지
    let bn = basename_of(path)
    if bn == "mistakes.jsonl" || bn == "lint_log.jsonl" || bn == "gc_log.jsonl" { return "" }
    if bn == "rules_usage.jsonl" || bn == "autofix_proposals.jsonl" || bn == "cleanup_log.jsonl" { return "" }
    // hexa 바이너리 resolver 부트스트랩 (hexa 찾기 전 실행)
    if path.index_of("shared/scripts/bin/hexa") >= 0 { return "" }
    let full = REPO_ROOT + "/" + path
    // 리터럴: /Users/<name>/, /home/<name>/, /root/ (따옴표·공백 경계 뒤)
    // 주의: /usr/, /opt/, /bin/, /sbin/, /tmp/, /dev/, /var/ 는 시스템 경로 허용
    let cmd = "grep -nE '[\"'\\'' ](/(Users|home|root)/[A-Za-z0-9_.-]+/)' '" + full + "' 2>/dev/null | grep -v '@allow-abspath' | wc -l"
    let hit = to_int(_str(exec(cmd)).trim())
    if hit > 0 {
        return "ABSPATH|error|홈 디렉토리 절대경로 하드코딩 " + to_string(hit) + "건 — env(\"HOME\") 또는 $HOME 사용 (// @allow-abspath)"
    }
    return ""
}

// ─── Check 7: AI-native — .hexa 알고리즘 함정 ───
// 메타 사용 (grep/exec 내부 문자열) 제외 — 자기 자신 false positive 방지
fn check_hexa_algorithm(path: string) -> string {
    let e = ext_of(path)
    if e != ".hexa" { return "" }
    // lint/autofix/gc/bitter-gate/gc-weekly 자신은 스킵 — 메타 grep 사용함
    if path == "shared/harness/lint.hexa" { return "" }
    if path == "shared/harness/autofix.hexa" { return "" }
    if path == "shared/harness/gc.hexa" { return "" }
    if path == "shared/harness/gc-weekly.hexa" { return "" }
    if path == "shared/harness/bitter-gate.hexa" { return "" }
    if path == "shared/harness/triage.hexa" { return "" }
    let full = REPO_ROOT + "/" + path
    // 코멘트(//) 제거 후 grep 하도록 sed 전처리 + grep/exec 메타 라인 제외
    let sed_clean = "sed 's|//.*||' '" + full + "' | grep -v 'grep ' | grep -v 'exec('"
    // R0 위반: `xs.push(` 앞에 `=` 없으면 silent no-op
    let noop_push = to_int(_str(exec(sed_clean + " | grep -nE '^[[:space:]]+[a-z_][a-zA-Z0-9_]*\\.push\\(' | wc -l")).trim())
    if noop_push > 0 {
        return "HEXA-ALGO|error|R0 pass-by-value — xs.push(v) " + to_string(noop_push) + "건 silent no-op (xs = xs.push(v) 패턴)"
    }
    let lio = to_int(_str(exec(sed_clean + " | grep -c '\\.last_index_of('")).trim())
    if lio > 0 {
        return "HEXA-ALGO|error|.last_index_of() 미지원 — _rfind(s, ch) 수동 구현 사용"
    }
    let ac = to_int(_str(exec(sed_clean + " | grep -c 'args()'")).trim())
    if ac > 0 {
        return "HEXA-ALGO|warn|args() 빈 배열 반환 — env var 또는 기본 모드 사용 권장"
    }
    return ""
}

// ─── Gather files to lint ───

fn get_staged_files() -> string {
    return exec("git diff --cached --name-only 2>/dev/null").trim()
}

fn get_all_shared_files() -> string {
    return exec("find " + SHARED_DIR + " -type f \\( -name '*.hexa' -o -name '*.py' -o -name '*.sh' -o -name '*.md' -o -name '*.json' -o -name '*.jsonl' \\) 2>/dev/null | sed 's|" + REPO_ROOT + "/||'").trim()
}

// ─── Main ───

// ─── Mode dispatch: env var (primary, args() 인터프리터 버그 우회) + args() fallback ───
let mut mode = "staged"
let mut single = ""

// Primary: env var — HARNESS_LINT_MODE=staged|all|file, HARNESS_LINT_FILE=<path>
let env_mode = env("HARNESS_LINT_MODE")
if env_mode == "all" { mode = "all" }
else if env_mode == "file" {
    mode = "file"
    single = env("HARNESS_LINT_FILE")
}
else if env_mode == "staged" { mode = "staged" }
// (unset → "staged" default, 기존 동작)

// Fallback: args() — 인터프리터가 수정되면 우선 적용
let a = args()
let mut ai: i64 = 2
while ai < len(a) {
    let tok = a[ai]
    if tok == "--staged" { mode = "staged" }
    else if tok == "--all" { mode = "all" }
    else if tok == "--file" {
        mode = "file"
        if ai + 1 < len(a) { single = a[ai + 1]; ai = ai + 1 }
    }
    ai = ai + 1
}

let mut files_raw = ""
if mode == "staged" { files_raw = get_staged_files() }
else if mode == "all" { files_raw = get_all_shared_files() }
else if mode == "file" { files_raw = single }

if files_raw == "" {
    // 검사할 파일 없음 — 조용히 통과
    let log = "{\"ts\":\"" + now_iso() + "\",\"mode\":\"" + mode + "\",\"files\":[],\"pass\":true,\"violations\":[]}"
    try { exec("echo '" + log + "' >> '" + LINT_LOG + "'") } catch e {}
    exit(0)
}

let files = files_raw.split("\n")
let mut violations: [string] = []
let mut checked: i64 = 0

for f in files {
    let path = _str(f).trim()
    if path == "" { continue }
    checked = checked + 1

    // Fast prefilter: skip checks that obviously don't apply by ext/path
    let e = ext_of(path)
    let under_shared = is_under_shared(path)

    // check_hexa_only: only .rs/.py/.sh under shared/
    if (e == ".py" || e == ".sh" || e == ".rs") && under_shared {
        let v1 = check_hexa_only(path)
        if v1 != "" { violations = violations.push(path + "|" + v1) }
    }

    // check_ai_native: only .md under rules/ or config/
    if e == ".md" && (path.starts_with("shared/rules/") || path.starts_with("shared/config/")) {
        let v2 = check_ai_native(path)
        if v2 != "" { violations = violations.push(path + "|" + v2) }
    }

    // check_l0_lockdown: only shared/ files
    if under_shared {
        let v3 = check_l0_lockdown(path)
        if v3 != "" { violations = violations.push(path + "|" + v3) }
    }

    // check_pitfalls: only .hexa files
    if e == ".hexa" {
        let v4 = check_pitfalls(path)
        if v4 != "" { violations = violations.push(path + "|" + v4) }
    }

    // check_claude_md: only CLAUDE.md files
    if e == ".md" {
        let v5 = check_claude_md(path)
        if v5 != "" { violations = violations.push(path + "|" + v5) }
    }

    // check_json: .json / .jsonl
    if e == ".json" || e == ".jsonl" {
        let v6 = check_json(path)
        if v6 != "" { violations = violations.push(path + "|" + v6) }
    }

    // check_hexa_algorithm: .hexa ai-native 알고리즘 강제
    if e == ".hexa" {
        let v7 = check_hexa_algorithm(path)
        if v7 != "" { violations = violations.push(path + "|" + v7) }
    }

    // check_hardcoded_path: /Users/ghost 하드코딩 금지
    let v8 = check_hardcoded_path(path)
    if v8 != "" { violations = violations.push(path + "|" + v8) }

    // check_harness_modification: shared/harness/ 수정 시 승인 마커 필요
    let v9 = check_harness_modification(path)
    if v9 != "" { violations = violations.push(path + "|" + v9) }

    // check_silent_exit (R19): .hexa/.sh/.py/.ts/.js 대상
    if e == ".hexa" || e == ".sh" || e == ".py" || e == ".ts" || e == ".js" {
        let v10 = check_silent_exit(path)
        if v10 != "" { violations = violations.push(path + "|" + v10) }
    }

    // check_hx4 (hexa-lang 프로젝트 전용): Rust 언급조차 금지
    let v11 = check_hx4(path)
    if v11 != "" { violations = violations.push(path + "|" + v11) }

    // check_pkill_substring (R20): pkill/pgrep -f substring 금지
    if e == ".hexa" || e == ".sh" {
        let v12 = check_pkill_substring(path)
        if v12 != "" { violations = violations.push(path + "|" + v12) }
    }

    // check_an2 (anima 프로젝트 전용): localStorage/sessionStorage 금지
    let v13 = check_an2(path)
    if v13 != "" { violations = violations.push(path + "|" + v13) }

    // check_vd1 (void 프로젝트 전용): Terminal.app 단일 참조
    let v14 = check_vd1(path)
    if v14 != "" { violations = violations.push(path + "|" + v14) }

    // check_vd2 (void 프로젝트 전용): 복잡도 동결 (C1 arity 합계, C3 CLI 플래그)
    let v14b = check_vd2(path)
    if v14b != "" { violations = violations.push(path + "|" + v14b) }

    // check_pp1 (papers 프로젝트 전용): CC-BY 4.0 라이선스 선언 필수
    let v15a = check_pp1(path)
    if v15a != "" { violations = violations.push(path + "|" + v15a) }

    // check_pp2 (papers 프로젝트 전용): 논문 md 에 검증코드 블록
    let v15 = check_pp2(path)
    if v15 != "" { violations = violations.push(path + "|" + v15) }

    // check_ag4 (airgenome 프로젝트 전용): launcher cap ≤8
    let v16 = check_ag4(path)
    if v16 != "" { violations = violations.push(path + "|" + v16) }

    // check_ag5 (airgenome 프로젝트 전용): 'filter' 네이밍 규율
    let v16b = check_ag5(path)
    if v16b != "" { violations = violations.push(path + "|" + v16b) }

    // check_ag6 (airgenome 프로젝트 전용): Mac 로컬 heavy compute 원격 가드 필수
    let v16c = check_ag6(path)
    if v16c != "" { violations = violations.push(path + "|" + v16c) }

    // check_n62a (n6-architecture 전용): 논문 md 에 ```python 블록 필수
    let v16d = check_n62a(path)
    if v16d != "" { violations = violations.push(path + "|" + v16d) }

    // ─── n6 논문 canonical 양식 12 규칙 (n6-architecture 전용) ───
    if e == ".md" {
        let n_c1 = check_n61_c1(path)
        if n_c1 != "" { violations = violations.push(path + "|" + n_c1) }
        let n_a1 = check_n61_a1(path)
        if n_a1 != "" { violations = violations.push(path + "|" + n_a1) }
        let n_b1 = check_n61_b1(path)
        if n_b1 != "" { violations = violations.push(path + "|" + n_b1) }
        let n_b2 = check_n61_b2(path)
        if n_b2 != "" { violations = violations.push(path + "|" + n_b2) }
        let n_b3 = check_n61_b3(path)
        if n_b3 != "" { violations = violations.push(path + "|" + n_b3) }
        let n_b4 = check_n61_b4(path)
        if n_b4 != "" { violations = violations.push(path + "|" + n_b4) }
        let n_mk1 = check_n61_mk1(path)
        if n_mk1 != "" { violations = violations.push(path + "|" + n_mk1) }
        let n_mk3 = check_n61_mk3(path)
        if n_mk3 != "" { violations = violations.push(path + "|" + n_mk3) }
        let n_mk4 = check_n61_mk4(path)
        if n_mk4 != "" { violations = violations.push(path + "|" + n_mk4) }
        let n_r1 = check_n61_r1(path)
        if n_r1 != "" { violations = violations.push(path + "|" + n_r1) }
        let n_r2 = check_n61_r2(path)
        if n_r2 != "" { violations = violations.push(path + "|" + n_r2) }
        let n_dsync = check_n6_dag_sync(path)
        if n_dsync != "" { violations = violations.push(path + "|" + n_dsync) }
        let n_vm1 = check_vp_m1(path)
        if n_vm1 != "" { violations = violations.push(path + "|" + n_vm1) }
        let n_vm2 = check_vp_m2(path)
        if n_vm2 != "" { violations = violations.push(path + "|" + n_vm2) }
        let n_jp = check_n6_jsonpair(path)
        if n_jp != "" { violations = violations.push(path + "|" + n_jp) }
    }

    // ─── n6 DAG 무결성 (papers/_dag.json 전용) ───
    let n_ddang = check_n6_dag_dangle(path)
    if n_ddang != "" { violations = violations.push(path + "|" + n_ddang) }
    let n_dcyc = check_n6_dag_cycle(path)
    if n_dcyc != "" { violations = violations.push(path + "|" + n_dcyc) }

    // check_project_rules: shared/rules/<project>.lint.jsonl 자동 로드 + 디스패치
    let v17 = check_project_rules(path)
    if v17 != "" { violations = violations.push(path + "|" + v17) }

    // check_atlas_guard (공통): atlas.n6 직접 편집 금지 — L1/L2/L3 진입 차단
    if e == ".hexa" || e == ".sh" {
        let v18 = check_atlas_guard(path)
        if v18 != "" { violations = violations.push(path + "|" + v18) }
    }

    // check_blow1 (공통): BLOWUP_LOCAL=1 금지
    let v19 = check_blow1(path)
    if v19 != "" { violations = violations.push(path + "|" + v19) }

    // check_blow3 (공통): blowup 신규 파일 서브폴더 강제
    if e == ".hexa" {
        let v20 = check_blow3(path)
        if v20 != "" { violations = violations.push(path + "|" + v20) }
    }

    // check_blow6 (공통): 폐기 JSON 발견 저장소 쓰기 금지 (R28)
    if e == ".hexa" {
        let v21 = check_blow6(path)
        if v21 != "" { violations = violations.push(path + "|" + v21) }
    }

}

let pass = len(violations) == 0

// ─── Log append (lint_log.jsonl) ───

let mut files_json = "["
let mut fi: i64 = 0
for f in files {
    let p = _str(f).trim()
    if p == "" { continue }
    if fi > 0 { files_json = files_json + "," }
    files_json = files_json + "\"" + json_escape(p) + "\""
    fi = fi + 1
}
files_json = files_json + "]"

let mut viol_json = "["
let mut vi: i64 = 0
let mut has_error = false
for v in violations {
    let vs = _str(v)
    if vs == "" { continue }
    let parts = vs.split("|")
    if len(parts) < 4 { continue }
    let vfile = _str(parts[0])
    let vrule = _str(parts[1])
    let vsev = _str(parts[2])
    let vhint = _str(parts[3])
    if vsev == "error" { has_error = true }
    if vi > 0 { viol_json = viol_json + "," }
    viol_json = viol_json + "{\"file\":\"" + json_escape(vfile) + "\",\"rule\":\"" + vrule + "\",\"severity\":\"" + vsev + "\",\"fix_hint\":\"" + json_escape(vhint) + "\"}"
    vi = vi + 1
}
viol_json = viol_json + "]"

let log_line = "{\"ts\":\"" + now_iso() + "\",\"mode\":\"" + mode + "\",\"checked\":" + to_string(checked) + ",\"pass\":" + (if pass { "true" } else { "false" }) + ",\"files\":" + files_json + ",\"violations\":" + viol_json + "}"
try { exec("echo '" + log_line.replace("'", "'\\''") + "' >> '" + LINT_LOG + "'") } catch e {}

// ─── Output: pass = silent, fail = loud ───

if pass { exit(0) }

// 실패는 시끄럽게 — stderr 에 JSON 라인 per violation
for v in violations {
    let vs = _str(v)
    if vs == "" { continue }
    let parts = vs.split("|")
    if len(parts) < 4 { continue }
    let vfile = _str(parts[0])
    let vrule = _str(parts[1])
    let vsev = _str(parts[2])
    let vhint = _str(parts[3])
    let line = "{\"file\":\"" + json_escape(vfile) + "\",\"rule\":\"" + vrule + "\",\"severity\":\"" + vsev + "\",\"fix_hint\":\"" + json_escape(vhint) + "\"}"
    // stderr 로
    try { exec("echo '" + line.replace("'", "'\\''") + "' >&2") } catch e {}
    // mistakes.jsonl 누적
    let m = "{\"ts\":\"" + now_iso() + "\",\"kind\":\"lint_fail\",\"file\":\"" + json_escape(vfile) + "\",\"rule\":\"" + vrule + "\",\"fix\":\"" + json_escape(vhint) + "\"}"
    try { exec("echo '" + m.replace("'", "'\\''") + "' >> '" + MISTAKES_LOG + "'") } catch e {}
}

// error 가 있으면 차단, warn/info 만이면 통과
if has_error { exit(1) }
exit(0)
