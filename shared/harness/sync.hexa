// sync.hexa — harness sync 라우터 v1 (manifest 기반)
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
// 역할: sync_manifest.json 의 29 태스크를 단일 진입점으로 dispatch.
// 호출:
//   hexa run shared/harness/sync.hexa list                          태스크 목록 + status
//   hexa run shared/harness/sync.hexa <task_id> [--dry-run] [--no-git]
//   hexa run shared/harness/sync.hexa all [--dry-run] [--no-git]    pending_* 제외
//   hexa run shared/harness/sync.hexa diff                           src vs dst hash drift 리포트
// 기본: git push ON (v1 호환성), --no-git 으로 끄기. dry-run 은 명시 필수.
// SSOT: shared/harness/sync_manifest.json

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let HEXA = NEXUS + "/shared/bin/hexa"
let HARNESS = NEXUS + "/shared/harness"
let MANIFEST = HARNESS + "/sync_manifest.json"
let TASKS = HARNESS + "/tasks"
let LOG = HARNESS + "/sync_log.jsonl"

fn json_field(task_id: str, field: str) -> str {
    let py = "import json\n" +
             "d=json.load(open('" + MANIFEST + "'))\n" +
             "for t in d.get('tasks',[]):\n" +
             "    if t.get('id')=='" + task_id + "':\n" +
             "        v=t.get('" + field + "','')\n" +
             "        if isinstance(v,list): print(' '.join(str(x) for x in v))\n" +
             "        else: print(v)\n" +
             "        break"
    return to_string(exec("/usr/bin/python3 -c \"" + py + "\"")).trim()  // @allow-bare-exec
}

fn task_ids_active() -> str {
    let py = "import json\n" +
             "d=json.load(open('" + MANIFEST + "'))\n" +
             "print(' '.join(t['id'] for t in d.get('tasks',[]) if t.get('status')=='active'))"
    return to_string(exec("/usr/bin/python3 -c \"" + py + "\"")).trim()  // @allow-bare-exec
}

fn task_ids_all() -> str {
    let py = "import json\n" +
             "d=json.load(open('" + MANIFEST + "'))\n" +
             "print(' '.join(t['id'] for t in d.get('tasks',[])))"
    return to_string(exec("/usr/bin/python3 -c \"" + py + "\"")).trim()  // @allow-bare-exec
}

fn task_status(task_id: str) -> str {
    return json_field(task_id, "status")
}

fn task_mode(task_id: str) -> str {
    return json_field(task_id, "mode")
}

fn log_append(task_id: str, result: str, dry: bool) {
    let ts = to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()  // @allow-bare-exec
    let dry_str = if dry { "True" } else { "False" }
    let safe_res = result.replace("\"", "'")
    // hexa 에서 bash quoting 이 어렵기 때문에 python3 로 JSON dump 후 append
    let py = "import json,sys\n" +
             "line=json.dumps({'ts':'" + ts + "','task':'" + task_id + "','result':'" + safe_res + "','dry':" + dry_str + "})\n" +
             "open('" + LOG + "','a').write(line+'\\n')"
    try { exec("/usr/bin/python3 -c \"" + py + "\"") } catch e {}  // @allow-bare-exec
}

fn usage() {
    println("usage: hexa run shared/harness/sync.hexa <mode> [flags]")
    println("modes:")
    println("  list                   태스크 목록 + status")
    println("  <task_id>              단일 태스크 실행")
    println("  all                    active 태스크 전부 (pending_* 제외)")
    println("  diff                   src vs dst hash drift 리포트")
    println("flags:")
    println("  --dry-run              실제 쓰기 없음, 변경 예정만 출력")
    println("  --no-git               git add/commit/push 스킵")
}

fn cmd_list() {
    println("=== sync task list ===")
    let ids = task_ids_all()
    for raw in ids.split(" ") {
        let id = raw.trim()
        if id.len() == 0 { continue }
        let mode = task_mode(id)
        let status = task_status(id)
        let mut line = "  " + id
        while line.len() < 32 { line = line + " " }
        line = line + "[" + status + "]"
        while line.len() < 52 { line = line + " " }
        line = line + "mode=" + mode
        println(line)
    }
}

fn cmd_diff() {
    println("=== sync drift report ===")
    // 복잡 python 은 별도 헬퍼 스크립트가 없으므로 heredoc 으로 안전하게 전달
    let py_file = HARNESS + "/.sync_diff.py"
    let py_body = "import json,hashlib,os\n" +
                  "HOME=os.environ['HOME']\n" +
                  "NEXUS=HOME+'/Dev/nexus'\n" +
                  "MANIFEST='" + MANIFEST + "'\n" +
                  "d=json.load(open(MANIFEST))\n" +
                  "def expand(p):\n" +
                  "    if not p: return ''\n" +
                  "    if p.startswith('/'): return p\n" +
                  "    if p.startswith('~/'): return HOME+p[1:]\n" +
                  "    return NEXUS+'/'+p\n" +
                  "def md5(f):\n" +
                  "    if not os.path.isfile(f): return 'missing'\n" +
                  "    try:\n" +
                  "        with open(f,'rb') as fh: return hashlib.md5(fh.read()).hexdigest()[:12]\n" +
                  "    except: return 'err'\n" +
                  "for t in d.get('tasks',[]):\n" +
                  "    if t.get('status')!='active': continue\n" +
                  "    mode=t.get('mode','')\n" +
                  "    tid=t.get('id','')\n" +
                  "    if mode=='copy':\n" +
                  "        s=expand(t.get('src','')); dst=expand(t.get('dst',''))\n" +
                  "        if not s or not dst:\n" +
                  "            print('  '+tid.ljust(30)+' patterned')\n" +
                  "            continue\n" +
                  "        a=md5(s); b=md5(dst)\n" +
                  "        st='same' if a==b else ('drift' if a!='missing' and b!='missing' else 'partial')\n" +
                  "        print('  '+tid.ljust(30)+' '+st.ljust(8)+' src='+a+' dst='+b)\n" +
                  "    elif mode=='gen_sidecar':\n" +
                  "        s=expand(t.get('src',''))\n" +
                  "        mt=str(int(os.path.getmtime(s))) if os.path.isfile(s) else 'missing'\n" +
                  "        print('  '+tid.ljust(30)+' src_mtime='+mt)\n" +
                  "    elif mode in ('mirror','bidir'):\n" +
                  "        print('  '+tid.ljust(30)+' dir_mode='+mode)\n" +
                  "    else:\n" +
                  "        print('  '+tid.ljust(30)+' mode='+mode+' (no hash)')"
    try { write_file(py_file, py_body) } catch e {}
    let out = to_string(exec("/usr/bin/python3 '" + py_file + "' 2>&1")).trim()  // @allow-bare-exec
    println(out)
    try { exec("rm -f '" + py_file + "'") } catch e {}  // @allow-bare-exec
}

fn expand_path(p: str) -> str {
    if p.len() == 0 { return "" }
    if p.substring(0, 1) == "/" { return p }
    if p.substring(0, 2) == "~/" { return HOME + p.substring(1, p.len()) }
    return NEXUS + "/" + p
}

fn dispatch_task(task_id: str, dry: bool, do_git: bool) {
    let status = task_status(task_id)
    if status.len() == 0 {
        eprintln("REJECT: unknown task '" + task_id + "'")
        exit(2)
    }
    if status == "pending_v2" || status == "pending_decision" {
        let dry_str = if dry { "1" } else { "0" }
        println("[" + task_id + "] skip:" + status + " (manifest 등록만, 실행 제외)")
        log_append(task_id, "skip_" + status, dry)
        return
    }
    let mode = task_mode(task_id)
    let mut handler = ""
    let mut extra = ""
    let dry_flag = if dry { "1" } else { "0" }
    let git_flag = if do_git { "1" } else { "0" }

    if mode == "copy" {
        handler = TASKS + "/copy.hexa"
        let src = json_field(task_id, "src")
        let dst = json_field(task_id, "dst")
        let dp = json_field(task_id, "dst_pattern")
        let pkey = json_field(task_id, "projects_key")
        let actual_src = if src.len() > 0 { src } else { json_field(task_id, "src") }
        let actual_dst = if dst.len() > 0 { dst } else { dp }
        let actual_pkey = if pkey.len() > 0 { pkey } else { "" }
        let handle_sym = json_field(task_id, "handle_symlink")
        let sym_flag = if handle_sym == "True" { "1" } else { "0" }
        extra = "'" + actual_src + "' '" + actual_dst + "' '" + actual_pkey + "' " + sym_flag + " " + dry_flag + " " + git_flag
    } else if mode == "template" {
        handler = TASKS + "/template.hexa"
        extra = dry_flag + " " + git_flag
    } else if mode == "marker" {
        handler = TASKS + "/marker.hexa"
        let src = json_field(task_id, "src")
        let ms = json_field(task_id, "marker_start")
        let me = json_field(task_id, "marker_end")
        let pkey = json_field(task_id, "projects_key")
        // dst_pattern 에서 basename 추출 (CLAUDE.md / README.md)
        let dp = json_field(task_id, "dst_pattern")
        let mut base = "README.md"
        if dp.contains("CLAUDE.md") { base = "CLAUDE.md" }
        extra = "'" + src + "' '" + ms + "' '" + me + "' '" + pkey + "' '" + base + "' " + dry_flag + " " + git_flag
    } else if mode == "mirror" {
        handler = TASKS + "/mirror.hexa"
        let src = json_field(task_id, "src")
        let dst = json_field(task_id, "dst")
        extra = "'" + src + "' '" + dst + "' " + dry_flag
    } else if mode == "gen_l0_owners" {
        handler = TASKS + "/gen_l0_owners.hexa"
        let src = json_field(task_id, "src")
        let pkey = json_field(task_id, "projects_key")
        let owner = json_field(task_id, "owner")
        extra = "'" + src + "' '" + pkey + "' '" + owner + "' " + dry_flag
    } else if mode == "gen_perm" {
        handler = TASKS + "/gen_perm.hexa"
        let src = json_field(task_id, "src")
        let dst = json_field(task_id, "dst")
        extra = "'" + src + "' '" + dst + "' " + dry_flag
    } else if mode == "gen_sidecar" {
        handler = TASKS + "/gen_sidecar.hexa"
        let src = json_field(task_id, "src")
        extra = "'" + src + "' " + dry_flag
    } else if mode == "multi" {
        handler = TASKS + "/multi.hexa"
        extra = dry_flag + " " + git_flag
    } else if mode == "scan" {
        handler = TASKS + "/scan.hexa"
        let scanner = json_field(task_id, "src_scanner")
        let ms = json_field(task_id, "marker_start")
        let me = json_field(task_id, "marker_end")
        let pkey = json_field(task_id, "projects_key")
        let dp = json_field(task_id, "dst_pattern")
        let mut base = "README.md"
        if dp.contains("CLAUDE.md") { base = "CLAUDE.md" }
        extra = "'" + scanner + "' '" + ms + "' '" + me + "' '" + pkey + "' '" + base + "' " + dry_flag
    } else if mode == "bidir" {
        handler = TASKS + "/bidir.hexa"
        let src = json_field(task_id, "src")
        let dst = json_field(task_id, "dst")
        extra = "'" + src + "' '" + dst + "' " + dry_flag
    } else {
        eprintln("REJECT: unknown mode '" + mode + "' for task '" + task_id + "'")
        log_append(task_id, "reject_unknown_mode_" + mode, dry)
        exit(2)
    }

    if file_exists(handler) == false {
        println("[" + task_id + "] skip:handler_missing " + handler)
        log_append(task_id, "skip_handler_missing", dry)
        return
    }

    let cmd = HEXA + " run " + handler + " " + task_id + " " + extra + " 2>&1"
    let out = to_string(exec(cmd)).trim()  // @allow-bare-exec
    if out.len() > 0 { println(out) }
    log_append(task_id, "dispatched_" + mode, dry)
}

fn dispatch_all(dry: bool, do_git: bool) {
    let ids = task_ids_active()
    for raw in ids.split(" ") {
        let id = raw.trim()
        if id.len() == 0 { continue }
        dispatch_task(id, dry, do_git)
    }
}

fn main() {
    let argv = args()
    if argv.len() < 3 {
        usage()
        return
    }
    let mode = argv[2].trim()
    if mode.len() == 0 { usage(); return }

    // 플래그 파싱
    let mut dry = false
    let mut do_git = true
    let mut i = 3
    while i < argv.len() {
        let a = argv[i].trim()
        if a == "--dry-run" { dry = true }
        else if a == "--no-git" { do_git = false }
        i = i + 1
    }

    if mode == "list" { cmd_list(); return }
    if mode == "diff" { cmd_diff(); return }
    if mode == "all" { dispatch_all(dry, do_git); return }
    dispatch_task(mode, dry, do_git)
}

main()
