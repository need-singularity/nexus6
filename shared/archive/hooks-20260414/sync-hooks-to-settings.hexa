// @allow-parse-fail — archived (shared/archive/hooks-20260414/)
// sync-hooks-to-settings.hexa — hooks-config.json → settings.json 동기화
// sync-hooks-to-settings.py 대체. setup.hexa 섹션 4 독립판.
// 사용법: hexa sync-hooks-to-settings.hexa

let HOME = env("HOME")
let HEXA = HOME + "/Dev/nexus/shared/scripts/bin/hexa"
let HOOK_DIR = HOME + "/Dev/nexus/shared/hooks"
let CONFIG = HOOK_DIR + "/hooks-config.json"
let SETTINGS = HOME + "/.claude/settings.json"

println("=== NEXUS-6 Hook Sync (HEXA) ===")

// 1. hooks-config.json 로드
let config_raw = try { read_file(CONFIG) } catch e {
    println("ERROR: hooks-config.json 로드 실패")
    exit(1)
}

fn parse_whitelist(raw: str) -> list {
    let mut projects = []
    if raw.contains("\"whitelisted_projects\"") == false { return projects }
    let after = raw.split("\"whitelisted_projects\"")[1]
    let arr = after.split("[")[1].split("]")[0]
    let items = arr.split(",")
    for item in items {
        let clean = item.trim().replace("\"", "").replace("\n", "")
        if len(clean) > 0 { projects = projects + [clean] }
    }
    projects
}

let projects = parse_whitelist(config_raw)
println("화이트리스트: " + to_string(projects.len()) + "개 프로젝트")

// 2. 스크립트 존재 확인
let scripts_section = config_raw.split("\"scripts\"")
if scripts_section.len() > 1 {
    let scripts_block = scripts_section[1].split("{")[1].split("}")[0]
    let script_lines = scripts_block.split(",")
    let mut missing = 0
    for sl in script_lines {
        let s = to_string(sl).trim()
        if len(s) == 0 { continue }
        if s.contains("\"") == false { continue }
        let name = s.split("\"")[1]
        let path = HOOK_DIR + "/" + name
        let exists = to_string(exec("test -f '" + path + "' && echo y || echo n")).trim()
        if exists == "n" {
            println("  MISSING: " + name)
            missing = missing + 1
        }
    }
    if missing > 0 { println("WARNING: " + to_string(missing) + "개 스크립트 누락") }
}

// 3. hexa 우선 명령어 생성
fn hexa_cmd(script: str) -> str {
    let hexa_name = script.replace(".sh", ".hexa").replace(".py", ".hexa")
    let hexa_path = HOOK_DIR + "/" + hexa_name
    if to_string(exec("test -f '" + hexa_path + "' && echo y || echo n")).trim() == "y" {
        return HEXA + " " + hexa_path
    }
    if script.ends_with(".py") { return "/usr/bin/python3 " + HOOK_DIR + "/" + script }
    return "bash " + HOOK_DIR + "/" + script
}

fn hook_entry(cmd: str) -> str {
    return "{\"type\":\"command\",\"command\":\"" + cmd + "\"}"
}
fn hook_block(entries: str) -> str {
    return "{\"hooks\":[" + entries + "]}"
}
fn hook_block_match(matcher: str, entries: str) -> str {
    return "{\"matcher\":\"" + matcher + "\",\"hooks\":[" + entries + "]}"
}

let banner = hexa_cmd("nexus-banner.sh")
let pre_tool = hexa_cmd("nexus-pre-tool.sh")
let post_edit = hexa_cmd("nexus-post-edit.sh")
let post_bash = hexa_cmd("nexus-post-bash.sh")
let prompt_scan = hexa_cmd("nexus-prompt-scan.sh")
let go_par = hexa_cmd("go-parallel.sh")
let blowup = hexa_cmd("blowup-parallel.hexa")

let h_banner = hook_entry(banner)
let h_prompt = hook_entry(prompt_scan)
let h_gopar = hook_entry(go_par)
let h_blowup = hook_entry(blowup)
let h_pretool = hook_entry(pre_tool)
let h_postedit = hook_entry(post_edit)
let h_postbash = hook_entry(post_bash)

// 4. 백업
if to_string(exec("test -f '" + SETTINGS + "' && echo y || echo n")).trim() == "y" {
    let bak = SETTINGS + ".bak-" + to_string(exec("date +%Y%m%d-%H%M%S")).trim()
    exec("cp '" + SETTINGS + "' '" + bak + "'")
    println("백업: " + bak)
}

// 5. settings.json hooks 블록 교체
let hooks_json = "\"hooks\":{" + "\"UserPromptSubmit\":[" + hook_block(h_banner + "," + h_prompt + "," + h_gopar + "," + h_blowup) + "]," + "\"SessionStart\":[" + hook_block(h_banner) + "]," + "\"Stop\":[" + hook_block(h_banner) + "]," + "\"PreCompact\":[" + hook_block(h_banner) + "]," + "\"PostCompact\":[" + hook_block(h_banner) + "]," + "\"Notification\":[" + hook_block(h_banner) + "]," + "\"PreToolUse\":[" + hook_block(h_pretool) + "]," + "\"PostToolUse\":[" + hook_block_match("Write|Edit", h_postedit) + "," + hook_block_match("Bash", h_postbash) + "]" + "}"

let settings_raw = try { read_file(SETTINGS) } catch e {
    println("ERROR: settings.json 로드 실패")
    exit(1)
}

let before_hooks = settings_raw.split("\"hooks\"")[0]
let new_settings = before_hooks + hooks_json + "}"
try { write_file(SETTINGS, new_settings + "\n") } catch e {
    println("ERROR: settings.json 쓰기 실패")
    exit(1)
}

let hook_count = to_string(exec("grep -c 'command' '" + SETTINGS + "' 2>/dev/null || echo 0")).trim()
println("동기화 완료: " + hook_count + " hook entries (HEXA 우선)")
