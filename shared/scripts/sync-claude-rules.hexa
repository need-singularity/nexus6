// sync-claude-rules.hexa — 공유 작업 규칙 전 리포 CLAUDE.md 동기화 (sync-claude-rules.sh 대체)
// 원본: nexus/shared/shared_work_rules.md → 각 리포 CLAUDE.md 마커 내 주입
// 사용: hexa shared/scripts/sync-claude-rules.hexa

let HOME = env("HOME")
let SHARED_DIR = HOME + "/Dev/nexus/shared/scripts"
let SHARED = SHARED_DIR + "/shared_work_rules.md"
let MARKER_START = "<!-- SHARED:WORK_RULES:START -->"
let MARKER_END = "<!-- SHARED:WORK_RULES:END -->"

let shared_ok = to_string(exec("test -f '" + SHARED + "' && echo y || echo n")).trim()
if shared_ok == "n" {
    println("오류: " + SHARED + " 없음")
    exit(1)
}

let rules_content = read_file(SHARED)

// 마커 기반 파일 동기화
fn sync_file(file: str, marker_start: str, marker_end: str, new_content: str) -> bool {
    let exists = to_string(exec("test -f '" + file + "' && echo y || echo n")).trim()
    if exists == "n" {
        println("  SKIP: " + file + " 없음")
        return false
    }
    let text = try { read_file(file) } catch e { println("  SKIP: 읽기 실패"); return false }
    if text.contains(marker_start) == false {
        println("  SKIP: " + file + " 마커 없음")
        return false
    }
    let before = text.split(marker_start)[0] + marker_start
    let after_parts = text.split(marker_end)
    let after = if after_parts.len() >= 2 { marker_end + after_parts[1] } else { marker_end }
    let updated = before + "\n" + new_content + after
    try { write_file(file, updated) } catch e { println("  SKIP: 쓰기 실패"); return false }
    println("  동기화: " + file)
    return true
}

fn commit_and_push(repo_dir: str, repo_name: str) {
    let diff = to_string(exec("bash -c 'cd " + repo_dir + " && git diff --quiet CLAUDE.md 2>/dev/null && echo same || echo diff'")).trim()
    if diff == "same" {
        println("  변경 없음")
        return
    }
    try {
        exec("bash", ["-c", "cd " + repo_dir + " && git add CLAUDE.md && git pull --rebase --quiet 2>/dev/null; git commit -m '동기화: TECS-L 공유 작업 규칙' && git push"])
        println("  푸시 완료!")
    } catch e {
        println("  커밋/푸시 스킵")
    }
}

let BASE = HOME + "/Dev/nexus/shared"
let PARENT = HOME + "/Dev"

println("=== 공유 작업 규칙 동기화 ===")
println("원본: " + SHARED)
println("")

let repos = ["TECS-L", "anima", "sedi", "n6-architecture", "brainwire", "papers"]
for repo in repos {
    let repo_dir = if repo == "TECS-L" { BASE } else { PARENT + "/" + repo }
    println("[" + repo + "]")
    sync_file(repo_dir + "/CLAUDE.md", MARKER_START, MARKER_END, rules_content)
    commit_and_push(repo_dir, repo)
}

println("")
println("완료!")
