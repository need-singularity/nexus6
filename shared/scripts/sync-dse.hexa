// MOVED → hexa shared/harness/sync.hexa dse  (이 파일은 백호환 shim, v2 에서 제거 예정)
// sync-dse.hexa — Universal DSE 도메인 전 리포 동기화 (sync-dse.sh 대체)
// 원본: nexus/shared/dse/ → n6-architecture/tools/universal-dse/domains/
// 사용: hexa shared/scripts/sync-dse.hexa

let HOME = env("HOME")
let SHARED_DIR = HOME + "/Dev/nexus/shared/scripts"
let DSE_SRC = SHARED_DIR + "/dse"
let BASE = HOME + "/Dev/nexus/shared"
let PARENT = HOME + "/Dev"
let STATE_FILE = SHARED_DIR + "/.sync_state.json"
let SYNC_KEY = "sync-dse"

// --- delta 검출 ---
fn _md5(path: str) -> str {
    return to_string(exec("md5 -q '" + path + "' 2>/dev/null || md5sum '" + path + "' | cut -d' ' -f1")).trim()
}

fn _load_state() -> str {
    if file_exists(STATE_FILE) { return read_file(STATE_FILE) }
    return "{}"
}

fn _get_stored_hash(state_raw: str, key: str) -> str {
    let v = to_string(exec("/usr/bin/python3 -c \"import json,sys; d=json.loads(sys.stdin.read()); print(d.get('" + key + "',''))\" <<'PYEOF'\n" + state_raw + "\nPYEOF")).trim()
    return v
}

fn _save_hash(key: str, hash_val: str) {
    let raw = _load_state()
    let updated = to_string(exec("/usr/bin/python3 -c \"import json,sys; d=json.loads(sys.stdin.read()); d['" + key + "']='" + hash_val + "'; print(json.dumps(d,indent=2))\" <<'PYEOF'\n" + raw + "\nPYEOF")).trim()
    write_file(STATE_FILE, updated + "\n")
}

let dse_ok = to_string(exec("test -d '" + DSE_SRC + "' && echo y || echo n")).trim()
if dse_ok == "n" {
    println("오류: " + DSE_SRC + " 없음")
    exit(1)
}

// 소스 해시: domains/ 디렉토리 전체 (모든 .toml 파일 연결 해시)
let src_hash = to_string(exec("bash -c \"cat '" + DSE_SRC + "/domains/'*.toml 2>/dev/null | md5 -q 2>/dev/null || cat '" + DSE_SRC + "/domains/'*.toml 2>/dev/null | md5sum | cut -d' ' -f1\"")).trim()
let state_raw = _load_state()
let stored = _get_stored_hash(state_raw, SYNC_KEY)

if src_hash == stored && src_hash != "" {
    println("=== Universal DSE 동기화: up-to-date (delta skip) ===")
    exit(0)
}
// --- delta 검출 끝 ---

let domain_count = to_string(exec("ls '" + DSE_SRC + "/domains/'*.toml 2>/dev/null | wc -l")).trim()

println("=== Universal DSE 동기화 ===")
println("원본: " + DSE_SRC + " (" + domain_count + " 도메인)")
println("")

// n6-architecture: 자체 universal-dse/domains/ 보유
let n6_dse = PARENT + "/n6-architecture/tools/universal-dse/domains"
let n6_ok = to_string(exec("test -d '" + n6_dse + "' && echo y || echo n")).trim()
if n6_ok == "y" {
    println("[n6-architecture tools/universal-dse/domains/]")
    let mut added = 0

    // shared -> n6 (누락 도메인 추가)
    let src_files = to_string(exec("ls '" + DSE_SRC + "/domains/'*.toml 2>/dev/null")).trim()
    for line in src_files.split("\n") {
        let f = line.trim()
        if len(f) == 0 { continue }
        let base = to_string(exec("basename '" + f + "'")).trim()
        let dest_ok = to_string(exec("test -f '" + n6_dse + "/" + base + "' && echo y || echo n")).trim()
        if dest_ok == "n" {
            exec("cp '" + f + "' '" + n6_dse + "/" + base + "'")
            println("  + " + base)
            added = added + 1
        }
    }

    // n6 -> shared (역동기화)
    let n6_files = to_string(exec("ls '" + n6_dse + "/'*.toml 2>/dev/null")).trim()
    for line in n6_files.split("\n") {
        let f = line.trim()
        if len(f) == 0 { continue }
        let base = to_string(exec("basename '" + f + "'")).trim()
        let src_ok = to_string(exec("test -f '" + DSE_SRC + "/domains/" + base + "' && echo y || echo n")).trim()
        if src_ok == "n" {
            exec("cp '" + f + "' '" + DSE_SRC + "/domains/" + base + "'")
            println("  < " + base + " (역동기화)")
            added = added + 1
        }
    }

    if added == 0 {
        println("  이미 동기화됨")
    } else {
        println("  " + to_string(added) + "건 동기화")
    }

    // n6 커밋
    try {
        exec("bash", ["-c", "cd '" + PARENT + "/n6-architecture' && (git diff --quiet tools/universal-dse/ 2>/dev/null && test -z \"$(git ls-files --others --exclude-standard tools/universal-dse/ 2>/dev/null | head -1)\") || (git add tools/universal-dse/ && git commit -m '동기화: TECS-L DSE 도메인' && git push)"])
    } catch e {}
}

// 심링크 리포 확인
println("")
let symlink_repos = ["anima", "sedi", "papers"]
for repo in symlink_repos {
    let repo_dir = PARENT + "/" + repo
    let is_link = to_string(exec("test -L '" + repo_dir + "/.shared' && echo y || echo n")).trim()
    if is_link == "y" {
        println("[" + repo + "] .shared/ 심링크 -- 자동 동기화")
    } else {
        let has_dse = to_string(exec("test -d '" + repo_dir + "/.shared/dse' && echo y || echo n")).trim()
        if has_dse == "y" {
            println("[" + repo + "] 경고: .shared/가 심링크 아님 -- 수동 동기화 필요")
        }
    }
}

// TECS-L dse 변경분 커밋
try {
    exec("bash", ["-c", "cd '" + BASE + "' && (git diff --quiet .shared/dse/ 2>/dev/null && test -z \"$(git ls-files --others --exclude-standard .shared/dse/ 2>/dev/null | head -1)\") || (git add .shared/dse/ && git commit -m '동기화: n6 역동기화 DSE 도메인' && git push)"])
} catch e {}

println("")
println("완료! (" + domain_count + " 도메인)")

// delta 상태 저장
_save_hash(SYNC_KEY, src_hash)
