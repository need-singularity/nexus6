// sync-readmes.hexa — 프로젝트 설명 전 리포 README 동기화 (sync-readmes.sh 대체)
// 원본: nexus/shared/scripts/projects.md → 각 리포 README 마커 내 주입 + 커밋+푸시
// 사용: hexa shared/scripts/sync-readmes.hexa

let HOME = env("HOME")
let SHARED_DIR = HOME + "/Dev/nexus/shared/scripts"
let SHARED = SHARED_DIR + "/projects.md"
let BASE = HOME + "/Dev/nexus/shared"
let PARENT = HOME + "/Dev"
let STATE_FILE = SHARED_DIR + "/.sync_state.json"
let SYNC_KEY = "sync-readmes"

// --- delta 검출 ---
fn _md5(path: str) -> str {
    return to_string(exec("md5 -q '" + path + "' 2>/dev/null || md5sum '" + path + "' | cut -d' ' -f1")).trim()
}

fn _load_state() -> str {
    if file_exists(STATE_FILE) { return read_file(STATE_FILE) }
    return "{}"
}

fn _get_stored_hash(state_raw: str, key: str) -> str {
    let v = to_string(exec("/usr/bin/python3 -c \"import json,sys; d=json.loads(sys.stdin.read()); print(d.get('" + key + "',''))\" <<'PYEOF'\n" + state_raw + "\nPYEOF")).trim()
    return v
}

fn _save_hash(key: str, hash_val: str) {
    let raw = _load_state()
    let updated = to_string(exec("/usr/bin/python3 -c \"import json,sys; d=json.loads(sys.stdin.read()); d['" + key + "']='" + hash_val + "'; print(json.dumps(d,indent=2))\" <<'PYEOF'\n" + raw + "\nPYEOF")).trim()
    write_file(STATE_FILE, updated + "\n")
}

let MARKER_START = "<!-- SHARED:PROJECTS:START -->"
let MARKER_END = "<!-- SHARED:PROJECTS:END -->"

let shared_ok = to_string(exec("test -f '" + SHARED + "' && echo y || echo n")).trim()
if shared_ok == "n" {
    println("오류: " + SHARED + " 없음")
    exit(1)
}

// 소스 해시: projects.md + sync helper scripts
let hash_projects = _md5(SHARED)
let sync_pj_path = SHARED_DIR + "/sync_projects_json.py"
let sync_ra_path = SHARED_DIR + "/sync_readme_all.py"
let hash_pj = if file_exists(sync_pj_path) { _md5(sync_pj_path) } else { "" }
let hash_ra = if file_exists(sync_ra_path) { _md5(sync_ra_path) } else { "" }
let src_hash = to_string(exec("echo '" + hash_projects + hash_pj + hash_ra + "' | md5 -q 2>/dev/null || echo '" + hash_projects + hash_pj + hash_ra + "' | md5sum | cut -d' ' -f1")).trim()

let state_raw = _load_state()
let stored = _get_stored_hash(state_raw, SYNC_KEY)

if src_hash == stored {
    println("=== 프로젝트 설명 동기화: up-to-date (delta skip) ===")
    exit(0)
}
// --- delta 검출 끝 ---

let content = read_file(SHARED)

// 마커 기반 파일 동기화
fn sync_file(file: str, marker_start: str, marker_end: str, new_content: str) -> bool {
    let exists = to_string(exec("test -f '" + file + "' && echo y || echo n")).trim()
    if exists == "n" {
        println("  SKIP: " + file + " 없음")
        return false
    }
    let text = try { read_file(file) } catch e { println("  SKIP: 읽기 실패"); return false }
    if text.contains(marker_start) == false {
        println("  SKIP: " + file + " 마커 없음")
        return false
    }
    let before = text.split(marker_start)[0] + marker_start
    let after_parts = text.split(marker_end)
    let after = if after_parts.len() >= 2 { marker_end + after_parts[1] } else { marker_end }
    let updated = before + "\n" + new_content + "\n" + after
    try { write_file(file, updated) } catch e { println("  SKIP: 쓰기 실패"); return false }
    println("  동기화: " + file)
    return true
}

fn commit_and_push(repo_dir: str, repo_name: str) {
    let diff = to_string(exec("bash -c 'cd " + repo_dir + " && git diff --quiet README.md 2>/dev/null && echo same || echo diff'")).trim()
    if diff == "same" {
        println("  변경 없음")
        return
    }
    try {
        exec("bash", ["-c", "cd " + repo_dir + " && git add README.md && git pull --rebase --quiet 2>/dev/null; git commit -m '동기화: TECS-L 프로젝트 목록' && git push"])
        println("  푸시 완료!")
    } catch e {
        println("  커밋/푸시 스킵")
    }
}

// 1단계: JSON SSOT 갱신
println("=== [1/3] Loop Lens: JSON -> projects.json + projects.md ===")
let sync_pj = SHARED_DIR + "/sync_projects_json.py"
let spj_ok = to_string(exec("test -f '" + sync_pj + "' && echo y || echo n")).trim()
if spj_ok == "y" {
    try { exec("/usr/bin/python3 '" + sync_pj + "' --apply") } catch e {}
}

println("")
println("=== [2/3] JSON SSOT -> README 자동 동기화 (전 리포) ===")
let sync_ra = SHARED_DIR + "/sync_readme_all.py"
let sra_ok = to_string(exec("test -f '" + sync_ra + "' && echo y || echo n")).trim()
if sra_ok == "y" {
    try { exec("/usr/bin/python3 '" + sync_ra + "' --apply") } catch e {}
}
println("")

// 3단계: 프로젝트 설명 동기화 + 커밋 + 푸시
println("=== [3/3] 프로젝트 설명 동기화 + 커밋 + 푸시 ===")
println("원본: " + SHARED)
println("")

// 리포 목록
let repos = [
    ["TECS-L", BASE],
    ["anima", PARENT + "/anima"],
    ["SEDI", PARENT + "/sedi"],
    ["n6-architecture", PARENT + "/n6-architecture"],
    ["BrainWire", PARENT + "/brainwire"],
    ["HEXA-LANG", PARENT + "/hexa-lang"],
    ["Papers", PARENT + "/papers"]
]

for entry in repos {
    let name = entry[0]
    let dir = entry[1]
    println("[" + name + "]")
    sync_file(dir + "/README.md", MARKER_START, MARKER_END, content)
    commit_and_push(dir, name)
}

println("")
println("완료!")

// delta 상태 저장
_save_hash(SYNC_KEY, src_hash)
