#!/bin/bash
# shared/scripts/bin/hexa — hexa 바이너리 resolver (외부 의존 없음)
# 어떤 프로젝트에서도 이 스크립트로 호출하면 자동으로 가용 hexa를 찾아 exec.
# 우선순위: 환경변수 → 로컬 실바이너리 → gate wrapper → 기타 fallback
# L0 준수: 전역 ~/.claude 미수정. 모든 hexa 호출이 shared 통과.

set -e

SELF="$(realpath "$0" 2>/dev/null || echo "$0")"

# Remote dispatch (AG6 Mac-compute-ZERO).
# Why: heavy hexa workloads pin Mac CPU; ubu/hetzner sit idle. Default-ON:
# eligible calls run on remote via hexa_remote (rsync + ssh). Opt-out = HEXA_LOCAL=1.
# Blacklist covers FFI-bound scripts that must stay on Mac (Cocoa, launchctl).
# Fallback: hexa_remote exits 64 if remote unreachable/unmappable → local path.
remote_eligible() {
    [ "${HEXA_LOCAL:-0}" != "1" ] || return 1
    # 2026-04-20 Heavy-compute override (nexus-cli stabilization T2):
    # drill/smash/free/absolute/meta-closure/hyperarithmetic 는 Mac 에서 stage0 SIGKILL
    # (Gatekeeper + 4GB RSS cap) 유발 → Darwin local-first 보다 먼저 원격 라우팅 강제.
    # Pattern: `hexa run {nexus_cli,nexus,run}.hexa {drill|smash|free|...} ...`
    # Override 는 HEXA_LOCAL=1 로만 해제 (HEXA_REMOTE 는 불필요).
    if [ "${1:-}" = "run" ] && [ -n "${2:-}" ]; then
        local __base="$(basename "$2")"
        case "$__base" in
            nexus_cli.hexa|nexus.hexa|run.hexa)
                local __arg
                for __arg in "${@:3}"; do
                    case "$__arg" in
                        drill|smash|free|absolute|meta-closure|hyperarithmetic)
                            return 0 ;;
                    esac
                done
                ;;
        esac
    fi
    # 2026-04-19 Darwin local-first (p-drill-remote-routing):
    # Mac 에서 원격 라우팅이 stage1 파서 에러 + 느린 warm-up 유발 → HEXA_REMOTE=1 명시시만 원격.
    # (heavy-compute 는 위에서 이미 return 0 처리됨)
    if [ "$(uname -s 2>/dev/null)" = "Darwin" ] && [ "${HEXA_REMOTE:-0}" != "1" ]; then
        return 1
    fi
    # 2026-04-18: cc (self-hosted compile) 은 가장 heavy (stage0 → stage1) → 원격 eligibility 로 전환.
    # 원격 실패 시 exit 64 → 로컬 fallback (safe_hexa_launchd RSS 4GB cap 으로 보호).
    case "${1:-}" in
        ""|version|--version|-V|help|--help|-h|lsp|status|gc) return 1 ;;
    esac
    if [ "${1:-}" = "run" ] && [ -n "${2:-}" ]; then
        local __base="$(basename "$2")"
        case "$__base" in
            menubar.hexa|run.hexa|nexus_cli.hexa|predictive_throttle.hexa|lock_gate.hexa|cmd_gate.hexa|entry.hexa) return 1 ;;
        esac
    fi
    # macOS case-insensitive FS: cwd can be /Users/ghost/dev/... or /Users/ghost/Dev/...
    local cwd_lc="$(pwd -P | tr '[:upper:]' '[:lower:]')"
    local home_lc="$(printf '%s' "$HOME" | tr '[:upper:]' '[:lower:]')"
    case "$cwd_lc" in
        "$home_lc/dev/airgenome"|"$home_lc/dev/airgenome"/*) ;;
        "$home_lc/dev/nexus"|"$home_lc/dev/nexus"/*) ;;
        "$home_lc/dev/anima"|"$home_lc/dev/anima"/*) ;;
        *) return 1 ;;
    esac
    return 0
}
REMOTE_WRAP="$(dirname "$SELF")/hexa_remote"
__is_heavy_compute=0
if [ "${1:-}" = "run" ] && [ -n "${2:-}" ]; then
    case "$(basename "$2")" in
        nexus_cli.hexa|nexus.hexa|run.hexa)
            for __a in "${@:3}"; do
                case "$__a" in
                    drill|smash|free|absolute|meta-closure|hyperarithmetic)
                        __is_heavy_compute=1; break ;;
                esac
            done ;;
    esac
fi
if [ -x "$REMOTE_WRAP" ] && remote_eligible "$@"; then
    # set -e would kill the script on a non-zero exit from the wrapper; use || to capture.
    # Capture stderr so we can parse NEXUS_REMOTE_ERROR hosts_tried array.
    __rc=0
    __rstderr="$(mktemp -t hexa_remote_stderr.XXXXXX 2>/dev/null || echo /tmp/hexa_remote_stderr.$$)"
    "$REMOTE_WRAP" "$@" 2> >(tee "$__rstderr" >&2) || __rc=$?
    # 64 = "fallback to local" signal; any other code is the remote script's real result.
    if [ "$__rc" != "64" ]; then
        rm -f "$__rstderr"
        exit "$__rc"
    fi
    # Extract hosts_tried from NEXUS_REMOTE_ERROR line (best-effort; empty if absent).
    __hosts_json="$(grep -o 'NEXUS_REMOTE_ERROR {[^}]*}' "$__rstderr" 2>/dev/null | tail -n 1 | sed -n 's/.*"hosts_tried":\(\[[^]]*\]\).*/\1/p')"
    [ -z "$__hosts_json" ] && __hosts_json='[]'
    rm -f "$__rstderr"
    __cmd_label="${3:-unknown}"
    __is_darwin=0
    [ "$(uname -s 2>/dev/null)" = "Darwin" ] && __is_darwin=1
    # A3: JSON-structured downgrade event (heavy-compute only).
    if [ "$__is_heavy_compute" = "1" ]; then
        if [ "$__is_darwin" = "1" ] && [ "${HEXA_ALLOW_LOCAL_FALLBACK:-0}" != "1" ]; then
            __fb="abort"
        else
            __fb="local"
        fi
        echo "hexa resolver: ⚠ heavy-compute ($2 ${3:-}) remote dispatch failed (exit 64) — Mac 로컬 실행 시 stage0 SIGKILL 위험 (Gatekeeper + 4GB RSS cap)" >&2
        printf 'NEXUS_REMOTE_DOWNGRADE {"heavy_compute":true,"cmd":"%s","hosts_tried":%s,"reason":"remote_unavailable","fallback":"%s"}\n' \
            "$__cmd_label" "$__hosts_json" "$__fb" >&2
    fi
    # A2: Mac heavy-compute + all-hosts-fail → exit 74 (local fallback blocked unless override).
    if [ "$__is_heavy_compute" = "1" ] && [ "$__is_darwin" = "1" ] && [ "${HEXA_ALLOW_LOCAL_FALLBACK:-0}" != "1" ]; then
        printf 'NEXUS_REMOTE_ERROR {"cmd":"%s","hosts_tried":%s,"reason":"all_timeout","action":"abort_to_prevent_oom","override_env":"HEXA_ALLOW_LOCAL_FALLBACK=1","exit_code":74}\n' \
            "$__cmd_label" "$__hosts_json" >&2
        echo "hexa resolver: heavy-compute + Darwin + all-hosts-unreachable → abort (exit 74). 우회: HEXA_ALLOW_LOCAL_FALLBACK=1" >&2
        exit 74
    fi
    echo "hexa resolver: remote dispatch returned 64, running locally" >&2
elif [ "$__is_heavy_compute" = "1" ] && [ ! -x "$REMOTE_WRAP" ]; then
    echo "hexa resolver: ⚠ heavy-compute ($2 ${3:-}) 인데 hexa_remote wrap 부재 — 로컬 실행 (Mac 는 stage0 SIGKILL 가능)" >&2
fi

pick_exec() {
    local cand real
    cand="$1"
    [ -n "$cand" ] || return 1
    [ -x "$cand" ] || return 1
    real="$(realpath "$cand" 2>/dev/null || echo "$cand")"
    [ "$real" = "$SELF" ] && return 1
    printf '%s\n' "$cand"
    return 0
}

# Decide whether to wrap in launchd jetsam-priority-40 sandbox.
# Why: 2026-04-14 verification — raw hexa runs at jetsam=180 (= Terminal),
# so an OOM hexa kills the Terminal alongside it. launchd-managed jobs
# get jetsam=40 (BACKGROUND_OPPORTUNISTIC), so jetsam targets them first.
# This shim forces every hexa invocation through the wrap by default,
# converting opt-in protection into opt-out.
WRAP="${NEXUS:-$HOME/Dev/nexus}/shared/harness/safe_hexa_launchd.sh"
USE_LAUNCHD=1
[ "${HEXA_NO_LAUNCHD:-0}" = "1" ] && USE_LAUNCHD=0   # explicit bypass (nested calls, debug)
[ -t 0 ] || USE_LAUNCHD=0                            # piped/redirected stdin: launchd has no stdin
[ -z "${1:-}" ] && USE_LAUNCHD=0                     # no args → REPL: needs tty
case "${1:-}" in
    version|--version|-V|help|--help|-h|status|lsp|cc) USE_LAUNCHD=0 ;;  # cheap/interactive subcommands
esac
[ -x "$WRAP" ] || USE_LAUNCHD=0                      # wrap missing → fall through
[ "${HEXA_FORCE_LAUNCHD:-0}" = "1" ] && USE_LAUNCHD=1   # CI/test override: re-enable wrap regardless

resolve_and_exec() {
    local cand="$1"; shift
    if [ "$USE_LAUNCHD" = "1" ]; then
        # HEXA_NO_LAUNCHD=1 is also injected into the launchd job's
        # EnvironmentVariables (in safe_hexa_launchd.sh), so any nested
        # `hexa` calls from inside the wrapped process bypass the wrap.
        HEXA_BIN="$cand" exec "$WRAP" "$@"
    else
        exec "$cand" "$@"
    fi
}

# 1. HEXA_BIN env var override (테스트/디버깅)
if cand="$(pick_exec "$HEXA_BIN")"; then
    resolve_and_exec "$cand" "$@"
fi

# 2. ~/.hx/bin/hexa (정규 설치 경로 — SSOT, read_stdin 검증된 최신 빌드)
if cand="$(pick_exec "$HOME/.hx/bin/hexa")"; then
    resolve_and_exec "$cand" "$@"
fi

# 3. 로컬 단일 바이너리 폴백 (stale 위험 — 2번 부재 시만)
for p in \
    "$HOME/Dev/hexa-lang/hexa" \
    "$HOME/.cargo/bin/hexa" ; do
    if cand="$(pick_exec "$p")"; then
        resolve_and_exec "$cand" "$@"
    fi
done

# 4. PATH 탐색 (self-loop 회피)
for cand in $(command -v -a hexa 2>/dev/null); do
    real="$(realpath "$cand" 2>/dev/null || echo "$cand")"
    if [ "$real" != "$SELF" ] && [ -x "$cand" ]; then
        resolve_and_exec "$cand" "$@"
    fi
done

echo "ERROR(shared/scripts/bin/hexa): hexa 바이너리 없음. ~/Dev/hexa-lang/hexa 또는 ~/.hx/bin/hexa 필요" >&2
exit 127
