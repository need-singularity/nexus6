#!/usr/bin/env python3
"""infra — 4호스트 자원 실시간 현황 (SSOT: nexus/shared/infra_state.json)
사용: infra | infra json | infra rec
어떤 프로젝트에서도 즉시 호출 가능. 캐시 cycle 10분."""
import json, sys, os, time
from pathlib import Path

SSOT = Path.home() / "Dev/nexus/shared/infra_state.json"
INFRA = Path.home() / "Dev/nexus/shared/config/infrastructure.json"

def age(ts):
    try:
        from datetime import datetime, timezone
        t = datetime.fromisoformat(ts.replace('Z', '+00:00'))
        return int((datetime.now(timezone.utc) - t).total_seconds())
    except: return -1

def fmt_age(s):
    if s < 0: return "?"
    if s < 60: return f"{s}s"
    if s < 3600: return f"{s//60}m"
    return f"{s//3600}h{(s%3600)//60}m"

def status_color(st):
    return {"active":"\033[32m●\033[0m", "online":"\033[32m●\033[0m",
            "offline":"\033[31m○\033[0m", "exited":"\033[31m○\033[0m"}.get(st, "\033[33m◐\033[0m")

def main():
    if not SSOT.exists():
        print(f"❌ SSOT 없음: {SSOT}", file=sys.stderr); sys.exit(2)
    d = json.loads(SSOT.read_text())
    mode = sys.argv[1] if len(sys.argv) > 1 else "compact"

    if mode == "json":
        print(json.dumps(d, ensure_ascii=False, indent=2)); return
    if mode == "rec":
        r = d.get("recommendation", {})
        print(f"GPU→{r.get('gpu_task','?')}  CPU→{r.get('cpu_task','?')}  AVOID→{r.get('avoid','?')}")
        return

    a = age(d.get("ts", ""))
    stale = " \033[31m[STALE]\033[0m" if a > 900 else ""
    print(f"\033[1m▎ infra\033[0m  ts={d.get('ts','?')} ({fmt_age(a)}){stale}")
    h = d.get("hosts", {})

    mac = h.get("mac", {})
    print(f"  {status_color(mac.get('status'))} mac    cpu={mac.get('cpu','?')}%  gpu={mac.get('gpu','?')}%")

    ubu = h.get("ubu", {})
    if ubu:
        ram_p = int(100 * (ubu.get('ram_used_mb',0) / max(ubu.get('ram_total_mb',1),1)))
        print(f"  {status_color(ubu.get('status'))} ubu    load={ubu.get('load','?')}  ram={ram_p}% ({ubu.get('ram_used_mb',0)//1024}/{ubu.get('ram_total_mb',0)//1024}G)  gpu={ubu.get('gpu_util','?')}%  vram={ubu.get('gpu_vram_used_mb',0)//1024}/{ubu.get('gpu_vram_total_mb',0)//1024}G")

    htz = h.get("htz", {})
    if htz:
        ram_p = int(100 * (htz.get('ram_used_mb',0) / max(htz.get('ram_total_mb',1),1)))
        print(f"  {status_color(htz.get('status'))} htz    load={htz.get('load','?')}/{htz.get('cpu_threads','?')}t  ram={ram_p}% ({htz.get('ram_used_mb',0)//1024}/{htz.get('ram_total_mb',0)//1024}G)")

    vast = h.get("vast", {})
    if vast:
        print(f"  {status_color(vast.get('status'))} vast   {vast.get('gpu','?')}  vram={vast.get('vram_used_gb','?')}/{vast.get('vram_gb','?')}G  util={vast.get('gpu_util','?')}%  cpu={vast.get('cpu_pct','?')}%/{vast.get('cpu_cores','?')}c  ram={vast.get('ram_used_gb','?')}/{vast.get('ram_total_gb','?')}G  {vast.get('price_hr','?')}")

    r = d.get("recommendation", {})
    print(f"  → GPU=\033[36m{r.get('gpu_task','?')}\033[0m  CPU=\033[36m{r.get('cpu_task','?')}\033[0m  AVOID=\033[31m{r.get('avoid','?')}\033[0m")

if __name__ == "__main__":
    main()
