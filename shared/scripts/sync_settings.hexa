// sync_settings.hexa — 전 프로젝트 .claude/settings.json hexa화 동기화
// 사용: hexa shared/scripts/sync_settings.hexa
// nexus settings.json을 템플릿으로 각 프로젝트에 복사 (프로젝트별 커스텀 훅 보존)

let HOME = env("HOME")
let HEXA = HOME + "/Dev/hexa-lang/hexa"
let HOOKS = HOME + "/Dev/nexus/shared/hooks"
let ENTRY = HOOKS + "/hook-entry.hexa"

// 공통 훅 블록 (hexa 전용)
let common_hooks = "{
  \"hooks\": {
    \"UserPromptSubmit\": [
      {
        \"matcher\": \"\",
        \"hooks\": [
          {
            \"type\": \"command\",
            \"command\": \"" + HEXA + " " + ENTRY + " prompt " + HOOKS + "/nexus-prompt-scan.hexa\",
            \"timeout\": 3
          },
          {
            \"type\": \"command\",
            \"command\": \"" + HEXA + " " + ENTRY + " prompt " + HOOKS + "/go-parallel.hexa\",
            \"timeout\": 3
          }
        ]
      }
    ],
    \"PreToolUse\": [
      {
        \"matcher\": \"Write|Edit\",
        \"hooks\": [
          {
            \"type\": \"command\",
            \"command\": \"" + HEXA + " " + ENTRY + " pretool " + HOOKS + "/block-forbidden-ext.hexa\"
          },
          {
            \"type\": \"command\",
            \"command\": \"" + HEXA + " " + ENTRY + " pretool " + HOOKS + "/absolute-rules-loader.hexa\"
          }
        ]
      },
      {
        \"matcher\": \"Agent\",
        \"hooks\": [
          {
            \"type\": \"command\",
            \"command\": \"" + HEXA + " " + ENTRY + " guard\"
          }
        ]
      }
    ],
    \"PostToolUse\": [
      {
        \"matcher\": \"Bash\",
        \"hooks\": [
          {
            \"type\": \"command\",
            \"command\": \"" + HEXA + " " + ENTRY + " post " + HOOKS + "/nexus-post-bash.hexa\"
          },
          {
            \"type\": \"command\",
            \"command\": \"" + HEXA + " " + ENTRY + " post " + HOOKS + "/hexa-grammar-guard.hexa\"
          }
        ]
      },
      {
        \"matcher\": \"Write|Edit\",
        \"hooks\": [
          {
            \"type\": \"command\",
            \"command\": \"" + HEXA + " " + ENTRY + " post " + HOOKS + "/nexus-post-edit.hexa\"
          }
        ]
      }
    ]
  }
}
"

let projects = ["anima", "papers", "void", "n6-architecture", "airgenome", "contact"]
let mut changed = 0

for proj in projects {
    let dir = HOME + "/Dev/" + proj
    let settings_dir = dir + "/.claude"
    let settings_file = settings_dir + "/settings.json"

    let dir_check = to_string(exec("test -d " + dir + " && echo 'yes' || echo 'no'")).trim()
    if dir_check != "yes" { continue }

    // .claude 디렉토리 생성
    try { exec("mkdir -p " + settings_dir) } catch e {}

    // 기존 백업
    if file_exists(settings_file) {
        try { exec("cp '" + settings_file + "' '" + settings_file + ".bak'") } catch e {}
    }

    // 공통 훅 적용
    write_file(settings_file, common_hooks)
    println("[" + proj + "] settings.json hexa화 완료")

    // git add + commit + push
    try {
        exec("bash", ["-c", "cd " + dir + " && git add .claude/settings.json && git commit -m 'sync: settings.json 100% hexa화 (hook-entry.hexa)' && git push"])
        println("[" + proj + "] pushed")
    } catch e {
        println("[" + proj + "] commit/push skipped")
    }
    changed = changed + 1
}

// hexa-lang은 커스텀 훅 유지 (lint_hook 등)
let hl_dir = HOME + "/Dev/hexa-lang"
let hl_settings = hl_dir + "/.claude/settings.json"
if file_exists(hl_settings) {
    // hexa-lang 전용: 기존 커스텀 훅 + 공통 prompt-scan/go-parallel 추가
    let hl_hooks = "{
  \"hooks\": {
    \"UserPromptSubmit\": [
      {
        \"matcher\": \"\",
        \"hooks\": [
          {
            \"type\": \"command\",
            \"command\": \"" + HEXA + " " + ENTRY + " prompt " + HOOKS + "/nexus-prompt-scan.hexa\",
            \"timeout\": 3
          },
          {
            \"type\": \"command\",
            \"command\": \"" + HEXA + " " + ENTRY + " prompt " + HOOKS + "/hexa-lang-prompt-guard.hexa\",
            \"timeout\": 3
          },
          {
            \"type\": \"command\",
            \"command\": \"" + HEXA + " " + ENTRY + " prompt " + HOOKS + "/go-parallel.hexa\",
            \"timeout\": 3
          }
        ]
      }
    ],
    \"PreToolUse\": [
      {
        \"matcher\": \"Write|Edit\",
        \"hooks\": [
          {
            \"type\": \"command\",
            \"command\": \"" + HEXA + " " + ENTRY + " pretool " + HOOKS + "/block-forbidden-ext.hexa\"
          },
          {
            \"type\": \"command\",
            \"command\": \"" + HEXA + " " + ENTRY + " pretool " + HOOKS + "/absolute-rules-loader.hexa\"
          },
          {
            \"type\": \"command\",
            \"command\": \"" + HEXA + " " + ENTRY + " pretool " + HOOKS + "/hexa-only-guard.hexa\"
          }
        ]
      }
    ],
    \"PostToolUse\": [
      {
        \"matcher\": \"Write|Edit\",
        \"hooks\": [
          {
            \"type\": \"command\",
            \"command\": \"" + HEXA + " " + HOME + "/Dev/hexa-lang/self/lint_hook.hexa\",
            \"timeout\": 10
          }
        ]
      },
      {
        \"matcher\": \"Bash\",
        \"hooks\": [
          {
            \"type\": \"command\",
            \"command\": \"" + HEXA + " " + ENTRY + " post " + HOOKS + "/hexa-grammar-guard.hexa\"
          }
        ]
      }
    ]
  }
}
"
    try { exec("cp '" + hl_settings + "' '" + hl_settings + ".bak'") } catch e {}
    write_file(hl_settings, hl_hooks)
    println("[hexa-lang] settings.json hexa화 완료 (커스텀 훅 보존)")
    try {
        exec("bash", ["-c", "cd " + hl_dir + " && git add .claude/settings.json && git commit -m 'sync: settings.json 100% hexa화 (hook-entry.hexa)' && git push"])
        println("[hexa-lang] pushed")
    } catch e {
        println("[hexa-lang] commit/push skipped")
    }
    changed = changed + 1
}

println("--- " + to_string(changed) + " projects synced ---")
