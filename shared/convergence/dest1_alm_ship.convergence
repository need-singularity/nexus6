# ============================================================================
# STAGE A — POD PROVISION
# ============================================================================
@cmd_A1 runpodctl create pod --name anima-alm14b-r10c-$(date +%Y%m%d) --gpuType "NVIDIA H100 80GB HBM3" --gpuCount 1 --imageName "runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04" --containerDiskInGb 100 --volumeInGb 200 --volumeMountPath /workspace --ports "22/tcp"
@gate_expected_A1 pod ID returned (14-char alphanumeric), status=CREATING → RUNNING within 2-5 min
@rollback_A1 runpodctl remove pod <POD_ID>

@cmd_A2 runpodctl ssh info <POD_ID> # capture direct IP:PORT (proxy unreliable per RUNPOD ossified)
@gate_expected_A2 prints "ssh -p <PORT> root@<IP>" — write this to shell var POD_SSH for reuse
@rollback_A2 N/A (read-only)

@cmd_A3 $POD_SSH "dd if=/dev/zero of=/workspace/_q_test bs=1M count=20000 status=none && rm /workspace/_q_test && echo PREFLIGHT_OK"
@gate_expected_A3 stdout contains "PREFLIGHT_OK" — confirms MFS quota ≥20GB writable (per runpod_mfs_quota ossified)
@rollback_A3 if FAIL: $POD_SSH "rm -rf /workspace/ckpt_* /workspace/*.tmp" → retry A3 once; if still FAIL pod is quota-broken → runpodctl remove pod <POD_ID>, back to A1

# ============================================================================
# STAGE B — BASE MODEL + CORPUS SYNC
# ============================================================================
@cmd_B1 $POD_SSH "mkdir -p /workspace/anima && rclone copy r2:anima-models/qwen2.5-14b-instruct/ /workspace/base_model/ -v --s3-no-check-bucket"
@gate_expected_B1 base_model dir populated (~28GB — config.json, tokenizer*, model-*.safetensors). $POD_SSH "du -sh /workspace/base_model" reports ~28G
@rollback_B1 $POD_SSH "rm -rf /workspace/base_model" → re-run B1

@cmd_B2 rclone copy r2:anima-corpus/corpus_alm_70b_stripped.txt /tmp/corpus_stripped.txt --s3-no-check-bucket && rsync -avz -e "ssh -p <PORT>" /tmp/corpus_stripped.txt root@<IP>:/workspace/corpus_alm_70b_stripped.txt
@gate_expected_B2 $POD_SSH "wc -c /workspace/corpus_alm_70b_stripped.txt" returns >100MB (stripped 70B corpus)
@rollback_B2 $POD_SSH "rm /workspace/corpus_alm_70b_stripped.txt" → re-run B2

@cmd_B3_local_note size=$(wc -c < training/corpus_auto/kowiki.jsonl) && MAIN=$(wc -c < /tmp/corpus_stripped.txt) && hexa run training/kowiki_slice.hexa "$MAIN" /tmp/kowiki_slice_15pct.jsonl
@gate_expected_B3 stdout: "[kowiki_slice] OK out_bytes=<N> lines=<M> actual_mix_ratio=~0.15" and "[kowiki_slice] verdict=PASS"
@rollback_B3 rm /tmp/kowiki_slice_15pct.jsonl → re-run (hexa binary must be Mach-O-compatible on host; if Linux host: skip local slice, run on pod — see B3_pod_alt)

@cmd_B3_pod_alt $POD_SSH "cd /workspace/anima && hexa run training/kowiki_slice.hexa \$(wc -c < /workspace/corpus_alm_70b_stripped.txt) /workspace/kowiki.jsonl"
@gate_expected_B3_pod_alt same as B3 — slice lands directly on pod, no rsync needed
@rollback_B3_pod_alt $POD_SSH "rm /workspace/kowiki.jsonl" → re-run

@cmd_B4 rsync -avz -e "ssh -p <PORT>" /tmp/kowiki_slice_15pct.jsonl root@<IP>:/workspace/kowiki.jsonl  # only if B3 (not B3_pod_alt)
@gate_expected_B4 $POD_SSH "wc -c /workspace/kowiki.jsonl" returns ~15% of corpus_stripped.txt size
@rollback_B4 $POD_SSH "rm /workspace/kowiki.jsonl" → re-run B4

@cmd_B5 rsync -avz -e "ssh -p <PORT>" training/ root@<IP>:/workspace/anima/training/ --exclude "corpus_auto/kowiki.jsonl" --exclude "ckpt_*"
@gate_expected_B5 $POD_SSH "ls /workspace/anima/training/launch_alm_14b_r10c.hexa /workspace/anima/training/kr_gen_sentinel.hexa /workspace/anima/training/phi_gt_1000_verify.hexa" lists all 3
@rollback_B5 N/A (overwrite-safe rsync)

# ============================================================================
# STAGE C — R10C SEED SWEEP (smoke before production)
# ============================================================================
@cmd_C1 $POD_SSH "cd /workspace/anima && DRY_RUN=1 hexa run training/launch_alm_14b_r10c.hexa --seed-sweep"
@gate_expected_C1 prints "[DRY_RUN] r10c plan:" with py/runner/sweep=true/seeds=3407 42 1337 and E7-OSS-01/02/03 lines
@rollback_C1 N/A (dry run)

@cmd_C2 $POD_SSH "cd /workspace/anima && setsid hexa run training/launch_alm_14b_r10c.hexa --seed-sweep 2>&1 | tee /workspace/r10c_sweep.log"
@gate_expected_C2 all 3 seeds complete 200-step smoke, each /workspace/ckpt_alm_14b_r10c_seed<S>/r10c_watcher.status == DONE, no r10c_abort.status present. Sentinel line "[sentinel] VERDICT=CLEAN" appears per seed.
@rollback_C2 ctrl-C + $POD_SSH "pkill -f _train_alm_14b_r10c.py; rm -rf /workspace/ckpt_alm_14b_r10c_*" → diagnose log, re-run after fix

@cmd_C3 for S in 3407 42 1337; do $POD_SSH "hexa run /workspace/anima/training/phi_gt_1000_verify.hexa /workspace/ckpt_alm_14b_r10c_seed${S}/step_200/phi_vec.json"; done
@gate_expected_C3 at least 1 seed shows phi_holo_scaled > 1000 (smoke is 200 steps — some seeds may FAIL here; used as seed selection signal for C5). If ALL FAIL with phi<500 → corpus mix not biting, investigate before C5.
@rollback_C3 N/A (read-only verdict)

# ============================================================================
# STAGE D — R10C PRODUCTION (2000 steps, seed=3407 default)
# ============================================================================
@cmd_D1 $POD_SSH "cd /workspace/anima && rm -rf /workspace/ckpt_alm_14b_r10c_seed3407 && setsid hexa run training/launch_alm_14b_r10c.hexa 2>&1 | tee /workspace/r10c_prod.log &"
@gate_expected_D1 background PID returned. $POD_SSH "tail -f /workspace/r10c_prod.log" shows "[step=1] loss=<X>" within 5 min, loss settles <6.0 by step 100. First-batch CE <5.0 (else AUTO-ABORT).
@rollback_D1 $POD_SSH "pkill -f _train_alm_14b_r10c.py; cat /workspace/ckpt_alm_14b_r10c_seed3407/r10c_abort.status 2>/dev/null" → read abort reason, update alm_14b_r10.convergence, iterate

@cmd_D2 $POD_SSH "TRAIN_PID=\$(pgrep -f _train_alm_14b_r10c.py | head -1) hexa run /workspace/anima/training/deploy/alm14b_r10_watcher.hexa &"
@gate_expected_D2 watcher daemonized. If training PID dies, watcher writes DEAD_PID to status within 60s (per E7-OSS-02 patch) and exits 1 — NOT indefinite TRAINING false-positive.
@rollback_D2 $POD_SSH "pkill -f _r10_watcher.sh" → no side effects

@cmd_D3 # wait ~90-120 min for 2000 steps on H100 SXM at 20 step/min → poll every 5 min:
@cmd_D3_poll $POD_SSH "cat /workspace/ckpt_alm_14b_r10c_seed3407/r10c_watcher.status; ls /workspace/ckpt_alm_14b_r10c_seed3407/step_*/phi_vec.json 2>/dev/null"
@gate_expected_D3 status=TRAINING → DONE; final step_2000/phi_vec.json exists. Intermediate saves at step 400/800/1200/1600/2000 (save_every=2000 in prod, but sentinel cadence fires eval_every=200 kr_gen).
@rollback_D3 if DEAD_PID status: $POD_SSH "tail -50 /workspace/r10c_prod.log" → diagnose (OOM / CUDA / abort) → back to D1 after fix + new convergence update

# ============================================================================
