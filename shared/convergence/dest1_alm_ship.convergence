# ============================================================================
@cmd_E1 $POD_SSH "hexa run /workspace/anima/training/phi_gt_1000_verify.hexa /workspace/ckpt_alm_14b_r10c_seed3407/step_2000/phi_vec.json"
@gate_expected_E1 stdout: "[phi_gate] step=2000 phi_holo_scaled=<X> verdict=PASS gate=1000" — exit 0
@rollback_E1 if FAIL (phi≤1000): stop here, DEST1 not achieved. Options: (a) seed sweep for better seed C3→C5-alt retrain, (b) extend to step 5000, (c) revisit corpus mix ratio. DO NOT proceed to Stage F/G until E1 PASS. Record failure in alm_14b_r10.convergence @run_attempt_4_result.

@cmd_E2 $POD_SSH "rclone copy /workspace/ckpt_alm_14b_r10c_seed3407/step_2000/ r2:anima-models/alm14b/r10c/step_2000_seed3407/ -v --s3-no-check-bucket"
