// uprim.hexa — anima u_* builtin shim
//
// Purpose: hexa-lang runtime.c exposes `log`, `env`, `floor`, `hexa_u_floor`
// natively, but some anima/training/serving sources reference `u_log`,
// `u_env`, `u_floor(x)` (single-arg) which the codegen does not route.
//
// This shim wraps the native primitives so consumers can `use "shared/lib/uprim"`
// and call u_log/u_env/u_floor1 uniformly without waiting on a sister (hexa-lang)
// patch. Stage0 safe, .py-free (R37/AN13/L3-PY).
//
// refs:
//   hexa-lang/self/codegen_c2.hexa#2852  log    -> hexa_math_log
//   hexa-lang/self/codegen_c2.hexa#2863  env    -> hexa_env_var
//   hexa-lang/self/codegen_c2.hexa#2875  floor  -> hexa_math_floor
//   hexa-lang/self/codegen_c2.hexa#2401  u_floor(a,b) -> hexa_u_floor (py //)

// u_log(x: float) -> float — natural log wrapper over builtin `log`.
fn u_log(x: float) -> float {
  log(x)
}

// u_env(name: string) -> string — env var wrapper over builtin `env`.
fn u_env(name: string) -> string {
  env(name)
}

// u_floor1(x: float) -> int — single-arg floor (IEEE 754) wrapper over
// builtin `floor`. Note: codegen already routes `u_floor(a,b)` as the
// two-arg Python `a // b` surrogate (hexa_u_floor). Consumers that need
// the single-arg form should call u_floor1 explicitly to avoid collision.
fn u_floor1(x: float) -> int {
  floor(x)
}
