// n6_emergence.hexa — extended 렌즈 (Rust 포팅)
// 카테고리: extended · 도메인: biology
// 원본: n6_lenses.rs · 이름: emergence
// 검증 축: Identify macro-patterns arising from micro-level interactions

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 렌즈별 핵심 상수 점검
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

// ─── D5: atlas.signals.n6 연동 (signal 입력 섹션) ───
let HOME = env("HOME")
let SIGNALS = HOME + "/Dev/nexus/shared/n6/atlas.signals.n6"

fn _count(file: string, pat: string) -> i64 {
    let cmd = "grep -c '" + pat + "' '" + file + "' 2>/dev/null || echo 0"
    let r = exec(cmd)
    let s_raw = if type_of(r) == "str" || type_of(r) == "string" { r } else { "0" }
    let s = s_raw.trim().split("\n")[0]
    let mut v: i64 = 0
    try { v = to_int(s) } catch e { v = 0 }
    return v
}

let n_sig_total = _count(SIGNALS, "^@S ")
let n_sig_cross = _count(SIGNALS, "\\[CROSS")
let n_sig_m10 = _count(SIGNALS, "\\[M10\\]")
let n_sig_m10star = _count(SIGNALS, "\\[M10\\*\\]")

println("lens[emergence] category=extended axis=\"Identify macro-patterns arising from micro-level interactions\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
println("  signals: total=" + to_string(n_sig_total) + "  [M10*]=" + to_string(n_sig_m10star) + "  [M10]=" + to_string(n_sig_m10) + "  [CROSS]=" + to_string(n_sig_cross))
