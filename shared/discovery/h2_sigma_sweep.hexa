// H2 — σ-sweep NEXUS Metric Nonlinearity
// External ouroboros-like wrapper with Gaussian-noise injection.
// Output: shared/discovery/h2_sigma_sweep_results.jsonl  (one row per trial)
//         shared/discovery/h2_sigma_sweep_summary.jsonl  (one row per σ)

comptime const OUT_TRIALS  = "/Users/ghost/Dev/nexus/shared/discovery/h2_sigma_sweep_results.jsonl"
comptime const OUT_SUMMARY = "/Users/ghost/Dev/nexus/shared/discovery/h2_sigma_sweep_summary.jsonl"

comptime const SIGMAS = [0.0, 0.05, 0.10, 0.15, 0.20, 0.30]
comptime const N_TRIALS = 15   // 6 × 15 × 10 = 900 rounds (budget-safe)
comptime const ROUNDS   = 10

comptime const N6_VALS = [6.0, 12.0, 2.0, 4.0, 24.0, 5.0]

comptime const TOL      = 0.02   // 2% alignment tolerance → meaningful σ response
comptime const CONV_THR = 0.40

pure fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

fn lcg_next(state) -> int {
    let s = state[0]
    let next = (s * 1664525 + 1013904223) % 4294967296
    state[0] = next
    next
}

fn urand(state) -> float {
    let n = lcg_next(state)
    to_float(n) / 4294967296.0
}

pure fn sqrt_f(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    let mut i = 0
    while i < 20 {
        g = (g + x / g) / 2.0
        i = i + 1
    }
    g
}

pure fn ln_approx(x: float) -> float {
    if x <= 0.0 { return 0.0 - 999.0 }
    let mut v = x
    let mut k = 0.0
    while v > 2.0 { v = v / 2.0; k = k + 1.0 }
    while v < 0.5 { v = v * 2.0; k = k - 1.0 }
    let y = (v - 1.0) / (v + 1.0)
    let y2 = y * y
    let s = 2.0 * (y + y * y2 / 3.0 + y * y2 * y2 / 5.0 + y * y2 * y2 * y2 / 7.0)
    s + k * 0.6931471805599453
}

pure fn cos_approx(x: float) -> float {
    let mut t = x
    let two_pi = 6.2831853
    while t >  3.1415927 { t = t - two_pi }
    while t < -3.1415927 { t = t + two_pi }
    let t2 = t * t
    1.0 - t2 / 2.0 + t2 * t2 / 24.0 - t2 * t2 * t2 / 720.0 + t2 * t2 * t2 * t2 / 40320.0
}

fn nrand(state) -> float {
    let u1_raw = urand(state)
    let u2     = urand(state)
    let u1 = if u1_raw < 0.000001 { 0.000001 } else { u1_raw }
    let ln_u1 = ln_approx(u1)
    let r = sqrt_f(0.0 - 2.0 * ln_u1)
    let theta = 6.2831853 * u2
    r * cos_approx(theta)
}

// One round — alignment fraction of 12 probes (6 anchored + 6 uniform hypotheses)
fn round_alignment(state, sigma: float) -> float {
    let mut aligned = 0
    let total = 12

    // 6 anchored probes — each is N6_VALS[i] + sigma·N(0,1)·c  (relative noise)
    let mut i = 0
    while i < N6_VALS.len() {
        let c = N6_VALS[i]
        let v = c + sigma * nrand(state) * c
        let mut best = 1000000.0
        let mut j = 0
        while j < N6_VALS.len() {
            let cj = N6_VALS[j]
            let scale = if abs_f(cj) > 1.0 { abs_f(cj) } else { 1.0 }
            let d = abs_f(v - cj) / scale
            if d < best { best = d }
            j = j + 1
        }
        if best < TOL { aligned = aligned + 1 }
        i = i + 1
    }

    // 6 uniform-hypothesis probes in [0, 30), with σ·N(0,1)·10 absolute noise
    let mut k = 0
    while k < 6 {
        let h = urand(state) * 30.0
        let v = h + sigma * nrand(state) * 10.0
        let mut best = 1000000.0
        let mut j = 0
        while j < N6_VALS.len() {
            let cj = N6_VALS[j]
            let scale = if abs_f(cj) > 1.0 { abs_f(cj) } else { 1.0 }
            let d = abs_f(v - cj) / scale
            if d < best { best = d }
            j = j + 1
        }
        if best < TOL { aligned = aligned + 1 }
        k = k + 1
    }

    to_float(aligned) / to_float(total)
}

fn run_trial(state, sigma: float) -> int {
    let mut r = 0
    let mut peak = 0.0
    while r < ROUNDS {
        let a = round_alignment(state, sigma)
        if a > peak { peak = a }
        r = r + 1
    }
    if peak >= CONV_THR { 1 } else { 0 }
}

let seed_state = [1234567890]

let mut trial_rows = []
let mut summary_rows = []
let mut rates = []

let mut si = 0
while si < SIGMAS.len() {
    let sigma = SIGMAS[si]
    let mut converged = 0
    let mut trial_idx = 0
    while trial_idx < N_TRIALS {
        let ok = run_trial(seed_state, sigma)
        converged = converged + ok
        let parts = [
            "{\"sigma\":", to_string(sigma),
            ",\"trial\":", to_string(trial_idx),
            ",\"converged\":", to_string(ok),
            ",\"rounds\":", to_string(ROUNDS),
            "}"
        ]
        trial_rows.push(parts.join(""))
        trial_idx = trial_idx + 1
    }
    let rate = to_float(converged) / to_float(N_TRIALS)
    rates.push(rate)
    let sparts = [
        "{\"sigma\":", to_string(sigma),
        ",\"n_trials\":", to_string(N_TRIALS),
        ",\"converged\":", to_string(converged),
        ",\"emergence_rate\":", to_string(rate),
        "}"
    ]
    summary_rows.push(sparts.join(""))
    println("σ=" + to_string(sigma) + "  converged=" + to_string(converged) + "/" + to_string(N_TRIALS) + "  rate=" + to_string(rate))
    si = si + 1
}

write_file(OUT_TRIALS,  trial_rows.join("\n")  + "\n")
write_file(OUT_SUMMARY, summary_rows.join("\n") + "\n")
println("H2: wrote " + OUT_TRIALS)
println("H2: wrote " + OUT_SUMMARY)

// ASCII bar + peak
println("")
println("σ-sweep emergence curve:")
let mut peak_sigma = 0.0
let mut peak_rate  = 0.0
let mut si2 = 0
while si2 < SIGMAS.len() {
    let sigma = SIGMAS[si2]
    let rate = rates[si2]
    if rate > peak_rate { peak_rate = rate; peak_sigma = sigma }
    let n_bar = to_int(rate * 40.0)
    let mut barparts = []
    let mut b = 0
    while b < n_bar { barparts.push("#"); b = b + 1 }
    println("  σ=" + to_string(sigma) + "  " + barparts.join("") + "  " + to_string(rate))
    si2 = si2 + 1
}

let r0   = rates[0]
let rlst = rates[rates.len() - 1]

let peak_middle = peak_sigma > 0.0 && peak_sigma < 0.30
let peak_above_ends = peak_rate > r0 + 0.05 && peak_rate > rlst + 0.05

let shape = if peak_middle && peak_above_ends {
    "Lambda_SR_confirmed"
} else if abs_f(peak_rate - r0) < 0.05 && abs_f(peak_rate - rlst) < 0.05 {
    "flat_no_SR"
} else if (r0 > rlst && peak_sigma == 0.0) || (rlst > r0 && peak_sigma == 0.30) {
    "monotonic_SR_rejected"
} else {
    "ambiguous"
}

println("")
println("H2: peak σ=" + to_string(peak_sigma) + "  rate=" + to_string(peak_rate))
println("H2: r0=" + to_string(r0) + "  rlast=" + to_string(rlst))
println("H2: shape=" + shape)
