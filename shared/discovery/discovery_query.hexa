// ═══════════════════════════════════════════════════════════
// discovery_query.hexa — DISC-P3-1 thin wrapper
//   사용: hexa run shared/discovery/discovery_query.hexa <subcmd> <args...>
//   위임: /usr/bin/python3 shared/discovery/discovery_query.py
//
// hexa-first-exempt 사유 (note field):
//   hexa stage1 runtime 에 sqlite3 bindings 부재 → Python 3 표준 라이브러리 sqlite3 사용.
//   본 래퍼는 sqlite3 CLI 위임 패턴(discovery_infra.hexa --sqlite)과 동일한 설계.
//
// 서브커맨드: ts <start> <end> | kind <k> | recent <n> | bench
// 인자 없으면 usage 출력.
// @no-lock-needed @allow-bare-exec
// ═══════════════════════════════════════════════════════════

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"  // @allow-devpath
let PY = "/usr/bin/python3"
let SCRIPT = NEXUS + "/shared/discovery/discovery_query.py"

fn _shq(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

let a = args()
if len(a) < 3 {
    println("usage: hexa run shared/discovery/discovery_query.hexa <ts|kind|recent|bench> [args...]")
    println("  ts <start_iso> <end_iso>    range query on ts")
    println("  kind <k>                    kind query")
    println("  recent <n>                  last n by ts")
    println("  bench                       100 random queries, p50/p95/p99 ms")
    exit(2)
}

let mut cmd = _shq(PY) + " " + _shq(SCRIPT)
let mut i: i64 = 2
while i < len(a) {
    cmd = cmd + " " + _shq(_str(a[i]))
    i = i + 1
}

let out = _str(exec(cmd + " 2>&1"))  // @allow-bare-exec — delegates to trusted local python
println(out.trim())
exit(0)
