    println("  6 = n Loeb-aware meta-rules (H-DOD/SCOPE/CLAIM-LEX/CONFESS/VERIFIER/BLIND-GT)")
    println("  28 = perfect deny patterns in permissions_ssot")
    println("  4 = tau reject-only modules (pre_tool_guard/cmd_gate/lockdown_gate/lint)")
    println("  4 = tau self-modification channels (gc/autofix/bitter-gate/instinct)")
    println("  5 = sopfr timeout-exempt modules (LONG_RUN_MODULES)")
    println("  3 = n/phi safe self-modification channels")
    println("  3 = n/phi minimum self-referential cycles")
    println("  10 = sigma-phi audit category ceiling")
    println("  70 = sopfr*(sigma+phi) audit max score")
    println("")
    println("structural findings (MATHEMATICAL FACT, not n=6):")
    println("  F1: harness IS a formal system subject to Goedel incompleteness")
    println("  F2: self_check IS a Kleene fixed point")
    println("  F3: multi-level verification IS the optimal response to incompleteness")
    println("  F4: user-as-oracle IS necessary for escaping Tarski hierarchy")
    println("  F5: reject-only modules ARE Loeb-safe (they never self-approve)")
    println("  F6: timeout IS a pragmatic halting oracle (sound but incomplete)")
    println("")
    println("results: shared/bt/attacks/bt547_results.jsonl")
    if file_exists(RESULTS_PATH) {
        let mut cnt = 0
        try { cnt = to_int(_str(exec("wc -l < '" + RESULTS_PATH + "' 2>/dev/null || echo 0")).trim()) } catch e {}
        println("findings: " + is(cnt))
    }
    println("")
    println("gaps:")
    println("  G1: n=6 coincidences are numerological, not structural")
    println("  G2: Goedel applies generally -- not specific to n=6")
    println("  G3: harness contraction (Banach) is empirical, not proven")
    println("  G4: instinct.hexa auto-promotion is borderline Loeb-unsafe")
    println("")
    println("next (R2 candidates):")
    println("  R2-A: formalize harness as PA fragment, count independent sentences")
    println("  R2-B: construct explicit Goedel sentence for NEXUS harness")
    println("  R2-C: measure actual contraction factor k across session history")
    println("  R2-D: prove or disprove instinct.hexa Loeb-safety")
}

// ===============================================================
fn main() {
    let argv = args()
    let mut mode = "status"
    if argv.len() >= 2 { mode = _str(argv[1]).trim() }
    if argv.len() >= 3 { mode = _str(argv[2]).trim() }
    if mode == "scan" { cmd_scan() }
    else if mode == "verify" { cmd_verify() }
    else if mode == "status" { cmd_status() }
    else { println("usage: hexa bt547_harness_singularity.hexa <scan|verify|status>") }
}

main()
