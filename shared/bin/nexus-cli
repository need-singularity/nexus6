#!/bin/bash
# nexus-cli — 외부 프로젝트(hive 등) 전용 단일 CLI 진입점
# thin wrapper: hexa resolver 경유로 shared/engine/nexus_cli.hexa 호출
# spec: shared/engine/nexus_cli_spec.json
#
# usage: nexus-cli <subcmd> [flags...]
# exit codes: 0=성공 1=실행오류 2=인자오류 3=gate거부

set -e

NEXUS_ROOT="${NEXUS:-${HOME}/Dev/nexus}"
HEXA="${NEXUS_ROOT}/shared/bin/hexa"
ENGINE="${NEXUS_ROOT}/shared/engine/nexus_cli.hexa"

if [ ! -x "$HEXA" ]; then
    echo "ERROR(nexus-cli): hexa resolver 부재: $HEXA" >&2
    exit 127
fi

if [ ! -f "$ENGINE" ]; then
    echo "ERROR(nexus-cli): engine 부재: $ENGINE" >&2
    exit 127
fi

# --catalog: bypass hexa runtime to emit pure JSON (no runtime banner)
# spec sidecar SSOT. hive dynamic loader uses this.
if [ "${1:-}" = "--catalog" ]; then
    SPEC="${NEXUS_ROOT}/shared/engine/nexus_cli_spec.json"
    if [ ! -f "$SPEC" ]; then
        echo "ERROR(nexus-cli --catalog): spec not found: $SPEC" >&2
        exit 1
    fi
    exec cat "$SPEC"
fi

exec "$HEXA" run "$ENGINE" "$@"
