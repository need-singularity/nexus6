#!/bin/bash
# hexa-cognitive — 인지 모듈 annotation 수집기 (grep MVP, v0.1)
#
# 25 annotation kinds, 5 카테고리 (vision/audio/memory/emotion/plan).
#
# 입력:
#   hexa-cognitive <file.hexa> [<file2.hexa> ...]
#   hexa-cognitive --dir <directory>
#   hexa-cognitive [--kind <name>] <files...>
#
# 출력 (stdout JSON):
#   { "version":"0.1", "source":"grep-mvp",
#     "annotations":[ {kind, fn, file, line, meta{...}} ],
#     "summary":{ <kind>:count..., total } }
#
# 인식 annotation (25종, fn decl 바로 위 라인, stacking 허용):
#   vision:  @vision(modality=image|video) @visual_cortex(v1|v2|mt) @saliency @gestalt @feature
#   audio:   @audio(srate_hz=<i>, ch=<i>) @cochlea(freq_bins=<i>) @pitch(hz=<f>) @timbre(mfcc=<i>) @prosody
#   memory:  @episodic(timestamp=<i>, context=<s>) @semantic(concept=<s>) @working(span_ms=<i>, slots=<i>)
#            @procedural(skill=<s>) @consolidate(stage=hippocampus|cortex)
#   emotion: @emotion(valence=<f>, arousal=<f>) @affect @mood @feeling(label=<s>) @appraisal
#   plan:    @plan(steps=<i>) @goal(priority=<i>, deadline=<s>) @hierarchy(level=<i>)
#            @decompose(parent=<s>, children=<i>) @replan(trigger=<s>)
#
# 학습 용어 규칙: learn/학습만 (train/훈련 금지).
#
# exit 0 정상 (빈 annotations 포함). 1=인자 오류
set -eu

# SSOT: 25 kinds
KINDS="vision visual_cortex saliency gestalt feature \
audio cochlea pitch timbre prosody \
episodic semantic working procedural consolidate \
emotion affect mood feeling appraisal \
plan goal hierarchy decompose replan"

usage() {
    cat >&2 <<EOF
usage: hexa-cognitive [--kind <name>] <file.hexa> [file2.hexa ...]
       hexa-cognitive [--kind <name>] --dir <directory>

kinds (25): vision visual_cortex saliency gestalt feature
            audio cochlea pitch timbre prosody
            episodic semantic working procedural consolidate
            emotion affect mood feeling appraisal
            plan goal hierarchy decompose replan
EOF
    exit 1
}

valid_kind() {
    local k="$1"
    for v in $KINDS; do
        [ "$v" = "$k" ] && return 0
    done
    return 1
}

filter_kind=""
files=()

while [ $# -gt 0 ]; do
    case "$1" in
        --kind)
            shift
            [ $# -ge 1 ] || usage
            if valid_kind "$1"; then
                filter_kind="$1"
            else
                echo "ERROR: invalid kind: $1" >&2
                usage
            fi
            shift
            ;;
        --dir)
            shift
            [ $# -ge 1 ] || usage
            dir="$1"
            [ -d "$dir" ] || { echo "ERROR: directory not found: $dir" >&2; exit 1; }
            while IFS= read -r -d '' f; do files+=("$f"); done < <(find "$dir" -type f -not -path "*/.claude/*" -not -path "*/node_modules/*" -name "*.hexa" -print0)
            shift
            ;;
        -h|--help)
            usage
            ;;
        *)
            [ -f "$1" ] || { echo "ERROR: file not found: $1" >&2; exit 1; }
            files+=("$1")
            shift
            ;;
    esac
done

[ "${#files[@]}" -gt 0 ] || usage

# pass 25-kind list to awk
KINDS_CSV=$(echo "$KINDS" | tr ' ' ',')

awk -v filter_kind="$filter_kind" -v kinds_csv="$KINDS_CSV" '
function json_escape(s,   r) {
    r = s
    gsub(/\\/, "\\\\", r)
    gsub(/"/, "\\\"", r)
    gsub(/\t/, "\\t", r)
    gsub(/\r/, "\\r", r)
    gsub(/\n/, "\\n", r)
    return r
}
function extract_all_kv(line, kv_keys, kv_vals,    tmp, k, v, n, i, ch) {
    n = 0
    delete kv_keys
    delete kv_vals
    tmp = line
    if (!match(tmp, /@[a-z_]+\(/)) return 0
    tmp = substr(tmp, RSTART + RLENGTH)
    while (1) {
        sub(/^[[:space:],]+/, "", tmp)
        if (length(tmp) == 0) break
        if (substr(tmp, 1, 1) == ")") break
        if (!match(tmp, /^[A-Za-z_][A-Za-z0-9_]*/)) break
        k = substr(tmp, 1, RLENGTH)
        tmp = substr(tmp, RLENGTH + 1)
        sub(/^[[:space:]]*=[[:space:]]*/, "", tmp)
        if (substr(tmp, 1, 1) == "\"") {
            v = ""
            i = 2
            while (i <= length(tmp)) {
                ch = substr(tmp, i, 1)
                if (ch == "\\" && i < length(tmp)) {
                    v = v substr(tmp, i, 2)
                    i += 2
                    continue
                }
                if (ch == "\"") break
                v = v ch
                i++
            }
            tmp = substr(tmp, i + 1)
            gsub(/\\"/, "\"", v)
            gsub(/\\\\/, "\\", v)
        } else {
            if (match(tmp, /[,)[:space:]]/)) {
                v = substr(tmp, 1, RSTART - 1)
                tmp = substr(tmp, RSTART)
            } else {
                v = tmp
                tmp = ""
            }
        }
        n++
        kv_keys[n] = k
        kv_vals[n] = v
    }
    return n
}
function detect_kind(line,    k, n_k, i, re) {
    # split KINDS_CSV into list
    n_k = split(kinds_csv, klist, ",")
    for (i = 1; i <= n_k; i++) {
        k = klist[i]
        re = "^[[:space:]]*@" k "([[:space:]]*\\(|[[:space:]]*$|[[:space:]]*\\/\\/|[[:space:]]*#)"
        if (line ~ re) return k
    }
    return ""
}

BEGIN {
    n_staged = 0
    total = 0
    n_k = split(kinds_csv, klist, ",")
    for (i = 1; i <= n_k; i++) {
        cnt[klist[i]] = 0
    }
}

{
    kind = detect_kind($0)
    is_anno = (kind != "")
    is_fn = ($0 ~ /^[[:space:]]*(pub[[:space:]]+)?fn[[:space:]]+[A-Za-z_][A-Za-z0-9_]*/)
    is_blank = ($0 ~ /^[[:space:]]*$/)
    is_comment = ($0 ~ /^[[:space:]]*(\/\/|#)/)
}

is_anno {
    line = $0

    n_staged++
    staged_kind[n_staged] = kind
    staged_line[n_staged] = FNR
    staged_file[n_staged] = FILENAME

    delete kv_k
    delete kv_v
    nk = extract_all_kv(line, kv_k, kv_v)
    staged_nkv[n_staged] = nk
    for (i = 1; i <= nk; i++) {
        staged_k[n_staged, i] = kv_k[i]
        staged_v[n_staged, i] = kv_v[i]
    }
    next
}

is_fn && n_staged > 0 {
    fn_name = ""
    tmp = $0
    sub(/^[[:space:]]*(pub[[:space:]]+)?fn[[:space:]]+/, "", tmp)
    if (match(tmp, /^[A-Za-z_][A-Za-z0-9_]*/)) {
        fn_name = substr(tmp, 1, RLENGTH)
    }

    for (s = 1; s <= n_staged; s++) {
        k = staged_kind[s]
        if (filter_kind != "" && filter_kind != k) continue

        if (total > 0) printf ","
        total++
        cnt[k]++

        printf "{"
        printf "\"kind\":\"%s\"", json_escape(k)
        printf ",\"fn\":\"%s\"", json_escape(fn_name)
        printf ",\"file\":\"%s\"", json_escape(staged_file[s])
        printf ",\"line\":%d", staged_line[s]
        printf ",\"meta\":{"
        nk = staged_nkv[s]
        for (i = 1; i <= nk; i++) {
            if (i > 1) printf ","
            printf "\"%s\":\"%s\"", json_escape(staged_k[s, i]), json_escape(staged_v[s, i])
        }
        printf "}"
        printf "}"
    }

    for (s = 1; s <= n_staged; s++) {
        delete staged_kind[s]
        delete staged_line[s]
        delete staged_file[s]
        delete staged_nkv[s]
    }
    for (key in staged_k) delete staged_k[key]
    for (key in staged_v) delete staged_v[key]
    n_staged = 0
    next
}

(!is_anno && !is_fn && !is_comment) {
    if (n_staged > 0 && is_blank) {
        for (s = 1; s <= n_staged; s++) {
            delete staged_kind[s]
            delete staged_line[s]
            delete staged_file[s]
            delete staged_nkv[s]
        }
        for (key in staged_k) delete staged_k[key]
        for (key in staged_v) delete staged_v[key]
        n_staged = 0
    }
}

END {
    # emit pipe-separated summary — kinds_csv 순서
    out = ""
    n_k = split(kinds_csv, klist, ",")
    for (i = 1; i <= n_k; i++) {
        if (i > 1) out = out "|"
        out = out cnt[klist[i]]
    }
    out = out "|" total
    print out > "/dev/stderr"
}
' "${files[@]}" > /tmp/.hexa-cognitive.$$.body 2> /tmp/.hexa-cognitive.$$.summary

body="$(cat /tmp/.hexa-cognitive.$$.body 2>/dev/null || true)"
summary_line="$(cat /tmp/.hexa-cognitive.$$.summary 2>/dev/null || true)"
rm -f /tmp/.hexa-cognitive.$$.body /tmp/.hexa-cognitive.$$.summary

# parse summary — 25 kinds + total
if [ -z "$summary_line" ]; then
    # build zeros
    zeros=""
    n_zero=0
    for k in $KINDS; do
        [ -n "$zeros" ] && zeros="${zeros}|"
        zeros="${zeros}0"
        n_zero=$((n_zero + 1))
    done
    summary_line="${zeros}|0"
fi

# split by pipe into array
IFS='|' read -r -a parts <<< "$summary_line"
n_parts=${#parts[@]}

# build summary JSON
summary_json=""
idx=0
for k in $KINDS; do
    v="${parts[$idx]:-0}"
    [ -n "$summary_json" ] && summary_json="${summary_json},"
    summary_json="${summary_json}\"${k}\":${v}"
    idx=$((idx + 1))
done
total="${parts[$idx]:-0}"
summary_json="${summary_json},\"total\":${total}"

printf '{"version":"0.1","source":"grep-mvp","annotations":[%s],"summary":{%s}}\n' \
    "$body" "$summary_json"
