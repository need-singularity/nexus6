#!/bin/bash
# hexa-infer — 추론 최적화 annotation 통합 수집기 (grep MVP, v0.1)
#
# 입력:
#   hexa-infer <file.hexa> [<file2.hexa> ...]
#   hexa-infer --dir <directory>
#   hexa-infer [--kind infer|quantize|cache_kv|speculate|batch_continuous] <files...>
#
# 출력 (stdout JSON):
#   { "version":"0.1", "source":"grep-mvp",
#     "annotations":[ {kind, fn, file, line, meta{...}} ],
#     "summary":{ infer, quantize, cache_kv, speculate, batch_continuous, total } }
#
# 인식 annotation (fn decl 바로 위 라인, stacking 허용):
#   @infer(model="<id>", cost_per_mtok=<float>, latency_ms=<int>)
#   @quantize(bits=<4|8|16>, scheme="<gptq|awq|int4_gqa>")
#   @cache_kv(ratio=<float 0..1>, policy="<lru|fifo>")
#   @speculate(method="<tree|medusa|eagle>", draft="<small_model_id>")
#   @batch_continuous(max_batch=<int>, paged_attention=<bool>)
#
# exit 0 정상 (빈 annotations 포함). 1=인자 오류
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-infer [--kind infer|quantize|cache_kv|speculate|batch_continuous] <file.hexa> [file2.hexa ...]
       hexa-infer [--kind ...] --dir <directory>
EOF
    exit 1
}

filter_kind=""
files=()

# parse args
while [ $# -gt 0 ]; do
    case "$1" in
        --kind)
            shift
            [ $# -ge 1 ] || usage
            case "$1" in
                infer|quantize|cache_kv|speculate|batch_continuous) filter_kind="$1" ;;
                *) echo "ERROR: invalid kind: $1" >&2; usage ;;
            esac
            shift
            ;;
        --dir)
            shift
            [ $# -ge 1 ] || usage
            dir="$1"
            [ -d "$dir" ] || { echo "ERROR: directory not found: $dir" >&2; exit 1; }
            while IFS= read -r -d '' f; do files+=("$f"); done < <(find "$dir" -type f -not -path "*/.claude/*" -not -path "*/node_modules/*" -name "*.hexa" -print0)
            shift
            ;;
        -h|--help)
            usage
            ;;
        *)
            [ -f "$1" ] || { echo "ERROR: file not found: $1" >&2; exit 1; }
            files+=("$1")
            shift
            ;;
    esac
done

[ "${#files[@]}" -gt 0 ] || usage

# awk 엔진 — annotation 라인을 stage 하고 fn decl 에서 flush.
awk -v filter_kind="$filter_kind" '
function json_escape(s,   r) {
    r = s
    gsub(/\\/, "\\\\", r)
    gsub(/"/, "\\\"", r)
    gsub(/\t/, "\\t", r)
    gsub(/\r/, "\\r", r)
    gsub(/\n/, "\\n", r)
    return r
}
function extract_all_kv(line, kv_keys, kv_vals,    tmp, k, v, n, i, ch) {
    # 모든 key=value 쌍을 수집 — depth 1 only
    n = 0
    delete kv_keys
    delete kv_vals
    tmp = line
    # find opening paren after @name
    if (!match(tmp, /@[a-z_]+\(/)) return 0
    tmp = substr(tmp, RSTART + RLENGTH)
    while (1) {
        sub(/^[[:space:],]+/, "", tmp)
        if (length(tmp) == 0) break
        if (substr(tmp, 1, 1) == ")") break
        # key
        if (!match(tmp, /^[A-Za-z_][A-Za-z0-9_]*/)) break
        k = substr(tmp, 1, RLENGTH)
        tmp = substr(tmp, RLENGTH + 1)
        sub(/^[[:space:]]*=[[:space:]]*/, "", tmp)
        # value
        if (substr(tmp, 1, 1) == "\"") {
            v = ""
            i = 2
            while (i <= length(tmp)) {
                ch = substr(tmp, i, 1)
                if (ch == "\\" && i < length(tmp)) {
                    v = v substr(tmp, i, 2)
                    i += 2
                    continue
                }
                if (ch == "\"") break
                v = v ch
                i++
            }
            tmp = substr(tmp, i + 1)
            gsub(/\\"/, "\"", v)
            gsub(/\\\\/, "\\", v)
        } else {
            if (match(tmp, /[,)[:space:]]/)) {
                v = substr(tmp, 1, RSTART - 1)
                tmp = substr(tmp, RSTART)
            } else {
                v = tmp
                tmp = ""
            }
        }
        n++
        kv_keys[n] = k
        kv_vals[n] = v
    }
    return n
}

BEGIN {
    n_staged = 0
    total = 0
    cnt_infer = 0
    cnt_quantize = 0
    cnt_cache_kv = 0
    cnt_speculate = 0
    cnt_batch_continuous = 0
}

{
    is_infer            = ($0 ~ /^[[:space:]]*@infer([[:space:]]*\(|[[:space:]]*$)/)
    is_quantize         = ($0 ~ /^[[:space:]]*@quantize([[:space:]]*\(|[[:space:]]*$)/)
    is_cache_kv         = ($0 ~ /^[[:space:]]*@cache_kv([[:space:]]*\(|[[:space:]]*$)/)
    is_speculate        = ($0 ~ /^[[:space:]]*@speculate([[:space:]]*\(|[[:space:]]*$)/)
    is_batch_continuous = ($0 ~ /^[[:space:]]*@batch_continuous([[:space:]]*\(|[[:space:]]*$)/)
    is_anno = (is_infer || is_quantize || is_cache_kv || is_speculate || is_batch_continuous)
    is_fn = ($0 ~ /^[[:space:]]*(pub[[:space:]]+)?fn[[:space:]]+[A-Za-z_][A-Za-z0-9_]*/)
    is_blank = ($0 ~ /^[[:space:]]*$/)
    is_comment = ($0 ~ /^[[:space:]]*(\/\/|#)/)
}

is_anno {
    line = $0
    kind = ""
    if      (is_infer)            kind = "infer"
    else if (is_quantize)         kind = "quantize"
    else if (is_cache_kv)         kind = "cache_kv"
    else if (is_speculate)        kind = "speculate"
    else if (is_batch_continuous) kind = "batch_continuous"

    n_staged++
    staged_kind[n_staged] = kind
    staged_line[n_staged] = FNR
    staged_file[n_staged] = FILENAME

    # meta 수집 — depth 1 key=value
    delete kv_k
    delete kv_v
    nk = extract_all_kv(line, kv_k, kv_v)
    staged_nkv[n_staged] = nk
    for (i = 1; i <= nk; i++) {
        staged_k[n_staged, i] = kv_k[i]
        staged_v[n_staged, i] = kv_v[i]
    }
    next
}

is_fn && n_staged > 0 {
    # extract fn name
    fn_name = ""
    tmp = $0
    sub(/^[[:space:]]*(pub[[:space:]]+)?fn[[:space:]]+/, "", tmp)
    if (match(tmp, /^[A-Za-z_][A-Za-z0-9_]*/)) {
        fn_name = substr(tmp, 1, RLENGTH)
    }

    # emit each staged annotation (if filter matches)
    for (s = 1; s <= n_staged; s++) {
        k = staged_kind[s]
        if (filter_kind != "" && filter_kind != k) continue

        if (total > 0) printf ","
        total++
        if      (k == "infer")            cnt_infer++
        else if (k == "quantize")         cnt_quantize++
        else if (k == "cache_kv")         cnt_cache_kv++
        else if (k == "speculate")        cnt_speculate++
        else if (k == "batch_continuous") cnt_batch_continuous++

        printf "{"
        printf "\"kind\":\"%s\"", json_escape(k)
        printf ",\"fn\":\"%s\"", json_escape(fn_name)
        printf ",\"file\":\"%s\"", json_escape(staged_file[s])
        printf ",\"line\":%d", staged_line[s]
        printf ",\"meta\":{"
        nk = staged_nkv[s]
        for (i = 1; i <= nk; i++) {
            if (i > 1) printf ","
            printf "\"%s\":\"%s\"", json_escape(staged_k[s, i]), json_escape(staged_v[s, i])
        }
        printf "}"
        printf "}"
    }

    # reset staging
    for (s = 1; s <= n_staged; s++) {
        delete staged_kind[s]
        delete staged_line[s]
        delete staged_file[s]
        delete staged_nkv[s]
    }
    # wipe 2D
    for (key in staged_k) delete staged_k[key]
    for (key in staged_v) delete staged_v[key]
    n_staged = 0
    next
}

# blank breaks the block (discard staging unless followed by more annos)
(!is_anno && !is_fn && !is_comment) {
    if (n_staged > 0 && is_blank) {
        for (s = 1; s <= n_staged; s++) {
            delete staged_kind[s]
            delete staged_line[s]
            delete staged_file[s]
            delete staged_nkv[s]
        }
        for (key in staged_k) delete staged_k[key]
        for (key in staged_v) delete staged_v[key]
        n_staged = 0
    }
}

END {
    # write summary to side channel (via tmpfile below)
    printf "%d|%d|%d|%d|%d|%d\n", cnt_infer, cnt_quantize, cnt_cache_kv, cnt_speculate, cnt_batch_continuous, total > "/dev/stderr"
}
' "${files[@]}" > /tmp/.hexa-infer.$$.body 2> /tmp/.hexa-infer.$$.summary

body="$(cat /tmp/.hexa-infer.$$.body 2>/dev/null || true)"
summary_line="$(cat /tmp/.hexa-infer.$$.summary 2>/dev/null || echo '0|0|0|0|0|0')"
rm -f /tmp/.hexa-infer.$$.body /tmp/.hexa-infer.$$.summary

IFS='|' read -r c_inf c_qu c_ck c_sp c_bc c_total <<< "$summary_line"

printf '{"version":"0.1","source":"grep-mvp","annotations":[%s],"summary":{"infer":%d,"quantize":%d,"cache_kv":%d,"speculate":%d,"batch_continuous":%d,"total":%d}}\n' \
    "$body" "${c_inf:-0}" "${c_qu:-0}" "${c_ck:-0}" "${c_sp:-0}" "${c_bc:-0}" "${c_total:-0}"
