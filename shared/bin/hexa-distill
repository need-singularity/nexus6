#!/bin/bash
# hexa-distill — 품질 경량화 annotation 통합 수집기 (grep MVP, v0.1)
#
# 입력:
#   hexa-distill <file.hexa> [<file2.hexa> ...]
#   hexa-distill --dir <directory>
#   hexa-distill [--kind distill|prune|lora|adapter|kd] <files...>
#
# 출력 (stdout JSON):
#   { "version":"0.1", "source":"grep-mvp",
#     "annotations":[ {kind, fn, file, line, meta{...}} ],
#     "summary":{ distill, prune, lora, adapter, kd, total } }
#
# 인식 annotation (fn decl 바로 위 라인, stacking 허용):
#   @distill(from="<teacher_id>", to="<student_id>", keep_quality=<float 0..1>)   # 지식 증류
#   @prune(kind="<structured|unstructured>", ratio=<float>)                        # 가지치기
#   @lora(rank=<int>, alpha=<int>, dropout=<float>)                                # LoRA 어댑터
#   @adapter(base="<model_id>", tenant="<name>")                                   # 어댑터 핫스왑
#   @kd(method="<response|feature|hinton>", temp=<float>)                          # Knowledge Distillation 변종 학습
#
# exit 0 정상 (빈 annotations 포함). 1=인자 오류
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-distill [--kind distill|prune|lora|adapter|kd] <file.hexa> [file2.hexa ...]
       hexa-distill [--kind ...] --dir <directory>
EOF
    exit 1
}

filter_kind=""
files=()

# parse args
while [ $# -gt 0 ]; do
    case "$1" in
        --kind)
            shift
            [ $# -ge 1 ] || usage
            case "$1" in
                distill|prune|lora|adapter|kd) filter_kind="$1" ;;
                *) echo "ERROR: invalid kind: $1" >&2; usage ;;
            esac
            shift
            ;;
        --dir)
            shift
            [ $# -ge 1 ] || usage
            dir="$1"
            [ -d "$dir" ] || { echo "ERROR: directory not found: $dir" >&2; exit 1; }
            while IFS= read -r -d '' f; do files+=("$f"); done < <(find "$dir" -type f -not -path "*/.claude/*" -not -path "*/node_modules/*" -name "*.hexa" -print0)
            shift
            ;;
        -h|--help)
            usage
            ;;
        *)
            [ -f "$1" ] || { echo "ERROR: file not found: $1" >&2; exit 1; }
            files+=("$1")
            shift
            ;;
    esac
done

[ "${#files[@]}" -gt 0 ] || usage

# awk 엔진 — annotation 라인을 stage 하고 fn decl 에서 flush.
awk -v filter_kind="$filter_kind" '
function json_escape(s,   r) {
    r = s
    gsub(/\\/, "\\\\", r)
    gsub(/"/, "\\\"", r)
    gsub(/\t/, "\\t", r)
    gsub(/\r/, "\\r", r)
    gsub(/\n/, "\\n", r)
    return r
}
function extract_all_kv(line, kv_keys, kv_vals,    tmp, pos, rest, c, k, v, n, i, ch) {
    # 모든 key=value 쌍을 수집 — depth 1 only
    # strip leading @name( and trailing )
    n = 0
    delete kv_keys
    delete kv_vals
    tmp = line
    # find opening paren
    if (!match(tmp, /@[a-z]+\(/)) return 0
    tmp = substr(tmp, RSTART + RLENGTH)
    # strip trailing ) optional — we just scan forward
    while (1) {
        sub(/^[[:space:],]+/, "", tmp)
        if (length(tmp) == 0) break
        if (substr(tmp, 1, 1) == ")") break
        # key
        if (!match(tmp, /^[A-Za-z_][A-Za-z0-9_]*/)) break
        k = substr(tmp, 1, RLENGTH)
        tmp = substr(tmp, RLENGTH + 1)
        sub(/^[[:space:]]*=[[:space:]]*/, "", tmp)
        # value
        if (substr(tmp, 1, 1) == "\"") {
            v = ""
            i = 2
            while (i <= length(tmp)) {
                ch = substr(tmp, i, 1)
                if (ch == "\\" && i < length(tmp)) {
                    v = v substr(tmp, i, 2)
                    i += 2
                    continue
                }
                if (ch == "\"") break
                v = v ch
                i++
            }
            tmp = substr(tmp, i + 1)
            gsub(/\\"/, "\"", v)
            gsub(/\\\\/, "\\", v)
        } else {
            if (match(tmp, /[,)[:space:]]/)) {
                v = substr(tmp, 1, RSTART - 1)
                tmp = substr(tmp, RSTART)
            } else {
                v = tmp
                tmp = ""
            }
        }
        n++
        kv_keys[n] = k
        kv_vals[n] = v
    }
    return n
}

BEGIN {
    n_staged = 0
    total = 0
    cnt_distill = 0
    cnt_prune = 0
    cnt_lora = 0
    cnt_adapter = 0
    cnt_kd = 0
}

{
    is_distill = ($0 ~ /^[[:space:]]*@distill([[:space:]]*\(|[[:space:]]*$)/)
    is_prune   = ($0 ~ /^[[:space:]]*@prune([[:space:]]*\(|[[:space:]]*$)/)
    is_lora    = ($0 ~ /^[[:space:]]*@lora([[:space:]]*\(|[[:space:]]*$)/)
    is_adapter = ($0 ~ /^[[:space:]]*@adapter([[:space:]]*\(|[[:space:]]*$)/)
    is_kd      = ($0 ~ /^[[:space:]]*@kd([[:space:]]*\(|[[:space:]]*$)/)
    is_anno = (is_distill || is_prune || is_lora || is_adapter || is_kd)
    is_fn = ($0 ~ /^[[:space:]]*(pub[[:space:]]+)?fn[[:space:]]+[A-Za-z_][A-Za-z0-9_]*/)
    is_blank = ($0 ~ /^[[:space:]]*$/)
    is_comment = ($0 ~ /^[[:space:]]*(\/\/|#)/)
}

is_anno {
    line = $0
    kind = ""
    if      (is_distill) kind = "distill"
    else if (is_prune)   kind = "prune"
    else if (is_lora)    kind = "lora"
    else if (is_adapter) kind = "adapter"
    else if (is_kd)      kind = "kd"

    n_staged++
    staged_kind[n_staged] = kind
    staged_line[n_staged] = FNR
    staged_file[n_staged] = FILENAME

    # meta 수집 — depth 1 key=value
    delete kv_k
    delete kv_v
    nk = extract_all_kv(line, kv_k, kv_v)
    staged_nkv[n_staged] = nk
    for (i = 1; i <= nk; i++) {
        staged_k[n_staged, i] = kv_k[i]
        staged_v[n_staged, i] = kv_v[i]
    }
    next
}

is_fn && n_staged > 0 {
    # extract fn name
    fn_name = ""
    tmp = $0
    sub(/^[[:space:]]*(pub[[:space:]]+)?fn[[:space:]]+/, "", tmp)
    if (match(tmp, /^[A-Za-z_][A-Za-z0-9_]*/)) {
        fn_name = substr(tmp, 1, RLENGTH)
    }

    # emit each staged annotation (if filter matches)
    for (s = 1; s <= n_staged; s++) {
        k = staged_kind[s]
        if (filter_kind != "" && filter_kind != k) continue

        if (total > 0) printf ","
        total++
        if      (k == "distill") cnt_distill++
        else if (k == "prune")   cnt_prune++
        else if (k == "lora")    cnt_lora++
        else if (k == "adapter") cnt_adapter++
        else if (k == "kd")      cnt_kd++

        printf "{"
        printf "\"kind\":\"%s\"", json_escape(k)
        printf ",\"fn\":\"%s\"", json_escape(fn_name)
        printf ",\"file\":\"%s\"", json_escape(staged_file[s])
        printf ",\"line\":%d", staged_line[s]
        printf ",\"meta\":{"
        nk = staged_nkv[s]
        for (i = 1; i <= nk; i++) {
            if (i > 1) printf ","
            printf "\"%s\":\"%s\"", json_escape(staged_k[s, i]), json_escape(staged_v[s, i])
        }
        printf "}"
        printf "}"
    }

    # reset staging
    for (s = 1; s <= n_staged; s++) {
        delete staged_kind[s]
        delete staged_line[s]
        delete staged_file[s]
        delete staged_nkv[s]
    }
    # wipe 2D
    for (key in staged_k) delete staged_k[key]
    for (key in staged_v) delete staged_v[key]
    n_staged = 0
    next
}

# blank breaks the block (discard staging unless followed by more annos)
(!is_anno && !is_fn && !is_comment) {
    if (n_staged > 0 && is_blank) {
        for (s = 1; s <= n_staged; s++) {
            delete staged_kind[s]
            delete staged_line[s]
            delete staged_file[s]
            delete staged_nkv[s]
        }
        for (key in staged_k) delete staged_k[key]
        for (key in staged_v) delete staged_v[key]
        n_staged = 0
    }
}

END {
    # write summary to side channel (via tmpfile below)
    printf "%d|%d|%d|%d|%d|%d\n", cnt_distill, cnt_prune, cnt_lora, cnt_adapter, cnt_kd, total > "/dev/stderr"
}
' "${files[@]}" > /tmp/.hexa-distill.$$.body 2> /tmp/.hexa-distill.$$.summary

body="$(cat /tmp/.hexa-distill.$$.body 2>/dev/null || true)"
summary_line="$(cat /tmp/.hexa-distill.$$.summary 2>/dev/null || echo '0|0|0|0|0|0')"
rm -f /tmp/.hexa-distill.$$.body /tmp/.hexa-distill.$$.summary

IFS='|' read -r c_distill c_prune c_lora c_adapter c_kd c_total <<< "$summary_line"

printf '{"version":"0.1","source":"grep-mvp","annotations":[%s],"summary":{"distill":%d,"prune":%d,"lora":%d,"adapter":%d,"kd":%d,"total":%d}}\n' \
    "$body" "${c_distill:-0}" "${c_prune:-0}" "${c_lora:-0}" "${c_adapter:-0}" "${c_kd:-0}" "${c_total:-0}"
