#!/bin/bash
# shared/bin/cl-refresh — nexus cl usage-cache.json 갱신 엔진
# spec: shared/engine/cl_refresh_spec.json
#
# 원칙:
#   - bash+curl+jq+security. airgenome/ccmon 0 의존.
#   - 토큰 raw 값 stdout/stderr/log 노출 금지 (set -x, curl -v 금지).
#   - 실패 시 기존 cache entry 유지 (zero-out 금지).
#   - refresh cap=2/cycle (IP rate_limit cascade 회피). usage fetch 병렬.
#
# 사용:
#   cl-refresh              전체 병렬 갱신
#   cl-refresh <name>       단일 계정
#   cl-refresh --dry-run    keychain 접근/만료 체크만 (API 호출 0)
#   cl-refresh --verify     현재 cache 요약
#   cl-refresh help

set -uo pipefail
set +x

NEXUS_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
CL_HOME="${CL_HOME:-$NEXUS_ROOT/shared/.runtime/accounts}"
ACCOUNTS="$CL_HOME/accounts.json"
USAGE="$CL_HOME/usage-cache.json"
LOCK="$CL_HOME/cl-refresh.lock"
LOG="$CL_HOME/cl-refresh.log"
KEYMAP="$NEXUS_ROOT/shared/config/claude_keychain_map.json"

USAGE_URL="https://api.anthropic.com/api/oauth/usage"
TOKEN_URL="https://platform.claude.com/v1/oauth/token"
CLIENT_ID="9d1c250a-e61b-44d9-88ed-5944d1962f5e"
BETA="oauth-2025-04-20"
TIMEOUT=10
CLI_TIMEOUT=30
CAP=2  # pre_check 선별용. CLI 실패 시 direct POST 는 CAP 무관 항상 시도.
PERL_TIMEOUT="$NEXUS_ROOT/shared/harness/perl_timeout.sh"
CLI_LOCK="$CL_HOME/cl-refresh.cli.lock"

# @convergence state=ossified id=REFRESH_BACKOFF_PERSISTENCE ossified_at=2026-04-18 value="rate_limit 응답 시 per-account 지수 backoff (15min 시작, 2배씩, 4h 상한) _retry_at 로 usage-cache 영속. login signal (.claude.json/.credentials.json mtime > cache _ts) 감지 시 backoff bypass — fresh RT 에 기회 부여" rationale="rate-limit cascade 영구화 해소. FOCUSED_BG_REFRESH + launchd 반복 호출로 claude7 같은 계정이 무한 rate-limit 순환하던 근본 원인 차단"
BACKOFF_INIT=900    # 15 min 초기 backoff
BACKOFF_MAX=14400   # 4h 상한

# 스크립트 레벨 상태 — trap cleanup 이 함수 return 후에도 참조 가능해야 함.
td=""

# ── 유틸 ──────────────────────────────────────────────────────────────
log() {
    mkdir -p "$CL_HOME"
    printf '[%s] %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" "$*" >> "$LOG" 2>/dev/null || true
}
err() { echo "cl-refresh: $*" >&2; log "ERR: $*"; }
require() { command -v "$1" >/dev/null 2>&1 || { err "$1 필요"; exit 3; }; }

acquire_lock() {
    mkdir -p "$CL_HOME"
    if [ -f "$LOCK" ]; then
        local pid; pid=$(cat "$LOCK" 2>/dev/null || echo)
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            err "이미 실행 중 (pid=$pid)"; exit 4
        fi
    fi
    echo "$$" > "$LOCK"
    chmod 600 "$LOCK" 2>/dev/null || true
}

# ── keychain 접근 ──────────────────────────────────────────────────────
hex8()       { jq -r --arg n "$1" '.map[$n] // empty' "$KEYMAP" 2>/dev/null; }
read_blob()  { security find-generic-password -l "Claude Code-credentials-$1" -a ghost -w 2>/dev/null; }
write_blob() {
    local label="Claude Code-credentials-$1"
    security delete-generic-password -s "$label" -a ghost >/dev/null 2>&1 || true
    security add-generic-password -l "$label" -s "$label" -a ghost -w "$2" 2>/dev/null
}

# ── 토큰 refresh ────────────────────────────────────────────────────────
# stdout: 성공 시 새 blob JSON, 실패 시 빈
# return code (L3, 2026-04-18 — 원인별 분류):
#   0 — 성공
#   1 — 네트워크/알 수 없는 에러 (기존 refresh-failed 와 동일 취급)
#   2 — rate_limit_error (transient — usage-cache 에 error 마킹 금지)
#   3 — invalid_grant/invalid_request (permanent — refresh-failed 마킹)
# @convergence state=ossified id=REFRESH_ERROR_CLASS value="rate_limit vs invalid_grant 분리 — rate_limit 은 transient 로 대시보드에 error 미표시" ossified_at=2026-04-18 rationale="CAP=2 cascade + rate_limit 이 영구 refresh-failed 로 오진되어 블랙홀 누적되던 문제 해결"
refresh_token() {
    local rt="$1" old="$2" body resp at nrt ein http_code error_type
    body=$(jq -cn --arg rt "$rt" --arg cid "$CLIENT_ID" \
        '{grant_type:"refresh_token", refresh_token:$rt, client_id:$cid}')
    resp=$(printf '%s' "$body" | curl -sS -m "$TIMEOUT" -X POST "$TOKEN_URL" \
        -H "Content-Type: application/json" --data @- \
        -w '|%HTTP%|%{http_code}' 2>/dev/null) || return 1
    # HTTP_CODE 분리 — JSON body 와 충돌 안 날 delimiter |%HTTP%|
    http_code="${resp##*|%HTTP%|}"
    resp="${resp%|%HTTP%|*}"
    at=$(jq -r '.access_token // empty' <<< "$resp" 2>/dev/null)
    if [ -n "$at" ]; then
        nrt=$(jq -r '.refresh_token // empty' <<< "$resp" 2>/dev/null)
        ein=$(jq -r '.expires_in // 3600' <<< "$resp" 2>/dev/null)
        jq -c --arg at "$at" --arg nrt "$nrt" --argjson ein "$ein" \
            '.claudeAiOauth.accessToken = $at
             | .claudeAiOauth.expiresAt = ((now*1000 | floor) + $ein*1000)
             | (if $nrt != "" then .claudeAiOauth.refreshToken = $nrt else . end)' \
            <<< "$old" 2>/dev/null
        return 0
    fi
    error_type=$(jq -r '.error.type // .error // empty' <<< "$resp" 2>/dev/null)
    case "$error_type" in
        rate_limit_error|rate_limited) return 2 ;;
        invalid_grant|invalid_request) return 3 ;;
    esac
    [ "$http_code" = "429" ] && return 2
    [ "$http_code" = "400" ] && return 3
    return 1
}

fetch_usage() {
    curl -sS -m "$TIMEOUT" "$USAGE_URL" \
        -H "Authorization: Bearer $1" -H "anthropic-beta: $BETA" 2>/dev/null
}

# ── CLI 경유 refresh — primary path (IP rate_limit 우회 + quota 0) ─────
# claude CLI 가 startup auth 체크에서 만료 토큰을 내부 refresh path 로 갱신.
# 이 경로는 Anthropic /v1/oauth/token IP rate_limit 과 별개로 동작.
# perl_timeout: hang 방지. mkdir mutex: 7개 동시 호출 시 keychain race 회피.
refresh_via_cli() {
    local name="$1"
    local cfg rc=0 i=0
    cfg=$(jq -r --arg n "$name" '.accounts[] | select(.name==$n) | .config_dir' "$ACCOUNTS" 2>/dev/null)
    [ -n "$cfg" ] && [ -d "$cfg" ] || return 1
    command -v claude >/dev/null 2>&1 || return 1

    # 직렬화 mutex (atomic mkdir). 동시 12개 → keychain race 회피.
    # lock 못 잡으면 CLI skip → 호출자가 direct POST fallback.
    local got_lock=0
    while [ $i -lt 40 ]; do
        if mkdir "$CLI_LOCK" 2>/dev/null; then got_lock=1; break; fi
        sleep 0.5; i=$((i+1))
    done

    if [ "$got_lock" -eq 0 ]; then
        log "cli-refresh lock-timeout: $name (skip → direct fallback)"
        return 1
    fi

    if [ -x "$PERL_TIMEOUT" ]; then
        CLAUDE_CONFIG_DIR="$cfg" "$PERL_TIMEOUT" "$CLI_TIMEOUT" \
            claude mcp list >/dev/null 2>&1
        rc=$?
    else
        CLAUDE_CONFIG_DIR="$cfg" claude mcp list >/dev/null 2>&1
        rc=$?
    fi

    rmdir "$CLI_LOCK" 2>/dev/null || true
    [ $rc -eq 124 ] && log "cli-refresh timeout: $name"
    # 성공 여부는 호출자가 keychain 재조회로 판단.
    return $rc
}

# ── 계정 1개 처리 → $td/$name.json 에 entry 또는 {error:"..."} ────────
process_one() {
    local name="$1" td="$2" allowed="$3"
    local out="$td/$name.json"
    local h8 blob at rt ea now resp
    h8=$(hex8 "$name")
    [ -n "$h8" ]   || { echo '{"error":"no-hex8"}'       > "$out"; return; }
    blob=$(read_blob "$h8")
    [ -n "$blob" ] || { echo '{"error":"keychain-read"}' > "$out"; return; }
    at=$(jq -r '.claudeAiOauth.accessToken // empty'  <<< "$blob" 2>/dev/null)
    rt=$(jq -r '.claudeAiOauth.refreshToken // empty' <<< "$blob" 2>/dev/null)
    ea=$(jq -r '.claudeAiOauth.expiresAt // 0'        <<< "$blob" 2>/dev/null)
    [ -n "$at" ] || { echo '{"error":"blob-malformed"}' > "$out"; return; }

    now=$(($(date -u +%s) * 1000))
    if [ "$ea" -lt "$((now + 60000))" ] 2>/dev/null; then
        [ -n "$rt" ] || { echo '{"error":"no-refresh-token"}' > "$out"; return; }
        local new_blob="" method=""

        # CLI primary: IP rate_limit 우회 + quota 0. memory feedback SSOT.
        refresh_via_cli "$name" || true
        blob=$(read_blob "$h8")
        if [ -n "$blob" ]; then
            at=$(jq -r '.claudeAiOauth.accessToken // empty' <<< "$blob" 2>/dev/null)
            ea=$(jq -r '.claudeAiOauth.expiresAt // 0'      <<< "$blob" 2>/dev/null)
            [ "$ea" -ge "$((now + 60000))" ] 2>/dev/null && method="cli"
        fi

        # CLI 실패 시 direct POST fallback.
        # CAP 은 pre_check 선별용 — CLI 실패 후에는 무조건 시도 (영구 refresh-failed 방지).
        # L3 (2026-04-18): refresh_token return code 로 원인 분류.
        local direct_rc=0
        if [ -z "$method" ]; then
            new_blob=$(refresh_token "$rt" "$blob"); direct_rc=$?
            if [ -n "$new_blob" ]; then
                write_blob "$h8" "$new_blob" || { echo '{"error":"keychain-write"}' > "$out"; return; }
                at=$(jq -r '.claudeAiOauth.accessToken' <<< "$new_blob" 2>/dev/null)
                ea=$(jq -r '.claudeAiOauth.expiresAt'   <<< "$new_blob" 2>/dev/null)
                method="direct"
            fi
        fi

        if [ -z "$method" ]; then
            # 원인별 라벨링 — rate_limit 은 transient 라 error=null, invalid_grant 만 영구.
            case "$direct_rc" in
                2)
                    # rate-limit 지수 backoff 계산
                    local prev_bo now_s cur_bo retry_at
                    now_s=$(date -u +%s)
                    prev_bo=$(jq -r --arg n "$name" '(.[$n]._backoff // 0) | tonumber' "$USAGE" 2>/dev/null)
                    [ -z "$prev_bo" ] || [ "$prev_bo" = "null" ] && prev_bo=0
                    if [ "$prev_bo" -lt "$BACKOFF_INIT" ] 2>/dev/null; then
                        cur_bo=$BACKOFF_INIT
                    elif [ "$prev_bo" -ge "$BACKOFF_MAX" ] 2>/dev/null; then
                        cur_bo=$BACKOFF_MAX
                    else
                        cur_bo=$((prev_bo * 2))
                        [ "$cur_bo" -gt "$BACKOFF_MAX" ] && cur_bo=$BACKOFF_MAX
                    fi
                    retry_at=$((now_s + cur_bo))
                    jq -nc --argjson ra "$retry_at" --argjson bo "$cur_bo" --argjson bat "$now_s" \
                        '{error:null, detail:"rate-limit", _retry_at:$ra, _backoff:$bo, _backoff_at:$bat}' > "$out"
                    log "rate-limit(transient): $name (cooldown ${cur_bo}s → retry @ $(date -u -r "$retry_at" '+%H:%MZ' 2>/dev/null || date -u -d "@$retry_at" '+%H:%MZ' 2>/dev/null || echo "+${cur_bo}s"))"
                    return ;;
                3) echo '{"error":"invalid-grant"}'          > "$out"; log "invalid-grant(permanent): $name"; return ;;
                *) echo '{"error":"refresh-failed"}'         > "$out"; return ;;
            esac
        fi
        # refresh 성공 — backoff 초기화 (이미 error=null 결과에 _retry_at/_backoff 없음)
        log "refreshed($method): $name"
    fi

    resp=$(fetch_usage "$at")
    if ! jq -e '.five_hour' <<< "$resp" >/dev/null 2>&1; then
        echo '{"error":"usage-api"}' > "$out"; return
    fi
    jq -c '{
        session_pct: .five_hour.utilization,
        session_resets: .five_hour.resets_at,
        week_all_pct: .seven_day.utilization,
        week_resets: .seven_day.resets_at,
        week_sonnet_pct: (.seven_day_sonnet.utilization // null),
        week_sonnet_resets: (.seven_day_sonnet.resets_at // null),
        error: null
    }' <<< "$resp" > "$out"
}

# ── merge: 성공 → 전체 교체, 실패 → 기존 entry 에 error 필드만 덮어씀 ─
merge_cache() {
    local td="$1"; shift
    local base='{}' acc name entry f
    [ -f "$USAGE" ] && base=$(jq 'del(._ts)' "$USAGE" 2>/dev/null || echo '{}')
    acc="$base"
    for name in "$@"; do
        f="$td/$name.json"
        [ -f "$f" ] || continue
        entry=$(cat "$f")
        if [ "$(jq -r '.error // "null"' <<< "$entry")" = "null" ]; then
            acc=$(jq --arg n "$name" --argjson v "$entry" '.[$n] = $v' <<< "$acc")
        else
            acc=$(jq --arg n "$name" --argjson v "$entry" '.[$n] = ((.[$n] // {}) + $v)' <<< "$acc")
        fi
    done
    local out="$USAGE.tmp.$$"
    jq --argjson t "$(date -u +%s)" '. + {_ts:$t}' <<< "$acc" > "$out"
    chmod 600 "$out" 2>/dev/null || true
    mv "$out" "$USAGE"
}

# ── backoff 체크 — rate-limit cooldown 중이면 skip ────────────────────
# login signal (.claude.json/.credentials.json mtime) > cache _ts 면 bypass
# 0 = skip (backoff active), 1 = proceed
should_skip_backoff() {
    local name="$1"
    [ -f "$USAGE" ] || return 1
    local now_s retry_at
    now_s=$(date -u +%s)
    retry_at=$(jq -r --arg n "$name" '(.[$n]._retry_at // 0) | tonumber' "$USAGE" 2>/dev/null)
    [ -z "$retry_at" ] || [ "$retry_at" = "null" ] && retry_at=0
    [ "$retry_at" -le "$now_s" ] 2>/dev/null && return 1  # backoff expired
    # backoff 활성 — login signal 이 backoff 설정 이후면 bypass (fresh RT 기회)
    local backoff_at sig sig_mt best=0
    backoff_at=$(jq -r --arg n "$name" '(.[$n]._backoff_at // 0) | tonumber' "$USAGE" 2>/dev/null)
    [ -z "$backoff_at" ] || [ "$backoff_at" = "null" ] && backoff_at=0
    for sig in "$HOME/.claude-$name/.claude.json" "$HOME/.claude-$name/.credentials.json"; do
        [ -f "$sig" ] || continue
        sig_mt=$(stat -f %m "$sig" 2>/dev/null || stat -c %Y "$sig" 2>/dev/null)
        [ -n "$sig_mt" ] && [ "$sig_mt" -gt "$best" ] 2>/dev/null && best=$sig_mt
    done
    [ "$best" -gt "$backoff_at" ] 2>/dev/null && return 1  # post-login, bypass
    return 0  # skip
}

# ── refresh 대상 선별 (최대 CAP 개) ──────────────────────────────────
pre_check_expiry() {
    local now n=0 name h8 blob ea
    now=$(($(date -u +%s) * 1000))
    for name in "$@"; do
        [ "$n" -ge "$CAP" ] && break
        h8=$(hex8 "$name");        [ -n "$h8" ]   || continue
        blob=$(read_blob "$h8");   [ -n "$blob" ] || continue
        ea=$(jq -r '.claudeAiOauth.expiresAt // 0' <<< "$blob" 2>/dev/null)
        if [ "$ea" -lt "$((now + 60000))" ] 2>/dev/null; then
            printf '%s\n' "$name"; n=$((n+1))
        fi
    done
}

# ── --verify ─────────────────────────────────────────────────────────
cmd_verify() {
    [ -f "$USAGE" ] || { err "cache 없음: $USAGE"; exit 1; }
    local ts age=""; ts=$(jq -r '._ts // empty' "$USAGE" 2>/dev/null)
    [ -n "$ts" ] && [ "$ts" != "null" ] && age=" (age=$(( $(date -u +%s) - ${ts%.*} ))s)"
    echo "cache: $USAGE$age"
    jq -r 'to_entries | map(select(.key != "_ts")) | sort_by(.key) | .[]
        | "\(.key)\t\(.value.week_all_pct // "?")%\t\(.value.session_pct // "?")%\t\(.value.error // "ok")"' \
        "$USAGE" | column -t -s $'\t'
}

# ── --dry-run ────────────────────────────────────────────────────────
cmd_dry_run() {
    require jq; require security
    [ -f "$ACCOUNTS" ] || { err "$ACCOUNTS 없음"; exit 2; }
    [ -f "$KEYMAP" ]   || { err "$KEYMAP 없음"; exit 2; }
    local now name h8 blob ea status
    now=$(($(date -u +%s) * 1000))
    while IFS= read -r name; do
        [ -n "$name" ] || continue
        h8=$(hex8 "$name")
        [ -n "$h8" ] || { printf '  %-10s  MISSING_MAP\n' "$name"; continue; }
        blob=$(read_blob "$h8")
        [ -n "$blob" ] || { printf '  %-10s  hex=%s  KEYCHAIN_FAIL\n' "$name" "$h8"; continue; }
        ea=$(jq -r '.claudeAiOauth.expiresAt // 0' <<< "$blob" 2>/dev/null)
        [ "$ea" -lt "$((now + 60000))" ] 2>/dev/null && status="EXPIRED" || status="valid"
        printf '  %-10s  hex=%s  %s\n' "$name" "$h8" "$status"
    done < <(jq -r '.accounts[].name' "$ACCOUNTS")
}

# ── refresh (default) ────────────────────────────────────────────────
cmd_refresh() {
    require jq; require curl; require security
    [ -f "$ACCOUNTS" ] || { err "$ACCOUNTS 없음"; exit 2; }
    [ -f "$KEYMAP" ]   || { err "$KEYMAP 없음"; exit 2; }
    acquire_lock

    local target="${1:-}" force=0 names=()
    if [ "$target" = "--force" ]; then force=1; target=""; fi
    if [ -n "$target" ]; then
        jq -e --arg n "$target" '.accounts[] | select(.name == $n)' "$ACCOUNTS" >/dev/null 2>&1 \
            || { err "계정 '$target' 없음"; exit 1; }
        names=("$target")
    else
        while IFS= read -r line; do
            [ -n "$line" ] && names+=("$line")
        done < <(jq -r '.accounts[].name' "$ACCOUNTS")
    fi
    [ "${#names[@]}" -gt 0 ] || { err "처리할 계정 없음"; exit 1; }

    # backoff 필터링 (--force 시 skip)
    if [ "$force" -eq 0 ]; then
        local filtered=() skipped=0 nm
        for nm in "${names[@]}"; do
            if should_skip_backoff "$nm"; then
                skipped=$((skipped+1))
                log "backoff skip: $nm"
            else
                filtered+=("$nm")
            fi
        done
        names=("${filtered[@]}")
        [ "$skipped" -gt 0 ] && log "$skipped account(s) in backoff — skipped"
        [ "${#names[@]}" -eq 0 ] && { log "all accounts in backoff, nothing to do"; exit 0; }
    fi

    td=$(mktemp -d -t cl-refresh.XXXXXX)
    chmod 700 "$td" 2>/dev/null || true
    trap 'rm -f "$LOCK"; [ -n "$td" ] && rm -rf "$td"' EXIT INT TERM

    local allowed; allowed=$(pre_check_expiry "${names[@]}")
    local n_allowed=0
    [ -n "$allowed" ] && n_allowed=$(printf '%s\n' "$allowed" | grep -c .)
    log "refresh start: ${#names[@]} accounts, refresh_allowed=$n_allowed"

    local name is_allowed
    for name in "${names[@]}"; do
        is_allowed=0
        printf '%s\n' "$allowed" | grep -qFx "$name" && is_allowed=1
        ( process_one "$name" "$td" "$is_allowed" ) &
    done
    wait

    merge_cache "$td" "${names[@]}"

    # 요약
    local ok=0 fail=0 wk ss status f
    printf '%-12s  %-8s  %s\n' "account" "status" "detail"
    printf '%-12s  %-8s  %s\n' "-----------" "--------" "--------------------"
    for name in "${names[@]}"; do
        f="$td/$name.json"
        [ -f "$f" ] || { printf '%-12s  %-8s  %s\n' "$name" "FAIL" "no-output"; fail=$((fail+1)); continue; }
        status=$(jq -r '.error // "ok"' "$f")
        if [ "$status" = "ok" ]; then
            wk=$(jq -r '.week_all_pct // "?"' "$f")
            ss=$(jq -r '.session_pct // "?"' "$f")
            printf '%-12s  %-8s  wk=%s%% ss=%s%%\n' "$name" "OK" "$wk" "$ss"
            ok=$((ok+1))
        else
            printf '%-12s  %-8s  %s\n' "$name" "FAIL" "$status"
            fail=$((fail+1))
        fi
    done
    printf 'total=%d ok=%d fail=%d\n' "${#names[@]}" "$ok" "$fail"
    log "refresh done: ok=$ok fail=$fail"
}

usage() {
    cat <<EOF
cl-refresh — nexus cl usage-cache.json 갱신 엔진

사용법:
  cl-refresh              전체 병렬 갱신
  cl-refresh <name>       단일 계정
  cl-refresh --dry-run    keychain 접근/만료 체크 (API 호출 0)
  cl-refresh --verify     현재 cache 요약
  cl-refresh help

spec: $NEXUS_ROOT/shared/engine/cl_refresh_spec.json
EOF
}

case "${1:-}" in
    ""|all)         cmd_refresh "" ;;
    --dry-run)      cmd_dry_run ;;
    --verify)       cmd_verify ;;
    help|-h|--help) usage ;;
    -*)             err "unknown option: $1"; exit 64 ;;
    *)              cmd_refresh "$1" ;;
esac
