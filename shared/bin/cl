#!/bin/bash
# shared/bin/cl — Claude Code multi-account launcher (nexus-managed, bash)
# 독립 명령. 자동 계정 선택(week_all_pct 최저) + rate-limit 수동 재선택.
#
# Store: ~/.claude-accounts/
#   accounts.json    {"accounts":[{"name","config_dir"}]}
#   cl-state.json    {"active":"<name>"}
#   usage-cache.json {"<name>":{week_all_pct,session_pct,error,resets}}
#
# Subcommands:
#   cl              대화형 픽커 (tty) → 선택 → exec claude. 비-tty면 cl u 와 동일
#   cl u            usage bars (비대화형 조회용)
#   cl status       간단 요약
#   cl pick [NAME]  활성 계정 전환만(런칭 X). NAME 없으면 week_all_pct 최저 자동
#   cl env          현재 활성 계정의 CLAUDE_CONFIG_DIR export 라인 출력
#   cl help
#
# AirGenome 기존 cl 은 hexa 기반으로 void-method 이슈로 깨짐.
# 본 스크립트는 기존 코드 무시, 자동 선택 로직만 참고하여 재작성.

set -euo pipefail

CL_HOME="${CL_HOME:-$HOME/.claude-accounts}"
ACCOUNTS="$CL_HOME/accounts.json"
STATE="$CL_HOME/cl-state.json"
USAGE="$CL_HOME/usage-cache.json"

mkdir -p "$CL_HOME"

# 1회성 seed — store 비어있으면 ~/.airgenome 에서 복사 (airgenome 의존 끊기 위한 이행 단계)
seed_from_airgenome() {
    local src="$HOME/.airgenome"
    [ -d "$src" ] || return 0
    [ ! -f "$ACCOUNTS" ] && [ -f "$src/accounts.json"   ] && cp "$src/accounts.json"   "$ACCOUNTS"   || true
    [ ! -f "$STATE"    ] && [ -f "$src/cl-state.json"   ] && cp "$src/cl-state.json"   "$STATE"      || true
    [ ! -f "$USAGE"    ] && [ -f "$src/usage-cache.json" ] && cp "$src/usage-cache.json" "$USAGE"     || true
}
seed_from_airgenome

[ -f "$ACCOUNTS" ] || { echo "ERROR(cl): $ACCOUNTS 없음" >&2; exit 2; }
command -v jq >/dev/null 2>&1 || { echo "ERROR(cl): jq 필요" >&2; exit 3; }

current_active() {
    jq -r '.active // empty' "$STATE" 2>/dev/null
}

set_active() {
    local name="$1"
    local tmp="$STATE.tmp.$$"
    jq -n --arg a "$name" '{active:$a}' > "$tmp" && mv "$tmp" "$STATE"
}

config_dir_for() {
    local name="$1"
    jq -r --arg n "$name" '.accounts[] | select(.name == $n) | .config_dir' "$ACCOUNTS"
}

# 자연 정렬 — claude1, claude2, ..., claude9, claude10 (사전식 X)
list_accounts() {
    jq -r '.accounts[].name' "$ACCOUNTS" | sort -V
}

# pct(정수 0..100) → 20칸 바
bar() {
    local pct=${1:-0}
    local filled=$(( (pct + 2) / 5 ))
    [ $filled -gt 20 ] && filled=20
    [ $filled -lt 0 ] && filled=0
    local empty=$((20 - filled))
    printf '%*s' "$filled" '' | tr ' ' '#'
    printf '%*s' "$empty" '' | tr ' ' '.'
}

# usage-cache 에서 week_all_pct 최저(error=null, <95) 계정 선택
auto_pick() {
    [ -f "$USAGE" ] || { echo "" ; return; }
    jq -r '
        [to_entries[]
            | select(.key != "_ts")
            | select(.value.error == null)
            | select((.value.week_all_pct // 100) < 95)
            | {name:.key, wk:(.value.week_all_pct // 100)}]
        | sort_by(.wk)
        | .[0].name // empty
    ' "$USAGE" 2>/dev/null
}

show_dashboard() {
    CL_EOL="" render_dashboard -1
}

# render_dashboard <cursor_idx> — cursor_idx<0 이면 커서 표시 없음
# CL_EOL 환경변수로 행 끝 ANSI 제어 시퀀스 주입 (인터랙티브: \033[K, 비대화형: 빈문자)
render_dashboard() {
    local cursor="${1:--1}"
    local eol="${CL_EOL-}"
    local active; active="$(current_active)"
    local names; names="$(list_accounts)"
    printf "cl — Claude accounts    active=%s    store=%s%s\n" "${active:-none}" "$CL_HOME" "$eol"
    printf "    %-3s  %-10s  %4s  %-20s  %4s  %-20s  %s%s\n" "no" "name" "wk%" "[week_all]" "ss%" "[session]" "err" "$eol"
    printf "    -------------------------------------------------------------------------------%s\n" "$eol"
    local i=0
    while IFS= read -r name; do
        [ -z "$name" ] && continue
        local week sess err wi si act_mark pointer num_label
        if [ -f "$USAGE" ]; then
            week=$(jq -r --arg n "$name" '.[$n].week_all_pct // 0' "$USAGE" 2>/dev/null)
            sess=$(jq -r --arg n "$name" '.[$n].session_pct // 0' "$USAGE" 2>/dev/null)
            err=$(jq -r --arg n "$name" '.[$n].error // ""' "$USAGE" 2>/dev/null)
        else
            week=0; sess=0; err="no-cache"
        fi
        wi=$(printf '%.0f' "${week:-0}")
        si=$(printf '%.0f' "${sess:-0}")
        act_mark=" "
        [ "$name" = "$active" ] && act_mark="*"
        if [ "$i" -lt 9 ]; then num_label=$((i+1));
        elif [ "$i" -eq 9 ]; then num_label="0";
        else num_label="-"; fi
        # prefix 4 col 고정 — 커서/비커서 동일 시각 폭. ASCII '>' 로 wide-char 모호성 회피.
        # 커서 행 전체 reverse video → 시각 명확. 행 폭은 비커서와 동일.
        if [ "$i" -eq "$cursor" ]; then
            printf "\033[7m  > %-3s %s%-10s  %3s%%  %s  %3s%%  %s  %s\033[0m%s\n" \
                "$num_label" "$act_mark" "$name" "$wi" "$(bar $wi)" "$si" "$(bar $si)" "${err:-}" "$eol"
        else
            printf "    %-3s %s%-10s  %3s%%  %s  %3s%%  %s  %s%s\n" \
                "$num_label" "$act_mark" "$name" "$wi" "$(bar $wi)" "$si" "$(bar $si)" "${err:-}" "$eol"
        fi
        i=$((i+1))
    done <<< "$names"
}

# 단일 키 읽기 — 이스케이프 시퀀스(화살표) 결합 처리
# bash 3.2 호환: -t 는 정수 초만 지원. 화살표는 ESC[X 가 atomic 으로 버퍼링되므로
# ESC 감지 후 2 바이트 더 읽기. lone ESC 는 1초 timeout (q 로 즉시 취소 가능).
read_key() {
    local key rest
    IFS= read -rsn1 key
    if [[ "$key" == $'\x1b' ]]; then
        rest=""
        IFS= read -rsn2 -t 1 rest 2>/dev/null || true
        key+="${rest}"
    fi
    printf '%s' "$key"
}

cmd_interactive() {
    if ! { [ -t 0 ] && [ -t 1 ]; }; then
        show_dashboard
        return 0
    fi
    local names=()
    while IFS= read -r n; do [ -n "$n" ] && names+=("$n"); done < <(list_accounts)
    local count=${#names[@]}
    [ "$count" -gt 0 ] || { echo "ERROR(cl): 계정 없음" >&2; exit 1; }

    local active; active="$(current_active)"
    local auto;   auto="$(auto_pick)"
    local cursor=0 i
    if [ -n "$auto" ]; then
        for i in "${!names[@]}"; do [ "${names[$i]}" = "$auto" ] && cursor=$i && break; done
    elif [ -n "$active" ]; then
        for i in "${!names[@]}"; do [ "${names[$i]}" = "$active" ] && cursor=$i && break; done
    fi

    local total_lines=$(( count + 4 ))   # 헤더1 + 컬럼1 + 구분1 + n + 푸터1
    local first=1 selected="" key moved=0 idx footer

    # 커서 숨김 + 종료 시 복원 (Ctrl-C 포함)
    printf '\033[?25l'
    trap 'printf "\033[?25h"' EXIT INT TERM

    # 인터랙티브에서는 행 끝에 \033[K 주입 → 덮어쓸 때 잔존 문자 제거
    local CL_EOL=$'\033[K'

    while true; do
        if [ $first -eq 1 ]; then
            first=0
        else
            # 커서만 위로 올리고 같은 자리에 덮어쓰기. \033[J 생략 → 깜빡임 없음.
            printf '\033[%dA\r' "$total_lines"
        fi
        CL_EOL="$CL_EOL" render_dashboard "$cursor"

        # 푸터 미리보기 — moved 전후 분기
        if [ "$moved" -eq 0 ] && [ -n "$auto" ] && [ "${names[$cursor]}" != "$auto" ]; then
            footer=$(printf "  ↑↓←→ 이동  Enter→%s  1-9/0 점프  q 취소  (그 외 → %s 추천)" \
                "${names[$cursor]}" "$auto")
        elif [ "$moved" -eq 0 ]; then
            footer=$(printf "  ↑↓←→ 이동  Enter→%s  1-9/0 점프  q 취소  (그 외 → 추천)" \
                "${names[$cursor]}")
        else
            footer=$(printf "  ↑↓←→ 이동  Enter→%s  1-9/0 점프  q 취소" \
                "${names[$cursor]}")
        fi
        printf '%s\033[K\n' "$footer"

        key=$(read_key)
        case "$key" in
            $'\x1b[A'|$'\x1b[D'|$'\x1bOA'|$'\x1bOD')
                cursor=$(( (cursor - 1 + count) % count )); moved=1 ;;
            $'\x1b[B'|$'\x1b[C'|$'\x1bOB'|$'\x1bOC')
                cursor=$(( (cursor + 1) % count )); moved=1 ;;
            "")  selected="${names[$cursor]}"; break ;;
            [1-9])
                idx=$(( key - 1 ))
                if [ "$idx" -lt "$count" ]; then selected="${names[$idx]}"; break; fi ;;
            0)
                if [ "$count" -ge 10 ]; then selected="${names[9]}"; break; fi ;;
            q|Q|$'\x1b')
                printf '\n취소\n'
                printf '\033[?25h'; trap - EXIT INT TERM
                return 1 ;;
            *)
                # 한 번이라도 이동했으면 커서 위치 선택, 아니면 추천
                if [ "$moved" -eq 1 ]; then
                    selected="${names[$cursor]}"
                else
                    selected="${auto:-${names[$cursor]}}"
                fi
                break ;;
        esac
    done

    printf '\033[?25h'; trap - EXIT INT TERM

    set_active "$selected"
    local dir; dir=$(config_dir_for "$selected")
    printf '\n→ %s (%s)\n' "$selected" "$dir"
    export CLAUDE_CONFIG_DIR="$dir"
    if command -v claude >/dev/null 2>&1; then
        exec claude
    else
        echo "WARN(cl): claude 바이너리 없음. env만 갱신" >&2
    fi
}

show_status() {
    local active; active="$(current_active)"
    local count; count=$(jq '.accounts | length' "$ACCOUNTS")
    echo "active: ${active:-none}"
    echo "count : $count"
    echo "store : $CL_HOME"
}

cmd_pick() {
    local target="${1:-}"
    if [ -z "$target" ]; then
        target="$(auto_pick)"
        [ -n "$target" ] || { echo "ERROR(cl): 가용 계정 없음 (모두 ≥95% 또는 error)" >&2; exit 1; }
        echo "auto-pick: $target"
    fi
    local exists; exists=$(jq -r --arg n "$target" '.accounts[] | select(.name == $n) | .name' "$ACCOUNTS")
    [ -n "$exists" ] || { echo "ERROR(cl): 계정 '$target' 없음" >&2; exit 1; }
    set_active "$target"
    local dir; dir=$(config_dir_for "$target")
    echo "active → $target ($dir)"
}

cmd_env() {
    local active; active="$(current_active)"
    [ -n "$active" ] || { echo "ERROR(cl): active 없음. 'cl pick' 먼저" >&2; exit 1; }
    local dir; dir=$(config_dir_for "$active")
    [ -n "$dir" ] || { echo "ERROR(cl): '$active' config_dir 없음" >&2; exit 1; }
    # eval "$(cl env)" 로 사용
    printf 'export CLAUDE_CONFIG_DIR=%q\n' "$dir"
}

case "${1:-interactive}" in
    ""|interactive)  cmd_interactive ;;
    u|dashboard)     show_dashboard ;;
    status)          show_status ;;
    pick)            shift || true; cmd_pick "${1:-}" ;;
    env)             cmd_env ;;
    help|-h|--help)
        cat <<USAGE
cl — Claude Code multi-account launcher (nexus-managed)

  cl              대화형 픽커 → 선택 → claude 런칭 (비-tty면 cl u)
  cl u            대시보드만 (조회/스크립트용)
  cl status       요약
  cl pick [NAME]  active 전환만 (런칭 X). NAME 없으면 자동
  cl env          eval "\$(cl env)" → CLAUDE_CONFIG_DIR export
  cl help

대화형 키:
  ↑↓←→     커서 이동 (이동 후엔 "그 외 키" 추천 진입 비활성 → 명시 선택만)
  Enter    커서 위치 선택
  1-9 / 0  번호 점프 (0 = 10번)
  q / ESC  취소
  그 외     auto-pick 즉시 진입 (단, 이동 전일 때만)

Store: $CL_HOME
USAGE
        ;;
    *) echo "ERROR(cl): unknown subcommand '$1' — 'cl help'" >&2; exit 64 ;;
esac
