#!/bin/bash
# shared/bin/cl — Claude Code multi-account launcher (nexus-managed, bash)
# 독립 명령. 자동 계정 선택(week_all_pct 최저) + rate-limit 수동 재선택.
#
# @convergence-meta project=cl description="Claude Code 멀티 계정 런처 TUI 픽커 — 기능별 골화/수렴/진화 추적" approval_tag=cl-approved lockdown=L0 store="shared/.runtime/accounts/ (accounts.json, cl-state.json, usage-cache.json) — R14 SSOT, gitignore" updated=2026-04-15
#
# Convergence SSOT: 본 파일 내부 source-embedded 블록 (스캐너가 주석 마커 페어를 파싱).
#   스캐너: hexa self/convergence_scan.hexa dump shared/bin/cl
#   — 골화(ossified) / 수렴(stable) / 미달(failed) / 진화(evolving) 추적.
#   — 기능 추가/개선 시 해당 블록 갱신 + cl-approved 태그로 커밋.
#
# Store: ~/.claude-accounts/
#   accounts.json    {"accounts":[{"name","config_dir"}]}
#   cl-state.json    {"active":"<name>"}
#   usage-cache.json {"<name>":{week_all_pct,session_pct,error,resets}}
#
# Subcommands:
#   cl              대화형 픽커 (tty) → 선택 → exec claude. 비-tty면 cl u 와 동일
#   cl u            usage bars (비대화형 조회용)
#   cl list         계정 목록 (cl u alias — 타 프로젝트 자동화 용)
#   cl status       간단 요약
#   cl pick [NAME]  활성 계정 전환만(런칭 X). NAME 없으면 week_all_pct 최저 자동
#   cl env          현재 활성 계정의 CLAUDE_CONFIG_DIR export 라인 출력
#   cl -- ARGS      auto-pick → claude "$@" (비대화형 passthrough, 자동화 용)
#   cl NAME -- ARGS NAME 계정으로 claude "$@" (명시 passthrough)
#   cl help
#
# Passthrough 특징:
#   - 비-tty 에서도 동작 → 타 프로젝트 스크립트/파이프에 연결 가능 (claude 대체재)
#   - stderr rate-limit 감지 시 usage-cache 에 error 마킹 + 다음 후보로 1회 재시도
#   - 각 계정별 CLAUDE_CONFIG_DIR 독립 → projects/memory 분리 (one-shot 에 안전)
#
# 이관 이력: 2026-04-14 airgenome/ccmon 의존 완전 제거. CL_HOME 기본값 shared/.runtime/accounts.
# 레거시 ~/.claude-accounts 존재 시 migrate_legacy_home() 이 1회 흡수 후 .migrated_from_home 마커.
# 골화 상태: 본 파일 내 source-embedded 블록 (cl.json SSOT 이관 — 스캐너 참조).

# @convergence state=ossified id=L0_LOCKDOWN value="CODEOWNERS + branch protection + cl-approved 커밋 태그 규약" threshold="직접 push 차단, PR 필요 + 승인 태그 필수" ossified_at=2026-04-13 ref_commit=85f50e4b

set -euo pipefail

# @convergence state=ossified id=SHARED_SSOT_MIGRATION value="cl cache 이관 ~/.claude-accounts → shared/.runtime/accounts/ + CL_HOME 기본값 변경 + airgenome seed 경로 제거" threshold="airgenome 의존 0개 — seed_from_airgenome() 함수 삭제, ~/.airgenome/ 참조 grep 0건" ossified_at=2026-04-14 ref_commit=TBD-cl-migration rationale="R14 shared SSOT 원칙 강화. airgenome/ccmon 의존 완전 제거. plist EnvironmentVariables CL_HOME 일관 경로."
CL_HOME="${CL_HOME:-/Users/ghost/Dev/nexus/shared/.runtime/accounts}"
ACCOUNTS="$CL_HOME/accounts.json"
STATE="$CL_HOME/cl-state.json"
# @convergence state=stable id=USAGE_CACHE_SCHEMA value="{week_all_pct, session_pct, error, resets} per account + _ts" note="스키마는 안정. 갱신 주기/트리거는 외부 프로세스(airgenome 등) 의존"
# @convergence state=stable id=USAGE_CACHE_SCHEMA_AI_NATIVE value="cl-refresh 가 작성하는 {session_pct,session_resets,week_all_pct,week_resets,week_sonnet_*,error} + _ts epoch. ccmon 'week_all_resets' 와 달리 cl 은 'week_resets' 키 사용." note="spec: shared/engine/cl_refresh_spec.json"
USAGE="$CL_HOME/usage-cache.json"

mkdir -p "$CL_HOME"

# 1회성 레거시 흡수 — ~/.claude-accounts 존재 시 3 파일 mv 후 .migrated_from_home 마커.
# airgenome 경로는 참조 0 (완전 제거). 마커 존재 시 즉시 return.
#
# @convergence state=ossified id=DROP_AIRGENOME_DEP value="~/.airgenome 시드 로직 완전 제거 — seed_from_airgenome() → migrate_legacy_home() 교체. airgenome 경로 참조 0" threshold="shared/bin/cl 에 .airgenome 문자열 0건" ossified_at=2026-04-14 ref_commit=TBD-cl-migration
# @convergence state=removed id=AIRGENOME_SEED value="seed_from_airgenome() 삭제 — migrate_legacy_home() 으로 대체 (shared/bin/cl:43~)" removed_at=2026-04-14 reason_kr="airgenome 의존 완전 제거 (ossified.DROP_AIRGENOME_DEP + SHARED_SSOT_MIGRATION). 레거시 ~/.claude-accounts 1회 흡수 후 .migrated_from_home 마커." rollback_kr="복구 불요 — ~/.airgenome 파일은 수동 삭제 대상"
migrate_legacy_home() {
    local marker="$CL_HOME/.migrated_from_home"
    [ -f "$marker" ] && return 0
    local legacy="$HOME/.claude-accounts"
    if [ -d "$legacy" ]; then
        local f
        for f in accounts.json cl-state.json usage-cache.json; do
            if [ -f "$legacy/$f" ] && [ ! -f "$CL_HOME/$f" ]; then
                mv "$legacy/$f" "$CL_HOME/$f" 2>/dev/null || true
            fi
        done
    fi
    : > "$marker"
}
migrate_legacy_home

[ -f "$ACCOUNTS" ] || { echo "ERROR(cl): $ACCOUNTS 없음" >&2; exit 2; }
command -v jq >/dev/null 2>&1 || { echo "ERROR(cl): jq 필요" >&2; exit 3; }

current_active() {
    jq -r '.active // empty' "$STATE" 2>/dev/null
}

set_active() {
    local name="$1"
    local tmp="$STATE.tmp.$$"
    jq -n --arg a "$name" '{active:$a}' > "$tmp" && mv "$tmp" "$STATE"
}

config_dir_for() {
    local name="$1"
    jq -r --arg n "$name" '.accounts[] | select(.name == $n) | .config_dir' "$ACCOUNTS"
}

# 자연 정렬 — claude1, claude2, ..., claude9, claude10 (사전식 X)
# @convergence state=ossified id=NATURAL_SORT value="sort -V 기반 — claude9 < claude10" threshold="사전식 정렬 금지" ossified_at=2026-04-13 ref_commit=14988d02
list_accounts() {
    jq -r '.accounts[].name' "$ACCOUNTS" | sort -V
}

# pct(정수 0..100) → 20칸 바. printf -v 로 변수 직접 작성 (no subshell, no pipe).
# bar_to <var_name> <pct>
bar_to() {
    local __var=$1 pct=${2:-0}
    local filled=$(( (pct + 2) / 5 ))
    [ $filled -gt 20 ] && filled=20
    [ $filled -lt 0 ] && filled=0
    local hashes="####################"   # 20
    local dots="...................."     # 20
    printf -v "$__var" '%s%s' "${hashes:0:filled}" "${dots:0:$((20-filled))}"
}

# usage-cache 에서 가용량(=100 - max(wk, ss)) 기준 후보군 뽑고 random 픽.
# 병목 모델: wk / ss 중 큰 값이 병목 → 100-병목이 실가용량.
#   예) wk 22% / ss 98% → 병목 98%, 가용 2% → 추천 제외.
#       wk 39% / ss 8%  → 병목 39%, 가용 61% → 후보군.
# 후보군: avail >= top_avail - SPREAD (기본 10%). 동시 세션 분산 목적.
# 컷오프: 가용 > 5% (= 병목 < 95%). 후보군 없으면 empty.
# 정직성 게이트: wk_resets / session_resets 과거면 해당 pct 0 으로 override (stale cache 방어).
# CL_PICK_SPREAD: 후보군 폭(%) 조정 (기본 10). 0 이면 기존 동작(top 1 고정).
# @convergence state=ossified id=AUTO_PICK_SPREAD value="auto_pick 후보군 (avail >= top_avail - CL_PICK_SPREAD, 기본 10%) 안에서 $RANDOM 픽" threshold="state-less 분산 (락/히스토리 파일 0). CL_PICK_SPREAD=0 으로 기존 top-1 고정 동작 복구 가능" ossified_at=2026-04-15 ref_commit=cee38b4d rationale="멀티세션 동시 실행 시 모든 세션이 top-1 계정에 쏠려 5h 세션 한도 조기 도달. PID 기반 $RANDOM 으로 세션마다 후보군 내 독립 픽 → 자연 분산."
# @convergence state=evolving id=PICKER_HISTORY value="마지막 N번 선택/성공/실패 기록 → auto_pick 가중치 반영" priority=low note="2026-04-15 AUTO_PICK_SPREAD 로 state-less 분산 해소 — history 영속화는 당분간 불필요. 다계정 정책 가중치가 필요해지면 재검토."
auto_pick() {
    [ -f "$USAGE" ] || { echo "" ; return; }
    local now spread cands n idx
    now=$(date -u +%s)
    spread="${CL_PICK_SPREAD:-10}"
    cands=$(jq -r --argjson now "$now" --argjson spread "$spread" '
        def parse_ts:
          if . == null or . == "" then null
          else
            (. | sub("\\.[0-9]+"; "") | sub("\\+00:00$"; "Z"))
            | try fromdateiso8601
          end;
        [to_entries[]
            | select(.key != "_ts")
            | select(.value.error == null)
            | . as $e
            | (($e.value.week_resets // $e.value.week_all_resets) | parse_ts) as $wrt
            | ($e.value.session_resets | parse_ts) as $srt
            | (if $wrt != null and $wrt < $now then 0
               else ($e.value.week_all_pct // 100) end) as $wk
            | (if $srt != null and $srt < $now then 0
               else ($e.value.session_pct // 100) end) as $ss
            | (100 - ([$wk, $ss] | max)) as $avail
            | {name:.key, avail:$avail, wk:$wk, ss:$ss}
            | select(.avail > 5)]
        | sort_by(-.avail, .wk, .ss)
        | if length == 0 then empty
          else
            (.[0].avail - $spread) as $cutoff
            | [.[] | select(.avail >= $cutoff)]
            | .[].name
          end
    ' "$USAGE" 2>/dev/null)
    [ -z "$cands" ] && return
    n=$(printf '%s\n' "$cands" | wc -l | tr -d ' ')
    if [ "$n" -le 1 ]; then
        printf '%s' "$cands"
    else
        # $RANDOM: 0~32767. 동시 세션마다 PID 다르므로 자연 분산.
        idx=$(( RANDOM % n + 1 ))
        printf '%s\n' "$cands" | sed -n "${idx}p"
    fi
}

# 글로벌 데이터 캐시. 인터랙티브 루프 전 1회 로드 → 프레임 빌드 시 jq 호출 0.
CL_ACTIVE=""
CL_AUTO=""
CL_NAMES=()
CL_WK=()
CL_SS=()
CL_ERR=()
CL_CACHE_TS=""   # _ts epoch. stale 표시용.
CL_STALE_H=0     # cache 나이(시간 단위, floor). 1 이상이면 헤더에 STALE 표시.

# 단일 jq 호출로 accounts.json + usage-cache.json 결합 → name\tweek\tsess\terr.
# 정렬은 sort -V (자연 정렬: claude9 < claude10).
# Before: 30+ jq 호출/프레임 (10계정 × 3필드). After: 1 jq 호출/세션.
#
# 정직성 게이트 (R-honesty): resets 시각이 현재보다 과거면 해당 pct 를 0 으로 override.
# 이유: cache 가 stale 하면 "5% 쓴 상태로 세션 리셋" 같은 낡은 숫자를 붙잡고 있음.
# resets 지난 시점에는 실제 서버에서 리셋됐을 가능성이 크므로 0 으로 간주 (허위 fullness 차단).
# 단, 세션 도중 cache 작성 후 100% 로 치달은 케이스는 여기서 못 잡음 → cl refresh 로 실측 필요.
#
# stale 표시: _ts 와 현재 시각 차이를 시간 단위로 CL_STALE_H 에 저장 → 헤더에 표시.
# @convergence state=ossified id=JQ_CACHE value="세션당 jq 1회 호출 (cl_load_data) — 프레임당 0" threshold="이전: 10계정 × 3필드 = 30+ jq/프레임" ossified_at=2026-04-13 ref_commit=f8320cfb
# @convergence state=stable id=CACHE_STALENESS value="usage-cache.json 갱신 주기 불명확 — 최근 사례: 5h+ stale" symptom="week_all_pct=0 표시되나 실제로는 5h 세션 한도 hit (예: 2026-04-13 claude10)" mitigation="ACTIVE_FIRST_CURSOR 로 active 사용 시 회피 (2026-04-13); 2026-04-14 cl-refresh + launchd 30m 주기로 근본 해소 (ossified.CL_REFRESH_ENGINE + AUTO_REFRESH_LAUNCHD)" threshold="픽커 실행 시점 기준 mtime < 10분" original_status=RESOLVED
# @convergence state=evolving id=RATE_LIMITS_FIELD value="Claude CLI 2.1.90+ statusline rate_limits 필드 (5h + 7d windows) 활용" priority=med ref="~/.claude-claudeN/cache/changelog.md — 'rate_limits field to statusline'"
cl_load_data() {
    CL_ACTIVE="$(current_active)"
    CL_AUTO="$(auto_pick)"
    CL_NAMES=(); CL_WK=(); CL_SS=(); CL_ERR=()
    CL_SRT=(); CL_WRT=()   # reset epoch (초). 빈값 또는 과거면 "" / 0.
    CL_CACHE_TS=""; CL_STALE_H=0
    local raw now
    now=$(date -u +%s)
    if [ -f "$USAGE" ]; then
        CL_CACHE_TS=$(jq -r '._ts // empty' "$USAGE" 2>/dev/null)
        if [ -n "$CL_CACHE_TS" ] && [ "$CL_CACHE_TS" != "null" ]; then
            CL_STALE_H=$(awk -v n="$now" -v t="$CL_CACHE_TS" \
                'BEGIN{a=int((n-t)/3600); if(a<0)a=0; print a}')
        fi
        raw=$(jq -r --slurpfile usage "$USAGE" --argjson now "$now" '
            def parse_ts:
              if . == null or . == "" then null
              else
                (. | sub("\\.[0-9]+"; "") | sub("\\+00:00$"; "Z"))
                | try fromdateiso8601
              end;
            $usage[0] as $u
            | .accounts[]
            | .name as $n
            | ($u[$n] // {}) as $e
            | (($e.week_resets // $e.week_all_resets) | parse_ts) as $wrt
            | ($e.session_resets | parse_ts) as $srt
            | (if $wrt != null and $wrt < $now then 0 else ($e.week_all_pct // 0) end) as $wk
            | (if $srt != null and $srt < $now then 0 else ($e.session_pct // 0) end) as $ss
            | "\($n)|\($wk)|\($ss)|\($e.error // "")|\($srt // "")|\($wrt // "")"
        ' "$ACCOUNTS" 2>/dev/null | sort -V)
    else
        raw=$(jq -r '.accounts[] | "\(.name)|0|0|no-cache||"' "$ACCOUNTS" 2>/dev/null | sort -V)
    fi
    # IFS=| (non-whitespace) — bash 3.2 read 는 whitespace IFS 에서 연속 delimiter 를 collapse 하므로
    # empty 필드 (err 미존재 등) 가 뒤 필드로 시프트 되는 버그 회피.
    local n w s e srt wrt
    while IFS='|' read -r n w s e srt wrt; do
        [ -z "$n" ] && continue
        CL_NAMES+=("$n"); CL_WK+=("$w"); CL_SS+=("$s"); CL_ERR+=("$e")
        CL_SRT+=("$srt"); CL_WRT+=("$wrt")
    done <<< "$raw"

    # L1+L2 (2026-04-18) — post-login self-heal.
    # Mac 의 login signal = ~/.claude-claudeN/.claude.json mtime (Claude Code 가 login 완료 시 재작성).
    # .claude.json mtime > usage-cache._ts 면 사용자가 /login 등으로 토큰을 갱신한 것 → refresh-failed 는 stale.
    # (a) 현재 프레임 표시: CL_ERR 비움 (L1 display guard)
    # (b) usage-cache.json 에 영속 clear (L2) — 다음 cl-refresh 전까지 깨끗 유지.
    # 근본 목적: rate-limit/CAP cascade 로 누적된 영구 블랙홀을 Mac /login 한 번에 해소.
    # 주의: Mac 은 .credentials.json 을 사용하지 않음(keychain-only). 원격(ubu) 은 .credentials.json — 둘 다 cover.
    # @convergence state=ossified id=REFRESH_FAILED_POSTLOGIN_SELFHEAL value="login signal (~/.claude-N/.claude.json 또는 .credentials.json) mtime > usage-cache._ts 면 refresh-failed 자동 clear (표시+영속)" ossified_at=2026-04-18 rationale="refresh-failed 영구화 수렴. Mac SSOT 원칙 — keychain 갱신 → .claude.json rewrite → cl 자동 인지."
    if [ ${#CL_NAMES[@]} -gt 0 ] && [ -n "$CL_CACHE_TS" ] && [ "$CL_CACHE_TS" != "null" ]; then
        local __i __sig __mt __cache_ts_int __mt_best
        __cache_ts_int=${CL_CACHE_TS%.*}
        local __to_clear=()
        for __i in "${!CL_NAMES[@]}"; do
            [ -z "${CL_ERR[$__i]:-}" ] && continue
            # login signal 후보 — mtime 가장 최근 값을 사용.
            __mt_best=0
            for __sig in "$HOME/.claude-${CL_NAMES[$__i]}/.claude.json" \
                         "$HOME/.claude-${CL_NAMES[$__i]}/.credentials.json"; do
                [ -f "$__sig" ] || continue
                __mt=$(stat -f %m "$__sig" 2>/dev/null || stat -c %Y "$__sig" 2>/dev/null)
                [ -z "$__mt" ] && continue
                [ "$__mt" -gt "$__mt_best" ] 2>/dev/null && __mt_best=$__mt
            done
            [ "$__mt_best" -eq 0 ] && continue
            if [ "$__mt_best" -gt "$__cache_ts_int" ] 2>/dev/null; then
                CL_ERR[$__i]=""
                __to_clear+=("${CL_NAMES[$__i]}")
            fi
        done
        # LAG FIX (2026-04-18): 디스플레이는 위에서 이미 CL_ERR 을 비웠으므로 사용자는 즉시 깨끗한 프레임을 본다.
        # L2 영속 writeback(jq+mv)는 인터랙티브 cold-start 를 느리게 만드는 주범 중 하나이므로
        # 백그라운드 서브셸로 분리 — fire-and-forget. 실패해도 다음 cl-refresh 주기에서 자연 복구.
        if [ ${#__to_clear[@]} -gt 0 ] && [ -w "$USAGE" ]; then
            local __names_json
            __names_json=$(printf '%s\n' "${__to_clear[@]}" | jq -R . | jq -sc .)
            (
                __tmp="${USAGE}.tmp.$$"
                if jq --argjson names "$__names_json" --argjson ts "$(date -u +%s)" \
                    'reduce $names[] as $n (.; if has($n) then .[$n].error = null | .[$n]._ts = $ts else . end)' \
                    "$USAGE" > "$__tmp" 2>/dev/null; then
                    chmod 600 "$__tmp" 2>/dev/null || true
                    mv "$__tmp" "$USAGE"
                else
                    rm -f "$__tmp"
                fi
            ) &
            disown 2>/dev/null || true
        fi
    fi
}

# fmt_until <out_var> <target_epoch> [width] — 남은 시간 문자열 (최대 7자).
# "-" (데이터 없음) / "now" (과거) / "45m" / "4h 12m" / "3d 18h" 형식.
# width>0 면 좌측 정렬 padding 적용 + diff<1h 면 bright cyan(\033[96m) wrap.
#   - reset 코드는 \033[39m (default fg only) — cursor 행의 reverse(\033[7m) 와 호환.
#   - ANSI escape 는 출력 너비에 포함되지 않으므로 padding 을 미리 적용 후 wrap.
# CL_NOW: caller 가 captured epoch 를 글로벌로 두면 함수 내 date 호출 0회.
fmt_until() {
    local __out=$1 target="${2:-}" width="${3:-0}"
    local raw now diff has=0
    if [ -z "$target" ] || [ "$target" = "null" ]; then
        raw="-"
    else
        has=1
        now=${CL_NOW:-$(date +%s)}
        diff=$(( target - now ))
        if   [ "$diff" -le 0 ];     then raw="now"
        elif [ "$diff" -lt 60 ];    then printf -v raw '%ds' "$diff"
        elif [ "$diff" -lt 3600 ];  then printf -v raw '%dm' $(( diff / 60 ))
        elif [ "$diff" -lt 86400 ]; then printf -v raw '%dh %02dm' $(( diff / 3600 )) $(( (diff % 3600) / 60 ))
        else                             printf -v raw '%dd %02dh' $(( diff / 86400 )) $(( (diff % 86400) / 3600 ))
        fi
    fi
    if [ "$width" -gt 0 ]; then
        local padded
        printf -v padded '%-*s' "$width" "$raw"
        if [ "$has" -eq 1 ] && [ "$diff" -gt 0 ] && [ "$diff" -lt 3600 ]; then
            printf -v "$__out" '\033[96m%s\033[39m' "$padded"
        else
            printf -v "$__out" '%s' "$padded"
        fi
    else
        printf -v "$__out" '%s' "$raw"
    fi
}

show_dashboard() {
    cl_load_data
    local frame
    CL_EOL="" build_frame_to frame -1
    printf '%s' "$frame"
}

# build_frame_to <out_var> <cursor_idx> — 캐시(CL_*)에서 frame 빌드.
# printf -v 만 사용 → 서브셸/파이프/jq 0개. 한 번의 printf 로 atomic 출력 가능.
# @convergence state=ossified id=ATOMIC_FRAME value="단일 printf 로 전체 프레임 한 번에 write — protrusion/flicker 0" threshold="10계정 프레임 빌드 서브셸/파이프 0개" ossified_at=2026-04-13 ref_commit=b1fd934e
# @convergence state=ossified id=ASCII_CURSOR value="'>' + reverse video — wide-char triangle 대체" threshold="터미널별 글자 protrusion 없음" ossified_at=2026-04-13 ref_commit=c33a1d33
build_frame_to() {
    local __out=$1
    local cursor="${2:--1}"
    local eol="${CL_EOL-}"
    # NOTE: 내부 누적 _buf — caller 의 'frame' 등과 dynamic scoping 충돌 방지.
    local _buf="" line b1 b2 stale_note=""
    local count=${#CL_NAMES[@]}
    local i name wi si err act_mark num_label s_in w_in
    local CL_NOW; CL_NOW=$(date +%s)

    # 정직성 게이트 후속: cache 나이 1h 이상이면 헤더에 STALE 경고.
    [ "${CL_STALE_H:-0}" -ge 1 ] && stale_note="    cache=${CL_STALE_H}h STALE→cl refresh"
    printf -v line "cl — Claude accounts    active=%s    store=%s%s%s\n" "${CL_ACTIVE:-none}" "$CL_HOME" "$stale_note" "$eol"
    _buf+="$line"
    # 컬럼 순서: session 을 앞쪽. 각 pct/bar 뒤에 reset 까지 남은 시간.
    printf -v line "    %-3s  %-10s  %4s  %-20s  %-7s  %4s  %-20s  %-7s  %s%s\n" \
        "no" "name" "ss%" "[session]" "resets" "wk%" "[week_all]" "resets" "err" "$eol"
    _buf+="$line"
    printf -v line "    -----------------------------------------------------------------------------------------------%s\n" "$eol"
    _buf+="$line"

    for ((i=0; i<count; i++)); do
        name="${CL_NAMES[$i]}"
        printf -v wi '%.0f' "${CL_WK[$i]:-0}"
        printf -v si '%.0f' "${CL_SS[$i]:-0}"
        err="${CL_ERR[$i]:-}"
        bar_to b1 "$wi"
        bar_to b2 "$si"
        fmt_until s_in "${CL_SRT[$i]:-}" 7
        fmt_until w_in "${CL_WRT[$i]:-}" 7
        # * = auto-pick (여유 있고 wk% 최저) = cursor 초기 위치. active 는 헤더에 표시.
        act_mark=" "
        [ "$name" = "$CL_AUTO" ] && act_mark="*"
        if [ "$i" -lt 9 ]; then num_label=$((i+1));
        elif [ "$i" -eq 9 ]; then num_label="0";
        else num_label="-"; fi
        # 순서: session(%,bar,resets) → week(%,bar,resets) → err. 커서 행 전체 reverse video.
        if [ "$i" -eq "$cursor" ]; then
            printf -v line "\033[7m  > %-3s %s%-10s  %3s%%  %s  %s  %3s%%  %s  %s  %s\033[0m%s\n" \
                "$num_label" "$act_mark" "$name" "$si" "$b2" "$s_in" "$wi" "$b1" "$w_in" "$err" "$eol"
        else
            printf -v line "    %-3s %s%-10s  %3s%%  %s  %s  %3s%%  %s  %s  %s%s\n" \
                "$num_label" "$act_mark" "$name" "$si" "$b2" "$s_in" "$wi" "$b1" "$w_in" "$err" "$eol"
        fi
        _buf+="$line"
    done

    printf -v "$__out" '%s' "$_buf"
}

# 단일 키 읽기 — 결과는 글로벌 CL_KEY 에. 서브셸 회피 (호출당 ~5ms 절약).
# bash 3.2 호환: -t 는 정수 초만 지원. 화살표는 ESC[X 가 atomic 으로 버퍼링되므로
# ESC 감지 후 2 바이트 더 읽기. lone ESC 는 1초 timeout (q 로 즉시 취소 가능).
# @convergence state=ossified id=BASH32_COMPAT value="read -t 정수 초 + ESC 2바이트 추가 감지" threshold="macOS 기본 bash 3.2 동작" ossified_at=2026-04-13 ref_commit=7ea4ba3f
CL_KEY=""
read_key() {
    local key rest
    IFS= read -rsn1 key
    if [[ "$key" == $'\x1b' ]]; then
        rest=""
        IFS= read -rsn2 -t 1 rest 2>/dev/null || true
        key+="${rest}"
    fi
    CL_KEY="$key"
}

# SPINNER (2026-04-18, LAG FIX) — cl-refresh.lock 존재 시 헤더에 애니메이션 표시.
# 설계:
#   - 1초 timeout read 로 tick 구동 (bash 3.2 정수초 한정). 프레임 1Hz → 조용하고 렉 0.
#   - 프레임마다 전체 repaint X. 오직 '헤더 우측 짧은 문자열' 만 cursor-save/restore 로 덮어씀.
#   - lock 없어지면 spinner char = ✓ 로 1회 갱신 후 자체 종료 (정적).
# 상태:
#   CL_SPIN_STATE : "run" | "done" | "off"
#   CL_SPIN_IDX   : 현재 프레임 인덱스
# 프레임: 점 증감 — "   " → ".  " → ".. " → "..." 4-컷. 접속 기간 내내 계속 순환.
CL_SPIN_FRAMES=('   ' '.  ' '.. ' '...')
CL_SPIN_IDX=0
CL_SPIN_STATE="off"

# 헤더 줄 우측에 spinner 문자열 오버레이. total_lines 위로 이동해 첫 줄 끝 쪽에 덧씌움.
# 인자: <total_lines>  (현재 커서 위치에서 위로 올라갈 행 수)
spin_paint() {
    local total="$1" frame label
    if [ "$CL_SPIN_STATE" = "run" ]; then
        frame="${CL_SPIN_FRAMES[$CL_SPIN_IDX]}"
        label="접속중${frame}"
        CL_SPIN_IDX=$(( (CL_SPIN_IDX + 1) % ${#CL_SPIN_FRAMES[@]} ))
    elif [ "$CL_SPIN_STATE" = "done" ]; then
        label="접속완료   "
    else
        return 0
    fi
    # cursor-save → up N → col 1 → 헤더 뒤에 덧씌움 → cursor-restore.
    # 헤더는 1번째 줄. "cl — Claude accounts    active=..." 뒤에 충분한 공백이 있으므로
    # 120 컬럼대까지는 안전. 우측 끝 근처 90열쯤에 기록.
    printf '\033[s\033[%dA\r\033[90G\033[2K%s\033[u' "$total" "$label"
}

# lock 존재 여부 (싱글 stat, 서브셸 0). CL_REFRESH_LOCK 에 캐시된 경로로 체크.
spin_lock_exists() {
    [ -f "$CL_HOME/cl-refresh.lock" ]
}

# @convergence state=ossified id=MULTI_ACCOUNT_LAUNCH value="cl → 픽커 → exec claude" threshold="계정 10개+ 지원, 자연 정렬 (claude1..claude10)" ossified_at=2026-04-13 ref_commit=bbb35a10
# @convergence state=ossified id=ACTIVE_FIRST_CURSOR value="active 가 <95% + error 없으면 커서/폴백 키 모두 거기, 아니면 auto_pick(=*)" threshold="캐시 stale 시 활성 계정 유지로 오인 전환 방지 — 커서 배치 + '그 외 키' fallback 동시 적용" ossified_at=2026-04-13 ref_commit=f852b076 rationale="claude10 사고 — 캐시 week_all_pct=0 이나 실제 5h 세션 한도 hit. 스페이스 등 '그 외 키' 에서도 auto 로 빠지던 잔여 경로 차단"
# @convergence state=stable id=FOOTER_HINT value="moved=0 && _placed=0 && auto 다를 때만 '그 외 → auto 추천', 그 외엔 커서 확정 문구만" note="active 우선 시 추천 힌트 감춤 — 커서=active 인데 auto 가 다른 계정이면 오해 유발"
# @convergence state=stable id=KEY_MAP value="arrows 이동, Enter 선택, 1-9/0 점프, q/ESC 취소, 그 외 → active 여유 시 커서 유지 / 아니면 auto" note="화살표 ESC[A/B/C/D + ESC O A/B/C/D 양식 모두 지원. 스페이스도 '그 외' 로 처리됨"
cmd_interactive() {
    if ! { [ -t 0 ] && [ -t 1 ]; }; then
        show_dashboard
        return 0
    fi
    # 데이터 1회 로드 — 루프 안에서는 jq 호출 없음
    cl_load_data
    local count=${#CL_NAMES[@]}
    [ "$count" -gt 0 ] || { echo "ERROR(cl): 계정 없음" >&2; exit 1; }

    local auto="$CL_AUTO"
    local cursor=0 i _placed=0
    # 커서 초기 위치: auto-pick(=*) 계정 (여유 있고 wk% 최저). 없으면 0.
    # 정렬 위치는 그대로(자연정렬) — cursor 만 * 위치로 이동.
    if [ -n "$auto" ]; then
        for ((i=0; i<count; i++)); do [ "${CL_NAMES[$i]}" = "$auto" ] && cursor=$i && break; done
    fi

    local total_lines=$(( count + 4 ))   # 헤더1 + 컬럼1 + 구분1 + n + 푸터1
    local first=1 selected="" moved=0 idx footer

    # 커서 숨김 + 종료 시 복원 (Ctrl-C 포함)
    printf '\033[?25l'
    trap 'printf "\033[?25h"' EXIT INT TERM

    # 인터랙티브에서는 행 끝에 \033[K 주입 → 덮어쓸 때 잔존 문자 제거
    local CL_EOL=$'\033[K'

    local body prefix
    while true; do
        # 1. 이동 prefix (첫 프레임 제외)
        if [ $first -eq 1 ]; then
            prefix=""; first=0
        else
            printf -v prefix '\033[%dA\r' "$total_lines"
        fi

        # 2. 대시보드 본문 (단일 문자열, 캐시에서 빌드 → jq 0)
        CL_EOL="$CL_EOL" build_frame_to body "$cursor"

        # 3. 푸터 — active 가 쓸만(_placed=1)하면 "그 외 → * 추천" 문구 감춤
        #    (커서가 이미 active 에 있고, fallback 도 cursor 유지이므로 추천 표시는 오해 유발)
        if [ "$moved" -eq 0 ] && [ "$_placed" -eq 0 ] && [ -n "$auto" ] && [ "${CL_NAMES[$cursor]}" != "$auto" ]; then
            printf -v footer "  ↑↓←→ 이동  Enter→%s  1-9/0 점프  q 취소  (그 외 → %s 추천)\033[K\n" \
                "${CL_NAMES[$cursor]}" "$auto"
        else
            printf -v footer "  ↑↓←→ 이동  Enter→%s  1-9/0 점프  q 취소\033[K\n" \
                "${CL_NAMES[$cursor]}"
        fi

        # 4. ATOMIC: 단일 printf 로 전체 프레임 한 번에 write
        printf '%s%s%s' "$prefix" "$body" "$footer"

        # 5. SPINNER + 키 입력.
        #    refresh 중이면 1초 timeout read 로 tick → 프레임당 헤더 우측만 partial repaint.
        #    키 들어오면 즉시 탈출. lock 사라지면 ✓ 한 번 찍고 spinner off.
        if spin_lock_exists; then
            CL_SPIN_STATE="run"
        fi
        if [ "$CL_SPIN_STATE" = "off" ]; then
            read_key
        else
            CL_KEY=""
            local _k _r
            while true; do
                spin_paint "$total_lines"
                # 1초 timeout — bash 3.2 정수초 한정. 무입력 시 spinner 프레임 진행.
                if IFS= read -rsn1 -t 1 _k; then
                    if [[ "$_k" == $'\x1b' ]]; then
                        _r=""
                        IFS= read -rsn2 -t 1 _r 2>/dev/null || true
                        _k+="$_r"
                    fi
                    CL_KEY="$_k"
                    break
                fi
                # timeout → lock 재확인. 사라졌으면 done 한 번 찍고 off.
                if ! spin_lock_exists; then
                    if [ "$CL_SPIN_STATE" = "run" ]; then
                        CL_SPIN_STATE="done"
                        spin_paint "$total_lines"
                        CL_SPIN_STATE="off"
                    fi
                    # spinner off 상태에서 다시 blocking read.
                    read_key
                    break
                fi
            done
        fi
        case "$CL_KEY" in
            $'\x1b[A'|$'\x1b[D'|$'\x1bOA'|$'\x1bOD')
                cursor=$(( (cursor - 1 + count) % count )); moved=1 ;;
            $'\x1b[B'|$'\x1b[C'|$'\x1bOB'|$'\x1bOC')
                cursor=$(( (cursor + 1) % count )); moved=1 ;;
            "")  selected="${CL_NAMES[$cursor]}"; break ;;
            [1-9])
                idx=$(( CL_KEY - 1 ))
                if [ "$idx" -lt "$count" ]; then selected="${CL_NAMES[$idx]}"; break; fi ;;
            0)
                if [ "$count" -ge 10 ]; then selected="${CL_NAMES[9]}"; break; fi ;;
            q|Q|$'\x1b')
                printf '\n취소\n'
                printf '\033[?25h'; trap - EXIT INT TERM
                return 1 ;;
            *)
                # 이동했거나 active 가 쓸만하면 커서 위치 선택.
                # auto_pick(=*) 은 캐시 stale 에 취약 — active 여유 있을 땐 무지성 전환 금지.
                if [ "$moved" -eq 1 ] || [ "$_placed" -eq 1 ]; then
                    selected="${CL_NAMES[$cursor]}"
                else
                    selected="${auto:-${CL_NAMES[$cursor]}}"
                fi
                break ;;
        esac
    done

    printf '\033[?25h'; trap - EXIT INT TERM

    set_active "$selected"
    local dir; dir=$(config_dir_for "$selected")
    # @convergence state=removed id=LAUNCH_SPINNER removed_at=2026-04-18 reason_kr="18f × 80ms 쿨다운 = exec 지연 1.4s 누적. 사용자 요청으로 정보 한 줄 + 즉시 exec 으로 교체. cx 측 handshake 진행은 cx stderr 에 표시됨"
    printf '\n→ %s (%s)\n' "$selected" "$dir"
    export CLAUDE_CONFIG_DIR="$dir"
    # @convergence state=ossified id=FOCUSED_BG_REFRESH ossified_at=2026-04-18 value="선택 계정 1건만 cl-refresh bg kick — CL_KICK 우회 (전역 12계정 bulk 부담 없음), ccmon 스타일" rationale="kick_bg_refresh 의 전역 30min 쿨다운/CL_KICK=0 으로 cache 영구 stale 블랙홀. TUI 접속 시 최소 선택 계정 1건만 즉시 refresh → 다음 cl 에 반영"
    ( "$(dirname "$0")/cl-refresh" "$selected" >/dev/null 2>&1 ) &
    disown 2>/dev/null || true
    # @convergence state=evolving id=LIMIT_MARK_INTERACTIVE value="interactive exec 경로에서도 rate-limit 감지 — 현재는 exec 하므로 post-exec 감시 불가. 래퍼 스크립트 or claude 자체 hook 필요" priority=med note="passthrough 경로는 2026-04-13 1e3724ab 에서 해소. 남은 건 대화형 exec 후 실패 케이스"
    # @convergence state=stable id=CLAUDE_EXEC_BRIDGE value="CLAUDE_EXEC env 로 exec 대상 오버라이드 — 기본 'claude', 설정 시 해당 커맨드로 교체 (예: CLAUDE_EXEC=cx 로 airgenome cross-host 라우터 경유)" ossified_at=2026-04-17 rationale="cl 은 계정만 고르고, cx 는 호스트만 고름 — 두 축을 독립적으로 결합. CLAUDE_CONFIG_DIR 은 이미 export 되어 있어 cx → ssh SendEnv 로 원격에 전달 가능"
    local __cmd="${CLAUDE_EXEC:-claude}"
    if command -v "$__cmd" >/dev/null 2>&1; then
        exec "$__cmd"
    else
        echo "WARN(cl): '$__cmd' 바이너리 없음. env만 갱신" >&2
    fi
}

show_status() {
    local active; active="$(current_active)"
    local count; count=$(jq '.accounts | length' "$ACCOUNTS")
    echo "active: ${active:-none}"
    echo "count : $count"
    echo "store : $CL_HOME"
}

cmd_pick() {
    local target="${1:-}"
    if [ -z "$target" ]; then
        target="$(auto_pick)"
        [ -n "$target" ] || { echo "ERROR(cl): 가용 계정 없음 (모두 가용량 ≤5% 또는 error)" >&2; exit 1; }
        echo "auto-pick: $target"
    fi
    local exists; exists=$(jq -r --arg n "$target" '.accounts[] | select(.name == $n) | .name' "$ACCOUNTS")
    [ -n "$exists" ] || { echo "ERROR(cl): 계정 '$target' 없음" >&2; exit 1; }
    set_active "$target"
    local dir; dir=$(config_dir_for "$target")
    echo "active → $target ($dir)"
}

# @convergence state=evolving id=MEMORY_SHARE value="계정별 CLAUDE_CONFIG_DIR 독립으로 projects/memory 분리. 장기 memory 공유 필요 시 심링크 명령(cl link-memory) 신설" priority=low note="one-shot -p 자동화는 stateless → 현재는 불필요. --resume 다계정 연속 작업이 생기면 진화"
cmd_env() {
    local active; active="$(current_active)"
    [ -n "$active" ] || { echo "ERROR(cl): active 없음. 'cl pick' 먼저" >&2; exit 1; }
    local dir; dir=$(config_dir_for "$active")
    [ -n "$dir" ] || { echo "ERROR(cl): '$active' config_dir 없음" >&2; exit 1; }
    # eval "$(cl env)" 로 사용
    printf 'export CLAUDE_CONFIG_DIR=%q\n' "$dir"
}

# 런타임 rate-limit 감지 시 usage-cache 에 error 필드 주입 → auto_pick 에서 즉시 배제
# @convergence state=ossified id=RATE_LIMIT_RUNTIME_MARK value="passthrough 중 claude 실패 + stderr rate-limit 패턴 감지 → usage-cache[name].error=\"rate-limit-runtime\" 주입 + auto_pick 재선정으로 1회 재시도" threshold="패턴 — rate-limit / usage limit / quota / 429 / too many request. retry 는 1회만(무한 루프 방지)" ossified_at=2026-04-13 ref_commit=1e3724ab rationale="failed.LIMIT_DETECTION 해소 — 캐시 stale 로 실제 limit 계정 뽑혀도 런타임에 자동 배제"
# @convergence state=stable id=LIMIT_DETECTION value="5h 세션 한도는 API 에러로만 드러남 — cache 에는 error=null" symptom="claude CLI 가 429/rate_limit 반환해도 usage-cache 업데이트 안 됨" threshold="claude 런칭 실패 시 해당 계정 자동 블랙리스트 or error 필드 주입" mitigation="ossified.RATE_LIMIT_RUNTIME_MARK (2026-04-13, 1e3724ab) — passthrough 경로에서 런타임 감지+마킹 구현. interactive exec 경로는 여전히 감시 불가(별도 래퍼 필요)" original_status=RESOLVED
mark_rate_limit() {
    local name="$1"
    [ -f "$USAGE" ] || return 0
    local tmp="$USAGE.tmp.$$"
    jq --arg n "$name" '.[$n].error = "rate-limit-runtime"' "$USAGE" > "$tmp" 2>/dev/null \
        && mv "$tmp" "$USAGE" || rm -f "$tmp"
}

account_exists() {
    local name="$1"
    [ -n "$name" ] || return 1
    jq -e --arg n "$name" '.accounts[] | select(.name == $n)' "$ACCOUNTS" >/dev/null 2>&1
}

# cmd_passthrough <NAME_or_empty> <claude_args...>
# - NAME 비어있으면 auto_pick
# - claude 실행 실패 + stderr 에 rate-limit 단서 → 해당 계정 마킹 + 다음 후보로 1회 재시도
# @convergence state=ossified id=PASSTHROUGH_MODE value="cl -- <args> (auto-pick) / cl NAME -- <args> (명시) → claude \"$@\"" threshold="비-tty 에서도 동작. interactive 픽커 우회. 타 프로젝트 자동화에서 claude 대체재" ossified_at=2026-04-13 ref_commit=1e3724ab rationale="사용자 요청 — 타 프로젝트 자동화(limit 걸린 계정 회피) 시 cl 을 claude 대신 호출. one-shot -p 용도가 주"
cmd_passthrough() {
    local name="$1"; shift
    if [ -z "$name" ]; then
        name="$(auto_pick)"
        [ -n "$name" ] || { echo "ERROR(cl): 가용 계정 없음 (모두 가용량 ≤5% 또는 error)" >&2; exit 1; }
    fi
    account_exists "$name" || { echo "ERROR(cl): 계정 '$name' 없음" >&2; exit 1; }
    command -v claude >/dev/null 2>&1 || { echo "ERROR(cl): claude 바이너리 없음" >&2; exit 127; }

    local dir; dir=$(config_dir_for "$name")
    set_active "$name"
    export CLAUDE_CONFIG_DIR="$dir"
    echo "cl: → $name ($dir)" >&2
    # FOCUSED_BG_REFRESH — passthrough 경로에서도 선택 계정만 bg refresh (ccmon 스타일).
    ( "$(dirname "$0")/cl-refresh" "$name" >/dev/null 2>&1 ) &
    disown 2>/dev/null || true

    # one-shot passthrough — stderr 를 임시 파일로 캡처 후 사용자에게 그대로 전달
    # CLAUDE_EXEC 오버라이드 적용 (기본 claude, 예: cx)
    local __cmd="${CLAUDE_EXEC:-claude}"
    local tmp_err rc
    tmp_err=$(mktemp -t cl-err.XXXXXX)
    if "$__cmd" "$@" 2>"$tmp_err"; then
        rc=0
    else
        rc=$?
    fi
    cat "$tmp_err" >&2

    # rate-limit 패턴 감지 → 해당 계정 마킹 + auto_pick 재선정 (self 제외) 1회 재시도
    if [ "$rc" -ne 0 ] && grep -qiE 'rate[- ]?limit|usage limit|quota|429|too many request' "$tmp_err" 2>/dev/null; then
        mark_rate_limit "$name"
        local next; next="$(auto_pick)"
        if [ -n "$next" ] && [ "$next" != "$name" ]; then
            echo "cl: rate-limit detected on $name → retry with $next" >&2
            rm -f "$tmp_err"
            local next_dir; next_dir=$(config_dir_for "$next")
            set_active "$next"
            export CLAUDE_CONFIG_DIR="$next_dir"
            exec "$__cmd" "$@"
        fi
    fi
    rm -f "$tmp_err"
    return "$rc"
}

# @convergence state=ossified id=LIST_ALIAS value="cl list = cl u (= show_dashboard)" threshold="자동화 스크립트 계정 목록 조회용 의미론 별칭" ossified_at=2026-04-13 ref_commit=1e3724ab
# @convergence state=ossified id=CL_REFRESH_ENGINE value="shared/bin/cl-refresh — bash+curl+jq+security 자체 엔진 (IP rate limit 회피 — refresh cap=2/cycle, usage fetch 10 parallel)" threshold="spec — shared/engine/cl_refresh_spec.json; 부분실패 시 기존 entry 유지(never_zero_out); 토큰 로그 0건" ossified_at=2026-04-14 ref_commit=TBD-cl-migration rationale="failed.CACHE_STALENESS + evolving.AUTO_REFRESH 해소 — 외부 airgenome/ccmon 의존 없이 자체 refresh"
# @convergence state=ossified id=LAUNCHD_MANAGER value="shared/bin/cl-refresh-launchd install|uninstall|status|run-now|logs — 모던 launchctl (bootstrap/bootout/kickstart)" threshold="deprecated load/unload 미사용. gui/uid 도메인 고정. plist 실체 복사. 30m 주기" ossified_at=2026-04-14 ref_commit=TBD-cl-migration
# @convergence state=ossified id=AUTO_REFRESH_LAUNCHD value="launchd 30m 주기 + plist CL_HOME env + cl refresh 서브커맨드 위임" threshold="cl refresh / --dry-run / --verify / <name> 모두 cl-refresh 로 exec" ossified_at=2026-04-14 ref_commit=TBD-cl-migration
# @convergence state=ossified id=LAUNCHD_PATH_HARDENED value="plist EnvironmentVariables.PATH 선두에 /Users/ghost/.local/bin — cron 컨텍스트에서 command -v claude 성공" threshold="refresh_via_cli 정상 동작 + IP rate_limit 우회 작동. 로그에 refreshed(cli) 다수 등장" ossified_at=2026-04-15 ref_commit=dba4246f rationale="2026-04-15 재발 사고 — claude=/Users/ghost/.local/bin/claude 인데 plist PATH(/opt/homebrew/bin:/usr/local/bin:...) 누락 → refresh_via_cli 조기 리턴 → direct POST CAP=2 캐스케이드 → fail=11 도달. 로그 전체에 refreshed(cli) 1건만 존재."
# @convergence state=stable id=STALE_REFRESH_UNUSED value="~/.airgenome/cl-stale-refresh.<name> 마커 생성되지만 cl 은 안 읽음" symptom="2026-04-13 12:01 cl-stale-refresh.claude10 생성, 픽커는 여전히 0% 표시" mitigation="2026-04-14 shared/.runtime/accounts/markers/ 로 이관 + cl-refresh 가 launchd 로 실측 갱신. 레거시 ~/.airgenome 마커는 deprecated" threshold="마커 존재 시 해당 계정 경고 표시 or refresh 트리거" original_status=RESOLVED
# @convergence state=evolving id=REFRESH_BACKOFF_PERSISTENCE value="cl-refresh 실패 계정별 지수 backoff 상태를 shared/.runtime/accounts/cl-refresh-cooldown.json 에 영속 — 현재는 매 사이클 재시도" priority=low note="spec — rate_limit_policy.cooldown_persistence. 현재 구현은 cap=2/cycle 만"

# cl 실행 시 background cl-refresh 를 cooldown(기본 30m)으로 트리거.
# launchd 자동실행 대체 — cl 을 쓰는 맥락에서만 usage-cache 가 갱신됨.
# CL_KICK_COOLDOWN 환경변수로 초 단위 조정. CL_KICK=0 로 완전 차단.
#
# LAG FIX (2026-04-18):
#   - marker 경로를 ~/.airgenome → $CL_HOME 으로 이관 (SHARED_SSOT_MIGRATION 일관)
#   - cl-refresh.lock 존재 시 즉시 skip (이미 돌고 있음 → 중복 실행 방지)
#   - kick 자체는 마이크로초 수준이지만 마커 I/O 는 최대한 게으르게
kick_bg_refresh() {
    [ "${CL_KICK:-1}" = "0" ] && return 0
    # 이미 refresh 돌고 있으면 marker 만 갱신하고 return (spinner 가 lock 기반으로 뜸)
    if [ -f "$CL_HOME/cl-refresh.lock" ]; then
        return 0
    fi
    local marker="$CL_HOME/cl-refresh.last_kick"
    local cooldown="${CL_KICK_COOLDOWN:-1800}"
    if [ -f "$marker" ]; then
        local age=$(( $(date +%s) - $(stat -f %m "$marker" 2>/dev/null || echo 0) ))
        [ "$age" -lt "$cooldown" ] && return 0
    fi
    : > "$marker"
    nohup "$(dirname "$0")/cl-refresh" >/dev/null 2>&1 &
    disown 2>/dev/null || true
}

case "${1:-interactive}" in
    ""|interactive)  kick_bg_refresh; cmd_interactive ;;
    u|dashboard|list) kick_bg_refresh; show_dashboard ;;
    status)          kick_bg_refresh; show_status ;;
    pick)            shift || true; kick_bg_refresh; cmd_pick "${1:-}" ;;
    env)             cmd_env ;;
    refresh)         shift || true; exec "$(dirname "$0")/cl-refresh" "$@" ;;
    --)              shift; kick_bg_refresh; cmd_passthrough "" "$@" ;;
    help|-h|--help)
        cat <<USAGE
cl — Claude Code multi-account launcher (nexus-managed)

Subcommands:
  cl                   대화형 픽커 → 선택 → claude 런칭 (비-tty면 cl u)
  cl u | list          대시보드만 (조회/스크립트용)
  cl status            요약
  cl pick [NAME]       active 전환만 (런칭 X). NAME 없으면 자동
  cl env               eval "\$(cl env)" → CLAUDE_CONFIG_DIR export
  cl refresh [...]     usage-cache.json 갱신 (cl-refresh 위임)
                         cl refresh            # 전체 계정 병렬 갱신
                         cl refresh <name>     # 단일 계정
                         cl refresh --dry-run  # keychain 접근 테스트
                         cl refresh --verify   # 현재 cache 요약
  cl help

Passthrough (타 프로젝트 자동화 용 — claude 대체재):
  cl -- <args>         auto-pick (limit 없는 최저 wk%) → claude "\$@"
  cl NAME -- <args>    NAME 계정으로 claude "\$@"

  예) cl -- -p "분석해줘"
      cl claude7 -- -p "..." --output-format json
  - 비-tty OK (파이프/스크립트 가능)
  - rate-limit 감지 시 해당 계정 error 마킹 + 다음 후보로 1회 재시도
  - 각 계정 CLAUDE_CONFIG_DIR 독립 → projects/memory 분리
    (장기 memory 공유 필요 시 별도 심링크, 현재 미제공)

대화형 키:
  ↑↓←→     커서 이동 (이동 후엔 "그 외 키" 추천 진입 비활성)
  Enter    커서 위치 선택
  1-9 / 0  번호 점프 (0 = 10번)
  q / ESC  취소
  그 외     active 가 쓸만하면 커서 유지, 아니면 * 계정으로 진입

표기:
  active=... (헤더)   현재 활성 계정
  *                   auto-pick (여유 있고 wk% 최저) = cursor 초기 위치
  >                   커서 위치

Store: $CL_HOME
USAGE
        ;;
    *)
        # 첫 인자가 accounts.json 에 있는 계정명이면 passthrough 로 처리
        # 사용법: cl NAME -- <claude args>   (또는 -- 생략도 허용)
        if account_exists "$1"; then
            name="$1"; shift
            [ "${1:-}" = "--" ] && shift || true
            kick_bg_refresh
            cmd_passthrough "$name" "$@"
        else
            echo "ERROR(cl): unknown subcommand '$1' — 'cl help'" >&2; exit 64
        fi
        ;;
esac
