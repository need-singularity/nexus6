#!/bin/bash
# shared/bin/cl — Claude Code multi-account launcher (nexus-managed, bash)
# 독립 명령. 자동 계정 선택(week_all_pct 최저) + rate-limit 수동 재선택.
#
# Convergence SSOT: shared/convergence/cl.json
#   — 골화(ossified) / 수렴(stable) / 미달(failed) / 진화(evolving) 추적.
#   — 기능 추가/개선 시 해당 섹션 갱신 + cl-approved 태그로 커밋.
#
# Store: ~/.claude-accounts/
#   accounts.json    {"accounts":[{"name","config_dir"}]}
#   cl-state.json    {"active":"<name>"}
#   usage-cache.json {"<name>":{week_all_pct,session_pct,error,resets}}
#
# Subcommands:
#   cl              대화형 픽커 (tty) → 선택 → exec claude. 비-tty면 cl u 와 동일
#   cl u            usage bars (비대화형 조회용)
#   cl list         계정 목록 (cl u alias — 타 프로젝트 자동화 용)
#   cl status       간단 요약
#   cl pick [NAME]  활성 계정 전환만(런칭 X). NAME 없으면 week_all_pct 최저 자동
#   cl env          현재 활성 계정의 CLAUDE_CONFIG_DIR export 라인 출력
#   cl -- ARGS      auto-pick → claude "$@" (비대화형 passthrough, 자동화 용)
#   cl NAME -- ARGS NAME 계정으로 claude "$@" (명시 passthrough)
#   cl help
#
# Passthrough 특징:
#   - 비-tty 에서도 동작 → 타 프로젝트 스크립트/파이프에 연결 가능 (claude 대체재)
#   - stderr rate-limit 감지 시 usage-cache 에 error 마킹 + 다음 후보로 1회 재시도
#   - 각 계정별 CLAUDE_CONFIG_DIR 독립 → projects/memory 분리 (one-shot 에 안전)
#
# AirGenome 기존 cl 은 hexa 기반으로 void-method 이슈로 깨짐.
# 본 스크립트는 기존 코드 무시, 자동 선택 로직만 참고하여 재작성.

set -euo pipefail

CL_HOME="${CL_HOME:-$HOME/.claude-accounts}"
ACCOUNTS="$CL_HOME/accounts.json"
STATE="$CL_HOME/cl-state.json"
USAGE="$CL_HOME/usage-cache.json"

mkdir -p "$CL_HOME"

# 1회성 seed — store 비어있으면 ~/.airgenome 에서 복사 (airgenome 의존 끊기 위한 이행 단계)
seed_from_airgenome() {
    local src="$HOME/.airgenome"
    [ -d "$src" ] || return 0
    [ ! -f "$ACCOUNTS" ] && [ -f "$src/accounts.json"   ] && cp "$src/accounts.json"   "$ACCOUNTS"   || true
    [ ! -f "$STATE"    ] && [ -f "$src/cl-state.json"   ] && cp "$src/cl-state.json"   "$STATE"      || true
    [ ! -f "$USAGE"    ] && [ -f "$src/usage-cache.json" ] && cp "$src/usage-cache.json" "$USAGE"     || true
}
seed_from_airgenome

[ -f "$ACCOUNTS" ] || { echo "ERROR(cl): $ACCOUNTS 없음" >&2; exit 2; }
command -v jq >/dev/null 2>&1 || { echo "ERROR(cl): jq 필요" >&2; exit 3; }

current_active() {
    jq -r '.active // empty' "$STATE" 2>/dev/null
}

set_active() {
    local name="$1"
    local tmp="$STATE.tmp.$$"
    jq -n --arg a "$name" '{active:$a}' > "$tmp" && mv "$tmp" "$STATE"
}

config_dir_for() {
    local name="$1"
    jq -r --arg n "$name" '.accounts[] | select(.name == $n) | .config_dir' "$ACCOUNTS"
}

# 자연 정렬 — claude1, claude2, ..., claude9, claude10 (사전식 X)
list_accounts() {
    jq -r '.accounts[].name' "$ACCOUNTS" | sort -V
}

# pct(정수 0..100) → 20칸 바. printf -v 로 변수 직접 작성 (no subshell, no pipe).
# bar_to <var_name> <pct>
bar_to() {
    local __var=$1 pct=${2:-0}
    local filled=$(( (pct + 2) / 5 ))
    [ $filled -gt 20 ] && filled=20
    [ $filled -lt 0 ] && filled=0
    local hashes="####################"   # 20
    local dots="...................."     # 20
    printf -v "$__var" '%s%s' "${hashes:0:filled}" "${dots:0:$((20-filled))}"
}

# usage-cache 에서 week_all_pct 최저(error=null, <95) 계정 선택
auto_pick() {
    [ -f "$USAGE" ] || { echo "" ; return; }
    jq -r '
        [to_entries[]
            | select(.key != "_ts")
            | select(.value.error == null)
            | select((.value.week_all_pct // 100) < 95)
            | {name:.key, wk:(.value.week_all_pct // 100)}]
        | sort_by(.wk)
        | .[0].name // empty
    ' "$USAGE" 2>/dev/null
}

# 글로벌 데이터 캐시. 인터랙티브 루프 전 1회 로드 → 프레임 빌드 시 jq 호출 0.
CL_ACTIVE=""
CL_AUTO=""
CL_NAMES=()
CL_WK=()
CL_SS=()
CL_ERR=()

# 단일 jq 호출로 accounts.json + usage-cache.json 결합 → name\tweek\tsess\terr.
# 정렬은 sort -V (자연 정렬: claude9 < claude10).
# Before: 30+ jq 호출/프레임 (10계정 × 3필드). After: 1 jq 호출/세션.
cl_load_data() {
    CL_ACTIVE="$(current_active)"
    CL_AUTO="$(auto_pick)"
    CL_NAMES=(); CL_WK=(); CL_SS=(); CL_ERR=()
    local raw
    if [ -f "$USAGE" ]; then
        raw=$(jq -r --slurpfile usage "$USAGE" '
            $usage[0] as $u
            | .accounts[]
            | "\(.name)\t\(($u[.name].week_all_pct // 0))\t\(($u[.name].session_pct // 0))\t\(($u[.name].error // ""))"
        ' "$ACCOUNTS" 2>/dev/null | sort -V)
    else
        raw=$(jq -r '.accounts[] | "\(.name)\t0\t0\tno-cache"' "$ACCOUNTS" 2>/dev/null | sort -V)
    fi
    local n w s e
    while IFS=$'\t' read -r n w s e; do
        [ -z "$n" ] && continue
        CL_NAMES+=("$n"); CL_WK+=("$w"); CL_SS+=("$s"); CL_ERR+=("$e")
    done <<< "$raw"
}

show_dashboard() {
    cl_load_data
    local frame
    CL_EOL="" build_frame_to frame -1
    printf '%s' "$frame"
}

# build_frame_to <out_var> <cursor_idx> — 캐시(CL_*)에서 frame 빌드.
# printf -v 만 사용 → 서브셸/파이프/jq 0개. 한 번의 printf 로 atomic 출력 가능.
build_frame_to() {
    local __out=$1
    local cursor="${2:--1}"
    local eol="${CL_EOL-}"
    # NOTE: 내부 누적 _buf — caller 의 'frame' 등과 dynamic scoping 충돌 방지.
    local _buf="" line b1 b2
    local count=${#CL_NAMES[@]}
    local i name wi si err act_mark num_label

    printf -v line "cl — Claude accounts    active=%s    store=%s%s\n" "${CL_ACTIVE:-none}" "$CL_HOME" "$eol"
    _buf+="$line"
    printf -v line "    %-3s  %-10s  %4s  %-20s  %4s  %-20s  %s%s\n" "no" "name" "wk%" "[week_all]" "ss%" "[session]" "err" "$eol"
    _buf+="$line"
    printf -v line "    -------------------------------------------------------------------------------%s\n" "$eol"
    _buf+="$line"

    for ((i=0; i<count; i++)); do
        name="${CL_NAMES[$i]}"
        printf -v wi '%.0f' "${CL_WK[$i]:-0}"
        printf -v si '%.0f' "${CL_SS[$i]:-0}"
        err="${CL_ERR[$i]:-}"
        bar_to b1 "$wi"
        bar_to b2 "$si"
        # * = 최선의 선택 (auto-pick: 여유 있고 wk% 최저). active 는 헤더에 표시.
        act_mark=" "
        [ "$name" = "$CL_AUTO" ] && act_mark="*"
        if [ "$i" -lt 9 ]; then num_label=$((i+1));
        elif [ "$i" -eq 9 ]; then num_label="0";
        else num_label="-"; fi
        # prefix 4 col 고정. 커서 행 전체 reverse video. ASCII '>' (wide-char 모호성 회피).
        if [ "$i" -eq "$cursor" ]; then
            printf -v line "\033[7m  > %-3s %s%-10s  %3s%%  %s  %3s%%  %s  %s\033[0m%s\n" \
                "$num_label" "$act_mark" "$name" "$wi" "$b1" "$si" "$b2" "$err" "$eol"
        else
            printf -v line "    %-3s %s%-10s  %3s%%  %s  %3s%%  %s  %s%s\n" \
                "$num_label" "$act_mark" "$name" "$wi" "$b1" "$si" "$b2" "$err" "$eol"
        fi
        _buf+="$line"
    done

    printf -v "$__out" '%s' "$_buf"
}

# 단일 키 읽기 — 결과는 글로벌 CL_KEY 에. 서브셸 회피 (호출당 ~5ms 절약).
# bash 3.2 호환: -t 는 정수 초만 지원. 화살표는 ESC[X 가 atomic 으로 버퍼링되므로
# ESC 감지 후 2 바이트 더 읽기. lone ESC 는 1초 timeout (q 로 즉시 취소 가능).
CL_KEY=""
read_key() {
    local key rest
    IFS= read -rsn1 key
    if [[ "$key" == $'\x1b' ]]; then
        rest=""
        IFS= read -rsn2 -t 1 rest 2>/dev/null || true
        key+="${rest}"
    fi
    CL_KEY="$key"
}

cmd_interactive() {
    if ! { [ -t 0 ] && [ -t 1 ]; }; then
        show_dashboard
        return 0
    fi
    # 데이터 1회 로드 — 루프 안에서는 jq 호출 없음
    cl_load_data
    local count=${#CL_NAMES[@]}
    [ "$count" -gt 0 ] || { echo "ERROR(cl): 계정 없음" >&2; exit 1; }

    local auto="$CL_AUTO"
    local cursor=0 i _placed=0 _wi _err
    # 커서 우선순위: active 가 아직 쓸만(<95%, error 없음) > auto_pick(=*) > 0
    # 캐시가 놓치는 외부 limit(예: 5시간 세션 한도)이 있을 수 있으므로,
    # 현재 계정이 여유 있을 때는 무지성 계정 전환 금지 — 유저가 직접 바꿀 때만 이동.
    if [ -n "$CL_ACTIVE" ]; then
        for ((i=0; i<count; i++)); do
            if [ "${CL_NAMES[$i]}" = "$CL_ACTIVE" ]; then
                printf -v _wi '%.0f' "${CL_WK[$i]:-100}"
                _err="${CL_ERR[$i]:-}"
                if [ -z "$_err" ] && [ "$_wi" -lt 95 ]; then
                    cursor=$i; _placed=1
                fi
                break
            fi
        done
    fi
    if [ "$_placed" -eq 0 ] && [ -n "$auto" ]; then
        for ((i=0; i<count; i++)); do [ "${CL_NAMES[$i]}" = "$auto" ] && cursor=$i && break; done
    fi

    local total_lines=$(( count + 4 ))   # 헤더1 + 컬럼1 + 구분1 + n + 푸터1
    local first=1 selected="" moved=0 idx footer

    # 커서 숨김 + 종료 시 복원 (Ctrl-C 포함)
    printf '\033[?25l'
    trap 'printf "\033[?25h"' EXIT INT TERM

    # 인터랙티브에서는 행 끝에 \033[K 주입 → 덮어쓸 때 잔존 문자 제거
    local CL_EOL=$'\033[K'

    local body prefix
    while true; do
        # 1. 이동 prefix (첫 프레임 제외)
        if [ $first -eq 1 ]; then
            prefix=""; first=0
        else
            printf -v prefix '\033[%dA\r' "$total_lines"
        fi

        # 2. 대시보드 본문 (단일 문자열, 캐시에서 빌드 → jq 0)
        CL_EOL="$CL_EOL" build_frame_to body "$cursor"

        # 3. 푸터 — active 가 쓸만(_placed=1)하면 "그 외 → * 추천" 문구 감춤
        #    (커서가 이미 active 에 있고, fallback 도 cursor 유지이므로 추천 표시는 오해 유발)
        if [ "$moved" -eq 0 ] && [ "$_placed" -eq 0 ] && [ -n "$auto" ] && [ "${CL_NAMES[$cursor]}" != "$auto" ]; then
            printf -v footer "  ↑↓←→ 이동  Enter→%s  1-9/0 점프  q 취소  (그 외 → %s 추천)\033[K\n" \
                "${CL_NAMES[$cursor]}" "$auto"
        else
            printf -v footer "  ↑↓←→ 이동  Enter→%s  1-9/0 점프  q 취소\033[K\n" \
                "${CL_NAMES[$cursor]}"
        fi

        # 4. ATOMIC: 단일 printf 로 전체 프레임 한 번에 write
        printf '%s%s%s' "$prefix" "$body" "$footer"

        # 5. 키 입력 (서브셸 없이 글로벌 CL_KEY 로)
        read_key
        case "$CL_KEY" in
            $'\x1b[A'|$'\x1b[D'|$'\x1bOA'|$'\x1bOD')
                cursor=$(( (cursor - 1 + count) % count )); moved=1 ;;
            $'\x1b[B'|$'\x1b[C'|$'\x1bOB'|$'\x1bOC')
                cursor=$(( (cursor + 1) % count )); moved=1 ;;
            "")  selected="${CL_NAMES[$cursor]}"; break ;;
            [1-9])
                idx=$(( CL_KEY - 1 ))
                if [ "$idx" -lt "$count" ]; then selected="${CL_NAMES[$idx]}"; break; fi ;;
            0)
                if [ "$count" -ge 10 ]; then selected="${CL_NAMES[9]}"; break; fi ;;
            q|Q|$'\x1b')
                printf '\n취소\n'
                printf '\033[?25h'; trap - EXIT INT TERM
                return 1 ;;
            *)
                # 이동했거나 active 가 쓸만하면 커서 위치 선택.
                # auto_pick(=*) 은 캐시 stale 에 취약 — active 여유 있을 땐 무지성 전환 금지.
                if [ "$moved" -eq 1 ] || [ "$_placed" -eq 1 ]; then
                    selected="${CL_NAMES[$cursor]}"
                else
                    selected="${auto:-${CL_NAMES[$cursor]}}"
                fi
                break ;;
        esac
    done

    printf '\033[?25h'; trap - EXIT INT TERM

    set_active "$selected"
    local dir; dir=$(config_dir_for "$selected")
    printf '\n→ %s (%s)\n' "$selected" "$dir"
    export CLAUDE_CONFIG_DIR="$dir"
    if command -v claude >/dev/null 2>&1; then
        exec claude --effort max
    else
        echo "WARN(cl): claude 바이너리 없음. env만 갱신" >&2
    fi
}

show_status() {
    local active; active="$(current_active)"
    local count; count=$(jq '.accounts | length' "$ACCOUNTS")
    echo "active: ${active:-none}"
    echo "count : $count"
    echo "store : $CL_HOME"
}

cmd_pick() {
    local target="${1:-}"
    if [ -z "$target" ]; then
        target="$(auto_pick)"
        [ -n "$target" ] || { echo "ERROR(cl): 가용 계정 없음 (모두 ≥95% 또는 error)" >&2; exit 1; }
        echo "auto-pick: $target"
    fi
    local exists; exists=$(jq -r --arg n "$target" '.accounts[] | select(.name == $n) | .name' "$ACCOUNTS")
    [ -n "$exists" ] || { echo "ERROR(cl): 계정 '$target' 없음" >&2; exit 1; }
    set_active "$target"
    local dir; dir=$(config_dir_for "$target")
    echo "active → $target ($dir)"
}

cmd_env() {
    local active; active="$(current_active)"
    [ -n "$active" ] || { echo "ERROR(cl): active 없음. 'cl pick' 먼저" >&2; exit 1; }
    local dir; dir=$(config_dir_for "$active")
    [ -n "$dir" ] || { echo "ERROR(cl): '$active' config_dir 없음" >&2; exit 1; }
    # eval "$(cl env)" 로 사용
    printf 'export CLAUDE_CONFIG_DIR=%q\n' "$dir"
}

# 런타임 rate-limit 감지 시 usage-cache 에 error 필드 주입 → auto_pick 에서 즉시 배제
mark_rate_limit() {
    local name="$1"
    [ -f "$USAGE" ] || return 0
    local tmp="$USAGE.tmp.$$"
    jq --arg n "$name" '.[$n].error = "rate-limit-runtime"' "$USAGE" > "$tmp" 2>/dev/null \
        && mv "$tmp" "$USAGE" || rm -f "$tmp"
}

account_exists() {
    local name="$1"
    [ -n "$name" ] || return 1
    jq -e --arg n "$name" '.accounts[] | select(.name == $n)' "$ACCOUNTS" >/dev/null 2>&1
}

# cmd_passthrough <NAME_or_empty> <claude_args...>
# - NAME 비어있으면 auto_pick
# - claude 실행 실패 + stderr 에 rate-limit 단서 → 해당 계정 마킹 + 다음 후보로 1회 재시도
cmd_passthrough() {
    local name="$1"; shift
    if [ -z "$name" ]; then
        name="$(auto_pick)"
        [ -n "$name" ] || { echo "ERROR(cl): 가용 계정 없음 (모두 ≥95% 또는 error)" >&2; exit 1; }
    fi
    account_exists "$name" || { echo "ERROR(cl): 계정 '$name' 없음" >&2; exit 1; }
    command -v claude >/dev/null 2>&1 || { echo "ERROR(cl): claude 바이너리 없음" >&2; exit 127; }

    local dir; dir=$(config_dir_for "$name")
    set_active "$name"
    export CLAUDE_CONFIG_DIR="$dir"
    echo "cl: → $name ($dir)" >&2

    # one-shot passthrough — stderr 를 임시 파일로 캡처 후 사용자에게 그대로 전달
    local tmp_err rc
    tmp_err=$(mktemp -t cl-err.XXXXXX)
    if claude --effort max "$@" 2>"$tmp_err"; then
        rc=0
    else
        rc=$?
    fi
    cat "$tmp_err" >&2

    # rate-limit 패턴 감지 → 해당 계정 마킹 + auto_pick 재선정 (self 제외) 1회 재시도
    if [ "$rc" -ne 0 ] && grep -qiE 'rate[- ]?limit|usage limit|quota|429|too many request' "$tmp_err" 2>/dev/null; then
        mark_rate_limit "$name"
        local next; next="$(auto_pick)"
        if [ -n "$next" ] && [ "$next" != "$name" ]; then
            echo "cl: rate-limit detected on $name → retry with $next" >&2
            rm -f "$tmp_err"
            local next_dir; next_dir=$(config_dir_for "$next")
            set_active "$next"
            export CLAUDE_CONFIG_DIR="$next_dir"
            exec claude --effort max "$@"
        fi
    fi
    rm -f "$tmp_err"
    return "$rc"
}

case "${1:-interactive}" in
    ""|interactive)  cmd_interactive ;;
    u|dashboard|list) show_dashboard ;;
    status)          show_status ;;
    pick)            shift || true; cmd_pick "${1:-}" ;;
    env)             cmd_env ;;
    --)              shift; cmd_passthrough "" "$@" ;;
    help|-h|--help)
        cat <<USAGE
cl — Claude Code multi-account launcher (nexus-managed)

Subcommands:
  cl                   대화형 픽커 → 선택 → claude 런칭 (비-tty면 cl u)
  cl u | list          대시보드만 (조회/스크립트용)
  cl status            요약
  cl pick [NAME]       active 전환만 (런칭 X). NAME 없으면 자동
  cl env               eval "\$(cl env)" → CLAUDE_CONFIG_DIR export
  cl help

Passthrough (타 프로젝트 자동화 용 — claude 대체재):
  cl -- <args>         auto-pick (limit 없는 최저 wk%) → claude "\$@"
  cl NAME -- <args>    NAME 계정으로 claude "\$@"

  예) cl -- -p "분석해줘"
      cl claude7 -- -p "..." --output-format json
  - 비-tty OK (파이프/스크립트 가능)
  - rate-limit 감지 시 해당 계정 error 마킹 + 다음 후보로 1회 재시도
  - 각 계정 CLAUDE_CONFIG_DIR 독립 → projects/memory 분리
    (장기 memory 공유 필요 시 별도 심링크, 현재 미제공)

대화형 키:
  ↑↓←→     커서 이동 (이동 후엔 "그 외 키" 추천 진입 비활성)
  Enter    커서 위치 선택
  1-9 / 0  번호 점프 (0 = 10번)
  q / ESC  취소
  그 외     active 가 쓸만하면 커서 유지, 아니면 * 계정으로 진입

표기:
  active=... (헤더)   현재 활성 계정
  *                   최선의 선택(auto-pick: 여유 있고 wk% 최저)
  >                   커서 위치

Store: $CL_HOME
USAGE
        ;;
    *)
        # 첫 인자가 accounts.json 에 있는 계정명이면 passthrough 로 처리
        # 사용법: cl NAME -- <claude args>   (또는 -- 생략도 허용)
        if account_exists "$1"; then
            name="$1"; shift
            [ "${1:-}" = "--" ] && shift || true
            cmd_passthrough "$name" "$@"
        else
            echo "ERROR(cl): unknown subcommand '$1' — 'cl help'" >&2; exit 64
        fi
        ;;
esac
