#!/bin/bash
# hexa-effect-map — Tier 3 annotation 통합 수집기 (grep MVP, v0.1)
#
# 입력:
#   hexa-effect-map <file.hexa> [<file2.hexa> ...]
#   hexa-effect-map --dir <directory>
#   hexa-effect-map [--kind effect|capability|ai|prove|refines] <files...>
#
# 출력 (stdout JSON):
#   { "version":"0.1", "source":"grep-mvp",
#     "annotations":[ {kind, fn, file, line, meta{...}} ],
#     "summary":{ effect, capability, ai, prove, refines, total } }
#
# 인식 annotation (fn decl 바로 위 라인, stacking 허용):
#   @effect(kind="io|net|state|time|rand")
#   @capability(cap="<name>")
#   @ai(hint="<text>")
#   @prove
#   @refines(pred="<expr>")
#
# exit 0 정상 (빈 annotations 포함). 1=인자 오류
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-effect-map [--kind effect|capability|ai|prove|refines] <file.hexa> [file2.hexa ...]
       hexa-effect-map [--kind ...] --dir <directory>
EOF
    exit 1
}

filter_kind=""
files=()

# parse args
while [ $# -gt 0 ]; do
    case "$1" in
        --kind)
            shift
            [ $# -ge 1 ] || usage
            case "$1" in
                effect|capability|ai|prove|refines) filter_kind="$1" ;;
                *) echo "ERROR: invalid kind: $1" >&2; usage ;;
            esac
            shift
            ;;
        --dir)
            shift
            [ $# -ge 1 ] || usage
            dir="$1"
            [ -d "$dir" ] || { echo "ERROR: directory not found: $dir" >&2; exit 1; }
            while IFS= read -r -d '' f; do files+=("$f"); done < <(find "$dir" -type f -not -path "*/.claude/*" -not -path "*/node_modules/*" -name "*.hexa" -print0)
            shift
            ;;
        -h|--help)
            usage
            ;;
        *)
            [ -f "$1" ] || { echo "ERROR: file not found: $1" >&2; exit 1; }
            files+=("$1")
            shift
            ;;
    esac
done

[ "${#files[@]}" -gt 0 ] || usage

# awk 엔진 — annotation 라인을 stage 하고 fn decl 에서 flush.
awk -v filter_kind="$filter_kind" '
function json_escape(s,   r) {
    r = s
    gsub(/\\/, "\\\\", r)
    gsub(/"/, "\\\"", r)
    gsub(/\t/, "\\t", r)
    gsub(/\r/, "\\r", r)
    gsub(/\n/, "\\n", r)
    return r
}
function extract_kv(line, key,    re, pos, rest, val, i, c) {
    # key="value" 또는 key=value (unquoted for bool/int)
    re = "[[:space:],(]" key "[[:space:]]*="
    pos = match(line, re)
    if (pos == 0) {
        re = "^@[a-z]+\\([[:space:]]*" key "[[:space:]]*="
        pos = match(line, re)
        if (pos == 0) return ""
    }
    rest = substr(line, pos + RLENGTH)
    sub(/^[[:space:]]+/, "", rest)
    if (substr(rest, 1, 1) == "\"") {
        val = ""
        i = 2
        while (i <= length(rest)) {
            c = substr(rest, i, 1)
            if (c == "\\" && i < length(rest)) {
                val = val substr(rest, i, 2)
                i += 2
                continue
            }
            if (c == "\"") break
            val = val c
            i++
        }
        gsub(/\\"/, "\"", val)
        gsub(/\\\\/, "\\", val)
        return val
    } else {
        if (match(rest, /[,)[:space:]]/)) {
            return substr(rest, 1, RSTART - 1)
        }
        return rest
    }
}
function extract_all_kv(line, kv_keys, kv_vals,    tmp, pos, rest, c, k, v, n, i, ch) {
    # 모든 key=value 쌍을 수집 — depth 1 only
    # strip leading @name( and trailing )
    n = 0
    delete kv_keys
    delete kv_vals
    tmp = line
    # find opening paren
    if (!match(tmp, /@[a-z]+\(/)) return 0
    tmp = substr(tmp, RSTART + RLENGTH)
    # strip trailing ) optional — we just scan forward
    while (1) {
        sub(/^[[:space:],]+/, "", tmp)
        if (length(tmp) == 0) break
        if (substr(tmp, 1, 1) == ")") break
        # key
        if (!match(tmp, /^[A-Za-z_][A-Za-z0-9_]*/)) break
        k = substr(tmp, 1, RLENGTH)
        tmp = substr(tmp, RLENGTH + 1)
        sub(/^[[:space:]]*=[[:space:]]*/, "", tmp)
        # value
        if (substr(tmp, 1, 1) == "\"") {
            v = ""
            i = 2
            while (i <= length(tmp)) {
                ch = substr(tmp, i, 1)
                if (ch == "\\" && i < length(tmp)) {
                    v = v substr(tmp, i, 2)
                    i += 2
                    continue
                }
                if (ch == "\"") break
                v = v ch
                i++
            }
            tmp = substr(tmp, i + 1)
            gsub(/\\"/, "\"", v)
            gsub(/\\\\/, "\\", v)
        } else {
            if (match(tmp, /[,)[:space:]]/)) {
                v = substr(tmp, 1, RSTART - 1)
                tmp = substr(tmp, RSTART)
            } else {
                v = tmp
                tmp = ""
            }
        }
        n++
        kv_keys[n] = k
        kv_vals[n] = v
    }
    return n
}

BEGIN {
    n_staged = 0
    total = 0
    cnt_effect = 0
    cnt_capability = 0
    cnt_ai = 0
    cnt_prove = 0
    cnt_refines = 0
}

{
    is_effect     = ($0 ~ /^[[:space:]]*@effect([[:space:]]*\(|[[:space:]]*$)/)
    is_capability = ($0 ~ /^[[:space:]]*@capability([[:space:]]*\(|[[:space:]]*$)/)
    is_ai         = ($0 ~ /^[[:space:]]*@ai([[:space:]]*\(|[[:space:]]*$)/)
    is_prove      = ($0 ~ /^[[:space:]]*@prove([[:space:]]*\(|[[:space:]]*$|[[:space:]]*\/\/|[[:space:]]*#)/)
    is_refines    = ($0 ~ /^[[:space:]]*@refines([[:space:]]*\(|[[:space:]]*$)/)
    is_anno = (is_effect || is_capability || is_ai || is_prove || is_refines)
    is_fn = ($0 ~ /^[[:space:]]*(pub[[:space:]]+)?fn[[:space:]]+[A-Za-z_][A-Za-z0-9_]*/)
    is_blank = ($0 ~ /^[[:space:]]*$/)
    is_comment = ($0 ~ /^[[:space:]]*(\/\/|#)/)
}

is_anno {
    line = $0
    kind = ""
    if (is_effect)          kind = "effect"
    else if (is_capability) kind = "capability"
    else if (is_ai)         kind = "ai"
    else if (is_prove)      kind = "prove"
    else if (is_refines)    kind = "refines"

    n_staged++
    staged_kind[n_staged] = kind
    staged_line[n_staged] = FNR
    staged_file[n_staged] = FILENAME

    # meta 수집 — depth 1 key=value
    delete kv_k
    delete kv_v
    nk = extract_all_kv(line, kv_k, kv_v)
    staged_nkv[n_staged] = nk
    for (i = 1; i <= nk; i++) {
        staged_k[n_staged, i] = kv_k[i]
        staged_v[n_staged, i] = kv_v[i]
    }
    next
}

is_fn && n_staged > 0 {
    # extract fn name
    fn_name = ""
    tmp = $0
    sub(/^[[:space:]]*(pub[[:space:]]+)?fn[[:space:]]+/, "", tmp)
    if (match(tmp, /^[A-Za-z_][A-Za-z0-9_]*/)) {
        fn_name = substr(tmp, 1, RLENGTH)
    }

    # emit each staged annotation (if filter matches)
    for (s = 1; s <= n_staged; s++) {
        k = staged_kind[s]
        if (filter_kind != "" && filter_kind != k) continue

        if (total > 0) printf ","
        total++
        if      (k == "effect")     cnt_effect++
        else if (k == "capability") cnt_capability++
        else if (k == "ai")         cnt_ai++
        else if (k == "prove")      cnt_prove++
        else if (k == "refines")    cnt_refines++

        printf "{"
        printf "\"kind\":\"%s\"", json_escape(k)
        printf ",\"fn\":\"%s\"", json_escape(fn_name)
        printf ",\"file\":\"%s\"", json_escape(staged_file[s])
        printf ",\"line\":%d", staged_line[s]
        printf ",\"meta\":{"
        nk = staged_nkv[s]
        for (i = 1; i <= nk; i++) {
            if (i > 1) printf ","
            printf "\"%s\":\"%s\"", json_escape(staged_k[s, i]), json_escape(staged_v[s, i])
        }
        printf "}"
        printf "}"
    }

    # reset staging
    for (s = 1; s <= n_staged; s++) {
        delete staged_kind[s]
        delete staged_line[s]
        delete staged_file[s]
        delete staged_nkv[s]
    }
    # wipe 2D
    for (key in staged_k) delete staged_k[key]
    for (key in staged_v) delete staged_v[key]
    n_staged = 0
    next
}

# blank breaks the block (discard staging unless followed by more annos)
(!is_anno && !is_fn && !is_comment) {
    if (n_staged > 0 && is_blank) {
        for (s = 1; s <= n_staged; s++) {
            delete staged_kind[s]
            delete staged_line[s]
            delete staged_file[s]
            delete staged_nkv[s]
        }
        for (key in staged_k) delete staged_k[key]
        for (key in staged_v) delete staged_v[key]
        n_staged = 0
    }
}

END {
    # write summary to side channel (via tmpfile below)
    printf "%d|%d|%d|%d|%d|%d\n", cnt_effect, cnt_capability, cnt_ai, cnt_prove, cnt_refines, total > "/dev/stderr"
}
' "${files[@]}" > /tmp/.hexa-effect-map.$$.body 2> /tmp/.hexa-effect-map.$$.summary

body="$(cat /tmp/.hexa-effect-map.$$.body 2>/dev/null || true)"
summary_line="$(cat /tmp/.hexa-effect-map.$$.summary 2>/dev/null || echo '0|0|0|0|0|0')"
rm -f /tmp/.hexa-effect-map.$$.body /tmp/.hexa-effect-map.$$.summary

IFS='|' read -r c_eff c_cap c_ai c_prove c_ref c_total <<< "$summary_line"

printf '{"version":"0.1","source":"grep-mvp","annotations":[%s],"summary":{"effect":%d,"capability":%d,"ai":%d,"prove":%d,"refines":%d,"total":%d}}\n' \
    "$body" "${c_eff:-0}" "${c_cap:-0}" "${c_ai:-0}" "${c_prove:-0}" "${c_ref:-0}" "${c_total:-0}"
