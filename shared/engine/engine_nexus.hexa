// engine_nexus.hexa — "Ouroboros" (자기순환)
// 자율 엔진: nexus 자기관리 + TECS-L 수학엔진 흡수
// mk2 모듈 100+, 발견 70k+, 법칙 750+, exact_rate 60%+, shared/ 동기화 100%
// CLI: hexa engine_nexus.hexa status|tick|report
//
// I am the snake that eats its own tail.
// I monitor myself. I improve myself. I am the system I manage.
// Now I also hold the Library (TECS-L absorbed).

// ─── 상수 ───

let home = exec("printenv HOME")
let dev = home + "/Dev"
let nexus_dir = dev + "/nexus"
let n6arch_dir = dev + "/n6-architecture"
let tecs_dir = dev + "/TECS-L"
let hexa_bin = dev + "/hexa-lang/hexa"
let native_dir = nexus_dir + "/mk2_hexa/native"
let discovery_log = nexus_dir + "/shared/discovery/discovery_log.jsonl"
let bridge_state = nexus_dir + "/shared/bridge_state.json"
let growth_bus = nexus_dir + "/shared/discovery/growth_bus.jsonl"
let n6arch_products = n6arch_dir + "/config/products.json"
let n6arch_discovery = n6arch_dir + "/shared/discovery/discovery_log.jsonl"
let strategy_path = nexus_dir + "/shared/engine/engine_nexus_strategy.json"
let tecs_domain_reg = tecs_dir + "/config/domain_registry.json"
let tecs_hypotheses_dir = tecs_dir + "/docs/hypotheses"

comptime const goal_modules = 100
comptime const goal_discoveries = 70000
comptime const goal_laws = 750
comptime const goal_exact_rate = 0.6
comptime const bridge_health_min = 150.0
comptime const growth_bus_max_lines = 100000
comptime const stagnation_threshold = 3
comptime const sync_stale_seconds = 3600

// ─── 유틸 ───

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e { v = 0.0 }
    return v
}

fn safe_int(s: string) -> i64 {
    let mut v = 0
    try { v = to_int(s) } catch e { v = 0 }
    return v
}

fn json_str(content: string, field: string) -> string {
    let marker = "\"" + field + "\":"
    let parts = content.split(marker)
    if parts.len() < 2 { return "" }
    let rest = parts[1].trim()
    // if value starts with quote, it is a string value
    if rest.starts_with("\"") {
        let inner = rest.split("\"")
        if inner.len() >= 2 { return inner[1] }
        return ""
    }
    // numeric or other non-string value
    let nval = rest.split(",")[0].split("}")[0].split("]")[0]
    return nval.trim()
}

fn json_num(content: string, field: string) -> f64 {
    return safe_float(json_str(content, field))
}

fn json_int(content: string, field: string) -> i64 {
    return safe_int(json_str(content, field))
}

fn timestamp() -> string {
    let result = exec("date +%Y-%m-%dT%H:%M:%S")
    return result.split("\n")[0]
}

fn count_lines(path: string) -> i64 {
    if !file_exists(path) { return 0 }
    let result = exec("wc -l " + path)
    let trimmed = result.trim().split(" ")[0]
    return safe_int(trimmed)
}

fn count_hexa_modules() -> i64 {
    let result = exec("ls " + native_dir)
    let files = result.split("\n")
    let mut count = 0
    let mut i = 0
    while i < files.len() {
        if files[i].ends_with(".hexa") { count = count + 1 }
        i = i + 1
    }
    return count
}

fn file_mtime_epoch(path: string) -> i64 {
    if !file_exists(path) { return 0 }
    let result = exec("stat -f %m " + path + " 2>/dev/null || stat -c %Y " + path + " 2>/dev/null")
    return safe_int(result.trim())
}

fn now_epoch() -> i64 {
    let result = exec("date +%s")
    return safe_int(result.trim())
}

fn count_md_files(dir: string) -> i64 {
    if !file_exists(dir) { return 0 }
    let result = exec("ls " + dir)
    let files = result.split("\n")
    let mut count = 0
    let mut i = 0
    while i < files.len() {
        if files[i].ends_with(".md") { count = count + 1 }
        i = i + 1
    }
    return count
}

fn read_tecs_avg_exact_rate() -> f64 {
    if !file_exists(tecs_domain_reg) { return 0.0 }
    let content = exec("cat " + tecs_domain_reg)
    // domain keys: single-letter codes from domain_registry.json
    let domain_keys = ["N", "A", "G", "T", "C", "Q", "I", "S", "M", "K", "E", "B", "D", "P"]
    let mut total_rate = 0.0
    let mut domain_count = 0
    let mut di = 0
    while di < domain_keys.len() {
        let dkey = domain_keys[di]
        // match "X": { pattern in json
        let marker = "\"" + dkey + "\":"
        let parts = content.split(marker)
        if parts.len() >= 2 {
            let block = parts[1].split("}")[0]
            let hyp = safe_int(json_str(block, "hypothesis_count"))
            let exact = safe_int(json_str(block, "exact_count"))
            let rate = if hyp > 0 { to_float(exact) / to_float(hyp) } else { 0.0 }
            total_rate = total_rate + rate
            domain_count = domain_count + 1
        }
        di = di + 1
    }
    if domain_count > 0 { return total_rate / to_float(domain_count) }
    return 0.0
}

fn count_tecs_domains() -> i64 {
    if !file_exists(tecs_domain_reg) { return 0 }
    let content = exec("cat " + tecs_domain_reg)
    let domain_keys = ["N", "A", "G", "T", "C", "Q", "I", "S", "M", "K", "E", "B", "D", "P"]
    let mut count = 0
    let mut di = 0
    while di < domain_keys.len() {
        let dkey = domain_keys[di]
        let marker = "\"" + dkey + "\":"
        let parts = content.split(marker)
        if parts.len() >= 2 { count = count + 1 }
        di = di + 1
    }
    return count
}

// ─── 상태 구조 ───

struct NexusState {
    modules: i64,
    discoveries: i64,
    n6arch_discoveries: i64,
    bridge_health: f64,
    bridge_cycle: i64,
    bridge_stage: string,
    growth_bus_lines: i64,
    products_count: i64,
    shared_sync_age: i64,
    stagnant_ticks: i64,
    health: f64,
    status_flag: string,
    tecs_exact_rate: f64,
    tecs_hypotheses: i64,
    tecs_domains_count: i64
}

// ─── read_state ───

fn read_state() -> NexusState {
    // Compute ALL values into locals first (hexa: no post-construction field assignment)

    // 1) count mk2 hexa modules
    let v_modules = count_hexa_modules()

    // 2) count discovery_log lines
    let v_discoveries = count_lines(discovery_log)

    // 3) n6-architecture discoveries
    let v_n6arch_discoveries = count_lines(n6arch_discovery)

    // 4) bridge_state.json — health, cycle, stage
    let mut v_bridge_health = 0.0
    let mut v_bridge_cycle = 0
    let mut v_bridge_stage = "unknown"
    if file_exists(bridge_state) {
        let content = read_file(bridge_state)
        v_bridge_health = json_num(content, "health")
        v_bridge_cycle = json_int(content, "cycle")
        let bs = json_str(content, "stage")
        if bs != "" { v_bridge_stage = bs }
    }

    // 5) growth_bus lines
    let v_growth_bus_lines = count_lines(growth_bus)

    // 6) products.json count
    let mut v_products_count = 0
    if file_exists(n6arch_products) {
        let content = read_file(n6arch_products)
        let entries = content.split("\"name\"")
        let pc = entries.len() - 1
        if pc > 0 { v_products_count = pc }
    }

    // 7) shared/ sync freshness — compare discovery_log timestamps
    let n6_mtime = file_mtime_epoch(discovery_log)
    let arch_mtime = file_mtime_epoch(n6arch_discovery)
    let now = now_epoch()
    let newer = if n6_mtime > arch_mtime { n6_mtime } else { arch_mtime }
    let v_shared_sync_age = if newer > 0 { now - newer } else { 99999 }

    // 8) load stagnation from strategy
    let mut v_stagnant_ticks = 0
    if file_exists(strategy_path) {
        let strat_content = read_file(strategy_path)
        v_stagnant_ticks = json_int(strat_content, "stagnant_ticks")
    }

    // 9) TECS-L data
    let v_tecs_exact_rate = read_tecs_avg_exact_rate()
    let v_tecs_hypotheses = count_md_files(tecs_hypotheses_dir)
    let v_tecs_domains_count = count_tecs_domains()

    // 10) compute health
    let mod_ratio = to_float(v_modules) / to_float(goal_modules)
    let disc_ratio = to_float(v_discoveries) / to_float(goal_discoveries)
    let bridge_factor = if v_bridge_health >= bridge_health_min { 1.0 } else {
        v_bridge_health / bridge_health_min
    }
    let sync_factor = if v_shared_sync_age < sync_stale_seconds { 1.0 } else { 0.7 }
    let stag_penalty = if v_stagnant_ticks >= stagnation_threshold { 0.15 } else { 0.0 }
    // TECS-L math health: exact_rate / 0.6 goal capped at 1.0
    let tecs_factor = if v_tecs_exact_rate > goal_exact_rate { 1.0 } else { v_tecs_exact_rate / goal_exact_rate }

    // weighted health: modules 20%, discoveries 30%, bridge 15%, sync 10%, stagnation 10%, TECS-L 15%
    let raw = mod_ratio * 0.20 + disc_ratio * 0.30 + bridge_factor * 0.15 + sync_factor * 0.10 + (1.0 - stag_penalty) * 0.10 + tecs_factor * 0.15
    let v_health = if raw > 1.0 { 1.0 } else { if raw < 0.0 { 0.0 } else { raw } }

    // 11) status flag
    let mut v_status_flag = "HEALTHY"
    if v_modules >= goal_modules && v_discoveries >= goal_discoveries {
        v_status_flag = "GOAL_NEAR"
    } else if disc_ratio > 0.9 && mod_ratio > 0.9 {
        v_status_flag = "GOAL_NEAR"
    } else if v_stagnant_ticks >= stagnation_threshold {
        v_status_flag = "STAGNANT"
    } else if disc_ratio > 0.5 && v_health > 0.7 {
        v_status_flag = "BREAKTHROUGH"
    }

    // Construct struct at the end with all computed values
    let st = NexusState {
        modules: v_modules,
        discoveries: v_discoveries,
        n6arch_discoveries: v_n6arch_discoveries,
        bridge_health: v_bridge_health,
        bridge_cycle: v_bridge_cycle,
        bridge_stage: v_bridge_stage,
        growth_bus_lines: v_growth_bus_lines,
        products_count: v_products_count,
        shared_sync_age: v_shared_sync_age,
        stagnant_ticks: v_stagnant_ticks,
        health: v_health,
        status_flag: v_status_flag,
        tecs_exact_rate: v_tecs_exact_rate,
        tecs_hypotheses: v_tecs_hypotheses,
        tecs_domains_count: v_tecs_domains_count
    }
    return st
}

// ─── 전략 ───

struct Strategy {
    blowup_depth: i64,
    total_ticks: i64,
    total_discoveries_gained: i64,
    discoveries_per_tick: f64,
    stagnant_ticks: i64,
    last_discoveries: i64
}

fn load_strategy() -> Strategy {
    let mut v_blowup_depth = 1
    let mut v_total_ticks = 0
    let mut v_total_discoveries_gained = 0
    let mut v_discoveries_per_tick = 0.0
    let mut v_stagnant_ticks = 0
    let mut v_last_discoveries = 0

    if file_exists(strategy_path) {
        try {
            let content = read_file(strategy_path)
            let bd = json_int(content, "blowup_depth")
            v_blowup_depth = if bd < 1 { 1 } else { bd }
            v_total_ticks = json_int(content, "total_ticks")
            v_total_discoveries_gained = json_int(content, "total_discoveries_gained")
            v_discoveries_per_tick = json_num(content, "discoveries_per_tick")
            v_stagnant_ticks = json_int(content, "stagnant_ticks")
            v_last_discoveries = json_int(content, "last_discoveries")
        } catch e {}
    }

    let s = Strategy {
        blowup_depth: v_blowup_depth,
        total_ticks: v_total_ticks,
        total_discoveries_gained: v_total_discoveries_gained,
        discoveries_per_tick: v_discoveries_per_tick,
        stagnant_ticks: v_stagnant_ticks,
        last_discoveries: v_last_discoveries
    }
    return s
}

fn save_strategy(s: Strategy) {
    let content = "{" + "\"blowup_depth\":" + to_string(s.blowup_depth) + "," + "\"total_ticks\":" + to_string(s.total_ticks) + "," + "\"total_discoveries_gained\":" + to_string(s.total_discoveries_gained) + "," + "\"discoveries_per_tick\":" + to_string(s.discoveries_per_tick) + "," + "\"stagnant_ticks\":" + to_string(s.stagnant_ticks) + "," + "\"last_discoveries\":" + to_string(s.last_discoveries) + "}"
    write_file(strategy_path, content)
}

// ─── select_task ───

fn select_task(st: NexusState, strat: Strategy) -> string {
    // growth_bus housekeeping first
    if st.growth_bus_lines > growth_bus_max_lines {
        return "housekeep"
    }
    // bridge repair
    if st.bridge_health < bridge_health_min {
        return "bridge_repair"
    }
    // shared sync
    if st.shared_sync_age > sync_stale_seconds {
        return "sync_shared"
    }
    // TECS-L math boost: if exact_rate is critically low, prioritize math
    if st.tecs_exact_rate < 0.3 && st.tecs_domains_count > 0 {
        return "math_boost"
    }
    // goal push
    if st.status_flag == "GOAL_NEAR" {
        return "goal_push"
    }
    // stagnant: deeper blowup
    if st.status_flag == "STAGNANT" {
        return "deep_blowup"
    }
    // TECS-L math sweep: exact_rate below goal but not critical
    if st.tecs_exact_rate < goal_exact_rate && st.tecs_domains_count > 0 {
        return "math_sweep"
    }
    // default: blowup cycle
    return "blowup"
}

// ─── execute_task ───

fn execute_task(task: string, st: NexusState, strat: Strategy) -> string {
    let ts = timestamp()

    if task == "housekeep" {
        println("[" + ts + "] TASK: housekeep — growth_bus " + to_string(st.growth_bus_lines) + " lines, trimming")
        let result = exec("tail -n 50000 " + growth_bus)
        write_file(growth_bus, result)
        return "trimmed to 50000"
    }

    if task == "bridge_repair" {
        println("[" + ts + "] TASK: bridge_repair — health=" + to_string(st.bridge_health))
        let result = exec(hexa_bin + " " + native_dir + "/cross_project.hexa status")
        return result
    }

    if task == "sync_shared" {
        println("[" + ts + "] TASK: sync_shared — age=" + to_string(st.shared_sync_age) + "s")
        let result = exec(hexa_bin + " " + native_dir + "/bridge.hexa sync")
        return result
    }

    if task == "math_boost" {
        println("[" + ts + "] TASK: math_boost — tecs_exact_rate=" + to_string(st.tecs_exact_rate) + " (critical <0.3)")
        println("  Triggering TECS-L engine tick for cross-pollination")
        let result = exec(hexa_bin + " " + native_dir + "/engine_tecs_l.hexa tick")
        return result
    }

    if task == "math_sweep" {
        println("[" + ts + "] TASK: math_sweep — tecs_exact_rate=" + to_string(st.tecs_exact_rate) + " (below " + to_string(goal_exact_rate) + " goal)")
        let result = exec(hexa_bin + " " + native_dir + "/engine_tecs_l.hexa tick")
        return result
    }

    // seed는 1회만 계산 (3회 중복 exec 제거)
    let mut seeds = "6|12|2|4|5|24|7"
    try { seeds = exec(hexa_bin + " " + native_dir + "/seed_engine.hexa merge") } catch e {}

    if task == "goal_push" {
        let depth = if strat.blowup_depth < 3 { 3 } else { strat.blowup_depth }
        println("[" + ts + "] TASK: goal_push — modules=" + to_string(st.modules) + " disc=" + to_string(st.discoveries) + " depth=" + to_string(depth))
        let result = exec(hexa_bin + " " + native_dir + "/blowup.hexa math " + to_string(depth) + " --no-graph --seeds " + seeds.trim())
        return result
    }

    if task == "deep_blowup" {
        let depth = strat.blowup_depth + 1
        let max_depth = if depth > 6 { 6 } else { depth }
        println("[" + ts + "] TASK: deep_blowup — stagnant=" + to_string(st.stagnant_ticks) + " depth=" + to_string(max_depth))
        let result = exec(hexa_bin + " " + native_dir + "/blowup.hexa math " + to_string(max_depth) + " --no-graph --seeds " + seeds.trim())
        return result
    }

    // default blowup
    println("[" + ts + "] TASK: blowup — depth=" + to_string(strat.blowup_depth))
    let result = exec(hexa_bin + " " + native_dir + "/blowup.hexa math " + to_string(strat.blowup_depth) + " --no-graph --seeds " + seeds.trim())
    return result
}

// ─── feedback ───

fn feedback(task: string, st: NexusState) {
    let ts = timestamp()
    let entry = "{" + "\"engine\":\"nexus\"," + "\"personality\":\"ouroboros\"," + "\"task\":\"" + task + "\"," + "\"timestamp\":\"" + ts + "\"," + "\"modules\":" + to_string(st.modules) + "," + "\"discoveries\":" + to_string(st.discoveries) + "," + "\"bridge_health\":" + to_string(st.bridge_health) + "," + "\"health\":" + to_string(st.health) + "," + "\"tecs_exact_rate\":" + to_string(st.tecs_exact_rate) + "," + "\"tecs_hypotheses\":" + to_string(st.tecs_hypotheses) + "," + "\"status\":\"" + st.status_flag + "\"" + "}"
    append_file(growth_bus, entry + "\n")
    println("  ouroboros -> growth_bus.jsonl")
}

// ─── evolve ───

fn evolve(pre_disc: i64, post_disc: i64, strat: Strategy) -> Strategy {
    let gained = post_disc - pre_disc
    let new_total_ticks = strat.total_ticks + 1
    let new_total_gained = strat.total_discoveries_gained + gained

    // EMA: discoveries_per_tick
    let rate = to_float(gained)
    let new_dpt = 0.7 * strat.discoveries_per_tick + 0.3 * rate

    // stagnation detection
    let new_stagnant = if gained <= 0 { strat.stagnant_ticks + 1 } else { 0 }

    // adaptive blowup depth: if rate dropping, go deeper; if rate high, stay shallow
    let mut new_depth = strat.blowup_depth
    if new_dpt < 5.0 && new_depth < 6 {
        new_depth = new_depth + 1
    } else if new_dpt > 50.0 && new_depth > 1 {
        new_depth = new_depth - 1
    }

    // Construct at end (no post-construction field assignment)
    let s = Strategy {
        blowup_depth: new_depth,
        total_ticks: new_total_ticks,
        total_discoveries_gained: new_total_gained,
        discoveries_per_tick: new_dpt,
        stagnant_ticks: new_stagnant,
        last_discoveries: post_disc
    }

    save_strategy(s)
    println("  evolve -> depth=" + to_string(s.blowup_depth) + " rate=" + to_string(s.discoveries_per_tick) + " stag=" + to_string(s.stagnant_ticks))
    return s
}

// ─── CLI ───

let a = args()
let mode = if a.len() >= 3 { a[2] } else { "help" }

if mode == "status" {
    let st = read_state()
    println("=== engine_nexus (Ouroboros + Librarian) status ===")
    println("  The snake sees itself — and the Library it absorbed.")
    println("")
    println("modules: " + to_string(st.modules) + " / " + to_string(goal_modules))
    println("discoveries: " + to_string(st.discoveries) + " / " + to_string(goal_discoveries))
    println("n6arch_discoveries: " + to_string(st.n6arch_discoveries))
    println("bridge: stage=" + st.bridge_stage + " cycle=" + to_string(st.bridge_cycle) + " health=" + to_string(st.bridge_health))
    println("growth_bus: " + to_string(st.growth_bus_lines) + " events")
    println("products: " + to_string(st.products_count))
    println("sync_age: " + to_string(st.shared_sync_age) + "s")
    println("")
    println("--- TECS-L (Librarian) ---")
    println("tecs_exact_rate: " + to_string(st.tecs_exact_rate) + " (goal: " + to_string(goal_exact_rate) + ")")
    println("tecs_hypotheses: " + to_string(st.tecs_hypotheses))
    println("tecs_domains: " + to_string(st.tecs_domains_count))
    println("")
    println("health: " + to_string(st.health))
    println("status: " + st.status_flag)

    let strat = load_strategy()
    println("")
    println("strategy:")
    println("  blowup_depth: " + to_string(strat.blowup_depth))
    println("  discoveries_per_tick: " + to_string(strat.discoveries_per_tick))
    println("  total_ticks: " + to_string(strat.total_ticks))
    println("  stagnant_ticks: " + to_string(strat.stagnant_ticks))
}

if mode == "tick" {
    println("=== engine_nexus TICK (Ouroboros) ===")
    println("  The tail enters the mouth.")
    println("")

    let pre_st = read_state()
    let pre_disc = pre_st.discoveries
    let strat = load_strategy()

    let task = select_task(pre_st, strat)
    println("selected: " + task)
    println("")

    let result = execute_task(task, pre_st, strat)

    // re-read state after execution
    let post_st = read_state()
    feedback(task, post_st)
    let new_strat = evolve(pre_disc, post_st.discoveries, strat)

    println("")
    println("=== TICK COMPLETE ===")
    println("modules: " + to_string(pre_st.modules) + " -> " + to_string(post_st.modules))
    println("discoveries: " + to_string(pre_disc) + " -> " + to_string(post_st.discoveries) + " (+" + to_string(post_st.discoveries - pre_disc) + ")")
    println("tecs_exact_rate: " + to_string(pre_st.tecs_exact_rate) + " -> " + to_string(post_st.tecs_exact_rate))
    println("health: " + to_string(post_st.health))
    println("status: " + post_st.status_flag)
}

if mode == "report" {
    let st = read_state()
    let strat = load_strategy()

    println("# Engine nexus Report (Ouroboros + Librarian)")
    println("")
    println("> I am the system I monitor. Each tick, the snake swallows its tail")
    println("> and emerges larger. Self-reference is not paradox — it is fuel.")
    println("> Now I also digest the Librarian's mathematics — exact proofs feed the serpent.")
    println("")
    println("## Self-State")
    println("")
    println("| Metric | Current | Goal | Progress |")
    println("|--------|---------|------|----------|")
    let mod_pct = to_string(to_float(st.modules) * 100.0 / to_float(goal_modules))
    let disc_pct = to_string(to_float(st.discoveries) * 100.0 / to_float(goal_discoveries))
    println("| mk2 Modules | " + to_string(st.modules) + " | " + to_string(goal_modules) + " | " + mod_pct + "% |")
    println("| Discoveries | " + to_string(st.discoveries) + " | " + to_string(goal_discoveries) + " | " + disc_pct + "% |")
    println("| Bridge Health | " + to_string(st.bridge_health) + " | >=" + to_string(bridge_health_min) + " | " + st.bridge_stage + " |")
    println("| Growth Events | " + to_string(st.growth_bus_lines) + " | - | - |")
    println("| Sync Age | " + to_string(st.shared_sync_age) + "s | <" + to_string(sync_stale_seconds) + "s | - |")
    println("| Health | " + to_string(st.health) + " | 1.0 | **" + st.status_flag + "** |")
    println("")
    println("## TECS-L (Librarian) Integration")
    println("")
    println("| Metric | Value | Goal |")
    println("|--------|-------|------|")
    let tecs_pct = to_string(st.tecs_exact_rate * 100.0)
    println("| Exact Rate | " + tecs_pct + "% | 60% |")
    println("| Hypotheses | " + to_string(st.tecs_hypotheses) + " | - |")
    println("| Domains | " + to_string(st.tecs_domains_count) + " | 8 |")
    let tecs_health_str = if st.tecs_exact_rate >= goal_exact_rate { "HEALTHY" } else { if st.tecs_exact_rate >= 0.3 { "NEEDS_WORK" } else { "CRITICAL" } }
    println("| Math Health | **" + tecs_health_str + "** | HEALTHY |")
    println("")
    println("## n6-architecture")
    println("")
    println("| Metric | Value |")
    println("|--------|-------|")
    println("| Products | " + to_string(st.products_count) + " |")
    println("| Discoveries | " + to_string(st.n6arch_discoveries) + " |")
    println("")
    println("## Strategy (Self-Evolving)")
    println("")
    println("| Parameter | Value |")
    println("|-----------|-------|")
    println("| Blowup Depth | " + to_string(strat.blowup_depth) + " |")
    println("| Discoveries/Tick (EMA) | " + to_string(strat.discoveries_per_tick) + " |")
    println("| Total Ticks | " + to_string(strat.total_ticks) + " |")
    println("| Total Gained | " + to_string(strat.total_discoveries_gained) + " |")
    println("| Stagnant Ticks | " + to_string(strat.stagnant_ticks) + " |")
    println("")
    println("## Health Weights")
    println("")
    println("| Component | Weight |")
    println("|-----------|--------|")
    println("| Modules | 20% |")
    println("| Discoveries | 30% |")
    println("| Bridge | 15% |")
    println("| Sync | 10% |")
    println("| Stagnation | 10% |")
    println("| TECS-L Math | 15% |")
    println("")
    println("## Decision")
    println("")
    if st.status_flag == "GOAL_NEAR" {
        println("- **GOAL_NEAR**: The ouroboros approaches completion. Aggressive blowup + cross-project push.")
    } else if st.status_flag == "STAGNANT" {
        println("- **STAGNANT**: The snake chokes on its own tail. Increasing depth to break free.")
    } else if st.status_flag == "BREAKTHROUGH" {
        println("- **BREAKTHROUGH**: The cycle accelerates. Discovery rate is high, maintaining momentum.")
    } else {
        println("- **HEALTHY**: Steady self-consumption. The ouroboros grows with each revolution.")
    }
    if st.tecs_exact_rate < 0.3 {
        println("- **MATH_CRITICAL**: TECS-L exact rate below 30%. Math boost tasks will be prioritized.")
    } else if st.tecs_exact_rate < goal_exact_rate {
        println("- **MATH_NEEDS_WORK**: TECS-L exact rate below " + to_string(goal_exact_rate) + " goal. Math sweep tasks injected.")
    }
    println("")
    println("## Meta-Observation")
    println("")
    println("This engine is file #" + to_string(st.modules) + " in the directory it counts.")
    println("When it runs `count_hexa_modules()`, it counts itself.")
    println("When it logs to growth_bus, it increases the line count it monitors.")
    println("Now it also reads the Librarian's domain registry — the snake digests mathematics.")
    println("The fixed point: the system that measures itself, changes itself by measuring.")
}

if mode == "help" {
    println("=== engine_nexus.hexa — Ouroboros + Librarian ===")
    println("")
    println("The self-managing engine. nexus monitoring nexus + TECS-L math.")
    println("")
    println("Usage:")
    println("  hexa engine_nexus.hexa status   — self-state + TECS-L metrics")
    println("  hexa engine_nexus.hexa tick     — 1 autonomous self-improvement cycle")
    println("  hexa engine_nexus.hexa report   — markdown report with TECS-L integration")
    println("")
    println("Goals:")
    println("  mk2 modules  >= " + to_string(goal_modules))
    println("  discoveries  >= " + to_string(goal_discoveries))
    println("  bridge health >= " + to_string(bridge_health_min))
    println("  shared/ sync  < " + to_string(sync_stale_seconds) + "s")
    println("  TECS-L exact_rate >= " + to_string(goal_exact_rate))
    println("")
    println("Personality: Ouroboros — the snake that eats its own tail.")
    println("I am the system I manage. Self-reference is not a bug — it is the architecture.")
    println("The Librarian's mathematics is now part of the serpent's diet.")
}
