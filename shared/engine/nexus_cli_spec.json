{
  "_meta": {
    "name": "nexus-cli SSOT spec",
    "description": "외부 프로젝트(hive 등) 전용 단일 CLI 진입점 — subcommand/flags/exit codes/json schema",
    "version": "0.2.1",
    "schema_version": "2",
    "updated": "2026-04-20",
    "entry": "shared/bin/nexus-cli",
    "engine": "shared/engine/nexus_cli.hexa",
    "runtime": "hexa",
    "related": ["run.hexa", "hive.json", "shared/roadmaps/drill_dod.json"],
    "remote_routing": {
      "_note": "Heavy-compute subcommands force-route to remote via shared/scripts/bin/hexa (Mac stage0 SIGKILL avoidance). Override: HEXA_LOCAL=1.",
      "heavy_compute": ["drill", "smash", "free", "absolute", "meta-closure", "hyperarithmetic"],
      "resolver": "shared/scripts/bin/hexa (remote_eligible())"
    }
  },
  "projects": [
    "nexus",
    "anima",
    "n6-architecture",
    "papers",
    "hexa-lang",
    "void",
    "airgenome"
  ],
  "project_paths": {
    "_ssot": "shared/config/projects.json readme_order",
    "roadmap_dir": "shared/roadmaps",
    "convergence_dir": "shared/convergence",
    "state_dir": "shared/state",
    "resolution": {
      "roadmap": "$NEXUS/shared/roadmaps/<project>.json",
      "convergence": "$NEXUS/shared/convergence/<project>.json",
      "fallback": "project-local roadmap/convergence 가 nexus 에 없으면 404"
    }
  },
  "env": {
    "NEXUS": { "desc": "nexus 루트 디렉토리", "default": "$HOME/Dev/nexus" },
    "HEXA": { "desc": "hexa 바이너리 경로 (미지정 시 shared/bin/hexa resolver)", "default": "" }
  },
  "global_flags": {
    "--json": { "type": "bool", "default": false, "desc": "기계 파싱용 JSON stdout (default=pretty)" },
    "--caller": { "type": "string", "default": "", "desc": "외부 호출자 식별 (예: hive). audit log 기록" },
    "--catalog": { "type": "bool", "default": false, "desc": "spec sidecar (이 파일) stdout 덤프 — subcmd 전에 분기. hive 등 dynamic loader 용" },
    "--help": { "type": "bool", "desc": "서브커맨드 도움말" },
    "-h": { "alias": "--help" }
  },
  "exit_codes": {
    "0": "성공",
    "1": "실행 오류 (엔진 실패, 내부 오류)",
    "2": "인자 오류 (unknown subcommand, missing required flag)",
    "3": "gate 거부 (harness violation, cmd_gate REJECT)"
  },
  "audit": {
    "log_path": "shared/logs/nexus_cli.log",
    "format": "jsonl",
    "fields": ["ts", "caller", "subcmd", "args", "exit_code", "duration_ms"]
  },
  "subcommands": {
    "thinking": {
      "desc": "anima 6-phase reflection",
      "usage": "nexus-cli thinking --query \"...\" [--depth 6] [--json]",
      "flags": {
        "--query": { "type": "string", "required": true, "desc": "질의 텍스트" },
        "--depth": { "type": "int", "default": 6, "desc": "reflection 깊이 (1-12)" }
      },
      "delegates_to": "entry.hexa thinking query <query>",
      "output_json": { "query": "string", "depth": "int", "phases": "[object]", "result": "string" }
    },
    "smash": {
      "desc": "blowup 9-phase 특이점 돌파",
      "usage": "nexus-cli smash (--seed \"...\" | --batch \"s1|s2|...\") [--depth 3] [--seeds \"s1,s2,...|auto\"] [--json]",
      "flags": {
        "--seed": { "type": "string", "required": false, "desc": "돌파 시드 텍스트 (single 모드). --batch 와 상호배타" },
        "--batch": { "type": "string", "required": false, "desc": "`|` 구분 N seed 일괄 발사 (1 dispatch, bash 기동 1회). seed_engine 풀 amortize" },
        "--depth": { "type": "int", "default": 3, "desc": "돌파 깊이" },
        "--seeds": { "type": "string", "required": false, "desc": "blowup.hexa passthrough (seed_engine crossover 보강). 값 `auto` 시 seed_engine merge 자동 주입 — bash SSOT 완전 parity" }
      },
      "modes": {
        "single": "nexus-cli smash --seed \"target\" [--seeds \"s1,s2\"|auto]",
        "batch":  "nexus-cli smash --batch \"t1|t2|t3\" [--seeds auto] — startup amortize"
      },
      "delegates_to": "exec_validated smash <seed> blowup.hexa <depth> [--seeds <v>]",
      "gate": "cmd_gate.hexa",
      "remote_routing": true,
      "output_json": { "seed": "string", "depth": "int", "result": "string", "exit_code": "int" }
    },
    "free": {
      "desc": "compose 5-module DFS 탐색",
      "usage": "nexus-cli free (--seed \"...\" | --batch \"s1|s2|...\") [--dfs 3] [--json]",
      "flags": {
        "--seed": { "type": "string", "required": false, "desc": "DFS 시드 (single). --batch 와 상호배타" },
        "--batch": { "type": "string", "required": false, "desc": "`|` 구분 N seed 일괄 DFS 발사 (1 dispatch)" },
        "--dfs": { "type": "int", "default": 3, "desc": "DFS 재귀 깊이" }
      },
      "delegates_to": "exec_validated free_dfs <seed> compose.hexa --modules all --dfs <dfs>",
      "gate": "cmd_gate.hexa",
      "remote_routing": true,
      "output_json": { "seed": "string", "dfs": "int", "result": "string", "exit_code": "int" }
    },
    "absolute": {
      "desc": "Mk.VIII Δ₀-absolute Π₀¹ 검증 — arithmetical discovery 자동 [10*]→[11*] 승급",
      "usage": "nexus-cli absolute [--seed \"...\"] [--json]",
      "flags": {
        "--seed": { "type": "string", "required": false, "desc": "검증 대상 seed (없으면 atlas 전체 스캔)" }
      },
      "delegates_to": "exec_validated absolute <seed> blowup_absolute.hexa",
      "gate": "cmd_gate.hexa",
      "remote_routing": true,
      "output_json": { "seed": "string", "pi01_pass": "bool", "promoted": "[string]", "exit_code": "int" }
    },
    "drill": {
      "desc": "단일 명령어 사슬 — smash → free → absolute → meta-closure → hyperarithmetic → resonance (Mk.IX 6-stage), 고갈까지 자율 반복",
      "usage": "nexus-cli drill --seed \"...\" [--max-rounds 10] [--json]",
      "flags": {
        "--seed": { "type": "string", "required": true, "desc": "사슬 진입 seed" },
        "--max-rounds": { "type": "int", "default": 10, "desc": "최대 라운드 수 (수렴 안 될 시 강제 종료)" }
      },
      "delegates_to": "run.hexa cmd_drill → loop { smash + free_dfs + absolute + meta_closure + hyperarithmetic + resonance }",
      "gate": "cmd_gate.hexa",
      "saturation": "round_new == 0 → SATURATED — Δ₀-absolute 경험적 확증",
      "dod": "shared/roadmaps/drill_dod.json (yield ratio tier: scaffold/wired/serving)",
      "remote_routing": true,
      "output_json": { "seed": "string", "rounds": "int", "total_absorptions": "int", "saturated": "bool" }
    },
    "meta-closure": {
      "desc": "Phase 10 Meta-Closure 단일 실행 — 🛸16 self-ref 고정점 검증 + [10**] 승급",
      "usage": "nexus-cli meta-closure [--seed \"...\"] [--json]",
      "flags": {
        "--seed": { "type": "string", "required": false, "desc": "역추적 대상 seed (없으면 최근 라운드)" }
      },
      "delegates_to": "exec_validated meta_closure <seed> blowup_meta_closure.hexa",
      "gate": "cmd_gate.hexa",
      "remote_routing": true,
      "output_json": { "seed": "string", "meta_closed": "int", "promoted_10ss": "int", "rejected_h1": "int", "rejected_h2": "int", "rejected_h3": "int" }
    },
    "hyperarithmetic": {
      "desc": "Mk.IX Π₀² reverse-math 판정 — 5체계 (RCA₀/WKL₀/ACA₀/ATR₀/Π¹₁-CA₀) cross-check",
      "usage": "nexus-cli hyperarithmetic --prop \"...\" [--json]",
      "flags": {
        "--prop": { "type": "string", "required": true, "desc": "판정 대상 Π₀² 명제 원문" }
      },
      "delegates_to": "exec_validated hyperarithmetic <prop> blowup_hyperarithmetic.hexa",
      "gate": "cmd_gate.hexa",
      "remote_routing": true,
      "output_json": { "prop": "string", "pi02": "bool", "reduced_pi01": "bool", "reverse_math": "string", "n6_invariant": "bool" }
    },
    "promote": {
      "desc": "수동 등급 승급 — [12*] 는 자동 금지, 감사 로그 필수",
      "usage": "nexus-cli promote --id <ID> --grade <10star|10starstar|11star|12star> --audit-log \"<reason>\"",
      "flags": {
        "--id": { "type": "string", "required": true, "desc": "atlas entry id" },
        "--grade": { "type": "string", "required": true, "enum": ["10star", "10starstar", "11star", "12star"] },
        "--audit-log": { "type": "string", "required": true, "desc": "승급 사유 (shared/blowup/audit/ 저장)" }
      },
      "delegates_to": "atlas_health.hexa promote_grade",
      "gate": "cmd_gate.hexa",
      "output_json": { "id": "string", "from_grade": "string", "to_grade": "string", "audit_path": "string" }
    },
    "lens": {
      "desc": "렌즈 검색/조회",
      "usage": "nexus-cli lens --query \"...\" [--top 5] [--json]",
      "flags": {
        "--query": { "type": "string", "required": true, "desc": "렌즈 검색 키워드" },
        "--top": { "type": "int", "default": 5, "desc": "상위 N개 반환" }
      },
      "delegates_to": "lens_registry.json grep + lens_forge.hexa",
      "output_json": { "query": "string", "top": "int", "matches": "[{id,name,domain,score}]", "total": "int" }
    },
    "atlas": {
      "desc": "atlas.n6 검색/추가",
      "subcommands": {
        "search": {
          "usage": "nexus-cli atlas search \"...\" [--limit 10] [--json]",
          "flags": {
            "--limit": { "type": "int", "default": 10 }
          },
          "delegates_to": "atlas_health.hexa search <query>"
        },
        "append": {
          "usage": "nexus-cli atlas append --node <json> | --edge <json> [--json]",
          "flags": {
            "--node": { "type": "string", "desc": "노드 JSON" },
            "--edge": { "type": "string", "desc": "엣지 JSON" }
          },
          "delegates_to": "atlas_health.hexa append"
        }
      },
      "output_json": { "action": "string", "results": "[object]", "count": "int" }
    },
    "discovery": {
      "desc": "discovery_log SQLite 쿼리",
      "subcommands": {
        "query": {
          "usage": "nexus-cli discovery query \"...\" [--json]",
          "delegates_to": "discovery_query.hexa"
        }
      },
      "output_json": { "query": "string", "results": "[object]", "count": "int" }
    },
    "roadmap": {
      "desc": "로드맵 조회",
      "subcommands": {
        "list": {
          "usage": "nexus-cli roadmap list [--project nexus] [--json]",
          "flags": { "--project": { "type": "string", "default": "nexus" } },
          "delegates_to": "entry.hexa roadmap list --project <project>"
        },
        "status": {
          "usage": "nexus-cli roadmap status [--project nexus] [--json]",
          "flags": { "--project": { "type": "string", "default": "nexus" } },
          "delegates_to": "entry.hexa roadmap status --project <project>"
        }
      },
      "output_json": { "project": "string", "phase": "string", "tasks": "[object]" }
    },
    "bus": {
      "desc": "이벤트 버스 (향후 hive bus 연결)",
      "subcommands": {
        "publish": {
          "usage": "nexus-cli bus publish --topic <t> --payload <json> [--json]",
          "flags": {
            "--topic": { "type": "string", "required": true },
            "--payload": { "type": "string", "required": true }
          },
          "delegates_to": "entry.hexa broadcast append"
        },
        "tail": {
          "usage": "nexus-cli bus tail [--limit 20] [--json]",
          "flags": { "--limit": { "type": "int", "default": 20 } },
          "delegates_to": "entry.hexa broadcast tail"
        },
        "history": {
          "usage": "nexus-cli bus history [--limit 50] [--json]",
          "flags": { "--limit": { "type": "int", "default": 50 } },
          "delegates_to": "entry.hexa broadcast list"
        }
      },
      "output_json": { "action": "string", "events": "[object]", "count": "int" }
    },
    "status": {
      "desc": "harness/loop/cl pool 전체 헬스 (인자 없음) — 프로젝트별은 status-proj",
      "usage": "nexus-cli status [--json]",
      "delegates_to": "entry.hexa self_check + entry.hexa health all",
      "output_json": { "harness": "object", "health": "object", "version": "string" }
    },
    "version": {
      "desc": "버전 출력",
      "usage": "nexus-cli version",
      "output": "nexus-cli 0.2.0"
    }
  },
  "subcmds_v2": {
    "_intro": "schema_version 2 — 7 프로젝트 일관 접근. projects[] 검증 + write 금지 + audit log.",
    "status-proj": {
      "desc": "프로젝트 건강지표 요약 (read-only)",
      "usage": "nexus-cli status-proj <project> [--json] [--caller X]",
      "positional": {
        "project": { "required": true, "enum_ref": "projects" }
      },
      "reads": [
        "shared/roadmaps/<project>.json (_meta + tracks keys)",
        "shared/convergence/<project>.json (optional)"
      ],
      "writes": [],
      "output_json": {
        "project": "string",
        "roadmap_exists": "bool",
        "convergence_exists": "bool",
        "roadmap_meta": "object",
        "track_count": "int",
        "total_tasks": "int|null",
        "updated": "string|null"
      },
      "exit": "0 on any project; 2 if project not in projects[]"
    },
    "roadmap-proj": {
      "desc": "프로젝트 로드맵 조회 (write 금지, next|list 전용)",
      "usage": "nexus-cli roadmap-proj <project> [next|list] [--json]",
      "positional": {
        "project": { "required": true, "enum_ref": "projects" },
        "action": { "required": false, "default": "list", "enum": ["next", "list"] }
      },
      "reads": ["shared/roadmaps/<project>.json"],
      "writes": [],
      "delegates_to": "entry.hexa roadmap <action> --project <project>",
      "output_json": { "project": "string", "action": "string", "result": "string" }
    },
    "convergence-proj": {
      "desc": "프로젝트 수렴 지표 스냅샷 (read-only)",
      "usage": "nexus-cli convergence-proj <project> [--json]",
      "positional": {
        "project": { "required": true, "enum_ref": "projects" }
      },
      "reads": ["shared/convergence/<project>.json"],
      "writes": [],
      "output_json": {
        "project": "string",
        "convergence_exists": "bool",
        "snapshot": "object|null"
      }
    }
  },
  "v2_invariants": [
    "hexa-only — bash 래퍼는 shared/bin/nexus-cli thin delegator",
    "projects[] 의 7개 프로젝트만 허용. 미지 프로젝트 exit 2",
    "모든 v2 subcmd 는 read-only. atlas append/bus publish 는 v1 전용",
    "audit log (shared/logs/nexus_cli.log) caller + subcmd + positional args 필수 기록",
    "파일명 버전 suffix 금지 — schema_version 필드로 진화 표현"
  ],
  "security": {
    "sanitize": "seed/query 에 shell metacharacter (; | & $ ` \\ \" ' < > ( ) { } ! # ~ 개행) 포함 시 strip 또는 escape",
    "caller_audit": "--caller 값은 audit log에 기록, 미지정 시 'unknown'",
    "gate_enforcement": "smash/free 는 cmd_gate.hexa 통과 필수, REJECT 시 exit 3 + stderr 이유"
  }
}
