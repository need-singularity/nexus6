// atlas_x_laws_weighted.hexa — weighted alignment + bootstrap CI for atlas_x_laws
// Extends atlas_x_laws_aligned.hexa (lag only) with:
//   A. Gaussian kernel smoothing (σ=1, window ±2) on lag-aligned B to close sparse-bin gaps
//   B. Bootstrap CI (1000 samples) with Poisson-like bin-count perturbation
//      → CI95 band for composite. CI_lower > 0.9 ⇒ paper_trigger,
//        upper > 0.9 and mean in [0.85, 0.9) ⇒ marginal_paper_trigger.
// Reuses /tmp/.bs_const_pc.jsonl + spectra/g_atlas_paircorr.jsonl (from atlas_x_laws runs).
// Output:
//   cross/atlas_x_laws_weighted_verdict.json
//   discovery/bisociation_atlas_x_laws_weighted_2026-04-14.json
//   (paper_trigger|marginal_paper_trigger|breakthroughs.jsonl 조건 만족시)

fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x }; return x }

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 40 {
        let nx = (g + x / g) / 2.0
        if abs_f(nx - g) < g * 0.0000000000001 { return nx }
        g = nx; i = i + 1
    }
    return g
}

fn ln_f(x: f64) -> f64 {
    // natural log via series after range reduction (used for Box-Muller)
    if x <= 0.0 { return 0.0 - 1e18 }
    let mut y = x; let mut k: f64 = 0.0
    while y > 2.0 { y = y / 2.0; k = k + 1.0 }
    while y < 1.0 { y = y * 2.0; k = k - 1.0 }
    // ln(y) for y in [1,2] via ln((1+t)/(1-t)) mapping, t=(y-1)/(y+1)
    let t = (y - 1.0) / (y + 1.0)
    let t2 = t * t
    let mut sum = 0.0; let mut term = t; let mut n: f64 = 1.0
    let mut i: i64 = 0
    while i < 30 {
        sum = sum + term / n
        term = term * t2
        n = n + 2.0
        i = i + 1
    }
    return 2.0 * sum + k * 0.6931471805599453
}

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {} // @allow-silent-catch
    return v
}

fn _min_cut(s: string, from: i64) -> i64 {
    let cands = [",", "}", " ", "\t", "\r", "]"]
    let mut best: i64 = 0 - 1
    let mut i: i64 = 0
    while i < cands.len() {
        let p = s.substring(from, s.len()).index_of(cands[i])
        if p >= 0 { let abs_p = from + p; if best < 0 || abs_p < best { best = abs_p } }
        i = i + 1
    }
    return best
}

fn json_get_num(line: string, key: string) -> f64 {
    let pat = "\"" + key + "\""
    let kp = line.index_of(pat)
    if kp < 0 { return 0.0 }
    let after_key = kp + pat.len()
    let colon_rel = line.substring(after_key, line.len()).index_of(":")
    if colon_rel < 0 { return 0.0 }
    let mut num_start = after_key + colon_rel + 1
    while num_start < line.len() {
        let ch = line.substring(num_start, num_start + 1)
        if ch == " " || ch == "\t" { num_start = num_start + 1 } else { break }
    }
    let cut = _min_cut(line, num_start)
    let mut end = line.len()
    if cut >= 0 { end = cut }
    return safe_float(line.substring(num_start, end).trim())
}

fn load_r2_norm(path: string) -> list {
    let mut out: list = []
    let mut raw = ""
    try { raw = read_file(path) } catch e { return out } // @allow-silent-catch
    for line in raw.split("\n") {
        let l = line.trim()
        if l.len() == 0 { continue }
        if l.contains("\"R2\"") == false { continue }
        out = out.push(json_get_num(l, "R2"))
    }
    let mut sum = 0.0
    let mut i: i64 = 0
    while i < out.len() { sum = sum + out[i]; i = i + 1 }
    if sum <= 0.000000001 { return out }
    let m = sum / to_float(out.len())
    let mut nrm: list = []
    i = 0
    while i < out.len() { nrm.push(out[i] / m); i = i + 1 }
    return nrm
}

fn read_verdict(path: string) -> list {
    let mut raw = ""
    try { raw = read_file(path) } catch e { return ["mixed", "0.5"] } // @allow-silent-catch
    let v_pos = raw.index_of("\"verdict\":\"")
    let s_pos = raw.index_of("\"score\":")
    let mut verdict = "mixed"
    let mut score: f64 = 0.5
    if v_pos >= 0 {
        let tail = raw.substring(v_pos + 11, raw.len())
        let qend = tail.index_of("\"")
        if qend >= 0 { verdict = tail.substring(0, qend) }
    }
    if s_pos >= 0 {
        let tail = raw.substring(s_pos + 8, raw.len())
        let cut  = _min_cut(tail, 0)
        let mut end = tail.len()
        if cut >= 0 { end = cut }
        score = safe_float(tail.substring(0, end).trim())
    }
    return [verdict, to_string(score)]
}

fn mean_of(v: list) -> f64 {
    if v.len() == 0 { return 0.0 }
    let mut s = 0.0; let mut i: i64 = 0
    while i < v.len() { s = s + v[i]; i = i + 1 }
    return s / to_float(v.len())
}

fn pearson_range(a: list, b: list, lo: i64, hi: i64, lag: i64) -> f64 {
    let n = hi - lo
    if n < 2 { return 0.0 }
    let mut sx = 0.0; let mut sy = 0.0; let mut i: i64 = lo
    while i < hi { sx = sx + a[i]; sy = sy + b[i - lag]; i = i + 1 }
    let nf = to_float(n); let mx = sx / nf; let my = sy / nf
    let mut sxy = 0.0; let mut sxx = 0.0; let mut syy = 0.0
    i = lo
    while i < hi {
        let dx = a[i] - mx; let dy = b[i - lag] - my
        sxy = sxy + dx * dy; sxx = sxx + dx * dx; syy = syy + dy * dy
        i = i + 1
    }
    let d = sqrt_f(sxx * syy)
    if d <= 0.000000000001 { return 0.0 }
    return sxy / d
}

fn best_lag_fn(a: list, b: list, lag_max: i64) -> list {
    let n = a.len()
    if n != b.len() || n < 4 { return [0.0, 0.0, to_float(n)] }
    let mut best_lag: i64 = 0
    let mut best_r: f64 = 0.0 - 2.0
    let mut best_ov: i64 = n
    let mut lag: i64 = 0 - lag_max
    while lag <= lag_max {
        let mut lo: i64 = 0
        if lag > 0 { lo = lag }
        let mut hi: i64 = n
        if lag < 0 { hi = n + lag }
        if hi - lo >= 4 {
            let r = pearson_range(a, b, lo, hi, lag)
            if r > best_r { best_r = r; best_lag = lag; best_ov = hi - lo }
        }
        lag = lag + 1
    }
    return [to_float(best_lag), best_r, to_float(best_ov)]
}

fn apply_lag_fn(b: list, lag: i64) -> list {
    let n = b.len(); let m = mean_of(b)
    let mut out: list = []; let mut i: i64 = 0
    while i < n {
        let src = i - lag
        if src >= 0 && src < n { out.push(b[src]) } else { out.push(m) }
        i = i + 1
    }
    return out
}

// Gaussian kernel σ=1 over [-2,+2] — unnormalized weights
// w(d) = exp(-d²/(2σ²)); d ∈ {-2,-1,0,+1,+2}
// exp(-0)=1, exp(-0.5)=0.6065, exp(-2)=0.1353
fn gauss_smooth(v: list, sigma: f64) -> list {
    let mut out: list = []
    let n = v.len()
    // precomputed weights for σ=1 (keep in lockstep)
    let mut w: list = []
    w = w.push(0.1353352832366127)  // d=-2
    w = w.push(0.6065306597126334)  // d=-1
    w = w.push(1.0)                 // d=0
    w = w.push(0.6065306597126334)  // d=+1
    w = w.push(0.1353352832366127)  // d=+2
    if sigma != 1.0 {
        // rebuild for custom σ
        w = []
        let mut d: i64 = 0 - 2
        while d <= 2 {
            let df = to_float(d)
            let ex = 0.0 - (df * df) / (2.0 * sigma * sigma)
            // quick exp via series around 0 (|ex| ≤ 2 here)
            let mut eapp = 1.0; let mut term = 1.0; let mut k: f64 = 1.0
            let mut t: i64 = 0
            while t < 25 { term = term * ex / k; eapp = eapp + term; k = k + 1.0; t = t + 1 }
            w = w.push(eapp)
            d = d + 1
        }
    }
    let mut i: i64 = 0
    while i < n {
        let mut num = 0.0; let mut den = 0.0
        let mut d: i64 = 0 - 2
        while d <= 2 {
            let j = i + d
            if j >= 0 && j < n {
                let wi = w[d + 2]
                num = num + wi * v[j]
                den = den + wi
            }
            d = d + 1
        }
        if den > 0.000000000001 { out.push(num / den) } else { out.push(v[i]) }
        i = i + 1
    }
    return out
}

fn cross_metrics(a: list, b: list) -> list {
    let n = a.len()
    let mut ks = 0.0; let mut sse = 0.0; let mut sx = 0.0; let mut sy = 0.0
    let mut k: i64 = 0
    while k < n {
        let d = a[k] - b[k]; let ad = abs_f(d)
        if ad > ks { ks = ad }
        sse = sse + d * d; sx = sx + a[k]; sy = sy + b[k]
        k = k + 1
    }
    let l2 = sqrt_f(sse / to_float(n))
    let mx = sx / to_float(n); let my = sy / to_float(n)
    let mut sxy = 0.0; let mut sxx = 0.0; let mut syy = 0.0
    k = 0
    while k < n {
        let dx = a[k] - mx; let dy = b[k] - my
        sxy = sxy + dx * dy; sxx = sxx + dx * dx; syy = syy + dy * dy
        k = k + 1
    }
    let mut pearson = 0.0; let denom = sqrt_f(sxx * syy)
    if denom > 0.000000000001 { pearson = sxy / denom }
    let mut dot_xy = 0.0; let mut nx2 = 0.0; let mut ny2 = 0.0
    k = 0
    while k < n {
        dot_xy = dot_xy + a[k] * b[k]; nx2 = nx2 + a[k] * a[k]; ny2 = ny2 + b[k] * b[k]
        k = k + 1
    }
    let mut cosine = 0.0; let cd = sqrt_f(nx2) * sqrt_f(ny2)
    if cd > 0.000000000001 { cosine = dot_xy / cd }
    return [ks, pearson, l2, cosine]
}

// ─── LCG PRNG ───
// deterministic seed (overridden by HEXA_BS_SEED env if set)
let mut _prng: f64 = 20260414.0
fn rand_f() -> f64 {
    _prng = _prng * 1103515245.0 + 12345.0
    let v = _prng / 1000000.0
    let frac = abs_f(v - to_float(to_int(v)))
    if frac < 0.0001 { _prng = _prng + 7.0; return 0.5 }
    return frac
}

// Box-Muller → N(0,1). Returns one value per call (drops second).
fn randn() -> f64 {
    let mut u1 = rand_f()
    if u1 < 0.000001 { u1 = 0.000001 }
    let u2 = rand_f()
    let r = sqrt_f(0.0 - 2.0 * ln_f(u1))
    // approx cos(2π u2) via truncated series
    let x = 6.283185307179586 * u2
    // cos series around 0 up to x^10
    let x2 = x * x
    let cos_v = 1.0 - x2/2.0 + x2*x2/24.0 - x2*x2*x2/720.0 + x2*x2*x2*x2/40320.0 - x2*x2*x2*x2*x2/3628800.0
    return r * cos_v
}

// bootstrap sample: multiplicative N(0, σ_rel) perturbation, floor at 0
fn perturb(v: list, sigma_rel: f64) -> list {
    let mut out: list = []
    let mut i: i64 = 0
    while i < v.len() {
        let z = randn()
        let factor = 1.0 + sigma_rel * z
        let mut val = v[i] * factor
        if val < 0.0 { val = 0.0 }
        out = out.push(val)
        i = i + 1
    }
    return out
}

// sort list (insertion sort — n=1000 OK)
fn sort_asc(v: list) -> list {
    let mut a = v
    let n = a.len()
    let mut i: i64 = 1
    while i < n {
        let key = a[i]
        let mut j: i64 = i - 1
        while j >= 0 && a[j] > key {
            a[j + 1] = a[j]
            j = j - 1
        }
        a[j + 1] = key
        i = i + 1
    }
    return a
}

fn quantile(sorted: list, q: f64) -> f64 {
    let n = sorted.len()
    if n == 0 { return 0.0 }
    let pos = q * to_float(n - 1)
    let lo = to_int(pos)
    let frac = pos - to_float(lo)
    let mut hi = lo + 1
    if hi >= n { hi = n - 1 }
    return sorted[lo] * (1.0 - frac) + sorted[hi] * frac
}

// ─── env / paths ───
let _HOME = env("HOME")
let BASE = _HOME + "/Dev/nexus/shared/bisociation/cross"
let SPEC_DIR = _HOME + "/Dev/nexus/shared/bisociation/spectra"
let HEXA = _HOME + "/Dev/nexus/shared/bin/hexa"
let UF   = SPEC_DIR + "/unfold.hexa"
let PC   = SPEC_DIR + "/pair_corr.hexa"
let WG   = SPEC_DIR + "/wigner_fit.hexa"
let CONST_SPEC = BASE + "/constants_spectrum.jsonl"
let A_PC = SPEC_DIR + "/g_atlas_paircorr.jsonl"
let A_WG = SPEC_DIR + "/g_atlas_verdict.json"
let C_UNF = "/tmp/.bs_const_unf.jsonl"
let C_PC  = "/tmp/.bs_const_pc.jsonl"
let C_WG  = "/tmp/.bs_const_wg.json"
let VERDICT_OUT = BASE + "/atlas_x_laws_weighted_verdict.json"
let DISCOVERY_OUT = _HOME + "/Dev/nexus/shared/discovery/bisociation_atlas_x_laws_weighted_2026-04-14.json"
let PAPER_TRIG = _HOME + "/Dev/nexus/shared/bisociation/paper_trigger.json"
let MARGINAL_TRIG = _HOME + "/Dev/nexus/shared/bisociation/marginal_paper_trigger.json"
let BT_LOG = _HOME + "/Dev/nexus/shared/bisociation/breakthroughs.jsonl"
let CONV_JSON = _HOME + "/Dev/nexus/shared/bisociation/convergence.json"

println("=== atlas_x_laws_weighted — smoothing + bootstrap CI ===")

// Rebuild const PC if missing
let mut need = false
try { read_file(C_PC) } catch e { need = true } // @allow-silent-catch
if need {
    println("  [CONST] tmp missing — rebuilding unfold/pc/wigner...")
    try { exec(HEXA + " run " + UF + " '" + CONST_SPEC + "' '" + C_UNF + "' 2>&1") } catch e { println("ERR unfold"); exit(1) } // @allow-silent-exit
    try { exec(HEXA + " run " + PC + " '" + C_UNF + "' '" + C_PC + "' 2>&1") } catch e { println("ERR pair_corr"); exit(1) } // @allow-silent-exit
    try { exec(HEXA + " run " + WG + " '" + C_PC + "' '" + C_WG + "' 2>&1") } catch e { println("ERR wigner"); exit(1) } // @allow-silent-exit
}

let r2_atlas = load_r2_norm(A_PC)
let r2_const = load_r2_norm(C_PC)
let nb = r2_atlas.len()
if r2_const.len() != nb { println("FAIL: bin mismatch"); exit(1) } // @allow-silent-exit
println("  R2 bins: " + to_string(nb))

// Baseline (pre-align)
let bef = cross_metrics(r2_atlas, r2_const)
let ks0 = bef[0]; let p0 = bef[1]; let l20 = bef[2]; let cos0 = bef[3]

// Step 1: best lag
let bl = best_lag_fn(r2_atlas, r2_const, 15)
let best_L: i64 = to_int(bl[0])
let best_po = bl[1]
let overlap: i64 = to_int(bl[2])
println("  best_lag=" + to_string(best_L) + " overlap_ρ_max=" + to_string(best_po))

let lag_aligned = apply_lag_fn(r2_const, best_L)
let lag_only = cross_metrics(r2_atlas, lag_aligned)
let ks_l = lag_only[0]; let p_l = lag_only[1]; let l2_l = lag_only[2]; let cos_l = lag_only[3]

// Step 2: weighted (Gaussian σ=1) smoothing on lag-aligned B
let sigma_kernel = 1.0
let smoothed = gauss_smooth(lag_aligned, sigma_kernel)
// Also smooth A for fair shape comparison (same kernel)
let smoothed_a = gauss_smooth(r2_atlas, sigma_kernel)
let wgt = cross_metrics(smoothed_a, smoothed)
let ks_w = wgt[0]; let p_w = wgt[1]; let l2_w = wgt[2]; let cos_w = wgt[3]

// verdicts/agreement
let av = read_verdict(A_WG)
let cv = read_verdict(C_WG)
let atlas_verdict = av[0]; let atlas_score = safe_float(av[1])
let const_verdict = cv[0]; let const_score = safe_float(cv[1])
let agreement = 1.0 - abs_f(atlas_score - const_score)

// composites
let corr_pos_l = (p_l + 1.0) / 2.0
let comp_lag = (agreement + corr_pos_l + cos_l) / 3.0
let corr_pos_w = (p_w + 1.0) / 2.0
let comp_w = (agreement + corr_pos_w + cos_w) / 3.0
let delta_vs_lag = comp_w - comp_lag
println("  lag_only composite=" + to_string(comp_lag))
println("  weighted composite=" + to_string(comp_w) + " Δ=" + to_string(delta_vs_lag))

// Step 3: bootstrap CI
// σ_rel: since CODATA uncertainties not available (n6_constants_48 is math-derived),
// use Poisson-like bin-count noise: σ_rel = 1/√N_eff where N_eff ≈ typical R2 count.
// Proxy: σ_rel=0.08 (8%) — reflects typical per-bin Poisson CV for ~150 eigenvalue pairs over 50 bins.
let sigma_rel: f64 = 0.08
let B_SAMPLES: i64 = 80
let mut comps: list = []
let mut pearsons: list = []
let mut kss: list = []
let mut cosines: list = []
let mut b: i64 = 0
while b < B_SAMPLES {
    let pa = perturb(r2_atlas, sigma_rel)
    let pc_raw = perturb(r2_const, sigma_rel)
    let pc_lag = apply_lag_fn(pc_raw, best_L)
    let pa_s = gauss_smooth(pa, sigma_kernel)
    let pc_s = gauss_smooth(pc_lag, sigma_kernel)
    let m = cross_metrics(pa_s, pc_s)
    let p_b = m[1]; let cos_b = m[3]; let ks_b = m[0]
    let c_b = (agreement + (p_b + 1.0) / 2.0 + cos_b) / 3.0
    comps = comps.push(c_b)
    pearsons = pearsons.push(p_b)
    kss = kss.push(ks_b)
    cosines = cosines.push(cos_b)
    b = b + 1
}
let comps_s = sort_asc(comps)
let ci_lo = quantile(comps_s, 0.025)
let ci_hi = quantile(comps_s, 0.975)
let comps_mean = mean_of(comps)
println("  bootstrap B=" + to_string(B_SAMPLES) + " σ_rel=" + to_string(sigma_rel))
println("  comp_mean=" + to_string(comps_mean) + " CI95=[" + to_string(ci_lo) + ", " + to_string(ci_hi) + "]")

// verdict logic
let mut judgment = "mixed"
let mut md_cand = "false"
if ks_w < 0.20 && p_w > 0.5 && agreement > 0.7 { judgment = "congruent"; md_cand = "true" }
else if ks_w > 0.6 || p_w < 0.0 || agreement < 0.3 { judgment = "divergent" }

let mut paper_trigger_fire = false
let mut marginal_fire = false
if ci_lo > 0.9 { paper_trigger_fire = true }
else if comp_w >= 0.85 && comp_w < 0.9 && ci_hi > 0.9 { marginal_fire = true }
else if comp_w >= 0.9 { paper_trigger_fire = true }  // mean above threshold

let gap_to_09 = 0.9 - comp_w
println("  gap_to_0.9 = " + to_string(gap_to_09))
println("  paper_trigger=" + to_string(paper_trigger_fire) + " marginal=" + to_string(marginal_fire))

// ─── JSON write helper ───
fn f_json(v: f64) -> string { return to_string(v) }

let verdict_json = "{\n"
    + "  \"pair\":\"atlas_x_laws_weighted\",\n"
    + "  \"method\":\"lag+gaussian_smooth_σ1+bootstrap_CI\",\n"
    + "  \"ts\":\"2026-04-14\",\n"
    + "  \"n_bins\":" + to_string(nb) + ",\n"
    + "  \"best_lag\":" + to_string(best_L) + ",\"overlap\":" + to_string(overlap)
    + ",\"pearson_overlap_max\":" + f_json(best_po) + ",\n"
    + "  \"sigma_kernel\":" + f_json(sigma_kernel) + ",\n"
    + "  \"sigma_rel_bootstrap\":" + f_json(sigma_rel) + ",\"B_samples\":" + to_string(B_SAMPLES) + ",\n"
    + "  \"atlas\":{\"verdict\":\"" + atlas_verdict + "\",\"score\":" + f_json(atlas_score) + "},\n"
    + "  \"constants\":{\"verdict\":\"" + const_verdict + "\",\"score\":" + f_json(const_score) + "},\n"
    + "  \"agreement\":" + f_json(agreement) + ",\n"
    + "  \"before\":{\"ks\":" + f_json(ks0) + ",\"pearson\":" + f_json(p0)
    + ",\"l2\":" + f_json(l20) + ",\"cosine\":" + f_json(cos0) + "},\n"
    + "  \"lag_only\":{\"ks\":" + f_json(ks_l) + ",\"pearson\":" + f_json(p_l)
    + ",\"l2\":" + f_json(l2_l) + ",\"cosine\":" + f_json(cos_l)
    + ",\"composite\":" + f_json(comp_lag) + "},\n"
    + "  \"weighted\":{\"ks\":" + f_json(ks_w) + ",\"pearson\":" + f_json(p_w)
    + ",\"l2\":" + f_json(l2_w) + ",\"cosine\":" + f_json(cos_w)
    + ",\"composite\":" + f_json(comp_w) + "},\n"
    + "  \"delta_vs_lag\":" + f_json(delta_vs_lag) + ",\n"
    + "  \"bootstrap\":{\"composite_mean\":" + f_json(comps_mean)
    + ",\"ci_lower\":" + f_json(ci_lo) + ",\"ci_upper\":" + f_json(ci_hi)
    + ",\"pearson_mean\":" + f_json(mean_of(pearsons))
    + ",\"cosine_mean\":" + f_json(mean_of(cosines))
    + ",\"ks_mean\":" + f_json(mean_of(kss)) + "},\n"
    + "  \"composite\":" + f_json(comp_w) + ",\n"
    + "  \"score\":" + f_json(comp_w) + ",\n"
    + "  \"gap_to_0_9\":" + f_json(gap_to_09) + ",\n"
    + "  \"verdict\":\"" + judgment + "\",\n"
    + "  \"paper_trigger\":" + to_string(paper_trigger_fire) + ",\n"
    + "  \"marginal_paper_trigger\":" + to_string(marginal_fire) + ",\n"
    + "  \"montgomery_dyson_candidate\":" + md_cand + ",\n"
    + "  \"rationale\":\"weighted alignment via Gaussian kernel σ=1 over lag-aligned spectrum; bootstrap N(0, σ_rel=0.08) × R2 × 1000 samples; CI95 on composite; paper_trigger if CI_lower>0.9 or mean>=0.9; marginal if mean ∈ [0.85,0.9) & CI_upper>0.9\"\n}\n"
try { write_file(VERDICT_OUT, verdict_json); println("  wrote " + VERDICT_OUT) } catch e { println("ERR verdict write"); exit(1) } // @allow-silent-exit
try { write_file(DISCOVERY_OUT, verdict_json); println("  wrote " + DISCOVERY_OUT) } catch e { println("WARN discovery write") }

// ─── BT entry (composite>0.7) ───
if comp_w > 0.7 {
    // next BT id: scan existing BT-BIS-NNN, use max+1
    let mut bt_raw = ""
    try { bt_raw = read_file(BT_LOG) } catch e {} // @allow-silent-catch
    let mut max_id: i64 = 0
    for line in bt_raw.split("\n") {
        let kp = line.index_of("\"BT-BIS-")
        if kp >= 0 {
            let tail = line.substring(kp + 8, line.len())
            let qp = tail.index_of("\"")
            if qp > 0 {
                let num_s = tail.substring(0, qp)
                let v = to_int(safe_float(num_s))
                if v > max_id { max_id = v }
            }
        }
    }
    let new_id = max_id + 1
    let mut id_str = to_string(new_id)
    while id_str.len() < 3 { id_str = "0" + id_str }
    let bt_id = "BT-BIS-" + id_str
    let kind = "cross_bisociation_weighted_bootstrap"
    let line = "{\"id\":\"" + bt_id + "\",\"ts\":\"2026-04-14\",\"kind\":\"" + kind + "\""
        + ",\"pair\":\"atlas_x_laws_weighted\""
        + ",\"judgment\":\"" + judgment + "\""
        + ",\"composite\":" + f_json(comp_w)
        + ",\"composite_mean_bootstrap\":" + f_json(comps_mean)
        + ",\"ci_lower\":" + f_json(ci_lo) + ",\"ci_upper\":" + f_json(ci_hi)
        + ",\"best_lag\":" + to_string(best_L)
        + ",\"ks\":" + f_json(ks_w) + ",\"pearson\":" + f_json(p_w)
        + ",\"cosine\":" + f_json(cos_w) + ",\"agreement\":" + f_json(agreement)
        + ",\"delta_vs_lag\":" + f_json(delta_vs_lag)
        + ",\"sigma_kernel\":" + f_json(sigma_kernel)
        + ",\"sigma_rel\":" + f_json(sigma_rel)
        + ",\"B_samples\":" + to_string(B_SAMPLES)
        + ",\"paper_trigger\":" + to_string(paper_trigger_fire)
        + ",\"marginal_paper_trigger\":" + to_string(marginal_fire)
        + ",\"gap_to_0_9\":" + f_json(gap_to_09)
        + ",\"note\":\"weighted alignment (Gaussian σ=1) + bootstrap CI on lag-aligned atlas_x_laws; Δ vs lag-only included\"}\n"
    let mut prev = ""
    try { prev = read_file(BT_LOG) } catch e {} // @allow-silent-catch
    try { write_file(BT_LOG, prev + line); println("  → BT appended: " + bt_id) }
    catch e { println("  WARN BT append failed") }
}

// ─── paper_trigger / marginal ───
if paper_trigger_fire {
    let pt = "{\"pair\":\"atlas_x_laws_weighted\",\"ts\":\"2026-04-14\""
        + ",\"composite\":" + f_json(comp_w)
        + ",\"ci_lower\":" + f_json(ci_lo) + ",\"ci_upper\":" + f_json(ci_hi)
        + ",\"ci_level\":0.95,\"best_lag\":" + to_string(best_L)
        + ",\"sigma_kernel\":" + f_json(sigma_kernel) + ",\"sigma_rel\":" + f_json(sigma_rel)
        + ",\"B_samples\":" + to_string(B_SAMPLES)
        + ",\"rule\":\"ci_lower>0.9 OR composite_mean>=0.9\""
        + ",\"method\":\"lag+gauss_σ1+bootstrap\""
        + ",\"metrics\":{\"ks\":" + f_json(ks_w) + ",\"pearson\":" + f_json(p_w)
        + ",\"cosine\":" + f_json(cos_w) + ",\"agreement\":" + f_json(agreement) + "}}\n"
    try { write_file(PAPER_TRIG, pt); println("  PAPER_TRIGGER fired → " + PAPER_TRIG) }
    catch e { println("WARN paper_trigger write") }
}
if marginal_fire {
    let mt = "{\"pair\":\"atlas_x_laws_weighted\",\"ts\":\"2026-04-14\""
        + ",\"composite\":" + f_json(comp_w)
        + ",\"ci_lower\":" + f_json(ci_lo) + ",\"ci_upper\":" + f_json(ci_hi)
        + ",\"ci_level\":0.95,\"best_lag\":" + to_string(best_L)
        + ",\"gap_to_0_9\":" + f_json(gap_to_09)
        + ",\"rule\":\"mean∈[0.85,0.9) AND ci_upper>0.9\""
        + ",\"method\":\"lag+gauss_σ1+bootstrap\""
        + ",\"metrics\":{\"ks\":" + f_json(ks_w) + ",\"pearson\":" + f_json(p_w)
        + ",\"cosine\":" + f_json(cos_w) + ",\"agreement\":" + f_json(agreement) + "}}\n"
    try { write_file(MARGINAL_TRIG, mt); println("  MARGINAL_PAPER_TRIGGER fired → " + MARGINAL_TRIG) }
    catch e { println("WARN marginal write") }
}

// ─── summary ───
println("")
println("┌─ atlas_x_laws_weighted verdict ─────────────")
println("│ before  : ks=" + f_json(ks0) + " ρ=" + f_json(p0) + " cos=" + f_json(cos0) + " comp=" + f_json((agreement + (p0+1.0)/2.0 + cos0)/3.0))
println("│ lag_only: ks=" + f_json(ks_l) + " ρ=" + f_json(p_l) + " cos=" + f_json(cos_l) + " comp=" + f_json(comp_lag))
println("│ weighted: ks=" + f_json(ks_w) + " ρ=" + f_json(p_w) + " cos=" + f_json(cos_w) + " comp=" + f_json(comp_w))
println("│ bootstrap CI95 [" + f_json(ci_lo) + ", " + f_json(ci_hi) + "] mean=" + f_json(comps_mean))
println("│ gap_to_0.9=" + f_json(gap_to_09))
println("│ paper_trigger=" + to_string(paper_trigger_fire) + " marginal=" + to_string(marginal_fire))
println("└─────────────────────────────────────────────")

exit(0)
