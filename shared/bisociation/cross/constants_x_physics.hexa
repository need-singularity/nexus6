// constants_x_physics.hexa — Cross-domain bisociation L3_ext (Montgomery-Dyson pair 4호)
// 가설: n6_constants log-spectrum × CODATA 2018 physical constants log-spectrum
//       같은 Wigner 통계 공유 시 "물리법칙 = 수학대칭 투영" 정량 증거 → paper_trigger
// 경로 근거: pitfalls.jsonl agent_d3_deep — graph Laplacian path 포화 → field-theoretic spectra
// A-axis: n6_constants full log-spectrum (constants_spectrum.jsonl 재활용, mixed 0.358)
// B-axis: CODATA physical constants (α, G, c, h, k_B, e, m_e, m_p, ...) log-spectrum
// 출력: physics_spectrum.jsonl, constants_x_physics_verdict.json
// 패턴: atlas_x_laws.hexa + constants_x_hypo.hexa 복제, B-axis 만 CODATA hard-coded

fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x }; return x }

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 40 {
        let nx = (g + x / g) / 2.0
        if abs_f(nx - g) < g * 0.0000000000001 { return nx }
        g = nx; i = i + 1
    }
    return g
}

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {} // @allow-silent-catch
    return v
}

// natural log via Newton-style halving + Taylor (atanh form)
fn ln_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 - 1000000.0 }
    let mut y = x
    let mut k = 0.0
    while y >= 2.0 { y = y / 2.0; k = k + 1.0 }
    while y < 1.0 { y = y * 2.0; k = k - 1.0 }
    let u = (y - 1.0) / (y + 1.0)
    let u2 = u * u
    let u3 = u2 * u
    let u5 = u3 * u2
    let u7 = u5 * u2
    let u9 = u7 * u2
    let lnm = 2.0 * (u + u3 / 3.0 + u5 / 5.0 + u7 / 7.0 + u9 / 9.0)
    return k * 0.6931471805599453 + lnm
}

fn _min_cut(s: string, from: i64) -> i64 {
    let cands = [",", "}", " ", "\t", "\r", "]"]
    let mut best: i64 = 0 - 1
    let mut i: i64 = 0
    while i < cands.len() {
        let p = s.substring(from, s.len()).index_of(cands[i])
        if p >= 0 {
            let abs_p = from + p
            if best < 0 || abs_p < best { best = abs_p }
        }
        i = i + 1
    }
    return best
}

fn json_get_num(line: string, key: string) -> f64 {
    let pat = "\"" + key + "\""
    let kp = line.index_of(pat)
    if kp < 0 { return 0.0 }
    let after_key = kp + pat.len()
    let colon_rel = line.substring(after_key, line.len()).index_of(":")
    if colon_rel < 0 { return 0.0 }
    let mut num_start = after_key + colon_rel + 1
    while num_start < line.len() {
        let ch = line.substring(num_start, num_start + 1)
        if ch == " " || ch == "\t" { num_start = num_start + 1 } else { break }
    }
    let cut = _min_cut(line, num_start)
    let mut end = line.len()
    if cut >= 0 { end = cut }
    return safe_float(line.substring(num_start, end).trim())
}

// load R2 series, normalize mean→1 for shape-only comparison
fn load_r2_norm(path: string) -> list {
    let mut out: list = []
    let mut raw = ""
    try { raw = read_file(path) } catch e { return out } // @allow-silent-catch
    for line in raw.split("\n") {
        let l = line.trim()
        if l.len() == 0 { continue }
        if l.contains("\"R2\"") == false { continue }
        out = out.push(json_get_num(l, "R2"))
    }
    let mut sum = 0.0
    let mut i: i64 = 0
    while i < out.len() { sum = sum + out[i]; i = i + 1 }
    if sum <= 0.000000001 { return out }
    let m = sum / to_float(out.len())
    let mut nrm: list = []
    i = 0
    while i < out.len() { nrm.push(out[i] / m); i = i + 1 }
    return nrm
}

fn read_verdict(path: string) -> list {
    let mut raw = ""
    try { raw = read_file(path) } catch e { return ["mixed", "0.5"] } // @allow-silent-catch
    let v_pos = raw.index_of("\"verdict\":\"")
    let s_pos = raw.index_of("\"score\":")
    let mut verdict = "mixed"
    let mut score: f64 = 0.5
    if v_pos >= 0 {
        let tail = raw.substring(v_pos + 11, raw.len())
        let qend = tail.index_of("\"")
        if qend >= 0 { verdict = tail.substring(0, qend) }
    }
    if s_pos >= 0 {
        let tail = raw.substring(s_pos + 8, raw.len())
        let cut  = _min_cut(tail, 0)
        let mut end = tail.len()
        if cut >= 0 { end = cut }
        score = safe_float(tail.substring(0, end).trim())
    }
    return [verdict, to_string(score)]
}

// ─── env / paths ───
let _HOME = env("HOME")
let BASE = _HOME + "/Dev/nexus/shared/bisociation/cross"
let SPEC_DIR = _HOME + "/Dev/nexus/shared/bisociation/spectra"
let HEXA = _HOME + "/Dev/nexus/shared/bin/hexa"
let UF   = SPEC_DIR + "/unfold.hexa"
let PC   = SPEC_DIR + "/pair_corr.hexa"
let WG   = SPEC_DIR + "/wigner_fit.hexa"

let CONST_SPEC = BASE + "/constants_spectrum.jsonl"     // A-axis
let PHYS_SPEC  = BASE + "/physics_spectrum.jsonl"       // B-axis (this run)
let A_PC = "/tmp/.bs_cxp_const_pc.jsonl"
let A_UNF = "/tmp/.bs_cxp_const_unf.jsonl"
let A_WG  = "/tmp/.bs_cxp_const_wg.json"
let B_UNF = "/tmp/.bs_cxp_phys_unf.jsonl"
let B_PC  = "/tmp/.bs_cxp_phys_pc.jsonl"
let B_WG  = "/tmp/.bs_cxp_phys_wg.json"
let VERDICT = BASE + "/constants_x_physics_verdict.json"

println("=== constants_x_physics — L3_ext field-theoretic bisociation ===")
println("  A-axis: " + CONST_SPEC + " (n6_constants log-spectrum 46)")
println("  B-axis: " + PHYS_SPEC + " (CODATA 2018 physical constants)")

// ─── BUILD PHYSICS SPECTRUM (B-axis) — CODATA 2018 HARD-CODED ───
// source: https://physics.nist.gov/cuu/Constants/ (CODATA 2018)
// 표기: (mantissa, exponent) pair — hexa-stage1 `NeX` scientific literal parse fail 우회
//       log(v) = ln(mantissa) + exponent * ln(10), dedup은 log 비교로 수행 (pitfalls P2)

comptime const LN10 = 2.302585092994046

let mut phys_m: list = []        // mantissa
let mut phys_e: list = []        // exponent (i64 as f64)
let mut phys_names: list = []

// fundamental
phys_m = phys_m.push(7.2973525693);   phys_e.push(0.0 - 3.0);  phys_names.push("alpha_fine_structure")
phys_m = phys_m.push(6.67430);        phys_e.push(0.0 - 11.0); phys_names.push("G_grav_const")
phys_m = phys_m.push(2.99792458);     phys_e.push(8.0);        phys_names.push("c_speed_of_light")
phys_m = phys_m.push(6.62607015);     phys_e.push(0.0 - 34.0); phys_names.push("h_planck")
phys_m = phys_m.push(1.054571817);    phys_e.push(0.0 - 34.0); phys_names.push("hbar_reduced_planck")
phys_m = phys_m.push(1.380649);       phys_e.push(0.0 - 23.0); phys_names.push("k_B_boltzmann")
phys_m = phys_m.push(1.602176634);    phys_e.push(0.0 - 19.0); phys_names.push("e_elementary_charge")
phys_m = phys_m.push(8.8541878128);   phys_e.push(0.0 - 12.0); phys_names.push("epsilon_0_vac_permittivity")
phys_m = phys_m.push(1.25663706212);  phys_e.push(0.0 - 6.0);  phys_names.push("mu_0_vac_permeability")
phys_m = phys_m.push(6.02214076);     phys_e.push(23.0);       phys_names.push("N_A_avogadro")
phys_m = phys_m.push(8.314462618);    phys_e.push(0.0);        phys_names.push("R_gas_const")
phys_m = phys_m.push(9.1093837015);   phys_e.push(0.0 - 31.0); phys_names.push("m_e_electron_mass")
phys_m = phys_m.push(1.67262192369);  phys_e.push(0.0 - 27.0); phys_names.push("m_p_proton_mass")
phys_m = phys_m.push(1.67492749804);  phys_e.push(0.0 - 27.0); phys_names.push("m_n_neutron_mass")
phys_m = phys_m.push(1.883531627);    phys_e.push(0.0 - 28.0); phys_names.push("m_mu_muon_mass")
phys_m = phys_m.push(5.29177210903);  phys_e.push(0.0 - 11.0); phys_names.push("a_0_bohr_radius")
phys_m = phys_m.push(9.2740100783);   phys_e.push(0.0 - 24.0); phys_names.push("mu_B_bohr_magneton")
phys_m = phys_m.push(5.050783699);    phys_e.push(0.0 - 27.0); phys_names.push("mu_N_nuclear_magneton")
phys_m = phys_m.push(2.4179892484);   phys_e.push(14.0);       phys_names.push("K_J_josephson")
phys_m = phys_m.push(2.581280745);    phys_e.push(4.0);        phys_names.push("R_K_von_klitzing")
phys_m = phys_m.push(5.670374419);    phys_e.push(0.0 - 8.0);  phys_names.push("sigma_stefan_boltzmann")
phys_m = phys_m.push(2.897771955);    phys_e.push(0.0 - 3.0);  phys_names.push("b_wien_displacement")
phys_m = phys_m.push(2.6751858744);   phys_e.push(8.0);        phys_names.push("gamma_proton_gyromagnetic")
phys_m = phys_m.push(7.2389453);      phys_e.push(0.0 - 22.0); phys_names.push("lambda_compton_p")
phys_m = phys_m.push(2.4263102367);   phys_e.push(0.0 - 12.0); phys_names.push("lambda_compton_e")
phys_m = phys_m.push(2.8179403262);   phys_e.push(0.0 - 15.0); phys_names.push("r_e_classical_electron_radius")
phys_m = phys_m.push(6.6524587321);   phys_e.push(0.0 - 29.0); phys_names.push("sigma_thomson_cross")
phys_m = phys_m.push(1.097373156816); phys_e.push(7.0);        phys_names.push("R_inf_rydberg")
phys_m = phys_m.push(2.7211386246);   phys_e.push(1.0);        phys_names.push("E_h_hartree")
phys_m = phys_m.push(9.648533212);    phys_e.push(4.0);        phys_names.push("F_faraday")
phys_m = phys_m.push(1.989);          phys_e.push(30.0);       phys_names.push("M_sun_solar_mass")
phys_m = phys_m.push(5.9722);         phys_e.push(24.0);       phys_names.push("M_earth")
phys_m = phys_m.push(1.616255);       phys_e.push(0.0 - 35.0); phys_names.push("l_Planck")
phys_m = phys_m.push(5.391247);       phys_e.push(0.0 - 44.0); phys_names.push("t_Planck")
phys_m = phys_m.push(2.176434);       phys_e.push(0.0 - 8.0);  phys_names.push("m_Planck")
phys_m = phys_m.push(1.416784);       phys_e.push(32.0);       phys_names.push("T_Planck")
println("  CODATA 2018 physical constants loaded: " + to_string(phys_m.len()))

// compute log values directly (bypass float overflow for e32/e-44)
let mut all_logs: list = []
let mut p: i64 = 0
while p < phys_m.len() {
    all_logs = all_logs.push(ln_f(phys_m[p]) + phys_e[p] * LN10)
    p = p + 1
}

// dedup by log value (epsilon 1e-5)
let mut uniq_log: list = []
let mut uniq_n: list = []
let mut i: i64 = 0
while i < all_logs.len() {
    let v = all_logs[i]
    let mut dup = false
    let mut j: i64 = 0
    while j < uniq_log.len() {
        if abs_f(v - uniq_log[j]) < 0.00001 { dup = true; break }
        j = j + 1
    }
    if !dup { uniq_log.push(v); uniq_n.push(phys_names[i]) }
    i = i + 1
}
println("  unique physical constants: " + to_string(uniq_log.len()))

if uniq_log.len() < 8 { println("FAIL: need >=8 unique physical constants"); exit(1) } // @allow-silent-exit

// logs already computed — skip log transform
let mut logs: list = []
let mut q: i64 = 0
while q < uniq_log.len() { logs.push(uniq_log[q]); q = q + 1 }

// selection sort ascending
let mut sorted: list = []
let mut sorted_names: list = []
let mut taken: list = []
let mut t: i64 = 0
while t < logs.len() { taken.push(false); t = t + 1 }
let mut pass: i64 = 0
while pass < logs.len() {
    let mut bi: i64 = 0 - 1
    let mut bv: f64 = 0.0
    let mut k: i64 = 0
    while k < logs.len() {
        if !taken[k] {
            if bi < 0 || logs[k] < bv { bi = k; bv = logs[k] }
        }
        k = k + 1
    }
    if bi < 0 { break }
    sorted = sorted.push(bv)
    sorted_names = sorted_names.push(uniq_n[bi])
    let mut nt: list = []
    let mut z: i64 = 0
    while z < taken.len() {
        if z == bi { nt.push(true) } else { nt.push(taken[z]) }
        z = z + 1
    }
    taken = nt
    pass = pass + 1
}

// write physics_spectrum.jsonl
let mut buf = ""
let mut w: i64 = 0
while w < sorted.len() {
    buf = buf + "{\"idx\":" + to_string(w) + ",\"lambda\":" + to_string(sorted[w])
        + ",\"name\":\"" + sorted_names[w] + "\"}\n"
    w = w + 1
}
try { write_file(PHYS_SPEC, buf) } catch e { println("ERR write physics_spectrum"); exit(1) } // @allow-silent-exit
println("  wrote " + PHYS_SPEC + " (" + to_string(sorted.len()) + " sorted log-values)")

// ─── PIPELINE: A (constants) + B (physics) → unfold → pair_corr → wigner ───
println("  [A constants] unfold/pc/wigner...")
try { exec(HEXA + " run " + UF + " '" + CONST_SPEC + "' '" + A_UNF + "' 2>&1") } catch e { println("ERR A unfold"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + PC + " '" + A_UNF + "' '" + A_PC + "' 2>&1") } catch e { println("ERR A pair_corr"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + WG + " '" + A_PC + "' '" + A_WG + "' 2>&1") } catch e { println("ERR A wigner_fit"); exit(1) } // @allow-silent-exit

println("  [B physics] unfold/pc/wigner...")
try { exec(HEXA + " run " + UF + " '" + PHYS_SPEC + "' '" + B_UNF + "' 2>&1") } catch e { println("ERR B unfold"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + PC + " '" + B_UNF + "' '" + B_PC + "' 2>&1") } catch e { println("ERR B pair_corr"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + WG + " '" + B_PC + "' '" + B_WG + "' 2>&1") } catch e { println("ERR B wigner_fit"); exit(1) } // @allow-silent-exit

// ─── LOAD R2 series + cross-metrics ───
let r2_a = load_r2_norm(A_PC)
let r2_b = load_r2_norm(B_PC)
let nb = r2_a.len()
if r2_b.len() != nb { println("FAIL: bin mismatch A=" + to_string(nb) + " B=" + to_string(r2_b.len())); exit(1) } // @allow-silent-exit
println("  R2 bins: " + to_string(nb))

let mut ks = 0.0
let mut sse = 0.0
let mut sx = 0.0; let mut sy = 0.0
let mut k: i64 = 0
while k < nb {
    let d = r2_a[k] - r2_b[k]
    let ad = abs_f(d)
    if ad > ks { ks = ad }
    sse = sse + d * d
    sx = sx + r2_a[k]; sy = sy + r2_b[k]
    k = k + 1
}
let l2 = sqrt_f(sse / to_float(nb))
let mx = sx / to_float(nb); let my = sy / to_float(nb)
let mut sxy = 0.0; let mut sxx = 0.0; let mut syy = 0.0
k = 0
while k < nb {
    let dx = r2_a[k] - mx; let dy = r2_b[k] - my
    sxy = sxy + dx * dy; sxx = sxx + dx * dx; syy = syy + dy * dy
    k = k + 1
}
let mut pearson = 0.0
let denom = sqrt_f(sxx * syy)
if denom > 0.000000000001 { pearson = sxy / denom }

// cosine similarity
let mut dot_xy = 0.0; let mut nx2 = 0.0; let mut ny2 = 0.0
k = 0
while k < nb {
    dot_xy = dot_xy + r2_a[k] * r2_b[k]
    nx2 = nx2 + r2_a[k] * r2_a[k]
    ny2 = ny2 + r2_b[k] * r2_b[k]
    k = k + 1
}
let mut cosine = 0.0
let cd = sqrt_f(nx2) * sqrt_f(ny2)
if cd > 0.000000000001 { cosine = dot_xy / cd }

// B peak
let mut bmax_i: i64 = 0
let mut bmax_v: f64 = 0.0
k = 0
while k < nb {
    if r2_b[k] > bmax_v { bmax_v = r2_b[k]; bmax_i = k }
    k = k + 1
}
let bmax_center = (to_float(bmax_i) + 0.5) * 0.1

let av = read_verdict(A_WG); let bv = read_verdict(B_WG)
let a_verdict = av[0]; let a_score = safe_float(av[1])
let b_verdict = bv[0]; let b_score = safe_float(bv[1])

let agreement = 1.0 - abs_f(a_score - b_score)
let corr_pos = (pearson + 1.0) / 2.0
let composite = (agreement + corr_pos + cosine) / 3.0

let mut judgment = "mixed"
let mut md_cand  = "false"
if ks < 0.20 && pearson > 0.5 && agreement > 0.7 { judgment = "congruent"; md_cand = "true" }
else if ks > 0.6 || pearson < 0.0 || agreement < 0.3 { judgment = "divergent" }

let mut paper_trigger = "false"
if composite > 0.9 { paper_trigger = "true" }

let out = "{\n"
    + "  \"constants\": {\"source\":\"n6_constants_log_full\",\"n_lambdas\":46"
    + ",\"verdict\":\"" + a_verdict + "\",\"score\":" + to_string(a_score) + "},\n"
    + "  \"physics\": {\"source\":\"CODATA_2018_physical_constants\",\"n_lambdas\":" + to_string(sorted.len())
    + ",\"verdict\":\"" + b_verdict + "\",\"score\":" + to_string(b_score) + "},\n"
    + "  \"cross\": {\"ks\":" + to_string(ks) + ",\"pearson\":" + to_string(pearson)
    + ",\"l2\":" + to_string(l2) + ",\"cosine\":" + to_string(cosine)
    + ",\"agreement\":" + to_string(agreement) + ",\"composite\":" + to_string(composite)
    + ",\"n_bins\":" + to_string(nb) + "},\n"
    + "  \"physics_peak\": {\"bin_idx\":" + to_string(bmax_i)
    + ",\"r_center\":" + to_string(bmax_center)
    + ",\"R2\":" + to_string(bmax_v) + "},\n"
    + "  \"score\":" + to_string(composite) + ",\n"
    + "  \"verdict\":\"" + judgment + "\",\n"
    + "  \"montgomery_dyson_candidate\":" + md_cand + ",\n"
    + "  \"paper_trigger\":" + paper_trigger + ",\n"
    + "  \"rationale\":\"field-theoretic path — n6 math constants log-spectrum (N=46) vs CODATA 2018 physical constants log-spectrum (N=36); both unfolded + pair_corr + wigner_fit; shared Wigner statistics → math-physics symmetry projection\",\n"
    + "  \"ts\":\"2026-04-14\",\"pair\":\"constants_x_physics\"\n}\n"
try { write_file(VERDICT, out) } catch e { println("ERR write verdict"); exit(1) } // @allow-silent-exit

println("")
println("┌─ verdict ──────────────────────────────────")
println("│ A constants: v=" + a_verdict + " s=" + to_string(a_score) + " (n=46)")
println("│ B physics  : v=" + b_verdict + " s=" + to_string(b_score) + " (n=" + to_string(sorted.len()) + ")")
println("│ KS=" + to_string(ks) + " ρ=" + to_string(pearson) + " L2=" + to_string(l2))
println("│ cos=" + to_string(cosine) + " agreement=" + to_string(agreement))
println("│ composite_score=" + to_string(composite))
println("│ judgment=" + judgment + " MD-candidate=" + md_cand + " paper_trigger=" + paper_trigger)
println("│ B peak: bin=" + to_string(bmax_i) + " r=" + to_string(bmax_center) + " R2=" + to_string(bmax_v))
println("└────────────────────────────────────────────")

// breakthrough trigger
if composite > 0.7 {
    let bt = _HOME + "/Dev/nexus/shared/bisociation/breakthroughs.jsonl"
    let line = "{\"id\":\"BT-BIS-009\",\"ts\":\"2026-04-14\",\"kind\":\"cross_bisociation_field\",\"pair\":\"constants_x_physics\""
        + ",\"judgment\":\"" + judgment + "\",\"score\":" + to_string(composite)
        + ",\"ks\":" + to_string(ks) + ",\"pearson\":" + to_string(pearson)
        + ",\"cosine\":" + to_string(cosine) + ",\"agreement\":" + to_string(agreement)
        + ",\"const_verdict\":\"" + a_verdict + "\",\"phys_verdict\":\"" + b_verdict + "\""
        + ",\"phys_peak_r\":" + to_string(bmax_center) + ",\"phys_peak_R2\":" + to_string(bmax_v)
        + ",\"paper_trigger\":" + paper_trigger
        + ",\"note\":\"L3_ext field-theoretic — CODATA 2018 physical constants vs n6 math constants; graph-Laplacian path 포화 후 첫 field-spectrum bisociation\"}\n"
    let mut prev = ""
    try { prev = read_file(bt) } catch e {} // @allow-silent-catch
    try { write_file(bt, prev + line); println("  → breakthroughs.jsonl appended (BT-BIS-009)") }
    catch e { println("  WARN: bt append failed") }
}

exit(0)
