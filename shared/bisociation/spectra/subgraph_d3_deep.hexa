// subgraph_d3_deep.hexa — L2 sub-decomposition of pfx_blowup-d3 (746n/670e, score=0.473)
// Goal: break 0.7 (Wigner GUE boundary) by re-splitting along finer axes.
// Axes: (a) sub-prefix bucket after 'blowup-d3_' (ded vs dual; ded_warp/ded_n/ded_dim/...)
//       (b) source-cluster bucket (which n6-* root the leaves derive from)
//       (c) degree bucket (hub-rich vs leaf-rich)
//       (d) connected component (BFS)
// Pipeline: for each sub-sub-net, awk-extract ids → induced CSR → Lanczos → unfold/pair_corr/wigner_fit.
// Out: subgraph_verdicts/pfx_blowup-d3_L2/<sublabel>.{eig,unf,pc,json}.jsonl
//      spectra/subgraph_d3_deep_summary.json
//      breakthroughs.jsonl (if any score >= 0.7)

fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x }; return x }
fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0; if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 40 { let nx = (g + x / g) / 2.0; if abs_f(nx - g) < g * 0.0000000000001 { return nx }; g = nx; i = i + 1 }
    return g
}
fn hypot_f(a: f64, b: f64) -> f64 {
    let aa = abs_f(a); let ab = abs_f(b)
    if aa > ab { let r = ab / aa; return aa * sqrt_f(1.0 + r * r) }
    if ab == 0.0 { return 0.0 }
    let r = aa / ab; return ab * sqrt_f(1.0 + r * r)
}
fn load_int_lines(path: string) -> [i64] {
    let lines = read_file(path).split("\n"); let mut out: [i64] = []; let mut i: i64 = 0
    while i < len(lines) { let t = lines[i].trim(); if t != "" { let mut v: i64 = 0; try { v = to_int(t) } catch e {} ; out.push(v) }; i = i + 1 } // @allow-silent-catch
    return out
}
fn matvec_L(x: [f64], deg: [i64], rp: [i64], cl: [i64], n: i64) -> [f64] {
    let mut y: [f64] = []; let mut r: i64 = 0
    while r < n {
        let mut s = to_float(deg[r]) * x[r]; let so = rp[r]; let eo = rp[r + 1]; let mut k = so
        while k < eo { s = s - x[cl[k]]; k = k + 1 }
        y = y.push(s); r = r + 1 }
    return y
}
fn dot(u: [f64], v: [f64], n: i64) -> f64 { let mut s = 0.0; let mut i: i64 = 0; while i < n { s = s + u[i] * v[i]; i = i + 1 }; return s }
fn sub_scaled(u: [f64], v: [f64], a: f64, n: i64) -> [f64] { let mut o: [f64] = []; let mut i: i64 = 0; while i < n { o.push(u[i] - a * v[i]); i = i + 1 }; return o }
fn norm2(u: [f64], n: i64) -> f64 { let mut s = 0.0; let mut i: i64 = 0; while i < n { s = s + u[i] * u[i]; i = i + 1 }; return sqrt_f(s) }
fn scale_inv(u: [f64], b: f64, n: i64) -> [f64] { let mut o: [f64] = []; let mut i: i64 = 0; while i < n { o.push(u[i] / b); i = i + 1 }; return o }
fn rebuild_with(li: [f64], i1: i64, v1: f64, i2: i64, v2: f64, i3: i64, v3: f64) -> [f64] {
    let mut o: [f64] = []; let mut i: i64 = 0
    while i < len(li) { let mut v = li[i]; if i == i1 { v = v1 }; if i == i2 { v = v2 }; if i == i3 { v = v3 }; o.push(v); i = i + 1 }
    return o }
fn qr_sweep(d_in: [f64], e_in: [f64], l: i64, p: i64) -> [[f64]] {
    let dd = (d_in[p - 1] - d_in[p]) / 2.0; let b2 = e_in[p - 1] * e_in[p - 1]
    let mut sgn = 1.0; if dd < 0.0 { sgn = -1.0 }
    let mu = d_in[p] - b2 / (dd + sgn * sqrt_f(dd * dd + b2))
    let mut dw = d_in; let mut ew = e_in
    let mut x = dw[l] - mu; let mut z = ew[l]; let mut i: i64 = l
    while i < p {
        let r = hypot_f(x, z); let mut c = 1.0; let mut s = 0.0
        if r > 0.0 { c = x / r; s = z / r }
        let di = dw[i]; let di1 = dw[i + 1]; let ei = ew[i]
        let nd = c * c * di + 2.0 * c * s * ei + s * s * di1
        let nd1 = s * s * di - 2.0 * c * s * ei + c * c * di1
        let ne = (c * c - s * s) * ei + c * s * (di1 - di)
        dw = rebuild_with(dw, i, nd, i + 1, nd1, -1, 0.0)
        if i > l { ew = rebuild_with(ew, i - 1, r, i, ne, -1, 0.0) } else { ew = rebuild_with(ew, i, ne, -1, 0.0, -1, 0.0) }
        if i + 1 < p { let oei1 = ew[i + 1]; ew = rebuild_with(ew, i + 1, c * oei1, -1, 0.0, -1, 0.0); z = s * oei1 }
        x = ne; i = i + 1
    }
    return [dw, ew]
}
fn lanczos_eigs(deg: [i64], rp: [i64], cl: [i64], n: i64, K_req: i64) -> [f64] {
    let mut K = K_req; if K > n { K = n }; if K > 200 { K = 200 }
    let mut v_init: [f64] = []; let mut s0 = 0.0; let mut ix: i64 = 0
    while ix < n { let kk = (ix * 2654435761) % 1000003; let xv = to_float(kk) / 1000003.0 - 0.5; v_init.push(xv); s0 = s0 + xv * xv; ix = ix + 1 }
    let nrm0 = sqrt_f(s0); if nrm0 < 0.000000001 { return [] }
    let mut v_cur = scale_inv(v_init, nrm0, n)
    let mut v_prev: [f64] = []; let mut vp: i64 = 0; while vp < n { v_prev.push(0.0); vp = vp + 1 }
    let mut alphas: [f64] = []; let mut betas: [f64] = []; let mut bp = 0.0; let mut it: i64 = 0
    while it < K {
        let Lv = matvec_L(v_cur, deg, rp, cl, n)
        let w1 = sub_scaled(Lv, v_prev, bp, n); let al = dot(w1, v_cur, n); alphas.push(al)
        let w2 = sub_scaled(w1, v_cur, al, n); let dp = dot(w2, v_prev, n); let w3 = sub_scaled(w2, v_prev, dp, n)
        let be = norm2(w3, n); if be < 0.00000000001 { break }
        betas = betas.push(be); v_prev = v_cur; v_cur = scale_inv(w3, be, n); bp = be; it = it + 1
    }
    let k_eff = len(alphas)
    if k_eff < 3 { return [] }
    let mut d = alphas; let mut e: [f64] = []; let mut bi: i64 = 0
    while bi < k_eff - 1 { e.push(betas[bi]); bi = bi + 1 }
    let mut me = k_eff; let ms = 80 * k_eff; let mut sw: i64 = 0
    while me > 1 && sw < ms {
        sw = sw + 1; let mut li: i64 = 0; let mut fnd = false; let mut ls = me - 2
        while ls >= 0 {
            let thr = 0.0000000000001 * (abs_f(d[ls]) + abs_f(d[ls + 1]))
            if abs_f(e[ls]) <= thr { e = rebuild_with(e, ls, 0.0, -1, 0.0, -1, 0.0); li = ls + 1; fnd = true; break }
            ls = ls - 1
        }
        if !fnd { li = 0 }
        if li == me - 1 { me = me - 1 } else { let p = me - 1; let res = qr_sweep(d, e, li, p); d = res[0]; e = res[1] }
    }
    let mut sorted_out: [f64] = []; let mut used: [bool] = []; let mut uu: i64 = 0
    while uu < k_eff { used.push(false); uu = uu + 1 }
    let mut pass: i64 = 0
    while pass < k_eff {
        let mut bi2: i64 = -1; let mut bv = 0.0; let mut j: i64 = 0
        while j < k_eff { if !used[j] { if bi2 < 0 || d[j] < bv { bi2 = j; bv = d[j] } }; j = j + 1 }
        if bi2 < 0 { break }
        sorted_out = sorted_out.push(bv)
        let mut u2: [bool] = []; let mut z: i64 = 0
        while z < k_eff { if z == bi2 { u2.push(true) } else { u2.push(used[z]) }; z = z + 1 }
        used = u2; pass = pass + 1
    }
    return sorted_out
}

fn make_safe(s: string) -> string {
    let mut o = ""; let mut i: i64 = 0
    while i < s.len() { let c = s.substring(i, i + 1); if c == " " || c == "\"" || c == "'" || c == "/" { o = o + "_" } else { o = o + c }; i = i + 1 }
    return o
}

let argv = args()
let _HOME = env("HOME")
let ATLAS = _HOME + "/Dev/nexus/shared/n6/atlas.n6"
let SPDIR = _HOME + "/Dev/nexus/shared/bisociation/spectra"
let OUT_DIR = SPDIR + "/subgraph_verdicts/pfx_blowup-d3_L2"
if !file_exists(ATLAS) { println("error: atlas missing"); exit(1) } // @allow-silent-exit
try { exec("mkdir -p '" + OUT_DIR + "'") } catch e {} // @allow-silent-catch

println("=== subgraph_d3_deep — L2 sub-decomposition ===")
println("  parent: pfx_blowup-d3 (746n/670e, score=0.473)")
println("  out:    " + OUT_DIR)

let pid = to_string(to_int(exec("echo $$").trim()))
// CORE = pure blowup-d3 ids (no closure); CLOSED = + 1-hop (parent set)
let CORE = "/tmp/.d3l2_core." + pid + ".txt"
let CLOSED = "/tmp/.d3l2_closed." + pid + ".txt"
let CTAG = "/tmp/.d3l2_tag." + pid + ".tsv"          // id<TAB>kind|sub2|sub3|src_root|deg
let CEDG = "/tmp/.d3l2_edges." + pid + ".tsv"        // from<TAB>to (edges fully inside CLOSED set)

// STEP 1: extract pure d3 nodes
try { exec("rm -f '" + CORE + "' '" + CLOSED + "' '" + CTAG + "' '" + CEDG + "'") } catch e {} // @allow-silent-catch
let extract_core = "awk '/\"type\":\"node\"/ { if(match($0,/\"id\":\"blowup-d3[^\"]*\"/)){ id=substr($0,RSTART+6,RLENGTH-7); print id } }' '" + ATLAS + "' | sort -u > '" + CORE + "'"
try { exec(extract_core) } catch e { println("core extract failed"); exit(1) } // @allow-silent-exit
let n_core = to_int(exec("wc -l < '" + CORE + "'").trim())
println("  pure d3 nodes (core): " + to_string(n_core))

// STEP 2: build edges where AT LEAST ONE endpoint is in CORE → CLOSED set = endpoints union CORE
let extract_edges = "awk 'FNR==NR{C[$1]=1; next} "
    + "/\"type\":\"edge\"/ { f=\"\"; t=\"\"; "
    + "  if(match($0,/\"from\":\"[^\"]*\"/)) f=substr($0,RSTART+8,RLENGTH-9); "
    + "  if(match($0,/\"to\":\"[^\"]*\"/))   t=substr($0,RSTART+6,RLENGTH-7); "
    + "  if(f!=\"\" && t!=\"\" && f!=t && (f in C || t in C)){ print f\"\\t\"t } "
    + "}' '" + CORE + "' '" + ATLAS + "' > '" + CEDG + "'"
try { exec(extract_edges) } catch e { println("edge extract failed"); exit(1) } // @allow-silent-exit
let n_edges = to_int(exec("wc -l < '" + CEDG + "'").trim())
println("  edges (1-hop): " + to_string(n_edges))

// CLOSED = union of edge endpoints + CORE
let build_closed = "awk -F'\\t' '{print $1; print $2}' '" + CEDG + "' | cat - '" + CORE + "' | sort -u > '" + CLOSED + "'"
try { exec(build_closed) } catch e {} // @allow-silent-catch
let n_closed = to_int(exec("wc -l < '" + CLOSED + "'").trim())
println("  closed nodes: " + to_string(n_closed))

// STEP 3: per-node tagging — kind(ded|dual|src), sub2(ded_warp|dual_d0|...), sub3(first 3 toks),
//   src_root (n6-* trunk for non-d3 nodes; or own trunk for d3 nodes), deg
let build_tag2 = "awk -F'\\t' 'BEGIN{OFS=\"\\t\"} "
    + "FNR==NR{ID[$0]=1; next} "
    + "{ DEG[$1]++; DEG[$2]++ } "
    + "END{ for(k in ID){ "
    + "  d=(k in DEG)?DEG[k]:0; "
    + "  is_d3=(substr(k,1,9)==\"blowup-d3\"); "
    + "  kind=\"src\"; sub2=\"src\"; sub3=\"src\"; root=k; "
    + "  if(is_d3){ "
    + "    rest=substr(k,11); "  // after "blowup-d3_"
    + "    n=split(rest,A,\"_\"); "
    + "    kind=(n>=1?A[1]:\"none\"); "
    + "    sub2=(n>=2?A[1]\"_\"A[2]:kind); "
    + "    sub3=(n>=3?A[1]\"_\"A[2]\"_\"A[3]:sub2); "
    + "    root=(n>=2?A[2]:\"none\"); "
    + "  } else { "
    + "    n=split(k,B,\"_\"); root=B[1]; kind=\"src\"; "
    + "    sub_=substr(k,1,9); sub2=\"src_\"sub_; sub3=sub2; "
    + "  } "
    + "  print k, kind, sub2, sub3, root, d "
    + "} }' '" + CLOSED + "' '" + CEDG + "' > '" + CTAG + "'"
try { exec(build_tag2) } catch e { println("tag build failed"); exit(1) } // @allow-silent-exit
let n_tag = to_int(exec("wc -l < '" + CTAG + "'").trim())
println("  tagged: " + to_string(n_tag))

// STEP 4: enumerate axis buckets that have >= MIN_BUCKET nodes (keep small to surface mixed regions)
let MIN_BUCKET: i64 = 30  // smaller than 50 since the parent has only ~750 nodes
// star-forest needs lower bar; parent itself was avg-deg ~1.8 (746n / 670e * 2)
let MIN_DEG_AVG: f64 = 1.0

// AXIS A: kind (ded vs dual)
let kinds_str = exec("awk -F'\\t' '$2!=\"\" {print $2}' '" + CTAG + "' | sort | uniq -c | awk '$2!=\"\" && $1>=" + to_string(MIN_BUCKET) + " {print $2\"\\t\"$1}'").trim()
println("  kinds: " + kinds_str)

// AXIS B: sub2 (ded_warp, ded_n, ded_dim, ded_d0, dual_d0...)
let sub2s_str = exec("awk -F'\\t' '$3!=\"\" {print $3}' '" + CTAG + "' | sort | uniq -c | awk '$2!=\"\" && $1>=" + to_string(MIN_BUCKET) + " {print $2\"\\t\"$1}'").trim()
println("  sub2: " + sub2s_str)

// AXIS C: src_root (which n6-* trunk: warp, n, dim, sigma, Omega, alpha, ...)
let roots_str = exec("awk -F'\\t' '$5!=\"\" {print $5}' '" + CTAG + "' | sort | uniq -c | awk '$2!=\"\" && $1>=" + to_string(MIN_BUCKET) + " {print $2\"\\t\"$1}'").trim()
println("  roots: " + roots_str)

// AXIS D: degree buckets — leaf(deg=1), low(2-3), mid(4-7), hub(8+)
// AXIS E: connected components (BFS via awk)

// Helper: write ids subset matching predicate to /tmp/.d3l2_ids.<lab>.<pid>.txt and return path
// CTAG cols: id  kind  sub2  sub3  root  deg
fn stage_pred(label: string, pred: string, CTAG: string, pid: string) -> string {
    let OUT = "/tmp/.d3l2_ids." + label + "." + pid + ".txt"
    try { exec("awk -F'\\t' '" + pred + " {print $1}' '" + CTAG + "' | sort -u > '" + OUT + "'") } catch e {} // @allow-silent-catch
    return OUT
}

// Edge-bucket stage: subset edges first, then take ALL endpoint nodes.
// epred: a body that decides keep=1 for edges to include. We invoke as:
//   awk '{keep=0; <epred>; if(keep){print $1; print $2}}' CEDG | sort -u // @allow-bare-interp
// epred MUST set the awk variable `keep` to 1 for edges to retain. // @allow-bare-interp
fn stage_edge_pred(label: string, epred: string, CEDG: string, pid: string) -> string {
    let OUT = "/tmp/.d3l2_ids." + label + "." + pid + ".txt"
    let body = "{ keep=0; " + epred + "; if(keep){ print $1; print $2 } }"
    let cmd = "awk -F'\\t' '" + body + "' '" + CEDG + "' | sort -u > '" + OUT + "'"
    try { exec(cmd) } catch e {} // @allow-silent-catch
    return OUT
}

// Sub2-bucket as edge-pred via leaf side: for each edge from→to, the to side is the d3 leaf.
// We classify by the d3 leaf's sub2 tag (extracted from id).
// The d3 leaf prefix scheme: "blowup-d3_<kind>_<sub2_2>_..." → sub2 = "<kind>_<sub2_2>"
fn sub2_of_id_awk_helper() -> string {
    // returns awk function fragment: extracts sub2 from variable v (string) // @allow-bare-interp
    // sub2_of(v) = if (v starts with blowup-d3_) → split rest; else "src"
    return "function sub2_of(v,    rest, n, A) { "
        + "  if(substr(v,1,10)!=\"blowup-d3_\") return \"src\"; "
        + "  rest=substr(v,11); n=split(rest,A,\"_\"); "
        + "  if(n>=2) return A[1]\"_\"A[2]; if(n==1) return A[1]; return \"none\"; "
        + "}"
}
fn root_of_id_awk_helper() -> string {
    return "function root_of(v,    n, A) { "
        + "  if(substr(v,1,3)==\"n6-\") { n=split(substr(v,4),A,\"_\"); return A[1]; } "
        + "  return \"x\"; "
        + "}"
}

fn parse_lines(s: string) -> [string] { let r = s.trim(); if r == "" { return [] }; return r.split("\n") }

// Spectrum chain on a node-id subset, using EDG as edge source
fn run_chain(label: string, ids_path: string, OUT_DIR: string, EDG: string, MIN_DEG_AVG: f64) -> [string] {
    let pid = to_string(to_int(exec("echo $$").trim()))
    let MEM = "/tmp/.d3l2_mem." + label + "." + pid + ".tsv"
    let RP  = "/tmp/.d3l2_rp."  + label + "." + pid + ".txt"
    let DG  = "/tmp/.d3l2_dg."  + label + "." + pid + ".txt"
    let CL  = "/tmp/.d3l2_cl."  + label + "." + pid + ".txt"
    try { exec("rm -f '" + MEM + "' '" + RP + "' '" + DG + "' '" + CL + "'") } catch e {} // @allow-silent-catch
    try { exec("sort -u '" + ids_path + "' | awk 'NF>0 {print NR-1\"\\t\"$1}' > '" + MEM + "'") } catch e {} // @allow-silent-catch
    let n = to_int(to_string(exec("wc -l < '" + MEM + "'")).trim())
    if n < 30 { return [label, to_string(n), "0", "0.0", "skip_small"] }
    // Build induced CSR
    let build = "awk -v NC=" + to_string(n) + " 'BEGIN{FS=\"\\t\"; while((getline l < \"" + MEM + "\")>0){split(l,a,\"\\t\"); MAP[a[2]]=a[1]}} "
        + "{ if($1 in MAP && $2 in MAP){ ia=MAP[$1]+0; ib=MAP[$2]+0; if(ia!=ib){ "
        + "  N[ia]=(ia in N ? N[ia]\" \"ib : ib); N[ib]=(ib in N ? N[ib]\" \"ia : ia); "
        + "  D[ia]=(ia in D ? D[ia]+1 : 1); D[ib]=(ib in D ? D[ib]+1 : 1) } } } "
        + "END{ acc=0; for(i=0;i<NC;i++){ deg=(i in D)?D[i]:0; "
        + "  printf \"%d\\n\", acc >> \"" + RP + "\"; acc+=deg; "
        + "  printf \"%d\\n\", deg >> \"" + DG + "\"; "
        + "  if(deg>0){ nn=split(N[i],NB,\" \"); for(j=1;j<=nn;j++) printf \"%s\\n\", NB[j] >> \"" + CL + "\" } } "
        + "  printf \"%d\\n\", acc >> \"" + RP + "\" }' '" + EDG + "'"
    try { exec(build) } catch e {} // @allow-silent-catch
    let row_ptr = load_int_lines(RP); let deg = load_int_lines(DG); let col_idx = load_int_lines(CL)
    let edges = len(col_idx) / 2
    let mut sd: i64 = 0; let mut id: i64 = 0
    while id < len(deg) { sd = sd + deg[id]; id = id + 1 }
    let md = to_float(sd) / to_float(n)
    if md < MIN_DEG_AVG { return [label, to_string(n), to_string(edges), "0.0", "skip_lowdeg"] }
    // L2 uses smaller K and lower min eig threshold (sub-sub-nets are smaller)
    let mut Kreq: i64 = 50
    if n < 60 { Kreq = n - 2 }
    let kmin_val: i64 = 8
    let bad_K = Kreq - kmin_val
    if bad_K < 0 { Kreq = kmin_val }
    let eig = lanczos_eigs(deg, row_ptr, col_idx, n, Kreq)
    let n_eig = len(eig)
    let neg_thr = n_eig - 4
    if neg_thr < 0 { return [label, to_string(n), to_string(edges), "0.0", "skip_lanczos_short"] }
    let EP = OUT_DIR + "/" + label + ".eig.jsonl"
    let mut buf = ""; let mut w: i64 = 0
    while w < len(eig) { buf = buf + "{\"idx\":" + to_string(w) + ",\"lambda\":" + to_string(eig[w]) + "}\n"; w = w + 1 }
    try { write_file(EP, buf) } catch e { return [label, to_string(n), to_string(edges), "0.0", "write_fail"] } // @allow-silent-catch
    let _H = env("HOME"); let SP = _H + "/Dev/nexus/shared/bisociation/spectra"
    let UNF = OUT_DIR + "/" + label + ".unf.jsonl"; let PCC = OUT_DIR + "/" + label + ".pc.jsonl"; let VRD = OUT_DIR + "/" + label + ".json"
    try { exec("hexa '" + SP + "/unfold.hexa' '" + EP + "' '" + UNF + "' 2>/dev/null") } catch e {} // @allow-silent-catch
    try { exec("hexa '" + SP + "/pair_corr.hexa' '" + UNF + "' '" + PCC + "' 2>/dev/null") } catch e {} // @allow-silent-catch
    try { exec("hexa '" + SP + "/wigner_fit.hexa' '" + PCC + "' '" + VRD + "' 2>/dev/null") } catch e {} // @allow-silent-catch
    let mut score = "0.0"; let mut verdict = "unknown"
    if file_exists(VRD) {
        let r = read_file(VRD).trim()
        let kp = r.index_of("\"score\":")
        if kp >= 0 { let af = r.substring(kp + 8, r.len()); let ct = af.index_of(","); let mut ep2 = af.len(); if ct >= 0 { ep2 = ct }; score = af.substring(0, ep2).trim() }
        let kv = r.index_of("\"verdict\":\"")
        if kv >= 0 { let af = r.substring(kv + 11, r.len()); let ct = af.index_of("\""); if ct >= 0 { verdict = af.substring(0, ct) } }
    }
    try { exec("rm -f '" + MEM + "' '" + RP + "' '" + DG + "' '" + CL + "'") } catch e {} // @allow-silent-catch
    return [label, to_string(n), to_string(edges), score, verdict]
}

// Build job list. Each job = [label, ids_path, edge_file]
// edge_file lets us swap CEDG for co-leaf clique transform (axis F).
let mut jobs: [[string]] = []
//
// IMPORTANT: pure node-only subsetting on this graph yields zero edges (it's a forest of n6-stars).
// Use edge-pred instead — predicate over the edge file, then union endpoints.
// CEDG cols: from  to   (from ~ n6-X source root, to ~ blowup-d3 leaf)

let _sub2_fn = sub2_of_id_awk_helper()
let _root_fn = root_of_id_awk_helper()

// AXIS A: kind (ded vs dual) — predicate on the leaf (column 2 = to)
let kl = parse_lines(kinds_str); let mut ki: i64 = 0
while ki < len(kl) {
    let p = kl[ki].split("\t")
    let mut keep = true
    if len(p) >= 2 { if p[0] == "src" { keep = false } } else { keep = false }
    if keep {
        let lab = "kind_" + p[0]
        let pred = "rest=substr($2,11); n=split(rest,A,\"_\"); if(n>=1 && A[1]==\"" + p[0] + "\") keep=1"
        let ids = stage_edge_pred(lab, pred, CEDG, pid)
        jobs = jobs.push([lab, ids, CEDG])
    }
    ki = ki + 1
}

// AXIS B: sub2 (ded_warp, ded_n, ...) — predicate on leaf
let sl = parse_lines(sub2s_str); let mut si: i64 = 0
while si < len(sl) {
    let p = sl[si].split("\t")
    let mut keep_b = true
    if len(p) < 2 { keep_b = false } else {
        if p[0] == "src" { keep_b = false }
        if p[0].len() >= 4 { if p[0].substring(0, 4) == "src_" { keep_b = false } }
    }
    if keep_b {
        let lab = "sub2_" + p[0]
        let pred = "rest=substr($2,11); n=split(rest,A,\"_\"); if(n>=2){ s2=A[1]\"_\"A[2]; if(s2==\"" + p[0] + "\") keep=1 }"
        let ids = stage_edge_pred(lab, pred, CEDG, pid)
        jobs = jobs.push([lab, ids, CEDG])
    }
    si = si + 1
}

// AXIS C: src_root (n6-warp, n6-n, ...) — predicate on from-side
let rl = parse_lines(roots_str); let mut ri: i64 = 0
while ri < len(rl) {
    let p = rl[ri].split("\t")
    let mut keep_c = true
    if len(p) < 2 { keep_c = false } else { if p[0] == "x" { keep_c = false } }
    if keep_c {
        let lab = "root_" + p[0]
        let pred = "if(substr($1,1,3)==\"n6-\"){ n=split(substr($1,4),B,\"_\"); if(B[1]==\"" + p[0] + "\") keep=1 }"
        let ids = stage_edge_pred(lab, pred, CEDG, pid)
        jobs = jobs.push([lab, ids, CEDG])
    }
    ri = ri + 1
}

// AXIS C2: pairwise root combinations (top 4 roots × top 4 roots) — captures cross-root coupling
// (only useful if edges between two n6-* roots through shared d3 leaves exist)
// This is a star forest, so most pairs share no leaves. But cc analysis above shows clusters of 50+
// that mix multiple roots (e.g. cc anchored at "ded_n_d0_comp_alpha_inv_Omega_m_Omega_L"). We use
// instead a "multi-root" union of roots {warp, n, dim, sigma} as one bucket.
let multi_pred = "if(substr($1,1,3)==\"n6-\"){ n=split(substr($1,4),B,\"_\"); r=B[1]; if(r==\"warp\"||r==\"n\"||r==\"dim\"||r==\"sigma\"||r==\"Omega\") keep=1 }"
jobs = jobs.push(["multi_warp_n_dim_sigma_Omega", stage_edge_pred("multi_warp_n_dim_sigma_Omega", multi_pred, CEDG, pid), CEDG])
let multi2_pred = "if(substr($1,1,3)==\"n6-\"){ n=split(substr($1,4),B,\"_\"); r=B[1]; if(r==\"phi\"||r==\"tau\"||r==\"sopfr\"||r==\"alpha\"||r==\"J2\"||r==\"M3\"||r==\"mu\"||r==\"P2\"||r==\"j2\") keep=1 }"
jobs = jobs.push(["multi_minor_roots", stage_edge_pred("multi_minor_roots", multi2_pred, CEDG, pid), CEDG])
// AXIS D: hub_top_roots — n6-* sources with >=20 leaves emitted
let HUB_LIST = "/tmp/.d3l2_hub." + pid + ".txt"
try { exec("awk -F'\\t' '{c[$1]++} END{for(k in c) if(c[k]>=20) print k}' '" + CEDG + "' > '" + HUB_LIST + "'") } catch e {} // @allow-silent-catch
let HUB_IDS = "/tmp/.d3l2_ids.hub_top_roots." + pid + ".txt"
try { exec("awk -F'\\t' 'FNR==NR{H[$1]=1; next} { if($1 in H){print $1; print $2} }' '" + HUB_LIST + "' '" + CEDG + "' | sort -u > '" + HUB_IDS + "'") } catch e {} // @allow-silent-catch
jobs = jobs.push(["hub_top_roots", HUB_IDS, CEDG])
// AXIS F: CO-LEAF graphs.
// Star forest has degenerate Lanczos spectrum (most λ ∈ {0,1}).
// Co-leaf transform: build a NEW edge file where two leaves are connected iff they share ≥1 source.
// This gives clique-of-clique structure with much richer spectrum.
// We do this scoped to subsets to avoid O(N^2) blowup on parent.
let COEDG = "/tmp/.d3l2_coleaf." + pid + ".tsv"
let make_coleaf_global = "awk -F'\\t' '{src=$1; lf=$2; "
    + "  if(!(src in S)){ S[src]=lf; CNT[src]=1 } "
    + "  else { S[src]=S[src]\" \"lf; CNT[src]++ } "
    + "} END{ "
    + "  for(s in S){ "
    + "    n=split(S[s], LEAVES, \" \"); "
    + "    if(n>1 && n<=80){ "  // cap clique size to avoid n^2 explosion
    + "      for(i=1;i<=n;i++) for(j=i+1;j<=n;j++) print LEAVES[i]\"\\t\"LEAVES[j]; "
    + "    } "
    + "  } "
    + "}' '" + CEDG + "' | sort -u > '" + COEDG + "'"
try { exec(make_coleaf_global) } catch e {} // @allow-silent-catch
let n_coleaf = to_int(exec("wc -l < '" + COEDG + "'").trim())
println("  co-leaf edges (capped 80): " + to_string(n_coleaf))

// CO-LEAF spectrum on the FULL set
let COIDS = "/tmp/.d3l2_ids.coleaf_all." + pid + ".txt"
try { exec("awk -F'\\t' '{print $1; print $2}' '" + COEDG + "' | sort -u > '" + COIDS + "'") } catch e {} // @allow-silent-catch
jobs = jobs.push(["coleaf_all", COIDS, COEDG])
// AUGMENTED graph: union of star + co-leaf — captures both bipartite + clique structure
let AUGEDG = "/tmp/.d3l2_aug." + pid + ".tsv"
try { exec("cat '" + CEDG + "' '" + COEDG + "' | sort -u > '" + AUGEDG + "'") } catch e {} // @allow-silent-catch
let n_aug = to_int(exec("wc -l < '" + AUGEDG + "'").trim())
println("  augmented edges (star+coleaf): " + to_string(n_aug))
let AUGIDS = "/tmp/.d3l2_ids.aug_all." + pid + ".txt"
try { exec("awk -F'\\t' '{print $1; print $2}' '" + AUGEDG + "' | sort -u > '" + AUGIDS + "'") } catch e {} // @allow-silent-catch
jobs = jobs.push(["aug_all", AUGIDS, AUGEDG])
// AUGMENTED + degree-bucket: focus on the augmented graph's hub region
// Take only nodes with augmented degree >= some threshold (say, 10)
let AUG_HUBIDS = "/tmp/.d3l2_ids.aug_hub." + pid + ".txt"
try { exec("awk -F'\\t' '{D[$1]++; D[$2]++} END{for(k in D) if(D[k]>=10) print k}' '" + AUGEDG + "' > '" + AUG_HUBIDS + "'") } catch e {} // @allow-silent-catch
jobs = jobs.push(["aug_hub", AUG_HUBIDS, AUGEDG])
// Two more variants worth trying:
//  (1) edge-strength filter: only Derives edges with strength >= 0.95 — but we don't have strength in CEDG → skip
//  (2) DERIVATION CHAIN graph: connect a leaf to its 'parent' leaf if the parent's id is a substring/prefix
//      e.g., blowup-d3_X_d0_Y derives from blowup-d3_X. This builds a derivation tree.
let DCEDG = "/tmp/.d3l2_dc." + pid + ".tsv"
let make_dc = "awk '/\"type\":\"node\"/ { if(match($0,/\"id\":\"blowup-d3[^\"]*\"/)){ id=substr($0,RSTART+6,RLENGTH-7); IDS[id]=1 } } "
    + "END{ for(id in IDS){ "
    + "  rest=substr(id,11); n=split(rest,A,\"_\"); "
    + "  for(k=n-1; k>=2; k--){ "
    + "    p=\"blowup-d3_\"; for(j=1;j<=k;j++){ p=p A[j]; if(j<k) p=p\"_\" } "
    + "    if(p in IDS){ print p\"\\t\"id; break } "
    + "  } "
    + "} }' '" + ATLAS + "' | sort -u > '" + DCEDG + "'"
try { exec(make_dc) } catch e {} // @allow-silent-catch
let n_dc = to_int(exec("wc -l < '" + DCEDG + "'").trim())
println("  derivation chain edges: " + to_string(n_dc))
let DCIDS = "/tmp/.d3l2_ids.dc_all." + pid + ".txt"
try { exec("awk -F'\\t' '{print $1; print $2}' '" + DCEDG + "' | sort -u > '" + DCIDS + "'") } catch e {} // @allow-silent-catch
jobs = jobs.push(["dc_all", DCIDS, DCEDG])
// AUG + DC combo: full structural picture
let FULLEDG = "/tmp/.d3l2_full." + pid + ".tsv"
try { exec("cat '" + AUGEDG + "' '" + DCEDG + "' | sort -u > '" + FULLEDG + "'") } catch e {} // @allow-silent-catch
let n_full = to_int(exec("wc -l < '" + FULLEDG + "'").trim())
println("  full (star+coleaf+chain) edges: " + to_string(n_full))
let FULLIDS = "/tmp/.d3l2_ids.full_all." + pid + ".txt"
try { exec("awk -F'\\t' '{print $1; print $2}' '" + FULLEDG + "' | sort -u > '" + FULLIDS + "'") } catch e {} // @allow-silent-catch
jobs = jobs.push(["full_all", FULLIDS, FULLEDG])
// CO-LEAF restricted to specific roots — should reveal whether a single root's clique-net is more GUE
let mut rci: i64 = 0
while rci < len(rl) {
    let p = rl[rci].split("\t")
    let mut ok = true
    if len(p) < 2 { ok = false } else { if p[0] == "x" { ok = false } }
    if ok {
        let r0 = p[0]
        let lab = "coleaf_root_" + r0
        // source-side filter: only edges where source root token == r0
        let CFOUT = "/tmp/.d3l2_coleaf_root." + lab + "." + pid + ".tsv"
        let cmd = "awk -F'\\t' 'substr($1,1,3)==\"n6-\"{ split(substr($1,4),B,\"_\"); if(B[1]==\"" + r0 + "\"){"
            + "  src=$1; lf=$2; "
            + "  if(!(src in S)){ S[src]=lf; } else { S[src]=S[src]\" \"lf; }"
            + "} } END{ for(s in S){ n=split(S[s],L,\" \"); if(n>1 && n<=80) for(i=1;i<=n;i++) for(j=i+1;j<=n;j++) print L[i]\"\\t\"L[j] } }' '"
            + CEDG + "' | sort -u > '" + CFOUT + "'"
        try { exec(cmd) } catch e {} // @allow-silent-catch
        // collect ids = all endpoints of CFOUT
        let CFIDS = "/tmp/.d3l2_ids." + lab + "." + pid + ".txt"
        try { exec("awk -F'\\t' '{print $1; print $2}' '" + CFOUT + "' | sort -u > '" + CFIDS + "'") } catch e {} // @allow-silent-catch
        // We need run_chain to use CFOUT instead of CEDG → push special marker
        jobs = jobs.push([lab, CFIDS, CFOUT])
    }
    rci = rci + 1
}

// AXIS E: connected components — BFS via awk transitive closure // @allow-bare-interp
// Compute CC label per node, then bucket by largest components
let CCFILE = "/tmp/.d3l2_cc." + pid + ".tsv"
let cc_awk = "awk -F'\\t' 'BEGIN{} "
    + "{ E1[NR]=$1; E2[NR]=$2; NE=NR; "
    + "  if(!($1 in CID)){ CID[$1]=$1 } "
    + "  if(!($2 in CID)){ CID[$2]=$2 } } "
    + "END{ "
    + "  changed=1; pass=0; "
    + "  while(changed && pass<200){ changed=0; pass++; "
    + "    for(i=1;i<=NE;i++){ a=E1[i]; b=E2[i]; ca=CID[a]; cb=CID[b]; "
    + "      if(ca!=cb){ "
    + "        if(ca<cb){ for(k in CID) if(CID[k]==cb) CID[k]=ca; } "
    + "        else     { for(k in CID) if(CID[k]==ca) CID[k]=cb; } "
    + "        changed=1 } } "
    + "  } "
    + "  for(k in CID) print k\"\\t\"CID[k] "
    + "}' '" + CEDG + "' > '" + CCFILE + "'"
try { exec(cc_awk) } catch e {} // @allow-silent-catch
let cc_count_str = exec("awk -F'\\t' '{print $2}' '" + CCFILE + "' | sort | uniq -c | sort -rn | head -10").trim()
println("  cc top10 sizes:\n" + cc_count_str)
let cc_top = exec("awk -F'\\t' '{print $2}' '" + CCFILE + "' | sort | uniq -c | sort -rn | awk '$1>=" + to_string(MIN_BUCKET) + " {print $2\"\\t\"$1}' | head -8").trim()
let cl_lines = parse_lines(cc_top); let mut cci: i64 = 0
while cci < len(cl_lines) {
    let p = cl_lines[cci].split("\t")
    if len(p) >= 2 {
        let cclab = "cc_" + p[0]
        let safe = make_safe(cclab)
        let CCIDS = "/tmp/.d3l2_ids." + safe + "." + pid + ".txt"
        try { exec("awk -F'\\t' '$2==\"" + p[0] + "\" {print $1}' '" + CCFILE + "' | sort -u > '" + CCIDS + "'") } catch e {} // @allow-silent-catch
        jobs = jobs.push([safe, CCIDS, CEDG])
    }
    cci = cci + 1
}

println("  jobs: " + to_string(len(jobs)))

let mut summary = "{\"generated_at\":\"2026-04-14\",\"parent\":\"pfx_blowup-d3\",\"parent_score\":0.473231,\"parent_n\":746,\"parent_e\":670,\"sub_subnets\":[\n"
let mut first_row = true
let mut best_label = ""; let mut best_score = -1.0; let mut best_n: i64 = 0; let mut best_e: i64 = 0
let mut break_label = ""; let mut break_score = -1.0; let mut break_n: i64 = 0; let mut break_e: i64 = 0
let mut ji: i64 = 0
while ji < len(jobs) {
    let job = jobs[ji]
    let label = make_safe(job[0])
    let mut edg_file = CEDG
    if len(job) >= 3 { edg_file = job[2] }
    println("  -> " + label)
    let row = run_chain(label, job[1], OUT_DIR, edg_file, MIN_DEG_AVG)
    let n_ = to_int(row[1]); let e_ = to_int(row[2]); let mut sc = 0.0; try { sc = to_float(row[3]) } catch x {} // @allow-silent-catch
    let vd = row[4]
    let entry = "{\"label\":\"" + label + "\",\"n\":" + row[1] + ",\"edges\":" + row[2] + ",\"score\":" + row[3] + ",\"verdict\":\"" + vd + "\"}"
    if first_row { summary = summary + "  " + entry; first_row = false } else { summary = summary + ",\n  " + entry }
    let valid = vd != "skip_small" && vd != "skip_lowdeg" && vd != "skip_lanczos_short" && vd != "write_fail"
    if valid && sc > best_score { best_score = sc; best_label = label; best_n = n_; best_e = e_ }
    if valid && sc >= 0.7 && sc > break_score { break_score = sc; break_label = label; break_n = n_; break_e = e_ }
    ji = ji + 1
}
summary = summary + "\n],\n\"best\":{\"label\":\"" + best_label + "\",\"n\":" + to_string(best_n) + ",\"edges\":" + to_string(best_e) + ",\"score\":" + to_string(best_score) + "}"
if break_score >= 0.7 {
    summary = summary + ",\n\"breakthrough\":{\"label\":\"" + break_label + "\",\"n\":" + to_string(break_n) + ",\"edges\":" + to_string(break_e) + ",\"score\":" + to_string(break_score) + "}"
} else {
    summary = summary + ",\n\"breakthrough\":null"
}
summary = summary + "\n}\n"
try { write_file(SPDIR + "/subgraph_d3_deep_summary.json", summary) } catch e { println("summary write fail") }

if break_score >= 0.7 {
    let BR = _HOME + "/Dev/nexus/shared/bisociation/breakthroughs.jsonl"
    let line = "{\"ts\":\"2026-04-14\",\"kind\":\"subgraph_gue_L2\",\"parent\":\"pfx_blowup-d3\",\"parent_score\":0.473231,\"subnet\":\"" + break_label + "\",\"score\":" + to_string(break_score) + ",\"n\":" + to_string(break_n) + ",\"edges\":" + to_string(break_e) + ",\"note\":\"L2 sub-decomposition broke 0.7 GUE boundary — Wigner pair correlation emerging\"}\n"
    let mut prev = ""; if file_exists(BR) { try { prev = read_file(BR) } catch e {} } // @allow-silent-catch
    try { write_file(BR, prev + line) } catch e {} // @allow-silent-catch
    println("  breakthroughs.jsonl appended for " + break_label + " score=" + to_string(break_score))
}

// Cleanup tmp
try { exec("rm -f /tmp/.d3l2_*." + pid + ".*") } catch e {} // @allow-silent-catch
try { exec("rm -f /tmp/.d3l2_*" + pid + "* /tmp/.d3l2_coleaf*" + pid + "*") } catch e {} // @allow-silent-catch
try { exec("rm -f " + CORE + " " + CLOSED + " " + CTAG + " " + CEDG + " " + CCFILE + " " + COEDG + " " + AUGEDG + " " + DCEDG + " " + FULLEDG + " " + HUB_LIST) } catch e {} // @allow-silent-catch

println("=== done ===")
println("  best: " + best_label + "  score=" + to_string(best_score) + "  (n=" + to_string(best_n) + " e=" + to_string(best_e) + ")")
if break_score >= 0.7 { println("  BREAKTHROUGH: " + break_label + " score=" + to_string(break_score)) }
println("  summary: " + SPDIR + "/subgraph_d3_deep_summary.json")
exit(0)
