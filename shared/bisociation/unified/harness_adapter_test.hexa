// harness_adapter_test.hexa — L1_unified harness_adapter dry-run 검증
// 안전: 실제 entry.hexa 호출 시 read-only/silent 모드만 (self_check, list, rosetta, _verify).
// pre/post/guard 같은 mutating 라우트는 _verify 의 mode-mapping 만 검증.
// 예산: 200 줄. pitfalls 회피: #5 has_key, #6 push, #9 args().

let HEXA = "$HOME/Dev/nexus/shared/bin/hexa"
let ADAPTER = "$HOME/Dev/nexus/shared/bisociation/unified/harness_adapter.hexa"
let ROSETTA = "$HOME/Dev/nexus/shared/bisociation/unified/rosetta_harness.jsonl"

fn _run(cmd: string) -> string {
    return to_string(exec(cmd + " 2>&1"))
}

fn t_adapter_exists() -> bool {
    let ok = file_exists(ADAPTER)
    if ok { println("  PASS  adapter exists") } else { println("  FAIL  adapter missing: " + ADAPTER) }
    return ok
}

fn t_rosetta_exists() -> bool {
    if !file_exists(ROSETTA) { println("  FAIL  rosetta_harness.jsonl missing"); return false }
    let mut raw = ""
    try { raw = read_file(ROSETTA) } catch e { println("  FAIL  read err"); return false }
    let lines = raw.split("\n")
    let mut n = 0
    let mut i = 0
    while i < lines.len() {
        let s = lines[i].trim()
        if s.starts_with("{") { n = n + 1 }
        i = i + 1
    }
    if n < 30 {
        println("  FAIL  rosetta has " + to_string(n) + " entries (<30)")
        return false
    }
    println("  PASS  rosetta has " + to_string(n) + " entries")
    return true
}

fn t_help() -> bool {
    let out = _run(HEXA + " run " + ADAPTER + " help")
    if out.contains("3 프로젝트 단일 라우터") {
        println("  PASS  help renders")
        return true
    }
    println("  FAIL  help missing keyword: " + out)
    return false
}

fn t_list() -> bool {
    let out = _run(HEXA + " run " + ADAPTER + " list")
    let mut hits = 0
    if out.contains("nexus") { hits = hits + 1 }
    if out.contains("anima") { hits = hits + 1 }
    if out.contains("n6arch") { hits = hits + 1 }
    if hits != 3 {
        println("  FAIL  list missing project (hits=" + to_string(hits) + ")")
        return false
    }
    if !out.contains("PRESENT") {
        println("  FAIL  list shows no PRESENT entries")
        return false
    }
    println("  PASS  list shows 3 projects PRESENT")
    return true
}

fn t_rosetta_cmd() -> bool {
    let out = _run(HEXA + " run " + ADAPTER + " rosetta")
    if !out.contains("prompt") || !out.contains("pre_tool") || !out.contains("self_check") {
        println("  FAIL  rosetta cmd output incomplete")
        return false
    }
    println("  PASS  rosetta cmd shows action map")
    return true
}

fn t_verify_all() -> bool {
    let out = _run(HEXA + " run " + ADAPTER + " _verify")
    if !out.contains("ALL PASS") {
        println("  FAIL  _verify did not yield ALL PASS:")
        println(out)
        return false
    }
    println("  PASS  _verify ALL PASS")
    return true
}

fn t_route_self_check_each() -> bool {
    let projects: list = ["nexus", "anima", "n6arch"]
    let mut ok = 0
    let mut i = 0
    while i < projects.len() {
        let p = projects[i]
        let out = _run(HEXA + " run " + ADAPTER + " " + p + " self_check")
        // entry self_check 는 "harness modules:" 출력
        if out.contains("harness modules") {
            println("  PASS  route " + p + "/self_check  (harness modules detected)")
            ok = ok + 1
        } else {
            println("  FAIL  route " + p + "/self_check  no 'harness modules' keyword")
            println("    out: " + out)
        }
        i = i + 1
    }
    return ok == 3
}

fn t_unknown_project_rejected() -> bool {
    let out = _run(HEXA + " run " + ADAPTER + " bogus self_check")
    if out.contains("REJECT") && out.contains("unknown project") {
        println("  PASS  unknown project rejected")
        return true
    }
    println("  FAIL  bogus project not rejected: " + out)
    return false
}

fn t_unknown_action_rejected() -> bool {
    let out = _run(HEXA + " run " + ADAPTER + " nexus bogus_action")
    if out.contains("REJECT") && out.contains("unknown action") {
        println("  PASS  unknown action rejected")
        return true
    }
    println("  FAIL  bogus action not rejected: " + out)
    return false
}

fn t_emit_idempotent() -> bool {
    // emit 후 파일 라인수 변화 X (동일 내용)
    let before = _run("wc -l " + ROSETTA)
    let _e = _run(HEXA + " run " + ADAPTER + " emit")
    let after = _run("wc -l " + ROSETTA)
    let bnum = before.trim().split(" ")[0]
    let anum = after.trim().split(" ")[0]
    if bnum == anum {
        println("  PASS  emit idempotent (lines=" + bnum + ")")
        return true
    }
    println("  FAIL  emit changed line count: " + bnum + " -> " + anum)
    return false
}

fn main() {
    println("harness_adapter_test")
    println("==========================================")
    let mut tests: list = [
        t_adapter_exists(),
        t_rosetta_exists(),
        t_help(),
        t_list(),
        t_rosetta_cmd(),
        t_verify_all(),
        t_route_self_check_each(),
        t_unknown_project_rejected(),
        t_unknown_action_rejected(),
        t_emit_idempotent()
    ]
    let mut pass = 0
    let mut i = 0
    while i < tests.len() {
        if tests[i] { pass = pass + 1 }
        i = i + 1
    }
    println("==========================================")
    println("result: " + to_string(pass) + "/" + to_string(tests.len()) + " PASS")
    if pass < tests.len() {
        eprintln("FAIL  harness_adapter_test")
    }
}

main()
