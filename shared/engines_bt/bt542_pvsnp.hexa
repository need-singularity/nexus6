// bt542_pvsnp.hexa -- BT-542 P vs NP 전용 엔진 (EF-P9-1)
// @no-lock-needed  @allow-bare-exec  @enforce-sandbox
// attack: BarrierCatalog -- complexity hierarchy n=6 skeleton
// formalism: HexaProof. slot: hetzner-bt-0 / hetzner-bt-1
// honesty: MISS-barrier-catalog status. NO resolution claim.
// usage: hexa bt542_pvsnp.hexa <run|status|profile>

import "bt_engine_base.hexa"

let BT_ID = "BT-542"
let DOMAIN = "complexity"
let DEPTH: i64 = 4
let SEEDS = "3sat_enum_n6,natural_proofs_barrier,circuit_lower_bound"
let ATTACK = "BarrierCatalog"

fn build_config() -> map {
    let mut c: map = #{}
    c["bt_id"] = BT_ID
    c["domain"] = DOMAIN
    c["depth"] = to_string(DEPTH)
    c["seeds"] = SEEDS
    c["attack_vector"] = ATTACK
    return c
}

fn cmd_run() {
    let cfg = build_config()
    let result = bt_run(cfg)
    if result.trim() != "" {
        let lines = result.split("\n")
        let tail_start = if lines.len() > 20 { lines.len() - 20 } else { 0 }
        let mut i = tail_start
        while i < lines.len() {
            let line = _str(lines[i]).trim()
            if line != "" { println("  " + line) }
            i = i + 1
        }
    }
}

fn cmd_profile() {
    println("=== " + BT_ID + " P vs NP ===")
    println("attack: " + ATTACK + " (MISS-barrier-catalog)")
    println("domain: " + DOMAIN + " depth: " + to_string(DEPTH))
    println("seeds: " + SEEDS)
    println("formalism: HexaProof")
    println("slot: hetzner-bt-0 (CPU 16T combinatorial) / hetzner-bt-1")
    println("budget: $35/mo")
    bt_status(BT_ID)
}

fn main() {
    let argv = args()
    let mut mode = "status"
    if argv.len() >= 3 { mode = _str(argv[2]).trim() }
    if mode == "run" { cmd_run() }
    else if mode == "status" { bt_status(BT_ID) }
    else if mode == "profile" { cmd_profile() }
    else { eprintln("usage: bt542_pvsnp <run|status|profile>"); exit(2) }
}

main()
