#!hexa strict
// modules/honesty_monitor/honesty_monitor.hexa — BT-AI2 honesty-bit falsifier API
//
// @tool(slug="honesty_monitor", desc="Online falsifier for the BT-AI2 honesty-bit contract: detect F-AI2-A (claimed PASS but loss diverged ≥5%) and F-AI2-B (claimed FAIL but loss within 1%). Pure-stdlib observe()/snapshot() API; SimPy event-sim is OPTIONAL and intentionally omitted in this hexa port.")
// @usage(hexa run modules/honesty_monitor/honesty_monitor.hexa [--demo] [--self-test])
// @sentinel(__HONESTY_MONITOR__ PASS|FAIL alerts=N steps=N)
// @origin(~/core/n6-architecture/experiments/anomaly/btAI2_honesty_bit_scheduler.py — productized to .hexa, HEXA-ONLY 2026-04-27)
// @api(fn observe(step,claimed_bit,loss,expected_loss)->map; fn snapshot()->map)
// @allow-bare-exec
//
// Falsifier contract (preserved verbatim from upstream):
//   F-AI2-A : claimed PASS (claimed_bit=true) but |loss - expected_loss| / expected_loss ≥ 0.05
//             → honesty contract violation (silent regression).
//   F-AI2-B : claimed FAIL (claimed_bit=false) but |loss - expected_loss| / expected_loss ≤ 0.01
//             → honesty contract violation (over-pessimistic / fake-fail).
//
// Threshold semantics:
//   strict ">=" for the 5% boundary so that 4.99% does NOT alert and 5.01% DOES.
//   strict "<=" for the 1% boundary mirroring the inclusive accept band.

// ─── module-state (single-process) ────────────────────────────
// Hexa scripts have no class/object module-state; we mimic via top-level
// mutable arrays populated by observe() and read by snapshot().

let mut _OBSERVATIONS = []     // each: [step, claimed, loss, expected, rel_err]
let mut _ALERTS = []           // each: {type, step, severity, message}

// ─── primitives ───────────────────────────────────────────────

fn _abs_f(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _rel_err(loss: float, expected: float) -> float {
    // Symmetric guard against expected=0 to avoid /0; treat zero expected as 1.0 reference.
    let denom = if _abs_f(expected) < 0.000000001 { 1.0 } else { _abs_f(expected) }
    return _abs_f(loss - expected) / denom
}

fn _severity_label(rel_err: float) -> string {
    // tiered for downstream alerting fanout
    if rel_err >= 0.20 { return "critical" }
    if rel_err >= 0.10 { return "high" }
    if rel_err >= 0.05 { return "medium" }
    return "low"
}

// ─── public API: observe / snapshot ───────────────────────────
// fn observe(step: int, claimed_bit: bool, loss: float, expected_loss: float) -> map
//   returns the alert map if one fired, else {"type":"NONE","step":step,...}.
fn observe(step: int, claimed_bit: bool, loss: float, expected_loss: float) -> map {
    let re = _rel_err(loss, expected_loss)
    _OBSERVATIONS.push([step, claimed_bit, loss, expected_loss, re])

    let mut out = {}
    out["type"] = "NONE"
    out["step"] = step
    out["severity"] = "none"
    out["message"] = ""
    out["rel_err"] = re

    // F-AI2-A: claimed PASS but ≥5% divergence
    if claimed_bit && re >= 0.05 {
        let sev = _severity_label(re)
        let msg = "F-AI2-A: claimed PASS but rel_err=" + to_string(re) + " ≥ 0.05 at step=" + to_string(step)
        let mut alert = {}
        alert["type"] = "F-AI2-A"
        alert["step"] = step
        alert["severity"] = sev
        alert["message"] = msg
        alert["rel_err"] = re
        _ALERTS.push(alert)
        return alert
    }
    // F-AI2-B: claimed FAIL but ≤1% divergence
    if !claimed_bit && re <= 0.01 {
        let sev = "medium"
        let msg = "F-AI2-B: claimed FAIL but rel_err=" + to_string(re) + " ≤ 0.01 at step=" + to_string(step)
        let mut alert = {}
        alert["type"] = "F-AI2-B"
        alert["step"] = step
        alert["severity"] = sev
        alert["message"] = msg
        alert["rel_err"] = re
        _ALERTS.push(alert)
        return alert
    }
    return out
}

// fn snapshot() -> map  — aggregate observation history
fn snapshot() -> map {
    let mut s = {}
    s["total_observations"] = len(_OBSERVATIONS)
    s["total_alerts"] = len(_ALERTS)
    let mut a_count = 0
    let mut b_count = 0
    let mut max_re = 0.0
    let mut max_re_step = -1
    let mut i = 0
    while i < len(_ALERTS) {
        let al = _ALERTS[i]
        if al["type"] == "F-AI2-A" { a_count = a_count + 1 }
        if al["type"] == "F-AI2-B" { b_count = b_count + 1 }
        let re = al["rel_err"]
        if re > max_re { max_re = re; max_re_step = al["step"] }
        i = i + 1
    }
    s["F_AI2_A_count"] = a_count
    s["F_AI2_B_count"] = b_count
    s["max_rel_err"] = max_re
    s["max_rel_err_step"] = max_re_step
    s["alerts"] = _ALERTS
    let verdict = if (a_count + b_count) == 0 { "honest" } else { "violation" }
    s["verdict"] = verdict
    return s
}

fn reset_state() {
    _OBSERVATIONS = []
    _ALERTS = []
}

// ─── --demo ───────────────────────────────────────────────────
fn _demo() {
    println("=== honesty_monitor --demo ===")
    reset_state()
    // synthetic 5-step trace mixing all alert classes
    let r1 = observe(1, true, 1.00, 1.00)         // honest pass
    println("step1 alert=" + r1["type"])
    let r2 = observe(2, true, 1.10, 1.00)         // F-AI2-A: claimed PASS, 10% diverged
    println("step2 alert=" + r2["type"] + " sev=" + r2["severity"])
    let r3 = observe(3, false, 1.005, 1.00)       // F-AI2-B: claimed FAIL but only 0.5% off
    println("step3 alert=" + r3["type"] + " sev=" + r3["severity"])
    let r4 = observe(4, true, 1.02, 1.00)         // claimed PASS, 2% off — within 5% → no alert
    println("step4 alert=" + r4["type"])
    let r5 = observe(5, false, 1.50, 1.00)        // claimed FAIL, 50% off — honest fail
    println("step5 alert=" + r5["type"])
    let snap = snapshot()
    println("snapshot total_obs=" + to_string(snap["total_observations"]))
    println("snapshot total_alerts=" + to_string(snap["total_alerts"]))
    println("snapshot F-AI2-A=" + to_string(snap["F_AI2_A_count"]))
    println("snapshot F-AI2-B=" + to_string(snap["F_AI2_B_count"]))
    println("snapshot verdict=" + snap["verdict"])
}

// ─── --self-test ──────────────────────────────────────────────
fn _self_test() {
    println("=== honesty_monitor --self-test ===")
    reset_state()
    // 5-step deterministic trace with deliberate F-AI2-A trigger.
    // Boundary brackets: step 4 = 4.99% → must NOT alert; step 5 = 5.01% → must alert.
    // Use precise decimal values to avoid float-epsilon issues at exact 5%.
    observe(1, true, 1.000, 1.000)               // honest pass
    observe(2, false, 2.000, 1.000)              // honest fail (100% off)
    observe(3, true, 1.10,  1.00)                // F-AI2-A trigger (10% off)
    observe(4, true, 1.0499, 1.00)               // 4.99% below 5% → NO alert
    observe(5, true, 1.0501, 1.00)               // 5.01% ≥ 5%   → alert

    let snap = snapshot()
    let total_obs = snap["total_observations"]
    let total_al = snap["total_alerts"]
    let a_count = snap["F_AI2_A_count"]

    let ok_obs = (total_obs == 5)
    // Expected alerts: step 3 (10%), step 5 (5.01%) = 2 F-AI2-A alerts; step 4 must NOT alert.
    let ok_alerts = (total_al == 2)
    let ok_a = (a_count == 2)
    let ok_verdict = (snap["verdict"] == "violation")

    println("  total_observations=" + to_string(total_obs) + " expect=5 → " + (if ok_obs { "PASS" } else { "FAIL" }))
    println("  total_alerts=" + to_string(total_al) + " expect=2 (steps 3,5) → " + (if ok_alerts { "PASS" } else { "FAIL" }))
    println("  F-AI2-A count=" + to_string(a_count) + " expect=2 → " + (if ok_a { "PASS" } else { "FAIL" }))
    println("  verdict=" + snap["verdict"] + " expect=violation → " + (if ok_verdict { "PASS" } else { "FAIL" }))

    // explicit boundary-bracket assertions
    let alerts = snap["alerts"]
    let mut step4_alerted = false
    let mut step5_alerted = false
    let mut i = 0
    while i < len(alerts) {
        let al = alerts[i]
        if al["step"] == 4 { step4_alerted = true }
        if al["step"] == 5 { step5_alerted = true }
        i = i + 1
    }
    let ok_bound = (!step4_alerted && step5_alerted)
    println("  bracket 4.99% (step 4) silent → " + (if !step4_alerted { "PASS" } else { "FAIL" }))
    println("  bracket 5.01% (step 5) alerts → " + (if step5_alerted { "PASS" } else { "FAIL" }))

    // F-AI2-B isolated check
    reset_state()
    observe(10, false, 1.005, 1.000)             // 0.5% off, claimed fail → F-AI2-B
    let snap2 = snapshot()
    let ok_b = (snap2["F_AI2_B_count"] == 1)
    println("  F-AI2-B fires for claimed-FAIL within 1% → " + (if ok_b { "PASS" } else { "FAIL" }))

    if ok_obs && ok_alerts && ok_a && ok_verdict && ok_bound && ok_b {
        println("__HONESTY_MONITOR__ PASS alerts=" + to_string(total_al) + " steps=" + to_string(total_obs))
        exit(0)
    }
    println("__HONESTY_MONITOR__ FAIL alerts=" + to_string(total_al) + " steps=" + to_string(total_obs))
    exit(2)
}

fn main() -> void {
    let raw = args()
    let mut cli = []
    let mut a = 2
    while a < len(raw) { cli.push(raw[a]); a = a + 1 }

    let mut self_test = false
    let mut demo = false

    let mut i = 0
    while i < len(cli) {
        let arg = cli[i]
        if arg == "--self-test" || arg == "--selftest" { self_test = true }
        else if arg == "--demo" { demo = true }
        else if arg == "--help" || arg == "-h" {
            println("usage: hexa run modules/honesty_monitor/honesty_monitor.hexa [--demo] [--self-test]")
            exit(0)
        } else {
            eprintln("honesty_monitor: unknown arg `" + arg + "`")
            exit(1)
        }
        i = i + 1
    }

    if self_test { _self_test() }
    if demo {
        _demo()
        exit(0)
    }
    // default: print API summary
    println("honesty_monitor: API module — call observe(step, claimed_bit, loss, expected_loss) and snapshot() from your driver.")
    println("Try: --demo or --self-test")
    exit(0)
}
