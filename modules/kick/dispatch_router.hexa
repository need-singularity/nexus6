#!hexa strict
// nexus/modules/kick/dispatch_router.hexa — pure no-spawn router (T0 selftest hook)
//
// @tool(slug="kick_dispatch_router", desc="no-spawn kick backend; produces synthetic witness path so CI smoke can exercise the router/registry without a real subagent.")
// @usage(hexa run nexus/modules/kick/dispatch_router.hexa --selftest)
// @sentinel(__KICK_DISPATCH_ROUTER__ <PASS|FAIL>)
// @resolver-bypass(reason="pure local — no spawn, no host claude, no network.")
//
// raw#9 hexa-only strict. raw#10:
//   (1) Synthetic witness file is NOT actually written; only the path is returned.
//       Selftest checks shape, not file existence.
//   (2) tier1_count = 0 + falsifier_pass = 0 always; no candidates produced.

struct KickRequest {
    topic:        str,
    backend:      str,
    stratum:      str,
    axes:         [str],
    noise_modes:  [str],
    parent_sid:   str,
    dry_run:      int
}

struct KickSourceMeta {
    name:           str,
    tier:           int,
    cost_usd:       int,
    lead_days:      int,
    is_local:       int,
    is_canonical:   int,
    status:         str,
    vendor:         str
}

struct KickResult {
    ok:           int,
    witness_path: str,
    sentinel:     str,
    tier1_count:  int,
    falsifier_pass: int,
    message:      str
}

fn kick_meta_make(
    name: str, tier: int, cost_usd: int, lead_days: int,
    is_local: int, is_canonical: int, status: str, vendor: str
) -> KickSourceMeta {
    return KickSourceMeta {
        name: name, tier: tier, cost_usd: cost_usd, lead_days: lead_days,
        is_local: is_local, is_canonical: is_canonical, status: status, vendor: vendor
    }
}

fn kick_result_ok(witness_path: str, sentinel: str, t1: int, fp: int, msg: str) -> KickResult {
    return KickResult { ok: 1, witness_path: witness_path, sentinel: sentinel, tier1_count: t1, falsifier_pass: fp, message: msg }
}

fn kick_source_meta_dispatch_router() -> KickSourceMeta {
    return kick_meta_make("dispatch_router", 0, 0, 0, 1, 0, "IMPLEMENTED", "selftest_no_spawn")
}

fn kick_source_dispatch_dispatch_router(req: KickRequest) -> KickResult {
    let witness = "/tmp/nexus_kick_dispatch_router_" + req.topic + ".json"
    let sent = "__KICK_RESULT__ DRY witness=" + witness + " tier1=0 falsifier_pass=0"
    return kick_result_ok(witness, sent, 0, 0, "dispatch_router: no-spawn (synthetic witness path)")
}

fn _selftest() -> int {
    let m = kick_source_meta_dispatch_router()
    if m.name != "dispatch_router" { return 0 }
    if m.tier != 0 { return 0 }
    if m.is_local != 1 { return 0 }
    let req = KickRequest { topic: "smoke", backend: "dispatch_router", stratum: "", axes: [], noise_modes: [], parent_sid: "", dry_run: 1 }
    let r = kick_source_dispatch_dispatch_router(req)
    if r.ok != 1 { return 0 }
    if len(r.witness_path) < 1 { return 0 }
    return 1
}

fn main() {
    println("[kick/dispatch_router] no-spawn selftest hook")
    if _selftest() == 1 {
        println("[kick/dispatch_router] SELFTEST PASS")
        println("__KICK_DISPATCH_ROUTER__ PASS")
    } else {
        println("[kick/dispatch_router] SELFTEST FAIL")
        println("__KICK_DISPATCH_ROUTER__ FAIL")
    }
}
