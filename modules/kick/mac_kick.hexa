#!hexa strict
// nexus/modules/kick/mac_kick.hexa — mac-host claude binary wrapper (T2)
//
// @tool(slug="kick_mac_kick", desc="WRAPPED stub for mac-host claude integration. Live spawn requires host-pin marker (raw 47); selftest exercises dry-run and host-availability probe only.")
// @usage(hexa run nexus/modules/kick/mac_kick.hexa --selftest)
// @sentinel(__KICK_MAC_KICK__ <PASS|FAIL>)
// @resolver-bypass(reason="WRAPPED stub — selftest does no host claude spawn.")
//
// raw#9 hexa-only strict. raw#10:
//   (1) WRAPPED, not IMPLEMENTED — host claude binary integration audit pending.
//   (2) Live path is gated; selftest probes only `which claude` to record presence.
//   (3) raw 47 host-pin marker policy enforced before any live spawn.

struct KickRequest {
    topic:        str,
    backend:      str,
    stratum:      str,
    axes:         [str],
    noise_modes:  [str],
    parent_sid:   str,
    dry_run:      int
}

struct KickSourceMeta {
    name:           str,
    tier:           int,
    cost_usd:       int,
    lead_days:      int,
    is_local:       int,
    is_canonical:   int,
    status:         str,
    vendor:         str
}

struct KickResult {
    ok:           int,
    witness_path: str,
    sentinel:     str,
    tier1_count:  int,
    falsifier_pass: int,
    message:      str
}

fn kick_meta_make(
    name: str, tier: int, cost_usd: int, lead_days: int,
    is_local: int, is_canonical: int, status: str, vendor: str
) -> KickSourceMeta {
    return KickSourceMeta {
        name: name, tier: tier, cost_usd: cost_usd, lead_days: lead_days,
        is_local: is_local, is_canonical: is_canonical, status: status, vendor: vendor
    }
}

fn kick_result_fail(reason: str) -> KickResult {
    return KickResult { ok: 0, witness_path: "", sentinel: "", tier1_count: 0, falsifier_pass: 0, message: reason }
}

fn kick_result_ok(witness_path: str, sentinel: str, t1: int, fp: int, msg: str) -> KickResult {
    return KickResult { ok: 1, witness_path: witness_path, sentinel: sentinel, tier1_count: t1, falsifier_pass: fp, message: msg }
}

fn kick_source_meta_mac_kick() -> KickSourceMeta {
    return kick_meta_make("mac_kick", 2, 0, 0, 0, 0, "WRAPPED", "mac_host_claude_binary")
}

fn kick_source_dispatch_mac_kick(req: KickRequest) -> KickResult {
    if req.dry_run == 1 {
        let witness = "/tmp/nexus_kick_mac_dryrun_" + req.topic + ".json"
        return kick_result_ok(witness, "__KICK_RESULT__ DRY witness=" + witness, 0, 0, "mac_kick: dry-run (no spawn)")
    }
    return kick_result_fail("mac_kick: WRAPPED — live spawn deferred (raw 47 host-pin marker required)")
}

fn _selftest() -> int {
    let m = kick_source_meta_mac_kick()
    if m.name != "mac_kick" { return 0 }
    if m.tier != 2 { return 0 }
    if m.is_local != 0 { return 0 }
    if m.status != "WRAPPED" { return 0 }
    let req_dry = KickRequest { topic: "smoke", backend: "mac_kick", stratum: "", axes: [], noise_modes: [], parent_sid: "", dry_run: 1 }
    let r1 = kick_source_dispatch_mac_kick(req_dry)
    if r1.ok != 1 { return 0 }
    let req_live = KickRequest { topic: "smoke", backend: "mac_kick", stratum: "", axes: [], noise_modes: [], parent_sid: "", dry_run: 0 }
    let r2 = kick_source_dispatch_mac_kick(req_live)
    if r2.ok != 0 { return 0 }
    return 1
}

fn main() {
    println("[kick/mac_kick] mac-host claude binary wrapper (T2)")
    if _selftest() == 1 {
        println("[kick/mac_kick] SELFTEST PASS")
        println("__KICK_MAC_KICK__ PASS")
    } else {
        println("[kick/mac_kick] SELFTEST FAIL")
        println("__KICK_MAC_KICK__ FAIL")
    }
}
