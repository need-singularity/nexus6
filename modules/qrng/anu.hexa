#!hexa strict
// nexus/modules/qrng/anu.hexa — ANU public quantum API (T1, IMPLEMENTED)
//
// @tool(slug="qrng_anu", desc="qrng.anu.edu.au public REST quantum byte stream. Free, no auth, ~1 req/min rate-limit. Selftest uses NEXUS_QRNG_MOCK=1 fixture.")
// @usage(hexa run nexus/modules/qrng/anu.hexa --selftest)
// @sentinel(__QRNG_ANU__ <PASS|FAIL>)
// @resolver-bypass(reason="selftest gated to mock fixture; live path is opt-in via NEXUS_QRNG_LIVE=1.")
//
// raw#10:
//   (1) Live path requires network + ~1 req/min pacing for chunks > 1024 bytes.
//   (2) ANIMA_QRNG_MOCK=1 OR NEXUS_QRNG_MOCK=1 → deterministic LCG fixture (CI).
//   (3) `anu` parser is best-effort; ANU schema change → parser update needed.

struct QrngBytes {
    ok:           int,
    n_bytes:      int,
    bytes_:       [int],
    sha256_hex:   str,
    nist_pass:    int,
    message:      str
}

struct QrngSourceMeta {
    name:           str,
    tier:           int,
    throughput_bps: int,
    cost_usd:       int,
    lead_days:      int,
    is_quantum:     int,
    is_local:       int,
    is_free:        int,
    status:         str,
    vendor:         str
}

fn qrng_meta_make(
    name: str, tier: int, throughput_bps: int, cost_usd: int,
    lead_days: int, is_quantum: int, is_local: int, is_free: int,
    status: str, vendor: str
) -> QrngSourceMeta {
    return QrngSourceMeta {
        name: name, tier: tier, throughput_bps: throughput_bps,
        cost_usd: cost_usd, lead_days: lead_days,
        is_quantum: is_quantum, is_local: is_local, is_free: is_free,
        status: status, vendor: vendor
    }
}

fn qrng_bytes_fail(reason: str) -> QrngBytes {
    return QrngBytes { ok: 0, n_bytes: 0, bytes_: [], sha256_hex: "", nist_pass: 0, message: reason }
}

fn qrng_bytes_ok(bytes_: [int], sha256_hex: str, msg: str) -> QrngBytes {
    return QrngBytes { ok: 1, n_bytes: len(bytes_), bytes_: bytes_, sha256_hex: sha256_hex, nist_pass: 0, message: msg }
}

fn qrng_source_meta_anu() -> QrngSourceMeta {
    return qrng_meta_make("anu", 1, 1000, 0, 0, 1, 0, 1, "IMPLEMENTED", "qrng.anu.edu.au")
}

fn _anu_parse(body: str) -> [int] {
    if body.contains("\"success\":true") == false { return [] }
    if body.contains("\"data\":[") == false { return [] }
    let after = body.split("\"data\":[")
    if len(after) < 2 { return [] }
    let arr_parts = after[1].split("]")
    if len(arr_parts) < 1 { return [] }
    let toks = arr_parts[0].split(",")
    let mut out = []
    let mut i = 0
    while i < len(toks) {
        let t = toks[i].trim()
        if len(t) > 0 {
            let v = to_int(t)
            if v >= 0 { if v <= 255 { out = out.push(v) } }
        }
        i = i + 1
    }
    return out
}

fn _mock_fixture(n_bytes: int, seed: int) -> QrngBytes {
    let mut s = if seed > 0 { seed } else { 12345 }
    let mut bytes_ = []
    let mut i = 0
    while i < n_bytes {
        s = (1664525 * s + 1013904223) % 4294967296
        bytes_ = bytes_.push(s % 256)
        i = i + 1
    }
    return qrng_bytes_ok(bytes_, "", "anu: mock fixture (NEXUS_QRNG_MOCK=1)")
}

fn qrng_source_collect_anu(n_bytes: int, seed: int) -> QrngBytes {
    if n_bytes < 1 { return qrng_bytes_fail("anu: n_bytes must be >= 1") }
    let mock_a = exec("printenv ANIMA_QRNG_MOCK 2>/dev/null || true").trim()
    let mock_n = exec("printenv NEXUS_QRNG_MOCK 2>/dev/null || true").trim()
    if mock_a == "1" { return _mock_fixture(n_bytes, seed) }
    if mock_n == "1" { return _mock_fixture(n_bytes, seed) }
    let live = exec("printenv NEXUS_QRNG_LIVE 2>/dev/null || true").trim()
    if live != "1" {
        return qrng_bytes_fail("anu: live path gated — set NEXUS_QRNG_LIVE=1 (or NEXUS_QRNG_MOCK=1 for CI)")
    }
    if n_bytes > 1024 {
        return qrng_bytes_fail("anu: chunk > 1024 bytes requires pacing wrapper (use route_collect for chained chunks)")
    }
    let url = "https://qrng.anu.edu.au/API/jsonI.php?length=" + str(n_bytes) + "&type=uint8"
    let cmd = "curl -sS --max-time 10 '" + url + "' 2>&1"
    let body = exec(cmd).trim()
    if len(body) < 1 { return qrng_bytes_fail("anu: empty response") }
    let bytes_ = _anu_parse(body)
    if len(bytes_) != n_bytes {
        return qrng_bytes_fail("anu: parse mismatch want=" + str(n_bytes) + " got=" + str(len(bytes_)))
    }
    return qrng_bytes_ok(bytes_, "", "anu: live (vacuum-fluctuation)")
}

fn _selftest() -> int {
    let m = qrng_source_meta_anu()
    if m.name != "anu" { return 0 }
    if m.is_quantum != 1 { return 0 }
    if m.tier != 1 { return 0 }
    // selftest uses mock to avoid network dependency
    let r = _mock_fixture(8, 42)
    if r.ok != 1 { return 0 }
    if r.n_bytes != 8 { return 0 }
    return 1
}

fn main() {
    println("[qrng/anu] ANU public quantum REST (T1)")
    if _selftest() == 1 {
        println("[qrng/anu] SELFTEST PASS")
        println("__QRNG_ANU__ PASS")
    } else {
        println("[qrng/anu] SELFTEST FAIL")
        println("__QRNG_ANU__ FAIL")
    }
}
