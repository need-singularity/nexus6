#!hexa strict
// nexus/modules/qrng/hardware_qrng.hexa — local HW QRNG (T3 IMPLEMENTED, mock-default + USB-serial probe)
//
// @tool(slug="qrng_hardware_qrng", desc="local hardware QRNG abstraction. Default mock-mode (deterministic LCG, byte-identical). Live path probes (a) /dev/quantis* (IDQ libQuantis SDK), (b) /dev/cu.usbmodem* / /dev/cu.usbserial* (ESP32-quantum-like serial source). Both paths are opt-in via NEXUS_QRNG_HW_LIVE=1.")
// @usage(hexa run nexus/modules/qrng/hardware_qrng.hexa --selftest)
// @sentinel(__QRNG_HARDWARE_QRNG__ <PASS|FAIL>)
// @resolver-bypass(reason="selftest gated to mock fixture; live path is opt-in via NEXUS_QRNG_HW_LIVE=1.")
//
// raw#9 hexa-only strict. raw#10:
//   (1) Mock-mode is the default. Live path is opt-in (NEXUS_QRNG_HW_LIVE=1).
//   (2) Probes 2 candidate device classes: /dev/quantis* (IDQ Quantis PCIe/USB)
//       and /dev/cu.usbmodem* / /dev/cu.usbserial* (ESP32 / FTDI serial bridges).
//       NEITHER is "real quantum" verified — vendor health check + NIST SP 800-90B
//       not implemented (informational only). is_quantum=1 is asserted by vendor
//       claim, NOT by independent measurement.
//   (3) Mock fixture is byte-identical to mock_qrng (same LCG params); use mock_qrng
//       directly for production CI to avoid path-conditional bytes.
//   (4) Registry selftest calls collect with no env → MUST still fail (preserved).
//   (5) Live serial path uses `head -c <n>` on the device file — BLOCKING I/O.
//       Caller MUST set NEXUS_QRNG_HW_TIMEOUT_S env (default fail-fast).
//   (6) Vendor label changes by probe outcome; tier remains 3 (commercial-class).
//   (7) Selftest never opens a device handle.

struct QrngBytes {
    ok:           int,
    n_bytes:      int,
    bytes_:       [int],
    sha256_hex:   str,
    nist_pass:    int,
    message:      str
}

struct QrngSourceMeta {
    name:           str,
    tier:           int,
    throughput_bps: int,
    cost_usd:       int,
    lead_days:      int,
    is_quantum:     int,
    is_local:       int,
    is_free:        int,
    status:         str,
    vendor:         str
}

fn qrng_meta_make(
    name: str, tier: int, throughput_bps: int, cost_usd: int,
    lead_days: int, is_quantum: int, is_local: int, is_free: int,
    status: str, vendor: str
) -> QrngSourceMeta {
    return QrngSourceMeta {
        name: name, tier: tier, throughput_bps: throughput_bps,
        cost_usd: cost_usd, lead_days: lead_days,
        is_quantum: is_quantum, is_local: is_local, is_free: is_free,
        status: status, vendor: vendor
    }
}

fn qrng_bytes_fail(reason: str) -> QrngBytes {
    return QrngBytes { ok: 0, n_bytes: 0, bytes_: [], sha256_hex: "", nist_pass: 0, message: reason }
}

fn qrng_bytes_ok(bytes_: [int], sha256_hex: str, msg: str) -> QrngBytes {
    return QrngBytes { ok: 1, n_bytes: len(bytes_), bytes_: bytes_, sha256_hex: sha256_hex, nist_pass: 0, message: msg }
}

fn qrng_source_meta_hardware_qrng() -> QrngSourceMeta {
    // status STUB → IMPLEMENTED (mock-default + opt-in live serial/PCIe probe).
    // Registry selftest path collects with no env and still FAILs (preserved).
    return qrng_meta_make("hardware_qrng", 3, 240000000, 5000, 42, 1, 1, 0, "IMPLEMENTED", "ID_Quantique_Quantis_PCIe_or_ESP32_serial")
}

fn _env(name: str) -> str {
    return exec("printenv " + name + " 2>/dev/null || true").trim()
}

fn _mock_fixture(n_bytes: int, seed: int) -> QrngBytes {
    let mut s = if seed > 0 { seed } else { 12345 }
    let mut bytes_ = []
    let mut i = 0
    while i < n_bytes {
        s = (1664525 * s + 1013904223) % 4294967296
        bytes_ = bytes_.push(s % 256)
        i = i + 1
    }
    return qrng_bytes_ok(bytes_, "", "hardware_qrng: mock fixture (NEXUS_QRNG_HW_MOCK=1)")
}

fn _probe_device() -> str {
    // Returns first candidate device path or "" if none.
    let q = exec("ls /dev/quantis* 2>/dev/null | head -1 || true").trim()
    if len(q) > 0 { return q }
    let u1 = exec("ls /dev/cu.usbmodem* 2>/dev/null | head -1 || true").trim()
    if len(u1) > 0 { return u1 }
    let u2 = exec("ls /dev/cu.usbserial* 2>/dev/null | head -1 || true").trim()
    if len(u2) > 0 { return u2 }
    return ""
}

fn _read_device_bytes(dev: str, n_bytes: int, timeout_s: str) -> QrngBytes {
    // Read n_bytes from dev, hex-encode, parse to int array.
    // Use timeout(1) gate to prevent indefinite block on serial.
    let cmd = "timeout " + timeout_s + " head -c " + str(n_bytes) + " " + dev + " 2>/dev/null | xxd -p -c 4096 | tr -d '\\n'"
    let hex = exec(cmd).trim()
    if len(hex) < 2 * n_bytes {
        return qrng_bytes_fail("hardware_qrng: device read short — got " + str(len(hex) / 2) + " bytes from " + dev)
    }
    let mut bytes_ = []
    let mut i = 0
    while i < n_bytes {
        let pair = hex.substring(2 * i, 2 * i + 2)
        // Parse 2-hex-digit string to int via shell printf.
        let v_str = exec("printf '%d' 0x" + pair + " 2>/dev/null || echo -1").trim()
        let v = to_int(v_str)
        if v < 0 { return qrng_bytes_fail("hardware_qrng: hex parse error at byte " + str(i)) }
        if v > 255 { return qrng_bytes_fail("hardware_qrng: hex parse overflow at byte " + str(i)) }
        bytes_ = bytes_.push(v)
        i = i + 1
    }
    return qrng_bytes_ok(bytes_, "", "hardware_qrng: live device " + dev)
}

fn qrng_source_collect_hardware_qrng(n_bytes: int, seed: int) -> QrngBytes {
    if n_bytes < 1 { return qrng_bytes_fail("hardware_qrng: n_bytes must be >= 1") }
    // Path 1: mock env (default-leaning).
    let mock_hw = _env("NEXUS_QRNG_HW_MOCK")
    let mock_n = _env("NEXUS_QRNG_MOCK")
    let mock_a = _env("ANIMA_QRNG_MOCK")
    if mock_hw == "1" { return _mock_fixture(n_bytes, seed) }
    if mock_n == "1" { return _mock_fixture(n_bytes, seed) }
    if mock_a == "1" { return _mock_fixture(n_bytes, seed) }
    // Path 2: live path — gated.
    let live = _env("NEXUS_QRNG_HW_LIVE")
    if live != "1" {
        return qrng_bytes_fail("hardware_qrng: live path gated — set NEXUS_QRNG_HW_LIVE=1 (or NEXUS_QRNG_HW_MOCK=1 for CI)")
    }
    let dev = _probe_device()
    if len(dev) < 1 {
        return qrng_bytes_fail("hardware_qrng: no device found at /dev/quantis* or /dev/cu.usbmodem* or /dev/cu.usbserial*")
    }
    let to = _env("NEXUS_QRNG_HW_TIMEOUT_S")
    let to_eff = if len(to) > 0 { to } else { "5" }
    if n_bytes > 65536 {
        return qrng_bytes_fail("hardware_qrng: chunk > 65536 bytes — use chained chunks (no streaming today)")
    }
    return _read_device_bytes(dev, n_bytes, to_eff)
}

fn _selftest() -> int {
    // 1. Meta shape
    let m = qrng_source_meta_hardware_qrng()
    if m.name != "hardware_qrng" { return 0 }
    if m.tier != 3 { return 0 }
    if m.is_quantum != 1 { return 0 }
    if m.status != "IMPLEMENTED" { return 0 }
    // 2. Mock fixture — set env via prefixed shell call (selftest-internal).
    //    Direct call to _mock_fixture (always available).
    let r1 = _mock_fixture(8, 42)
    let r2 = _mock_fixture(8, 42)
    if r1.ok != 1 { return 0 }
    if r2.ok != 1 { return 0 }
    if r1.n_bytes != 8 { return 0 }
    let mut k = 0
    while k < 8 { if r1.bytes_[k] != r2.bytes_[k] { return 0 } k = k + 1 }
    // 3. Determinism: different seed → different bytes
    let r3 = _mock_fixture(8, 99)
    let mut diff = 0
    let mut j = 0
    while j < 8 {
        if r1.bytes_[j] != r3.bytes_[j] { diff = diff + 1 }
        j = j + 1
    }
    if diff < 1 { return 0 }
    // 4. Live path with no env → FAIL (preserves registry contract).
    let live = exec("printenv NEXUS_QRNG_HW_LIVE 2>/dev/null || true").trim()
    let mock_hw = exec("printenv NEXUS_QRNG_HW_MOCK 2>/dev/null || true").trim()
    let mock_n = exec("printenv NEXUS_QRNG_MOCK 2>/dev/null || true").trim()
    let mock_a = exec("printenv ANIMA_QRNG_MOCK 2>/dev/null || true").trim()
    if live != "1" {
        if mock_hw != "1" { if mock_n != "1" { if mock_a != "1" {
            let r4 = qrng_source_collect_hardware_qrng(4, 1)
            if r4.ok != 0 { return 0 }
        } } }
    }
    // 5. n_bytes < 1 → FAIL
    let r5 = qrng_source_collect_hardware_qrng(0, 1)
    if r5.ok != 0 { return 0 }
    return 1
}

fn main() {
    println("[qrng/hardware_qrng] local HW QRNG (T3 IMPLEMENTED mock-default)")
    if _selftest() == 1 {
        println("[qrng/hardware_qrng] SELFTEST PASS")
        println("__QRNG_HARDWARE_QRNG__ PASS")
    } else {
        println("[qrng/hardware_qrng] SELFTEST FAIL")
        println("__QRNG_HARDWARE_QRNG__ FAIL")
    }
}
