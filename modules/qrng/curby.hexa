#!hexa strict
// nexus/modules/qrng/curby.hexa — CURBy (NIST + CU Boulder) Bell-test QRNG (T1, IMPLEMENTED)
//
// @tool(slug="qrng_curby", desc="CURBy public REST quantum byte stream (NIST + University of Colorado Boulder, Bell-test entanglement-verified, Twine-blockchain anchored). Free, no auth, 512 bits / 60s pulse cadence. Selftest uses NEXUS_QRNG_MOCK=1 fixture or live via NEXUS_QRNG_LIVE=1.")
// @usage(hexa run nexus/modules/qrng/curby.hexa --selftest)
// @sentinel(__QRNG_CURBY__ <PASS|FAIL>)
// @resolver-bypass(reason="selftest gated to mock fixture; live path is opt-in via NEXUS_QRNG_LIVE=1.")
//
// raw#9 hexa-only strict. raw#10 (honest C3):
//   (1) is_quantum=1 — Bell-inequality violation is independently witnessed by
//       NIST/CU Boulder physics protocol (loophole-free Bell test). Treat as
//       vendor-asserted quantum until we run our own Bell witness end-to-end.
//   (2) Throughput 8.5 bps sustained (512 bits / 60 s). Cap at 64 bytes per
//       pulse; multi-pulse aggregation requires waiting 60s per chunk.
//   (3) Twine anchor field MUST be non-empty on live pulses; F_CURBY_03 enforces.
//   (4) Selftest uses fixture JSON (mock); set NEXUS_QRNG_LIVE=1 for real call.
//   (5) Network failure / server down → returns ok=0 with reason; router falls
//       back to next source in chain.
//
// FALSIFIERS (frozen):
//   F_CURBY_01: mock fixture deterministic (same fixture JSON → same pulse_id + hex)
//   F_CURBY_02: live pulse 64 bytes valid hex (skipped if no network)
//   F_CURBY_03: twine_anchor non-empty on ok=1 pulse

struct QrngBytes {
    ok:           int,
    n_bytes:      int,
    bytes_:       [int],
    sha256_hex:   str,
    nist_pass:    int,
    message:      str
}

struct QrngSourceMeta {
    name:           str,
    tier:           int,
    throughput_bps: int,
    cost_usd:       int,
    lead_days:      int,
    is_quantum:     int,
    is_local:       int,
    is_free:        int,
    status:         str,
    vendor:         str
}

struct CurbyPulse {
    pulse_id:         int,
    output_value_hex: str,
    timestamp:        str,
    twine_anchor:     str,
    ok:               int
}

fn qrng_meta_make(
    name: str, tier: int, throughput_bps: int, cost_usd: int,
    lead_days: int, is_quantum: int, is_local: int, is_free: int,
    status: str, vendor: str
) -> QrngSourceMeta {
    return QrngSourceMeta {
        name: name, tier: tier, throughput_bps: throughput_bps,
        cost_usd: cost_usd, lead_days: lead_days,
        is_quantum: is_quantum, is_local: is_local, is_free: is_free,
        status: status, vendor: vendor
    }
}

fn qrng_bytes_fail(reason: str) -> QrngBytes {
    return QrngBytes { ok: 0, n_bytes: 0, bytes_: [], sha256_hex: "", nist_pass: 0, message: reason }
}

fn qrng_bytes_ok(bytes_: [int], sha256_hex: str, msg: str) -> QrngBytes {
    return QrngBytes { ok: 1, n_bytes: len(bytes_), bytes_: bytes_, sha256_hex: sha256_hex, nist_pass: 0, message: msg }
}

// ── CURBy constants ─────────────────────────────────────────

let CURBY_NAME       = "curby"
let CURBY_TIER       = 1
let CURBY_BPS        = 8                 // 512 bits / 60s ≈ 8.5 bps sustained
let CURBY_VENDOR     = "nist+cu_boulder"
let CURBY_ENDPOINT   = "https://random.colorado.edu/api/randomness/latest"
let CURBY_TIMEOUT_S  = 10
let CURBY_BYTES_PER_PULSE = 64           // 512 bits = 64 bytes

fn qrng_source_meta_curby() -> QrngSourceMeta {
    return qrng_meta_make(
        CURBY_NAME, CURBY_TIER, CURBY_BPS,
        0,    // cost_usd (free)
        0,    // lead_days (immediate, no auth)
        1,    // is_quantum (Bell-test verified entanglement, vendor-asserted)
        0,    // is_local (network call)
        1,    // is_free
        "IMPLEMENTED",
        CURBY_VENDOR
    )
}

// ── Helper: parse CURBy JSON pulse ──────────────────────────

fn _curby_extract_field(body: str, key: str) -> str {
    let needle = "\"" + key + "\":"
    if body.contains(needle) == false { return "" }
    let after = body.split(needle)
    if len(after) < 2 { return "" }
    let rest = after[1].trim()
    if len(rest) == 0 { return "" }
    let first_ch = rest.substr(0, 1)
    if first_ch == "\"" {
        let q1 = rest.split("\"")
        if len(q1) >= 2 { return q1[1] }
        return ""
    }
    let toks = rest.split(",")
    if len(toks) < 1 { return "" }
    let head = toks[0].split("}")
    if len(head) < 1 { return "" }
    return head[0].trim()
}

fn _curby_parse_pulse(body: str) -> CurbyPulse {
    let pid_s   = _curby_extract_field(body, "pulse_id")
    let hex_s   = _curby_extract_field(body, "output_value_hex")
    let ts_s    = _curby_extract_field(body, "timestamp")
    let twine_s = _curby_extract_field(body, "twine_anchor")
    let pid = if len(pid_s) > 0 { to_int(pid_s) } else { 0 }
    let ok_flag = if len(hex_s) >= 64 { if len(twine_s) > 0 { 1 } else { 0 } } else { 0 }
    return CurbyPulse {
        pulse_id: pid, output_value_hex: hex_s, timestamp: ts_s,
        twine_anchor: twine_s, ok: ok_flag
    }
}

// ── Hex → bytes + sha256 ───────────────────────────────────

fn _curby_hex_char_val(c: str) -> int {
    if c == "0" { return 0 } if c == "1" { return 1 } if c == "2" { return 2 } if c == "3" { return 3 }
    if c == "4" { return 4 } if c == "5" { return 5 } if c == "6" { return 6 } if c == "7" { return 7 }
    if c == "8" { return 8 } if c == "9" { return 9 }
    if c == "a" { return 10 } if c == "b" { return 11 } if c == "c" { return 12 } if c == "d" { return 13 }
    if c == "e" { return 14 } if c == "f" { return 15 }
    if c == "A" { return 10 } if c == "B" { return 11 } if c == "C" { return 12 } if c == "D" { return 13 }
    if c == "E" { return 14 } if c == "F" { return 15 }
    return -1
}

fn _curby_hex_to_bytes(hex_s: str, n_max: int) -> [int] {
    let mut out = []
    let mut i = 0
    let n = len(hex_s)
    while i + 1 < n {
        if len(out) >= n_max { return out }
        let hi = _curby_hex_char_val(hex_s.substr(i, 1))
        let lo = _curby_hex_char_val(hex_s.substr(i + 1, 1))
        if hi < 0 { return out }
        if lo < 0 { return out }
        out = out.push(hi * 16 + lo)
        i = i + 2
    }
    return out
}

fn _curby_sha256_of_bytes(bytes_: [int], seed: int) -> str {
    let n = len(bytes_)
    if n == 0 { return "" }
    let tmp = "/tmp/nexus_qrng_curby_" + str(seed) + "_" + str(n) + ".bin"
    let mut hex = ""
    let mut k = 0
    while k < n {
        let b = bytes_[k]
        let hi = b / 16
        let lo = b - hi * 16
        let hi_c = if hi < 10 { str(hi) } else { if hi == 10 { "a" } else { if hi == 11 { "b" } else { if hi == 12 { "c" } else { if hi == 13 { "d" } else { if hi == 14 { "e" } else { "f" } } } } } }
        let lo_c = if lo < 10 { str(lo) } else { if lo == 10 { "a" } else { if lo == 11 { "b" } else { if lo == 12 { "c" } else { if lo == 13 { "d" } else { if lo == 14 { "e" } else { "f" } } } } } }
        hex = hex + hi_c + lo_c
        k = k + 1
    }
    let cmd = "printf '%s' '" + hex + "' | xxd -r -p > " + tmp + " 2>&1; (shasum -a 256 " + tmp + " 2>/dev/null || sha256sum " + tmp + ") | awk '{print $1}'"
    let sha = exec(cmd).trim()
    let _rc = exec("rm -f " + tmp + "; echo OK")
    return sha
}

// ── Live fetch ──────────────────────────────────────────────

fn curby_fetch_latest() -> CurbyPulse {
    let mock_n = exec("printenv NEXUS_QRNG_MOCK 2>/dev/null || true").trim()
    let mock_a = exec("printenv ANIMA_QRNG_MOCK 2>/dev/null || true").trim()
    if mock_n == "1" {
        let fx_path = "modules/qrng/fixtures/curby_pulse_sample.json"
        let body = exec("cat " + fx_path + " 2>/dev/null || echo ''")
        return _curby_parse_pulse(body)
    }
    if mock_a == "1" {
        let fx_path = "modules/qrng/fixtures/curby_pulse_sample.json"
        let body = exec("cat " + fx_path + " 2>/dev/null || echo ''")
        return _curby_parse_pulse(body)
    }
    let cmd = "curl -sS --max-time " + str(CURBY_TIMEOUT_S) + " '" + CURBY_ENDPOINT + "' 2>/dev/null"
    let body = exec(cmd)
    if len(body) < 16 {
        return CurbyPulse { pulse_id: 0, output_value_hex: "", timestamp: "", twine_anchor: "", ok: 0 }
    }
    return _curby_parse_pulse(body)
}

// ── Collect ─────────────────────────────────────────────────
//
// CURBy yields exactly 64 bytes per pulse. n_bytes > 64 requires multi-pulse
// aggregation (60s/pulse cadence — caller handles).

fn qrng_source_collect_curby(n_bytes: int, seed: int) -> QrngBytes {
    if n_bytes < 1 {
        return qrng_bytes_fail("curby: n_bytes must be >= 1")
    }
    if n_bytes > CURBY_BYTES_PER_PULSE {
        return qrng_bytes_fail("curby: n_bytes > 64 requires multi-pulse aggregation (60s/pulse cadence); use seed-anchor pattern")
    }
    let mock_n = exec("printenv NEXUS_QRNG_MOCK 2>/dev/null || true").trim()
    let mock_a = exec("printenv ANIMA_QRNG_MOCK 2>/dev/null || true").trim()
    let live = exec("printenv NEXUS_QRNG_LIVE 2>/dev/null || true").trim()
    if mock_n != "1" { if mock_a != "1" { if live != "1" {
        return qrng_bytes_fail("curby: live path gated — set NEXUS_QRNG_LIVE=1 (or NEXUS_QRNG_MOCK=1 for CI)")
    } } }
    let pulse = curby_fetch_latest()
    if pulse.ok != 1 {
        return qrng_bytes_fail("curby: fetch fail (network/parse/empty twine_anchor)")
    }
    let bytes_all = _curby_hex_to_bytes(pulse.output_value_hex, CURBY_BYTES_PER_PULSE)
    if len(bytes_all) < n_bytes {
        return qrng_bytes_fail("curby: hex decode short, got=" + str(len(bytes_all)) + " want=" + str(n_bytes))
    }
    let mut bytes_ = []
    let mut i = 0
    while i < n_bytes {
        bytes_ = bytes_.push(bytes_all[i])
        i = i + 1
    }
    let sha = _curby_sha256_of_bytes(bytes_, seed)
    return qrng_bytes_ok(bytes_, sha, "curby: ok pulse_id=" + str(pulse.pulse_id) + " twine=" + pulse.twine_anchor.substr(0, 24))
}

// ── Selftest ────────────────────────────────────────────────

fn _selftest() -> int {
    let m = qrng_source_meta_curby()
    if m.name != "curby" { return 0 }
    if m.tier != 1 { return 0 }
    if m.is_quantum != 1 { return 0 }
    if m.is_local != 0 { return 0 }
    if m.is_free != 1 { return 0 }
    if m.vendor != "nist+cu_boulder" { return 0 }
    if m.status != "IMPLEMENTED" { return 0 }
    // F_CURBY_01: parse known fixture JSON
    let fixture = "{\"pulse_id\":1234567,\"output_value_hex\":\"a1b2c3d4e5f60708091a2b3c4d5e6f70a1b2c3d4e5f60708091a2b3c4d5e6f70a1b2c3d4e5f60708091a2b3c4d5e6f70a1b2c3d4e5f60708091a2b3c4d5e6f70\",\"timestamp\":\"2026-05-03T13:00:00Z\",\"twine_anchor\":\"twine:cu_boulder:nist:bell_test:hash:0xdeadbeef\"}"
    let p = _curby_parse_pulse(fixture)
    if p.ok != 1 { return 0 }
    if p.pulse_id != 1234567 { return 0 }
    if len(p.output_value_hex) != 128 { return 0 }
    // F_CURBY_03: twine_anchor non-empty
    if len(p.twine_anchor) == 0 { return 0 }
    let bs = _curby_hex_to_bytes(p.output_value_hex, 64)
    if len(bs) != 64 { return 0 }
    if bs[0] != 161 { return 0 }   // 0xa1
    if bs[1] != 178 { return 0 }   // 0xb2
    // Failure path: empty body
    let p_bad = _curby_parse_pulse("{}")
    if p_bad.ok != 0 { return 0 }
    // sha256 round-trip
    let sha = _curby_sha256_of_bytes(bs, 1)
    if len(sha) != 64 { return 0 }
    // n_bytes < 1 → FAIL
    let r0 = qrng_source_collect_curby(0, 1)
    if r0.ok != 0 { return 0 }
    // gated path with no env → FAIL (preserves registry contract)
    let live = exec("printenv NEXUS_QRNG_LIVE 2>/dev/null || true").trim()
    let mock_n = exec("printenv NEXUS_QRNG_MOCK 2>/dev/null || true").trim()
    let mock_a = exec("printenv ANIMA_QRNG_MOCK 2>/dev/null || true").trim()
    if live != "1" { if mock_n != "1" { if mock_a != "1" {
        let r_gated = qrng_source_collect_curby(8, 1)
        if r_gated.ok != 0 { return 0 }
    } } }
    return 1
}

fn main() {
    println("[qrng/curby] CURBy (NIST + CU Boulder) Bell-test QRNG (T1)")
    println("[qrng/curby] __QRNG_CURBY_FALSIFIERS__ F_CURBY_01 F_CURBY_02 F_CURBY_03")
    if _selftest() == 1 {
        println("[qrng/curby] SELFTEST PASS")
        println("__QRNG_CURBY__ PASS")
    } else {
        println("[qrng/curby] SELFTEST FAIL")
        println("__QRNG_CURBY__ FAIL")
    }
    let live = exec("printenv NEXUS_QRNG_LIVE 2>/dev/null || true").trim()
    if live == "1" {
        println("[qrng/curby] LIVE probe (NEXUS_QRNG_LIVE=1)")
        let r = qrng_source_collect_curby(8, 1)
        if r.ok == 1 {
            println("[qrng/curby] LIVE n=" + str(r.n_bytes) + " sha=" + r.sha256_hex)
        } else {
            println("[qrng/curby] LIVE FAIL: " + r.message)
        }
    }
}
