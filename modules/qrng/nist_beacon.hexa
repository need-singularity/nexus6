#!hexa strict
// nexus/modules/qrng/nist_beacon.hexa — NIST Randomness Beacon 2.0 (T1, IMPLEMENTED)
//
// @tool(slug="qrng_nist_beacon", desc="NIST Beacon 2.0 public REST signed-pulse byte stream (US sovereign mixed-entropy beacon, ECDSA P-384 signed). Free, no auth, 512 bits / 60s pulse cadence. Selftest uses NEXUS_QRNG_MOCK=1 fixture or live via NEXUS_QRNG_LIVE=1.")
// @usage(hexa run nexus/modules/qrng/nist_beacon.hexa --selftest)
// @sentinel(__QRNG_NIST_BEACON__ <PASS|FAIL>)
// @resolver-bypass(reason="selftest gated to mock fixture; live path is opt-in via NEXUS_QRNG_LIVE=1.")
//
// raw#9 hexa-only strict. raw#10 (honest C3):
//   (1) is_quantum=0 — vendor self-classifies as MIXED entropy (HSM + multiple
//       RNGs, possibly QRNG-augmented). Do NOT advertise this as "pure quantum"
//       downstream. Use as US sovereignty mirror to ANU (AU) when geographic
//       diversity proof is required.
//   (2) ECDSA signature MUST be present on live pulses; F_NIST_03 enforces.
//   (3) Throughput 8.5 bps sustained (512 bits / 60 s). Cap at 64 bytes per
//       pulse; multi-pulse aggregation requires waiting 60s per chunk.
//   (4) Selftest mock via NEXUS_QRNG_MOCK=1; live via NEXUS_QRNG_LIVE=1.
//
// FALSIFIERS (frozen):
//   F_NIST_01: mock fixture deterministic
//   F_NIST_02: live pulse 64 bytes valid hex (skipped if no network)
//   F_NIST_03: signature non-empty on ok=1 pulse

struct QrngBytes {
    ok:           int,
    n_bytes:      int,
    bytes_:       [int],
    sha256_hex:   str,
    nist_pass:    int,
    message:      str
}

struct QrngSourceMeta {
    name:           str,
    tier:           int,
    throughput_bps: int,
    cost_usd:       int,
    lead_days:      int,
    is_quantum:     int,
    is_local:       int,
    is_free:        int,
    status:         str,
    vendor:         str
}

struct NistBeaconPulse {
    pulse_index:  int,
    time_stamp:   str,
    output_value: str,
    signature:    str,
    sig_alg:      str,
    ok:           int
}

fn qrng_meta_make(
    name: str, tier: int, throughput_bps: int, cost_usd: int,
    lead_days: int, is_quantum: int, is_local: int, is_free: int,
    status: str, vendor: str
) -> QrngSourceMeta {
    return QrngSourceMeta {
        name: name, tier: tier, throughput_bps: throughput_bps,
        cost_usd: cost_usd, lead_days: lead_days,
        is_quantum: is_quantum, is_local: is_local, is_free: is_free,
        status: status, vendor: vendor
    }
}

fn qrng_bytes_fail(reason: str) -> QrngBytes {
    return QrngBytes { ok: 0, n_bytes: 0, bytes_: [], sha256_hex: "", nist_pass: 0, message: reason }
}

fn qrng_bytes_ok(bytes_: [int], sha256_hex: str, msg: str) -> QrngBytes {
    return QrngBytes { ok: 1, n_bytes: len(bytes_), bytes_: bytes_, sha256_hex: sha256_hex, nist_pass: 0, message: msg }
}

// ── NIST Beacon constants ──────────────────────────────────

let NIST_BEACON_NAME       = "nist_beacon"
let NIST_BEACON_TIER       = 1
let NIST_BEACON_BPS        = 8                // 512 bits / 60s
let NIST_BEACON_VENDOR     = "nist"
let NIST_BEACON_LATEST_URL = "https://beacon.nist.gov/beacon/2.0/pulse/last"
let NIST_BEACON_TIME_URL   = "https://beacon.nist.gov/beacon/2.0/pulse/time/"
let NIST_BEACON_TIMEOUT_S  = 10
let NIST_BEACON_BYTES_PER_PULSE = 64          // 512-bit output

fn qrng_source_meta_nist_beacon() -> QrngSourceMeta {
    return qrng_meta_make(
        NIST_BEACON_NAME, NIST_BEACON_TIER, NIST_BEACON_BPS,
        0,    // cost_usd (free)
        0,    // lead_days (no auth)
        0,    // is_quantum=0 (mixed HSM+RNGs, vendor self-classification)
        0,    // is_local
        1,    // is_free
        "IMPLEMENTED",
        NIST_BEACON_VENDOR
    )
}

// ── JSON field extract ──────────────────────────────────────

fn _nist_extract(body: str, key: str) -> str {
    let needle = "\"" + key + "\":"
    if body.contains(needle) == false { return "" }
    let after = body.split(needle)
    if len(after) < 2 { return "" }
    let rest = after[1].trim()
    if len(rest) == 0 { return "" }
    let first_ch = rest.substr(0, 1)
    if first_ch == "\"" {
        let q1 = rest.split("\"")
        if len(q1) >= 2 { return q1[1] }
        return ""
    }
    let toks = rest.split(",")
    if len(toks) < 1 { return "" }
    let head = toks[0].split("}")
    if len(head) < 1 { return "" }
    return head[0].trim()
}

fn _nist_parse_pulse(body: str) -> NistBeaconPulse {
    let idx_s  = _nist_extract(body, "pulseIndex")
    let idx_s2 = if len(idx_s) > 0 { idx_s } else { _nist_extract(body, "pulse_index") }
    let ts_s   = _nist_extract(body, "timeStamp")
    let ts_s2  = if len(ts_s) > 0 { ts_s } else { _nist_extract(body, "time_stamp") }
    let out_s  = _nist_extract(body, "outputValue")
    let out_s2 = if len(out_s) > 0 { out_s } else { _nist_extract(body, "output_value") }
    let sig_s  = _nist_extract(body, "signatureValue")
    let sig_s2 = if len(sig_s) > 0 { sig_s } else { _nist_extract(body, "signature") }
    let alg_s  = _nist_extract(body, "sig_alg")
    let alg_s2 = if len(alg_s) > 0 { alg_s } else { "ECDSA_P384_SHA384" }
    let pid = if len(idx_s2) > 0 { to_int(idx_s2) } else { 0 }
    let ok_flag = if len(out_s2) >= 64 { if len(sig_s2) > 0 { 1 } else { 0 } } else { 0 }
    return NistBeaconPulse {
        pulse_index: pid, time_stamp: ts_s2,
        output_value: out_s2, signature: sig_s2, sig_alg: alg_s2,
        ok: ok_flag
    }
}

// ── Hex → bytes + sha256 ───────────────────────────────────

fn _nist_hex_char_val(c: str) -> int {
    if c == "0" { return 0 } if c == "1" { return 1 } if c == "2" { return 2 } if c == "3" { return 3 }
    if c == "4" { return 4 } if c == "5" { return 5 } if c == "6" { return 6 } if c == "7" { return 7 }
    if c == "8" { return 8 } if c == "9" { return 9 }
    if c == "a" { return 10 } if c == "b" { return 11 } if c == "c" { return 12 } if c == "d" { return 13 }
    if c == "e" { return 14 } if c == "f" { return 15 }
    if c == "A" { return 10 } if c == "B" { return 11 } if c == "C" { return 12 } if c == "D" { return 13 }
    if c == "E" { return 14 } if c == "F" { return 15 }
    return -1
}

fn _nist_hex_to_bytes(hex_s: str, n_max: int) -> [int] {
    let mut out = []
    let mut i = 0
    let n = len(hex_s)
    while i + 1 < n {
        if len(out) >= n_max { return out }
        let hi = _nist_hex_char_val(hex_s.substr(i, 1))
        let lo = _nist_hex_char_val(hex_s.substr(i + 1, 1))
        if hi < 0 { return out }
        if lo < 0 { return out }
        out = out.push(hi * 16 + lo)
        i = i + 2
    }
    return out
}

fn _nist_sha256_of_bytes(bytes_: [int], seed: int) -> str {
    let n = len(bytes_)
    if n == 0 { return "" }
    let tmp = "/tmp/nexus_qrng_nist_" + str(seed) + "_" + str(n) + ".bin"
    let mut hex = ""
    let mut k = 0
    while k < n {
        let b = bytes_[k]
        let hi = b / 16
        let lo = b - hi * 16
        let hi_c = if hi < 10 { str(hi) } else { if hi == 10 { "a" } else { if hi == 11 { "b" } else { if hi == 12 { "c" } else { if hi == 13 { "d" } else { if hi == 14 { "e" } else { "f" } } } } } }
        let lo_c = if lo < 10 { str(lo) } else { if lo == 10 { "a" } else { if lo == 11 { "b" } else { if lo == 12 { "c" } else { if lo == 13 { "d" } else { if lo == 14 { "e" } else { "f" } } } } } }
        hex = hex + hi_c + lo_c
        k = k + 1
    }
    let cmd = "printf '%s' '" + hex + "' | xxd -r -p > " + tmp + " 2>&1; (shasum -a 256 " + tmp + " 2>/dev/null || sha256sum " + tmp + ") | awk '{print $1}'"
    let sha = exec(cmd).trim()
    let _rc = exec("rm -f " + tmp + "; echo OK")
    return sha
}

// ── Live fetch ──────────────────────────────────────────────

fn nist_beacon_fetch_latest() -> NistBeaconPulse {
    let mock_n = exec("printenv NEXUS_QRNG_MOCK 2>/dev/null || true").trim()
    let mock_a = exec("printenv ANIMA_QRNG_MOCK 2>/dev/null || true").trim()
    if mock_n == "1" {
        let fx_path = "modules/qrng/fixtures/nist_beacon_pulse_sample.json"
        let body = exec("cat " + fx_path + " 2>/dev/null || echo ''")
        return _nist_parse_pulse(body)
    }
    if mock_a == "1" {
        let fx_path = "modules/qrng/fixtures/nist_beacon_pulse_sample.json"
        let body = exec("cat " + fx_path + " 2>/dev/null || echo ''")
        return _nist_parse_pulse(body)
    }
    let cmd = "curl -sS --max-time " + str(NIST_BEACON_TIMEOUT_S) + " '" + NIST_BEACON_LATEST_URL + "' 2>/dev/null"
    let body = exec(cmd)
    if len(body) < 16 {
        return NistBeaconPulse { pulse_index: 0, time_stamp: "", output_value: "", signature: "", sig_alg: "", ok: 0 }
    }
    return _nist_parse_pulse(body)
}

// ── Collect ─────────────────────────────────────────────────

fn qrng_source_collect_nist_beacon(n_bytes: int, seed: int) -> QrngBytes {
    if n_bytes < 1 {
        return qrng_bytes_fail("nist_beacon: n_bytes must be >= 1")
    }
    if n_bytes > NIST_BEACON_BYTES_PER_PULSE {
        return qrng_bytes_fail("nist_beacon: n_bytes > 64 requires multi-pulse aggregation (60s/pulse cadence)")
    }
    let mock_n = exec("printenv NEXUS_QRNG_MOCK 2>/dev/null || true").trim()
    let mock_a = exec("printenv ANIMA_QRNG_MOCK 2>/dev/null || true").trim()
    let live = exec("printenv NEXUS_QRNG_LIVE 2>/dev/null || true").trim()
    if mock_n != "1" { if mock_a != "1" { if live != "1" {
        return qrng_bytes_fail("nist_beacon: live path gated — set NEXUS_QRNG_LIVE=1 (or NEXUS_QRNG_MOCK=1 for CI)")
    } } }
    let pulse = nist_beacon_fetch_latest()
    if pulse.ok != 1 {
        return qrng_bytes_fail("nist_beacon: fetch fail (network/parse/empty signature)")
    }
    let bytes_all = _nist_hex_to_bytes(pulse.output_value, NIST_BEACON_BYTES_PER_PULSE)
    if len(bytes_all) < n_bytes {
        return qrng_bytes_fail("nist_beacon: hex decode short, got=" + str(len(bytes_all)) + " want=" + str(n_bytes))
    }
    let mut bytes_ = []
    let mut i = 0
    while i < n_bytes {
        bytes_ = bytes_.push(bytes_all[i])
        i = i + 1
    }
    let sha = _nist_sha256_of_bytes(bytes_, seed)
    return qrng_bytes_ok(bytes_, sha, "nist_beacon: ok pulse_index=" + str(pulse.pulse_index) + " sig_alg=" + pulse.sig_alg)
}

// ── Selftest ────────────────────────────────────────────────

fn _selftest() -> int {
    let m = qrng_source_meta_nist_beacon()
    if m.name != "nist_beacon" { return 0 }
    if m.tier != 1 { return 0 }
    if m.is_quantum != 0 { return 0 }   // honest C3: mixed, NOT pure quantum
    if m.is_local != 0 { return 0 }
    if m.is_free != 1 { return 0 }
    if m.vendor != "nist" { return 0 }
    if m.status != "IMPLEMENTED" { return 0 }
    // F_NIST_01: parse known fixture
    let fixture = "{\"pulseIndex\":9876543,\"timeStamp\":\"2026-05-03T13:00:00.000Z\",\"outputValue\":\"fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210\",\"signatureValue\":\"30640230abc123def456\"}"
    let p = _nist_parse_pulse(fixture)
    if p.ok != 1 { return 0 }
    if p.pulse_index != 9876543 { return 0 }
    if len(p.output_value) != 128 { return 0 }
    // F_NIST_03: signature non-empty
    if len(p.signature) == 0 { return 0 }
    let bs = _nist_hex_to_bytes(p.output_value, 64)
    if len(bs) != 64 { return 0 }
    if bs[0] != 254 { return 0 }   // 0xfe
    if bs[1] != 220 { return 0 }   // 0xdc
    // Failure path: empty body
    let p_bad = _nist_parse_pulse("{}")
    if p_bad.ok != 0 { return 0 }
    let sha = _nist_sha256_of_bytes(bs, 1)
    if len(sha) != 64 { return 0 }
    // n_bytes < 1 → FAIL
    let r0 = qrng_source_collect_nist_beacon(0, 1)
    if r0.ok != 0 { return 0 }
    // gated path with no env → FAIL (preserves registry contract)
    let live = exec("printenv NEXUS_QRNG_LIVE 2>/dev/null || true").trim()
    let mock_n = exec("printenv NEXUS_QRNG_MOCK 2>/dev/null || true").trim()
    let mock_a = exec("printenv ANIMA_QRNG_MOCK 2>/dev/null || true").trim()
    if live != "1" { if mock_n != "1" { if mock_a != "1" {
        let r_gated = qrng_source_collect_nist_beacon(8, 1)
        if r_gated.ok != 0 { return 0 }
    } } }
    return 1
}

fn main() {
    println("[qrng/nist_beacon] NIST Randomness Beacon 2.0 (T1, mixed entropy)")
    println("[qrng/nist_beacon] __QRNG_NIST_BEACON_FALSIFIERS__ F_NIST_01 F_NIST_02 F_NIST_03")
    if _selftest() == 1 {
        println("[qrng/nist_beacon] SELFTEST PASS")
        println("__QRNG_NIST_BEACON__ PASS")
    } else {
        println("[qrng/nist_beacon] SELFTEST FAIL")
        println("__QRNG_NIST_BEACON__ FAIL")
    }
    let live = exec("printenv NEXUS_QRNG_LIVE 2>/dev/null || true").trim()
    if live == "1" {
        println("[qrng/nist_beacon] LIVE probe (NEXUS_QRNG_LIVE=1)")
        let r = qrng_source_collect_nist_beacon(8, 1)
        if r.ok == 1 {
            println("[qrng/nist_beacon] LIVE n=" + str(r.n_bytes) + " sha=" + r.sha256_hex)
        } else {
            println("[qrng/nist_beacon] LIVE FAIL: " + r.message)
        }
    }
}
