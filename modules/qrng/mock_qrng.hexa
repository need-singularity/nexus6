#!hexa strict
// nexus/modules/qrng/mock_qrng.hexa — deterministic LCG fixture (T0)
//
// @tool(slug="qrng_mock_qrng", desc="deterministic LCG byte stream for CI / determinism tests; same seed → same bytes byte-identical across runs.")
// @usage(hexa run nexus/modules/qrng/mock_qrng.hexa --selftest)
// @sentinel(__QRNG_MOCK_QRNG__ <PASS|FAIL>)
// @resolver-bypass(reason="pure local — no network, no host call.")

struct QrngBytes {
    ok:           int,
    n_bytes:      int,
    bytes_:       [int],
    sha256_hex:   str,
    nist_pass:    int,
    message:      str
}

struct QrngSourceMeta {
    name:           str,
    tier:           int,
    throughput_bps: int,
    cost_usd:       int,
    lead_days:      int,
    is_quantum:     int,
    is_local:       int,
    is_free:        int,
    status:         str,
    vendor:         str
}

fn qrng_meta_make(
    name: str, tier: int, throughput_bps: int, cost_usd: int,
    lead_days: int, is_quantum: int, is_local: int, is_free: int,
    status: str, vendor: str
) -> QrngSourceMeta {
    return QrngSourceMeta {
        name: name, tier: tier, throughput_bps: throughput_bps,
        cost_usd: cost_usd, lead_days: lead_days,
        is_quantum: is_quantum, is_local: is_local, is_free: is_free,
        status: status, vendor: vendor
    }
}

fn qrng_bytes_fail(reason: str) -> QrngBytes {
    return QrngBytes { ok: 0, n_bytes: 0, bytes_: [], sha256_hex: "", nist_pass: 0, message: reason }
}

fn qrng_bytes_ok(bytes_: [int], sha256_hex: str, msg: str) -> QrngBytes {
    return QrngBytes { ok: 1, n_bytes: len(bytes_), bytes_: bytes_, sha256_hex: sha256_hex, nist_pass: 0, message: msg }
}

fn qrng_source_meta_mock_qrng() -> QrngSourceMeta {
    return qrng_meta_make("mock_qrng", 0, 1000000000, 0, 0, 0, 1, 1, "IMPLEMENTED", "deterministic_LCG")
}

fn qrng_source_collect_mock_qrng(n_bytes: int, seed: int) -> QrngBytes {
    if n_bytes < 1 { return qrng_bytes_fail("mock_qrng: n_bytes must be >= 1") }
    let mut s = if seed > 0 { seed } else { 12345 }
    let mut bytes_ = []
    let mut i = 0
    while i < n_bytes {
        s = (1664525 * s + 1013904223) % 4294967296
        bytes_ = bytes_.push(s % 256)
        i = i + 1
    }
    return qrng_bytes_ok(bytes_, "", "mock_qrng: deterministic LCG ok")
}

fn _selftest() -> int {
    let m = qrng_source_meta_mock_qrng()
    if m.name != "mock_qrng" { return 0 }
    if m.is_quantum != 0 { return 0 }
    if m.tier != 0 { return 0 }
    let r1 = qrng_source_collect_mock_qrng(8, 42)
    let r2 = qrng_source_collect_mock_qrng(8, 42)
    if r1.ok != 1 { return 0 }
    if r2.ok != 1 { return 0 }
    let mut k = 0
    while k < 8 { if r1.bytes_[k] != r2.bytes_[k] { return 0 } k = k + 1 }
    return 1
}

fn main() {
    println("[qrng/mock_qrng] deterministic LCG fixture (T0)")
    if _selftest() == 1 {
        println("[qrng/mock_qrng] SELFTEST PASS")
        println("__QRNG_MOCK_QRNG__ PASS")
    } else {
        println("[qrng/mock_qrng] SELFTEST FAIL")
        println("__QRNG_MOCK_QRNG__ FAIL")
    }
}
