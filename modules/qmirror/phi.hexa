#!hexa strict
// nexus/modules/qmirror/phi.hexa — anima_phi_v3_canonical port (Phase 2 EXEC)
//
// @tool(slug="qmirror_phi", desc="Sample-partition log|Cov| φ★ over arbitrary complex state vector. Port of anima_phi_v3_canonical from state/p9_p0_warmup_live_2026_05_03/warmup_probe_real.py (lines 200-260). Bridges to _python_bridge/phi_runner.py for slogdet numerics. Default HID_TRUNC = N//2, K = 8 partitions.")
// @usage(hexa run nexus/modules/qmirror/phi.hexa --selftest)
// @sentinel(__QMIRROR_PHI__ <PASS|FAIL>)
// @resolver-bypass(reason="Selftest builds an N_CALIB synthetic hidden-state matrix (no engine_aer dep); bridges to phi_runner.py for slogdet only.")
//
// Spec ref: docs/nexus_qmirror_spec_2026_05_03.md §3.6 (qmirror.phi)
//
// raw#10:
//   (1) Reference recipe (anima_phi_v3_canonical, warmup_probe_real.py:203-253):
//         X      = stack of N_CALIB hidden-state mean-pooled vectors (N, D)
//         var    = X.var(axis=0)
//         top_k  = argsort(var)[::-1][:HID_TRUNC]
//         Xt     = X[:, top_k]
//         I_full = log|Cov(Xt) + ridge·I|              # safe slogdet
//         for k in K_PARTS:
//             idx   = rng.permutation(N)
//             s1,s2 = idx[:HALF], idx[HALF:]
//             I1, I2 = log|Cov(Xt[s1])|, log|Cov(Xt[s2])|
//             phi_k  = I_full - (I1 + I2)
//         return min(phi_k), mean(phi_k)
//   (2) qmirror.phi adapts this for COMPLEX AMPLITUDE vectors: build N_CALIB
//       hidden rows by perturbing the outcome-probability vector p_i = |ψ_i|²
//       through fresh draws (sampler dep); selftest path uses synthetic
//       perturbations to keep Phase 1 sampler dep loose-coupled.
//   (3) HID_TRUNC default = N // 2.
//   (4) K = 8 partitions default.
//   (5) Output schema MUST match trajectory.json phi_star block:
//       {phi_min, phi_mean, partitions_tested}.

// ── Structs ───────────────────────────────────────────────────────────────────

struct Complex {
    re: float,
    im: float
}

struct PhiResult {
    ok:                  int,
    phi_min:             float,
    phi_mean:            float,
    partitions_tested:   int,
    hid_trunc_used:      int,
    n_calib:             int,
    ridge:               float,
    seed:                int,
    message:             str
}

// ── Constructors ──────────────────────────────────────────────────────────────

fn complex_make(re: float, im: float) -> Complex {
    return Complex { re: re, im: im }
}

fn phi_fail(reason: str) -> PhiResult {
    return PhiResult {
        ok: 0, phi_min: 0.0, phi_mean: 0.0, partitions_tested: 0,
        hid_trunc_used: 0, n_calib: 0, ridge: 0.0, seed: 0, message: reason
    }
}

fn phi_ok(phi_min: float, phi_mean: float, parts: int, hid: int, n_calib: int, ridge: float, seed: int, msg: str) -> PhiResult {
    return PhiResult {
        ok: 1, phi_min: phi_min, phi_mean: phi_mean,
        partitions_tested: parts, hid_trunc_used: hid,
        n_calib: n_calib, ridge: ridge, seed: seed, message: msg
    }
}

// ── Bridge plumbing ───────────────────────────────────────────────────────────

fn _phi_env(name: str) -> str {
    return exec("printenv " + name + " 2>/dev/null || true").trim()
}

fn _phi_bridge_path() -> str {
    let override = _phi_env("NEXUS_QMIRROR_PHI_BRIDGE_PATH")
    if len(override) > 0 { return override }
    let home = _phi_env("HOME")
    return home + "/core/nexus/modules/qmirror/_python_bridge/phi_runner.py"
}

fn _phi_proc_run_with_stdin(cmd: str, stdin_str: str) -> str {
    let now = exec("date +%s").trim()
    let nonce = now + "_" + str(len(stdin_str))
    let tmp = "/tmp/hexa_phi_stdin_" + nonce + ".txt"
    write_file(tmp, stdin_str)
    let out = exec(cmd + " < '" + tmp + "' 2>&1")
    let _drop = exec("rm -f '" + tmp + "'")
    return out
}

fn _phi_proc_json_bridge(cmd: str, payload) {
    let stdin_str = json_stringify(payload)
    let stdout = _phi_proc_run_with_stdin(cmd, stdin_str)
    let head_len = if len(stdout) < 200 { len(stdout) } else { 200 }
    let head = stdout.substring(0, head_len)
    let first_open = stdout.index_of("{")
    let last_close = stdout.last_index_of("}")
    if first_open < 0 || last_close < 0 || last_close < first_open {
        let err = json_parse("{}")
        err["ok"] = 0
        err["message"] = "phi bridge: stdout has no JSON object; got " + head
        return err
    }
    let candidate = stdout.substring(first_open, last_close + 1)
    let parsed = json_parse(candidate)
    if type_of(parsed) != "map" {
        let err = json_parse("{}")
        err["ok"] = 0
        err["message"] = "phi bridge: stdout was not JSON map; got " + head
        return err
    }
    return parsed
}

fn _phi_invoke_bridge_X(X: [[float]], hid_trunc: int, k_partitions: int, ridge: float, seed: int) -> map {
    let bridge = _phi_bridge_path()
    let exists = exec("test -f '" + bridge + "' && echo y || echo n").trim()
    if exists != "y" {
        let err = json_parse("{}")
        err["ok"] = 0
        err["message"] = "phi: bridge not found at " + bridge
        return err
    }
    let payload = json_parse("{}")
    payload["mode"] = "phi_measure"
    payload["X"] = X
    payload["hid_trunc"] = hid_trunc
    payload["k_partitions"] = k_partitions
    payload["ridge"] = ridge
    payload["seed"] = seed
    let cmd = "python3 '" + bridge + "'"
    return _phi_proc_json_bridge(cmd, payload)
}

// ── Hidden-row synthesis (Phase 2: synthetic perturbation; Phase 3: sampler-fed) ──

// Build N_CALIB hidden rows from a single |ψ⟩ amplitude vector by
// perturbing the outcome-probability vector p_i = |ψ_i|² with seed-deterministic
// noise. This is the loose-coupled stand-in for the sampler.hexa multi-shot
// re-run path that lands in Phase 3 (which will replace _phi_synth_rows with
// actual M-shot histograms).
fn _phi_synth_rows(amps_re: [float], amps_im: [float], n_calib: int, noise_amp: float, seed: int) -> [[float]] {
    let dim = len(amps_re)
    let mut rows = []
    let mut s = if seed > 0 { seed } else { 42 }
    let mut row_i = 0
    while row_i < n_calib {
        let mut row = []
        let mut j = 0
        while j < dim {
            let p = amps_re[j] * amps_re[j] + amps_im[j] * amps_im[j]
            // LCG-driven perturbation in [-noise_amp/2, +noise_amp/2].
            s = (1664525 * s + 1013904223) % 4294967296
            let u = to_float(s % 1000000) / 1000000.0
            let pert = noise_amp * (u - 0.5)
            row = row.push(p + pert)
            j = j + 1
        }
        rows = rows.push(row)
        row_i = row_i + 1
    }
    return rows
}

// ── Public API ────────────────────────────────────────────────────────────────

fn phi_measure(state_vector: [Complex], hid_trunc: int, k_partitions: int) -> PhiResult {
    let n = len(state_vector)
    if n < 2 {
        return phi_fail("phi_measure: state_vector dim < 2")
    }

    // Defaults (raw#10 cond.3 / cond.4).
    let hid_eff = if hid_trunc <= 0 { let h = n / 2; if h < 1 { 1 } else { h } } else { hid_trunc }
    let k_eff = if k_partitions <= 0 { 8 } else { k_partitions }

    // Split Complex list into amps_re / amps_im.
    let mut amps_re = []
    let mut amps_im = []
    let mut i = 0
    while i < n {
        amps_re = amps_re.push(state_vector[i].re)
        amps_im = amps_im.push(state_vector[i].im)
        i = i + 1
    }

    // Synthesise N_CALIB hidden rows (Phase 2 loose-coupled stand-in).
    let n_calib = 32
    let noise_amp = 0.05
    let seed_env = _phi_env("NEXUS_QMIRROR_PHI_SEED")
    let seed = if len(seed_env) > 0 { to_int(seed_env) } else { 42 }
    let X = _phi_synth_rows(amps_re, amps_im, n_calib, noise_amp, seed)

    // Bridge to phi_runner.py for slogdet numerics.
    let resp = _phi_invoke_bridge_X(X, hid_eff, k_eff, 0.001, seed)
    if !has_key(resp, "ok") {
        return phi_fail("phi_measure: bridge response missing 'ok' key")
    }
    if resp["ok"] != 1 {
        let m = if has_key(resp, "message") { to_string(resp["message"]) } else { "unknown bridge error" }
        return phi_fail("phi_measure: bridge ok=0 message=" + m)
    }

    let phi_min = to_float(resp["phi_min"])
    let phi_mean = to_float(resp["phi_mean"])
    let parts = to_int(resp["partitions_tested"])
    let hid_used = to_int(resp["hid_trunc_used"])
    let nc = to_int(resp["n_calib"])
    let ridge = to_float(resp["ridge"])
    let seed_used = to_int(resp["seed"])
    return phi_ok(phi_min, phi_mean, parts, hid_used, nc, ridge, seed_used,
                  "phi_measure: ok engine=" +
                  (if has_key(resp, "engine") { to_string(resp["engine"]) } else { "unknown" }))
}

fn phi_measure_from_circuit(qasm3: str, n_qubits: int, n_calib: int, hid_trunc: int, k_partitions: int) -> PhiResult {
    // Phase 2: not wired to engine_aer for arbitrary qasm — Phase 3 lands the
    // engine_aer + sampler full path. For now caller should drive engine_aer
    // separately and pass the amplitude vector to phi_measure().
    return phi_fail("phi_measure_from_circuit: Phase 3 only — use phi_measure([Complex]) directly in Phase 2")
}

// ── F4: CHSH cross-substrate gate (numerical Tsirelson reproduction via phi.hexa) ──
//
// F4 in this module's selftest = "phi_measure on a Bell |ψ⟩ produces a
// finite, non-NaN φ_min within a sane range, and the underlying sampler
// reproduces CHSH S in [2.7, 2.85] cross-substrate (delegating to chsh.hexa
// is the spec path; here we sanity-check the phi pipeline doesn't blow
// up on the same Bell state).

fn _abs_p(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _selftest() -> int {
    // (a) Struct constructors round-trip.
    let psi_0 = complex_make(0.7071067811865475, 0.0)
    let psi_3 = complex_make(0.7071067811865475, 0.0)
    let bell = [psi_0, complex_make(0.0, 0.0), complex_make(0.0, 0.0), psi_3]
    if len(bell) != 4 { return 0 }

    // (b) phi_measure on a Bell |ψ⟩ should return ok=1, finite phi_min/mean,
    //     and respect default HID_TRUNC = N//2 = 2, K = 8.
    let r = phi_measure(bell, 0, 0)
    if r.ok != 1 { return 0 }
    if r.partitions_tested < 1 { return 0 }
    if r.hid_trunc_used != 2 { return 0 }
    if r.n_calib != 32 { return 0 }
    // Sanity range: synthetic-noise hidden rows give finite phi.
    if _abs_p(r.phi_min) > 1000.0 { return 0 }
    if _abs_p(r.phi_mean) > 1000.0 { return 0 }

    // (c) Explicit hid_trunc + k_partitions overrides honored.
    let r2 = phi_measure(bell, 3, 4)
    if r2.ok != 1 { return 0 }
    if r2.hid_trunc_used != 3 { return 0 }
    if r2.partitions_tested > 4 { return 0 }   // upper-bounded by request

    // (d) Reject too-small state vector.
    let tiny = [psi_0]
    let rt = phi_measure(tiny, 0, 0)
    if rt.ok != 0 { return 0 }
    if !rt.message.contains("dim < 2") { return 0 }

    return 1
}

fn main() {
    println("[qmirror/phi] anima_phi_v3_canonical port (Phase 2 EXEC)")
    println("  bridge path = " + _phi_bridge_path())
    if _selftest() == 1 {
        println("[qmirror/phi] SELFTEST PASS (F4: phi_measure(Bell) finite + defaults honored)")
        println("__QMIRROR_PHI__ PASS")
    } else {
        println("[qmirror/phi] SELFTEST FAIL (F4 falsifier triggered)")
        println("__QMIRROR_PHI__ FAIL")
    }
}
