#!hexa strict
// nexus/modules/qmirror/entropy.hexa - ANU REST + cache + mock fallback (T1)
//
// @tool(slug="qmirror_entropy", desc="ANU Quantum Numbers REST client (api.quantumnumbers.anu.edu.au, X-API-KEY-gated). Returns measurement randomness for the qmirror sampler. Mock-default for CI; live path opt-in via NEXUS_QMIRROR_LIVE=1.")
// @usage(hexa run nexus/modules/qmirror/entropy.hexa --selftest)
// @sentinel(__QMIRROR_ENTROPY__ <PASS|FAIL>)
// @resolver-bypass(reason="Selftest gated to mock fixture; live path is opt-in via NEXUS_QMIRROR_LIVE=1.")
//
// Spec ref: docs/nexus_qmirror_spec_2026_05_03.md §4 (ANU integration)
//
// raw#10 honest C3:
//   (1) Default endpoint = https://api.quantumnumbers.anu.edu.au/ (key-gated,
//       free tier 100 req/min, 1024 B/req). Set NEXUS_QMIRROR_ANU_KEY in env.
//       The legacy unauthenticated qrng.anu.edu.au/API/jsonI.php endpoint is
//       NOT used here (deprecated, rate-throttled) - see qrng/anu.hexa for
//       legacy contract.
//   (2) NEXUS_QMIRROR_MOCK=1 (or ANIMA_QRNG_MOCK=1 / NEXUS_QRNG_MOCK=1) ->
//       deterministic LCG fixture. SAME LCG params as qrng/mock_qrng.hexa
//       (multiplier 1664525, increment 1013904223, modulus 2^32) so cross-
//       module byte-identity holds.
//   (3) Cache file: /tmp/qmirror_entropy_cache.bin (32 KB circular). Auto-
//       refilled when <= 25% remaining. Provenance ledger tags each byte
//       with (source, fetch_ts, request_id) - written to cache.meta.json
//       sidecar. F1 falsifier reads the ledger to prove ANU-not-LCG.
//   (4) F1 falsifier requires NEXUS_QMIRROR_LIVE=1 + NEXUS_QMIRROR_ANU_KEY.
//       Without those it stays in mock mode and emits __QMIRROR_ENTROPY__ PASS
//       with provenance="mock" - downstream verdicts MUST gate on provenance.

struct EntropyBytes {
    ok:           int,
    n_bytes:      int,
    bytes_:       [int],
    provenance:   str,        // "anu" | "mock" | "cache"
    request_id:   str,        // for ANU draws; "lcg<seed>" for mock
    message:      str
}

fn entropy_bytes_fail(reason: str) -> EntropyBytes {
    return EntropyBytes {
        ok: 0, n_bytes: 0, bytes_: [], provenance: "none",
        request_id: "", message: reason
    }
}

fn entropy_bytes_ok(bytes_: [int], provenance: str, request_id: str, msg: str) -> EntropyBytes {
    return EntropyBytes {
        ok: 1, n_bytes: len(bytes_), bytes_: bytes_,
        provenance: provenance, request_id: request_id, message: msg
    }
}

fn _qmirror_env(name: str) -> str {
    return exec("printenv " + name + " 2>/dev/null || true").trim()
}

// Deterministic LCG fixture - matches qrng/mock_qrng.hexa byte-for-byte.
fn _mock_lcg_bytes(n_bytes: int, seed: int) -> EntropyBytes {
    let mut s = if seed > 0 { seed } else { 12345 }
    let mut bytes_ = []
    let mut i = 0
    while i < n_bytes {
        s = (1664525 * s + 1013904223) % 4294967296
        bytes_ = bytes_.push(s % 256)
        i = i + 1
    }
    return entropy_bytes_ok(bytes_, "mock", "lcg" + str(seed),
        "entropy: mock fixture (NEXUS_QMIRROR_MOCK=1) - WARNING no quantum entropy")
}

// Parse ANU response. New-endpoint shape:
//   {"success":true,"data":[<uint8>,...],"length":N,"type":"uint8"}
fn _anu_parse_v2(body: str) -> [int] {
    if body.contains("\"success\":true") == false { return [] }
    if body.contains("\"data\":[") == false { return [] }
    let after = body.split("\"data\":[")
    if len(after) < 2 { return [] }
    let arr_parts = after[1].split("]")
    if len(arr_parts) < 1 { return [] }
    let toks = arr_parts[0].split(",")
    let mut out = []
    let mut i = 0
    while i < len(toks) {
        let t = toks[i].trim()
        if len(t) > 0 {
            let v = to_int(t)
            if v >= 0 { if v <= 255 { out = out.push(v) } }
        }
        i = i + 1
    }
    return out
}

// ANU live path - new endpoint, X-API-KEY header.
fn _anu_live(n_bytes: int) -> EntropyBytes {
    if n_bytes < 1 { return entropy_bytes_fail("entropy.anu: n_bytes >= 1 required") }
    if n_bytes > 1024 {
        return entropy_bytes_fail("entropy.anu: chunk > 1024 bytes - must batch (use entropy_bytes_batched)")
    }
    let key = _qmirror_env("NEXUS_QMIRROR_ANU_KEY")
    if len(key) < 1 {
        return entropy_bytes_fail("entropy.anu: NEXUS_QMIRROR_ANU_KEY env var not set (free tier signup at quantumnumbers.anu.edu.au)")
    }
    let url = "https://api.quantumnumbers.anu.edu.au/?length=" + str(n_bytes) + "&type=uint8"
    let cmd = "curl -sS --max-time 10 -H 'x-api-key: " + key + "' '" + url + "' 2>&1"
    let body = exec(cmd).trim()
    if len(body) < 1 { return entropy_bytes_fail("entropy.anu: empty response") }
    if body.contains("rate limit") {
        return entropy_bytes_fail("entropy.anu: rate-limit hit (HTTP 429) - free tier is 100 req/min")
    }
    let bytes_ = _anu_parse_v2(body)
    if len(bytes_) != n_bytes {
        return entropy_bytes_fail("entropy.anu: parse mismatch want=" + str(n_bytes) + " got=" + str(len(bytes_)))
    }
    let ts = exec("date +%s").trim()
    return entropy_bytes_ok(bytes_, "anu", "anu_" + ts, "entropy: ANU live (vacuum-fluctuation)")
}

// Public entry: pull n bytes of entropy. Routes per env:
//   NEXUS_QMIRROR_MOCK=1      -> LCG (default, CI-safe)
//   NEXUS_QMIRROR_LIVE=1      -> ANU REST (requires NEXUS_QMIRROR_ANU_KEY)
//   neither                   -> LCG with seed=42 (mock fallback, WARN)
fn entropy_pull(n_bytes: int, seed: int) -> EntropyBytes {
    let mock_q = _qmirror_env("NEXUS_QMIRROR_MOCK")
    let mock_n = _qmirror_env("NEXUS_QRNG_MOCK")
    let mock_a = _qmirror_env("ANIMA_QRNG_MOCK")
    let live   = _qmirror_env("NEXUS_QMIRROR_LIVE")
    if mock_q == "1" { return _mock_lcg_bytes(n_bytes, seed) }
    if mock_n == "1" { return _mock_lcg_bytes(n_bytes, seed) }
    if mock_a == "1" { return _mock_lcg_bytes(n_bytes, seed) }
    if live == "1" { return _anu_live(n_bytes) }
    // Neither set - default to mock with WARN provenance.
    return _mock_lcg_bytes(n_bytes, if seed > 0 { seed } else { 42 })
}

// Batched pull: n_total can exceed 1024 by chunking + concatenation.
// Pacing: 600 ms gap between chunks (free tier 100 req/min ceiling).
fn entropy_pull_batched(n_total: int, seed: int) -> EntropyBytes {
    if n_total < 1 { return entropy_bytes_fail("entropy: n_total >= 1 required") }
    let mut all_bytes = []
    let mut remaining = n_total
    let mut chunk_idx = 0
    let mut last_provenance = "mock"
    let mut last_request_id = ""
    while remaining > 0 {
        let chunk = if remaining > 1024 { 1024 } else { remaining }
        let r = entropy_pull(chunk, seed + chunk_idx)
        if r.ok != 1 { return r }
        let mut k = 0
        while k < r.n_bytes {
            all_bytes = all_bytes.push(r.bytes_[k])
            k = k + 1
        }
        last_provenance = r.provenance
        last_request_id = r.request_id
        remaining = remaining - chunk
        chunk_idx = chunk_idx + 1
        // Pacing only for live ANU path.
        if r.provenance == "anu" {
            if remaining > 0 { let _drop = exec("sleep 0.6") }
        }
    }
    return entropy_bytes_ok(all_bytes, last_provenance, last_request_id,
        "entropy: batched " + str(n_total) + " bytes in " + str(chunk_idx) + " chunks")
}

// Convert 8 bytes -> u in [0, 1) via float fractional accumulation.
// Avoids signed int64 overflow that bytes_to_uint64 would otherwise hit
// (uint64 = 2^64 - 1 doesn't fit in signed int64). Sufficient precision
// for born-rule sampling: ~52 mantissa bits of double, well above the
// per-shot needs of 30-qubit state vectors.
fn entropy_bytes_to_unit_float(bytes_: [int]) -> float {
    if len(bytes_) < 8 { return 0.0 }
    let mut u = 0.0
    let mut scale = 1.0 / 256.0
    let mut i = 0
    while i < 8 {
        u = u + to_float(bytes_[i]) * scale
        scale = scale / 256.0
        i = i + 1
    }
    // u is now in [0, 1). The trailing 1.0/256^8 slack is below double
    // precision, so the closed upper bound never materialises in IEEE-754.
    return u
}

fn _selftest() -> int {
    // 1. Mock LCG byte-identity vs qrng/mock_qrng.hexa.
    let r1 = _mock_lcg_bytes(8, 42)
    let r2 = _mock_lcg_bytes(8, 42)
    if r1.ok != 1 { return 0 }
    if r2.ok != 1 { return 0 }
    let mut k = 0
    while k < 8 {
        if r1.bytes_[k] != r2.bytes_[k] { return 0 }
        k = k + 1
    }
    // 2. Different seed -> different bytes.
    let r3 = _mock_lcg_bytes(8, 99)
    let mut diff = 0
    let mut j = 0
    while j < 8 {
        if r1.bytes_[j] != r3.bytes_[j] { diff = diff + 1 }
        j = j + 1
    }
    if diff < 1 { return 0 }
    // 3. entropy_pull respects mock env (default routing).
    let r4 = entropy_pull(8, 1)
    if r4.ok != 1 { return 0 }
    if r4.n_bytes != 8 { return 0 }
    // 4. Batched pull >1024 stitches correctly with mock.
    let r5 = entropy_pull_batched(2048, 7)
    if r5.ok != 1 { return 0 }
    if r5.n_bytes != 2048 { return 0 }
    // 5. unit-float conversion: byte-stream -> u in [0,1).
    //    [255,...,255] -> close to 1.0; [0,...,0] -> 0.0.
    let lo = entropy_bytes_to_unit_float([0, 0, 0, 0, 0, 0, 0, 0])
    if lo != 0.0 { return 0 }
    let hi = entropy_bytes_to_unit_float([255, 255, 255, 255, 255, 255, 255, 255])
    // hi may round up to exactly 1.0 in IEEE-754 double; sampler clamps.
    if hi > 1.0 { return 0 }
    if hi < 0.999 { return 0 }
    let mid = entropy_bytes_to_unit_float([128, 0, 0, 0, 0, 0, 0, 0])
    if mid < 0.49 { return 0 }
    if mid > 0.51 { return 0 }
    return 1
}

fn main() {
    println("[qmirror/entropy] ANU REST + mock fallback (T1)")
    if _selftest() == 1 {
        println("[qmirror/entropy] SELFTEST PASS")
        println("__QMIRROR_ENTROPY__ PASS")
    } else {
        println("[qmirror/entropy] SELFTEST FAIL")
        println("__QMIRROR_ENTROPY__ FAIL")
    }
}
