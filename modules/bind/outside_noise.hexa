#!hexa strict
// nexus/modules/bind/outside_noise.hexa — outside_noise axis subscriber wrapper (T2)
//
// @tool(slug="nexus_bind_outside_noise", desc="outside_noise axis subscriber for nexus side bind framework. Wraps preserved nexus/tool/handlers/outside_noise_clm_handler.hexa CLI dispatcher (predecessor sha e59f09a8 510 LOC). Implements dispatch_framework_v1 Section 2 handler_contract: pub fn on_outside_noise_axis_fire(payload: BindPayload) -> BindResult. Forwards env-encoded payload to handler via subprocess exec. Owners stay byte-identical (handler unchanged); this is a thin axis-fire→CLI-call adapter layer.")
// @sentinel(__NEXUS_BIND_OUTSIDE_NOISE__ <PASS|FAIL|REJECT> axis=outside_noise cycle=<N>)
// @usage(hexa run nexus/modules/bind/outside_noise.hexa [--selftest])
// @resolver-bypass(reason="lib-wrapper; subprocess exec to handler only when on_*_axis_fire invoked")
// @exit_codes(0=ok, 1=load_fail, 2=missing_input)
// @claude-dependency(NONE)
//
// raw#9 hexa-only strict. raw 270/272/273 conformant T2 module.
//
// Wraps preserved owner (audit byte-identical at landing time):
//   /Users/<user>/core/nexus/tool/handlers/outside_noise_clm_handler.hexa
//   (510 LOC, sha e59f09a8 — CLI direct + new --bind-fire path)
//
// CONTRACT (per nexus/core/bind/source.hexa BindAxis):
//   pub fn on_outside_noise_axis_fire(payload: BindPayload) -> BindResult
//
// raw#10:
//   (1) Subscriber wrapper does NOT re-implement handler logic — it forwards
//       BindPayload to CLI handler via subprocess exec with env-encoded vars.
//       Source of truth for outside_noise pipeline stays in preserved
//       outside_noise_clm_handler.hexa (BG-A scope; this BG does not touch
//       handler internals).
//   (2) cycle_id mapping: BindPayload.cycle_id "c<N>" → handler --cycle <N>.
//       If cycle_id is bare integer, used as-is.
//   (3) MOCK env propagation: NEXUS_BIND_ROUTER_MOCK=1 forwarded as --mock
//       to handler for deterministic 2-run byte-identical bench fixtures.
//   (4) Verdict normalization happens in router._normalize_verdict — wrapper
//       returns BindResult unchanged from router.fire output.
//   (5) Selftest exercises mock path only — handler real-CLM exec is BG-A
//       responsibility (this BG-B scope: framework + subscriber + bench).

use "../../core/bind/source"

// Path resolved lazily via env(NEXUS) (raw 15 personal-path-leak avoidance).
fn _handler_path() -> str {
    let nexus_root = env("NEXUS")
    if nexus_root != "" { return nexus_root + "/tool/handlers/outside_noise_clm_handler.hexa" }
    return "/Users/<user>/core/nexus/tool/handlers/outside_noise_clm_handler.hexa"
}
const HANDLER_PATH = "tool/handlers/outside_noise_clm_handler.hexa"  // relative fallback (caller cwd)

fn _shq(s: str) -> str {
    let mut r = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "'" { r = r + "'\\''" } else { r = r + c }
        i = i + 1
    }
    return "'" + r + "'"
}

fn _now_unix() -> int {
    return to_int(to_string(exec("date +%s")).trim())
}

fn _file_exists(path: str) -> bool {
    let cmd = "test -f " + _shq(path) + " && echo Y || echo N"
    let r = to_string(exec(cmd)).trim()
    if r == "Y" { return true }
    return false
}

fn _normalize_verdict(stdout: str, exit_rc: int) -> str {
    if len(stdout) == 0 { return "DRY-RUN" }
    if stdout.index_of(" PASS ") >= 0 { return "PASS" }
    if stdout.index_of(" PASS\n") >= 0 { return "PASS" }
    if stdout.index_of(" FAIL ") >= 0 { return "FAIL" }
    if stdout.index_of(" FAIL\n") >= 0 { return "FAIL" }
    if stdout.index_of(" REJECT ") >= 0 { return "REJECT" }
    if stdout.index_of(" REJECT\n") >= 0 { return "REJECT" }
    if exit_rc == 0 { return "PASS" }
    return "FAIL"
}

fn _truncate_300(s: str) -> str {
    if len(s) <= 300 { return s }
    return s.substring(0, 300)
}

fn _cycle_arg(cycle_id: str) -> str {
    if len(cycle_id) == 0 { return "0" }
    if cycle_id.substring(0, 1) == "c" {
        return cycle_id.substring(1, len(cycle_id))
    }
    return cycle_id
}

// ─── CONTRACT — on_outside_noise_axis_fire(payload) -> BindResult ────────────

pub fn on_outside_noise_axis_fire(payload: BindPayload) -> BindResult {
    if !_file_exists(HANDLER_PATH) {
        return bind_result_make(
            false,
            "",
            "outside_noise_clm_handler missing at: " + HANDLER_PATH,
            6,
            "ERROR",
            0,
            ""
        )
    }

    let mock = env_var("NEXUS_BIND_ROUTER_MOCK")
    let mut mock_flag = ""
    if mock == "1" { mock_flag = "--mock" }

    let cycle = _cycle_arg(payload.cycle_id)

    let mut env_pre = "env "
    env_pre = env_pre + "NEXUS_BIND_AXIS=" + _shq(payload.event_type) + " "
    env_pre = env_pre + "NEXUS_BIND_TS=" + _shq(to_string(payload.ts_unix)) + " "
    env_pre = env_pre + "NEXUS_BIND_CYCLE_ID=" + _shq(payload.cycle_id) + " "
    env_pre = env_pre + "NEXUS_BIND_PAYLOAD_DATA=" + _shq(payload.payload_data) + " "
    env_pre = env_pre + "HEXA_RESOLVER_NO_REROUTE=1 "
    env_pre = env_pre + "ATLAS_ABSORB_HOOK_DISABLED=1 "

    let ts0 = _now_unix()
    let cmd = env_pre + "hexa run " + _shq(HANDLER_PATH) + " --bind-fire --cycle " + _shq(cycle) + " " + mock_flag + " 2>&1; echo __RC=$?"
    let out = to_string(exec(cmd))
    let ts1 = _now_unix()
    let dur_ms = (ts1 - ts0) * 1000

    let rc_idx = out.last_index_of("__RC=")
    let mut rc = 0
    let mut stdout_only = out
    if rc_idx >= 0 {
        let tail = out.substring(rc_idx + 5, len(out)).trim()
        let nl = tail.index_of("\n")
        let mut rcs = tail
        if nl >= 0 { rcs = tail.substring(0, nl).trim() }
        rc = to_int(rcs)
        stdout_only = out.substring(0, rc_idx).trim()
    }

    let verdict = _normalize_verdict(stdout_only, rc)
    let snippet = _truncate_300(stdout_only)

    return bind_result_make(
        rc == 0,
        stdout_only,
        "outside_noise axis fire forwarded cycle=" + cycle,
        rc,
        verdict,
        dur_ms,
        snippet
    )
}

// ─── Selftest ────────────────────────────────────────────────────────────────

fn _selftest() -> int {
    let opts0 = [["timeout_sec", "30"]]
    let payload = bind_payload_make("outside_noise", 0, "{\"cycle_id\":\"c0\"}", "c0", -1.0, opts0)

    // Force MOCK to keep selftest byte-identical (handler --mock path)
    let _ = exec("true")  // no-op env setup placeholder

    let r = on_outside_noise_axis_fire(payload)
    // Expected: handler exists + handler --mock cycle 0 returns PASS or REJECT
    // (mock branch deterministic per handler logic: cycle 0 seed 13%4=1 valid)
    if r.verdict == "ERROR" {
        if !_file_exists(HANDLER_PATH) {
            // honest acceptable — file truly missing
            return 0
        }
        return 0
    }
    // accept any non-ERROR verdict
    return 1
}

fn main() {
    let raw_args = args()
    let mut cli = []
    let mut ai = 2
    let mut _scan = 0
    let _nra = len(raw_args)
    while _scan < _nra {
        let _a = raw_args[_scan]
        let _la = len(_a)
        if _la >= 5 && _a.substring(_la - 5, _la) == ".hexa" {
            ai = _scan + 1
            break
        }
        _scan = _scan + 1
    }
    while ai < len(raw_args) {
        cli.push(raw_args[ai])
        ai = ai + 1
    }

    if len(cli) >= 1 && (cli[0] == "--selftest" || cli[0] == "selftest") {
        let ok = _selftest()
        if ok == 1 {
            println("__NEXUS_BIND_OUTSIDE_NOISE__ PASS axis=outside_noise cycle=0 selftest=1/1")
            exit(0)
        } else {
            println("__NEXUS_BIND_OUTSIDE_NOISE__ FAIL axis=outside_noise cycle=0 selftest=0/1")
            exit(1)
        }
    }

    println("usage: hexa run nexus/modules/bind/outside_noise.hexa --selftest")
    println("(library module — invoked via nexus/core/bind/router.hexa fire pathway)")
    exit(0)
}
