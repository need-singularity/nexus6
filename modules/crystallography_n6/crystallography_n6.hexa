#!hexa strict
// modules/crystallography_n6/crystallography_n6.hexa
//
// Pure integer enumeration of Fedorov 230 / 14 Bravais / 7 systems / 32 point
// groups against n=6 closed forms. Pure single-domain hexa rewrite of lost
// 397 LOC python module. No external deps.
//
// n=6 closed-form anchors:
//   F1: Fedorov-230  = sigma*J_2 - J_2*phi - (sigma-phi) = 12*24 - 24*2 - 10 = 288 - 48 - 10 = 230
//   F2: Bravais-14   = phi*(sopfr+phi) = sigma+phi       = 14
//   F3: systems-7    = sopfr+phi                          = 7
//   F4: |O_h|=48     = sigma*tau                          = 48
//   F5: 32 pt groups = J_2 + sigma - tau = 24 + 12 - 4   = 32
//   F6: max axis-6   = n                                  = 6
//
// IUCr canonical counts: 230, 14, 7, 32, 48 (Oh order), 6 (max rotational axis).
//
// @sentinel(__CRYSTALLOGRAPHY_N6__ PASS|FAIL)
// @usage(hexa run modules/crystallography_n6/crystallography_n6.hexa --self-test)
// @usage(hexa run modules/crystallography_n6/crystallography_n6.hexa --atlas)
// @usage(hexa run modules/crystallography_n6/crystallography_n6.hexa --system cubic)

// ─── number-theory primitives (local) ───

fn sigma(n: int) -> int {
    let mut s = 0
    let mut k = 1
    while k <= n {
        if n % k == 0 { s = s + k }
        k = k + 1
    }
    return s
}

fn tau_div(n: int) -> int {
    let mut s = 0
    let mut k = 1
    while k <= n {
        if n % k == 0 { s = s + 1 }
        k = k + 1
    }
    return s
}

fn euler_phi(n: int) -> int {
    if n == 1 { return 1 }
    let mut count = 0
    let mut k = 1
    while k < n {
        if gcd(k, n) == 1 { count = count + 1 }
        k = k + 1
    }
    return count
}

fn gcd(a: int, b: int) -> int {
    let mut x = a
    let mut y = b
    if x < 0 { x = 0 - x }
    if y < 0 { y = 0 - y }
    while y != 0 {
        let r = x % y
        x = y
        y = r
    }
    return x
}

// sopfr(n) = sum of prime factors with multiplicity. sopfr(6) = 2 + 3 = 5.
fn sopfr(n: int) -> int {
    let mut x = n
    let mut s = 0
    let mut p = 2
    while p * p <= x {
        while x % p == 0 {
            s = s + p
            x = x / p
        }
        p = p + 1
    }
    if x > 1 { s = s + x }
    return s
}

// jordan_totient_2(n) = n^2 * prod_{p|n}(1 - 1/p^2). For n=6: 36 * (3/4) * (8/9) = 24.
fn jordan_totient_2(n: int) -> int {
    let mut x = n
    let mut num = n * n
    // collect distinct prime factors
    let mut primes = []
    let mut p = 2
    while p * p <= x {
        if x % p == 0 {
            primes.push(p)
            while x % p == 0 { x = x / p }
        }
        p = p + 1
    }
    if x > 1 { primes.push(x) }
    let mut i = 0
    while i < len(primes) {
        let pr = primes[i]
        // multiply num by (p^2 - 1) / p^2 — apply as integer ops carefully:
        // num = num * (pr*pr - 1) / (pr*pr)
        num = (num * (pr * pr - 1)) / (pr * pr)
        i = i + 1
    }
    return num
}

// ─── n=6 anchor block ───

fn _n6() -> array {
    let n = 6
    let s = sigma(n)             // 12
    let t = tau_div(n)           // 4
    let p = euler_phi(n)         // 2
    let sp = sopfr(n)            // 5
    let j2 = jordan_totient_2(n) // 24
    return [n, s, t, p, sp, j2]
}

// ─── canonical IUCr enumeration tables (integer-only) ───
//
// Each system row: [system_name, bravais_count, space_group_count, point_group_names_array]
// (point group names are "string" but we keep them in array form for reporting.)
//
// IUCr canonical:
//   triclinic    1 Bravais  2  space  pt: 1, -1
//   monoclinic   2 Bravais  13 space  pt: 2, m, 2/m
//   orthorhombic 4 Bravais  59 space  pt: 222, mm2, mmm
//   tetragonal   2 Bravais  68 space  pt: 4, -4, 4/m, 422, 4mm, -42m, 4/mmm
//   trigonal     1 Bravais  25 space  pt: 3, -3, 32, 3m, -3m
//   hexagonal    1 Bravais  27 space  pt: 6, -6, 6/m, 622, 6mm, -6m2, 6/mmm
//   cubic        3 Bravais  36 space  pt: 23, m-3, 432, -43m, m-3m
// totals:  14    230   32

fn _system_data() -> array {
    let mut rows = []
    rows.push(["triclinic",    1, 2,  ["1", "-1"]])
    rows.push(["monoclinic",   2, 13, ["2", "m", "2/m"]])
    rows.push(["orthorhombic", 4, 59, ["222", "mm2", "mmm"]])
    rows.push(["tetragonal",   2, 68, ["4", "-4", "4/m", "422", "4mm", "-42m", "4/mmm"]])
    rows.push(["trigonal",     1, 25, ["3", "-3", "32", "3m", "-3m"]])
    rows.push(["hexagonal",    1, 27, ["6", "-6", "6/m", "622", "6mm", "-6m2", "6/mmm"]])
    rows.push(["cubic",        3, 36, ["23", "m-3", "432", "-43m", "m-3m"]])
    return rows
}

// ─── enumerate(crystal_system) ───
//
// Returns array:
//   [systems_list, total_bravais, total_space_groups, total_point_groups, falsifier_code, selected_system]
// systems_list is array of [name, bravais, space_groups, point_group_count]
// falsifier_code: 0=PASS:n6-locked, 1=FAIL:closed-form-mismatch, 2=FAIL:unknown-system

fn enumerate(crystal_system: string) -> array {
    let rows = _system_data()
    let n6 = _n6()
    // closed forms:
    let s = n6[1]      // 12
    let t = n6[2]      // 4
    let p = n6[3]      // 2
    let sp = n6[4]     // 5
    let j2 = n6[5]     // 24

    let cf_systems_7    = sp + p                   // 5 + 2 = 7
    let cf_bravais_14   = p * (sp + p)             // 2 * 7 = 14
    let cf_fedorov_230  = s * j2 - j2 * p - (s - p)  // 288 - 48 - 10 = 230
    let cf_pointgroups_32 = j2 + s - t             // 24 + 12 - 4 = 32

    let mut filtered = []
    let mut found = false
    let mut i = 0
    while i < len(rows) {
        let r = rows[i]
        if len(crystal_system) == 0 || r[0] == crystal_system {
            let pgs = r[3]
            filtered.push([r[0], r[1], r[2], len(pgs)])
            if r[0] == crystal_system { found = true }
        }
        i = i + 1
    }

    if len(crystal_system) > 0 && !found {
        return [[], 0, 0, 0, 2, crystal_system]
    }

    let mut total_b = 0
    let mut total_sg = 0
    let mut total_pg = 0
    let mut k = 0
    while k < len(filtered) {
        total_b = total_b + filtered[k][1]
        total_sg = total_sg + filtered[k][2]
        total_pg = total_pg + filtered[k][3]
        k = k + 1
    }

    // when full enumeration, validate vs closed forms
    let mut falsifier = 0
    if len(crystal_system) == 0 {
        if len(filtered) != cf_systems_7   { falsifier = 1 }
        if total_b != cf_bravais_14        { falsifier = 1 }
        if total_sg != cf_fedorov_230      { falsifier = 1 }
        if total_pg != cf_pointgroups_32   { falsifier = 1 }
    }

    return [filtered, total_b, total_sg, total_pg, falsifier, crystal_system]
}

// ─── atlas_facts() — 6 DSL-ready strings ───

fn atlas_facts() -> array {
    let mut out = []
    out.push("@F CRYSTAL-N6-01 fedorov-230-closure = sigma*J_2 - J_2*phi - (sigma-phi) = 230 :: crystallography [10]")
    out.push("@F CRYSTAL-N6-02 bravais-14 = phi*(sopfr+phi) = sigma+phi = 14 :: crystallography [10]")
    out.push("@F CRYSTAL-N6-03 systems-7 = sopfr+phi = 7 :: crystallography [10]")
    out.push("@F CRYSTAL-N6-04 octahedral-Oh-order = sigma*tau = 48 :: crystallography [10]")
    out.push("@F CRYSTAL-N6-05 point-groups-32 = J_2 + sigma - tau = 32 :: crystallography [10]")
    out.push("@F CRYSTAL-N6-06 max-rotation-axis = n = 6 :: crystallography [10]")
    return out
}

// ─── status decoder ───

fn _falsifier_label(code: int) -> string {
    if code == 0 { return "PASS:n6-locked" }
    if code == 1 { return "FAIL:closed-form-mismatch" }
    if code == 2 { return "FAIL:unknown-system" }
    return "UNKNOWN"
}

fn _emit_json(res: array) -> string {
    let mut s = "{\n"
    s = s + "  \"selected_system\": \"" + res[5] + "\",\n"
    s = s + "  \"systems\": [\n"
    let sys = res[0]
    let mut i = 0
    while i < len(sys) {
        let r = sys[i]
        s = s + "    {\"system\": \"" + r[0] + "\", \"bravais_count\": " + to_string(r[1])
        s = s + ", \"space_group_count\": " + to_string(r[2])
        s = s + ", \"point_group_count\": " + to_string(r[3]) + "}"
        if i < len(sys) - 1 { s = s + "," }
        s = s + "\n"
        i = i + 1
    }
    s = s + "  ],\n"
    s = s + "  \"aggregate\": {\n"
    s = s + "    \"total_bravais\": " + to_string(res[1]) + ",\n"
    s = s + "    \"total_space_groups\": " + to_string(res[2]) + ",\n"
    s = s + "    \"total_point_groups\": " + to_string(res[3]) + ",\n"
    s = s + "    \"falsifier_status\": \"" + _falsifier_label(res[4]) + "\"\n"
    s = s + "  }\n"
    s = s + "}\n"
    return s
}

// ─── self-test ───

fn _run_self_test() -> void {
    println("=== crystallography_n6 --self-test ===")

    // case 1: full enumeration — closed forms must match IUCr counts
    let r1 = enumerate("")
    println("  case1 (full enumerate)   : systems=" + to_string(len(r1[0])) + " bravais=" + to_string(r1[1]) + " space=" + to_string(r1[2]) + " pt=" + to_string(r1[3]) + " status=" + _falsifier_label(r1[4]))
    let mut pass1 = true
    if len(r1[0]) != 7  { pass1 = false }
    if r1[1] != 14      { pass1 = false }
    if r1[2] != 230     { pass1 = false }
    if r1[3] != 32      { pass1 = false }
    if r1[4] != 0       { pass1 = false }

    // case 2: atlas_facts() len == 6
    let af = atlas_facts()
    println("  case2 (atlas_facts len)  : len=" + to_string(len(af)))
    let mut pass2 = true
    if len(af) != 6 { pass2 = false }
    let mut k = 0
    while k < len(af) {
        if af[k].index_of("@F CRYSTAL-N6-") != 0 { pass2 = false }
        if af[k].index_of(":: crystallography [10]") < 0 { pass2 = false }
        k = k + 1
    }

    // case 3: unknown system → falsifier=2
    let r3 = enumerate("zzzzz_unknown")
    println("  case3 (unknown system)   : status=" + _falsifier_label(r3[4]))
    let mut pass3 = true
    if r3[4] != 2 { pass3 = false }

    // case 4: closed-form arithmetic identities
    let n6 = _n6()
    let s = n6[1]   // 12
    let t = n6[2]   // 4
    let p = n6[3]   // 2
    let sp = n6[4]  // 5
    let j2 = n6[5]  // 24
    let mut pass4 = true
    if (sp + p) != 7                        { pass4 = false }    // F3
    if (p * (sp + p)) != 14                 { pass4 = false }    // F2
    if (s * j2 - j2 * p - (s - p)) != 230   { pass4 = false }    // F1
    if (s * t) != 48                        { pass4 = false }    // F4
    if (j2 + s - t) != 32                   { pass4 = false }    // F5
    println("  case4 (closed-form math) : sigma=" + to_string(s) + " tau=" + to_string(t) + " phi=" + to_string(p) + " sopfr=" + to_string(sp) + " J_2=" + to_string(j2) + " → identities=" + (if pass4 { "PASS" } else { "FAIL" }))

    // case 5: single-system query
    let r5 = enumerate("cubic")
    println("  case5 (cubic only)       : bravais=" + to_string(r5[1]) + " space=" + to_string(r5[2]) + " pt=" + to_string(r5[3]))
    let mut pass5 = true
    if r5[1] != 3 { pass5 = false }
    if r5[2] != 36 { pass5 = false }
    if r5[3] != 5 { pass5 = false }
    if r5[4] != 0 { pass5 = false }

    let mut overall = "PASS"
    if !pass1 || !pass2 || !pass3 || !pass4 || !pass5 { overall = "FAIL" }

    println("  case1=" + (if pass1 { "PASS" } else { "FAIL" }) + " case2=" + (if pass2 { "PASS" } else { "FAIL" }) + " case3=" + (if pass3 { "PASS" } else { "FAIL" }) + " case4=" + (if pass4 { "PASS" } else { "FAIL" }) + " case5=" + (if pass5 { "PASS" } else { "FAIL" }))
    if overall == "PASS" {
        println("__CRYSTALLOGRAPHY_N6__ PASS")
        exit(0)
    }
    println("__CRYSTALLOGRAPHY_N6__ FAIL")
    exit(1)
}

// ─── runner ───

fn main() -> void {
    let raw_args = args()
    let mut cli = []
    let mut ai = 2
    while ai < len(raw_args) {
        cli.push(raw_args[ai])
        ai = ai + 1
    }

    let mut self_test = false
    let mut atlas_mode = false
    let mut json_mode = false
    let mut system = ""

    let mut i = 0
    while i < len(cli) {
        let a = cli[i]
        if a == "--self-test" || a == "--selftest" { self_test = true }
        else if a == "--atlas" { atlas_mode = true }
        else if a == "--json" { json_mode = true }
        else if a == "--system" {
            if i + 1 >= len(cli) { eprintln("--system requires value"); exit(1) }
            system = cli[i + 1]
            i = i + 1
        }
        else if a == "--help" || a == "-h" {
            println("usage: hexa run modules/crystallography_n6/crystallography_n6.hexa [opts]")
            println("  --self-test         run 5-case self-check")
            println("  --atlas             print 6 DSL-ready @F CRYSTAL-N6-* facts")
            println("  --json              JSON output mode")
            println("  --system NAME       enumerate single crystal system (default: all)")
            println("  systems             triclinic monoclinic orthorhombic tetragonal trigonal hexagonal cubic")
            exit(0)
        }
        else {
            eprintln("crystallography_n6: unknown arg `" + a + "`")
            exit(1)
        }
        i = i + 1
    }

    if self_test { _run_self_test() }

    if atlas_mode {
        let af = atlas_facts()
        let mut k = 0
        while k < len(af) {
            println(af[k])
            k = k + 1
        }
        exit(0)
    }

    let res = enumerate(system)
    if json_mode {
        println(_emit_json(res))
    } else {
        println("selected_system    = " + (if len(res[5]) == 0 { "(all)" } else { res[5] }))
        let sys = res[0]
        let mut k = 0
        while k < len(sys) {
            let r = sys[k]
            println("  " + r[0] + " : bravais=" + to_string(r[1]) + " space_groups=" + to_string(r[2]) + " point_groups=" + to_string(r[3]))
            k = k + 1
        }
        println("total_bravais      = " + to_string(res[1]))
        println("total_space_groups = " + to_string(res[2]))
        println("total_point_groups = " + to_string(res[3]))
        println("falsifier_status   = " + _falsifier_label(res[4]))
    }
    exit(0)
}
