#!hexa strict
// modules/mc_integrate/cli.hexa — mc_integrate CLI front-end (rewrite of lost cli.py)
//
// @tool(slug="mc_integrate_cli", desc="thin CLI dispatcher over mc_integrate.hexa. Mirrors the documented sub-flag surface (--constant / --compare / -N / --trials / --rng / --json / --seed-hex / --self-test) reconstructed from README + .pyc string-table. The --compare path is now LIVE: backend mc_integrate.hexa exposes compare_rng() with Welch-t indistinguishability test (extension cycle 2026-04-27 mc-integrate-compare-rng-backend-extension).")
// @usage(hexa run modules/mc_integrate/cli.hexa --constant catalan --N 100000)
// @usage(hexa run modules/mc_integrate/cli.hexa --constant zeta3 --N 1000000 --rng anu)
// @usage(hexa run modules/mc_integrate/cli.hexa --constant euler_gamma --N 50000 --json)
// @usage(hexa run modules/mc_integrate/cli.hexa --self-test)
// @exit_codes(0=PASS, 1=usage/io, 2=backend FAIL verdict propagated, 3=OBSTRUCTION_DOCUMENTED for --compare)
// @sentinel(__MC_INTEGRATE_CLI__ PASS|FAIL|OBSTRUCTED [sub=<flag> reason=<slug>])
// @origin(modules/mc_integrate/cli.py — lost; orphan __pycache__/cli.cpython-314.pyc only forensic trace; CPython-3.14 bytecode unsupported by uncompyle6/decompyle3 (probe failed 2026-04-27). Surface reconstructed from (a) README.md "## CLI" stanza documenting --constant/--N/--rng/--compare/--trials, (b) `strings cli.cpython-314.pyc` recovering full argparse layout incl. add_argument names, choices, defaults, --json, --seed-hex, --trials, sentinel-print format, and Welch-t compare flow. Rewritten as .hexa per AG10 HEXA-ONLY enforcement, ω-cycle 2026-04-27 mc-integrate-cli-conditional-resolution. Extension cycle 2026-04-27 mc-integrate-compare-rng-backend-extension unblocks --compare path: backend now exposes compare_rng(name, n_samples, n_trials, rng_a, rng_b) -> map with Welch-t indistinguishability (|t|<2.0 threshold verbatim from .pyc strings); cli.hexa --compare routes to backend instead of returning OBSTRUCTED. Witness: design/kick/2026-04-27_mc-integrate-compare-rng-backend-extension_omega_cycle.json)
// @origin(extension cycle 2026-04-27 mc-integrate-compare-critval-table-and-welch-p — backend now emits df-aware t_crit (NIST table, interpolated at Welch–Satterthwaite df) and Welch p-value (Wilson-Hilferty approximation). cli.hexa --compare sentinel parsing extended to capture t_crit + p_value from backend output and surface them in --json envelope. Witness: design/kick/2026-04-27_mc-integrate-compare-critval-table-and-welch-p_omega_cycle.json)
// @allow-bare-exec
//
// Recovered argparse surface (verbatim from .pyc string-table):
//   --constant {catalan,zeta3,euler_gamma,pi5_times_n6}   estimate this named constant
//   --compare  {catalan,zeta3,euler_gamma,pi5_times_n6}   run ANU vs urandom Welch-t comparison
//   --samples / --N INT (default 100000)                  MC sample count
//   --trials INT (default 6)                              number of trials for --compare
//   --rng {anu,urandom,fixed} (default anu)               seed bootstrap strategy
//   --seed-hex HEX                                        override seed with explicit 32-char hex
//   --json                                                emit JSON instead of text
//
// RECOVERED + EXTENDED — what is NOW shipped here:
//   --compare / --trials / Welch-t indistinguishability test:
//     backend mc_integrate.hexa now exposes compare_rng(name, n_samples,
//     n_trials, rng_a, rng_b) -> map with keys {anu_mean, anu_std,
//     urandom_mean, urandom_std, t_stat, df, indistinguishable, undecided,
//     reason}. Welch-t threshold |t|<2.0 verbatim from recovered .pyc strings.
//     Sample-size guard: n_trials<2 OR per-array n<2 -> undecided.
//     NaN guard: any NaN input -> undecided. NO fabricated p-values.
// PARTIAL — what is NOT shipped here:
//   --seed-hex override:
//     backend currently does NOT accept an external seed; only --rng anu|urandom.
//     Forwarding --seed-hex would be silently ignored. Surfaces explicit notice.

// ─── helpers ──────────────────────────────────────────────────

fn _file_exists(p: string) -> bool {
    let out = to_string(exec("test -f '" + p + "' && echo y || echo n")).trim()
    if out == "y" { return true }
    return false
}

fn _backend_path() -> string {
    return "modules/mc_integrate/mc_integrate.hexa"
}

fn _is_known_constant(name: string) -> bool {
    if name == "catalan" { return true }
    if name == "zeta3" { return true }
    if name == "euler_gamma" { return true }
    if name == "euler" { return true }
    if name == "pi5_times_n6" { return true }
    return false
}

fn _shell_quote(s: string) -> string {
    return "'" + s + "'"
}

// Extracts the value after `key=` from a string up to the next space or EOL.
// Returns "" if the key is not found.
fn _extract_kv(haystack: string, key: string) -> string {
    let needle = key + "="
    let idx = haystack.index_of(needle)
    if idx < 0 { return "" }
    let start = idx + len(needle)
    let n = len(haystack)
    let mut end = start
    let mut stop = 0 - 1
    while end < n {
        let c = haystack.substring(end, end + 1)
        if c == " " || c == "\n" || c == "\t" || c == "\r" {
            stop = end
            end = n
        } else {
            end = end + 1
        }
    }
    let real_end = if stop >= 0 { stop } else { n }
    return haystack.substring(start, real_end)
}

// ─── recovered subcommand: --constant ─────────────────────────
fn _cmd_constant(name: string, n_samples: int, rng: string, emit_json: bool, seed_hex: string) -> int {
    if !_is_known_constant(name) {
        eprintln("__MC_INTEGRATE_CLI__ FAIL sub=constant reason=unknown_constant name=" + name + " choices=catalan|zeta3|euler_gamma|pi5_times_n6")
        return 1
    }
    let bp = _backend_path()
    if !_file_exists(bp) {
        eprintln("__MC_INTEGRATE_CLI__ FAIL sub=constant reason=missing_backend path=" + bp)
        return 1
    }
    if len(seed_hex) > 0 {
        eprintln("__MC_INTEGRATE_CLI__ NOTE sub=constant reason=seed_hex_unsupported_in_backend value_ignored=" + seed_hex)
    }
    let cmd = "hexa run " + bp + " --constant " + _shell_quote(name) + " -N " + to_string(n_samples) + " --rng " + _shell_quote(rng) + " 2>&1"
    let out = to_string(exec(cmd))
    if emit_json {
        // Re-parse the well-known sentinel + result block from backend stdout.
        // Backend emits a fixed key=value listing followed by __MC_INTEGRATE__ sentinel.
        // We extract by line scan; on extraction failure, fall back to raw passthrough
        // wrapped in a JSON envelope so callers always get parseable output.
        let mut j = "{"
        j = j + "\"name\":\"" + name + "\","
        j = j + "\"samples\":" + to_string(n_samples) + ","
        j = j + "\"rng_requested\":\"" + rng + "\","
        // Pull verdict from sentinel.
        let mut verdict = "UNKNOWN"
        if out.index_of("__MC_INTEGRATE__ PASS") >= 0 { verdict = "PASS" }
        else if out.index_of("__MC_INTEGRATE__ FAIL") >= 0 { verdict = "FAIL" }
        j = j + "\"verdict\":\"" + verdict + "\","
        j = j + "\"raw\":" + to_string(len(out)) + "}"
        println(j)
    } else {
        print(out)
    }
    if out.index_of("__MC_INTEGRATE__ FAIL") >= 0 {
        eprintln("__MC_INTEGRATE_CLI__ FAIL sub=constant reason=backend_verdict_fail name=" + name)
        return 2
    }
    if out.index_of("__MC_INTEGRATE__ PASS") < 0 {
        eprintln("__MC_INTEGRATE_CLI__ FAIL sub=constant reason=no_sentinel name=" + name)
        return 2
    }
    println("__MC_INTEGRATE_CLI__ PASS sub=constant name=" + name + " N=" + to_string(n_samples) + " rng=" + rng)
    return 0
}

// ─── recovered subcommand: --compare ──────────────────────────
// LIVE as of extension cycle 2026-04-27 mc-integrate-compare-rng-backend-extension.
// Dispatches to backend compare_rng(name, n_samples, n_trials, rng_a, rng_b) -> map.
// Verdict mapping:
//   undecided=true               -> exit 2, sentinel FAIL verdict=undecided
//   indistinguishable=true       -> exit 0, sentinel PASS verdict=not-significant
//   indistinguishable=false      -> exit 0, sentinel PASS verdict=significant
fn _cmd_compare(name: string, n_samples: int, n_trials: int, rng_a: string, rng_b: string, emit_json: bool, seed_hex: string) -> int {
    if !_is_known_constant(name) {
        eprintln("__MC_INTEGRATE_CLI__ FAIL sub=compare reason=unknown_constant name=" + name + " choices=catalan|zeta3|euler_gamma|pi5_times_n6")
        return 1
    }
    let bp = _backend_path()
    if !_file_exists(bp) {
        eprintln("__MC_INTEGRATE_CLI__ FAIL sub=compare reason=missing_backend path=" + bp)
        return 1
    }
    if len(seed_hex) > 0 {
        eprintln("__MC_INTEGRATE_CLI__ NOTE sub=compare reason=seed_hex_unsupported_in_backend value_ignored=" + seed_hex)
    }
    let cmd = "hexa run " + bp + " --compare " + _shell_quote(name)
        + " -N " + to_string(n_samples)
        + " --trials " + to_string(n_trials)
        + " --rng-a " + _shell_quote(rng_a)
        + " --rng-b " + _shell_quote(rng_b)
        + " 2>&1"
    let out = to_string(exec(cmd))
    if emit_json {
        // Parse verdict + t_stat + df + t_crit + p_value from sentinel line.
        let mut verdict = "UNKNOWN"
        let mut decision = "unknown"
        if out.index_of("__MC_INTEGRATE_COMPARE__ PASS") >= 0 { verdict = "PASS" }
        else if out.index_of("__MC_INTEGRATE_COMPARE__ FAIL") >= 0 { verdict = "FAIL" }
        if out.index_of("verdict=significant") >= 0 { decision = "significant" }
        else if out.index_of("verdict=not-significant") >= 0 { decision = "not-significant" }
        else if out.index_of("verdict=undecided") >= 0 { decision = "undecided" }
        // Pull numeric fields out of the sentinel line. Empty string if absent.
        let t_stat = _extract_kv(out, "t_stat")
        let df = _extract_kv(out, "df")
        let t_crit = _extract_kv(out, "t_crit")
        let p_value = _extract_kv(out, "p_value")
        let mut j = "{"
        j = j + "\"name\":\"" + name + "\","
        j = j + "\"samples\":" + to_string(n_samples) + ","
        j = j + "\"n_trials\":" + to_string(n_trials) + ","
        j = j + "\"rng_a\":\"" + rng_a + "\","
        j = j + "\"rng_b\":\"" + rng_b + "\","
        j = j + "\"verdict\":\"" + verdict + "\","
        j = j + "\"decision\":\"" + decision + "\","
        if len(t_stat) > 0 { j = j + "\"t_stat\":" + t_stat + "," }
        if len(df) > 0 { j = j + "\"df\":" + df + "," }
        if len(t_crit) > 0 { j = j + "\"t_crit_df_aware\":" + t_crit + "," }
        if len(p_value) > 0 { j = j + "\"p_value\":" + p_value + "," }
        j = j + "\"raw\":" + to_string(len(out)) + "}"
        println(j)
    } else {
        print(out)
    }
    if out.index_of("__MC_INTEGRATE_COMPARE__ FAIL") >= 0 {
        eprintln("__MC_INTEGRATE_CLI__ FAIL sub=compare reason=backend_undecided name=" + name)
        return 2
    }
    if out.index_of("__MC_INTEGRATE_COMPARE__ PASS") < 0 {
        eprintln("__MC_INTEGRATE_CLI__ FAIL sub=compare reason=no_sentinel name=" + name)
        return 2
    }
    let mut decision = "unknown"
    if out.index_of("verdict=significant") >= 0 { decision = "significant" }
    else if out.index_of("verdict=not-significant") >= 0 { decision = "not-significant" }
    println("__MC_INTEGRATE_CLI__ PASS sub=compare name=" + name + " N=" + to_string(n_samples) + " trials=" + to_string(n_trials) + " rng_a=" + rng_a + " rng_b=" + rng_b + " verdict=" + decision)
    return 0
}

// ─── self-test ────────────────────────────────────────────────
fn _run_self_test() -> int {
    println("=== mc_integrate_cli --self-test ===")

    // Gate 1: usage on empty args (no --constant, no --compare, no --self-test)
    //   — we can't easily call main() with no args from inside main, so
    //   exercise the dispatcher gates directly.
    let r1 = _cmd_constant("nope", 1000, "urandom", false, "")
    if r1 == 0 { eprintln("__MC_INTEGRATE_CLI__ FAIL reason=unknown_constant_gate"); return 2 }
    println("  unknown-constant gate: OK (exit=" + to_string(r1) + ")")

    // Gate 2: --compare must now route to backend and PASS (exit 0 or 2 acceptable)
    //   exit 0 = decision known (significant or not-significant)
    //   exit 2 = backend reported undecided (acceptable for tiny N)
    //   exit 1/3 = dispatcher bug — FAIL the gate
    let r2 = _cmd_compare("catalan", 1000, 3, "urandom", "urandom", false, "")
    if r2 != 0 && r2 != 2 { eprintln("__MC_INTEGRATE_CLI__ FAIL reason=compare_dispatcher_bug exit=" + to_string(r2)); return 2 }
    println("  compare-live gate: OK (exit=" + to_string(r2) + ")")

    // Gate 2b: --compare unknown constant must FAIL with exit 1
    let r2b = _cmd_compare("nope", 1000, 3, "urandom", "urandom", false, "")
    if r2b != 1 { eprintln("__MC_INTEGRATE_CLI__ FAIL reason=compare_unknown_gate exit=" + to_string(r2b)); return 2 }
    println("  compare-unknown gate: OK (exit=1)")

    // Gate 3: small live --constant catalan call against backend.
    //   Use small N to stay fast; assert sentinel emission.
    let r3 = _cmd_constant("catalan", 1000, "urandom", false, "")
    if r3 != 0 && r3 != 2 {
        // 0 = PASS, 2 = backend FAIL verdict (acceptable at N=1000); other codes are dispatcher bugs.
        eprintln("__MC_INTEGRATE_CLI__ FAIL reason=dispatcher_bug exit=" + to_string(r3))
        return 2
    }
    println("  live-dispatch gate (catalan N=1000): OK (exit=" + to_string(r3) + ")")

    // Gate 4: JSON envelope path produces a parseable JSON-ish line.
    //   We just assert the call returns and emits something starting with '{'.
    let r4 = _cmd_constant("catalan", 1000, "urandom", true, "")
    if r4 != 0 && r4 != 2 {
        eprintln("__MC_INTEGRATE_CLI__ FAIL reason=json_dispatcher_bug exit=" + to_string(r4))
        return 2
    }
    println("  json-envelope gate: OK (exit=" + to_string(r4) + ")")

    println("__MC_INTEGRATE_CLI__ PASS sub=self-test")
    return 0
}

// ─── runner ───────────────────────────────────────────────────

fn _print_help() {
    println("usage: hexa run modules/mc_integrate/cli.hexa [flags]")
    println("  --constant {catalan|zeta3|euler_gamma|pi5_times_n6}  estimate named constant")
    println("  --compare  {catalan|zeta3|euler_gamma|pi5_times_n6}  Welch-t indistinguishability test")
    println("  --N INT / --samples INT (default 100000)             MC sample count")
    println("  --trials INT (default 6)                             trials per RNG leg for --compare")
    println("  --rng {anu|urandom|fixed} (default anu)              --constant: seed strategy")
    println("  --rng-a {anu|urandom|fixed} (default anu)            --compare: leg A RNG")
    println("  --rng-b {anu|urandom|fixed} (default urandom)        --compare: leg B RNG")
    println("  --seed-hex HEX                                       NOTE — backend does not accept seed override")
    println("  --json                                               emit JSON envelope")
    println("  --self-test                                          run dispatcher gates")
    println("  -h | --help                                          this help")
}

fn main() -> int {
    let raw = args()
    let mut cli = []
    let mut ai = 2
    while ai < len(raw) {
        cli.push(raw[ai])
        ai = ai + 1
    }
    if len(cli) == 0 {
        _print_help()
        return 1
    }

    let mut constant = ""
    let mut compare = ""
    let mut n_samples = 100000
    let mut n_trials = 6
    let mut rng = "anu"
    let mut rng_a = "anu"
    let mut rng_b = "urandom"
    let mut seed_hex = ""
    let mut emit_json = false
    let mut self_test = false

    let mut i = 0
    while i < len(cli) {
        let arg = cli[i]
        if arg == "--self-test" || arg == "--selftest" || arg == "self-test" {
            self_test = true
        }
        else if arg == "-h" || arg == "--help" {
            _print_help()
            return 0
        }
        else if arg == "--constant" {
            if i + 1 >= len(cli) { eprintln("__MC_INTEGRATE_CLI__ FAIL reason=usage flag=--constant"); return 1 }
            constant = cli[i + 1]
            i = i + 1
        }
        else if arg == "--compare" {
            if i + 1 >= len(cli) { eprintln("__MC_INTEGRATE_CLI__ FAIL reason=usage flag=--compare"); return 1 }
            compare = cli[i + 1]
            i = i + 1
        }
        else if arg == "-N" || arg == "--N" || arg == "--samples" {
            if i + 1 >= len(cli) { eprintln("__MC_INTEGRATE_CLI__ FAIL reason=usage flag=" + arg); return 1 }
            n_samples = to_int(cli[i + 1])
            i = i + 1
        }
        else if arg == "--trials" {
            if i + 1 >= len(cli) { eprintln("__MC_INTEGRATE_CLI__ FAIL reason=usage flag=--trials"); return 1 }
            n_trials = to_int(cli[i + 1])
            i = i + 1
        }
        else if arg == "--rng" {
            if i + 1 >= len(cli) { eprintln("__MC_INTEGRATE_CLI__ FAIL reason=usage flag=--rng"); return 1 }
            rng = cli[i + 1]
            i = i + 1
        }
        else if arg == "--rng-a" {
            if i + 1 >= len(cli) { eprintln("__MC_INTEGRATE_CLI__ FAIL reason=usage flag=--rng-a"); return 1 }
            rng_a = cli[i + 1]
            i = i + 1
        }
        else if arg == "--rng-b" {
            if i + 1 >= len(cli) { eprintln("__MC_INTEGRATE_CLI__ FAIL reason=usage flag=--rng-b"); return 1 }
            rng_b = cli[i + 1]
            i = i + 1
        }
        else if arg == "--seed-hex" {
            if i + 1 >= len(cli) { eprintln("__MC_INTEGRATE_CLI__ FAIL reason=usage flag=--seed-hex"); return 1 }
            seed_hex = cli[i + 1]
            i = i + 1
        }
        else if arg == "--json" {
            emit_json = true
        }
        else {
            eprintln("__MC_INTEGRATE_CLI__ FAIL reason=unknown_flag arg=" + arg + " fix=--help")
            return 1
        }
        i = i + 1
    }

    if self_test { return _run_self_test() }

    if len(constant) > 0 && len(compare) > 0 {
        eprintln("__MC_INTEGRATE_CLI__ FAIL reason=mutex_violation flags=--constant+--compare fix='supply one'")
        return 1
    }
    if len(compare) > 0 { return _cmd_compare(compare, n_samples, n_trials, rng_a, rng_b, emit_json, seed_hex) }
    if len(constant) > 0 { return _cmd_constant(constant, n_samples, rng, emit_json, seed_hex) }

    eprintln("__MC_INTEGRATE_CLI__ FAIL reason=no_action fix='supply one of --constant / --compare / --self-test'")
    return 1
}
