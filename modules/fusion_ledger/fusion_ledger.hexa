#!hexa strict
// modules/fusion_ledger/fusion_ledger.hexa — n=6 fusion-energy constants verifier
//
// @tool(slug="fusion_ledger", desc="ITER + n=6 fusion design ledger: verify 27 measured constants against closed-form n=6 expressions (sigma, tau, phi, sopfr, J2, n, mu) within per-entry tolerance. Reports honest match count + falsified list.")
// @usage(hexa run modules/fusion_ledger/fusion_ledger.hexa --self-test)
// @usage(hexa run modules/fusion_ledger/fusion_ledger.hexa --verify [--json])
// @sentinel(__FUSION_LEDGER__ <PASS|FAIL> [reason=<slug>])
// @origin(rewrite of lost 425-LOC Python module via .hexa, sourced from
//         ~/core/n6-architecture/domains/energy/fusion/ + verify_fusion.hexa
//         + data/iter_constants.json (already on disk).
//         HONESTY: previous Python build verified 26/27 (96.3%); the
//         lawson_triple_keV_s_per_m3 entry is falsified by one decade
//         (measured 5.6e21 keV·s/m³ vs n=6 closed-form 5.6e20). Preserved.)
//
// Hard rules:
//   - HEXA-ONLY policy: no .py / .sh / .rs / .toml writes
//   - Honesty: do NOT inflate match count; lawson_triple stays falsified
//   - Per-entry tolerance: 0.0 (exact) or fraction of measured (e.g. 0.05 = 5%)
//
// API note:
//   The public verifier function is `run_verify(constants: map) -> map`.
//   The original spec asked for `verify(...)`, but `verify` is a reserved
//   keyword in hexa (claimed by the @invariant DSL); renaming to run_verify
//   keeps every other contract intact: same input shape, same return keys.
//
// Number-theory primitives (defined locally; no shared lib import):
//   N=6, PHI=2, TAU=4, SIGMA=12, SOPFR=5, J2=24, MU=1
//   Master identity: σ·φ = n·τ = J₂ = 24
//   Fuel: D ↔ A=φ=2, T ↔ A=n/φ=3, α ↔ A=τ=4
//   Q-gain = σ-φ = 10, Brayton η = σ/J₂ = 50%, plasma T_i = σ+φ = 14 keV

// ─── n=6 anchors ──────────────────────────────────────────────

fn _N() -> int { return 6 }
fn _PHI() -> int { return 2 }
fn _TAU() -> int { return 4 }
fn _SIGMA() -> int { return 12 }
fn _SOPFR() -> int { return 5 }
fn _J2() -> int { return 24 }
fn _MU() -> int { return 1 }

fn _Nf() -> float { return 6.0 }
fn _PHIf() -> float { return 2.0 }
fn _TAUf() -> float { return 4.0 }
fn _SIGMAf() -> float { return 12.0 }
fn _SOPFRf() -> float { return 5.0 }
fn _J2f() -> float { return 24.0 }
fn _MUf() -> float { return 1.0 }

fn _assert_n6_identity() -> bool {
    if _SIGMA() * _PHI() != _J2() { return false }
    if _N() * _TAU() != _J2() { return false }
    return true
}

fn _abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ─── 27 ITER constants (hardcoded fallback) ───────────────────
// Each entry: [name, measured, formula_value, tolerance_frac, formula_text, section]
// formula_value is the closed-form n=6 expression already evaluated at compile time
// of this hexa source — same arithmetic the Python build performed verbatim.
//
// Tolerance semantics: |measured - formula| / max(|measured|, 1e-30) <= tolerance.
// tolerance == 0.0 means exact equality.

fn _all_constants() -> array {
    // Construct numeric formula values once, with float arithmetic.
    let s = _SIGMAf()
    let p = _PHIf()
    let t = _TAUf()
    let sp = _SOPFRf()
    let n = _Nf()
    let j2 = _J2f()
    let m = _MUf()

    let alpha_e = 100.0 / sp                // 20
    let neut_e = 100.0 * t / sp             // 80
    let plasma = s + p                      // 14
    let q_gain = s - p                      // 10
    let crit_r = 1.0 / (s - p)              // 0.1
    let brayton = 100.0 * s / j2            // 50
    let tau_e = 1.0 / s                     // 0.0833...
    let lawson = (s * t * 1.0e19) * (1.0 / s) * (s + p)  // 5.6e20  (one decade short of measured 5.6e21)
    let p_fus = p * sp                      // 10
    let ruler = s * t                       // 48
    let speed = s - p                       // 10

    return [
        ["n_basic_unit",                  6.0,        n,                  0.0,    "n",                              "fusion.md §4"],
        ["dual_symmetry_phi",             2.0,        p,                  0.0,    "phi",                            "fusion.md §4"],
        ["parallel_channels_tau",         4.0,        t,                  0.0,    "tau",                            "fusion.md §4"],
        ["integration_output_sigma",      12.0,       s,                  0.0,    "sigma",                          "fusion.md §4"],
        ["sopfr_prime_factor_sum",        5.0,        sp,                 0.0,    "sopfr",                          "fusion.md §4"],
        ["dual_J2",                       24.0,       j2,                 0.0,    "J2",                             "fusion.md §4"],
        ["ruler_field_T",                 48.0,       ruler,              0.0,    "sigma * tau",                    "fusion.md §4 (SC coil)"],
        ["speed_limit",                   10.0,       speed,              0.0,    "sigma - phi",                    "fusion.md §4"],
        ["critical_radius_m",             0.1,        crit_r,             1.0e-6, "1.0 / (sigma - phi)",            "fusion.md §4 (B^4)"],
        ["mu_squarefree",                 1.0,        m,                  0.0,    "mu",                             "fusion.md §4"],
        ["se3_dim",                       6.0,        n,                  0.0,    "n",                              "fusion.md §4"],
        ["deuterium_mass_number",         2.0,        p,                  0.0,    "phi",                            "verify_fusion.hexa"],
        ["tritium_mass_number",           3.0,        n / p,              0.0,    "n / phi",                        "verify_fusion.hexa"],
        ["alpha_mass_number",             4.0,        t,                  0.0,    "tau",                            "verify_fusion.hexa"],
        ["alpha_energy_fraction_pct",     20.0,       alpha_e,            0.05,   "100.0 / sopfr",                  "verify_fusion.hexa"],
        ["neutron_energy_fraction_pct",   80.0,       neut_e,             0.05,   "100.0 * tau / sopfr",            "verify_fusion.hexa"],
        ["plasma_temperature_keV",        14.0,       plasma,             0.0,    "sigma + phi",                    "verify_fusion.hexa"],
        ["Q_gain",                        10.0,       q_gain,             0.0,    "sigma - phi",                    "fusion.md §8.4"],
        ["Li6_mass_number",               6.0,        n,                  0.0,    "n",                              "verify_fusion.hexa (blanket)"],
        ["TBR_numerator",                 7.0,        n + 1.0,            0.0,    "n + 1",                          "verify_fusion.hexa"],
        ["TBR_denominator",               6.0,        n,                  0.0,    "n",                              "verify_fusion.hexa"],
        ["brayton_efficiency_pct",        50.0,       brayton,            0.05,   "100.0 * sigma / J2",             "verify_fusion.hexa"],
        ["TF_coils",                      18.0,       3.0 * n,            0.0,    "3 * n",                          "verify_fusion.hexa"],
        ["energy_confinement_time_s",     0.083,      tau_e,              0.01,   "1.0 / sigma",                    "fusion.md §8.4"],
        ["lawson_triple_keV_s_per_m3",    5.6e21,     lawson,             0.001,  "(sigma*tau*1e19)*(1/sigma)*(sigma+phi)", "fusion.md §8.1 (one-decade gap, honest)"],
        ["P_fus_per_V_MWm3",              10.0,       p_fus,              0.0,    "phi * sopfr",                    "fusion.md §8.4 (conjecture)"],
        ["B4_scaling_exponent",           4.0,        t,                  0.0,    "tau",                            "fusion.md §8.3"]
    ]
}

// ─── verifier core ────────────────────────────────────────────

fn _within_tolerance(measured: float, formula: float, tol: float) -> bool {
    let delta = _abs(measured - formula)
    if tol == 0.0 {
        // Exact: allow 1e-12 epsilon for float identity
        if delta < 1.0e-12 { return true }
        return false
    }
    let ref_val = _abs(measured)
    let denom = if ref_val < 1.0e-30 { 1.0e-30 } else { ref_val }
    let ratio = delta / denom
    if ratio <= tol { return true }
    return false
}

fn run_verify(constants: map) -> map {
    // `constants` parameter is currently advisory: this implementation uses
    // the locally-hardcoded 27-entry table (matching data/iter_constants.json).
    // The map argument is kept in the signature for API parity and future
    // override hooks; len(constants)==0 means "use hardcoded defaults".
    let table = _all_constants()
    let total = len(table)
    let mut matched = 0
    let mut falsified = []
    let mut details = []
    let mut i = 0
    while i < total {
        let row = table[i]
        let name = row[0]
        let measured = row[1]
        let formula = row[2]
        let tol = row[3]
        let formula_text = row[4]
        let ok = _within_tolerance(measured, formula, tol)
        if ok {
            matched = matched + 1
            details.push([name, "MATCH", measured, formula])
        } else {
            falsified.push(name)
            details.push([name, "FALSIFIED", measured, formula])
        }
        i = i + 1
    }
    let pct = (100.0 * to_float(matched)) / to_float(total)
    return #{
        "constants_total": total,
        "n6_match":        matched,
        "n6_match_pct":    pct,
        "falsified":       falsified,
        "details":         details
    }
}

fn _to_float_safe(x) -> float {
    return to_float(x)
}

// ─── self-test ───────────────────────────────────────────────

fn _self_test() -> void {
    println("=== fusion_ledger --self-test ===")
    if !_assert_n6_identity() {
        println("__FUSION_LEDGER__ FAIL reason=n6-identity fix=verify σ·φ=n·τ=24")
        exit(1)
    }
    println("  σ·φ=n·τ=" + to_string(_J2()) + " PASS")
    let result = run_verify(#{})
    // 1) result is dict-shaped with required keys
    let total = result["constants_total"]
    let matched = result["n6_match"]
    let pct = result["n6_match_pct"]
    let falsified = result["falsified"]
    if total != 27 {
        println("__FUSION_LEDGER__ FAIL reason=bad-total got=" + to_string(total) + " expected=27")
        exit(1)
    }
    println("  constants_total=" + to_string(total) + " (=27) PASS")
    // 2) match >= 80%
    let pct_int = to_int(pct)
    if pct_int < 80 {
        println("__FUSION_LEDGER__ FAIL reason=low-match pct=" + to_string(pct) + " threshold=80")
        exit(1)
    }
    println("  n6_match=" + to_string(matched) + "/" + to_string(total) + " = " + to_string(pct) + "% (>=80) PASS")
    // 3) lawson_triple in falsified list (HONESTY guard)
    let mut found_lawson = false
    let mut i = 0
    while i < len(falsified) {
        if falsified[i] == "lawson_triple_keV_s_per_m3" {
            found_lawson = true
        }
        i = i + 1
    }
    if !found_lawson {
        println("__FUSION_LEDGER__ FAIL reason=honesty-violation lawson_triple missing from falsified list (must NOT silently pass) fix=preserve 26/27 honest finding")
        exit(1)
    }
    println("  HONESTY: lawson_triple_keV_s_per_m3 in falsified list PASS (one-decade gap preserved)")
    // 4) honest count must be exactly 26/27 (no over-claim)
    if matched != 26 {
        println("__FUSION_LEDGER__ FAIL reason=match-count-drift got=" + to_string(matched) + " expected=26 (Python build: 26/27 = 96.3%) fix=do not paint over the lawson gap")
        exit(1)
    }
    println("  honest count exactly 26/27 (no inflation to 27/27) PASS")
    // 5) tolerance predicate sanity
    if !_within_tolerance(10.0, 10.0, 0.0) {
        println("__FUSION_LEDGER__ FAIL reason=tolerance-exact-broken")
        exit(1)
    }
    if _within_tolerance(1.0, 100.0, 0.05) {
        println("__FUSION_LEDGER__ FAIL reason=tolerance-too-loose 1 vs 100 within 5% should be FALSE")
        exit(1)
    }
    if !_within_tolerance(50.0, 51.0, 0.05) {
        println("__FUSION_LEDGER__ FAIL reason=tolerance-too-tight 50 vs 51 within 5% should be TRUE")
        exit(1)
    }
    println("  tolerance predicate sanity PASS")
    println("__FUSION_LEDGER__ PASS total=" + to_string(total) + " matched=" + to_string(matched) + " falsified=" + to_string(len(falsified)) + " pct=" + to_string(pct))
    exit(0)
}

// ─── CLI ─────────────────────────────────────────────────────

fn _print_help() -> void {
    println("usage:")
    println("  hexa run modules/fusion_ledger/fusion_ledger.hexa --verify   # full ledger report")
    println("  hexa run modules/fusion_ledger/fusion_ledger.hexa --self-test")
    println("notes:")
    println("  27 ITER + n=6 fusion-design constants. HONEST 26/27 match (one-decade lawson gap preserved).")
}

fn _print_verify(result: map) -> void {
    let total = result["constants_total"]
    let matched = result["n6_match"]
    let pct = result["n6_match_pct"]
    let falsified = result["falsified"]
    let details = result["details"]
    println("=== fusion_ledger verify ===")
    println("constants_total : " + to_string(total))
    println("n6_match        : " + to_string(matched) + "/" + to_string(total))
    println("n6_match_pct    : " + to_string(pct) + "%")
    println("falsified       : " + to_string(len(falsified)) + " entr(y|ies)")
    let mut i = 0
    while i < len(falsified) {
        println("  - " + falsified[i])
        i = i + 1
    }
    println("---")
    let mut j = 0
    while j < len(details) {
        let d = details[j]
        let mark = if d[1] == "MATCH" { "[OK]" } else { "[XX]" }
        println("  " + mark + " " + d[0] + "  measured=" + to_string(d[2]) + "  formula=" + to_string(d[3]))
        j = j + 1
    }
    println("---")
    println("HONESTY: lawson_triple_keV_s_per_m3 reported as falsified (measured 5.6e21 vs n=6 closed-form 5.6e20 — one decade gap, source-noted '×10 calibration scale').")
    println("__FUSION_LEDGER__ PASS total=" + to_string(total) + " matched=" + to_string(matched) + " pct=" + to_string(pct))
}

fn main() -> void {
    let raw = args()
    let mut cli = []
    let mut ai = 2
    while ai < len(raw) {
        cli.push(raw[ai])
        ai = ai + 1
    }
    let mut do_verify = false
    let mut self_test = false
    let mut i = 0
    while i < len(cli) {
        let a = cli[i]
        if a == "--self-test" || a == "--selftest" { self_test = true }
        else if a == "--verify" { do_verify = true }
        else if a == "--help" || a == "-h" { _print_help(); exit(0) }
        else {
            eprintln("__FUSION_LEDGER__ FAIL reason=unknown-arg arg=" + a)
            exit(1)
        }
        i = i + 1
    }
    if self_test { _self_test() }
    if do_verify {
        let r = run_verify(#{})
        _print_verify(r)
        exit(0)
    }
    _print_help()
    exit(0)
}
