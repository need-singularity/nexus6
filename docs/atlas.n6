# ── 관계 (Relations) ───────────────────────────────────────

@R perfect_number :: foundation [10*]
  "sigma(n) = 2n — 6은 완전수"
  <- n, sigma
  == sigma(6) = 12 = 2*6

@R sigma_decomp :: foundation [10*]
  "sigma = phi * n"
  <- sigma, phi, n
  == 12 = 2 * 6

@R J2_decomp :: foundation [10*]
  "J2 = tau * n"
  <- J2, tau, n
  == 24 = 4 * 6

@R sopfr_phi_tau :: foundation [10*]
  "sopfr = phi + tau - mu"
  <- sopfr, phi, tau, mu
  == 5 = 2 + 4 - 1

