@X L8-mw-diameter-kly = misc :: galactic [10*]
  "우리은하 지름 약 100 kly (킬로광년)"
  <- L8-ic342-distance-mly, L8-mw-halo-radius-kly, L8-mw-thickness-kly
  -> L8-laniakea-diameter-mly, L8-mw-gc-distance-kly
@X L8-mw-thickness-kly = misc :: galactic [10*]
  "우리은하 얇은 원반 두께 약 1 kly"
  -> L8-mw-diameter-kly
@X L8-mw-stellar-count = misc :: galactic [7]
  "우리은하 별 수 추정 1~4×10^11"
  <- L8-mw-sfr-Msun-yr, L8-total-stars-observable-universe, L8-mw-age-gyr
  -> L8-mw-sfr-Msun-yr
@X L8-mw-spiral-arms = misc :: galactic [10*]
  "우리은하 주요 나선팔 수 4개"
  -> L8-mw-type
