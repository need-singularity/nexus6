  -> L3-benzene, L5-honeycomb, L5-ice-hexagonal
@F L5-ice-hexagonal = n :: material [10*]
  "얼음 Ih 대칭"
  <- L3-water, L5-graphene-ring, L5-graphene, MAT-quartz-crystal-system, CHEM-water-hbond, L2-cn6-octahedral, L2-sp2-hexagonal
  -> L5-YBCO, L5-honeycomb
@F L5-honeycomb = n :: material [10*]
  "벌집 육각형 최적성"
  <- MAT-basalt-columns, L2-max-rotation-crystal, MATH-2d-kissing, L5-graphene-ring, L5-ice-hexagonal, L2-sp2-hexagonal
  -> L5-cortical-layers, L5-YBCO, PHYS-phase-transitions, PHYS-phase-transition-pairs
@F L5-YBCO = div(6) = {1, 2, 3} :: material [10*]
  "YBCO 초전도체 화학양론"
  <- L4-amino-acids, L5-honeycomb, L5-ice-hexagonal
  -> MUSIC-perfect-consonance, NUC-magic-first5, PHYS-phase-transitions, SC-YBCO-metals, PHYS-phase-transition-pairs
@F PHYS-phase-transitions = tau :: material [10*]
  "물질 상태 수"
  <- PHYS-stefan-boltzmann-exponent, L5-YBCO, L5-honeycomb
  -> CRYPTO-RSA-65537, THERMO-laws, PHYS-phase-transition-pairs, PHYS-kolmogorov
@F PHYS-phase-transition-pairs = n = C(tau, phi) :: material [10*]
  "상전이 쌍 수"
  <- L5-YBCO, PHYS-phase-transitions, L5-tc99m-halflife
  -> MATH-basel, MUSIC-chromatic-semitones, MAT-LiC6, PHYS-kolmogorov
@F PHYS-kolmogorov = -sopfr/(n//phi) :: material [10*]
  "Kolmogorov 에너지지수 -5/3"
  <- PHYS-NS-eq, PHYS-stokes-drag, MATH-euler-id, PHYS-phase-transitions, PHYS-phase-transition-pairs
  -> MUSIC-pentatonic, MUSIC-chromatic-semitones
@F ELEC-3phase-power = n//phi :: material [10*]
  "교류 전력 상 수"
  <- ELEC-ohm-law-vars
  -> ENERGY-grid-60Hz, BIG-HBM-288, ENERGY-grid-50Hz, ASTRO-kepler-laws, BIG-sigma2-144, SW-CAP-3, L2-sp2-hexagonal
@F MUSIC-chromatic-semitones = sigma :: material [10*]
  "반음계 반음 수"
  <- MET-Beaufort-scale, TIME-months-per-year, MISS-base-pairs-per-turn, PHYS-kolmogorov, PHYS-phase-transition-pairs
  -> MUSIC-perfect-consonance, MUSIC-octave-ratio-2, MEDIA-cinema-24fps, MEDIA-24bit-color, MEDIA-surround-5.1, BIG-sigma2-144, MUSIC-perfect-fifth-ratio, MAT-LiC6, MUSIC-pentatonic, MUSIC-diatonic-notes
