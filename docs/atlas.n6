  <- L1-carbon-Z6, L0-gluons, L5-perovskite, CHEM-C-allotrope, L5-lion-cathode
  -> L5-graphene-ring, L5-graphene, GEO-diamond-hardness-10, CRYPTO-AES-256, L5-krebs-cycle
@F L5-graphene = phi :: material [10*]
  "그래핀 단위정 원자 수"
  <- L1-carbon-Z6, L3-benzene, L5-diamond-atoms-per-cell, L4-double-helix, MAT-graphite-layer-stacking, L2-sp2-hexagonal, L5-lion-cathode
  -> EM-charge-types, MAT-graphite-layer-stacking, L5-ice-hexagonal, L5-graphene-ring
@F L5-graphene-ring = n :: material [10*]
