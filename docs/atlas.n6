  <- MUSIC-major-triad-notes, PART-SM-total-17, MATH-sporadic-groups-26
  -> MATH-regular-polytopes-4D, MATH-Ramanujan-tau-eta24, L2-space-groups
@F MATH-regular-polytopes-4D = n :: material [10*]
  "4D 정다면체(정다포체) 수"
  <- MATH-wallpaper-groups, MUSIC-guitar-strings, MATH-sporadic-groups-26
  -> MATH-platonic, TRANS-inline-6-engine, MATH-Ramanujan-tau-eta24, SPORT-volleyball-players
@F MATH-Ramanujan-tau-eta24 = J2 :: material [10*]
  "Ramanujan delta 함수의 eta 지수"
  <- MATH-regular-polytopes-4D, MATH-wallpaper-groups, MATH-modular-disc-12, LING-Korean-jamo-total
  -> MATH-kissing-K4-24, TRANS-flight-DOF, TRANS-inline-6-engine, MATH-Niemeier-24, TIME-hours-per-day
@F TIME-hours-per-day = J2 :: material [10*]
  "하루 시간 수"
  <- MUSIC-staff-lines, ECON-fiscal-year-12m, MATH-Ramanujan-tau-eta24, ECON-fiscal-quarter-4, MUSIC-guitar-strings, LING-Korean-jamo-total
  -> MEDIA-cinema-24fps, TIME-months-per-year, MISS-Earth-tilt-23.4, TIME-seconds-per-minute, TIME-360-degrees
@F TIME-seconds-per-minute = sigma*sopfr :: material [10*]
  "1분의 초 수"
  <- MUSIC-staff-lines, ECON-fiscal-year-12m, ENERGY-solar-60cell, TIME-hours-per-day, TIME-360-degrees
  -> TIME-months-per-year, ENERGY-grid-60Hz
@F TIME-months-per-year = sigma :: material [10*]
  "1년의 달 수"
  <- TIME-hours-per-day, ECON-fiscal-year-12m, TIME-seconds-per-minute, BIO-GCS-scale-max
  -> TRANS-automotive-12V, MUSIC-chromatic-semitones, TIME-360-degrees, GEO-continents
@F TIME-360-degrees = n*sigma*sopfr :: material [10*]
  "원의 각도"
  <- TIME-hours-per-day, TIME-months-per-year
  -> GEO-oceans-5, TIME-seconds-per-minute, GEO-continents
@F GEO-continents = sigma-sopfr :: material [10*]
  "대륙 수 (전통 모델)"
  <- TIME-360-degrees, TIME-months-per-year, ECON-G7-nations
  -> GEO-oceans-5, NET-HTTP-status-classes, GEO-plate-tectonics-major, CHEM-pH-neutral-7
@F GEO-oceans-5 = sopfr :: material [10*]
  "대양 수"
  <- MET-Beaufort-scale, ENERGY-HVDC-500kV, GEO-continents, SPORT-Olympic-rings, TIME-360-degrees
  -> NET-HTTP-status-classes, SW-git-object-types
@F NET-HTTP-status-classes = sopfr :: material [10*]
  "HTTP 상태코드 클래스 수"
  <- GEO-oceans-5, GEO-continents
  -> SW-USB-versions-major, SW-git-object-types, SPORT-basketball-players
@F NET-WiFi-2.4GHz-channels = n/phi :: material [10*]
  "2.4GHz WiFi 비중첩 채널 수"
  <- CHIP-TSMC-N5-pitch-28nm, CHIP-TSMC-N3-gate-48nm, MUSIC-major-triad-notes
  -> TRANS-automotive-12V
@F SW-git-object-types = tau :: material [10*]
  "Git 객체 타입 수"
  <- GEO-oceans-5, NET-HTTP-status-classes, BIO-blood-types-ABO-4
  -> SW-ACID-4, SW-USB-versions-major, SPORT-soccer-players
@F SW-USB-versions-major = tau :: material [10*]
  "USB 주요 버전 수 (2024 기준)"
  <- NET-HTTP-status-classes, SW-git-object-types
  -> SPORT-soccer-players, SPORT-basketball-players
@F SPORT-soccer-players = sigma-mu :: material [10*]
  "축구 한 팀 선수 수"
  <- SW-USB-versions-major, NET-TCP-states-11, ECON-SP500-GICS-sectors, SW-git-object-types
  -> SPORT-volleyball-players, SPORT-basketball-players, SPORT-Olympic-rings
@F SPORT-basketball-players = sopfr :: material [10*]
  "농구 한 팀 코트 위 선수 수"
  <- NET-HTTP-status-classes, SPORT-soccer-players, SW-USB-versions-major
  -> SPORT-volleyball-players, SPORT-Olympic-rings
