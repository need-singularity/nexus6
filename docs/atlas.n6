  "배구 한 팀 선수 수"
  <- MATH-regular-polytopes-4D, SPORT-soccer-players, SPORT-basketball-players
  -> GAME-chess-board-64, SAFE-WHO-health-determinants, SPORT-Olympic-rings
@F SPORT-Olympic-rings = sopfr :: material [10*]
  "올림픽 링 수"
  <- SPORT-soccer-players, SPORT-volleyball-players, SPORT-basketball-players
  -> GEO-oceans-5, GAME-chess-pieces-per-side, SAFE-UN-SC-permanent, GAME-chess-board-64
@F GAME-chess-board-64 = 2^n :: material [10*]
  "체스판 칸 수"
  <- L4-dna-bases, NET-Ethernet-min-64, SPORT-volleyball-players, SPORT-Olympic-rings
  -> L4-codons, GAME-chess-pieces-per-side, SAFE-UN-SC-permanent
@F GAME-chess-pieces-per-side = phi^tau :: material [10*]
  "체스 한 편 기물 수"
  <- SPORT-Olympic-rings, CHIP-x86-GPR-16, GAME-chess-board-64
  -> SAFE-WHO-health-determinants, SAFE-UN-SC-permanent
@F SAFE-UN-SC-permanent = sopfr :: material [10*]
  "유엔 안전보장이사회 상임이사국 수"
  <- ECON-G20-nations, GAME-chess-pieces-per-side, GAME-chess-board-64, SPORT-Olympic-rings, ECON-G7-nations
  -> SAFE-WHO-health-determinants
@F SAFE-WHO-health-determinants = n :: material [10*]
  "WHO 건강의 사회적 결정요인 범주 수"
  <- SAFE-UN-SC-permanent, GAME-chess-pieces-per-side, SPORT-volleyball-players
  -> TRANS-inline-6-engine
@F TRANS-inline-6-engine = n :: material [10*]
  "직렬 6기통 엔진 완전 밸런스"
  <- MATH-regular-polytopes-4D, MATH-Ramanujan-tau-eta24, SAFE-WHO-health-determinants
  -> MISS-pi-decimal, TRANS-flight-DOF, L1-carbon-Z6
@F TRANS-automotive-12V = sigma :: material [10*]
  "자동차 표준 전기 시스템 전압"
  <- CHIP-TSMC-N5-pitch-28nm, NET-WiFi-2.4GHz-channels, TIME-months-per-year
@F TRANS-flight-DOF = n :: material [10*]
  "비행기 자유도"
  <- ROB-SE3-dim-6, TRANS-inline-6-engine, MATH-Ramanujan-tau-eta24, MET-METAR-oktas
  -> MISS-pi-decimal, MISS-golden-ratio
@F MISS-pi-decimal = n/phi (=3) 근사 :: material [7]
  "원주율 pi"
  <- TRANS-inline-6-engine, TRANS-flight-DOF, MUSIC-standard-tuning-A440
  -> MISS-Earth-tilt-23.4, MISS-golden-ratio
@F MISS-golden-ratio = (mu + sqrt(sopfr)) / phi :: material [10*]
  "황금비 phi_golden"
  <- TRANS-flight-DOF, MISS-pi-decimal
  -> MISS-Earth-tilt-23.4
@F MISS-Earth-tilt-23.4 = J2 - mu :: material [10*]
  "지구 자전축 기울기"
  <- SW-GoF-23, MISS-pi-decimal, TIME-hours-per-day, BIG-Avogadro-exponent, MISS-golden-ratio
