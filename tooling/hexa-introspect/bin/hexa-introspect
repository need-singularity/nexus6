#!/bin/bash
# tooling/hexa-introspect/bin/hexa-introspect — launcher shim
#
# `hexa --ast` / `hexa --symbols` 와 같은 인터페이스를 본 wrapper 가 흉내낸다.
# spec: design/hexa_cli_introspection_spec.md (Phase 1 = --ast + --symbols)
# 갭 카탈로그: hexa-cli-introspection (Rank 3)
#
# 사용:
#   hexa-introspect --ast      <file.hexa>
#   hexa-introspect --symbols  <file.hexa>
#
# 환경 변수:
#   HEXA_BIN  (기본: ~/.hx/bin/hexa) — 실제 hexa 컴파일러 경로
#
# stdout: JSON
# stderr: NEXUS_HEXA_INTROSPECT NDJSON 메타 + (resolver 1줄)
# exit: 0=ok, 1=invalid-args, 2=file-unreadable
set -eu

_usage() {
  cat <<'EOF' >&2
usage: hexa-introspect <mode> <file.hexa> [opts...]
modes:
  --ast               emit Program AST JSON (Phase 1 spec § 2.1)
  --symbols           emit Symbol array JSON (Phase 1 spec § 2.2)
  --check             emit lint NDJSON (Phase 2 spec § 2.3, 6 rules)
  --check ... --strict  same as --check; exit 1 if any violation
  --refs <file.hexa> <symbol>          emit NDJSON refs (Phase 3 § 2.4)
  --hover <file.hexa> <line>:<col>     emit single hover JSON (Phase 3 § 2.5)
  --diff <a.hexa> <b.hexa>             emit symbol-table hash diff NDJSON (Phase 5a)
exit: 0=ok (or --check w/o --strict), 1=invalid-args/strict-violations, 2=file-unreadable
EOF
}
if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ] || [ "${1:-}" = "help" ]; then
  _usage; exit 0
fi
# --refs/--hover/--diff 는 mode + file + (token|file) 의 3개 위치 인자 필요
min_argc=2
case "${1:-}" in
  --refs|--hover|--diff) min_argc=3 ;;
esac
if [ $# -lt "$min_argc" ]; then
  _usage; exit 1
fi
case "${1}" in
  --ast|--symbols|--check|--refs|--hover|--diff) ;;
  *) _usage; exit 1 ;;
esac

# 본 shim 위치에서 ../hexa_introspect.hexa 를 실행. realpath 가 BSD/GNU 양립
# 부족할 수 있으므로 dirname-only 도 폴백.
self_dir="$(cd "$(dirname "$0")" && pwd)"
script="$self_dir/../hexa_introspect.hexa"
if [ ! -f "$script" ]; then
  echo "hexa-introspect: script not found: $script" >&2
  exit 2
fi

HEXA_BIN="${HEXA_BIN:-$HOME/.hx/bin/hexa}"
if [ ! -x "$HEXA_BIN" ]; then
  echo "hexa-introspect: hexa compiler not found at $HEXA_BIN" >&2
  exit 2
fi

# HEXA_LOCAL=1 로 강제 — wrapper 자체는 metadata-only 이므로 docker hard-
# landing 도 darwin-bypass 도 모두 안전. NO_SENTINEL=1 로 stdout 청정 보장.
# scanner 의 prefix-rescan 루프가 큰 파일 (>30KB) 에서 O(N*decls) RSS 를
# 유발 — Phase 1 은 768MB 디폴트 캡을 2GB 로 완화. Phase 2 에서 incremental
# line counter 로 교체 예정 (Rank 4 후속 항목).
export HEXA_LOCAL=1
export HEXA_NO_SENTINEL=1
export HEXA_MEM_CAP_MB="${HEXA_MEM_CAP_MB:-2048}"
exec "$HEXA_BIN" run "$script" "$@"
