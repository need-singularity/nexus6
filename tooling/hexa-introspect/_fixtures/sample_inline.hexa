// inline fixture — simple fn that can be inlined.
//
// 의도된 사용: --inline sample_inline.hexa double
//   호출처 (caller_a, caller_b) 의 double(x) 호출을 본문 (x * 2) 로 치환.

fn double(x: i64) -> i64 {
    return x * 2
}

fn caller_a() -> i64 {
    return double(10)
}

fn caller_b(n: i64) -> i64 {
    let y = double(n)
    return y + 1
}
