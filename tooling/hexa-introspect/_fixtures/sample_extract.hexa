// extract fixture — simple expression block that can be extracted to a fn.
//
// 의도된 사용: --extract sample_extract.hexa 4 6 compute_total
//   line 4..6 의 "let sum = a + b; let prod = a * b; return sum + prod" 를
//   compute_total(a, b) 로 추출.

fn compute(a: i64, b: i64) -> i64 {
    let sum = a + b
    let prod = a * b
    return sum + prod
}

fn caller() -> i64 {
    return compute(2, 3)
}
