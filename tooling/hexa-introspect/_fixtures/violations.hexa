// 의도적 위반 fixture — Phase 2 `--check` 검증용.
//
// 각 룰 1개 이상의 위반을 의도적으로 포함. spec § 2.3 / § 7 갭 매핑 참조.
// 본 fixture 는 컴파일을 시도하지 않으며 (sample.hexa 와 동일), 토큰 패턴
// 검출만이 목적.

// ─── HX001-banned-gte (error) ───────────────────────────
// 2 hits — `>=` 와 `<=` 각각 1.
fn hx001_a(n: i64) -> bool {
    if n >= 1 { return true }
    return false
}
fn hx001_b(n: i64) -> bool {
    if n <= 0 { return true }
    return false
}

// ─── HX002-bare-exec (error) ───────────────────────────
// 1 hit — 정책 주석 부재 exec(...)
fn hx002() {
    let r = to_string(exec("date +%s"))
}
// 화이트리스트 케이스 — 같은 패턴이지만 escape 부착
fn hx002_ok() {
    let r2 = to_string(exec("date +%s"))  // @allow-bare-exec
}

// ─── HX003-silent-catch (warning) ───────────────────────
// 1 hit — 빈 catch 블록 + escape 부재
fn hx003() {
    try { let x = 1 } catch e {}
}
fn hx003_ok() {
    try { let x = 1 } catch e {}  // @allow-silent-catch
}

// ─── HX004-awk-utf8-eq (warning) ────────────────────────
// 1 hit — awk 스크립트 컨텍스트의 UTF-8 == 비교 (한글 문자열 fallback)
fn hx004() {
    let mut s: [string] = []
    s.push("BEGIN{ if(\"가\" == \"나\") print 1 }")
    let _ = to_string(exec("awk '" + s.join("") + "'"))  // @allow-bare-exec
}

// ─── HX005-rc-trailer-missing (hint) ────────────────────
// 1 hit — exec("hexa run ...") 호출 + 다음 10라인에 __RC= 부재
fn hx005() {
    let out = to_string(exec("hexa run /tmp/foo.hexa --some arg"))  // @allow-bare-exec
    let _ = out.trim()
    return
}
fn hx005_ok() {
    let out2 = to_string(exec("hexa run /tmp/bar.hexa; echo __RC=$?"))  // @allow-bare-exec
    let rc_at = out2.index_of("__RC=")
    let _ = rc_at
}

// ─── HX006-argv-slice-bare (hint) ───────────────────────
// 1 hit — args() 직접 인덱스
fn hx006() -> string {
    return args()[2]
}
fn hx006_ok() -> string {
    let aa = args()
    if len(aa) > 2 { return aa[2] }
    return ""
}
