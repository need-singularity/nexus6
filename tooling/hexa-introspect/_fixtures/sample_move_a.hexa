// move fixture — source file (sample_move_a.hexa) containing _safe_token
// to be moved to sample_move_b.hexa (utility module).

fn _safe_token(s: string) -> bool {
    let n = s.len()
    if n < 1 { return false }
    if n > 128 { return false }
    return true
}

fn lookup(token: string) -> string {
    if !_safe_token(token) { return "" }
    return "ok:" + token
}
