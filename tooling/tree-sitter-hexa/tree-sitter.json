{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "hexa",
      "camelcase": "Hexa",
      "scope": "source.hexa",
      "path": ".",
      "file-types": ["hexa"],
      "highlights": ["queries/highlights.scm"],
      "locals": ["queries/locals.scm"],
      "tags": ["queries/tags.scm"],
      "injection-regex": "^hexa$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the hexa-lang DSL used in nexus.",
    "authors": [
      { "name": "nexus" }
    ],
    "links": {
      "repository": "https://github.com/dancinlife/nexus"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": true,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
