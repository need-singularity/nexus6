# hexa builtin functions — SSOT for tree-sitter highlights + LSP defaultLibrary modifier.
# Mirrors the future `get_builtins()` array in `hexa-lang/self/lsp.hexa`.
# Format: one identifier per line, `#` for comments. Empty lines ignored.
#
# tree-sitter highlights.scm (`@function.builtin`) consumes this list via
# the `^(…|…)$` predicate. When this list changes, regenerate the regex
# in `queries/highlights.scm`.
#
# Spec: design/hexa_token_taxonomy_unified_spec.md § 5.2

# I/O
println
print
read_file
write_file

# string / number conversions
to_string
to_int
to_float

# collections
len

# diagnostics
assert
panic
format

# process / env
env
argv
exit
