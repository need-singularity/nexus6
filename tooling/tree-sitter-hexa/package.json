{
  "name": "tree-sitter-hexa",
  "version": "0.1.0",
  "description": "Tree-sitter grammar seed for the hexa-lang DSL (nexus).",
  "main": "bindings/node",
  "keywords": [
    "parser",
    "tree-sitter",
    "hexa",
    "hexa-lang",
    "nexus"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tree-sitter generate",
    "test":  "tree-sitter test",
    "parse": "tree-sitter parse"
  },
  "tree-sitter": [
    {
      "scope": "source.hexa",
      "file-types": ["hexa"],
      "highlights": "queries/highlights.scm",
      "locals":     "queries/locals.scm",
      "tags":       "queries/tags.scm"
    }
  ],
  "devDependencies": {
    "tree-sitter-cli": "^0.22.0"
  }
}
