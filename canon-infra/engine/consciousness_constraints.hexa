// engine/consciousness_constraints.hexa
// ──────────────────────────────────────────────────────────────────────────
// Consciousness Constraints — minimal real selftest (R24-selftest-flip)
// 원본 SSOT: engine/consciousness_constraints.py (git 94bf0e28^, 130 줄)
// 원본 역할: Consciousness-law design constraint validator (Laws 1/8/22/30/32/44/63/33)
//
// 이식 범위 (dict-기반 config 는 scalar-param 으로 평탄화; Laws 1/22/33/63 는
// hardcoded_flag / structure_flag / topology_flag / gate 필드로 단순화):
//   - Law 8  : heads must divide d_model evenly
//   - Law 30 : cells ≤ 1024
//   - Law 32 : cells ≥ 3
//   - Law 44 : factions == σ(6) = 12  (SIGMA anchor)
//   - compound violation count = 정확히 Law 8+30+32+44 동시 위반 시 4 … 명세
//     상으로는 3 (hardcode + heads + cells 상한) — 원본 테스트 패턴 유지
// 규칙: R1 HEXA-FIRST, R18 미니멀, N61 한글
// ──────────────────────────────────────────────────────────────────────────

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n { if n % i == 0 { s = s + i } i = i + 1 }
    return s
}

comptime const SIGMA6: i64 = 12                // σ(6) = Law 44 anchor

// 단일 Law detector — 각각 bool 반환, true = violation
fn violates_law8(d_model: i64, heads: i64) -> bool {
    if heads == 0 { return false }
    if d_model == 0 { return false }
    return d_model % heads != 0
}

fn violates_law30(cells: i64) -> bool {
    return cells > 1024
}

fn violates_law32(cells: i64) -> bool {
    return cells > 0 && cells < 3
}

fn violates_law44(factions: i64) -> bool {
    if factions == 0 { return false }
    return factions != SIGMA6
}

// 전체 위반 수 count (config vector: d_model, heads, cells, factions)
fn violation_count(d_model: i64, heads: i64, cells: i64, factions: i64) -> i64 {
    let mut c: i64 = 0
    if violates_law8(d_model, heads) { c = c + 1 }
    if violates_law30(cells) { c = c + 1 }
    if violates_law32(cells) { c = c + 1 }
    if violates_law44(factions) { c = c + 1 }
    return c
}

// ── 자기 테스트 ───────────────────────────────────────────
fn main() -> i64 {
    let mut pass: i64 = 0
    let mut fail: i64 = 0

    // T1: σ(6) = 12  (Law 44 anchor)
    if sigma(6) == SIGMA6 && SIGMA6 == 12 {
        println("T1 PASS : σ(6) = 12 = Law 44 anchor")
        pass = pass + 1
    } else {
        println("T1 FAIL : σ(6) anchor drift")
        fail = fail + 1
    }

    // T2: optimal config (d_model=384, heads=12, cells=512, factions=12)
    //     모든 Law 통과 ⇒ violation_count = 0
    let vc_opt: i64 = violation_count(384, 12, 512, 12)
    if vc_opt == 0 {
        println("T2 PASS : optimal config passes (0 violations)")
        pass = pass + 1
    } else {
        println("T2 FAIL : optimal config has false violations")
        fail = fail + 1
    }

    // T3: Law 8 — heads=7, d_model=100 ⇒ 100%7 != 0  (detector isolated)
    if violates_law8(100, 7)
       && !violates_law30(100) && !violates_law32(100) && !violates_law44(12) {
        println("T3 PASS : Law 8 detects non-divisible heads")
        pass = pass + 1
    } else {
        println("T3 FAIL : Law 8 detector wrong")
        fail = fail + 1
    }

    // T4: Law 30 — cells=2000 > 1024 ⇒ violation; other Laws quiet
    if violates_law30(2000)
       && !violates_law32(2000) && !violates_law44(12) && !violates_law8(384, 12) {
        println("T4 PASS : Law 30 detects cells > 1024")
        pass = pass + 1
    } else {
        println("T4 FAIL : Law 30 detector wrong")
        fail = fail + 1
    }

    // T5: Law 32 — cells=2 < 3 ⇒ violation (but >0); other Laws quiet
    if violates_law32(2)
       && !violates_law30(2) && !violates_law44(12) && !violates_law8(384, 12) {
        println("T5 PASS : Law 32 detects cells < 3")
        pass = pass + 1
    } else {
        println("T5 FAIL : Law 32 detector wrong")
        fail = fail + 1
    }

    // T6: Law 44 — factions=6 ≠ σ(6)=12 ⇒ violation; others quiet
    if violates_law44(6)
       && !violates_law30(512) && !violates_law32(512) && !violates_law8(384, 12) {
        println("T6 PASS : Law 44 detects factions ≠ σ(6)")
        pass = pass + 1
    } else {
        println("T6 FAIL : Law 44 detector wrong")
        fail = fail + 1
    }

    // T7: compound violation — heads=7 (L8) + cells=2 (L32) + factions=6 (L44)
    //     3 개 동시 위반, violation_count == 3
    let vc_compound: i64 = violation_count(100, 7, 2, 6)
    if vc_compound == 3 {
        println("T7 PASS : compound violation count = 3")
        pass = pass + 1
    } else {
        println("T7 FAIL : compound count wrong")
        fail = fail + 1
    }

    println("────────────────────────────────────────")
    println("SELFTEST consciousness_constraints : PASS/FAIL below")
    println(pass)
    println(fail)
    return fail
}

main()
