// roadmap.hexa — canon 로드맵 어댑터
//
// 위임: $NEXUS/shared/harness/roadmap_guard.hexa (--project canon 고정)
// 사용: $HEXA scripts/roadmap.hexa [verify|artifacts|status|all]
//
// SSOT: $NEXUS/shared/roadmaps/canon.json (nexus 리포 내 SSOT)

fn main() {
    let a = args()
    let cmd = if len(a) >= 3 { a[2] } else { "status" }

    // TODO: canonical relocation pending — currently fallback to $HOME/shared/
    let g = env("HOME") + "/shared/harness/roadmap_guard.hexa"
    let h = env("HEXA_BIN") || (env("HOME") + "/core/hexa-lang/hexa")

    let call = h + " " + g + " " + cmd + " --project canon"
    let rc = to_string(exec(call))
    print(rc)
}

main()
