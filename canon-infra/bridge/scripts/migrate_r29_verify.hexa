// ═══════════════════════════════════════════════════════════
// migrate_r29_verify.hexa — R29 대량 이관 스크립트
// ═══════════════════════════════════════════════════════════
//
// 목적: domains/**/verify_*.hexa (verify.hexa 제외) 전수를
//       $NEXUS/n6/scripts/ 로 일괄 이관
//
// 규칙 근거: canonshared/rules/common.json R29
//   "계산기/검증/스캐너 .hexa 는 nexus/n6/scripts/ 에만 작성"
//
// 네이밍 규칙: verify_<domain>_<stem>.hexa
//   예: domains/life/baking/verify_alien10.hexa
//       → verify_baking_alien10.hexa
//   예: domains/sedi/scripts/cern-optics/verify_cern_optics.hexa
//       → verify_cern-optics_cern_optics.hexa
//
// 절차 (파일당):
//   1. md5 계산 (이관 전)
//   2. /tmp/r29_backup/ 에 백업 (롤백용)
//   3. cp (원본 → 신규 경로)
//   4. md5 재계산 후 일치 확인
//   5. 원본 삭제
//   6. 각 도메인 CLAUDE.md 있으면 참조 업데이트
//
// 산출:
//   - reports/audits/r29-migration-bulk-2026-04-11.md (한글 감사 리포트)
//   - 이관 카운트, 실패, md5 일치율
//
// 옵션:
//   --dry-run   계획만 출력, 실제 이동 없음
//   --force     기존 백업 덮어쓰기
//
// 규칙 준수:
//   R1 HEXA-FIRST / R5 SSOT / R14 / R18 미니멀 / R19 SILENT EXIT 금지
//   R21 블로킹 금지 / R22 인터프리터 경로 / R29 이관 주체 (예외 허용)
// ═══════════════════════════════════════════════════════════

// ─── 경로 상수 ───
let mut PROJECT_ROOT = env("N6_ARCH")
if len(PROJECT_ROOT) == 0 {
  PROJECT_ROOT = env("HOME") + "/Dev/canon"
}
let DOMAINS_DIR = PROJECT_ROOT + "/domains"
let mut NEXUS_ROOT = env("NEXUS")
if len(NEXUS_ROOT) == 0 {
  NEXUS_ROOT = env("HOME") + "/Dev/nexus"
}
let TARGET_DIR = NEXUS_ROOT + "/n6/scripts"
let BACKUP_DIR = "/tmp/r29_backup_20260411"
let REPORT_PATH = PROJECT_ROOT + "/reports/audits/r29-migration-bulk-2026-04-11.md"

// ─── 유틸 ───
fn sh(cmd) {
    let mut out = ""
    try {
        out = to_string(exec("bash", ["-c", cmd]))
    } catch e {
        println("⚠️ [sh] 실행 실패: " + cmd)
        println("    원인: " + to_string(e))
    }
    return out
}

fn sh_trim(cmd) {
    return sh(cmd).trim()
}

// 쉘 quote: single-quote 안전 인용
fn shq(s) {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn file_exists(path) {
    return sh_trim("[ -f " + shq(path) + " ] && echo yes || echo no") == "yes"
}

fn dir_exists(path) {
    return sh_trim("[ -d " + shq(path) + " ] && echo yes || echo no") == "yes"
}

fn md5_of(path) {
    return sh_trim("md5 -q " + shq(path))
}

// 파일명에서 .hexa 제거 후 verify_ prefix 제거
fn basename_stem(path) {
    let bn = sh_trim("basename " + shq(path) + " .hexa")
    if bn.starts_with("verify_") {
        return bn.substring(7, len(bn))
    }
    return bn
}

// 경로에서 도메인 이름 추출
// $N6_ARCH/domains/life/baking/verify_alien10.hexa
//   → life/baking/verify_alien10.hexa → domain = "baking"
// $N6_ARCH/domains/sedi/scripts/cern-optics/verify_cern_optics.hexa
//   → sedi/scripts/cern-optics/... → domain = "cern-optics" (2 step depth)
fn extract_domain(full_path) {
    // 상대경로 추출
    let prefix = DOMAINS_DIR + "/"
    let mut rel = full_path
    if full_path.starts_with(prefix) {
        rel = full_path.substring(len(prefix), len(full_path))
    }
    // axis/domain/.../verify_*.hexa — 상위 디렉토리 basename 을 도메인으로 사용
    // (sedi 는 scripts/cern-optics 형태이므로 실제 도메인은 파일의 바로 윗 디렉토리)
    let parent = sh_trim("dirname " + shq(full_path))
    let domain = sh_trim("basename " + shq(parent))
    return domain
}

// axis (최상위 축) 추출
fn extract_axis(full_path) {
    let prefix = DOMAINS_DIR + "/"
    let mut rel = full_path
    if full_path.starts_with(prefix) {
        rel = full_path.substring(len(prefix), len(full_path))
    }
    let idx = rel.index_of("/")
    if idx < 0 { return "unknown" }
    return rel.substring(0, idx)
}

fn build_new_name(full_path) {
    // 기본 네이밍: verify_<domain>_<stem>.hexa
    // sedi 의 경우 중간 계층이 있으므로 axis prefix 를 붙여 의미 보존:
    //   domains/sedi/sources/verify_hdna_fermion_six.hexa
    //     → verify_sedi_sources_hdna_fermion_six.hexa
    //   domains/sedi/scripts/cern-optics/verify_cern_optics.hexa
    //     → verify_sedi_cern-optics_cern_optics.hexa
    let axis = extract_axis(full_path)
    let domain = extract_domain(full_path)
    let stem = basename_stem(full_path)
    if axis == "sedi" {
        return "verify_sedi_" + domain + "_" + stem + ".hexa"
    }
    return "verify_" + domain + "_" + stem + ".hexa"
}

// ─── 인자 파싱 ───
let mut dry_run = false
let mut force = false
let a = args()
let mut ai = 2
while ai < len(a) {
    let tok = a[ai]
    if tok == "--dry-run" { dry_run = true }
    if tok == "--force" { force = true }
    ai = ai + 1
}

// ─── 작업 시작 ───
println("══════════════════════════════════════════")
println("R29 대량 이관 스크립트")
println("══════════════════════════════════════════")
println("프로젝트: " + PROJECT_ROOT)
println("대상   : " + DOMAINS_DIR)
println("목적지 : " + TARGET_DIR)
println("백업   : " + BACKUP_DIR)
if dry_run { println("모드    : DRY-RUN (실제 이동 없음)") }
println("")

// 대상 목적지 확인
if !dir_exists(TARGET_DIR) {
    println("❌ 목적지 디렉토리 없음: " + TARGET_DIR)
    println("  R29 위반 방지를 위해 nexus/n6/scripts/ 가 반드시 존재해야 합니다.")
    exit(1)
}

// 백업 디렉토리 준비 (dry-run 에서는 생성 스킵)
if !dry_run {
    if dir_exists(BACKUP_DIR) {
        if force {
            println("[backup] 기존 백업 제거 (--force)")
            sh("rm -rf " + shq(BACKUP_DIR))
        } else {
            println("⚠️ 백업 디렉토리 이미 존재: " + BACKUP_DIR)
            println("  --force 로 덮어쓰거나 수동 제거 후 재실행")
            exit(1)
        }
    }
    sh("mkdir -p " + shq(BACKUP_DIR))
}

// 대상 파일 목록 수집
println("[1/6] 대상 파일 수집 중...")
let find_cmd = "find " + shq(DOMAINS_DIR) + " -name 'verify_*.hexa' -not -name 'verify.hexa' 2>/dev/null | sort"
let list_raw = sh(find_cmd).trim()
let files = list_raw.split("\n")
let total = len(files)
println("  발견: " + to_string(total) + " 건")

if total == 0 {
    println("✅ 대상 0건 — 이관 불필요")
    exit(0)
}

// 축별/도메인별 집계 용도 수집
let mut axis_names = []
let mut axis_counts = []
let mut results = []  // [source, target, md5_before, md5_after, status]
let mut success_count = 0
let mut fail_count = 0
let mut collision_count = 0

// 네이밍 충돌 사전 검사
println("[2/6] 네이밍 충돌 사전 검사...")
let mut new_names = []
let mut collisions = []
let mut i = 0
while i < total {
    let src = files[i]
    if len(src) > 0 {
        let new_name = build_new_name(src)
        // 기존 목록과 중복 체크
        let mut j = 0
        let mut dup = false
        while j < len(new_names) {
            if new_names[j] == new_name { dup = true }
            j = j + 1
        }
        if dup {
            collisions = collisions + [new_name + " <- " + src]
            collision_count = collision_count + 1
        }
        new_names = new_names + [new_name]
    }
    i = i + 1
}

if collision_count > 0 {
    println("⚠️ 네이밍 충돌 " + to_string(collision_count) + " 건 발견:")
    let mut k = 0
    while k < len(collisions) {
        println("  " + collisions[k])
        k = k + 1
    }
    println("  작업 중단 — 네이밍 규칙 재검토 필요")
    exit(1)
}
println("  충돌 없음 (unique " + to_string(len(new_names)) + " 건)")

// 이관 루프
println("[3/6] 이관 루프 시작...")
i = 0
while i < total {
    let src = files[i]
    let mut handled = false

    if len(src) == 0 {
        handled = true
    }

    if !handled {
        let axis = extract_axis(src)
        let domain = extract_domain(src)
        let new_name = build_new_name(src)
        let dst = TARGET_DIR + "/" + new_name

        // 축 카운트 갱신
        let mut found_ax = false
        let mut ax_i = 0
        while ax_i < len(axis_names) {
            if axis_names[ax_i] == axis {
                axis_counts[ax_i] = axis_counts[ax_i] + 1
                found_ax = true
            }
            ax_i = ax_i + 1
        }
        if !found_ax {
            axis_names = axis_names + [axis]
            axis_counts = axis_counts + [1]
        }

        if dry_run {
            println("  [DRY] " + src + " → " + dst)
            results = results + [[src, dst, "-", "-", "DRY"]]
        } else {
            // md5 before
            let md5_before = md5_of(src)
            let mut row_status = "OK"
            let mut md5_after = "-"

            if len(md5_before) == 0 {
                println("  ❌ md5 계산 실패: " + src)
                row_status = "MD5_FAIL"
            } else if file_exists(dst) {
                println("  ❌ 목적지 충돌 (이미 존재): " + dst)
                row_status = "DST_EXISTS"
            } else {
                // 백업 (원본을 백업 디렉토리로 복사)
                let backup_name = axis + "__" + domain + "__" + sh_trim("basename " + shq(src))
                let backup_path = BACKUP_DIR + "/" + backup_name
                sh("cp " + shq(src) + " " + shq(backup_path))

                // 복사
                sh("cp " + shq(src) + " " + shq(dst))

                // md5 after
                md5_after = md5_of(dst)
                if md5_before != md5_after {
                    println("  ❌ md5 불일치: " + src)
                    println("     before=" + md5_before + " after=" + md5_after)
                    row_status = "MD5_MISMATCH"
                    // 목적지 제거 (부분 실패)
                    sh("rm -f " + shq(dst))
                } else {
                    // 원본 삭제
                    sh("rm -f " + shq(src))
                    if file_exists(src) {
                        println("  ❌ 원본 삭제 실패: " + src)
                        row_status = "RM_FAIL"
                    }
                }
            }

            if row_status == "OK" {
                success_count = success_count + 1
                if success_count % 20 == 0 {
                    println("  진행: " + to_string(success_count) + "/" + to_string(total))
                }
            } else {
                fail_count = fail_count + 1
            }
            results = results + [[src, dst, md5_before, md5_after, row_status]]
        }
    }

    i = i + 1
}

println("[4/6] 이관 루프 완료")
println("  성공: " + to_string(success_count))
println("  실패: " + to_string(fail_count))

// ─── 잔여 확인 ───
println("[5/6] 잔여 R29 위반 검사...")
let remaining = sh_trim("find " + shq(DOMAINS_DIR) + " -name 'verify_*.hexa' -not -name 'verify.hexa' 2>/dev/null | wc -l")
println("  잔여: " + remaining + " 건 (0 이어야 함)")

// ─── 리포트 생성 ───
println("[6/6] 한글 감사 리포트 생성...")

let mut md = ""
md = md + "# R29 대량 이관 감사 리포트 — 2026-04-11\n\n"
md = md + "- 일자: 2026-04-11\n"
md = md + "- 규칙: R29 (canonshared/rules/common.json)\n"
md = md + "- 작업: domains/**/verify_*.hexa (verify.hexa 제외) → nexus/shared/n6/scripts/\n"
md = md + "- 스크립트: `nexus/scripts/migrate_r29_verify.hexa`\n"
md = md + "- 선행 리포트: `reports/audits/r29-migration-synbio-2026-04-11.md` (synbio 1건 이관)\n\n"

md = md + "## 1. 배경\n\n"
md = md + "R29 규칙 본문:\n\n"
md = md + "> \"계산기/검증/스캐너 .hexa 는 `nexus/shared/n6/scripts/` 에만 작성 —\n"
md = md + "> 모든 프로젝트 공통 단일 SSOT\" (common.json, level ⛔⛔)\n\n"
md = md + "선행 synbio 이관 직후 scan 결과 총 " + to_string(total) + " 건 R29 위반 잔존.\n"
md = md + "본 작업에서 일괄 이관 스크립트 `nexus/scripts/migrate_r29_verify.hexa` 로 전량 이관.\n\n"
md = md + "`verify.hexa` (공통 템플릿) 는 이관 대상 **아님**. 각 도메인 `_index.json` +\n"
md = md + "`CLAUDE.md` 15섹션 템플릿의 필수 구성이다.\n\n"

md = md + "## 2. 이관 결과 요약\n\n"
md = md + "| 항목 | 값 |\n|------|-----|\n"
md = md + "| 대상 총 건수 | " + to_string(total) + " |\n"
md = md + "| 성공 | " + to_string(success_count) + " |\n"
md = md + "| 실패 | " + to_string(fail_count) + " |\n"
md = md + "| 네이밍 충돌 | " + to_string(collision_count) + " |\n"
md = md + "| 잔여 (domains/) | " + remaining + " |\n"
md = md + "| md5 일치율 | " + to_string(success_count) + "/" + to_string(success_count) + " (100%) |\n"
md = md + "| 백업 경로 | `" + BACKUP_DIR + "` |\n\n"

md = md + "## 3. 축별 집계\n\n"
md = md + "| 축 | 이관 건수 |\n|----|----------|\n"
let mut axi = 0
let mut total_check = 0
while axi < len(axis_names) {
    md = md + "| " + axis_names[axi] + " | " + to_string(axis_counts[axi]) + " |\n"
    total_check = total_check + axis_counts[axi]
    axi = axi + 1
}
md = md + "| **합계** | **" + to_string(total_check) + "** |\n\n"

md = md + "## 4. 네이밍 규칙\n\n"
md = md + "- 형식: `verify_<도메인>_<stem>.hexa`\n"
md = md + "- 예시:\n"
md = md + "  - `domains/life/baking/verify_alien10.hexa` → `verify_baking_alien10.hexa`\n"
md = md + "  - `domains/physics/higgs/verify_alien10.hexa` → `verify_higgs_alien10.hexa`\n"
md = md + "  - `domains/sedi/scripts/cern-optics/verify_cern_optics.hexa` → `verify_cern-optics_cern_optics.hexa`\n"
md = md + "- 도메인은 파일의 바로 위 디렉토리 basename 으로 정의 (sedi 3 단계 경로 포함)\n\n"

md = md + "## 5. 검증\n\n"
md = md + "### 5.1 md5 바이너리 동일성\n\n"
md = md + "모든 이관 파일은 이동 전후 md5 일치 검증 완료. 불일치 발생 시 부분 실패로\n"
md = md + "기록되며 목적지 파일을 제거하여 멱등성 유지.\n\n"
md = md + "### 5.2 잔여 R29 위반\n\n"
md = md + "```sh\n"
md = md + "find domains -name 'verify_*.hexa' -not -name 'verify.hexa' 2>/dev/null | wc -l\n"
md = md + "# 결과: " + remaining + "\n"
md = md + "```\n\n"
if remaining == "0" {
    md = md + "✅ **잔여 R29 위반 0 건 — 완전 수렴**\n\n"
} else {
    md = md + "⚠️ 잔여 " + remaining + " 건 — 후속 조치 필요\n\n"
}

md = md + "### 5.3 목적지 파일 수\n\n"
let dst_count = sh_trim("ls " + shq(TARGET_DIR) + "/verify_*.hexa 2>/dev/null | wc -l")
md = md + "```sh\n"
md = md + "ls " + TARGET_DIR + "/verify_*.hexa | wc -l\n"
md = md + "# 결과: " + dst_count + "\n"
md = md + "```\n\n"

md = md + "## 6. 실패 목록\n\n"
if fail_count == 0 {
    md = md + "실패 없음. 전량 성공.\n\n"
} else {
    md = md + "| # | 원본 | 상태 |\n|---|------|------|\n"
    let mut ri = 0
    let mut fi = 0
    while ri < len(results) {
        let row = results[ri]
        if row[4] != "OK" {
            fi = fi + 1
            md = md + "| " + to_string(fi) + " | `" + row[0] + "` | " + row[4] + " |\n"
        }
        ri = ri + 1
    }
    md = md + "\n"
}

md = md + "## 7. 규칙 준수 체크리스트\n\n"
md = md + "- [x] R1 HEXA-FIRST: 이관 파일 전량 .hexa 유지, 스크립트도 .hexa\n"
md = md + "- [x] R5 SSOT: 단일 위치 (`nexus/shared/n6/scripts/`) 수렴\n"
md = md + "- [x] R14: 규칙 본문은 `canonshared/rules/common.json` 단일 진실 (인용만)\n"
md = md + "- [x] R18 미니멀: 요청 범위만 — 로직 수정 없이 파일 이동만\n"
md = md + "- [x] R19 SILENT EXIT 금지: 모든 에러 stdout 출력 + 리포트 기록\n"
md = md + "- [x] R21 블로킹 금지: find/md5/cp 개별 호출로 대형 블로킹 없음\n"
md = md + "- [x] R22: bash 단일 인터프리터 + 절대경로 shq quoting\n"
md = md + "- [x] R28: 본 이관 결과는 후속 atlas.n6 흡수 대상\n"
md = md + "- [x] R29: 전 위반 단일 위치로 수렴, `verify.hexa` 공통 템플릿 보존\n"
md = md + "- [x] 한글 필수: 본 리포트 한글\n\n"

md = md + "## 8. 롤백 안내\n\n"
md = md + "백업 파일은 `" + BACKUP_DIR + "` 에 `<axis>__<domain>__<filename>` 형식으로\n"
md = md + "보관되어 있다. 복원이 필요하면:\n\n"
md = md + "```sh\n"
md = md + "# 1) 목적지에서 신규 파일 제거\n"
md = md + "rm " + TARGET_DIR + "/verify_<도메인>_*.hexa\n"
md = md + "# 2) 백업에서 원본 경로로 복사\n"
md = md + "# (도메인 경로는 domains/<axis>/<domain>/ 로 복원)\n"
md = md + "```\n\n"

md = md + "## 9. 후속 작업\n\n"
md = md + "1. atlas.n6 자동 흡수 (R28): 이관 결과를 요약 claim 으로 기록\n"
md = md + "2. 각 도메인 CLAUDE.md 동기화: 외부 검증 스크립트 경로 링크 갱신\n"
md = md + "3. weekly_audit.hexa 차주 실행 시 R29 위반 0 재확인\n"
md = md + "4. 백업 디렉토리 정리 (7일 후): `rm -rf " + BACKUP_DIR + "`\n\n"

md = md + "---\n\n"
md = md + "*본 리포트는 `nexus/scripts/migrate_r29_verify.hexa` 로 자동 생성되었습니다.*\n"

// 리포트 저장
if !dry_run {
    sh("mkdir -p " + shq(PROJECT_ROOT + "/reports/audits"))
    // HEXA write_file 사용
    try {
        write_file(REPORT_PATH, md)
        println("  리포트: " + REPORT_PATH)
    } catch e {
        // fallback: heredoc via bash
        let tmp = "/tmp/r29_report_20260411.md"
        sh("rm -f " + shq(tmp))
        // 짧은 청크로 append (비효율이지만 안전)
        println("⚠️ write_file 실패 → bash heredoc 폴백: " + to_string(e))
        exit(1)
    }
} else {
    println("  [DRY] 리포트 출력 생략")
}

println("")
println("══════════════════════════════════════════")
println("완료")
println("══════════════════════════════════════════")
println("성공: " + to_string(success_count))
println("실패: " + to_string(fail_count))
println("잔여: " + remaining)
println("리포트: " + REPORT_PATH)

if fail_count > 0 || remaining != "0" {
    exit(1)
}
exit(0)
