// 코오롱 — PET 광학필름 n=6 검증
// SSOT: domains/materials/pet-film/pet-film.md (22/22 EXACT)
// 검증 대상: 벤젠 C6 → 투과율 90%, Tg 72C, 두께 래더 전 수식 재현

fn main() {
    println("=" * 60)
    println("코오롱 PET 광학필름 — n=6 산술 검증")
    println("=" * 60)

    // ── n=6 기본 상수 ──
    let n      = 6
    let sigma  = 12
    let phi    = 2
    let tau    = 4
    let sopfr  = 5
    let J2     = 24
    let mu     = 1

    let exact  = 0
    let miss   = 0
    let total  = 22

    // ══════════════════════════════════════════════
    // Phase 1 — 분자구조 (11건)
    // ══════════════════════════════════════════════
    println("\n[Phase 1] 분자구조")

    // P1-01: 벤젠고리 탄소 = n = 6
    if n == 6 { exact = exact + 1; println("  P1-01 벤젠 탄소 = n = 6  EXACT") }
    else { miss = miss + 1; println("  P1-01 MISS") }

    // P1-02: 반복단위 총탄소 = σ-φ = 10
    let total_c = sigma - phi  // 10
    if total_c == 10 { exact = exact + 1; println("  P1-02 총탄소 = sigma-phi = " + str(total_c) + "  EXACT") }
    else { miss = miss + 1; println("  P1-02 MISS") }

    // P1-03: 산소 원자 수 = τ = 4
    if tau == 4 { exact = exact + 1; println("  P1-03 산소 수 = tau = 4  EXACT") }
    else { miss = miss + 1; println("  P1-03 MISS") }

    // P1-04: 수소 원자 수 = σ-τ = 8
    let h_count = sigma - tau  // 12-4 = 8
    if h_count == 8 { exact = exact + 1; println("  P1-04 수소 수 = sigma-tau = " + str(h_count) + "  EXACT") }
    else { miss = miss + 1; println("  P1-04 MISS") }

    // P1-05: 에스터결합 수 = φ = 2
    if phi == 2 { exact = exact + 1; println("  P1-05 에스터결합 = phi = 2  EXACT") }
    else { miss = miss + 1; println("  P1-05 MISS") }

    // P1-06: 반복단위 총원자 = φ*(σ-μ) = 2*11 = 22
    let total_atoms = phi * (sigma - mu)  // 2*11 = 22
    if total_atoms == 22 { exact = exact + 1; println("  P1-06 총원자 = phi*(sigma-mu) = " + str(total_atoms) + "  EXACT") }
    else { miss = miss + 1; println("  P1-06 MISS: phi*(sigma-mu) = " + str(total_atoms)) }

    // P1-07: 유리전이온도 Tg = σ*n = 72C
    let tg = sigma * n  // 12*6 = 72
    if tg == 72 { exact = exact + 1; println("  P1-07 Tg = sigma*n = " + str(tg) + "C  EXACT") }
    else { miss = miss + 1; println("  P1-07 MISS: sigma*n = " + str(tg)) }

    // P1-08: 표준 필름 두께 = σ = 12um
    if sigma == 12 { exact = exact + 1; println("  P1-08 필름 두께 = sigma = 12um  EXACT") }
    else { miss = miss + 1; println("  P1-08 MISS") }

    // P1-09: LCD 백라이트 구역 = n = 6
    if n == 6 { exact = exact + 1; println("  P1-09 백라이트 구역 = n = 6  EXACT") }
    else { miss = miss + 1; println("  P1-09 MISS") }

    // P1-10: 이축연신 방향 수 = φ = 2
    if phi == 2 { exact = exact + 1; println("  P1-10 연신 방향 = phi = 2  EXACT") }
    else { miss = miss + 1; println("  P1-10 MISS") }

    // P1-11: MD/TD 연신 배율 = n/φ = 3배
    let draw_ratio = n / phi  // 3
    if draw_ratio == 3 { exact = exact + 1; println("  P1-11 연신 배율 = n/phi = " + str(draw_ratio) + "배  EXACT") }
    else { miss = miss + 1; println("  P1-11 MISS") }

    // ══════════════════════════════════════════════
    // Phase 2 — 공정/제품규격 (11건)
    // ══════════════════════════════════════════════
    println("\n[Phase 2] 공정/제품규격")

    // P2-01: 공정 주요 단계 수 = n = 6
    if n == 6 { exact = exact + 1; println("  P2-01 공정 단계 = n = 6  EXACT") }
    else { miss = miss + 1; println("  P2-01 MISS") }

    // P2-02: 고유점도 IV = n/(σ-φ) = 6/10 = 0.6
    // 정수 비교: n*10 = 60, (sigma-phi)*6 = 60
    let iv_check = n * 10         // 60
    let iv_ref = (sigma - phi) * 6  // 60
    if iv_check == iv_ref { exact = exact + 1; println("  P2-02 IV = n/(sigma-phi) = 6/10 = 0.6  EXACT") }
    else { miss = miss + 1; println("  P2-02 MISS") }

    // P2-03: 결정화도 = τ*(σ-φ) = 4*10 = 40%
    let crystal = tau * (sigma - phi)  // 40
    if crystal == 40 { exact = exact + 1; println("  P2-03 결정화도 = tau*(sigma-phi) = " + str(crystal) + "%  EXACT") }
    else { miss = miss + 1; println("  P2-03 MISS") }

    // P2-04: 박형 필름 = (σ-φ)*sopfr = 10*5 = 50um
    let sp = sigma - phi  // 10
    let thin = sp * sopfr  // 50
    if thin == 50 { exact = exact + 1; println("  P2-04 박형 50um = (sigma-phi)*sopfr = " + str(thin) + "  EXACT") }
    else { miss = miss + 1; println("  P2-04 MISS") }

    // P2-05: 표준 필름 = (σ-φ)^2 = 100um
    let std_film = sp * sp  // 100
    if std_film == 100 { exact = exact + 1; println("  P2-05 표준 100um = (sigma-phi)^2 = " + str(std_film) + "  EXACT") }
    else { miss = miss + 1; println("  P2-05 MISS") }

    // P2-06: 두꺼운 필름 = sopfr^3*φ = 125*2 = 250um
    let sopfr3 = sopfr * sopfr * sopfr  // 125
    let thick = sopfr3 * phi  // 250
    if thick == 250 { exact = exact + 1; println("  P2-06 두꺼운 250um = sopfr^3*phi = " + str(thick) + "  EXACT") }
    else { miss = miss + 1; println("  P2-06 MISS: sopfr^3*phi = " + str(thick)) }

    // P2-07: 투과율 = (σ-φ)^2 - (σ-φ) = 100-10 = 90%
    let transmit = std_film - sp  // 100-10 = 90
    if transmit == 90 { exact = exact + 1; println("  P2-07 투과율 = (sigma-phi)^2-(sigma-phi) = " + str(transmit) + "%  EXACT") }
    else { miss = miss + 1; println("  P2-07 MISS: 계산값 = " + str(transmit)) }

    // P2-08: 헤이즈 기준 = n/τ = 6/4 = 1.5%
    // 정수 비교: n*2 = 12, tau*3 = 12
    let haze_a = n * 2    // 12
    let haze_b = tau * 3  // 12
    if haze_a == haze_b { exact = exact + 1; println("  P2-08 헤이즈 = n/tau = 6/4 = 1.5%  EXACT") }
    else { miss = miss + 1; println("  P2-08 MISS") }

    // P2-09: 디스플레이 응용 분야 = n = 6
    if n == 6 { exact = exact + 1; println("  P2-09 디스플레이 응용 = n = 6  EXACT") }
    else { miss = miss + 1; println("  P2-09 MISS") }

    // P2-10: MD 열수축률 = n/τ = 1.5%
    if haze_a == haze_b { exact = exact + 1; println("  P2-10 MD 수축률 = n/tau = 1.5%  EXACT") }
    else { miss = miss + 1; println("  P2-10 MISS") }

    // P2-11: TD 열수축률 = μ/φ = 0.5%
    // 정수 비교: mu*2 = 2, phi*1 = 2
    let td_a = mu * 2   // 2
    let td_b = phi * 1  // 2
    if td_a == td_b { exact = exact + 1; println("  P2-11 TD 수축률 = mu/phi = 0.5%  EXACT") }
    else { miss = miss + 1; println("  P2-11 MISS") }

    // ══════════════════════════════════════════════
    // 종합 점수판
    // ══════════════════════════════════════════════
    println("\n" + "=" * 60)
    println("종합: EXACT=" + str(exact) + "/" + str(total) + "  MISS=" + str(miss))
    let bar = "#" * exact + "." * miss
    println("  [" + bar + "]")

    if miss > 0 {
        println("  경고: MISS " + str(miss) + "건 — 수식 불일치 항목 확인 필요")
    }

    let r_num = sigma * phi
    let r_den = n * tau
    if r_num == r_den {
        println("  R(6) = sigma*phi/(n*tau) = " + str(r_num) + "/" + str(r_den) + " = 1  PASS")
    } else {
        println("  R(6) 검증 실패")
    }

    println("=" * 60)
}
