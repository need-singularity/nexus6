#!hexa strict
// tools/check_drift.hexa — verify every (canonical, copy) seed pair in
// standalone_registry.toml still matches its recorded md5.
//
// Usage:
//   HEXA_FORK_CAP=0 hexa run tools/check_drift.hexa
//
// Reads standalone_registry.toml line-by-line (no full TOML parser — the
// file is generated by tools/build_registry.hexa with a fixed schema).
// Per seed, recomputes md5 of canonical and copy paths, compares against
// the recorded md5_canon / md5_copy.
//
// Exit semantics:
//   __CHECK_DRIFT__ PASS              — every seed matches recorded md5
//   __CHECK_DRIFT__ FAIL count=<N>    — at least one drift / missing detected

let REGISTRY = "standalone_registry.toml"

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn n6_root() -> str {
    let r = exec("git -C . rev-parse --show-toplevel 2>/dev/null").trim()
    if r.len() > 0 { return r }
    return env("PWD")
}

fn core_root() -> str {
    return env("HOME") + "/core"
}

fn md5_of(path: str) -> str {
    let probe = exec("[ -f " + shq(path) + " ] && echo yes || echo no").trim()
    if probe != "yes" { return "MISSING" }
    let bsd = exec("md5 -q " + shq(path) + " 2>/dev/null").trim()
    if bsd.len() == 32 { return bsd }
    let gnu = exec("md5sum " + shq(path) + " 2>/dev/null | awk '{print $1}'").trim()
    if gnu.len() == 32 { return gnu }
    return "ERROR"
}

fn parse_value(line: str) -> str {
    // Lines look like:  key = "value"
    let parts = line.split("=")
    if parts.len() < 2 { return "" }
    // Re-join everything after the first '=' (in case value contains '=')
    let mut v = parts[1]
    let mut k = 2
    while k < parts.len() {
        v = v + "=" + parts[k]
        k = k + 1
    }
    v = v.trim()
    // strip surrounding quotes
    let quoted = v.split("\"")
    if quoted.len() >= 3 { return quoted[1] }
    return v
}

fn main() {
    let n6 = n6_root()
    let core = core_root()
    let raw = read_file(n6 + "/" + REGISTRY)
    if raw.len() == 0 {
        println("ERROR: cannot read " + REGISTRY)
        println("__CHECK_DRIFT__ FAIL reason=registry-missing")
        return
    }

    let lines = raw.split("\n")
    let mut current_slug = ""
    let mut canonical = ""
    let mut copy = ""
    let mut md5_canon_rec = ""
    let mut md5_copy_rec = ""
    let mut in_seed = false

    let mut total_seeds = 0
    let mut ok = 0
    let mut drift_canon = 0
    let mut drift_copy = 0
    let mut both_drift = 0
    let mut missing = 0

    let mut report = ""

    let mut i = 0
    while i < lines.len() {
        let line = lines[i].trim()
        i = i + 1
        if line.starts_with("[[standalone]]") {
            in_seed = false
            current_slug = ""
            continue
        }
        if line.starts_with("[[standalone.seeds]]") {
            in_seed = true
            canonical = ""
            copy = ""
            md5_canon_rec = ""
            md5_copy_rec = ""
            continue
        }
        if line.starts_with("slug") && !in_seed {
            current_slug = parse_value(line)
            continue
        }
        if !in_seed { continue }
        if line.starts_with("canonical") { canonical = parse_value(line); continue }
        if line.starts_with("copy")      { copy      = parse_value(line); continue }
        if line.starts_with("md5_canon") { md5_canon_rec = parse_value(line); continue }
        if line.starts_with("md5_copy")  {
            md5_copy_rec = parse_value(line)
            // last field of seed block — evaluate now
            total_seeds = total_seeds + 1
            let canon_path = n6 + "/" + canonical
            let copy_path = core + "/" + current_slug + "/" + copy
            let now_canon = md5_of(canon_path)
            let now_copy = md5_of(copy_path)
            if now_canon == "MISSING" || now_copy == "MISSING" {
                missing = missing + 1
                report = report + "  MISSING    [" + current_slug + "] " + canonical + " ↔ " + copy + "\n"
            } else {
                let canon_ok = now_canon == md5_canon_rec
                let copy_ok = now_copy == md5_copy_rec
                if canon_ok && copy_ok {
                    ok = ok + 1
                } else if !canon_ok && !copy_ok {
                    both_drift = both_drift + 1
                    report = report + "  BOTH-DRIFT [" + current_slug + "] " + canonical + " ↔ " + copy + "\n"
                } else if !canon_ok {
                    drift_canon = drift_canon + 1
                    report = report + "  CANON-DRIFT [" + current_slug + "] " + canonical + "\n"
                    report = report + "    recorded: " + md5_canon_rec + "\n"
                    report = report + "    current : " + now_canon + "\n"
                } else {
                    drift_copy = drift_copy + 1
                    report = report + "  COPY-DRIFT  [" + current_slug + "] " + copy + "\n"
                    report = report + "    recorded: " + md5_copy_rec + "\n"
                    report = report + "    current : " + now_copy + "\n"
                }
            }
            in_seed = false
            continue
        }
    }

    if report.len() > 0 {
        println("Drift report:")
        println(report)
    }
    println("Summary: " + str(ok) + "/" + str(total_seeds) + " match")
    println("  canon-only drift: " + str(drift_canon))
    println("  copy-only drift:  " + str(drift_copy))
    println("  both-drift:       " + str(both_drift))
    println("  missing:          " + str(missing))

    let bad = drift_canon + drift_copy + both_drift + missing
    if bad == 0 {
        println("__CHECK_DRIFT__ PASS")
    } else {
        println("__CHECK_DRIFT__ FAIL reason=drift-detected count=" + str(bad))
    }
}
