// cross_feed_probe.hexa — Stage 6 cross-feed re-measurement (cascade-s2 tick-1)
// raw 91 C3 honest: report whatever the numbers say
//
// Mechanism:
//   1. Run Stage 1+2 normally to seed Stage 3 input phi_seed
//   2. Inject perturbation: phi_seed[cell_X] += DELTA  where cell_X is chosen
//      to be displaced along source-axis X (X in {0,1,2})
//   3. Run Stage 3 (φ⁴) for ticks. Get phi_pert.
//   4. Run unperturbed phi_base for same ticks.
//   5. Response on response-axis Y: sum_i |phi_pert[i] - phi_base[i]| over
//      cells displaced from cell_X by neighbor-axis Y (one neighbor step)
//   6. C(X→Y) = (response_axis_Y) / DELTA  (normalized response coefficient)
//
// Topology subset: {flat=PR_FLAT, t3, s3, blackhole, wormhole}
// (chain1d/complete/cartoon NOT supported by propagation module — disclosure)

const PROP_SIGMA: i64 = 64
const PROP_HBAR: i64 = 100
const PROP_LSCALE: i64 = 65536
const PROP_LHIST: i64 = 4
const PROP_FDT: i64 = 100
const PROP_FSCALE: i64 = 1000

const PR_FLAT: i64 = 0
const PR_T3: i64 = 2
const PR_S3: i64 = 4
const PR_BLACKHOLE: i64 = 6
const PR_WORMHOLE: i64 = 7

fn _prtopo_id(name: string) -> i64 {
    if name == "flat" { return PR_FLAT }
    if name == "t3" { return PR_T3 }
    if name == "s3" { return PR_S3 }
    if name == "blackhole" { return PR_BLACKHOLE }
    if name == "wormhole" { return PR_WORMHOLE }
    return 0 - 1
}

fn _prneighbor_t3(i: i64, axis: i64) -> i64 {
    let x = i % 4
    let y = (i / 4) % 4
    let z = i / 16
    if axis == 0 { let xm = (x + 3) % 4; return z * 16 + y * 4 + xm }
    if axis == 1 { let ym = (y + 3) % 4; return z * 16 + ym * 4 + x }
    let zm = (z + 3) % 4
    return zm * 16 + y * 4 + x
}

fn _prneighbor(i: i64, axis: i64, topo: i64) -> i64 {
    if topo == PR_FLAT {
        if axis == 0 { return (i + PROP_SIGMA - 1) % PROP_SIGMA }
        return (i + 1) % PROP_SIGMA
    }
    if topo == PR_S3 {
        let i_q = i % 32
        let x = i_q % 4
        let y = (i_q / 4) % 4
        let z = i_q / 16
        if axis == 0 { let xm = (x + 3) % 4; return z * 16 + y * 4 + xm }
        if axis == 1 { let ym = (y + 3) % 4; return z * 16 + ym * 4 + x }
        if axis == 2 { let zm = (z + 3) % 4; return zm * 16 + y * 4 + x }
        return i_q + 32
    }
    if topo == PR_BLACKHOLE {
        let i_BH: i64 = 21
        if i == i_BH { return i_BH }
        let x = i % 4
        let y = (i / 4) % 4
        let z = i / 16
        let mut dx = x - 1; if dx < 0 { dx = 0 - dx }
        let mut dy = y - 1; if dy < 0 { dy = 0 - dy }
        let mut dz = z - 1; if dz < 0 { dz = 0 - dz }
        let d = dx + dy + dz
        if d <= 1 {
            let mut nx = x; let mut ny = y; let mut nz = z
            if axis == 0 { if x > 1 { nx = x - 1 } else if x < 1 { nx = x + 1 } }
            else if axis == 1 { if y > 1 { ny = y - 1 } else if y < 1 { ny = y + 1 } }
            else { if z > 1 { nz = z - 1 } else if z < 1 { nz = z + 1 } }
            return nz * 16 + ny * 4 + nx
        }
        return _prneighbor_t3(i, axis)
    }
    if topo == PR_WORMHOLE {
        if axis >= 3 {
            if i < 32 { let off = i % 8; return 32 + ((i + off) % 32) }
            let i2 = i - 32; let off = i2 % 8; return (i2 + off) % 32
        }
        let base = if i < 32 { 0 } else { 32 }
        let r = i - base
        let x = r % 4; let y = (r / 4) % 4; let z = r / 16
        if axis == 0 { let xm = (x + 3) % 4; return base + z * 16 + y * 4 + xm }
        if axis == 1 { let ym = (y + 3) % 4; return base + z * 16 + ym * 4 + x }
        let zm = (z + 1) % 2
        return base + zm * 16 + y * 4 + x
    }
    return _prneighbor_t3(i, axis)
}

fn propagate_stage1_quantum(topo: i64, ticks: i64) -> [i64] {
    let mut re: [i64] = []
    let mut im: [i64] = []
    let mut i = 0
    while i < PROP_SIGMA {
        let mut d = i - 32; if d < 0 { d = 0 - d }
        let denom = 1 + (d * d) / 4
        let mut v: i64 = 10000 / denom
        v = v + (6 * 17 + i * 3) % 100
        if v < 0 { v = 0 - v }
        re = re + [v]; im = im + [0]
        i = i + 1
    }
    let mut t = 0
    while t < ticks {
        let mut new_re: [i64] = []
        let mut new_im: [i64] = []
        i = 0
        while i < PROP_SIGMA {
            let mut sum_re: i64 = 0
            let mut sum_im: i64 = 0
            let mut a = 0
            while a < 3 {
                let j = _prneighbor(i, a, topo)
                if j >= 0 && j < PROP_SIGMA { sum_re = sum_re + re[j]; sum_im = sum_im + im[j] }
                a = a + 1
            }
            let lap_re = sum_re - 3 * re[i]
            let lap_im = sum_im - 3 * im[i]
            new_re = new_re + [re[i] + (PROP_HBAR * lap_im) / 10000]
            new_im = new_im + [im[i] - (PROP_HBAR * lap_re) / 10000]
            i = i + 1
        }
        re = new_re; im = new_im
        t = t + 1
    }
    let mut density: [i64] = []
    i = 0
    while i < PROP_SIGMA {
        let p = (re[i] * re[i] + im[i] * im[i]) / 10000
        density = density + [p]
        i = i + 1
    }
    return density
}

fn propagate_stage2_lorentz(input: [i64], topo: i64, ticks: i64) -> [i64] {
    let mut hist: [i64] = []
    let mut k = 0
    while k < PROP_SIGMA * PROP_LHIST {
        let i = k % PROP_SIGMA
        let v = input[i] + (k / PROP_SIGMA) * 7
        hist = hist + [v]
        k = k + 1
    }
    let mut t_now: i64 = 0
    let mut tick = 0
    while tick < ticks {
        t_now = (t_now + 1) % PROP_LHIST
        let mut new_buf: [i64] = []
        k = 0
        while k < PROP_SIGMA * PROP_LHIST { new_buf = new_buf + [hist[k]]; k = k + 1 }
        let mut i = 0
        while i < PROP_SIGMA {
            let t1_idx = (t_now - 1 + PROP_LHIST * 2) % PROP_LHIST
            let t2_idx = (t_now - 2 + PROP_LHIST * 2) % PROP_LHIST
            let prev = hist[t1_idx * PROP_SIGMA + i]
            let prev2 = hist[t2_idx * PROP_SIGMA + i]
            let time_term = 0 - prev + prev2 / 4
            let mut sum_n: i64 = 0
            let mut a = 0
            while a < 3 {
                let j = _prneighbor(i, a, topo)
                sum_n = sum_n + hist[t1_idx * PROP_SIGMA + j]
                a = a + 1
            }
            let space_term = sum_n / 3
            let mut nv = (time_term + space_term + PROP_LSCALE) % PROP_LSCALE
            if nv < 0 { nv = nv + PROP_LSCALE }
            new_buf[t_now * PROP_SIGMA + i] = nv
            i = i + 1
        }
        hist = new_buf
        tick = tick + 1
    }
    let mut out: [i64] = []
    let mut i = 0
    while i < PROP_SIGMA {
        out = out + [hist[t_now * PROP_SIGMA + i]]
        i = i + 1
    }
    return out
}

// Stage 3 with optional perturbation injected at start (cell pert_cell, +pert_delta in scaled phi units)
fn propagate_stage3_field_pert(input: [i64], topo: i64, ticks: i64, pert_cell: i64, pert_delta: i64) -> [i64] {
    let mut phi: [i64] = []
    let mut pi: [i64] = []
    let mut i = 0
    while i < PROP_SIGMA {
        let v = input[i] / 65
        phi = phi + [v]
        pi = pi + [(6 * 7 + i * 3) % 30]
        i = i + 1
    }
    if pert_cell >= 0 && pert_cell < PROP_SIGMA {
        phi[pert_cell] = phi[pert_cell] + pert_delta
    }
    let m2: i64 = 100
    let mut t = 0
    while t < ticks {
        let mut force: [i64] = []
        i = 0
        while i < PROP_SIGMA {
            let mut sum_n: i64 = 0
            let mut a = 0
            while a < 3 { sum_n = sum_n + phi[_prneighbor(i, a, topo)]; a = a + 1 }
            let lap = sum_n - 3 * phi[i]
            let dV = m2 * phi[i] / PROP_FSCALE
            force = force + [lap - dV]
            i = i + 1
        }
        let mut pi_half: [i64] = []
        let mut new_phi: [i64] = []
        i = 0
        while i < PROP_SIGMA {
            let pi_h = pi[i] + (PROP_FDT * force[i]) / (2 * PROP_FSCALE)
            pi_half = pi_half + [pi_h]
            new_phi = new_phi + [phi[i] + (PROP_FDT * pi_h) / PROP_FSCALE]
            i = i + 1
        }
        let mut force_new: [i64] = []
        i = 0
        while i < PROP_SIGMA {
            let mut sum_n: i64 = 0
            let mut a = 0
            while a < 3 { sum_n = sum_n + new_phi[_prneighbor(i, a, topo)]; a = a + 1 }
            let lap = sum_n - 3 * new_phi[i]
            let dV = m2 * new_phi[i] / PROP_FSCALE
            force_new = force_new + [lap - dV]
            i = i + 1
        }
        let mut new_pi: [i64] = []
        i = 0
        while i < PROP_SIGMA {
            new_pi = new_pi + [pi_half[i] + (PROP_FDT * force_new[i]) / (2 * PROP_FSCALE)]
            i = i + 1
        }
        phi = new_phi; pi = new_pi
        t = t + 1
    }
    return phi
}

// Pick a "central" cell well inside the lattice for a given topology
fn _center_cell(topo: i64) -> i64 {
    if topo == PR_FLAT { return 32 }
    // 4x4x4 lattice center-ish cell
    let x: i64 = 2; let y: i64 = 2; let z: i64 = 2
    return z * 16 + y * 4 + x
}

// Compute response on axis-Y: total |delta phi| over cells reached by stepping
// axis Y from pert_cell (one step forward and one back, summed)
fn _axis_response(phi_pert: [i64], phi_base: [i64], pert_cell: i64, axis_Y: i64, topo: i64) -> i64 {
    let n_fwd = _prneighbor(pert_cell, axis_Y, topo)
    let mut total: i64 = 0
    if n_fwd >= 0 && n_fwd < PROP_SIGMA {
        let mut d = phi_pert[n_fwd] - phi_base[n_fwd]
        if d < 0 { d = 0 - d }
        total = total + d
    }
    // also second-neighbor along axis Y for spread sensitivity
    if n_fwd >= 0 && n_fwd < PROP_SIGMA {
        let n2 = _prneighbor(n_fwd, axis_Y, topo)
        if n2 >= 0 && n2 < PROP_SIGMA {
            let mut d = phi_pert[n2] - phi_base[n2]
            if d < 0 { d = 0 - d }
            total = total + d
        }
    }
    return total
}

fn _measure_topo(topo_name: string) {
    let topo = _prtopo_id(topo_name)
    if topo < 0 { println("[skip] unknown topo=" + topo_name); return }
    let ticks: i64 = 12
    let pert_delta: i64 = 1000   // 1.0 in PROP_FSCALE units
    let s1 = propagate_stage1_quantum(topo, ticks)
    let s2 = propagate_stage2_lorentz(s1, topo, ticks)
    let baseline = propagate_stage3_field_pert(s2, topo, ticks, 0 - 1, 0)
    let cell0 = _center_cell(topo)
    println("[topo=" + topo_name + "] center_cell=" + to_string(cell0) + " delta=" + to_string(pert_delta))
    let mut srcX = 0
    while srcX < 3 {
        // For each "source axis" X, perturb the cell that is the X-neighbor of cell0
        let pert_cell = _prneighbor(cell0, srcX, topo)
        let phi_pert = propagate_stage3_field_pert(s2, topo, ticks, pert_cell, pert_delta)
        let mut row = "  C(X=" + to_string(srcX) + " pert_cell=" + to_string(pert_cell) + " → Y): "
        let mut respY = 0
        while respY < 3 {
            let r = _axis_response(phi_pert, baseline, pert_cell, respY, topo)
            row = row + "[Y" + to_string(respY) + "=" + to_string(r) + "] "
            respY = respY + 1
        }
        println(row)
        srcX = srcX + 1
    }
}

fn main_run() {
    let topos = ["flat", "t3", "s3", "blackhole", "wormhole"]
    println("=== cross-feed-probe cascade-s2 tick-1 ===")
    println("perturbation: +1000 (scaled phi units) at axis-X-neighbor of center cell")
    println("response: Σ|Δφ| at axis-Y first+second neighbors of perturbed cell")
    println("ticks_per_stage=12  PROP_SIGMA=64  PROP_FSCALE=1000")
    let mut i = 0
    while i < topos.len() { _measure_topo(topos[i]); i = i + 1 }
    println("=== END ===")
}

main_run()
