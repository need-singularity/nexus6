{
  "resource": "canon",
  "version": "0.1.0",
  "hive_compat": ">=0.1",
  "trust": "local",
  "root": "~/core/canon",
  "runtime": "hexa",
  "entry": "run.hexa",
  "limits": {
    "cpu_percent": 25,
    "memory_mb": 512,
    "timeout_s": 300,
    "nice": 10,
    "qos": "utility"
  },
  "caps": {
    "status": {
      "desc": "resource health check",
      "invoke": ["hx", "run", "canon", "status"],
      "timeout_s": 30
    }
  },
  "bus": {
    "subscribe": [],
    "publish": []
  }
}
