// zenodo_upload.hexa — Zenodo DOI 발급 자동화 (초안 스텁)
// 원본 참조: $PAPERS/upload_zenodo.sh (bash 원본)
// 포팅 상태: STUB DRAFT (본 에이전트는 실제 API 호출 금지 — 사용자 수동 실행 전제)
// 원본 요약:
//   1) manifest.json 에서 <PAPER_ID> 항목을 읽어 file/title/keywords/abstract 추출
//   2) Zenodo deposit 생성 → 파일 업로드 → 메타데이터 설정 → publish
//   3) DOI 출력 (manifest.json 갱신은 사용자가 별도 수행)
//
// 사용법 (계획):
//   ZENODO_TOKEN=xxx nexus hexa run zenodo_upload.hexa -- N6-054
//   ZENODO_TOKEN=xxx nexus hexa run zenodo_upload.hexa -- N6-057
//   ZENODO_TOKEN=xxx nexus hexa run zenodo_upload.hexa -- N6-058
//
// 대상 3 편 (2026-04-11 기준, 통합 158/158 OSSIFIED):
//   N6-054: papers/n6-cross-paradigm-ai-paper.md              (39/39 OSSIFIED)
//   N6-057: papers/n6-ai-17-techniques-experimental-paper.md  (40/40 OSSIFIED)
//   N6-058: papers/n6-synthetic-biology-paper.md              (79/79 OSSIFIED)
//
// 체크리스트 소스 (최신): reports/audits/zenodo-publish-3-papers-2026-04-11.md
// 선행 체크리스트 (2편): reports/audits/zenodo-publish-ready-2026-04-11.md
//
// 절대규칙:
//   - R14: manifest.json 은 SSOT — 본 스크립트는 읽기만
//   - R29: 본 파일은 verify/calc/scanner 가 아닌 '발행 자동화' 이므로 nexus/scripts/ 허용
//   - PP1: license=cc-by-4.0 고정
//   - PP2: 업로드 전 ```python 블록 임베드 실행 → OSSIFIED 확인 후 발행
//   - PP3: 발행 성공 후 사용자가 manifest.json doi 필드 갱신
//
// 본격 포팅: hexa run 으로 추진 예정
// (현재는 STUB — 사용자가 직접 upload_zenodo.sh 를 사용하거나 본 스크립트 승급 후 사용)

fn step_read_manifest(paper_id) {
    // 1) $PAPERS/manifest.json 파싱
    // 2) papers[].id == paper_id 항목 검색
    // 3) file / title / keywords / abstract_first_line 추출
    println("STUB: manifest 읽기 (paper_id=" + paper_id + ")")
}

fn step_preflight_n62(paper_path) {
    // 1) paper_path 본문에서 ```python 블록 추출
    // 2) python3 로 실행
    // 3) "OSSIFIED: N/N (iter=K)" 패턴 매칭
    // 4) 실패 시 abort (N62/PP2 위반)
    println("STUB: N62 임베드 재실행 (paper_path=" + paper_path + ")")
}

fn step_zenodo_deposit(token) {
    // POST https://zenodo.org/api/deposit/depositions
    // Authorization: Bearer $token
    // -> deposit_id, bucket_url 획득
    println("STUB: deposit 생성 (token redacted)")
}

fn step_upload_file(bucket_url, file_path, token) {
    // PUT $bucket_url/$filename
    // Content-Type: application/octet-stream
    // --data-binary @$file_path
    println("STUB: 파일 업로드 (" + file_path + ")")
}

fn step_set_metadata(deposit_id, payload_json, token) {
    // PUT https://zenodo.org/api/deposit/depositions/$deposit_id
    // Content-Type: application/json
    // body: payload_json (reports/audits/zenodo-publish-ready-2026-04-11.md section 1.3 / 2.3)
    println("STUB: 메타데이터 설정 (deposit_id=" + deposit_id + ")")
}

fn step_publish(deposit_id, token) {
    // POST https://zenodo.org/api/deposit/depositions/$deposit_id/actions/publish
    // -> doi 획득
    println("STUB: publish (deposit_id=" + deposit_id + ")")
}

fn step_report_doi(paper_id, doi, deposit_id) {
    // stdout 에 DOI / Zenodo URL / 사용자에게 manifest 갱신 안내
    println("STUB: DOI 출력 (paper_id=" + paper_id + " doi=" + doi + ")")
}

fn main() {
    println("STUB: nexus/scripts/zenodo_upload.hexa (초안 — 사용자 수동 발행 전제)")
    println("권장: ZENODO_TOKEN=xxx bash $PAPERS/upload_zenodo.sh N6-054")
    println("     ZENODO_TOKEN=xxx bash $PAPERS/upload_zenodo.sh N6-057")
    println("     ZENODO_TOKEN=xxx bash $PAPERS/upload_zenodo.sh N6-058")
    println("통합 검증: 158/158 OSSIFIED (39+40+79, iter=1)")
    println("체크리스트 (3편 통합): reports/audits/zenodo-publish-3-papers-2026-04-11.md")
    println("체크리스트 (2편 선행): reports/audits/zenodo-publish-ready-2026-04-11.md")
}
