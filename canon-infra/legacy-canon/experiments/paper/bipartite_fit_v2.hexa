// ============================================================
// bipartite_fit_v2.hexa — 3채널 증거 기반 fit 재산출 알고리즘
// ------------------------------------------------------------
// 태스크   : DSE-P5-1
// 축       : experiments/paper
// 규칙     : R0 정직검증, R1 HEXA-FIRST, R2 하드코딩 금지,
//            R3 측정값 필수, R18 미니멀
// 배경     : P4 감사에서 기존 fit 알고리즘이 100% 거짓양성 확인.
//            메타데이터 유사성만 반영하고 논문 본문 근거가 전무.
//            본 알고리즘은 3채널 실측 증거로 fit_v2 를 재산출한다.
//
// 입력     : papers/lint_progress.jsonl       (3023 엣지)
//            papers/n6-{slug}-paper.md        (126편 논문 본문)
//            techniques/**/*.hexa             (226개 기법 파일)
// 출력     : experiments/paper/_bipartite_v2_results.jsonl
// ============================================================

use std::io::{read_lines, read_file, write_file, append_line}
use std::collections::{HashSet, HashMap}
use std::fs::{list_dir, walk_dir, exists}
use std::re::{find_all, matches}
use std::math::{min, max}
use std::json::{parse, stringify}
use std::string::{lower, replace, contains, split, starts_with, trim}

// ------------------------------------------------------------
// 1. 경로 상수 — R2 하드코딩 금지
// ------------------------------------------------------------
const ROOT       = env("N6_ARCH") || (env("HOME") + "/Dev/canon")
const PAPERS_DIR = ROOT + "/papers"
const TECH_DIR   = ROOT + "/techniques"
const EDGE_FILE  = PAPERS_DIR + "/lint_progress.jsonl"
const OUT_FILE   = ROOT + "/experiments/paper/_bipartite_v2_results.jsonl"

// ------------------------------------------------------------
// 2. 가중치 — v2 3채널 증거 가중 평균
// ------------------------------------------------------------
// W1: 본문 텍스트 직접 grep (가장 강한 증거)
// W2: BT 번호 교차 참조 (간접 증거)
// W3: 섹션 제목 키워드 (구조적 증거)
const W_TEXT_GREP    = 0.50   // 채널1: 논문 본문에 기법명 직접 등장
const W_BT_CROSSREF  = 0.30   // 채널2: 기법 hexa 의 BT 가 논문에도 인용
const W_SECTION_HEAD = 0.20   // 채널3: 섹션 제목에 기법 키워드 포함

// 거짓양성 방지: 최소 1채널 증거 없으면 fit_v2 = 0
const MIN_EVIDENCE_CHANNELS = 1

// ------------------------------------------------------------
// 3. 자료구조
// ------------------------------------------------------------
struct Edge {
    tech       : String
    tech_cat   : String
    paper      : String        // 논문 slug
    fit_v1     : Float         // 기존 메타데이터 기반 점수
    lens       : String        // evidence_lens
}

struct TechInfo {
    name   : String
    path   : String
    bt_set : HashSet<String>   // 기법 hexa 파일 내 BT-NNN 참조
}

struct FitResult {
    tech           : String
    paper          : String
    fit_v1         : Float     // 기존 점수
    ch1_text_grep  : Float     // 0.0 또는 1.0
    ch2_bt_xref    : Float     // 0.0 ~ 1.0 (교차 BT 비율)
    ch3_section    : Float     // 0.0 또는 1.0
    evidence_count : Int       // PASS 채널 수 (0~3)
    fit_v2         : Float     // 최종 v2 점수
    verdict        : String    // PASS | MISS
}

// ------------------------------------------------------------
// 4. 검색 변형 생성 — 기법명의 다양한 표기
// ------------------------------------------------------------
fn make_variants(tech_name: String) -> Vec<String> {
    let base = lower(tech_name)
    let variants = [
        base,
        replace(base, "_", " "),
        replace(base, "_", "-"),
        // 주요 축약형/별칭 (수동 등록 없이 기계적 변형만)
    ]
    // 3글자 이하 기법명은 오탐 위험 → 단어 경계 요구 (구현 시 정규식)
    return variants
}

// ------------------------------------------------------------
// 5. 기법 BT 매핑 로딩
// ------------------------------------------------------------
fn load_tech_bt_map() -> HashMap<String, TechInfo> {
    let map = HashMap::new()
    let entries = walk_dir(TECH_DIR, "*.hexa")
    for entry in entries {
        let name = entry.stem()           // 파일명에서 .hexa 제거
        let content = read_file(entry.path)
        let bts = find_all(content, r"BT-\d+")
        let bt_set = HashSet::from(bts)
        map.insert(name, TechInfo {
            name: name,
            path: entry.path,
            bt_set: bt_set,
        })
    }
    return map
}

// ------------------------------------------------------------
// 6. 논문 본문 캐시 — @memoize 로 중복 I/O 차단
// ------------------------------------------------------------
@memoize
fn load_paper(slug: String) -> String {
    let path = PAPERS_DIR + "/n6-" + slug + "-paper.md"
    if exists(path) {
        return read_file(path)
    }
    return ""
}

@memoize
fn load_paper_bts(slug: String) -> HashSet<String> {
    let content = load_paper(slug)
    return HashSet::from(find_all(content, r"BT-\d+"))
}

@memoize
fn load_paper_sections(slug: String) -> Vec<String> {
    // 섹션 제목 = '#' 으로 시작하는 줄
    let content = load_paper(slug)
    let lines = split(content, "\n")
    let sections = []
    for line in lines {
        if starts_with(trim(line), "#") {
            sections.push(lower(trim(line)))
        }
    }
    return sections
}

// ------------------------------------------------------------
// 7. 채널별 증거 평가 함수
// ------------------------------------------------------------

// 채널1: 논문 본문에서 기법명 직접 grep
fn eval_ch1_text_grep(tech: String, slug: String) -> Float {
    let content = lower(load_paper(slug))
    if content == "" {
        return 0.0
    }
    let variants = make_variants(tech)
    for v in variants {
        // 3글자 이하는 단어 경계 필요 (false positive 방지)
        if len(v) <= 3 {
            // 정규식: \b{v}\b
            if matches(content, r"\b" + v + r"\b") {
                return 1.0
            }
        } else {
            if contains(content, v) {
                return 1.0
            }
        }
    }
    return 0.0
}

// 채널2: BT 번호 교차 참조
fn eval_ch2_bt_crossref(tech: String, slug: String,
                        tech_bt_map: HashMap<String, TechInfo>) -> Float {
    let tech_info = tech_bt_map.get(tech)
    if tech_info == nil || tech_info.bt_set.len() == 0 {
        return 0.0   // 기법에 BT 참조 없으면 채널2 평가 불가
    }
    let paper_bts = load_paper_bts(slug)
    if paper_bts.len() == 0 {
        return 0.0
    }
    let overlap = tech_info.bt_set.intersection(paper_bts)
    // 교차 BT 수 / 기법 BT 수 비율
    return min(1.0, overlap.len() as Float / tech_info.bt_set.len() as Float)
}

// 채널3: 섹션 제목에 기법 키워드 존재
fn eval_ch3_section_head(tech: String, slug: String) -> Float {
    let sections = load_paper_sections(slug)
    if sections.len() == 0 {
        return 0.0
    }
    let variants = make_variants(tech)
    for section in sections {
        for v in variants {
            if contains(section, v) {
                return 1.0
            }
        }
    }
    return 0.0
}

// ------------------------------------------------------------
// 8. v2 종합 fit 산출
// ------------------------------------------------------------
fn compute_fit_v2(ch1: Float, ch2: Float, ch3: Float) -> (Float, Int) {
    // 증거 채널 수 합산
    let evidence_count = 0
    if ch1 > 0.0 { evidence_count += 1 }
    if ch2 > 0.0 { evidence_count += 1 }
    if ch3 > 0.0 { evidence_count += 1 }

    // 최소 증거 미달 시 fit = 0
    if evidence_count < MIN_EVIDENCE_CHANNELS {
        return (0.0, 0)
    }

    // 3채널 가중 평균
    let score = (W_TEXT_GREP * ch1) + (W_BT_CROSSREF * ch2) + (W_SECTION_HEAD * ch3)
    return (score, evidence_count)
}

// ------------------------------------------------------------
// 9. 메인 실행
// ------------------------------------------------------------
fn main() {
    println("== bipartite_fit_v2 — 3채널 증거 기반 fit 재산출 ==")
    println("")

    // 9-1. 엣지 로딩
    let lines = read_lines(EDGE_FILE)
    let edges = []
    for line in lines {
        let rec = parse(line)
        if rec.get("record_type") == "edge" {
            edges.push(Edge {
                tech:     rec["tech"],
                tech_cat: rec["tech_cat"],
                paper:    rec["paper"],
                fit_v1:   rec["fit_score"],
                lens:     rec["evidence_lens"],
            })
        }
    }
    println("엣지 로딩: " + str(edges.len()) + "건")

    // 9-2. 기법 BT 매핑 로딩
    let tech_bt_map = load_tech_bt_map()
    println("기법 BT 매핑: " + str(tech_bt_map.len()) + "건")

    // 9-3. 전체 엣지 v2 재산출
    let results = []
    let pass_count = 0
    let miss_count = 0
    let ch1_total = 0
    let ch2_total = 0
    let ch3_total = 0

    for edge in edges {
        let ch1 = eval_ch1_text_grep(edge.tech, edge.paper)
        let ch2 = eval_ch2_bt_crossref(edge.tech, edge.paper, tech_bt_map)
        let ch3 = eval_ch3_section_head(edge.tech, edge.paper)
        let (fit_v2, ev_count) = compute_fit_v2(ch1, ch2, ch3)

        let verdict = "MISS"
        if fit_v2 > 0.0 {
            verdict = "PASS"
            pass_count += 1
        } else {
            miss_count += 1
        }

        if ch1 > 0.0 { ch1_total += 1 }
        if ch2 > 0.0 { ch2_total += 1 }
        if ch3 > 0.0 { ch3_total += 1 }

        let result = FitResult {
            tech:           edge.tech,
            paper:          edge.paper,
            fit_v1:         edge.fit_v1,
            ch1_text_grep:  ch1,
            ch2_bt_xref:    ch2,
            ch3_section:    ch3,
            evidence_count: ev_count,
            fit_v2:         fit_v2,
            verdict:        verdict,
        }
        results.push(result)
    }

    // 9-4. 결과 저장
    let out_lines = []
    for r in results {
        out_lines.push(stringify({
            "tech":           r.tech,
            "paper":          r.paper,
            "fit_v1":         r.fit_v1,
            "ch1_text_grep":  r.ch1_text_grep,
            "ch2_bt_xref":    r.ch2_bt_xref,
            "ch3_section":    r.ch3_section,
            "evidence_count": r.evidence_count,
            "fit_v2":         r.fit_v2,
            "verdict":        r.verdict,
        }))
    }
    write_file(OUT_FILE, out_lines.join("\n") + "\n")

    // 9-5. 집계 출력
    println("")
    println("== v2 전수 결과 ==")
    println("총 엣지:             " + str(edges.len()))
    println("PASS (fit_v2 > 0):   " + str(pass_count))
    println("MISS (fit_v2 = 0):   " + str(miss_count))
    println("")
    println("채널별 PASS:")
    println("  채널1 (본문 grep): " + str(ch1_total))
    println("  채널2 (BT 교차):  " + str(ch2_total))
    println("  채널3 (섹션 제목): " + str(ch3_total))
    println("")

    // 9-6. 상위 10쌍 재검증 (P4 대조)
    println("== 상위 10쌍 재검증 (v1 기준 정렬) ==")
    let top10_v1 = sorted(results, key=|r| -r.fit_v1)[:10]
    println("| # | tech | paper | fit_v1 | ch1 | ch2 | ch3 | fit_v2 | 판정 |")
    println("|---|------|-------|--------|-----|-----|-----|--------|------|")
    for i, r in enumerate(top10_v1) {
        println("| " + str(i+1) + " | " + r.tech + " | " + r.paper +
                " | " + str(r.fit_v1) + " | " + str(r.ch1_text_grep) +
                " | " + str(r.ch2_bt_xref) + " | " + str(r.ch3_section) +
                " | " + str(r.fit_v2) + " | **" + r.verdict + "** |")
    }

    // 9-7. v2 PASS 엣지 상위 10 (새 스코어 기준)
    println("")
    println("== v2 PASS 상위 10 (fit_v2 내림차순) ==")
    let top10_v2 = sorted(results.filter(|r| r.fit_v2 > 0.0), key=|r| -r.fit_v2)[:10]
    if top10_v2.len() == 0 {
        println("(PASS 엣지 없음 — 전수 MISS)")
    } else {
        for i, r in enumerate(top10_v2) {
            println(str(i+1) + ". " + r.tech + " -> " + r.paper +
                    " fit_v2=" + str(r.fit_v2) +
                    " (ch1=" + str(r.ch1_text_grep) +
                    " ch2=" + str(r.ch2_bt_xref) +
                    " ch3=" + str(r.ch3_section) + ")")
        }
    }

    // 9-8. 거짓양성율 비교
    println("")
    println("== v1 vs v2 거짓양성율 비교 ==")
    let v1_top10_miss = top10_v1.filter(|r| r.verdict == "MISS").len()
    println("v1 상위10 거짓양성: " + str(v1_top10_miss) + "/10 (" + str(v1_top10_miss * 10) + "%)")
    let v2_pass_total = results.filter(|r| r.fit_v2 > 0.0).len()
    println("v2 PASS 총 수:     " + str(v2_pass_total) + "/" + str(edges.len()))
    println("v2 는 증거 없는 거짓양성을 생산하지 않음 (최소 1채널 실측 증거 필수)")
}
