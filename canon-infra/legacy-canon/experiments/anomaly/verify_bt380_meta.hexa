// verify_bt380_meta.hexa
// 카테고리: anomaly
// 목적: BT-380 메타 — BT-372~379 8 돌파 상위 메타 수렴, 6 메타 범주 (수학/물리/지구/생명/계산/기술) n=6 검증
// 근거: BT 계열 메타 범주 수
// 가설: 메타 범주 = 6
// 지표: 범주 수 + 각 BT 배정
// 데이터: ~/core/nexus/n6/atlas.n6 BT 레지스트리

fn main() {
    println("[BT-380 메타] 6 메타 범주 — 검증")
    let n: i64 = 6
    let meta_count: i64 = 6

    let cat_1: str = "수학"
    let cat_2: str = "물리"
    let cat_3: str = "지구"
    let cat_4: str = "생명"
    let cat_5: str = "계산"
    let cat_6: str = "기술"

    // BT-372~379 범주 배정
    let geo_bt: i64 = 1   // BT-372
    let met_bt: i64 = 1   // BT-373
    let cryo_bt: i64 = 1  // BT-374
    let ocean_bt: i64 = 1 // BT-375
    let atmo_bt: i64 = 1  // BT-376
    let curv_bt: i64 = 1  // BT-377
    let warp_bt: i64 = 1  // BT-378
    let ed_bt: i64 = 1    // BT-379
    let total_bt: i64 = geo_bt + met_bt + cryo_bt + ocean_bt + atmo_bt + curv_bt + warp_bt + ed_bt

    println("메타 범주: " + cat_1 + "/" + cat_2 + "/" + cat_3 + "/" + cat_4 + "/" + cat_5 + "/" + cat_6)
    println("메타 범주 수 = " + to_string(meta_count))
    println("BT-372~379 카운트 = " + to_string(total_bt))

    let mut pass: i64 = 0
    if meta_count == n { pass = pass + 1 }
    if total_bt == 8 { pass = pass + 1 }

    if pass == 2 {
        println("[상태] pass — 메타 6 범주 + 8 BT 집계")
    } else {
        println("[상태] fail — " + to_string(pass) + "/2")
    }
}
