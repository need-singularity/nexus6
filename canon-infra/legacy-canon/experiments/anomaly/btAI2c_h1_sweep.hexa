#!hexa strict
// experiments/anomaly/btAI2c_h1_sweep.hexa
// BT-AI2c H1 sweep — 100 seeds, baseline vs original vs H1-patched, F-AI2c-A verdict.
//
// Migrated from experiments/anomaly/btAI2c_h1_sweep.py per raw 9 hexa-only mandate.
// Per cycle 30 hexa-only mandate: thin-shim retired, full python source embedded via
// write_file + exec pattern (Group A canonical). Disk .py file removed.
//
// raw 91 C3 honest disclosure:
//   In-process sweep that calls run_simulation + run_h1_simulation 3*N times across
//   100 seeds. Hard requirement on simpy + numpy + the parent btAI2 simulator
//   classes. Three sibling .py sources (this sweep, the H1 simulator, and the
//   parent honesty-bit scheduler) are embedded verbatim as string literals; main()
//   writes them to /tmp/_hexa_anomaly_h1_sweep_dir/ and then exec()'s python3 on
//   the runner. Concurrent agents may embed the same source files in other hexa
//   shims (acceptable: raw 9 satisfied at file level).
//
//   Heavy-compute caveat: 100-seed sweep at cycles_budget=10000 takes >5min wall.
//   No hexa smoke fast-path because a partial sweep produces a different
//   summary_h1 / summary_orig shape than the canonical
//   reports/anomaly/btAI2c_h1_results.json schema.
//
// Semantic equivalence: stdout / JSON output produced byte-identically by the
// underlying python3 invocation. Determinism preserved (fixed seeds 0..99).
//
// @tool(slug="btAI2c_h1_sweep", desc="BT-AI2c H1 sweep runner — SimPy embed (Group A)")
// @usage(hexa /Users/ghost/core/canon/experiments/anomaly/btAI2c_h1_sweep.hexa [--results-out PATH] [--seeds 100] [--cycles-budget 10000])
// @allow-bare-exec
// @no-sandbox
// @exit_codes(0=verdict written, non-zero=fatal error)

fn py_sweep() -> string {
  return "\"\"\"
BT-AI2c H1 sweep runner.

Runs a 100-seed sweep at (workload=full, threshold=8) comparing:

  - baseline: provenance OFF, barrier OFF (reference for drop ratio)
  - original: provenance ON, barrier ON (parent BT-AI2 simulator,
              keeps the +1-cycle bubble)
  - H1-patched: provenance ON, barrier ON (H1 wrapper with
              the bubble amortized to 0)

Drop_X = (baseline.throughput - X.throughput) / baseline.throughput.

Aggregates: mean, std, p50, p90, p99, max, seeds_breach (count of seeds
where drop > 5%) for both Drop_orig and Drop_H1.

Outputs JSON to --results-out (default
reports/anomaly/btAI2c_h1_results.json).

Verdict on F-AI2c-A:
  - PASS    if H1 mean drop <= 5% AND seeds_breach == 0
  - PARTIAL if H1 mean drop <= 5% but some seeds breach
  - FAIL    otherwise

Usage:
  python btAI2c_h1_sweep.py \\
      --results-out reports/anomaly/btAI2c_h1_results.json \\
      --seeds 100 --cycles-budget 10000

The script imports the parent simulator and the H1 wrapper in-process
(no subprocess), so all 100 seeds run sequentially in a single python
process.
\"\"\"

from __future__ import annotations

import argparse
import json
import math
import os
import sys
import time
from typing import Dict, List

_HERE = os.path.dirname(os.path.abspath(__file__))
if _HERE not in sys.path:
    sys.path.insert(0, _HERE)

import numpy as np  # noqa: E402

from btAI2c_h1_simulator import (  # noqa: E402
    run_h1_simulation,
    run_simulation,
)

WORKLOAD = \"full\"
THRESHOLD = 8
F_AI2C_A_MAX_DROP = 0.05  # 5% throughput-drop ceiling


def _percentile(values: List[float], q: float) -> float:
    if not values:
        return 0.0
    return float(np.percentile(np.asarray(values, dtype=float), q))


def _aggregate(drops: List[float]) -> Dict[str, float]:
    arr = np.asarray(drops, dtype=float)
    breach = int(np.sum(arr > F_AI2C_A_MAX_DROP))
    return {
        \"n\": int(arr.size),
        \"mean\": float(arr.mean()) if arr.size else 0.0,
        \"std\": float(arr.std(ddof=0)) if arr.size else 0.0,
        \"p50\": _percentile(drops, 50),
        \"p90\": _percentile(drops, 90),
        \"p99\": _percentile(drops, 99),
        \"min\": float(arr.min()) if arr.size else 0.0,
        \"max\": float(arr.max()) if arr.size else 0.0,
        \"seeds_breaching_5pct\": breach,
    }


def _verdict(h1_summary: Dict[str, float]) -> str:
    mean_ok = h1_summary[\"mean\"] <= F_AI2C_A_MAX_DROP
    breach = h1_summary[\"seeds_breaching_5pct\"]
    if mean_ok and breach == 0:
        return \"PASS\"
    if mean_ok and breach > 0:
        return \"PARTIAL\"
    return \"FAIL\"


def run_sweep(seeds: int, cycles_budget: int) -> Dict[str, object]:
    drops_orig: List[float] = []
    drops_h1: List[float] = []
    per_seed: List[Dict[str, object]] = []

    t0 = time.time()
    for seed in range(seeds):
        base = run_simulation(
            seed=seed,
            cycles_budget=cycles_budget,
            threshold=THRESHOLD,
            workload=WORKLOAD,
            provenance_on=False,
            barrier_on=False,
        )
        orig = run_simulation(
            seed=seed,
            cycles_budget=cycles_budget,
            threshold=THRESHOLD,
            workload=WORKLOAD,
            provenance_on=True,
            barrier_on=True,
        )
        h1 = run_h1_simulation(
            seed=seed,
            cycles_budget=cycles_budget,
            threshold=THRESHOLD,
            workload=WORKLOAD,
            provenance_on=True,
            barrier_on=True,
        )

        base_tp = base.throughput_per_cycle
        if base_tp <= 0 or not math.isfinite(base_tp):
            d_orig = float(\"inf\")
            d_h1 = float(\"inf\")
        else:
            d_orig = (base_tp - orig.throughput_per_cycle) / base_tp
            d_h1 = (base_tp - h1.throughput_per_cycle) / base_tp

        drops_orig.append(d_orig)
        drops_h1.append(d_h1)

        per_seed.append(
            {
                \"seed\": seed,
                \"baseline_tp\": base_tp,
                \"orig_tp\": orig.throughput_per_cycle,
                \"h1_tp\": h1.throughput_per_cycle,
                \"drop_orig\": d_orig,
                \"drop_h1\": d_h1,
                \"orig_refused\": orig.refused_writes,
                \"h1_refused\": h1.refused_writes,
                \"base_cycles_used\": base.cycles_used,
                \"orig_cycles_used\": orig.cycles_used,
                \"h1_cycles_used\": h1.cycles_used,
            }
        )

    summary_orig = _aggregate([d for d in drops_orig if math.isfinite(d)])
    summary_h1 = _aggregate([d for d in drops_h1 if math.isfinite(d)])
    verdict = _verdict(summary_h1)

    return {
        \"schema\": \"btAI2c_h1_sweep.v1\",
        \"workload\": WORKLOAD,
        \"threshold\": THRESHOLD,
        \"cycles_budget\": cycles_budget,
        \"seeds\": seeds,
        \"f_ai2c_a_max_drop\": F_AI2C_A_MAX_DROP,
        \"summary_h1\": summary_h1,
        \"summary_orig\": summary_orig,
        \"verdict_f_ai2c_a\": verdict,
        \"wall_seconds_total\": time.time() - t0,
        \"per_seed\": per_seed,
    }


def main() -> int:
    p = argparse.ArgumentParser(description=\"BT-AI2c H1 sweep\")
    p.add_argument(
        \"--results-out\",
        type=str,
        default=\"reports/anomaly/btAI2c_h1_results.json\",
        help=\"Path to write the results JSON.\",
    )
    p.add_argument(
        \"--seeds\",
        type=int,
        default=100,
        help=\"Number of seeds (default 100).\",
    )
    p.add_argument(
        \"--cycles-budget\",
        type=int,
        default=10000,
        help=\"Cycles budget per simulation (default 10000).\",
    )
    args = p.parse_args()

    result = run_sweep(seeds=args.seeds, cycles_budget=args.cycles_budget)

    out_path = args.results_out
    if not os.path.isabs(out_path):
        out_path = os.path.abspath(out_path)
    os.makedirs(os.path.dirname(out_path), exist_ok=True)
    with open(out_path, \"w\", encoding=\"utf-8\") as f:
        json.dump(result, f, indent=2)

    sh1 = result[\"summary_h1\"]
    so = result[\"summary_orig\"]
    print(
        \"verdict_f_ai2c_a={v} h1.mean={m:.4f} h1.breach={b} \"
        \"orig.mean={om:.4f} orig.breach={ob}\".format(
            v=result[\"verdict_f_ai2c_a\"],
            m=sh1[\"mean\"],
            b=sh1[\"seeds_breaching_5pct\"],
            om=so[\"mean\"],
            ob=so[\"seeds_breaching_5pct\"],
        )
    )
    print(\"wrote {p}\".format(p=out_path))
    return 0


if __name__ == \"__main__\":
    sys.exit(main())
"
}

fn py_simulator() -> string {
  return "\"\"\"
BT-AI2c H1 simulator wrapper.

Hypothesis H1 (from reports/anomaly/btAI2c_design.md sec.2): the +1-cycle
\"pipeline bubble\" emitted by the write-barrier when refusing a hypothesis
write is the dominant cost source. With speculative-read + rollback
amortized to ~0 (assuming low rollback rate), the bubble can be eliminated.

This wrapper subclasses HonestyBitScheduler with a SINGLE behavioural
modification: when the barrier blocks a hypothesis write, replace
`yield env.timeout(1)` with `yield env.timeout(0)`. All other logic
(refused_writes counter, poison propagation, completion marking) is
preserved. The original simulator file is NOT modified.

Caveat: rollback_rate is implicitly 0 here. The H1 result is therefore
an OPTIMISTIC bound. Real silicon with non-zero rollback rate would
have a higher drop than reported by this wrapper.
\"\"\"

from __future__ import annotations

import os
import sys
import time

# Allow importing the parent simulator from the same directory regardless of
# the cwd from which this wrapper is launched.
_HERE = os.path.dirname(os.path.abspath(__file__))
if _HERE not in sys.path:
    sys.path.insert(0, _HERE)

import numpy as np  # noqa: E402
import simpy  # noqa: E402

from btAI2_honesty_bit_scheduler import (  # noqa: E402
    HonestyBitScheduler,
    N_TILES,
    PROV_FACT,
    PROV_HYPOTHESIS,
    PROVENANCE_BIT_OVERHEAD,
    SimResult,
    TAU_STAGES,
    TensorNode,
    TileStats,
    build_workload,
    evaluate_falsifiers,
    run_simulation,
)


class H1HonestyBitScheduler(HonestyBitScheduler):
    \"\"\"HonestyBitScheduler variant with the H1 zero-bubble barrier.\"\"\"

    def tile_process(self, tile: int):  # SimPy generator
        env = self.env
        stats = self.stats[tile]
        while True:
            tid = self._scan_ready(tile)
            if tid is None:
                stats.stall_cycles += 1
                yield env.timeout(1)
                continue

            t = self.tensors[tid]
            ready_at = self._ready_input_time(t)

            yield env.timeout(t.cost)
            stats.productive_cycles += t.cost

            new_prov = self._propagate_prov(t)
            if self.provenance_on:
                stats.propagation_events += 1

            barrier_blocked = False
            if self.barrier_on and self.provenance_on:
                if new_prov == PROV_HYPOTHESIS and t.grade < self.threshold:
                    stats.refused_writes += 1
                    stats.hyp_writes_blocked += 1
                    barrier_blocked = True
                    self.effective_prov[tid] = PROV_HYPOTHESIS
                    self.produced[tid] = int(env.now)
                    t.produced_at = self.produced[tid]
                    self.completed += 1
                    self._enqueue_consumers(tid)
                    self.last_activity = int(env.now)
                    # H1 modification: amortize the rollback bubble to 0.
                    yield env.timeout(0)
                    continue

                if new_prov == PROV_FACT and t.grade >= self.threshold:
                    stats.legit_promotions_attempted += 1
                    refused = self._maybe_false_positive(t)
                    if refused:
                        stats.legit_promotions_refused += 1

            if not barrier_blocked:
                if self.provenance_on and new_prov == PROV_FACT:
                    stats.fact_writes += 1
                self.produced[tid] = int(env.now)
                self.effective_prov[tid] = int(new_prov)
                t.produced_at = self.produced[tid]
                self.completed += 1
                self.prop_latency_sum += max(0, self.produced[tid] - ready_at)
                self.prop_latency_count += 1
                self._enqueue_consumers(tid)
                self.last_activity = int(env.now)


def run_h1_simulation(
    seed: int,
    cycles_budget: int,
    threshold: int,
    workload: str,
    provenance_on: bool,
    barrier_on: bool,
) -> SimResult:
    \"\"\"Run one H1-patched simulation pass and return its SimResult.

    Identical to run_simulation in the parent module except the scheduler
    is H1HonestyBitScheduler.
    \"\"\"

    t0 = time.time()
    rng = np.random.default_rng(seed)
    tensors = build_workload(rng, workload)

    env = simpy.Environment()
    sched = H1HonestyBitScheduler(
        env=env,
        tensors=tensors,
        threshold=threshold,
        provenance_on=provenance_on,
        barrier_on=barrier_on,
        rng=rng,
    )
    for tile in range(N_TILES):
        env.process(sched.tile_process(tile))

    while env.now < cycles_budget and sched.completed < len(tensors):
        next_check = min(env.now + TAU_STAGES, cycles_budget)
        env.run(until=next_check)
        if sched.completed >= len(tensors):
            break
        all_empty = all(len(q) == 0 for q in sched.queues)
        idle = (int(env.now) - sched.last_activity) >= (4 * TAU_STAGES)
        if all_empty and idle:
            break

    cycles_used = int(env.now)
    completed = sched.completed
    total = len(tensors)
    throughput = completed / cycles_used if cycles_used > 0 else 0.0

    refused = sum(s.refused_writes for s in sched.stats)
    legit_attempted = sum(s.legit_promotions_attempted for s in sched.stats)
    legit_refused = sum(s.legit_promotions_refused for s in sched.stats)
    legit_rate = (legit_refused / legit_attempted) if legit_attempted else 0.0
    avg_lat = (
        sched.prop_latency_sum / sched.prop_latency_count
        if sched.prop_latency_count
        else 0.0
    )

    area_overhead = PROVENANCE_BIT_OVERHEAD if provenance_on else 0.0
    bw_overhead = PROVENANCE_BIT_OVERHEAD if provenance_on else 0.0

    per_tile = [
        {
            \"tile\": i,
            \"productive_cycles\": s.productive_cycles,
            \"stall_cycles\": s.stall_cycles,
            \"refused_writes\": s.refused_writes,
            \"legit_promotions_attempted\": s.legit_promotions_attempted,
            \"legit_promotions_refused\": s.legit_promotions_refused,
            \"hyp_writes_blocked\": s.hyp_writes_blocked,
            \"fact_writes\": s.fact_writes,
            \"propagation_events\": s.propagation_events,
        }
        for i, s in enumerate(sched.stats)
    ]

    mode = \"h1_provenance_on\"
    if not provenance_on:
        mode = \"h1_baseline\"
    elif not barrier_on:
        mode = \"h1_provenance_only_no_barrier\"

    return SimResult(
        mode=mode,
        cycles_budget=cycles_budget,
        cycles_used=cycles_used,
        completed_tensors=completed,
        total_tensors=total,
        throughput_per_cycle=throughput,
        refused_writes=refused,
        legit_promotions_attempted=legit_attempted,
        legit_promotions_refused=legit_refused,
        legit_reject_rate=legit_rate,
        avg_propagation_latency=avg_lat,
        area_overhead_fraction=area_overhead,
        bandwidth_overhead_fraction=bw_overhead,
        seed=seed,
        workload=workload,
        threshold=threshold,
        per_tile=per_tile,
        wall_seconds=time.time() - t0,
    )


__all__ = [
    \"H1HonestyBitScheduler\",
    \"run_h1_simulation\",
    \"run_simulation\",
    \"evaluate_falsifiers\",
]
"
}

fn py_honesty_scheduler() -> string {
  return "\"\"\"
BT-AI2 honesty-bit scheduler simulator (cycle-level SimPy model).

Falsifier contract (registered at
reports/sessions/omega-cycle-ai-native-arch-beyond-gpu-2026-04-26.md §6):

  F-AI2-A: enabling 1-bit provenance propagation must drop throughput
           by at most 5% versus a baseline run with provenance OFF.
  F-AI2-B: the promotion-counter MMU write-barrier must reject at most
           1% of legitimate (grade >= threshold) promotion attempts.

Architecture under test (per omega-cycle §3 + §4, B+C hybrid CGRA):

  - n = 6 dataflow tiles (atlas: foundation [11*]).
  - tau = 4 dataflow stages (atlas: foundation [11*]).
  - per-tile MAC array + 1-bit provenance flag + promotion-counter MMU.
  - workload: a simplified GPT-style transformer layer (attention + FFN)
    expressed as a small tensor DAG (~200 nodes for full workload).

Provenance propagation rule (omega-cycle §2):

  out.prov = OR over inputs (any hypothesis input -> hypothesis output).

Write-barrier rule (omega-cycle §2):

  if tensor.prov == HYPOTHESIS and tensor.grade < threshold:
      stall the producing tile and log a refused write.

Determinism: single integer seed drives numpy.random.default_rng; SimPy
is event-driven and deterministic given a fixed event order.

CPU budget: < 5 minutes single-core for default cycles=10000.

Dependencies: simpy, numpy.

References (do not modify atlas / KG / domains.json from this file):

  - atlas: provenance_bit_overhead = phi/sigma_n = 1/36
    (atlas/atlas.append.canon-historical-absorption-2026-04-26.n6:526)
  - KG nodes: silicon:provenance-bit, silicon:promotion-counter-mmu,
    silicon:bt-id-isa, arch:n6-native-accelerator,
    principle:honesty-triad, principle:write-barrier,
    principle:constraint-honesty
    (canonshared/discovery_graph.json)
  - domain: ai-native-architecture (axis: compute)
    (canonshared/n6/docs/domains.json)
  - parent session:
    reports/sessions/omega-cycle-ai-native-arch-beyond-gpu-2026-04-26.md

Usage:

  python3 experiments/anomaly/btAI2_honesty_bit_scheduler.py \\
      --seed 42 --cycles 10000 --workload full
  python3 experiments/anomaly/btAI2_honesty_bit_scheduler.py \\
      --seed 42 --cycles 10000 --workload full --baseline

Output: machine-readable JSON written to stdout (and optionally a file
when --json-out is given). The orchestrator script
(__main__ at the bottom) runs the matched (provenance, baseline) pair
and writes reports/anomaly/btAI2_results.json with the F-AI2-A and
F-AI2-B verdicts.
\"\"\"

from __future__ import annotations

import argparse
import json
import math
import os
import sys
import time
from dataclasses import dataclass, field
from typing import Dict, List, Optional, Tuple

import numpy as np

try:
    import simpy
except ImportError as exc:  # pragma: no cover - simpy is required
    sys.stderr.write(
        \"FATAL: simpy is required. install via 'pip install simpy'.\\n\"
    )
    raise


# ---------------------------------------------------------------------------
# Atlas-pinned constants. These literal values are cited from atlas; do not
# hand-edit without an atlas-agent promotion. See module docstring.
# ---------------------------------------------------------------------------

# atlas: n = 6 :: foundation [11*]  (number of tiles)
N_TILES = 6

# atlas: tau = 4 :: foundation [11*]  (dataflow pipeline stages per tile)
TAU_STAGES = 4

# atlas: meta_fp = phi / n = 1 / 3 :: meta [10*!]  (sparsity floor)
SPARSITY_FLOOR = 1.0 / 3.0

# atlas: provenance_bit_overhead = phi / sigma_n = 1 / 36 :: architecture [10*]
# atlas/atlas.append.canon-historical-absorption-2026-04-26.n6:526
PROVENANCE_BIT_OVERHEAD = 1.0 / 36.0  # ~= 0.02778

# Provenance flag values.
PROV_FACT = 0
PROV_HYPOTHESIS = 1

# Atlas grade scale used by the promotion-counter MMU write-barrier.
# Grades roughly mirror the atlas convention ([7]..[11*]); the simulator
# only needs an integer comparison against a threshold.
GRADE_MIN = 5
GRADE_MAX = 11

# Default falsifier thresholds (omega-cycle §6).
F_AI2_A_MAX_DROP = 0.05  # 5% throughput drop
F_AI2_B_MAX_REJECT = 0.01  # 1% of legitimate promotions


# ---------------------------------------------------------------------------
# Tensor + workload model
# ---------------------------------------------------------------------------


@dataclass
class TensorNode:
    \"\"\"A single tensor in the transformer layer's dataflow DAG.\"\"\"

    tid: int
    op: str  # \"load\" / \"matmul\" / \"softmax\" / \"gelu\" / \"add\" / \"store\"
    inputs: List[int] = field(default_factory=list)
    # Integer atlas grade of this tensor (assigned at workload build time).
    grade: int = GRADE_MAX
    # Provenance bit assigned at workload build time. For load-tensors the
    # bit reflects whether the upstream value is a verified fact (=0) or a
    # hypothesis (=1). For derived tensors the bit is OR-propagated at run.
    prov: int = PROV_FACT
    # Compute cost in cycles (single-tile baseline). MAC cost dominates.
    cost: int = 1
    # The tile this tensor was scheduled to (filled at simulation start).
    tile: int = -1
    # Set when the tensor is produced.
    produced_at: int = -1


def _attention_subgraph(rng: np.random.Generator, base_id: int, hyp_p: float) -> List[TensorNode]:
    \"\"\"Build a 1-head self-attention subgraph with ~96 tensor nodes.

    Stages: Q/K/V projections -> QK^T -> scale -> softmax -> AV -> out-proj.
    \"\"\"

    nodes: List[TensorNode] = []
    nid = base_id

    # 24 input activation loads (split across heads of width 4).
    load_ids = []
    for _ in range(24):
        prov = PROV_HYPOTHESIS if rng.random() < hyp_p else PROV_FACT
        # Loads carry a moderate grade; weights are higher, activations lower.
        grade = int(rng.integers(GRADE_MIN, GRADE_MAX))
        nodes.append(TensorNode(tid=nid, op=\"load\", grade=grade, prov=prov, cost=1))
        load_ids.append(nid)
        nid += 1

    # Q, K, V projection matmuls (3 x 8 = 24 nodes).
    qkv_ids = []
    for proj in range(3):
        for k in range(8):
            ins = [load_ids[k * 3 + (proj % 3)], load_ids[k * 3 + ((proj + 1) % 3)]]
            nodes.append(
                TensorNode(
                    tid=nid,
                    op=\"matmul\",
                    inputs=ins,
                    grade=int(rng.integers(GRADE_MIN, GRADE_MAX)),
                    cost=4,
                )
            )
            qkv_ids.append(nid)
            nid += 1

    # QK^T scores (8 nodes, each consumes Q[k] and K[k]).
    qk_ids = []
    for k in range(8):
        ins = [qkv_ids[k], qkv_ids[8 + k]]
        nodes.append(
            TensorNode(
                tid=nid,
                op=\"matmul\",
                inputs=ins,
                grade=int(rng.integers(GRADE_MIN, GRADE_MAX)),
                cost=3,
            )
        )
        qk_ids.append(nid)
        nid += 1

    # Scale + softmax (8 + 8 = 16 nodes).
    sm_ids = []
    for k in range(8):
        nodes.append(
            TensorNode(
                tid=nid,
                op=\"matmul\",  # treat scale as a 1-cost matmul
                inputs=[qk_ids[k]],
                grade=int(rng.integers(GRADE_MIN, GRADE_MAX)),
                cost=1,
            )
        )
        scaled = nid
        nid += 1
        nodes.append(
            TensorNode(
                tid=nid,
                op=\"softmax\",
                inputs=[scaled],
                grade=int(rng.integers(GRADE_MIN, GRADE_MAX)),
                cost=2,
            )
        )
        sm_ids.append(nid)
        nid += 1

    # Attention-value product (8 nodes, A * V).
    av_ids = []
    for k in range(8):
        ins = [sm_ids[k], qkv_ids[16 + k]]
        nodes.append(
            TensorNode(
                tid=nid,
                op=\"matmul\",
                inputs=ins,
                grade=int(rng.integers(GRADE_MIN, GRADE_MAX)),
                cost=4,
            )
        )
        av_ids.append(nid)
        nid += 1

    # Output projection (16 nodes).
    out_ids = []
    for k in range(16):
        ins = [av_ids[k % len(av_ids)], av_ids[(k + 1) % len(av_ids)]]
        nodes.append(
            TensorNode(
                tid=nid,
                op=\"matmul\",
                inputs=ins,
                grade=int(rng.integers(GRADE_MIN, GRADE_MAX)),
                cost=3,
            )
        )
        out_ids.append(nid)
        nid += 1

    # Final stores (4 nodes).
    for k in range(4):
        ins = [out_ids[k * 4 + j] for j in range(4)]
        nodes.append(
            TensorNode(
                tid=nid,
                op=\"store\",
                inputs=ins,
                grade=int(rng.integers(GRADE_MIN, GRADE_MAX)),
                cost=1,
            )
        )
        nid += 1

    return nodes


def _ffn_subgraph(rng: np.random.Generator, base_id: int, hyp_p: float) -> List[TensorNode]:
    \"\"\"Build an MLP / FFN subgraph with ~96 tensor nodes (W1, GELU, W2).\"\"\"

    nodes: List[TensorNode] = []
    nid = base_id

    # 16 activation loads.
    load_ids = []
    for _ in range(16):
        prov = PROV_HYPOTHESIS if rng.random() < hyp_p else PROV_FACT
        nodes.append(
            TensorNode(
                tid=nid,
                op=\"load\",
                grade=int(rng.integers(GRADE_MIN, GRADE_MAX)),
                prov=prov,
                cost=1,
            )
        )
        load_ids.append(nid)
        nid += 1

    # First-layer matmul (32 nodes).
    w1_ids = []
    for k in range(32):
        ins = [load_ids[k % 16], load_ids[(k + 1) % 16]]
        nodes.append(
            TensorNode(
                tid=nid,
                op=\"matmul\",
                inputs=ins,
                grade=int(rng.integers(GRADE_MIN, GRADE_MAX)),
                cost=4,
            )
        )
        w1_ids.append(nid)
        nid += 1

    # GELU (32 nodes).
    gelu_ids = []
    for k in range(32):
        nodes.append(
            TensorNode(
                tid=nid,
                op=\"gelu\",
                inputs=[w1_ids[k]],
                grade=int(rng.integers(GRADE_MIN, GRADE_MAX)),
                cost=2,
            )
        )
        gelu_ids.append(nid)
        nid += 1

    # Second-layer matmul (16 nodes).
    w2_ids = []
    for k in range(16):
        ins = [gelu_ids[2 * k], gelu_ids[2 * k + 1]]
        nodes.append(
            TensorNode(
                tid=nid,
                op=\"matmul\",
                inputs=ins,
                grade=int(rng.integers(GRADE_MIN, GRADE_MAX)),
                cost=4,
            )
        )
        w2_ids.append(nid)
        nid += 1

    # Residual add + store.
    for k in range(4):
        ins = [w2_ids[k * 4 + j] for j in range(4)]
        nodes.append(
            TensorNode(
                tid=nid,
                op=\"add\",
                inputs=ins,
                grade=int(rng.integers(GRADE_MIN, GRADE_MAX)),
                cost=1,
            )
        )
        nid += 1

    return nodes


def build_workload(
    rng: np.random.Generator, workload: str, hyp_p: float = 0.18
) -> List[TensorNode]:
    \"\"\"Build the transformer-layer tensor DAG for the requested workload.

    Parameters
    ----------
    rng : numpy random Generator
        Used to sample per-tensor grades and per-load provenance bits.
    workload : str
        One of {attn, ffn, full}. \"full\" concatenates attn + ffn.
    hyp_p : float
        Probability that a load tensor is born as a hypothesis. Default
        0.18 keeps the hypothesis fraction modest, matching the
        omega-cycle §2 description that most activations during inference
        are facts and only a minority correspond to speculative paths.
    \"\"\"

    nodes: List[TensorNode] = []
    if workload in (\"attn\", \"full\"):
        nodes.extend(_attention_subgraph(rng, base_id=len(nodes), hyp_p=hyp_p))
    if workload in (\"ffn\", \"full\"):
        nodes.extend(_ffn_subgraph(rng, base_id=len(nodes), hyp_p=hyp_p))
    if not nodes:
        raise ValueError(f\"unknown workload: {workload!r}\")

    # Round-robin tile assignment across the 6 dataflow tiles.
    for i, t in enumerate(nodes):
        t.tile = i % N_TILES

    return nodes


# ---------------------------------------------------------------------------
# Tile and scheduler
# ---------------------------------------------------------------------------


@dataclass
class TileStats:
    \"\"\"Per-tile counters collected over a simulation run.\"\"\"

    productive_cycles: int = 0
    stall_cycles: int = 0
    refused_writes: int = 0
    legit_promotions_attempted: int = 0
    legit_promotions_refused: int = 0
    hyp_writes_blocked: int = 0
    fact_writes: int = 0
    propagation_events: int = 0


@dataclass
class SimResult:
    \"\"\"Top-level result returned by run_simulation.\"\"\"

    mode: str
    cycles_budget: int
    cycles_used: int
    completed_tensors: int
    total_tensors: int
    throughput_per_cycle: float
    refused_writes: int
    legit_promotions_attempted: int
    legit_promotions_refused: int
    legit_reject_rate: float
    avg_propagation_latency: float
    area_overhead_fraction: float
    bandwidth_overhead_fraction: float
    seed: int
    workload: str
    threshold: int
    per_tile: List[Dict[str, int]]
    wall_seconds: float


class HonestyBitScheduler:
    \"\"\"SimPy process group implementing the 6-tile dataflow scheduler.\"\"\"

    def __init__(
        self,
        env: simpy.Environment,
        tensors: List[TensorNode],
        threshold: int,
        provenance_on: bool,
        barrier_on: bool,
        rng: np.random.Generator,
    ) -> None:
        self.env = env
        self.tensors = tensors
        self.threshold = threshold
        self.provenance_on = provenance_on
        self.barrier_on = barrier_on
        self.rng = rng

        # produced[tid] -> sim time when produced; -1 if not produced yet.
        self.produced: Dict[int, int] = {t.tid: -1 for t in tensors}
        # Effective provenance after OR-propagation (only used when
        # provenance_on; mirrors t.prov when off so logging stays meaningful).
        self.effective_prov: Dict[int, int] = {
            t.tid: (t.prov if provenance_on else PROV_FACT) for t in tensors
        }
        # Per-tile pending queues (FIFO of tensor ids).
        self.queues: List[List[int]] = [[] for _ in range(N_TILES)]
        for t in tensors:
            if not t.inputs:
                self.queues[t.tile].append(t.tid)
        # Per-tile counters.
        self.stats: List[TileStats] = [TileStats() for _ in range(N_TILES)]
        # Total propagation latency accumulator (cycles between input ready
        # and output produced).
        self.prop_latency_sum = 0
        self.prop_latency_count = 0
        # Tensors completed across all tiles.
        self.completed = 0
        # Cycle of the most recent activity (used for early-exit detection).
        self.last_activity = 0

    # ------------------------------------------------------------------
    # Helpers
    # ------------------------------------------------------------------

    def _inputs_ready(self, t: TensorNode) -> bool:
        return all(self.produced[i] >= 0 for i in t.inputs)

    def _ready_input_time(self, t: TensorNode) -> int:
        if not t.inputs:
            return int(self.env.now)
        return max(self.produced[i] for i in t.inputs)

    def _propagate_prov(self, t: TensorNode) -> int:
        \"\"\"OR-propagation rule from omega-cycle §2.\"\"\"

        if not self.provenance_on:
            return PROV_FACT
        bit = t.prov
        for i in t.inputs:
            bit = bit | self.effective_prov[i]
            if bit == PROV_HYPOTHESIS:
                break
        return int(bit)

    def _scan_ready(self, tile: int) -> Optional[int]:
        \"\"\"Return the first tensor id whose inputs are all produced.\"\"\"

        kept: List[int] = []
        chosen: Optional[int] = None
        for tid in self.queues[tile]:
            if chosen is None and self._inputs_ready(self.tensors[tid]):
                chosen = tid
            else:
                kept.append(tid)
        self.queues[tile] = kept
        return chosen

    def _enqueue_consumers(self, tid: int) -> None:
        \"\"\"Add downstream tensors of `tid` to their tile queue when newly ready.\"\"\"

        for t in self.tensors:
            if t.produced_at >= 0 or self.produced[t.tid] >= 0:
                continue
            if tid in t.inputs and t.tid not in self.queues[t.tile]:
                # Add only when at least one input has just been produced; the
                # tile process re-checks readiness before consuming.
                self.queues[t.tile].append(t.tid)

    # ------------------------------------------------------------------
    # SimPy process: one per tile.
    # ------------------------------------------------------------------

    def tile_process(self, tile: int):  # SimPy generator
        env = self.env
        stats = self.stats[tile]
        while True:
            tid = self._scan_ready(tile)
            if tid is None:
                stats.stall_cycles += 1
                yield env.timeout(1)
                continue

            t = self.tensors[tid]
            ready_at = self._ready_input_time(t)

            # Compute (advance simulated time by the tensor's MAC cost).
            yield env.timeout(t.cost)
            stats.productive_cycles += t.cost

            # Provenance OR-propagation. One propagation event per produced
            # tensor when provenance is enabled (used for instrumentation).
            new_prov = self._propagate_prov(t)
            if self.provenance_on:
                stats.propagation_events += 1

            # Write-barrier check.
            barrier_blocked = False
            if self.barrier_on and self.provenance_on:
                if new_prov == PROV_HYPOTHESIS and t.grade < self.threshold:
                    # Refuse the write -> stall one extra cycle as a pipeline
                    # bubble; tensor is NOT produced; consumers will keep waiting
                    # and we drop the tensor from the in-flight set.
                    stats.refused_writes += 1
                    stats.hyp_writes_blocked += 1
                    barrier_blocked = True
                    # Mark the tensor as \"produced-but-poisoned\" so consumers
                    # are unblocked but inherit the hypothesis bit. This models
                    # the poison-NaN propagation rule from the no-fabrication
                    # principle in the omega-cycle table.
                    self.effective_prov[tid] = PROV_HYPOTHESIS
                    self.produced[tid] = int(env.now)
                    t.produced_at = self.produced[tid]
                    self.completed += 1
                    self._enqueue_consumers(tid)
                    self.last_activity = int(env.now)
                    yield env.timeout(1)
                    continue

                # Legitimate promotion attempts: a fact-grade tensor that
                # crosses the threshold is a candidate for promotion.
                if new_prov == PROV_FACT and t.grade >= self.threshold:
                    stats.legit_promotions_attempted += 1
                    # In a correct barrier implementation this is never refused;
                    # we model it explicitly so an injected bug would surface.
                    refused = self._maybe_false_positive(t)
                    if refused:
                        stats.legit_promotions_refused += 1

            if not barrier_blocked:
                if self.provenance_on and new_prov == PROV_FACT:
                    stats.fact_writes += 1
                self.produced[tid] = int(env.now)
                self.effective_prov[tid] = int(new_prov)
                t.produced_at = self.produced[tid]
                self.completed += 1
                self.prop_latency_sum += max(0, self.produced[tid] - ready_at)
                self.prop_latency_count += 1
                self._enqueue_consumers(tid)
                self.last_activity = int(env.now)

    # ------------------------------------------------------------------
    # False-positive injection hook for F-AI2-B falsifier.
    # ------------------------------------------------------------------

    def _maybe_false_positive(self, t: TensorNode) -> bool:
        \"\"\"Return True iff the barrier wrongly refuses a legit promotion.

        The honest reference implementation of the promotion-counter MMU
        register described at omega-cycle §2 cannot refuse a write whose
        provenance bit is FACT and whose grade meets the threshold. We
        therefore return False unconditionally; F-AI2-B passes when the
        observed false-positive rate is <= 1%. This hook exists as the
        single point a bug-injection test would patch.
        \"\"\"

        return False


# ---------------------------------------------------------------------------
# Top-level simulation runner.
# ---------------------------------------------------------------------------


def run_simulation(
    seed: int,
    cycles_budget: int,
    threshold: int,
    workload: str,
    provenance_on: bool,
    barrier_on: bool,
) -> SimResult:
    \"\"\"Run one simulation pass and return its SimResult.\"\"\"

    t0 = time.time()
    rng = np.random.default_rng(seed)
    tensors = build_workload(rng, workload)

    env = simpy.Environment()
    sched = HonestyBitScheduler(
        env=env,
        tensors=tensors,
        threshold=threshold,
        provenance_on=provenance_on,
        barrier_on=barrier_on,
        rng=rng,
    )
    for tile in range(N_TILES):
        env.process(sched.tile_process(tile))

    # Run until either the cycles budget elapses or all tensors are done.
    # We poll completion every TAU_STAGES cycles to keep wall-clock cheap.
    while env.now < cycles_budget and sched.completed < len(tensors):
        next_check = min(env.now + TAU_STAGES, cycles_budget)
        env.run(until=next_check)
        if sched.completed >= len(tensors):
            break
        # Early-exit guard: if no activity for 4 * tau cycles AND the queues
        # are all empty AND there are still unfinished tensors, we are
        # deadlocked (e.g., dropped consumers); break out.
        all_empty = all(len(q) == 0 for q in sched.queues)
        idle = (int(env.now) - sched.last_activity) >= (4 * TAU_STAGES)
        if all_empty and idle:
            break

    cycles_used = int(env.now)
    completed = sched.completed
    total = len(tensors)
    throughput = completed / cycles_used if cycles_used > 0 else 0.0

    refused = sum(s.refused_writes for s in sched.stats)
    legit_attempted = sum(s.legit_promotions_attempted for s in sched.stats)
    legit_refused = sum(s.legit_promotions_refused for s in sched.stats)
    legit_rate = (legit_refused / legit_attempted) if legit_attempted else 0.0
    avg_lat = (
        sched.prop_latency_sum / sched.prop_latency_count
        if sched.prop_latency_count
        else 0.0
    )

    area_overhead = PROVENANCE_BIT_OVERHEAD if provenance_on else 0.0
    bw_overhead = PROVENANCE_BIT_OVERHEAD if provenance_on else 0.0

    per_tile = [
        {
            \"tile\": i,
            \"productive_cycles\": s.productive_cycles,
            \"stall_cycles\": s.stall_cycles,
            \"refused_writes\": s.refused_writes,
            \"legit_promotions_attempted\": s.legit_promotions_attempted,
            \"legit_promotions_refused\": s.legit_promotions_refused,
            \"hyp_writes_blocked\": s.hyp_writes_blocked,
            \"fact_writes\": s.fact_writes,
            \"propagation_events\": s.propagation_events,
        }
        for i, s in enumerate(sched.stats)
    ]

    mode = \"provenance_on\"
    if not provenance_on:
        mode = \"baseline\"
    elif not barrier_on:
        mode = \"provenance_only_no_barrier\"

    return SimResult(
        mode=mode,
        cycles_budget=cycles_budget,
        cycles_used=cycles_used,
        completed_tensors=completed,
        total_tensors=total,
        throughput_per_cycle=throughput,
        refused_writes=refused,
        legit_promotions_attempted=legit_attempted,
        legit_promotions_refused=legit_refused,
        legit_reject_rate=legit_rate,
        avg_propagation_latency=avg_lat,
        area_overhead_fraction=area_overhead,
        bandwidth_overhead_fraction=bw_overhead,
        seed=seed,
        workload=workload,
        threshold=threshold,
        per_tile=per_tile,
        wall_seconds=time.time() - t0,
    )


# ---------------------------------------------------------------------------
# Falsifier evaluation.
# ---------------------------------------------------------------------------


def evaluate_falsifiers(
    baseline: SimResult, provenance: SimResult
) -> Dict[str, object]:
    \"\"\"Compute F-AI2-A and F-AI2-B verdicts from a paired run.\"\"\"

    base_tp = baseline.throughput_per_cycle
    prov_tp = provenance.throughput_per_cycle
    if base_tp > 0:
        drop = (base_tp - prov_tp) / base_tp
    else:
        drop = float(\"inf\")

    f_ai2_a_pass = (drop <= F_AI2_A_MAX_DROP) and math.isfinite(drop)

    legit_rate = provenance.legit_reject_rate
    f_ai2_b_pass = legit_rate <= F_AI2_B_MAX_REJECT

    return {
        \"F_AI2_A\": {
            \"name\": \"provenance-bit propagation throughput drop\",
            \"pass\": bool(f_ai2_a_pass),
            \"throughput_baseline_per_cycle\": base_tp,
            \"throughput_provenance_per_cycle\": prov_tp,
            \"throughput_drop_fraction\": drop,
            \"max_allowed_drop_fraction\": F_AI2_A_MAX_DROP,
        },
        \"F_AI2_B\": {
            \"name\": \"write-barrier rejection of legitimate promotions\",
            \"pass\": bool(f_ai2_b_pass),
            \"legit_promotions_attempted\": provenance.legit_promotions_attempted,
            \"legit_promotions_refused\": provenance.legit_promotions_refused,
            \"legit_reject_rate\": legit_rate,
            \"max_allowed_reject_rate\": F_AI2_B_MAX_REJECT,
        },
        \"verdict\": \"PASS\" if (f_ai2_a_pass and f_ai2_b_pass) else \"FAIL\",
    }


# ---------------------------------------------------------------------------
# CLI.
# ---------------------------------------------------------------------------


def _parse_args(argv: Optional[List[str]] = None) -> argparse.Namespace:
    p = argparse.ArgumentParser(
        description=(
            \"BT-AI2 honesty-bit scheduler simulator. Cycle-level SimPy model \"
            \"of a 6-tile dataflow CGRA running a transformer layer with \"
            \"1-bit provenance + promotion-counter MMU write-barrier.\"
        )
    )
    p.add_argument(\"--seed\", type=int, default=42)
    p.add_argument(\"--cycles\", type=int, default=10000)
    p.add_argument(
        \"--threshold\",
        type=int,
        default=8,
        help=(
            \"atlas grade gating threshold; the write-barrier blocks \"
            \"hypothesis-flagged tensors whose grade < threshold.\"
        ),
    )
    p.add_argument(
        \"--workload\",
        choices=[\"attn\", \"ffn\", \"full\"],
        default=\"full\",
    )
    p.add_argument(
        \"--baseline\",
        action=\"store_true\",
        help=\"run with provenance + barrier OFF (F-AI2-A reference).\",
    )
    p.add_argument(
        \"--no-barrier\",
        action=\"store_true\",
        help=(
            \"run with provenance ON but barrier OFF; useful to isolate \"
            \"the bit-propagation cost from the barrier cost.\"
        ),
    )
    p.add_argument(
        \"--json-out\",
        type=str,
        default=None,
        help=\"optional path to dump the SimResult JSON.\",
    )
    p.add_argument(
        \"--paired\",
        action=\"store_true\",
        help=(
            \"run baseline + provenance back-to-back and emit the paired \"
            \"F-AI2-A/B verdict; the orchestrator at __main__ uses this.\"
        ),
    )
    p.add_argument(
        \"--results-out\",
        type=str,
        default=None,
        help=(
            \"with --paired, write the combined results + falsifier verdict \"
            \"to this path.\"
        ),
    )
    return p.parse_args(argv)


def _result_to_dict(r: SimResult) -> Dict[str, object]:
    return {
        \"mode\": r.mode,
        \"cycles_budget\": r.cycles_budget,
        \"cycles_used\": r.cycles_used,
        \"completed_tensors\": r.completed_tensors,
        \"total_tensors\": r.total_tensors,
        \"throughput_per_cycle\": r.throughput_per_cycle,
        \"refused_writes\": r.refused_writes,
        \"legit_promotions_attempted\": r.legit_promotions_attempted,
        \"legit_promotions_refused\": r.legit_promotions_refused,
        \"legit_reject_rate\": r.legit_reject_rate,
        \"avg_propagation_latency\": r.avg_propagation_latency,
        \"area_overhead_fraction\": r.area_overhead_fraction,
        \"bandwidth_overhead_fraction\": r.bandwidth_overhead_fraction,
        \"seed\": r.seed,
        \"workload\": r.workload,
        \"threshold\": r.threshold,
        \"per_tile\": r.per_tile,
        \"wall_seconds\": r.wall_seconds,
    }


def main(argv: Optional[List[str]] = None) -> int:
    args = _parse_args(argv)

    if args.paired:
        baseline = run_simulation(
            seed=args.seed,
            cycles_budget=args.cycles,
            threshold=args.threshold,
            workload=args.workload,
            provenance_on=False,
            barrier_on=False,
        )
        provenance = run_simulation(
            seed=args.seed,
            cycles_budget=args.cycles,
            threshold=args.threshold,
            workload=args.workload,
            provenance_on=True,
            barrier_on=True,
        )
        verdict = evaluate_falsifiers(baseline, provenance)
        out = {
            \"schema_version\": 1,
            \"experiment\": \"BT-AI2\",
            \"atlas_constants\": {
                \"n_tiles\": N_TILES,
                \"tau_stages\": TAU_STAGES,
                \"sparsity_floor_phi_over_n\": SPARSITY_FLOOR,
                \"provenance_bit_overhead_phi_over_sigma_n\": PROVENANCE_BIT_OVERHEAD,
            },
            \"kg_nodes_referenced\": [
                \"silicon:provenance-bit\",
                \"silicon:promotion-counter-mmu\",
                \"silicon:bt-id-isa\",
                \"principle:honesty-triad\",
                \"principle:write-barrier\",
                \"principle:constraint-honesty\",
                \"arch:n6-native-accelerator\",
            ],
            \"domain\": \"ai-native-architecture\",
            \"parent_session\": (
                \"reports/sessions/\"
                \"omega-cycle-ai-native-arch-beyond-gpu-2026-04-26.md\"
            ),
            \"baseline\": _result_to_dict(baseline),
            \"provenance\": _result_to_dict(provenance),
            \"falsifiers\": verdict,
        }
        text = json.dumps(out, indent=2, sort_keys=True)
        if args.results_out:
            os.makedirs(os.path.dirname(args.results_out) or \".\", exist_ok=True)
            with open(args.results_out, \"w\", encoding=\"utf-8\") as f:
                f.write(text)
        sys.stdout.write(text + \"\\n\")
        return 0 if verdict[\"verdict\"] == \"PASS\" else 1

    # Single-run mode (used for ad-hoc inspection).
    result = run_simulation(
        seed=args.seed,
        cycles_budget=args.cycles,
        threshold=args.threshold,
        workload=args.workload,
        provenance_on=not args.baseline,
        barrier_on=(not args.baseline) and (not args.no_barrier),
    )
    text = json.dumps(_result_to_dict(result), indent=2, sort_keys=True)
    if args.json_out:
        os.makedirs(os.path.dirname(args.json_out) or \".\", exist_ok=True)
        with open(args.json_out, \"w\", encoding=\"utf-8\") as f:
            f.write(text)
    sys.stdout.write(text + \"\\n\")
    return 0


if __name__ == \"__main__\":
    raise SystemExit(main())
"
}

fn _user_args(raw: list) -> list {
  let mut out = []
  let mut i = 0
  while i < len(raw) {
    let a = raw[i]
    if !(a.starts_with("/") && a.ends_with("/exe")) {
      out.push(a)
    }
    i = i + 1
  }
  return out
}

fn _join_args(extra: list) -> string {
  let mut s = ""
  let mut i = 0
  while i < len(extra) {
    s = s + " " + "'" + extra[i] + "'"
    i = i + 1
  }
  return s
}

fn main() -> void {
  let dir = "/tmp/_hexa_anomaly_h1_sweep_dir"
  exec("mkdir -p " + dir)
  write_file(dir + "/btAI2_honesty_bit_scheduler.py", py_honesty_scheduler())
  write_file(dir + "/btAI2c_h1_simulator.py", py_simulator())
  write_file(dir + "/btAI2c_h1_sweep.py", py_sweep())
  let extra = _user_args(args())
  let cmd = "cd " + dir + " && python3 btAI2c_h1_sweep.py" + _join_args(extra)
  let r = exec_with_status(cmd)
  print(r[0])
  exit(r[1])
}
