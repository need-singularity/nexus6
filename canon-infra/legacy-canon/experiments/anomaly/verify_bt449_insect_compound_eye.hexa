// verify_bt449_insect_compound_eye.hexa
// 카테고리: anomaly
// 목적: BT-449 곤충 복안 ommatidium 6각 최적 패킹 검증
// 근거: 초파리 ~800 ommatidia, 6각 격자 면적 효율
// 가설: 6각 패킹 효율 pi/(2*sqrt(3)) ~ 0.9069
// 지표: ommatidia 수, 충진 밀도, 각해상
// 데이터: Drosophila 시각계 연구

fn main() {
    println("[BT-449 곤충 복안] 6각 ommatidium — 산술 검증")
    let sqrt3: f64 = 1.73205080757
    let pi: f64 = 3.14159265358979

    let drosophila_count: i64 = 800
    let bee_count: i64 = 6300
    let dragonfly_count: i64 = 30000

    // 6각 충진 밀도
    let hex_density: f64 = pi / (2.0 * sqrt3)   // 0.9069
    // 사각 충진 밀도
    let sq_density: f64 = pi / 4.0              // 0.7854

    // 각해상 ~ 1/sqrt(N)
    let res_dro: f64 = 1.0 / 28.0               // 1/sqrt(800)
    let res_bee: f64 = 1.0 / 79.0               // 1/sqrt(6300)

    println("초파리 ommatidia = " + to_string(drosophila_count))
    println("꿀벌 ommatidia = " + to_string(bee_count))
    println("6각 밀도 = " + to_string(hex_density))
    println("사각 밀도 = " + to_string(sq_density))
    println("꿀벌 각해상 ~ " + to_string(res_bee))

    let mut pass: i64 = 0
    if hex_density > sq_density { pass = pass + 1 }
    if hex_density > 0.9 && hex_density < 0.91 { pass = pass + 1 }
    if res_bee < res_dro { pass = pass + 1 }

    if pass == 3 {
        println("[상태] pass — 복안 6각 패킹 최적")
    } else {
        println("[상태] fail — " + to_string(pass) + "/3")
    }
}
