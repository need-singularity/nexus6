# ────────────────────────────────────────────────────────────
# Phase 34 — must_fail ↔ expected pair consistency.
#   run_proof_obligations 의 판정 로직:
#     must_fail=true  → result 가 비어있거나 "0"/"false" 면 green (expected
#                        는 참조되지 않음 — 비어있어야 정상)
#     must_fail=false → result == expected 이면 green (expected 이 비어있
#                        으면 의미없는 비교 — 항상 "" 와 match)
#   두 대조 값이 엇나가면 config 는 정적으로는 통과하지만 의미상으론 dead
#   하거나 misleading 하다. Gate 로 예방.
#   Rules:
#     must_fail=true  AND expected≠""   → flagged (dead expected)
#     must_fail=false AND expected==""  → flagged (vacuous compare)
#   claim: scanners/44_must_fail_expected_pair.claim.json
# ────────────────────────────────────────────────────────────
scan_must_fail_expected_pair() {
  local out="reports/n6_must_fail_expected_pair.json"
  local total=0 flag_count=0 entries="" first=1
  for f in scanners/*.claim.json; do
    [ -f "$f" ] || continue
    total=$((total+1))
    local mf exp base reason=""
    base=$(basename "$f")
    mf=$(jq -r '.must_fail // false' "$f")
    exp=$(jq -r '.expected // ""' "$f")
    if [ "$mf" = "true" ] && [ -n "$exp" ] && [ "$exp" != "null" ]; then
      reason="must_fail_true_with_nonempty_expected"
    elif [ "$mf" = "false" ] && { [ -z "$exp" ] || [ "$exp" = "null" ]; }; then
      reason="must_fail_false_with_empty_expected"
    fi
    if [ -n "$reason" ]; then
      flag_count=$((flag_count+1))
      [ $first -eq 0 ] && entries="${entries},"
      entries="${entries}{\"file\":\"${base}\",\"must_fail\":${mf},\"expected\":\"${exp}\",\"reason\":\"${reason}\"}"
      first=0
    fi
  done
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_must_fail_expected_pair/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "total_claims": $total,
  "flagged_count": $flag_count,
  "flagged": [$entries],
  "rules": [
    "must_fail=true  AND expected!=\"\" → dead config (expected is unused)",
    "must_fail=false AND expected==\"\" → vacuous compare (always matches empty)"
  ],
  "note": "Phase 34 — run_proof_obligations evaluates the two fields as a pair. Mismatches pass structural/enum gates but are semantically broken. Gate: flagged_count == 0.",
  "status": "$([ $flag_count -eq 0 ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (total=$total flagged=$flag_count)"
}

