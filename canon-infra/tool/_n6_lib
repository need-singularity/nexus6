#   scan_engine_integrity():
#     매니페스트(config/engine_manifest.json)와 실제 구현의 일치 여부 검증.
#       - rule 1: phases live 개수 == tool/_n6_lib 의 "Phase <N>" 헤더 수
#       - rule 2: scanner_registry 에 나열된 이름이 dispatcher case 에 존재
#       - rule 3: claims_total == scanners/*.claim.json 실제 파일 수
#       - rule 4 (Phase 18): dispatcher primary case 가 registry 에 존재
#                             (역방향 완전성, built-in non-scanner 제외)
#     불일치 시 drift 로 기록.
#   append_audit_trail():
#     reports/n6_meta_audit.jsonl 에 현재 실행의 한 줄 스냅샷 append.
#     (ts / engine_version / head_sha / health / proof / selftest / blockers)
# ────────────────────────────────────────────────────────────
scan_engine_integrity() {
  local out="reports/n6_engine_integrity.json"
  local mf="config/engine_manifest.json"
  local drifts="["
  local first=1
  local drift_count=0
  _idrift() {
    [ $first -eq 0 ] && drifts="${drifts},"
    drifts="${drifts}{\"rule\":\"$1\",\"manifest\":$2,\"actual\":$3}"
    first=0
    drift_count=$((drift_count+1))
  }

  # rule 1: phases.live vs "Phase N" 주석 카운트
  local phases_live
  phases_live=$(jq -r '[.phases[] | select(.state=="live")] | length' "$mf" 2>/dev/null)
  local phase_headers
  phase_headers=$(grep -cE "^# Phase [0-9]+" tool/_n6_lib | head -1)
  # 주석이 각 Phase 별로 여러 줄 있을 수 있으니, '# Phase <N>' 고유 N 수로 측정
  local phase_ids
  phase_ids=$(grep -oE "# Phase [0-9]+" tool/_n6_lib | sort -u | wc -l | tr -d ' ')
  [ "$phase_ids" != "$phases_live" ] && _idrift "phases.live_vs_source" "$phases_live" "$phase_ids"

  # rule 2: scanner_registry 이름들이 dispatcher 에 존재
  local missing_dispatch=0
  local all_names
  all_names=$(jq -r '.scanner_registry.time_invariant + .scanner_registry.time_dependent + .scanner_registry.meta | .[]' "$mf" 2>/dev/null)
  while IFS= read -r n; do
    [ -z "$n" ] && continue
    # dispatcher case 체크: "  <name>)" 또는 "|<name>)" 이 존재
    grep -qE "(^|[|\( ])${n}(\||\))" tool/_n6_lib || missing_dispatch=$((missing_dispatch+1))
  done <<EOF_NAMES
$all_names
EOF_NAMES
  [ "$missing_dispatch" -gt 0 ] && _idrift "scanner_registry.dispatch_missing" "0" "$missing_dispatch"

  # rule 3: claims_total (매니페스트 manifest report 에 기록된 값) == 실제 파일 수
  local claims_declared
  claims_declared=$(jq -r '.claims_total // 0' reports/n6_manifest.json 2>/dev/null)
  local claims_actual
  claims_actual=$(ls scanners/*.claim.json 2>/dev/null | wc -l | tr -d ' ')
  [ "$claims_declared" != "$claims_actual" ] && _idrift "claims.declared_vs_actual" "$claims_declared" "$claims_actual"

  # Phase 18 — rule 4: dispatcher reverse completeness.
  # 디스패처의 primary case 이름(첫 alternative)이 scanner_registry 어디에도
  # 없으면 orphan. 단 built-in non-scanner 는 제외 (continuous-scan, fast,
  # telemetry — high-level commands, 개별 scanner 가 아님).
  local dispatcher_orphans=0
  local orphan_list=""
  local registry_all
  registry_all=$(jq -r '.scanner_registry.time_invariant + .scanner_registry.time_dependent + .scanner_registry.meta | .[]' "$mf" 2>/dev/null | sort -u)
  # primary case 이름만 추출 (`  <name>)` 또는 `  <name>|...)` 형태)
  local primary_cases
  primary_cases=$(grep -oE '^  [a-z][a-z_-]*(\||\))' tool/_n6_lib | sed -E 's/^  //; s/[|)]$//' | sort -u)
  local builtin_exclude="continuous-scan fast telemetry"
  while IFS= read -r pc; do
    [ -z "$pc" ] && continue
    # built-in 제외
    case " $builtin_exclude " in *" $pc "*) continue;; esac
    # registry 에 존재?
    echo "$registry_all" | grep -qxF "$pc" && continue
    dispatcher_orphans=$((dispatcher_orphans+1))
    orphan_list="${orphan_list}${pc} "
  done <<< "$primary_cases"
  [ "$dispatcher_orphans" -gt 0 ] && _idrift "dispatcher.orphan_cases" "\"in_registry\"" "\"${orphan_list% }\""

  drifts="${drifts}]"
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_engine_integrity/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "checks": {
    "phases_live_declared": $phases_live,
    "phases_live_in_source": $phase_ids,
    "scanner_dispatch_missing": $missing_dispatch,
    "claims_declared": $claims_declared,
    "claims_actual": $claims_actual,
    "dispatcher_orphans": $dispatcher_orphans
  },
  "drift_count": $drift_count,
  "drifts": $drifts,
  "status": "$([ $drift_count -eq 0 ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (drift=$drift_count)"
}

# ────────────────────────────────────────────────────────────
# Phase 20 — engine source-hash stamp (tamper-evidence ceremony)
#   sha256(tool/_n6_lib) 을 manifest 의 engine.source_hash 에 stamp.
#   scan_engine_hash 은 현재 sha 와 stamp 을 비교하여 일치 확인.
#   엔진 변경이 있을 때마다 의도적으로 stamp 을 갱신 (commit ceremony).
#   claim: scanners/30_engine_source_hash_matches.claim.json
# ────────────────────────────────────────────────────────────
scan_engine_hash() {
  local out="reports/n6_engine_hash.json"
  local mf="config/engine_manifest.json"
  local actual stamped matches
  if [ -f tool/_n6_lib ]; then
    actual=$(shasum -a 256 tool/_n6_lib 2>/dev/null | awk '{print $1}')
  fi
  actual="${actual:-unknown}"
  stamped=$(jq -r '.engine.source_hash // "unstamped"' "$mf" 2>/dev/null)
  stamped="${stamped:-unstamped}"
  if [ "$actual" = "$stamped" ]; then matches="true"; else matches="false"; fi
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_engine_hash/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "source_file": "tool/_n6_lib",
  "actual_sha256": "$actual",
  "stamped_sha256": "$stamped",
  "matches": $matches,
  "status": "$([ "$matches" = "true" ] && echo GREEN || echo AMBER)",
  "note": "If matches=false, either (a) engine was intentionally modified — rotate manifest.engine.source_hash to the current sha OR (b) tamper detected — investigate diff."
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (matches=$matches)"
}

# ────────────────────────────────────────────────────────────
# Phase 21 — audit trail retention (rotation + claim).
#   audit jsonl 이 MAX (기본 1000) 을 넘으면 가장 오래된 (count-KEEP) 줄을
#   reports/history/audit_archive_YYYY-MM-DD.jsonl 로 append 하고 main 에는
#   최신 KEEP 줄만 남긴다. 방어적으로만 동작 — MAX 이하일 때 no-op.
#   claim: scanners/31_audit_retention_bounded.claim.json
# ────────────────────────────────────────────────────────────
scan_audit_retention() {
  local out="reports/n6_audit_retention.json"
  local src="reports/n6_meta_audit.jsonl"
  local max="${N6_AUDIT_MAX:-1000}"
  local keep="${N6_AUDIT_KEEP:-500}"
  local entries=0 archived=0 kept=0
  local archive_path="(none)"
  if [ -s "$src" ]; then
    entries=$(wc -l < "$src" | tr -d ' ')
    if [ "$entries" -gt "$max" ]; then
      local today
      today=$(date -u +%Y-%m-%d)
      archive_path="reports/history/audit_archive_${today}.jsonl"
      mkdir -p reports/history
      local cutoff=$(( entries - keep ))
      head -n "$cutoff" "$src" >>"$archive_path"
      tail -n "$keep" "$src" >"${src}.tmp" && mv "${src}.tmp" "$src"
      archived=$cutoff
      kept=$keep
    else
      kept=$entries
    fi
  fi
  local within_bound
  [ "$kept" -le "$max" ] && within_bound="true" || within_bound="false"
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_audit_retention/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "source": "$src",
  "max_entries": $max,
  "keep_after_rotation": $keep,
  "entries_before": $entries,
  "entries_archived_this_run": $archived,
  "entries_in_main_after": $kept,
  "archive_path": "$archive_path",
  "within_bound": $within_bound,
  "status": "$([ "$within_bound" = "true" ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (kept=$kept, archived_this_run=$archived)"
}

# ────────────────────────────────────────────────────────────
# Phase 22 — reports emitter registry (orphan detection).
#   reports/n6_*.json 을 그리고 tool/_n6_lib 의 emit 패턴을 대조해 orphan
#   (emitter 가 없는 리포트) 을 찾는다. 다음 두 경로 인정:
#     (a) `out="reports/n6_<name>.json"` 패턴으로 쓰는 함수
#     (b) 직접 write 하는 emit (health → reports/n6_health.json)
#   (a)(b) 어디에도 없으면 legacy allowlist (LEGACY_REPORTS) 로 관용.
#   claim: scanners/32_reports_no_orphans.claim.json
# ────────────────────────────────────────────────────────────
scan_emitter_registry() {
  local out="reports/n6_emitter_registry.json"
  # a: out= 패턴
  local emitters_declared
  emitters_declared=$(grep -oE 'out="reports/n6_[a-z_]+\.json"' tool/_n6_lib \
    | awk -F'"' '{print $2}' | sed 's|^reports/||' | sort -u)
  # b: direct writer — health() 가 유일
  local direct_writers="n6_health.json"
  # legacy allowlist — 과거 ad-hoc 리포트 (tool 이 쓰지 않음)
  local legacy_allowlist="n6_loss_free_roi_audit.json"
  # 실제 파일 목록
  local actual
  actual=$(ls reports/n6_*.json 2>/dev/null | xargs -n1 basename | sort -u)
  # orphan = actual - (emitters + direct + legacy)
  local orphans=""
  local orphan_count=0
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    echo "$emitters_declared" | grep -qxF "$f" && continue
    echo "$direct_writers" | tr ' ' '\n' | grep -qxF "$f" && continue
    echo "$legacy_allowlist" | tr ' ' '\n' | grep -qxF "$f" && continue
    orphans="${orphans}${f} "
    orphan_count=$((orphan_count+1))
  done <<< "$actual"
  local emitter_count
  emitter_count=$(echo "$emitters_declared" | grep -c . | tr -d ' ')
  local actual_count
  actual_count=$(echo "$actual" | grep -c . | tr -d ' ')
  # jq-encode orphan list
  local orphans_json
  orphans_json=$(echo "$orphans" | tr ' ' '\n' | grep -v '^$' | jq -R -s -c 'split("\n") | map(select(length>0))')
  orphans_json="${orphans_json:-[]}"
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_emitter_registry/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "emitters_declared_count": $emitter_count,
  "direct_writers": ["$direct_writers"],
  "legacy_allowlist": ["$legacy_allowlist"],
  "reports_actual_count": $actual_count,
  "orphan_count": $orphan_count,
  "orphans": $orphans_json,
  "status": "$([ "$orphan_count" -eq 0 ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (orphans=$orphan_count, actual=$actual_count)"
}

# ────────────────────────────────────────────────────────────
# Phase 23 — claim effectiveness (observe-only).
#   Phase 16 이 append_audit_trail 에 red_claims[] / fail_scanners[] identity
#   를 기록하기 시작한 덕분에, 이제 "한 번도 울리지 않은 알람" 을 식별할 수 있다.
#   각 scanners/*.claim.json 에 대해 audit jsonl window 안의 fail_count 를 집계.
#   fail_count == 0 인 claim 은 silent — 아직 효과가 관측된 적 없다는 뜻.
#   이 phase 는 지표만 emit 하고 gate 하지 않는다 (retention window 가 신뢰
#   가능한 수준까지 누적되어야 silence ⇒ ineffective 추론이 가능).
#   claim: scanners/33_claim_effectiveness_observed.claim.json
# ────────────────────────────────────────────────────────────
scan_claim_effectiveness() {
  local out="reports/n6_claim_effectiveness.json"
  local src="reports/n6_meta_audit.jsonl"
  local total_entries=0
  [ -s "$src" ] && total_entries=$(wc -l < "$src" | tr -d ' ')
  local claim_fail_map="{}"
  if [ "$total_entries" -gt 0 ]; then
    claim_fail_map=$(jq -c -s '[.[].proof.red_claims // [] | .[]] | group_by(.) | map({(.[0]): length}) | add // {}' "$src" 2>/dev/null)
  fi
  [ -z "$claim_fail_map" ] && claim_fail_map="{}"
  local claims_json
  claims_json=$(
    for f in scanners/*.claim.json; do
      [ -f "$f" ] || continue
      local base cid fc
      base=$(basename "$f")
      cid=$(jq -r '.id // ""' "$f")
      fc=$(echo "$claim_fail_map" | jq -r --arg k "$base" '.[$k] // 0')
      printf '{"file":"%s","id":"%s","fail_count":%s}\n' "$base" "$cid" "$fc"
    done | jq -s -c '.'
  )
  [ -z "$claims_json" ] && claims_json="[]"
  local claims_total silent_count
  claims_total=$(echo "$claims_json" | jq 'length')
  silent_count=$(echo "$claims_json" | jq '[.[] | select(.fail_count == 0)] | length')
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_claim_effectiveness/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "audit_source": "$src",
  "audit_entries_scanned": $total_entries,
  "claims_total": $claims_total,
  "claims_silent_count": $silent_count,
  "claims": $claims_json,
  "note": "Observe-only (P23). fail_count=0 means the claim has not flagged any run in the retained audit trail window. Do NOT prune silent claims until the window is long enough to trust silence ⇒ ineffective.",
  "status": "GREEN"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (claims=$claims_total silent=$silent_count entries=$total_entries)"
}

# ────────────────────────────────────────────────────────────
# Phase 24 — reverse coverage map (observe-only, dual of P18).
#   P18 이 "dispatcher → scanner" orphan (선언됐지만 연결 안 된 scanner) 을
#   잡았다면, 이번엔 그 역 — 어떤 scanner 도 읽지 않는 canonical 소스 디렉토리
#   (repo 에는 있지만 어떤 scan 함수 본문에서도 이름조차 언급되지 않는 dir).
#   이런 dir 은 내용이 drift 해도 meta-engine 이 알아차리지 못한다.
#   Observe-only — 지금은 unobserved_count 만 emit 하고 gate 하지 않는다.
#   실질적 커버리지(의미 기반)가 아닌 "이름 참조 존재 여부"만 본다; 정적 proxy.
#   claim: scanners/34_coverage_map_observed.claim.json
# ────────────────────────────────────────────────────────────
scan_coverage_map() {
  local out="reports/n6_coverage_map.json"
  local must_observe=(atlas engine scanners tool config domains papers techniques experiments theory bridge calc)
  local total=${#must_observe[@]}
  local observed_count=0
  local unobserved=""
  local entries=""
  local first=1
  # Reference source = tool/_n6_lib with scan_coverage_map's own body
  # stripped (its must_observe array mentions every dir by definition).
  local corpus
  corpus=$(awk '/^scan_coverage_map\(\) \{/{skip=1} skip && /^\}$/{skip=0; next} !skip' tool/_n6_lib)
  for d in "${must_observe[@]}"; do
    [ -d "$d" ] || continue
    local refs file_count st
    refs=$(printf '%s\n' "$corpus" | grep -cw "$d" 2>/dev/null || true)
    file_count=$(find "$d" -type f 2>/dev/null | wc -l | tr -d ' ')
    if [ "${refs:-0}" -gt 0 ]; then
      observed_count=$((observed_count+1)); st="observed"
    else
      unobserved="${unobserved}${d} "; st="unobserved"
    fi
    [ $first -eq 0 ] && entries="${entries},"
    entries="${entries}{\"dir\":\"${d}\",\"references\":${refs:-0},\"files\":${file_count},\"status\":\"${st}\"}"
    first=0
  done
  local unobserved_count=$((total - observed_count))
  local unobserved_json
  unobserved_json=$(echo "$unobserved" | tr ' ' '\n' | grep -v '^$' | jq -R -s -c 'split("\n") | map(select(length>0))')
  unobserved_json="${unobserved_json:-[]}"
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_coverage_map/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "must_observe_count": $total,
  "observed_count": $observed_count,
  "unobserved_count": $unobserved_count,
  "unobserved": $unobserved_json,
  "dirs": [$entries],
  "note": "Observe-only (P24). Static proxy: a dir is 'observed' iff its bare name appears as a word in tool/_n6_lib. references=0 means no scan function mentions the dir, so content drift there goes unnoticed. Not a semantic coverage check — only name-reference presence.",
  "status": "GREEN"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (observed=$observed_count/$total unobserved=$unobserved_count)"
}

# ────────────────────────────────────────────────────────────
# Phase 25 — unobserved-dir inventory (closes P24's open finding).
#   P24 가 "어떤 scanner 도 이름조차 언급 않는 canonical dir" 로 theory/ ·
#   bridge/ · calc/ 3개를 뽑았다. 이 phase 는 해당 3개에 대해 최소 inventory
#   (file count / total bytes / newest mtime) 를 emit — 즉 내용 자체를 깊이
#   검증하지는 않지만 이름을 참조함으로써 (a) P24 unobserved_count=0 으로
#   수렴, (b) 다음 run 에서 파일 수나 최신 mtime 급변(=content drift) 이
#   관측 가능한 표면이 된다.
#   claim: scanners/35_unobserved_inventory.claim.json
# ────────────────────────────────────────────────────────────
scan_dir_inventory() {
  local out="reports/n6_dir_inventory.json"
  # Dirs that P24 flagged as unobserved (bridge/theory/calc). Listing them
  # here also makes them referenced for P24's name-proxy heuristic.
  local watched=(theory bridge calc)
  local entries="" first=1 grand_files=0 grand_bytes=0
  for d in "${watched[@]}"; do
    [ -d "$d" ] || continue
    local files bytes newest
    files=$(find "$d" -type f 2>/dev/null | wc -l | tr -d ' ')
    bytes=$(find "$d" -type f -exec stat -f '%z' {} + 2>/dev/null | awk '{s+=$1} END{print s+0}')
    newest=$(find "$d" -type f -exec stat -f '%m' {} + 2>/dev/null | sort -n | tail -1)
    newest="${newest:-0}"
    grand_files=$((grand_files + files))
    grand_bytes=$((grand_bytes + bytes))
    [ $first -eq 0 ] && entries="${entries},"
    entries="${entries}{\"dir\":\"${d}\",\"files\":${files},\"bytes\":${bytes},\"newest_mtime\":${newest}}"
    first=0
  done
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_dir_inventory/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "watched": $(printf '%s\n' "${watched[@]}" | jq -R -s -c 'split("\n") | map(select(length>0))'),
  "dirs": [$entries],
  "grand_files": $grand_files,
  "grand_bytes": $grand_bytes,
  "note": "Phase 25 — minimal inventory for dirs that P24 flagged unobserved. Not a semantic check; a baseline surface so future drift (sudden file-count or mtime shift) is at least visible. Pairs with P24 to close the coverage gap it opened.",
  "status": "GREEN"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (dirs=${#watched[@]} files=$grand_files bytes=$grand_bytes)"
}

# ────────────────────────────────────────────────────────────
# Phase 26 — emission completeness (dual of P22 orphan).
#   P22 는 emitter 없는 reports/n6_*.json (orphan) 을 잡았다. 그 역 —
#   tool/_n6_lib 안에 out="reports/n6_<name>.json" 패턴으로 선언됐지만
#   실제 파일이 존재하지 않는 emitter. scan 함수가 runtime 중간에 죽어
#   출력이 안 나온 경우 (예: P24 구현 중 내가 직접 겪은 set -e 탈출)
#   를 탐지한다. P22 가 "고아 산출물" 이라면 P26 은 "유산이 없는 산모".
#   Gate on: missing_count == 0 (실제 gating).
#   claim: scanners/36_emission_completeness.claim.json
# ────────────────────────────────────────────────────────────
scan_emission_completeness() {
  local out="reports/n6_emission_completeness.json"
  local declared
  # Exclude self: this scanner's own output is written AFTER the check below,
  # so without the grep -v it would always report missing=1 for itself.
  declared=$(grep -oE 'out="reports/n6_[a-z_]+\.json"' tool/_n6_lib | awk -F'"' '{print $2}' | grep -vx "$out" | sort -u)
  local total=0 present=0 missing_count=0 missing=""
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    total=$((total+1))
    if [ -f "$f" ]; then
      present=$((present+1))
    else
      missing="${missing}${f} "
      missing_count=$((missing_count+1))
    fi
  done <<< "$declared"
  local missing_json
  missing_json=$(echo "$missing" | tr ' ' '\n' | grep -v '^$' | jq -R -s -c 'split("\n") | map(select(length>0))')
  missing_json="${missing_json:-[]}"
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_emission_completeness/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "declared_emitter_count": $total,
  "present_count": $present,
  "missing_count": $missing_count,
  "missing": $missing_json,
  "note": "Phase 26 — dual of P22. Declared emitter (out=reports/n6_<name>.json pattern) whose output file is absent signals a scan function that silently died mid-run (common: set -e triggered on zero-match grep exit=1) or that the dispatcher never called it this cycle. missing_count>0 is AMBER — investigate immediately.",
  "status": "$([ $missing_count -eq 0 ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (declared=$total present=$present missing=$missing_count)"
}

# ────────────────────────────────────────────────────────────
# Phase 27 — claim cmd purity.
#   Proof obligation 의 verdict 는 "같은 repo state → 같은 결과" 라는 재현성
#   가정 위에 서 있다. 그러나 actual_cmd 가 wall-clock (date), network
#   (curl/wget/http), PID ($$), random ($RANDOM), shared mutable fs (/tmp),
#   환경 고유 절대경로 (/Users/, /home/) 에 의존하면 그 가정이 깨진다 —
#   같은 HEAD 에서도 run 마다 verdict 가 달라질 수 있다. Static pattern
#   scan 으로 이런 의존성을 잡고 gate (flagged_count == 0).
#   claim: scanners/37_claim_cmd_purity.claim.json
# ────────────────────────────────────────────────────────────
scan_claim_cmd_purity() {
  local out="reports/n6_claim_purity.json"
  local total=0 flag_count=0 entries="" first=1
  for f in scanners/*.claim.json; do
    [ -f "$f" ] || continue
    total=$((total+1))
    local cmd flags base
    base=$(basename "$f")
    cmd=$(jq -r '.actual_cmd // .actual // ""' "$f")
    flags=""
    echo "$cmd" | grep -qE '\bdate\b'                    && flags="${flags}date "
    echo "$cmd" | grep -qE '\bcurl\b|\bwget\b|https?://' && flags="${flags}network "
    echo "$cmd" | grep -qE '\$RANDOM'                    && flags="${flags}random "
    echo "$cmd" | grep -qE '\$\$'                        && flags="${flags}pid "
    echo "$cmd" | grep -qE '/tmp/'                       && flags="${flags}tmp "
    echo "$cmd" | grep -qE '/Users/|/home/'              && flags="${flags}abspath "
    if [ -n "$flags" ]; then
      flag_count=$((flag_count+1))
      [ $first -eq 0 ] && entries="${entries},"
      entries="${entries}{\"file\":\"${base}\",\"flags\":\"${flags% }\"}"
      first=0
    fi
  done
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_claim_purity/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "total_claims": $total,
  "flagged_count": $flag_count,
  "flagged": [$entries],
  "patterns_checked": ["date", "network(curl/wget/http)", "random(\$RANDOM)", "pid(\$\$)", "tmp(/tmp/)", "abspath(/Users/|/home/)"],
  "note": "Phase 27 — each claim's actual_cmd must be a pure function of repo state so that verdicts are reproducible. Patterns above mark dependence on wall clock, network, PID, random, mutable shared fs, or env-specific abs path — each breaks 'same HEAD → same verdict'. Gating: flagged_count must be 0.",
  "status": "$([ $flag_count -eq 0 ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (total=$total flagged=$flag_count)"
}

# ────────────────────────────────────────────────────────────
# Phase 28 — claim meta hygiene (owner enum + proposal_ref pattern).
#   P17 은 required 필드의 presence 만 보장한다. 값 자체가 drift 하면 감사
#   체계가 조용히 오염된다 — 예: owner 가 오타 ("meta_engine" vs
#   "meta-engine") 로 팀 할당이 바뀐 것처럼 보임. P28 은 값 레벨 검증:
#     owner        ∈ known enum (현재 9개 팀/모듈)
#     proposal_ref ∈ {null, "phase-<n>-<slug>", "n6a-<YYYYMMDD>-<NNN>"}
#   Gate: flagged_count == 0. 새 owner 나 새 proposal scheme 이 필요하면
#   이 함수의 allowlist 를 먼저 확장하는 ceremony 가 강제된다.
#   claim: scanners/38_claim_meta_hygiene.claim.json
# ────────────────────────────────────────────────────────────
scan_claim_meta_hygiene() {
  local out="reports/n6_claim_meta_hygiene.json"
  local allowed_owners="meta-engine arithmetic_core atlas_team discovery engine infra publish techniques_team verify"
  local ref_pattern='^(phase-[0-9]+-[a-z0-9-]+|n6a-[0-9]{8}-[0-9]{3})$'
  local total=0 flag_count=0 entries="" first=1
  for f in scanners/*.claim.json; do
    [ -f "$f" ] || continue
    total=$((total+1))
    local owner ref base reasons
    base=$(basename "$f")
    owner=$(jq -r '.owner // ""' "$f")
    ref=$(jq -r '.proposal_ref // ""' "$f")
    reasons=""
    if ! echo " $allowed_owners " | grep -qE " ${owner} " 2>/dev/null; then
      reasons="${reasons}owner_unknown(${owner}) "
    fi
    if [ -n "$ref" ] && ! echo "$ref" | grep -qE "$ref_pattern" 2>/dev/null; then
      reasons="${reasons}ref_malformed(${ref}) "
    fi
    if [ -n "$reasons" ]; then
      flag_count=$((flag_count+1))
      [ $first -eq 0 ] && entries="${entries},"
      entries="${entries}{\"file\":\"${base}\",\"reasons\":\"${reasons% }\"}"
      first=0
    fi
  done
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_claim_meta_hygiene/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "total_claims": $total,
  "flagged_count": $flag_count,
  "flagged": [$entries],
  "allowed_owners": "$allowed_owners",
  "proposal_ref_pattern": "$ref_pattern",
  "note": "Phase 28 — value-level hygiene for claim metadata. P17 checks presence; P28 checks validity. Extending either allowlist (new team or new proposal scheme) is a deliberate ceremony — update this function, not an individual claim, so drift can't creep in.",
  "status": "$([ $flag_count -eq 0 ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (total=$total flagged=$flag_count)"
}

# ────────────────────────────────────────────────────────────
# Phase 29 — manifest phase id monotonicity.
#   config/engine_manifest.json 의 phases[].id 는 P1, P2, ..., Pn 으로
#   gap 없이 단조 증가해야 한다. append-only 라는 진화 모델의 구조적 불변.
#   gap 이 생기면 "P27 이 빠지고 P28 이 있다" 같은 상태가 생길 수 있는데,
#   이는 phase history 가 실제 commit 히스토리와 어긋난다는 신호.
#   Gate: gap_count == 0 AND out_of_order_count == 0.
#   claim: scanners/39_manifest_phase_monotonic.claim.json
# ────────────────────────────────────────────────────────────
scan_manifest_phase_monotonic() {
  local out="reports/n6_manifest_phase_monotonic.json"
  local mf="config/engine_manifest.json"
  local total gaps="" gap_count=0 ooo="" ooo_count=0 prev=0
  local ids
  ids=$(jq -r '.phases[].id' "$mf" 2>/dev/null)
  total=$(echo "$ids" | grep -c . | tr -d ' ')
  local expected=1
  while IFS= read -r id; do
    [ -z "$id" ] && continue
    local n
    n=$(echo "$id" | sed -E 's/^P([0-9]+)$/\1/')
    if ! [[ "$n" =~ ^[0-9]+$ ]]; then
      ooo="${ooo}${id} "
      ooo_count=$((ooo_count+1))
      continue
    fi
    if [ "$n" -ne "$expected" ]; then
      # Either a gap (n > expected) or out-of-order (n < expected or equal-to-prev)
      if [ "$n" -gt "$expected" ]; then
        local miss=$expected
        while [ "$miss" -lt "$n" ]; do
          gaps="${gaps}P${miss} "
          gap_count=$((gap_count+1))
          miss=$((miss+1))
        done
      else
        ooo="${ooo}${id} "
        ooo_count=$((ooo_count+1))
      fi
    fi
    expected=$((n+1))
    prev=$n
  done <<< "$ids"
  local gaps_json ooo_json
  gaps_json=$(echo "$gaps" | tr ' ' '\n' | grep -v '^$' | jq -R -s -c 'split("\n") | map(select(length>0))')
  gaps_json="${gaps_json:-[]}"
  ooo_json=$(echo "$ooo" | tr ' ' '\n' | grep -v '^$' | jq -R -s -c 'split("\n") | map(select(length>0))')
  ooo_json="${ooo_json:-[]}"
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_manifest_phase_monotonic/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "total_phases": $total,
  "last_id": "P${prev}",
  "gap_count": $gap_count,
  "gaps": $gaps_json,
  "out_of_order_count": $ooo_count,
  "out_of_order": $ooo_json,
  "note": "Phase 29 — phases[] must be P1..Pn contiguous. Gap or out-of-order signals the phase history has drifted from actual commit sequence (e.g. a phase was deleted, or an insertion landed between existing ones).",
  "status": "$([ $gap_count -eq 0 ] && [ $ooo_count -eq 0 ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (total=$total last=P$prev gaps=$gap_count ooo=$ooo_count)"
}

# ────────────────────────────────────────────────────────────
# Phase 30 — scanner registry ↔ continuous_scan_order parity.
#   continuous_scan_order 에 있는 모든 scanner 는 scanner_registry (의
#   time_invariant/time_dependent/meta 중 하나) 에 선언되어야 한다. 역방향
#   (registry 에만 있는 scanner) 은 allowlist — health/idempotence/selftest
#   은 on-demand 로 돌아서 CSO 에 없는 게 정상. unlisted scanner 가 CSO 에
#   들어오면 registry 에 정식 등록 없이 실행되는 상태 — phase 선언-집행 drift.
#   Gate: unregistered_in_cso == 0.
#   claim: scanners/40_registry_cso_parity.claim.json
# ────────────────────────────────────────────────────────────
scan_registry_cso_parity() {
  local out="reports/n6_registry_cso_parity.json"
  local mf="config/engine_manifest.json"
  local on_demand="health idempotence selftest"
  local reg cso unreg="" unreg_count=0 on_demand_count=0 on_demand_list=""
  reg=$(jq -r '(.scanner_registry.time_invariant + .scanner_registry.time_dependent + .scanner_registry.meta)[]' "$mf" 2>/dev/null | sort -u)
  cso=$(jq -r '.continuous_scan_order[]' "$mf" 2>/dev/null | sort -u)
  local reg_total cso_total
  reg_total=$(echo "$reg" | grep -c . | tr -d ' ')
  cso_total=$(echo "$cso" | grep -c . | tr -d ' ')
  while IFS= read -r s; do
    [ -z "$s" ] && continue
    if ! echo "$reg" | grep -qxF "$s"; then
      unreg="${unreg}${s} "
      unreg_count=$((unreg_count+1))
    fi
  done <<< "$cso"
  # Registry entries not in CSO = expected on-demand OR unexpected orphan
  while IFS= read -r s; do
    [ -z "$s" ] && continue
    if ! echo "$cso" | grep -qxF "$s"; then
      if echo " $on_demand " | grep -qE " ${s} "; then
        on_demand_list="${on_demand_list}${s} "
        on_demand_count=$((on_demand_count+1))
      else
        unreg="${unreg}registry_only(${s}) "
        unreg_count=$((unreg_count+1))
      fi
    fi
  done <<< "$reg"
  local unreg_json on_demand_json
  unreg_json=$(echo "$unreg" | tr ' ' '\n' | grep -v '^$' | jq -R -s -c 'split("\n") | map(select(length>0))')
  unreg_json="${unreg_json:-[]}"
  on_demand_json=$(echo "$on_demand_list" | tr ' ' '\n' | grep -v '^$' | jq -R -s -c 'split("\n") | map(select(length>0))')
  on_demand_json="${on_demand_json:-[]}"
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_registry_cso_parity/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "registry_total": $reg_total,
  "cso_total": $cso_total,
  "unregistered_count": $unreg_count,
  "unregistered": $unreg_json,
  "on_demand_count": $on_demand_count,
  "on_demand_allowlist": $on_demand_json,
  "note": "Phase 30 — every continuous_scan_order entry must be in scanner_registry (declaration ↔ execution parity). Registry entries absent from CSO are allowed only if in {health, idempotence, selftest} — they are intentionally on-demand. Any other registry-only entry is orphan (declared but never run in continuous scan). Gate: unregistered_count == 0.",
  "status": "$([ $unreg_count -eq 0 ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (reg=$reg_total cso=$cso_total unregistered=$unreg_count on_demand=$on_demand_count)"
}

# ────────────────────────────────────────────────────────────
# Phase 31 — selftest ↔ function-definition parity.
#   selftest() 의 for-loop 는 각 scan_*/gap_*/propose_*/promote_*/run_* 를
#   이름으로 호출한다. 이름이 실제 함수 정의와 어긋나면 (오타·삭제·리팩터)
#   rc=127 을 캡처해 verdict=FAIL 로 기록되는데 — P31 은 이 지연 발견 대신
#   static 검증으로 앞당긴다. selftest 가 "열거는 했으나 부를 수 없는" 함수
#   를 담고 있으면 즉시 gate.
#   Gate: undefined_count == 0.
#   claim: scanners/41_selftest_fn_parity.claim.json
# ────────────────────────────────────────────────────────────
scan_selftest_fn_parity() {
  local out="reports/n6_selftest_fn_parity.json"
  local src="tool/_n6_lib"
  local fns undef="" undef_count=0 total=0
  # Extract the selftest for-loop list: start at "for cmd in" line, take up to
  # the closing "; do" on the same line.
  fns=$(grep -E '^  for cmd in ' "$src" | head -1 | sed -E 's/^  for cmd in //; s/; do$//')
  for fn in $fns; do
    total=$((total+1))
    if ! grep -qE "^${fn}\(\) \{" "$src"; then
      undef="${undef}${fn} "
      undef_count=$((undef_count+1))
    fi
  done
  local undef_json
  undef_json=$(echo "$undef" | tr ' ' '\n' | grep -v '^$' | jq -R -s -c 'split("\n") | map(select(length>0))')
  undef_json="${undef_json:-[]}"
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_selftest_fn_parity/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "listed_fn_count": $total,
  "undefined_count": $undef_count,
  "undefined": $undef_json,
  "note": "Phase 31 — every name in selftest's for-loop must have a matching function definition in tool/_n6_lib. A typo or stale name causes rc=127 at runtime which selftest records as FAIL — but that verdict looks like a scanner bug, not a registration drift. P31 turns that late discovery into a static gate.",
  "status": "$([ $undef_count -eq 0 ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (listed=$total undefined=$undef_count)"
}

# ────────────────────────────────────────────────────────────
# Phase 32 — version ↔ last-phase alignment.
#   version 스키마는 관습적으로 "0.<N>.0" 형태이고 <N> 은 현재 last phase
#   번호와 일치한다 (P29 → 0.29.0, P31 → 0.31.0). 새 phase 를 추가할 때
#   version bump 을 빠뜨리면 source_hash 는 업데이트됐는데 version 은
#   stale — manifest 가 "어느 phase 로 stamp 됐는지" 와 엉키게 된다.
#   Gate: aligned == true (minor == last_phase_num).
#   claim: scanners/42_version_phase_alignment.claim.json
# ────────────────────────────────────────────────────────────
scan_version_phase_alignment() {
  local out="reports/n6_version_phase_alignment.json"
  local mf="config/engine_manifest.json"
  local version last_id minor last_num aligned
  version=$(jq -r '.engine.version' "$mf")
  last_id=$(jq -r '.phases | last | .id' "$mf")
  minor=$(echo "$version" | awk -F. '{print $2}')
  last_num=$(echo "$last_id" | sed -E 's/^P([0-9]+)$/\1/')
  if [ "$minor" = "$last_num" ] && [ -n "$minor" ] && [[ "$minor" =~ ^[0-9]+$ ]]; then
    aligned="true"
  else
    aligned="false"
  fi
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_version_phase_alignment/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "manifest_version": "$version",
  "version_minor": "$minor",
  "last_phase_id": "$last_id",
  "last_phase_num": "$last_num",
  "aligned": $aligned,
  "note": "Phase 32 — engine.version follows '0.<N>.0' where N equals the last phase's numeric id. Missing a version bump after adding a phase leaves the manifest in an inconsistent stamp state (source_hash rotated but version stale). Gate: aligned == true.",
  "status": "$([ "$aligned" = "true" ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (version=$version last=$last_id aligned=$aligned)"
}

# ────────────────────────────────────────────────────────────
