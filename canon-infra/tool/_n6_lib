# ────────────────────────────────────────────────────────────
# Phase 36 — invariants manifest schema presence.
#   R24+26 에서 config/invariants.json 을 atlas↔engine functor 의 machine-
#   readable manifest 로 생성. P36 은 그 manifest 의 schema presence 만 gate
#   (값 자체 verify 는 P37 이후 예약). 검사: file 존재, 필수 top-level key 존재,
#   atoms 10개 이상 & 각 atom 이 {value, atlas_ref, engine_count, engine_value}
#   필드 보유.
#   claim: scanners/46_invariants_manifest_present.claim.json
# ────────────────────────────────────────────────────────────
scan_invariants_manifest() {
  local out="reports/n6_invariants_manifest.json"
  local mf="config/invariants.json"
  local exists="false" atom_count=0 atom_deficient=0 deficient_list=""
  local required_top="schema atoms semiring_operations foundation_relations euclid_euler_generator closing_theorem"
  local missing_top=""
  if [ -f "$mf" ]; then
