    atom_count=$(jq '.monotone_atoms | length' "$mf" 2>/dev/null || echo 0)
    local req_fields="value atlas_ref direction closure_predicate enforced_by_phase"
    local atom_keys
    atom_keys=$(jq -r '.monotone_atoms | keys[]' "$mf" 2>/dev/null)
    for a in $atom_keys; do
      for f in $req_fields; do
        if ! jq -e ".monotone_atoms[\"$a\"] | has(\"$f\")" "$mf" >/dev/null 2>&1; then
          deficient_list="${deficient_list}${a}.${f} "
          atom_deficient=$((atom_deficient+1))
        fi
      done
    done
  fi
  local missing_top_json deficient_json
  missing_top_json=$(echo "$missing_top" | tr ' ' '\n' | grep -v '^$' | jq -R -s -c 'split("\n") | map(select(length>0))')
  missing_top_json="${missing_top_json:-[]}"
  deficient_json=$(echo "$deficient_list" | tr ' ' '\n' | grep -v '^$' | jq -R -s -c 'split("\n") | map(select(length>0))')
  deficient_json="${deficient_json:-[]}"
  local healthy="false"
  if [ "$exists" = "true" ] && [ -z "$missing_top" ] && [ "$atom_count" -ge 1 ] && [ "$atom_deficient" -eq 0 ]; then
    healthy="true"
  fi
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_thermodynamic_closure_manifest/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "manifest_path": "$mf",
  "exists": $exists,
  "atom_count": $atom_count,
  "atom_field_deficient_count": $atom_deficient,
  "atom_field_deficient": $deficient_json,
  "missing_top_keys": $missing_top_json,
  "healthy": $healthy,
  "note": "Phase 44 — schema presence check for config/thermodynamic_closure.json (axis E3 manifest, R24+31). Parallels P36/P42/P43. F_dir sub-functor back-reference audit reserved for future P45.",
  "status": "$([ "$healthy" = "true" ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (exists=$exists atoms=$atom_count deficient=$atom_deficient)"
}

append_audit_trail() {
  local out="reports/n6_meta_audit.jsonl"
  local score
  score=$(jq -r '.score // 0' reports/n6_health.json 2>/dev/null)
  local p_green p_red p_total
  p_green=$(jq -r '.green // 0' reports/n6_proof_obligations.json 2>/dev/null)
  p_red=$(jq -r '.red // 0'   reports/n6_proof_obligations.json 2>/dev/null)
  p_total=$(jq -r '.total // 0' reports/n6_proof_obligations.json 2>/dev/null)
  local s_pass s_fail
  s_pass=$(jq -r '.pass // 0' reports/n6_selftest.json 2>/dev/null)
  s_fail=$(jq -r '.fail // 0' reports/n6_selftest.json 2>/dev/null)
  local b_high b_med b_low
  b_high=$(jq -r '.summary.high // 0' reports/n6_blockers.json 2>/dev/null)
  b_med=$(jq -r '.summary.med // 0'   reports/n6_blockers.json 2>/dev/null)
  b_low=$(jq -r '.summary.low // 0'   reports/n6_blockers.json 2>/dev/null)
  # Phase 16 — identity of failing claims/scanners (not just counts).
  # Makes the audit jsonl self-diagnostic instead of merely self-counting.
  local red_claims fail_scanners
  red_claims=$(jq -c '[.claims[]? | select(.status != "green") | .file] | sort' reports/n6_proof_obligations.json 2>/dev/null)
  fail_scanners=$(jq -c '[.verdicts[]? | select(.verdict != "PASS") | .scanner] | sort' reports/n6_selftest.json 2>/dev/null)
  red_claims="${red_claims:-[]}"
  fail_scanners="${fail_scanners:-[]}"
  local line
  line=$(printf '{"ts":"%s","engine_version":"%s","head":"%s","health":%s,"proof":{"total":%s,"green":%s,"red":%s,"red_claims":%s},"selftest":{"pass":%s,"fail":%s,"fail_scanners":%s},"blockers":{"high":%s,"med":%s,"low":%s}}\n' \
    "$(ts)" "${ENGINE_VERSION}" "$(head_sha)" "${score:-0}" \
    "${p_total:-0}" "${p_green:-0}" "${p_red:-0}" "$red_claims" \
    "${s_pass:-0}" "${s_fail:-0}" "$fail_scanners" \
    "${b_high:-0}" "${b_med:-0}" "${b_low:-0}")
  echo "$line" >>"$out"
  echo "OK: audit += $(echo "$line" | jq -c '{ts,engine_version,health,red_claims:.proof.red_claims,fail_scanners:.selftest.fail_scanners}')"
}

# ────────────────────────────────────────────────────────────
# Phase 13 — audit trail consumer + continuity
#   scan_audit_summary():
#     reports/n6_meta_audit.jsonl 를 읽어 집계/경향 요약 emit.
#     - entries_total, last entry (ts/engine_version/head)
#     - health min/max/avg, any_red_proof, any_selftest_fail
#     - last_engine_version_matches_current (continuity claim)
#     - last_entry_is_current_head (optional — true iff this run's head matches last entry's head)
#   consumer claim 은 scanners/24_audit_summary_continuity.claim.json 로 fix.
# Phase 15 — trail integrity (ts 비감소 + engine_version 비다운그레이드).
#   같은 함수(scan_audit_summary) 안에서 trail_integrity 필드 추가.
#   claim: scanners/26_audit_trail_integrity.claim.json (두 카운트 == 0)
# Phase 16 — failing identity + persistent failures.
#   append_audit_trail 이 .proof.red_claims / .selftest.fail_scanners 배열 기록.
#   scan_audit_summary 가 최근 5개 entry 를 훑어 3회 이상 등장한 id 를 persistent
#   failure 로 flag. claim: scanners/27_no_persistent_failures.claim.json.
# ────────────────────────────────────────────────────────────
# ────────────────────────────────────────────────────────────
# Phase 14 — gate alignment
#   scan_gate_alignment():
#     manifest 의 pre_commit_hard_gates / pre_commit_advisory 에 선언된
#     모든 predicate 의 핵심 식별자(예: "critical_alarm", "regression") 가
#     hooks/pre-commit-n6-integrity 파일에 grep 으로 존재하는지 확인.
#     선언만 있고 집행이 없는 drift 를 잡는다.
#   claim: scanners/25_gate_alignment.claim.json  (unmatched_count == 0)
# ────────────────────────────────────────────────────────────
scan_gate_alignment() {
  local out="reports/n6_gate_alignment.json"
  local mf="config/engine_manifest.json"
  local hook="hooks/pre-commit-n6-integrity"
  local hard advisory
  hard=$(jq -r '.pre_commit_hard_gates[]? // empty' "$mf" 2>/dev/null)
  advisory=$(jq -r '.pre_commit_advisory[]? // empty' "$mf" 2>/dev/null)
  local unmatched=0
  local items="["
  local first=1
  _check_gate() {
    local kind="$1" gate="$2"
    # predicate key = 문자열 중 첫 '.' 뒤 영숫자_밑줄 토큰 (예: "falsification.critical_alarm == false" -> "critical_alarm")
    local key
    key=$(echo "$gate" | sed -nE 's/^[^.]+\.([A-Za-z_][A-Za-z0-9_]*).*/\1/p')
    [ -z "$key" ] && key="$gate"
    local matched="false"
    if [ -f "$hook" ] && grep -q "$key" "$hook"; then
      matched="true"
    else
      unmatched=$((unmatched+1))
    fi
    [ $first -eq 0 ] && items="${items},"
    items="${items}{\"kind\":\"${kind}\",\"gate\":\"${gate}\",\"key\":\"${key}\",\"matched\":${matched}}"
    first=0
  }
  while IFS= read -r g; do [ -n "$g" ] && _check_gate "hard" "$g"; done <<< "$hard"
  while IFS= read -r g; do [ -n "$g" ] && _check_gate "advisory" "$g"; done <<< "$advisory"
  items="${items}]"
  local hook_present="false"
  [ -f "$hook" ] && hook_present="true"
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_gate_alignment/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "hook_path": "$hook",
  "hook_present": $hook_present,
  "gates": $items,
  "unmatched_count": $unmatched,
  "status": "$([ $unmatched -eq 0 ] && [ "$hook_present" = "true" ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (unmatched=$unmatched)"
}

# ────────────────────────────────────────────────────────────
# Phase 17 — claim schema completeness
#   모든 scanners/*.claim.json 이 8개 필수 필드를 가지고 있는지 확인.
#   필수: id, type, description, actual_cmd, expected, must_fail,
#         recheck_cadence, owner.
#   선택: proposal_ref, tolerance (둘 다 기존 파일 일부에만 존재).
#   claim: scanners/28_claim_schema_complete.claim.json (deficient == 0)
# ────────────────────────────────────────────────────────────
scan_claim_schema() {
  local out="reports/n6_claim_schema.json"
  local required='["id","type","description","actual_cmd","expected","must_fail","recheck_cadence","owner"]'
  local deficient="["
  local first=1
  local deficient_count=0
  local total=0
  for f in scanners/*.claim.json; do
    [ -f "$f" ] || continue
    total=$((total+1))
    local missing
    missing=$(jq --argjson req "$required" \
      '. as $claim | [$req[] | . as $k | select($claim | has($k) | not)]' "$f" 2>/dev/null)
    local miss_count
    miss_count=$(echo "$missing" | jq 'length' 2>/dev/null)
    miss_count="${miss_count:-0}"
    if [ "$miss_count" != "0" ]; then
      [ $first -eq 0 ] && deficient="${deficient},"
      deficient="${deficient}{\"file\":\"$(basename "$f")\",\"missing\":$missing}"
      first=0
      deficient_count=$((deficient_count+1))
    fi
  done
  deficient="${deficient}]"
  # Phase 19 — duplicate id detection (extension of P17 schema scan).
  # Two claim files with the same `.id` would produce one proof slot that
  # overwrites the other silently — the runner keys by id. Flag any id
  # appearing >1 times across scanners/*.claim.json.
  local duplicate_ids
  duplicate_ids=$(jq -r '.id // empty' scanners/*.claim.json 2>/dev/null \
    | sort | uniq -d | jq -R -s 'split("\n") | map(select(length>0))')
  duplicate_ids="${duplicate_ids:-[]}"
  local duplicate_id_count
  duplicate_id_count=$(echo "$duplicate_ids" | jq 'length')
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_claim_schema/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "required_fields": $required,
  "total_claims": $total,
  "deficient_count": $deficient_count,
  "deficient": $deficient,
  "duplicate_id_count": $duplicate_id_count,
  "duplicate_ids": $duplicate_ids,
  "status": "$([ $deficient_count -eq 0 ] && [ "$duplicate_id_count" = "0" ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (deficient=$deficient_count, duplicate_ids=$duplicate_id_count / $total)"
}

scan_audit_summary() {
  local src="reports/n6_meta_audit.jsonl"
  local out="reports/n6_audit_summary.json"
  local entries=0
  local last_ts="null" last_ver="null" last_head="null" last_health="0"
  local last_proof_red="0" last_selftest_fail="0"
  local last_red_claims="[]" last_fail_scanners="[]"
  local h_min=100 h_max=0 h_avg=0
  local any_red_proof="false" any_selftest_fail="false"
  local ver_match="false" head_match="false"

  if [ -s "$src" ]; then
    entries=$(wc -l < "$src" | tr -d ' ')
    # last entry
    local last_line
    last_line=$(tail -1 "$src")
    last_ts=$(echo "$last_line" | jq -r '.ts // empty')
    last_ver=$(echo "$last_line" | jq -r '.engine_version // empty')
    last_head=$(echo "$last_line" | jq -r '.head // empty')
    last_health=$(echo "$last_line" | jq -r '.health // 0')
    last_proof_red=$(echo "$last_line" | jq -r '.proof.red // 0')
    last_selftest_fail=$(echo "$last_line" | jq -r '.selftest.fail // 0')
    # Phase 16 — carry identity of failing items through to summary.
    last_red_claims=$(echo "$last_line" | jq -c '.proof.red_claims // []')
    last_fail_scanners=$(echo "$last_line" | jq -c '.selftest.fail_scanners // []')
    # aggregates across all lines (historical observability — NOT gating)
    local aggs
    aggs=$(jq -s '
      # Phase 15 integrity: ts must be monotonically non-decreasing,
      # engine_version must never downgrade (semver-compare on dot-ints).
      def semver_tuple: split(".") | map(try tonumber catch 0);
      def cmp_semver(a; b):
        (a | semver_tuple) as $x |
        (b | semver_tuple) as $y |
        ($x[0] - $y[0]) as $d0 |
        (if $d0 != 0 then $d0
         else ($x[1] // 0) - ($y[1] // 0) as $d1 |
              (if $d1 != 0 then $d1
               else ($x[2] // 0) - ($y[2] // 0) end)
         end);
      . as $all |
      {
        h_min: (map(.health // 0) | min // 0),
        h_max: (map(.health // 0) | max // 0),
        h_avg: ((map(.health // 0) | add // 0) / (length | if . == 0 then 1 else . end) | floor),
        any_red_proof: (any(.[]; (.proof.red // 0) > 0)),
        any_selftest_fail: (any(.[]; (.selftest.fail // 0) > 0)),
        ts_regressions: ([range(1; length) as $i | select(($all[$i].ts // "") < ($all[$i-1].ts // ""))] | length),
        version_downgrades: ([range(1; length) as $i | select(cmp_semver($all[$i].engine_version // "0"; $all[$i-1].engine_version // "0") < 0)] | length),
        persistent_red_claims: (
          # Phase 16 — claim ids that appear as red in the most recent
          # K=5 entries, AND have never gone green in that window.
          # Signals an unresolved systemic failure vs a transient flake.
          ([.[-5:][] | (.proof.red_claims // [])] | add // []) as $recent |
          ($recent | group_by(.) | map(select(length >= 3) | .[0]))
        ),
        persistent_fail_scanners: (
          ([.[-5:][] | (.selftest.fail_scanners // [])] | add // []) as $recent |
          ($recent | group_by(.) | map(select(length >= 3) | .[0]))
        )
      }
    ' "$src" 2>/dev/null)
    h_min=$(echo "$aggs" | jq -r '.h_min')
    h_max=$(echo "$aggs" | jq -r '.h_max')
    h_avg=$(echo "$aggs" | jq -r '.h_avg')
    any_red_proof=$(echo "$aggs" | jq -r '.any_red_proof')
    any_selftest_fail=$(echo "$aggs" | jq -r '.any_selftest_fail')
    ts_regressions=$(echo "$aggs" | jq -r '.ts_regressions // 0')
    version_downgrades=$(echo "$aggs" | jq -r '.version_downgrades // 0')
    persistent_red_claims=$(echo "$aggs" | jq -c '.persistent_red_claims // []')
    persistent_fail_scanners=$(echo "$aggs" | jq -c '.persistent_fail_scanners // []')
    # continuity
    [ "$last_ver" = "${ENGINE_VERSION}" ] && ver_match="true"
    [ "$last_head" = "$(head_sha)" ] && head_match="true"
  fi
  : "${ts_regressions:=0}"
  : "${version_downgrades:=0}"
  : "${persistent_red_claims:=[]}"
  : "${persistent_fail_scanners:=[]}"

  cat >"$out" <<JEOF
{
  "schema": "canon/n6_audit_summary/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "source": "$src",
  "entries_total": $entries,
  "last_entry": {
    "ts": $([ "$last_ts" = "null" ] && echo null || printf '"%s"' "$last_ts"),
    "engine_version": $([ "$last_ver" = "null" ] && echo null || printf '"%s"' "$last_ver"),
    "head": $([ "$last_head" = "null" ] && echo null || printf '"%s"' "$last_head"),
    "health": ${last_health:-0},
    "proof_red": ${last_proof_red:-0},
    "selftest_fail": ${last_selftest_fail:-0},
    "red_claims": $last_red_claims,
    "fail_scanners": $last_fail_scanners
  },
  "health": {
    "min": $h_min,
    "max": $h_max,
    "avg": $h_avg
  },
  "historical": {
    "any_red_proof_ever": $any_red_proof,
    "any_selftest_fail_ever": $any_selftest_fail
  },
  "trail_integrity": {
    "ts_regressions": $ts_regressions,
    "version_downgrades": $version_downgrades
  },
  "persistent_failures": {
    "red_claims_last_5": $persistent_red_claims,
    "fail_scanners_last_5": $persistent_fail_scanners,
    "threshold": "appears >=3 times in last 5 entries"
  },
  "continuity": {
    "last_engine_version_matches_current": $ver_match,
    "last_head_matches_current": $head_match
  },
  "status": "$([ "$ver_match" = "true" ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (entries=$entries, health_avg=$h_avg)"
}

# ────────────────────────────────────────────────────────────
# Phase 11 — engine manifest + schema audit
#   scan_manifest():  emit live summary pinned to config/engine_manifest.json
#   scan_schemas():   audit every reports/n6_*.json for a well-formed
#                     "schema" field whose prefix matches the manifest's
#                     schema_prefix. Catches drift where a scanner is
#                     renamed/evolved but forgets to update its schema.
# ────────────────────────────────────────────────────────────
scan_manifest() {
  local out="reports/n6_manifest.json"
  local mf="config/engine_manifest.json"
  [ -f "$mf" ] || {
    echo "{\"schema\":\"canon/n6_manifest/1\",\"ts\":\"$(ts)\",\"engine_version\":\"${ENGINE_VERSION}\",\"error\":\"missing ${mf}\"}" >"$out"
    echo "MISS: $mf"; return 0
  }
  local phases_live=$(jq -r '[.phases[] | select(.state=="live")] | length' "$mf")
  local phases_total=$(jq -r '.phases | length' "$mf")
  local scanners_time_invariant=$(jq -r '.scanner_registry.time_invariant | length' "$mf")
  local scanners_time_dependent=$(jq -r '.scanner_registry.time_dependent | length' "$mf")
  local scanners_meta=$(jq -r '.scanner_registry.meta | length' "$mf")
  local hard_gates=$(jq -r '.pre_commit_hard_gates | length' "$mf")
  local claims_total=$(ls scanners/*.claim.json 2>/dev/null | wc -l | tr -d ' ')
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_manifest/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "phases": {"live": $phases_live, "total": $phases_total},
  "scanners": {
    "time_invariant": $scanners_time_invariant,
    "time_dependent": $scanners_time_dependent,
    "meta": $scanners_meta
  },
  "claims_total": $claims_total,
  "pre_commit_hard_gates": $hard_gates
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

scan_schemas() {
  local out="reports/n6_schema_audit.json"
  local prefix=$(jq -r '.schema_prefix // "canon/"' config/engine_manifest.json 2>/dev/null)
  local total=0 ok=0 drift=0
  local drifts="["
  local first=1
  for f in reports/n6_*.json; do
    [ -f "$f" ] || continue
    # skip non-schema-bearing aggregate files
    case "$(basename "$f")" in
      n6_health.json|n6_meta_telemetry.json|n6_manifest.json|n6_schema_audit.json) continue ;;
    esac
    total=$((total+1))
    local s=$(jq -r '.schema // ""' "$f" 2>/dev/null)
    if [ -z "$s" ] || [ "${s:0:${#prefix}}" != "$prefix" ]; then
      drift=$((drift+1))
      [ $first -eq 0 ] && drifts="${drifts},"
      drifts="${drifts}{\"file\":\"${f}\",\"schema\":\"${s:-<missing>}\"}"
      first=0
    else
      ok=$((ok+1))
    fi
  done
  drifts="${drifts}]"
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_schema_audit/1",
  "ts": "$(ts)",
  "engine_version": "${ENGINE_VERSION}",
  "schema_prefix_required": "${prefix}",
  "total_reports": $total,
  "ok": $ok,
  "drift_count": $drift,
  "drifts": $drifts,
  "status": "$([ $drift -eq 0 ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (${ok}/${total} schema-clean)"
}

# ────────────────────────────────────────────────────────────
# Phase 10 — scanner idempotence
#   Run each time-invariant scanner twice and verify its output (after
#   stripping volatile keys: ts, anything ending in _ts, runtime_ms)
#   is byte-identical. A mismatch means the scanner is non-deterministic
#   and must be fixed before its numbers can be trusted across time.
# ────────────────────────────────────────────────────────────
scan_idempotence() {
  local out="reports/n6_idempotence.json"
  # Only scanners that are pure functions of repo state (no network,
  # no wall-clock age, no git-log since-now). Exclude:
  #   blockers  — nexus_reach probes network
  #   roi       — atlas_signal_age_hours depends on wall clock
  #   experiments — bench runs may vary
  #   trend     — compares today vs prior (time-dependent by design)
  #   proof / selftest / doctor / health — meta-level composites
  local targets=(arithmetic derivation atlas domains papers monte_carlo causal citations nexus_dep loop_rules falsification)
  local results="["
  local first=1
  local total=0 pass=0 fail=0
  for s in "${targets[@]}"; do
    total=$((total+1))
    local report="reports/n6_${s}.json"
    # Map sub name → report path for ones that don't follow n6_<s>.json exactly.
    case "$s" in
      monte_carlo) report="reports/n6_monte_carlo.json" ;;
      citations)   report="reports/n6_external_citation_drift.json" ;;
      nexus_dep)   report="reports/n6_nexus_dep_drift.json" ;;
      loop_rules)  report="reports/n6_loop_rules.json" ;;
      domains)     report="reports/n6_domain_coverage.json" ;;
      papers)      report="reports/n6_paper_lineage.json" ;;
      derivation)  report="reports/n6_derivation_lineage.json" ;;
      causal)      report="reports/n6_causal_chain.json" ;;
      atlas)       report="reports/n6_atlas_integrity.json" ;;
      arithmetic)  report="reports/n6_arithmetic_check.json" ;;
      falsification) report="reports/n6_falsification.json" ;;
    esac
    # First run
    scan_"$s" >/dev/null 2>&1 || true
    local h1
    h1=$(jq 'del(.ts) | del(.. | .ts? // empty)' "$report" 2>/dev/null | shasum -a 256 | awk '{print $1}')
    # Second run
    scan_"$s" >/dev/null 2>&1 || true
    local h2
    h2=$(jq 'del(.ts) | del(.. | .ts? // empty)' "$report" 2>/dev/null | shasum -a 256 | awk '{print $1}')
    local verdict="PASS"
    if [ -z "$h1" ] || [ "$h1" != "$h2" ]; then
      verdict="FAIL"; fail=$((fail+1))
    else
      pass=$((pass+1))
    fi
    [ $first -eq 0 ] && results="${results},"
    results="${results}{\"scanner\":\"${s}\",\"h1\":\"${h1:0:12}\",\"h2\":\"${h2:0:12}\",\"verdict\":\"${verdict}\"}"
    first=0
  done
  results="${results}]"
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_idempotence/1",
  "ts": "$(ts)",
  "total": $total,
  "pass": $pass,
  "fail": $fail,
  "results": $results,
  "status": "$([ $fail -eq 0 ] && echo GREEN || echo RED)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out  (${pass}/${total} idempotent)"
}

# ────────────────────────────────────────────────────────────
# Phase 9 — cross-scan invariants
#   Numbers reported by multiple scanners must agree. A disagreement
#   means one scanner is stale (or the repo changed between scans).
#   We compare the three load-bearing counts (domains, techniques,
#   papers) across scan_roi + scan_citations + scan_domains.
#   Also checks ROI SSOT vs live n6_roi.json (items with status=done
#   in SSOT shouldn't reappear as findings).
# ────────────────────────────────────────────────────────────
scan_invariants() {
  local out="reports/n6_invariants.json"
  local drifts="["
  local first=1
  local drift_count=0

  # helper: emit one drift entry
  _drift() {
    local metric="$1" a_src="$2" a_val="$3" b_src="$4" b_val="$5"
    [ $first -eq 0 ] && drifts="${drifts},"
    drifts="${drifts}{\"metric\":\"${metric}\",\"a\":{\"source\":\"${a_src}\",\"value\":${a_val}},\"b\":{\"source\":\"${b_src}\",\"value\":${b_val}}}"
    first=0
    drift_count=$((drift_count+1))
  }

  # read once
  local roi_domains  roi_techniques roi_papers
  local cit_domains  cit_techniques cit_papers
  local dom_total    dom_techniques
  roi_domains=$(jq -r '.counters.products_actual // 0'    reports/n6_roi.json 2>/dev/null)
  roi_techniques=$(jq -r '.counters.techniques_total // 0' reports/n6_roi.json 2>/dev/null)
  roi_papers=$(jq -r '.counters.papers_total // 0'        reports/n6_roi.json 2>/dev/null)

  cit_domains=$(jq -r '.actual.domains // 0'    reports/n6_external_citation_drift.json 2>/dev/null)
  cit_techniques=$(jq -r '.actual.techniques // 0' reports/n6_external_citation_drift.json 2>/dev/null)
  cit_papers=$(jq -r '.actual.papers // 0'      reports/n6_external_citation_drift.json 2>/dev/null)

  dom_total=$(jq -r '.domains_total // 0'      reports/n6_domain_coverage.json 2>/dev/null)
  dom_techniques=$(jq -r '.techniques_total // 0' reports/n6_domain_coverage.json 2>/dev/null)

  # rule 1: domains count triad (roi · citations · domain_coverage)
  [ "$roi_domains" != "$cit_domains" ] && _drift "domains" "n6_roi.counters.products_actual" "$roi_domains" "n6_external_citation_drift.actual.domains" "$cit_domains"
  [ "$roi_domains" != "$dom_total" ]   && _drift "domains" "n6_roi.counters.products_actual" "$roi_domains" "n6_domain_coverage.domains_total" "$dom_total"

  # rule 2: techniques triad
  [ "$roi_techniques" != "$cit_techniques" ]  && _drift "techniques" "n6_roi.counters.techniques_total" "$roi_techniques" "n6_external_citation_drift.actual.techniques" "$cit_techniques"
  [ "$roi_techniques" != "$dom_techniques" ]  && _drift "techniques" "n6_roi.counters.techniques_total" "$roi_techniques" "n6_domain_coverage.techniques_total" "$dom_techniques"

  # rule 3: papers pair
  [ "$roi_papers" != "$cit_papers" ] && _drift "papers" "n6_roi.counters.papers_total" "$roi_papers" "n6_external_citation_drift.actual.papers" "$cit_papers"

  # rule 4: SSOT vs live — items marked status=done in the nexus ROI SSOT
  # must NOT be re-flagged in today's findings.
  local ssot="/Users/ghost/core/nexus/config/roi/canon.json"
  if [ -f "$ssot" ]; then
    # Example: orphan_paper done in SSOT ⇒ findings.orphan_paper length should be 0.
    local orphan_done=$(jq -r '.items[] | select(.id=="n6-roi-004" and .status=="done") | .id' "$ssot" 2>/dev/null)
    if [ -n "$orphan_done" ]; then
      local live_orphan=$(jq -r '.findings.orphan_paper | length' reports/n6_roi.json 2>/dev/null)
      [ "${live_orphan:-0}" -gt 0 ] && _drift "ssot_vs_live.orphan_paper" "nexus/config/roi.n6-roi-004.status" "\"done\"" "n6_roi.findings.orphan_paper.length" "$live_orphan"
    fi
    local dead_done=$(jq -r '.items[] | select(.id=="n6-roi-005" and .status=="done") | .id' "$ssot" 2>/dev/null)
    if [ -n "$dead_done" ]; then
      local live_dead=$(jq -r '.findings.dead_technique | length' reports/n6_roi.json 2>/dev/null)
      [ "${live_dead:-0}" -gt 0 ] && _drift "ssot_vs_live.dead_technique" "nexus/config/roi.n6-roi-005.status" "\"done\"" "n6_roi.findings.dead_technique.length" "$live_dead"
    fi
  fi

  drifts="${drifts}]"

  cat >"$out" <<JEOF
{
  "schema": "canon/n6_invariants/1",
  "ts": "$(ts)",
  "checked": {
    "domains_triad":    ["n6_roi", "n6_external_citation_drift", "n6_domain_coverage"],
    "techniques_triad": ["n6_roi", "n6_external_citation_drift", "n6_domain_coverage"],
    "papers_pair":      ["n6_roi", "n6_external_citation_drift"],
    "ssot_vs_live":     ["n6-roi-004 orphan_paper", "n6-roi-005 dead_technique"]
  },
  "drift_count": $drift_count,
  "drifts": $drifts,
  "status": "$([ $drift_count -eq 0 ] && echo GREEN || echo AMBER)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

# ────────────────────────────────────────────────────────────
# Phase 7 — historical trend + regression alarm
#   Compare today's key metrics against the most recent prior snapshot in
#   reports/history/YYYY-MM-DD/. Emit reports/n6_trend.json with deltas,
#   and set regression=true if any of the guardrails fire:
#     - health score dropped by more than HEALTH_REGRESS_MAX (default 5)
#     - proof obligations red count increased
#     - blocker high count increased
#     - falsification critical_alarm newly true
#   regression=true is a soft signal (surfaced in reports + claim); it is
#   NOT a hard commit block. The pre-commit hook still hard-blocks only on
#   falsification critical_alarm; trend regression is advisory only.
# ────────────────────────────────────────────────────────────
scan_trend() {
  local out="reports/n6_trend.json"
  local history_root="reports/history"
  local regress_max="${HEALTH_REGRESS_MAX:-5}"

  # locate prior snapshot (latest date dir that isn't today)
  local today=$(date -u +%Y-%m-%d)
  local prior_dir=""
  if [ -d "$history_root" ]; then
    prior_dir=$(find "$history_root" -maxdepth 1 -mindepth 1 -type d \
      ! -name "$today" 2>/dev/null | sort | tail -1)
  fi

  # today's metrics (from live reports)
  local today_score today_proof_red today_high today_alarm
  today_score=$(jq -r '.score // 0' reports/n6_health.json 2>/dev/null)
  [ -z "$today_score" ] && today_score=0
  today_proof_red=$(jq -r '.red // 0' reports/n6_proof_obligations.json 2>/dev/null)
  today_high=$(jq -r '.summary.high // 0' reports/n6_blockers.json 2>/dev/null)
  today_alarm=$(jq -r '.critical_alarm // false' reports/n6_falsification.json 2>/dev/null)

  # prior metrics
  local prior_score=null prior_proof_red=null prior_high=null prior_alarm=null prior_date=null
  if [ -n "$prior_dir" ] && [ -d "$prior_dir" ]; then
    prior_date="\"$(basename "$prior_dir")\""
    if [ -f "$prior_dir/n6_health.json" ]; then
      prior_score=$(jq -r '.score // empty' "$prior_dir/n6_health.json" 2>/dev/null)
    fi
    [ -z "$prior_score" ] && prior_score=null
    prior_proof_red=$(jq -r '.red // 0' "$prior_dir/n6_proof_obligations.json" 2>/dev/null)
    [ -z "$prior_proof_red" ] && prior_proof_red=null
    prior_high=$(jq -r '.summary.high // 0' "$prior_dir/n6_blockers.json" 2>/dev/null)
    [ -z "$prior_high" ] && prior_high=null
    prior_alarm=$(jq -r '.critical_alarm // false' "$prior_dir/n6_falsification.json" 2>/dev/null)
    [ -z "$prior_alarm" ] && prior_alarm=false
  fi

  # deltas + regression detection (guard against "null" / non-numeric prior)
  local delta_score=0 delta_proof_red=0 delta_high=0
  local regression=false
  local reasons="[]"
  local r_items=""
  _is_num() { case "$1" in ''|*[!0-9-]*) return 1;; *) return 0;; esac; }
  if _is_num "$prior_score" && _is_num "$prior_proof_red" && _is_num "$prior_high"; then
    delta_score=$(( today_score - prior_score ))
    delta_proof_red=$(( today_proof_red - prior_proof_red ))
    delta_high=$(( today_high - prior_high ))
    if [ "$delta_score" -lt "-${regress_max}" ]; then
      regression=true
      r_items="${r_items}\"health drop ${delta_score} > allowed -${regress_max}\","
    fi
    if [ "$delta_proof_red" -gt 0 ]; then
      regression=true
      r_items="${r_items}\"proof red increased by ${delta_proof_red}\","
    fi
    if [ "$delta_high" -gt 0 ]; then
      regression=true
      r_items="${r_items}\"blocker high increased by ${delta_high}\","
    fi
    if [ "$today_alarm" = "true" ] && [ "$prior_alarm" != "true" ]; then
      regression=true
      r_items="${r_items}\"falsification critical_alarm newly true\","
    fi
    r_items="${r_items%,}"
    reasons="[${r_items}]"
  fi

  cat >"$out" <<JEOF
{
  "schema": "canon/n6_trend/1",
  "ts": "$(ts)",
  "prior_snapshot": ${prior_date:-null},
  "today": {
    "score": $today_score,
    "proof_red": $today_proof_red,
    "blocker_high": $today_high,
    "falsification_alarm": $today_alarm
  },
  "prior": {
    "score": ${prior_score:-null},
    "proof_red": ${prior_proof_red:-null},
    "blocker_high": ${prior_high:-null},
    "falsification_alarm": ${prior_alarm:-false}
  },
  "delta": {
    "score": $delta_score,
    "proof_red": $delta_proof_red,
    "blocker_high": $delta_high
  },
  "regress_max_allowed_drop": $regress_max,
  "regression": $regression,
  "regression_reasons": $reasons
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

# ────────────────────────────────────────────────────────────
# Phase 6.4 — Proof Obligation DSL runner
# ────────────────────────────────────────────────────────────
run_proof_obligations() {
  local out="reports/n6_proof_obligations.json"
  local dsl_dir="scanners"
  local total=0 green=0 red=0 details="["
  local first=1
  for f in "$dsl_dir"/*.claim.json; do
    [ -f "$f" ] || continue
    total=$((total+1))
    local type must_fail actual_cmd expected tolerance result status
    type=$(jq -r '.type' "$f")
    must_fail=$(jq -r '.must_fail // false' "$f")
    actual_cmd=$(jq -r '.actual_cmd // .actual // ""' "$f")
    expected=$(jq -r '.expected // ""' "$f")
    tolerance=$(jq -r '.tolerance // 0' "$f")
    result=$(bash -c "$actual_cmd" 2>/dev/null | head -1 | tr -d ' \n')
    if [ "$must_fail" = "true" ]; then
      if [ -z "$result" ] || [ "$result" = "0" ] || [ "$result" = "false" ]; then
        status="green"; green=$((green+1))
      else
        status="red"; red=$((red+1))
      fi
    else
      if [ "$result" = "$expected" ]; then
        status="green"; green=$((green+1))
      else
        local diff
        diff=$(awk -v a="$result" -v b="$expected" 'BEGIN{d=a-b; if(d<0)d=-d; print d}' 2>/dev/null | head -1 || echo 0)
        if [ -n "$diff" ] && awk -v d="$diff" -v t="$tolerance" 'BEGIN{exit !(d<=t)}' 2>/dev/null; then
          status="green"; green=$((green+1))
        else
          status="red"; red=$((red+1))
        fi
      fi
    fi
    [ $first -eq 0 ] && details="${details},"
    details="${details}{\"file\":\"$(basename "$f")\",\"type\":\"${type}\",\"status\":\"${status}\",\"result\":\"${result}\",\"expected\":\"${expected}\"}"
    first=0
  done
  details="${details}]"
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_proof_obligations/1",
  "ts": "$(ts)",
  "total": $total,
  "green": $green,
  "red": $red,
  "status": "$([ $red -eq 0 ] && echo GREEN || echo RED)",
  "claims": $details
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

# ────────────────────────────────────────────────────────────
# Aggregators
# ────────────────────────────────────────────────────────────
doctor() {
  local out="reports/n6_doctor.json"
  local summary="["
  local first=1
  for report in reports/n6_*.json; do
    [ -f "$report" ] || continue
    [[ "$(basename "$report")" == "n6_doctor.json" ]] && continue
    [[ "$(basename "$report")" == "n6_meta_telemetry.jsonl" ]] && continue
    local name=$(basename "$report" .json)
    local ts_r=$(jq -r '.ts // "unknown"' "$report" 2>/dev/null)
    [ $first -eq 0 ] && summary="${summary},"
    summary="${summary}{\"report\":\"$name\",\"ts\":\"$ts_r\",\"size\":$(stat -f '%z' "$report" 2>/dev/null | head -1 || echo 0)}"
    first=0
  done
  summary="${summary}]"
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_doctor/1",
  "ts": "$(ts)",
  "reports_present": $summary
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

health() {
  # 0-100 composite score
  local score=100
  # penalize blockers
  if [ -f reports/n6_blockers.json ]; then
    local high=$(jq -r '.summary.high // 0' reports/n6_blockers.json)
    local med=$(jq -r '.summary.med // 0' reports/n6_blockers.json)
    local low=$(jq -r '.summary.low // 0' reports/n6_blockers.json)
    score=$((score - high*10 - med*4 - low*1))
  fi
  # penalize falsification red
  if [ -f reports/n6_falsification.json ]; then
    local alarm=$(jq -r '.critical_alarm // false' reports/n6_falsification.json)
    [ "$alarm" = "true" ] && score=$((score - 50))
  fi
  # penalize citation drift
  if [ -f reports/n6_external_citation_drift.json ]; then
    local drift=$(jq -r '.drift_count // 0' reports/n6_external_citation_drift.json)
    score=$((score - drift*2))
  fi
  # proof obligation red
  if [ -f reports/n6_proof_obligations.json ]; then
    local red=$(jq -r '.red // 0' reports/n6_proof_obligations.json)
    score=$((score - red*3))
  fi
  [ $score -lt 0 ] && score=0
  [ $score -gt 100 ] && score=100
  local payload="{\"ts\":\"$(ts)\",\"score\":${score}}"
  # Also persist so scan_trend (and other consumers) can read it back.
  echo "$payload" >reports/n6_health.json
  echo "$payload"
}

# ────────────────────────────────────────────────────────────
# Phase 5 — continuous scan driver (pairs with launchd 12h plist)
# ────────────────────────────────────────────────────────────
continuous_scan() {
  local phases=(blockers roi arithmetic derivation atlas domains papers monte_carlo causal citations nexus_dep loop_rules experiments falsification)
  for p in "${phases[@]}"; do
    local st=$(date +%s)
    local st_ms=$(( st * 1000 ))
    scan_${p} >/dev/null 2>&1 || true
    local rc=$?
    log_telemetry "$p" "$st_ms" "$rc" "reports/n6_${p}.json"
  done
  gap_proposer >/dev/null 2>&1 || true
  propose_from_gaps >/dev/null 2>&1 || true
  promote_cross_repo >/dev/null 2>&1 || true
  scan_invariants >/dev/null 2>&1 || true
  scan_manifest >/dev/null 2>&1 || true
  scan_schemas >/dev/null 2>&1 || true
  scan_engine_integrity >/dev/null 2>&1 || true
  scan_engine_hash >/dev/null 2>&1 || true
  scan_emitter_registry >/dev/null 2>&1 || true
  scan_gate_alignment >/dev/null 2>&1 || true
  scan_claim_schema >/dev/null 2>&1 || true
  run_proof_obligations >/dev/null 2>&1 || true
  doctor >/dev/null
  # trend must come AFTER doctor (reads doctor's score) and BEFORE history
  # archive (so today's trend is what gets snapshotted).
  scan_trend >/dev/null 2>&1 || true
  # audit trail: one line per continuous_scan run
  append_audit_trail >/dev/null 2>&1 || true
  # Phase 21 — retention rotation runs BEFORE summary so the summary's
  # entries_total reflects the post-rotation file (not pre-rotation).
  scan_audit_retention >/dev/null 2>&1 || true
  # Phase 13 — audit summary MUST come after append_audit_trail so the
  # just-appended entry is reflected in entries_total and last_entry.
  scan_audit_summary >/dev/null 2>&1 || true
  # Phase 23 — claim effectiveness (observe-only). Must come after audit
  # trail is written so this run's red_claims are included in the window.
  scan_claim_effectiveness >/dev/null 2>&1 || true
  # Phase 25 — inventory for P24-flagged unobserved dirs (must come BEFORE
  # coverage-map so the references added here are picked up in the same run).
  scan_dir_inventory >/dev/null 2>&1 || true
  # Phase 24 — reverse coverage map (observe-only).
  scan_coverage_map >/dev/null 2>&1 || true
  # Phase 27 — claim cmd purity (static scan of scanners/*.claim.json,
  # no dependency on other reports; runs before emission-completeness).
  scan_claim_cmd_purity >/dev/null 2>&1 || true
  # Phase 28 — claim meta hygiene (owner enum + proposal_ref pattern).
  scan_claim_meta_hygiene >/dev/null 2>&1 || true
  # Phase 29 — manifest phase id monotonicity.
  scan_manifest_phase_monotonic >/dev/null 2>&1 || true
  # Phase 30 — scanner registry ↔ continuous_scan_order parity.
  scan_registry_cso_parity >/dev/null 2>&1 || true
  # Phase 31 — selftest ↔ function-definition parity.
  scan_selftest_fn_parity >/dev/null 2>&1 || true
  # Phase 32 — version ↔ last-phase alignment.
  scan_version_phase_alignment >/dev/null 2>&1 || true
  # Phase 33 — recheck_cadence enum gate.
  scan_recheck_cadence_enum >/dev/null 2>&1 || true
  # Phase 34 — must_fail ↔ expected pair consistency.
  scan_must_fail_expected_pair >/dev/null 2>&1 || true
  # Phase 35 — claim .type enum gate.
  scan_claim_type_enum >/dev/null 2>&1 || true
  # Phase 36 — invariants manifest schema presence.
  scan_invariants_manifest >/dev/null 2>&1 || true
  # Phase 37 — invariants atom VALUE verification (sigma atom).
  scan_invariants_atom_values >/dev/null 2>&1 || true
  # Phase 38 — atom object-level faithfulness (value == engine_value).
  scan_invariants_atom_faithful >/dev/null 2>&1 || true
  # Phase 39 — foundation relation live verification (5 relations eval).
  scan_invariants_relations_live >/dev/null 2>&1 || true
  # Phase 40 — Euclid-Euler generator orbit verification (P1..P4).
  scan_invariants_generator_orbits >/dev/null 2>&1 || true
  # Phase 41 — morphism composition batch.
  scan_invariants_composition >/dev/null 2>&1 || true
  # Phase 42 — silicon_functor manifest schema presence.
  scan_silicon_functor_manifest >/dev/null 2>&1 || true
  # Phase 43 — measurement_boundary manifest schema presence.
  scan_measurement_boundary_manifest >/dev/null 2>&1 || true
  # Phase 44 — thermodynamic_closure manifest schema presence.
  scan_thermodynamic_closure_manifest >/dev/null 2>&1 || true
  # Phase 26 — emission completeness (MUST run last: every declared
  # emitter must have produced its file by now for the check to be valid).
  scan_emission_completeness >/dev/null 2>&1 || true
  # history archive
  local today=$(date -u +%Y-%m-%d)
  mkdir -p "reports/history/$today"
  cp reports/n6_*.json "reports/history/$today/" 2>/dev/null || true
  health
}

