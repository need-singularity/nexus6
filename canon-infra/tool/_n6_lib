# ────────────────────────────────────────────────────────────
# Phase 6.2 — gap proposer
# ────────────────────────────────────────────────────────────
gap_proposer() {
  local out="reports/n6_gap_proposals.json"
  # Phase 8 hotfix pattern detector — Phase 16 tightening.
  # OLD: substring match in any commit subject.
  #      → false positives: "regression alarm" (P7 title),
  #        "audit(meta): close auto_hotfix_pattern" (audit closure),
  #        "feat(daemon): ... commit/revert/dashboard" (revert as feature name).
  # NEW: match only conventional-commit type prefixes —
  #      `revert:` / `revert(` / `Revert "` / `hotfix:` / `hotfix(` /
  #      `emergency:` / `emergency(` / `workaround:`  (or `workaround `).
  # Also cancel `Revert "X"` commits that have a matching later `Reapply "X"`
  # — those are compensating pairs, net zero impact.
  # See proposals/auto_hotfix_pattern_2026_04_23.md for the driving audit.
  local raw_hotfix
  raw_hotfix=$(git log --since='30 days ago' --oneline 2>/dev/null \
    | grep -cE '^[a-f0-9]+ (Revert "|revert:|revert\(|hotfix:|hotfix\(|emergency:|emergency\(|workaround[: ])' \
    || echo 0)
  local revert_subjs reapply_subjs compensated
  revert_subjs=$(git log --since='30 days ago' --format='%s' 2>/dev/null | grep -oE '^Revert "[^"]+"' | sort -u)
  reapply_subjs=$(git log --since='30 days ago' --format='%s' 2>/dev/null | grep -oE '^Reapply "[^"]+"' | sed 's/^Reapply /Revert /' | sort -u)
  if [ -n "$revert_subjs" ] && [ -n "$reapply_subjs" ]; then
    compensated=$(comm -12 <(echo "$revert_subjs") <(echo "$reapply_subjs") | wc -l | tr -d ' ')
  else
    compensated=0
  fi
  local hotfix=$(( raw_hotfix - compensated ))
  [ $hotfix -lt 0 ] && hotfix=0
  local repeat_proposals=$(git log --since='90 days ago' --name-only --pretty=format: -- proposals/ 2>/dev/null | sort | uniq -c | awk '$1 >= 3 {print $2}' | head -10 | j_arr_from_stdin)
  repeat_proposals="${repeat_proposals:-[]}"
  # Exclude this library itself (it contains the TODO regex literal) to
  # prevent self-anchoring. Keep scanning .hexa/.py/.json/.md in engine/
  # tool/ scanners/; skip _n6_lib where the pattern string lives.
  local todo_comments=$(grep -rnE "// TODO|# TODO|나중에 확인" engine/ tool/ scanners/ 2>/dev/null | grep -v "^tool/_n6_lib:" | head -20 | j_arr_from_stdin)
  todo_comments="${todo_comments:-[]}"
  local todo_count=$(echo "$todo_comments" | jq 'length')
  local repeat_count=$(echo "$repeat_proposals" | jq 'length')
  cat >"$out" <<JEOF
{
  "schema": "canon/n6_gap_proposals/1",
  "ts": "$(ts)",
  "hotfix_commit_count_30d": $hotfix,
  "hotfix_raw_count_30d": $raw_hotfix,
  "hotfix_compensated_pairs": $compensated,
  "hotfix_threshold": 5,
  "repeat_edited_proposals": $repeat_proposals,
  "repeat_threshold": 1,
  "todo_anchors": $todo_comments,
  "todo_threshold": 5,
  "triggers": {
    "hotfix_over_threshold":  $([ "$hotfix" -ge 5 ] && echo true || echo false),
    "repeat_over_threshold":  $([ "$repeat_count" -ge 1 ] && echo true || echo false),
    "todo_over_threshold":    $([ "$todo_count" -ge 5 ] && echo true || echo false)
  }
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

