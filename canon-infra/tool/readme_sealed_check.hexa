#!hexa strict
// tool/readme_sealed_check.hexa — own#14 readme-sealed-required enforcement.
//
// Computes SHA-256 of repo-root README.md and compares against the sealed hash
// stored in README.md.sealed.hash. On first run (no sealed file) the file is
// initialised and the run exits 0 with a warning, per the spec.
//
// Also syncs the hash into .readme-rules.json scopes.root.sealed_hash when
// that field is present or writable — preserving it as additional SSOT
// pointer per own#14 decl.
//
// Migrated from tool/readme_sealed_check.py (137 LoC) per raw 9 hexa-only
// + raw 65 idempotent (same exit codes, same JSON sync semantics).
//
// SHA-256 computation delegates to POSIX shasum -a 256 (raw 18 self-host
// fixpoint compatible — shasum is POSIX-standard, no external lib).
//
// @tool(slug="readme_sealed_check", desc="own#14 README.md SHA-256 sealed-hash enforcement; matches stored README.md.sealed.hash + syncs .readme-rules.json scopes.root.sealed_hash field")
// @usage(hexa $HOME/core/canon/tool/readme_sealed_check.hexa [--update])
// @exit_codes(0=match-or-init, 1=mismatch, 2=internal error)

let REPO_ROOT   = env("HOME") + "/core/canon"
let README_PATH = REPO_ROOT + "/README.md"
let SEALED_PATH = REPO_ROOT + "/README.md.sealed.hash"
let RULES_PATH  = REPO_ROOT + "/.readme-rules.json"

fn _file_exists(path: string) -> bool {
  let r = to_string(exec("test -f '" + path + "' && echo y || echo n")).trim()
  return r == "y"
}

fn _is_hex_lower(c: string) -> bool {
  return (c >= "0" && c <= "9") || (c >= "a" && c <= "f")
}

fn _is_hex_any(c: string) -> bool {
  return (c >= "0" && c <= "9") || (c >= "a" && c <= "f") || (c >= "A" && c <= "F")
}

fn _to_lower_hex(s: string) -> string {
  let mut out = ""
  let mut i = 0
  while i < len(s) {
    let c = s.substring(i, i + 1)
    if c >= "A" && c <= "F" {
      // ASCII A=65, a=97 → +32
      // hexa-lang: convert via map lookup
      if c == "A" { out = out + "a" }
      if c == "B" { out = out + "b" }
      if c == "C" { out = out + "c" }
      if c == "D" { out = out + "d" }
      if c == "E" { out = out + "e" }
      if c == "F" { out = out + "f" }
    } else {
      out = out + c
    }
    i = i + 1
  }
  return out
}

fn compute_sha256(path: string) -> string {
  // POSIX shasum -a 256 — output: '<hex>  <path>\n'
  let raw = to_string(exec("shasum -a 256 '" + path + "' 2>/dev/null")).trim()
  if len(raw) < 64 { return "" }
  // Take first 64 hex chars
  let mut digest = ""
  let mut i = 0
  while i < 64 && i < len(raw) {
    let c = raw.substring(i, i + 1)
    if _is_hex_any(c) {
      digest = digest + c
    } else {
      i = 64  // break
    }
    i = i + 1
  }
  if len(digest) != 64 { return "" }
  return _to_lower_hex(digest)
}

fn read_sealed_hash(path: string) -> string {
  // Return 64-char hex digest, or "" if missing/invalid (legacy content).
  // Accept bare 64-hex or 'sha256:<hex>' prefix.
  if !_file_exists(path) { return "" }
  let raw = read_file(path).trim()
  if len(raw) == 0 { return "" }
  // First whitespace-delimited token
  let mut token = ""
  let mut i = 0
  while i < len(raw) {
    let c = raw.substring(i, i + 1)
    if c == " " || c == "\t" || c == "\n" {
      i = len(raw)  // break
    } else {
      token = token + c
    }
    i = i + 1
  }
  // Strip 'sha256:' prefix
  if len(token) >= 7 && token.substring(0, 7) == "sha256:" {
    token = token.substring(7, len(token))
  }
  if len(token) != 64 { return "" }
  // Validate all hex
  let mut j = 0
  while j < 64 {
    if !_is_hex_any(token.substring(j, j + 1)) { return "" }
    j = j + 1
  }
  return _to_lower_hex(token)
}

fn write_sealed_hash(path: string, digest: string) -> void {
  write_file(path, "sha256:" + digest + "\n")
}

fn sync_rules_field(digest: string) -> bool {
  // Write sealed_hash into .readme-rules.json scopes.root via sed/jq fallback.
  // Returns true if file updated, false otherwise. Best-effort, never raises.
  if !_file_exists(RULES_PATH) { return false }
  // Use python json for safe edit (raw 9 honest C3: pure-hexa JSON edit deferred,
  // shell out to python via exec for sync — read_file + manual JSON merge is
  // fragile in pure hexa without proper JSON parser).
  let cmd = "python3 -c \"import json,pathlib; p=pathlib.Path('" + RULES_PATH + "'); d=json.loads(p.read_text()); s=d.get('scopes'); "
    + "import sys; "
    + "_=s and isinstance(s,dict) and (lambda r: (r['sealed_hash']!='" + digest + "') and (r.__setitem__('sealed_hash','" + digest + "') or p.write_text(json.dumps(d,indent=2,ensure_ascii=False)+chr(10)) or print('CHANGED')))(s.get('root') if isinstance(s.get('root'),dict) else None)\" 2>/dev/null"
  let r = to_string(exec(cmd)).trim()
  return r == "CHANGED"
}

fn _short(s: string) -> string {
  if len(s) < 12 { return s }
  return s.substring(0, 12)
}

fn main() -> void {
  if !_file_exists(README_PATH) {
    println("[sealed-check] FATAL: " + README_PATH + " missing — own#14 cannot run")
    exit(2)
  }

  let raw_args = args()
  let mut update_mode = false
  let mut ai = 0
  while ai < len(raw_args) {
    if raw_args[ai] == "--update" { update_mode = true }
    ai = ai + 1
  }

  let current = compute_sha256(README_PATH)
  if len(current) != 64 {
    println("[sealed-check] FATAL: shasum -a 256 failed on README.md")
    exit(2)
  }

  let sealed = read_sealed_hash(SEALED_PATH)

  // First-run / init mode: sealed file missing or non-SHA256 legacy content.
  if len(sealed) == 0 {
    write_sealed_hash(SEALED_PATH, current)
    let changed = sync_rules_field(current)
    println("[sealed-check] INIT: wrote sealed hash sha256:" + _short(current) + "... -> README.md.sealed.hash")
    if changed { println("[sealed-check] INIT: synced sealed_hash into .readme-rules.json scopes.root") }
    println("[sealed-check] warn: first-run initialisation, not blocking. Re-run to enforce.")
    exit(0)
  }

  if update_mode {
    write_sealed_hash(SEALED_PATH, current)
    let _r = sync_rules_field(current)
    println("[sealed-check] UPDATE: new sealed sha256:" + _short(current) + "... (was " + _short(sealed) + "...)")
    exit(0)
  }

  if current == sealed {
    // Keep .readme-rules.json in sync if the field drifted.
    let synced = sync_rules_field(current)
    let mut status = "clean"
    if synced { status = "SYNCED .readme-rules.json" }
    println("[sealed-check] MATCH sha256:" + _short(current) + "... (" + status + ")")
    exit(0)
  }

  println("[sealed-check] FAIL: README.md sha256 drift")
  println("  current : sha256:" + current)
  println("  sealed  : sha256:" + sealed)
  println("  remedy  : re-seal via `hexa tool/readme_sealed_check.hexa --update`")
  exit(1)
}
