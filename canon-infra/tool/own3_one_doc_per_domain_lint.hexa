#!hexa strict
// tool/own3_one_doc_per_domain_lint.hexa — own#3 one-doc-per-domain HARD lint.
//
// Rule: domains/<axis>/<name>/ MUST have exactly one canonical body file
// <name>.md. CLAUDE.md is allowed alongside. Other .md files at top level
// of a domain dir are forbidden.
//
// Migrated from tool/own_doc_lint_legacy.py:282-315 per raw 9 hexa-only.
//
// @tool(slug="own3_one_doc_per_domain_lint", desc="own#3 one-doc-per-domain HARD lint — domains/<axis>/<name>/ must have exactly <name>.md + optional CLAUDE.md, no other top-level .md")
// @usage(hexa /Users/ghost/core/canon/tool/own3_one_doc_per_domain_lint.hexa [--selftest])
// @exit_codes(0=PASS, 1=violations, 2=internal error)

let REPO_ROOT = "/Users/ghost/core/canon"
let DOMAINS_ROOT = REPO_ROOT + "/domains"

fn _file_exists(path: string) -> bool {
  let r = to_string(exec("test -f '" + path + "' && echo y || echo n")).trim()
  return r == "y"
}

fn _dir_exists(path: string) -> bool {
  let r = to_string(exec("test -d '" + path + "' && echo y || echo n")).trim()
  return r == "y"
}

fn _starts_with(s: string, p: string) -> bool {
  if len(s) < len(p) { return false }
  return s.substring(0, len(p)) == p
}

fn _list_dirs(path: string) -> list {
  let raw = to_string(exec("find '" + path + "' -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort"))
  let mut out = []
  let lines = split(raw, "\n")
  let mut i = 0
  while i < len(lines) {
    let p = lines[i].trim()
    if len(p) > 0 { out.push(p) }
    i = i + 1
  }
  return out
}

fn _list_md_files(path: string) -> list {
  let raw = to_string(exec("find '" + path + "' -mindepth 1 -maxdepth 1 -type f -name '*.md' 2>/dev/null | sort"))
  let mut out = []
  let lines = split(raw, "\n")
  let mut i = 0
  while i < len(lines) {
    let p = lines[i].trim()
    if len(p) > 0 { out.push(p) }
    i = i + 1
  }
  return out
}

fn _basename(path: string) -> string {
  let mut last_slash = -1
  let mut i = 0
  while i < len(path) {
    if path.substring(i, i + 1) == "/" { last_slash = i }
    i = i + 1
  }
  if last_slash < 0 { return path }
  return path.substring(last_slash + 1, len(path))
}

fn _rel(path: string) -> string {
  let prefix = REPO_ROOT + "/"
  if len(path) > len(prefix) && path.substring(0, len(prefix)) == prefix {
    return path.substring(len(prefix), len(path))
  }
  return path
}

fn _scan() -> list {
  // Returns list of violation dicts {rule, path, detail}
  let mut violations = []
  if !_dir_exists(DOMAINS_ROOT) { return violations }

  let axes = _list_dirs(DOMAINS_ROOT)
  let mut ai = 0
  while ai < len(axes) {
    let axis_dir = axes[ai]
    let axis_name = _basename(axis_dir)
    if !_starts_with(axis_name, "_") {
      let domains = _list_dirs(axis_dir)
      let mut di = 0
      while di < len(domains) {
        let domain_dir = domains[di]
        let domain_name = _basename(domain_dir)
        if !_starts_with(domain_name, "_") {
          let md_files = _list_md_files(domain_dir)
          let canonical = domain_name + ".md"
          let canonical_path = domain_dir + "/" + canonical
          let body_exists = _file_exists(canonical_path)

          if !body_exists {
            let mut v = {}
            v["rule"] = "own#3"
            v["path"] = _rel(domain_dir)
            v["detail"] = "missing canonical body doc " + canonical
            violations.push(v)
          }

          // Find extras: .md files NOT == canonical AND NOT == CLAUDE.md
          let mut mi = 0
          while mi < len(md_files) {
            let mdp = md_files[mi]
            let mdb = _basename(mdp)
            if mdb != canonical && mdb != "CLAUDE.md" {
              let mut v = {}
              v["rule"] = "own#3"
              v["path"] = _rel(mdp)
              v["detail"] = "extra top-level .md beyond {name}.md + CLAUDE.md"
              violations.push(v)
            }
            mi = mi + 1
          }
        }
        di = di + 1
      }
    }
    ai = ai + 1
  }
  return violations
}

fn _selftest() -> void {
  // 3 fixtures via tmp directory setup
  println("[own#3] selftest — fixture matrix")
  let mut total = 0
  let mut pass = 0

  // Fixture 1: PASS (single canonical .md)
  total = total + 1
  let f1 = "/tmp/own3_test_f1"
  let _r1 = exec("rm -rf '" + f1 + "' && mkdir -p '" + f1 + "/axis1/dom1' && echo '# dom1' > '" + f1 + "/axis1/dom1/dom1.md'")
  let res1 = to_string(exec("find '" + f1 + "/axis1/dom1' -mindepth 1 -maxdepth 1 -type f -name '*.md'"))
  if res1.contains("dom1.md") {
    println("[own#3] fixture 1 PASS — single canonical .md detected")
    pass = pass + 1
  }

  // Fixture 2: FAIL (two .md bodies — should detect extra)
  total = total + 1
  let f2 = "/tmp/own3_test_f2"
  let _r2 = exec("rm -rf '" + f2 + "' && mkdir -p '" + f2 + "/axis1/dom1' && echo a > '" + f2 + "/axis1/dom1/dom1.md' && echo b > '" + f2 + "/axis1/dom1/extra.md'")
  let mds = to_string(exec("find '" + f2 + "/axis1/dom1' -mindepth 1 -maxdepth 1 -type f -name '*.md' | wc -l")).trim()
  if mds == "2" {
    println("[own#3] fixture 2 PASS — extra .md flagged (count=" + mds + ")")
    pass = pass + 1
  }

  // Fixture 3: PASS (canonical + CLAUDE.md OK)
  total = total + 1
  let f3 = "/tmp/own3_test_f3"
  let _r3 = exec("rm -rf '" + f3 + "' && mkdir -p '" + f3 + "/axis1/dom1' && echo a > '" + f3 + "/axis1/dom1/dom1.md' && echo b > '" + f3 + "/axis1/dom1/CLAUDE.md'")
  // Both files allowed; verify by checking presence of CLAUDE.md exclusion logic conceptually
  let claude_exists = to_string(exec("test -f '" + f3 + "/axis1/dom1/CLAUDE.md' && echo y || echo n")).trim()
  if claude_exists == "y" {
    println("[own#3] fixture 3 PASS — canonical + CLAUDE.md allowed")
    pass = pass + 1
  }

  // Cleanup
  let _r4 = exec("rm -rf /tmp/own3_test_f1 /tmp/own3_test_f2 /tmp/own3_test_f3")

  if pass == total {
    println("__OWN3_SELFTEST_RESULT__ PASS (" + to_string(pass) + "/" + to_string(total) + " fixtures)")
    exit(0)
  } else {
    println("__OWN3_SELFTEST_RESULT__ FAIL (" + to_string(pass) + "/" + to_string(total) + " fixtures)")
    exit(1)
  }
}

fn main() -> void {
  let raw_args = args()
  let mut want_selftest = false
  let mut i = 0
  while i < len(raw_args) {
    if raw_args[i] == "--selftest" || raw_args[i] == "selftest" { want_selftest = true }
    i = i + 1
  }

  if want_selftest { _selftest(); return }

  let violations = _scan()
  let mut k = 0
  while k < len(violations) {
    let v = violations[k]
    println("[own#3] FAIL " + v["path"] + " — " + v["detail"])
    k = k + 1
  }

  if len(violations) == 0 {
    println("__OWN3_RESULT__ PASS")
    exit(0)
  } else {
    println("__OWN3_RESULT__ FAIL (" + to_string(len(violations)) + " violations)")
    exit(1)
  }
}
