// sync-products-readme.hexa — products.json SSOT → README.md 자동 동기화
// 원본: scripts/sync_products_readme.py (328줄, R1 HEXA-FIRST 포팅 대상)
// R5 SSOT: products.json 이 원본, README.md 는 생성물
// R19: 에러 발생 시 stderr 출력 후 non-zero 종료
// R29 예외: 계산기/검증기 아닌 sync 유틸이므로 canon/shared/ 유지
//
// ⚠️  2026-04-18 이전 공지:
//   도메인 1:1 SSOT = docs/domains.json 로 이전 완료.
//   이 sync 유틸은 레거시 products.json 을 계속 사용하며 deprecated 경로임.
//   후속 작업: domains.json 기반 README 재렌더링 유틸 작성 후 이 파일 폐기 예정.
//
// 사용법:
//   hexa sync-products-readme.hexa            # 실제 갱신
//   hexa sync-products-readme.hexa --dry-run  # 변경만 출력, 파일 미수정
//
// 환경변수:
//   N6_PRODUCTS_JSON  — products.json 경로 (미지정 시 기본 경로)
//   N6_README_MD      — README.md  경로 (미지정 시 기본 경로)

// ───────── 상수 (R2: 하드코딩 최소화, 환경변수 우선) ─────────
// 2026-04-28 sibling fix mirroring sync-readme.hexa A.1:
//   was `exec("printenv HOME")` — silently empty in busybox container
//   without printenv applet. env_var() goes through hexa_env_var →
//   getenv() at C runtime layer (container-shell-builtin independent).
let mut HOME = ""
try {
    let h = env_var("HOME")
    if type_of(h) == "string" {
        HOME = to_string(h)
    }
} catch err {
    HOME = ""
}
if len(HOME) == 0 {
    HOME = exec("echo \"$HOME\"").trim()
}
// TODO: canonical relocation pending — currently fallback to $HOME/shared/
let DEFAULT_PRODUCTS = HOME + "/shared/n6/docs/products.json"
let DEFAULT_README   = HOME + "/core/canon/README.md"

// ───────── 유틸: 에러 출력 + 종료 ─────────
fn die(msg: string) {
    // R19 SILENT EXIT 금지 — stderr 로 명시 출력 후 exit
    exec("printf '%s\\n' '[sync_products_readme] ERR: " + msg + "' 1>&2")
    exit(1)
}

// ───────── 유틸: 경로 해결 (env → 기본값) ─────────
fn resolve_path(env_key: string, default_path: string) {
    let mut v = ""
    try {
        let raw = env_var(env_key)
        if type_of(raw) == "string" {
            v = raw
        }
    } catch err {
        v = ""
    }
    if len(v) > 0 {
        return v
    }
    return default_path
}

// ───────── 유틸: products.json 로드 ─────────
fn load_products(path: string) {
    if file_exists(path) == false {
        die("products.json 없음: " + path)
    }
    let raw = read_file(path)
    if len(raw) == 0 {
        die("products.json 빈 파일: " + path)
    }
    // 파싱 실패 시 die(), 성공 시 json_parse 결과 반환
    let data = json_parse(raw)
    return data
}

// ───────── 유틸: 안전 필드 접근 ─────────
// 키 없으면 default, 값이 null/nil 이어도 default 반환.
fn get_or(obj, key: string, default_val) {
    try {
        let v = obj[key]
        let t = type_of(v)
        if t == "null" {
            return default_val
        }
        if t == "nil" {
            return default_val
        }
        return v
    } catch err {
        return default_val
    }
}

fn has_field(obj, key: string) {
    try {
        let v = obj[key]
        let t = type_of(v)
        if t == "null" {
            return false
        }
        if t == "nil" {
            return false
        }
        return true
    } catch err {
        return false
    }
}

// ───────── 링크 배열 → "[label](path) · ..." ─────────
fn format_links(links) {
    let mut out = ""
    let mut i = 0
    let n = len(links)
    while i < n {
        let lnk = links[i]
        let label = get_or(lnk, "label", "")
        let path  = get_or(lnk, "path", "")
        if i > 0 {
            out = out + " · "
        }
        out = out + "[" + to_string(label) + "](" + to_string(path) + ")"
        i = i + 1
    }
    return out
}

// ───────── bt 퍼센트 문자열 ─────────
fn bt_pct_str(sec) {
    let disp = get_or(sec, "bt_exact_pct_display", "")
    if type_of(disp) == "string" {
        if len(disp) > 0 {
            return disp
        }
    }
    if has_field(sec, "bt_exact_pct") {
        return to_string(sec["bt_exact_pct"]) + "%"
    }
    return ""
}

// ───────── SUMMARY 블록 생성 ─────────
// 원본 _gen_summary 와 1:1 대응, "> ..." 단일 라인 반환
fn render_summary_block(sec) {
    let mut parts = []
    // [0] 외계지수 + ceiling
    parts.push("**🛸" + to_string(get_or(sec, "alien_index", 0)) + "**")
    if get_or(sec, "ceiling", false) == true {
        parts.push("✅")
    }
    // BT
    let bt_count = get_or(sec, "bt_count", 0)
    let pct = bt_pct_str(sec)
    if bt_count != 0 {
        if len(pct) > 0 {
            parts.push("BT " + to_string(bt_count) + "개 " + pct + "EXACT")
        }
    }
    // summary_extra
    let extra = get_or(sec, "summary_extra", "")
    if type_of(extra) == "string" {
        if len(extra) > 0 {
            parts.push(extra)
        }
    }
    // 산업
    if has_field(sec, "industry_pct") {
        let mut ind = "산업" + to_string(sec["industry_pct"]) + "%"
        let idtl = get_or(sec, "industry_detail", "")
        if type_of(idtl) == "string" {
            if len(idtl) > 0 {
                ind = ind + " (" + idtl + ")"
            }
        }
        parts.push(ind)
    }
    // 실험
    if has_field(sec, "experiment_pct") {
        let mut exp = "실험" + to_string(sec["experiment_pct"]) + "%"
        let edtl = get_or(sec, "experiment_detail", "")
        if type_of(edtl) == "string" {
            if len(edtl) > 0 {
                exp = exp + " " + edtl
            }
        }
        parts.push(exp)
    }
    // 물리한계
    let pl = get_or(sec, "physics_limit_count", 0)
    if pl != 0 {
        parts.push("물리한계" + to_string(pl))
    }
    // TP
    if has_field(sec, "tp_count") {
        parts.push("TP" + to_string(sec["tp_count"]))
    }
    // 발견
    let disc = get_or(sec, "discovery_count", 0)
    if disc != 0 {
        parts.push("발견" + to_string(disc))
    }
    // Mk
    let mk = get_or(sec, "mk_count", 0)
    if mk != 0 {
        parts.push("Mk.V")
    }

    // join with " | "
    return "> " + parts.join(" | ")
}

// ───────── FOOTER 블록 생성 ─────────
fn render_footer_block(sec) {
    let domains = get_or(sec, "domains", [])
    let mut line = "> 도메인: "
    let mut i = 0
    let nd = len(domains)
    while i < nd {
        if i > 0 {
            line = line + " · "
        }
        let d = to_string(domains[i])
        line = line + "[" + d + "/](docs/" + d + "/)"
        i = i + 1
    }
    let tools = get_or(sec, "tools", [])
    let nt = len(tools)
    if nt > 0 {
        line = line + " · 도구: "
        let mut k = 0
        while k < nt {
            if k > 0 {
                line = line + " · "
            }
            line = line + "`" + to_string(tools[k]) + "`"
            k = k + 1
        }
    }
    return line
}

// ───────── 제품 테이블 생성 ─────────
fn render_products_table(sec) {
    let mut out = "| 🛸 | 천장확인 | ver | 완성제품 | 핵심 | 링크 |\n"
    out = out + "|:--:|:--:|:---:|---------|------|------|"
    let prods = get_or(sec, "products", [])
    let n = len(prods)
    let mut i = 0
    while i < n {
        let p = prods[i]
        // visible: false 항목은 README 표에서 제외 (기본값 true → 기존 항목 유지)
        if get_or(p, "visible", true) == false {
            i = i + 1
            continue
        }
        let mut ufo = "—"
        if has_field(p, "ufo") {
            ufo = to_string(p["ufo"])
        }
        let mut ceil = ""
        if get_or(p, "ceiling", false) == true {
            ceil = " ✅"
        }
        let ver = to_string(get_or(p, "ver", ""))
        let name = "**" + to_string(get_or(p, "name", "")) + "**"
        let desc = to_string(get_or(p, "description", ""))
        let links = get_or(p, "links", [])
        let links_str = format_links(links)
        out = out + "\n| " + ufo + " |" + ceil + " | " + ver + " | " + name + " | " + desc + " | " + links_str + " |"
        i = i + 1
    }
    return out
}

// ───────── BATTERY_SCALE 서브블록 생성 ─────────
// battery_scales 배열 → 크기별×사용별 테이블 (에너지 섹션 전용)
fn render_battery_scale_block(sec) {
    let scales = get_or(sec, "battery_scales", [])
    let n = len(scales)
    if n == 0 {
        return ""
    }
    let mut out = "### 🔋 궁극의 배터리 8단 — 크기별 × 사용별\n\n"
    out = out + "> 18650 셀 → 모듈 → 팩 → ESS → 그리드 — n=6 동일 산술이 **전 스케일을 관통**한다.\n\n"
    out = out + "| 단 | 🛸 | 천장 | 스케일 | 용량 | 대표 용도 | n=6 핵심 | 문서 |\n"
    out = out + "|:--:|:--:|:--:|--------|------|----------|----------|------|"
    let mut i = 0
    while i < n {
        let s = scales[i]
        let stage    = to_string(get_or(s, "stage", ""))
        let ufo      = to_string(get_or(s, "ufo", "—"))
        let mut ceil = ""
        if get_or(s, "ceiling", false) == true {
            ceil = "✅"
        }
        let scale    = to_string(get_or(s, "scale", ""))
        let capacity = to_string(get_or(s, "capacity", ""))
        let usage    = to_string(get_or(s, "usage", ""))
        let n6_key   = to_string(get_or(s, "n6_key", ""))
        let link     = to_string(get_or(s, "link", ""))
        let mut link_str = ""
        if len(link) > 0 {
            link_str = "[문서](" + link + ")"
        }
        out = out + "\n| " + stage + " | " + ufo + " | " + ceil + " | " + scale + " | **" + capacity + "** | " + usage + " | " + n6_key + " | " + link_str + " |"
        i = i + 1
    }
    // 공통 돌파 footer
    let footer = get_or(sec, "battery_scales_footer", "")
    if type_of(footer) == "string" {
        if len(footer) > 0 {
            out = out + "\n\n> **공통 돌파**: " + footer
        }
    }
    return out
}

// ───────── ALIEN_INDEX 테이블 ─────────
fn render_alien_index(data) {
    let mut out = "| 섹션 | 🛸 구현 | 천장확인 | BT검증 | 산업검증 | 실험검증 | TP | 발견 |\n"
    out = out + "|------|:------:|:------:|:------:|:-------:|:-------:|:--:|:----:|"

    let sections = get_or(data, "sections", [])
    // _meta 는 객체이지만 fallback 은 단순한 배열로 — 없으면 order 도 비어있음
    let mut order = []
    if has_field(data, "_meta") {
        let meta = data["_meta"]
        order = get_or(meta, "alien_index_order", [])
    }

    // id → section 맵을 배열 선형 탐색으로 대체
    let mut oi = 0
    let no = len(order)
    while oi < no {
        let sid = to_string(order[oi])
        oi = oi + 1
        // 선형 탐색 — 찾으면 즉시 처리, 못 찾으면 다음 sid
        let mut si = 0
        let ns = len(sections)
        let mut found_idx = -1
        while si < ns {
            let s = sections[si]
            if to_string(get_or(s, "id", "")) == sid {
                found_idx = si
                break
            }
            si = si + 1
        }
        if found_idx < 0 {
            continue
        }
        let sec = sections[found_idx]

        let icon = to_string(get_or(sec, "icon", ""))
        let title = to_string(get_or(sec, "title", ""))
        let ai = to_string(get_or(sec, "alien_index", ""))
        let mut ceil = "❌"
        if get_or(sec, "ceiling", false) == true {
            ceil = "✅"
        }

        // BT
        let mut bt_str = "—"
        let disp = get_or(sec, "bt_exact_pct_display", "")
        if type_of(disp) == "string" {
            if len(disp) > 0 {
                bt_str = disp
            }
        }
        if bt_str == "—" {
            if has_field(sec, "bt_exact_pct") {
                bt_str = to_string(sec["bt_exact_pct"]) + "%"
            }
        }

        // Industry
        let mut ind_str = "—"
        if has_field(sec, "industry_pct") {
            ind_str = to_string(sec["industry_pct"]) + "%"
            let idtl = get_or(sec, "industry_detail", "")
            if type_of(idtl) == "string" {
                if len(idtl) > 0 {
                    ind_str = ind_str + " (" + idtl + ")"
                }
            }
        } else {
            let idtl = get_or(sec, "industry_detail", "")
            if type_of(idtl) == "string" {
                if len(idtl) > 0 {
                    ind_str = "(" + idtl + ")"
                }
            }
        }

        // Experiment
        let mut exp_str = "—"
        if has_field(sec, "experiment_pct") {
            exp_str = to_string(sec["experiment_pct"]) + "%"
            let edtl = get_or(sec, "experiment_detail", "")
            if type_of(edtl) == "string" {
                if len(edtl) > 0 {
                    exp_str = exp_str + " " + edtl
                }
            }
        } else {
            let edtl = get_or(sec, "experiment_detail", "")
            if type_of(edtl) == "string" {
                if len(edtl) > 0 {
                    exp_str = edtl
                }
            }
        }

        // TP / Discovery
        let mut tp_str = "—"
        if has_field(sec, "tp_count") {
            tp_str = to_string(sec["tp_count"])
        }
        let mut disc_str = "—"
        if has_field(sec, "discovery_count") {
            disc_str = to_string(sec["discovery_count"])
        }

        let anchor = to_string(get_or(sec, "anchor", ""))
        let sec_link = "[" + icon + " " + title + "](#" + anchor + ")"

        out = out + "\n| " + sec_link + " | 🛸" + ai + " | " + ceil + " | " + bt_str + " | " + ind_str + " | " + exp_str + " | " + tp_str + " | " + disc_str + " |"
    }
    return out
}

// ───────── STATS 블록 (전체 통계 요약 1~2줄) ─────────
fn render_stats(data) {
    let mut total_products = "0"
    let mut total_domains = "0"
    let mut total_papers = "0"
    let mut last_updated = ""
    if has_field(data, "_meta") {
        let meta = data["_meta"]
        total_products = to_string(get_or(meta, "total_products", 0))
        total_domains  = to_string(get_or(meta, "total_domains", 0))
        total_papers   = to_string(get_or(meta, "total_papers", 0))
        last_updated   = to_string(get_or(meta, "last_updated", ""))
    }
    let sections = get_or(data, "sections", [])
    let section_count = to_string(len(sections))
    let mut line = "> 완성제품 " + total_products + "개 · 도메인 " + total_domains + "개 · 섹션 " + section_count + "개 · 논문 " + total_papers + "편"
    if len(last_updated) > 0 {
        line = line + " · 갱신 " + last_updated
    }
    return line
}

// ───────── 마커 블록 치환 ─────────
// <!-- AUTO:NAME:START --> ~ <!-- AUTO:NAME:END --> 사이를 new_content 로 교체
fn replace_marker(text: string, name: string, new_content: string) {
    let start_tag = "<!-- AUTO:" + name + ":START -->"
    let end_tag   = "<!-- AUTO:" + name + ":END -->"
    let s = text.index_of(start_tag)
    if s < 0 {
        return text
    }
    let e = text.index_of(end_tag)
    if e < 0 {
        return text
    }
    if e < s {
        return text
    }
    let before = text.substring(0, s + len(start_tag))
    let after  = text.substring(e, len(text))
    return before + "\n" + new_content + "\n" + after
}

// ───────── 제품 테이블 영역 치환 ─────────
// SUMMARY_<id>:END 와 FOOTER_<id>:START 사이에서 '| 🛸 |' 로 시작하는 테이블만 교체.
// 표가 없으면 블록 시작에 새로 삽입.
fn replace_products_table(text: string, section_id: string, products_content: string) {
    let sum_end = "<!-- AUTO:SUMMARY_" + section_id + ":END -->"
    let foot_start = "<!-- AUTO:FOOTER_" + section_id + ":START -->"

    let idx_sum = text.index_of(sum_end)
    if idx_sum < 0 {
        return text
    }
    let idx_foot = text.index_of(foot_start)
    if idx_foot < 0 {
        return text
    }
    let after_sum = idx_sum + len(sum_end)
    if idx_foot <= after_sum {
        return text
    }

    let between = text.substring(after_sum, idx_foot)
    let lines = between.split("\n")
    let nl = len(lines)

    // 1차 스캔: 표 시작/끝 찾기
    let mut table_start = -1
    let mut table_end = -1
    let mut in_table = false
    let mut li = 0
    while li < nl {
        let raw_ln = lines[li]
        let stripped = raw_ln.trim()
        if table_start < 0 {
            if stripped.starts_with("| 🛸 |") {
                table_start = li
                in_table = true
            }
        } else {
            if in_table == true {
                if stripped.starts_with("|") == false {
                    table_end = li
                    in_table = false
                    break
                }
            }
        }
        li = li + 1
    }

    // 표 없음 → 블록 시작 직후에 삽입
    if table_start < 0 {
        let new_between = "\n\n" + products_content + "\n\n"
        return text.substring(0, after_sum) + new_between + text.substring(idx_foot, len(text))
    }

    // table_end 미정 → 끝까지. 뒤쪽 빈줄은 trim (post_table 로 보존)
    if table_end < 0 {
        table_end = nl
        while table_end > table_start {
            let tail = lines[table_end - 1].trim()
            if len(tail) == 0 {
                table_end = table_end - 1
            } else {
                break
            }
        }
    }

    // 재조립
    let mut new_between = ""
    let mut k = 0
    while k < table_start {
        if k > 0 {
            new_between = new_between + "\n"
        }
        new_between = new_between + lines[k]
        k = k + 1
    }
    // 표 자리
    if table_start > 0 {
        new_between = new_between + "\n"
    }
    new_between = new_between + products_content
    // 뒤쪽
    let mut m = table_end
    while m < nl {
        new_between = new_between + "\n" + lines[m]
        m = m + 1
    }

    return text.substring(0, after_sum) + new_between + text.substring(idx_foot, len(text))
}

// ───────── 원자적 쓰기: temp → rename ─────────
fn write_readme(path: string, text: string) {
    let tmp = path + ".tmp.sync"
    write_file(tmp, text)
    exec("mv -f '" + tmp + "' '" + path + "'")
}

// ───────── MAIN ─────────
fn main() {
    // CLI 파싱
    let a = args()
    let mut dry_run = false
    let mut ai = 0
    let na = len(a)
    while ai < na {
        if to_string(a[ai]) == "--dry-run" {
            dry_run = true
        }
        ai = ai + 1
    }

    let products_path = resolve_path("N6_PRODUCTS_JSON", DEFAULT_PRODUCTS)
    let readme_path   = resolve_path("N6_README_MD",     DEFAULT_README)

    println("[sync_products_readme] products=" + products_path)
    println("[sync_products_readme] readme  =" + readme_path)
    if dry_run == true {
        println("[sync_products_readme] mode    =DRY-RUN")
    } else {
        println("[sync_products_readme] mode    =WRITE")
    }

    // 1. 로드
    let data = load_products(products_path)
    if file_exists(readme_path) == false {
        die("README.md 없음: " + readme_path)
    }
    let original = read_file(readme_path)
    let mut readme_text = original

    // 2. ALIEN_INDEX
    let alien_content = render_alien_index(data)
    readme_text = replace_marker(readme_text, "ALIEN_INDEX", alien_content)
    println("  [OK] ALIEN_INDEX 치환")

    // 3. STATS
    let stats_content = render_stats(data)
    readme_text = replace_marker(readme_text, "STATS", stats_content)
    println("  [OK] STATS 치환")

    // 4. 각 섹션 SUMMARY + FOOTER + 제품테이블
    let sections = get_or(data, "sections", [])
    let ns = len(sections)
    let mut si = 0
    while si < ns {
        let sec = sections[si]
        let sid = to_string(get_or(sec, "id", ""))
        if len(sid) == 0 {
            si = si + 1
            continue
        }
        let summary = render_summary_block(sec)
        readme_text = replace_marker(readme_text, "SUMMARY_" + sid, summary)

        let table = render_products_table(sec)
        readme_text = replace_products_table(readme_text, sid, table)

        // BATTERY_SCALE — energy 섹션 전용 서브블록
        if has_field(sec, "battery_scales") {
            let batt = render_battery_scale_block(sec)
            if len(batt) > 0 {
                readme_text = replace_marker(readme_text, "BATTERY_SCALE", batt)
                println("  [OK] BATTERY_SCALE 치환 (" + to_string(len(get_or(sec, "battery_scales", []))) + "단)")
            }
        }

        let footer = render_footer_block(sec)
        readme_text = replace_marker(readme_text, "FOOTER_" + sid, footer)

        println("  [OK] " + sid + ": SUMMARY + 제품테이블 + FOOTER 치환")
        si = si + 1
    }

    // 5. 쓰기 / 드라이런
    if dry_run == true {
        println("")
        println("[DRY-RUN] README.md 변경 없음")
        if readme_text != original {
            let old_lines = original.split("\n")
            let new_lines = readme_text.split("\n")
            println("  변경: " + to_string(len(old_lines)) + "줄 -> " + to_string(len(new_lines)) + "줄")
        } else {
            println("  변경 없음")
        }
    } else {
        if readme_text != original {
            write_readme(readme_path, readme_text)
            let old_lines = original.split("\n")
            let new_lines = readme_text.split("\n")
            println("")
            println("[DONE] README.md 갱신 완료 (" + to_string(len(old_lines)) + "줄 -> " + to_string(len(new_lines)) + "줄)")
        } else {
            println("")
            println("[DONE] 변경 없음 (이미 최신)")
        }
    }
}

main()
