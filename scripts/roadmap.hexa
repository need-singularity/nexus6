// roadmap.hexa — nexus 로드맵 어댑터
//
// 위임: shared/tool/roadmap_guard.hexa (--project nexus 고정)
// 사용: $HEXA scripts/roadmap.hexa [verify|artifacts|status|all]
//
// SSOT: shared/roadmaps/nexus.json

fn main() {
    let a = args()
    let cmd = if len(a) >= 3 { a[2] } else { "status" }

    let g = env("HOME") + "/Dev/nexus/tool/roadmap_guard.hexa"
    let h = env("HOME") + "/Dev/hexa-lang/hexa"

    let call = h + " " + g + " " + cmd + " --project nexus"
    let rc = to_string(exec(call))
    print(rc)
}

main()
