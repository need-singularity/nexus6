// MOVED → hexa shared/tool/sync.hexa lenses  (이 파일은 백호환 shim, v2 에서 제거 예정)
// sync-nexus-lenses.hexa — NEXUS-6 렌즈 수 동기화 (sync-nexus-lenses.sh 대체)
// 원본: nexus telescope_test.rs 어서션 → CLAUDE.md + installed_tools.json + calculators.json
// 사용: hexa shared/scripts/sync-nexus-lenses.hexa

let HOME = env("HOME")
let SHARED_DIR = HOME + "/core/nexus/scripts"
let BASE = HOME + "/core/nexus/shared"
let PARENT = HOME + "/Dev"
let N6_DIR = PARENT + "/n6-architecture"
let NEXUS_DIR = N6_DIR + "/tools/nexus"
let STATE_FILE = SHARED_DIR + "/.sync_state.json"
let SYNC_KEY = "sync-nexus-lenses"

// --- delta 검출 ---
fn _md5(path: str) -> str {
    return to_string(exec("md5 -q '" + path + "' 2>/dev/null || md5sum '" + path + "' | cut -d' ' -f1")).trim()
}

fn _load_state() -> str {
    if file_exists(STATE_FILE) { return read_file(STATE_FILE) }
    return "{}"
}

fn _get_stored_hash(state_raw: str, key: str) -> str {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = state_raw
    let _ = key
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync-nexus-lenses.hexa:_get_stored_hash. Escalate to user for hexa-native replacement.")
    return ""
}

fn _save_hash(key: str, hash_val: str) {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = _load_state()
    let _ = key
    let _ = hash_val
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync-nexus-lenses.hexa:_save_hash. Escalate to user for hexa-native replacement.")
}

// 소스 해시: telescope_test.rs (렌즈 수 소스)
let test_file_path = NEXUS_DIR + "/tests/telescope_test.rs"
let src_hash = if file_exists(test_file_path) { _md5(test_file_path) } else {
    // fallback: telescope src 디렉토리 전체
    to_string(exec("bash -c \"cat '" + NEXUS_DIR + "/src/telescope/'*.rs 2>/dev/null | md5 -q 2>/dev/null || cat '" + NEXUS_DIR + "/src/telescope/'*.rs 2>/dev/null | md5sum | cut -d' ' -f1\"")).trim()
}

let state_raw = _load_state()
let stored = _get_stored_hash(state_raw, SYNC_KEY)

if src_hash == stored && src_hash != "" {
    println("=== NEXUS-6 렌즈 동기화: up-to-date (delta skip) ===")
    exit(0)
}
// --- delta 검출 끝 ---

println("=== NEXUS-6 렌즈 동기화 ===")
println("")

// 1단계: 소스에서 렌즈 수 추출
println("[1/5] 소스에서 렌즈 수 추출 중...")

let test_file = NEXUS_DIR + "/tests/telescope_test.rs"
let test_ok = to_string(exec("test -f '" + test_file + "' && echo y || echo n")).trim()

let mut total = "0"
let mut core = "22"
let mut extended = "0"

if test_ok == "y" {
    let t = to_string(exec("grep -oE 'reg\\.len\\(\\),\\s*[0-9]+' '" + test_file + "' | head -1 | grep -oE '[0-9]+$' 2>/dev/null")).trim()
    if len(t) > 0 { total = t }
    let c = to_string(exec("grep -oE 'cores\\.len\\(\\),\\s*[0-9]+' '" + test_file + "' | head -1 | grep -oE '[0-9]+$' 2>/dev/null")).trim()
    if len(c) > 0 { core = c }
    let e = to_string(exec("grep -oE 'extended\\.len\\(\\),\\s*[0-9]+' '" + test_file + "' | head -1 | grep -oE '[0-9]+$' 2>/dev/null")).trim()
    if len(e) > 0 { extended = e }
} else {
    // fallback: 소스 파일에서 LensEntry 수
    let tel_dir = NEXUS_DIR + "/src/telescope"
    let tel_ok = to_string(exec("test -d '" + tel_dir + "' && echo y || echo n")).trim()
    if tel_ok == "n" {
        println("오류: " + tel_dir + " 없음")
        exit(1)
    }
    total = to_string(exec("grep -c 'LensEntry {' '" + tel_dir + "'/*.rs 2>/dev/null || echo 0")).trim()
    extended = to_string(to_int(total) - to_int(core))
}

println("  합계: " + total + " 렌즈 (코어: " + core + ", 확장: " + extended + ")")
println("")

if total == "0" {
    println("오류: 렌즈 수 추출 실패")
    exit(1)
}

// 2단계: 모듈별 분석
println("[2/5] 모듈별 분석 중...")
if test_ok == "y" {
    let entries_lines = to_string(exec("grep 'entries\\.len()' '" + test_file + "' 2>/dev/null")).trim()
    for line in entries_lines.split("\n") {
        let l = line.trim()
        if len(l) > 0 { println("  " + l) }
    }
}
println("")

// 3단계: CLAUDE.md 갱신
println("[3/5] CLAUDE.md 갱신 중...")
let mut changed = 0

let claude_md = SHARED_DIR + "/CLAUDE.md"
let cmd_ok = to_string(exec("test -f '" + claude_md + "' && echo y || echo n")).trim()
if cmd_ok == "y" {
    let text = read_file(claude_md)
    let mut updated = text

    // 패턴 치환: NEXUS-6 망원경 (NNN종 렌즈) 등
    let patterns_to_check = [
        "종 렌즈 레지스트리",
        "종 레지스트리",
        "종 렌즈)"
    ]

    // sed로 일괄 치환 (정규식)
    let result = to_string(exec("bash -c \"cd /tmp && cat '" + claude_md + "' | sed -E 's/[0-9]+종 렌즈 레지스트리/" + total + "종 렌즈 레지스트리/g; s/[0-9]+종 레지스트리/" + total + "종 레지스트리/g; s/NEXUS-6 망원경 \\([0-9]+종 렌즈\\)/NEXUS-6 망원경 (" + total + "종 렌즈)/g; s/NEXUS-6 \\([0-9]+종\\)/NEXUS-6 (" + total + "종)/g; s/렌즈 [0-9]+종 구성/렌즈 " + total + "종 구성/g'\"")).trim()

    if result != text.trim() {
        write_file(claude_md, result + "\n")
        println("  갱신 완료")
        changed = 1
    } else {
        println("  이미 최신")
    }
} else {
    println("  SKIP: " + claude_md + " 없음")
}
println("")

// 4단계: installed_tools.json 갱신
println("[4/5] installed_tools.json 갱신 중...")
let tools_json = SHARED_DIR + "/installed_tools.json"
let tj_ok = to_string(exec("test -f '" + tools_json + "' && echo y || echo n")).trim()
if tj_ok == "y" {
    let new_purpose = "NEXUS-6 Discovery Engine -- telescope " + total + " lenses + OUROBOROS evolution + graph + verifier"
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    // Original: python3 JSON update installed_tools.json cli_tools.nexus.purpose
    let _ = new_purpose
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync-nexus-lenses.hexa:installed_tools update. Escalate to user for hexa-native replacement.")
    println("  SKIP: R37 python3 차단")
} else {
    println("  SKIP: " + tools_json + " 없음")
}
println("")

// 5단계: calculators.json 갱신
println("[5/5] calculators.json 갱신 중...")
let calc_json = SHARED_DIR + "/calculators.json"
let cj_ok = to_string(exec("test -f '" + calc_json + "' && echo y || echo n")).trim()
if cj_ok == "y" {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    // Original: python3 JSON update calculators.json description field
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync-nexus-lenses.hexa:calculators update. Escalate to user for hexa-native replacement.")
    println("  SKIP: R37 python3 차단")
} else {
    println("  SKIP: " + calc_json + " 없음")
}
println("")

// 커밋 (푸시 안 함)
if changed > 0 {
    println("=== 변경 커밋 중 ===")
    try {
        exec("bash", ["-c", "cd '" + BASE + "' && git add .shared/CLAUDE.md .shared/config/installed_tools.json .shared/config/calculators.json 2>/dev/null; git diff --cached --quiet 2>/dev/null || git commit -m '동기화: NEXUS-6 렌즈 수 -> " + total + " (자동)'"])
        println("  커밋 완료! (푸시는 수동)")
    } catch e {
        println("  커밋 스킵")
    }
} else {
    println("=== 변경 없음 ===")
}

println("")
println("완료! NEXUS-6 렌즈 수: " + total)
println("  코어: " + core)
println("  확장: " + extended)

// delta 상태 저장
_save_hash(SYNC_KEY, src_hash)
