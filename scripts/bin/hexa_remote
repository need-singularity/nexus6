#!/bin/bash
# hexa_remote — rsync + ssh wrapper to run hexa on a remote host (ubu1 default).
# Purpose: AG6 Mac-compute-ZERO — heavy hexa work offloaded to ubu1/hetzner.
#
# Eligibility is decided by the caller (shared/scripts/bin/hexa resolver).
# This script trusts inputs and performs:
#   1. Path mapping: $HOME/Dev/airgenome → ~/airgenome, $HOME/Dev/nexus → ~/Dev/nexus
#   2. Incremental rsync of the project root to the remote
#   3. ssh -T exec of hexa with the same args, at mapped cwd
#
# Env:
#   HEXA_REMOTE_HOST             remote host (default: ubu1)
#   HEXA_REMOTE_BIN              remote hexa path (default: $HOME/.hx/bin/hexa_real)
#   HEXA_REMOTE_NO_SYNC          skip rsync (assume tree already fresh)
#   HEXA_REMOTE_CONNECT_TIMEOUT  ssh ConnectTimeout seconds (default: 8)
#   HEXA_REMOTE_PROBE_RETRY      probe retry count on fail (default: 1)
#
# Exit 64 → caller should fall back to local (cwd not mappable).

set -u

# Pick host. Priority: HEXA_REMOTE_HOST env → dispatch_state.json compute → ubu1.
# Zero-defect reachability (2026-04-20, 2026-04-22 htz 추가):
#   - multi-host fallback: preferred → ubu1 → ubu2 → htz (host sshd 22/TCP, hexa binary 위치에 직결)
#   - ConnectTimeout 3→8s (heavy load 대응)
#   - ServerAliveInterval 로 BannerTimeout hang 방지
#   - 최초 probe 실패 시 다음 후보로 (이전엔 exit 64 즉시 fallback → Mac SIGKILL)
#   - 2026-04-22: htz(hetzner anima-ax102) 를 자동 fallback 체인 말단에 포함 —
#     ubu1/ubu2 동시 장애(LAN 이슈) 시 compute 복원 경로 확보.
#     (airgenome offload 쪽에서 htz alias 재사용, ssh config Host htz → 157.180.8.154.)
pick_preferred_host() {
    if [ -n "${HEXA_REMOTE_HOST:-}" ]; then
        printf '%s' "$HEXA_REMOTE_HOST"; return
    fi
    local state="$HOME/Dev/nexus/shared/dispatch_state.json"
    if [ -r "$state" ] && command -v jq >/dev/null 2>&1; then
        local h
        h="$(jq -r '.selection.compute // "ubu1"' "$state" 2>/dev/null)"
        case "$h" in
            ubu1|ubu2) printf '%s' "$h"; return ;;
            none|mac|htz|hetzner|"") ;;
        esac
    fi
    printf 'ubu1'
}
_probe_host() {
    local cand="$1"
    local err rc attempt
    # Env-tunable: HEXA_REMOTE_CONNECT_TIMEOUT (default 8), HEXA_REMOTE_PROBE_RETRY (default 1).
    local ctimeout="${HEXA_REMOTE_CONNECT_TIMEOUT:-8}"
    local retry="${HEXA_REMOTE_PROBE_RETRY:-1}"
    local total=$((retry + 1))
    local reason="unknown"
    attempt=0
    while [ $attempt -lt $total ]; do
        err="$(ssh -o ConnectTimeout=$ctimeout -o BatchMode=yes -o ServerAliveInterval=5 \
            -o ServerAliveCountMax=1 \
            -o ControlPath=/tmp/ssh-nexus-%r@%h:%p "$cand" true 2>&1 1>/dev/null)"
        rc=$?
        if [ $rc -eq 0 ]; then
            return 0
        fi
        attempt=$((attempt + 1))
    done
    reason="unknown(rc=$rc)"
    case "$err" in
        *"Could not resolve hostname"*|*"Name or service not known"*|*"nodename nor servname"*)
            reason="DNS 해석 실패" ;;
        *"Connection refused"*)
            reason="SSH 거부 (sshd down? 포트 차단?)" ;;
        *"Permission denied"*|*"publickey"*|*"Authentication failed"*)
            reason="인증 실패 (키/agent 확인)" ;;
        *"Connection timed out"*|*"Operation timed out"*|*"timed out"*)
            reason="타임아웃 (네트워크/방화벽)" ;;
        *"Host key verification failed"*)
            reason="호스트 키 불일치" ;;
        *"No route to host"*)
            reason="라우팅 없음" ;;
        *)
            [ -n "$err" ] && reason="$(printf '%s' "$err" | tail -n 1)" ;;
    esac
    echo "hexa_remote: host=$cand 실패: $reason" >&2
    return $rc
}

PREFERRED="$(pick_preferred_host)"
# Normalize htz → hetzner (ssh config 의 canonical alias).
[ "$PREFERRED" = "htz" ] && PREFERRED="hetzner"

# Build fallback chain — preferred 먼저, 그 다음 ubu1/ubu2/htz (compute host).
# 2026-04-22: htz 를 체인 말단에 추가. ubu1/ubu2 동시 unreachable (LAN 장애) 시에도
# remote dispatch 가 hetzner anima-ax102 로 복원되도록. htz alias 는 ssh config
# (Host hetzner htz htz1) 에서 157.180.8.154 (root) 로 풀림 — airgenome 쪽과 동일.
FALLBACK_CHAIN="$PREFERRED"
for cand in ubu1 ubu2 htz; do
    case " $FALLBACK_CHAIN " in
        *" $cand "*) ;;
        *) FALLBACK_CHAIN="$FALLBACK_CHAIN $cand" ;;
    esac
done

# 2026-04-22: preflight — parallel 300ms TCP probe of $FALLBACK_CHAIN via
# $HEXA_LANG/gate/remote_preflight.hexa (hexa-lang PR#24). Fast-path exit 64
# when all hosts are down, instead of paying per-host ConnectTimeout×N.
# Disable with HEXA_REMOTE_SKIP_PREFLIGHT=1. Stderr JSON verdict parsing is
# used (preflight's own exit code is informational-only until its exit(74)
# bug is fixed upstream).
_PREFLIGHT_SRC="${HEXA_LANG:-$HOME/core/hexa-lang}/gate/remote_preflight.hexa"
_PREFLIGHT_BIN="${HEXA_BIN:-$HOME/.hx/bin/hexa}"
if [ "${HEXA_REMOTE_SKIP_PREFLIGHT:-0}" != "1" ] \
   && [ -f "$_PREFLIGHT_SRC" ] \
   && [ -x "$_PREFLIGHT_BIN" ]; then
    _pf_csv="$(printf '%s' "$FALLBACK_CHAIN" | tr ' ' ',')"
    _pf_out="$("$_PREFLIGHT_BIN" run "$_PREFLIGHT_SRC" \
        --hosts "$_pf_csv" \
        --timeout-ms "${HEXA_REMOTE_PREFLIGHT_TIMEOUT_MS:-300}" 2>&1 1>/dev/null || true)"
    case "$_pf_out" in
        *'"verdict":"all_unreachable"'*)
            echo "hexa_remote: preflight — all hosts unreachable (tried: $FALLBACK_CHAIN), fast-aborting" >&2
            _pf_hosts_json=""
            for _h in $FALLBACK_CHAIN; do
                if [ -z "$_pf_hosts_json" ]; then _pf_hosts_json="\"$_h\""
                else _pf_hosts_json="$_pf_hosts_json,\"$_h\""; fi
            done
            printf 'NEXUS_REMOTE_ERROR {"hosts_tried":[%s],"reason":"all_unreachable_preflight","exit_code":64}\n' "$_pf_hosts_json" >&2
            exit 64
            ;;
    esac
fi

HOST=""
for cand in $FALLBACK_CHAIN; do
    if _probe_host "$cand"; then
        HOST="$cand"
        [ "$PREFERRED" != "$cand" ] && echo "hexa_remote: $PREFERRED unreachable, using $cand" >&2
        break
    fi
done

if [ -z "$HOST" ]; then
    echo "hexa_remote: all hosts unreachable (tried: $FALLBACK_CHAIN), falling back to local" >&2
    # AI-native JSON emit — caller (shared/scripts/bin/hexa) parses to decide exit 64 vs 74.
    # Build JSON host array from FALLBACK_CHAIN (space-separated).
    _hosts_json=""
    for _h in $FALLBACK_CHAIN; do
        if [ -z "$_hosts_json" ]; then
            _hosts_json="\"$_h\""
        else
            _hosts_json="$_hosts_json,\"$_h\""
        fi
    done
    printf 'NEXUS_REMOTE_ERROR {"hosts_tried":[%s],"reason":"all_unreachable","exit_code":64}\n' "$_hosts_json" >&2
    exit 64
fi

# 2026-04-22: 구 default ($HOME/Dev/hexa-lang/hexa) 는 4월14 빌드 — `^` / `&` 비트연산자 파서 미지원.
#   ubu1 기준 $HOME/.hx/bin/hexa_real 은 4월19+ 빌드 — run.hexa line 1048 ($HOME/.hx/packages/nexus/cli/run.hexa FNV-hash) 파싱 성공.
#   rebuild 전까지 default 교체.
REMOTE_HEXA="${HEXA_REMOTE_BIN:-\$HOME/.hx/bin/hexa_real}"

CWD="$(pwd -P)"
# macOS case-insensitive FS: lowercase for detection only; preserve CWD for rsync source.
CWD_LC="$(printf '%s' "$CWD" | tr '[:upper:]' '[:lower:]')"
HOME_LC="$(printf '%s' "$HOME" | tr '[:upper:]' '[:lower:]')"
case "$CWD_LC" in
  "$HOME_LC/dev/airgenome"|"$HOME_LC/dev/airgenome"/*)
    LOCAL_ROOT="${CWD%%/[Aa]irgenome*}/airgenome"
    # actual path might be /Users/ghost/Dev/airgenome or /Users/ghost/dev/airgenome.
    # Pick whichever exists.
    for candidate in "$HOME/Dev/airgenome" "$HOME/dev/airgenome"; do
        [ -d "$candidate" ] && LOCAL_ROOT="$candidate" && break
    done
    REMOTE_ROOT='$HOME/airgenome'
    SYNC_EXCLUDES=(--exclude=archive/v1/ --exclude=data/ --exclude=__pycache__/
                   --exclude=.git/ --exclude='*.log' --exclude=.DS_Store)
    ;;
  "$HOME_LC/dev/nexus"|"$HOME_LC/dev/nexus"/*|"$HOME_LC/core/nexus"|"$HOME_LC/core/nexus"/*)
    # 2026-04-22: $HOME/core/nexus 는 $HOME/Dev/nexus 의 canonical 물리 경로.
    # pwd -P 가 symlink 를 해제해 cwd 는 항상 core/ → LOCAL_ROOT 도 core/ 우선이라야
    # CWD_LC prefix strip (REL) 이 빈 문자열이 되고 REMOTE_ROOT 로 정확 dispatch 된다.
    for candidate in "$HOME/core/nexus" "$HOME/Dev/nexus" "$HOME/dev/nexus"; do
        [ -d "$candidate" ] && LOCAL_ROOT="$candidate" && break
    done
    REMOTE_ROOT='$HOME/Dev/nexus'
    SYNC_EXCLUDES=(--exclude=.git/ --exclude='*.log' --exclude=.DS_Store
                   --exclude=.runtime/ --exclude=shared/blowup/lens/)
    ;;
  "$HOME_LC/dev/anima"|"$HOME_LC/dev/anima"/*)
    for candidate in "$HOME/Dev/anima" "$HOME/dev/anima"; do
        [ -d "$candidate" ] && LOCAL_ROOT="$candidate" && break
    done
    REMOTE_ROOT='$HOME/anima'
    # anima = 87GB, mostly data/artifacts. Sync only source code paths;
    # exclude large data trees. Local anima-engines/ is ~1.2MB.
    SYNC_EXCLUDES=(
        --exclude=.git/
        --exclude='*.log'
        --exclude=.DS_Store
        --exclude=__pycache__/
        --exclude=ready/
        --exclude=checkpoints/
        --exclude=models/
        --exclude=data/
        --exclude=shared/
        --exclude=logs/
        --exclude=training/
        --exclude=docs/
        --exclude=bench/
        --exclude=.claude-memory/
        --exclude=.growth/
        --exclude=.claude/
    )
    ;;
  "$HOME_LC/core/n6-architecture"|"$HOME_LC/core/n6-architecture"/*)
    # 2026-04-24: n6-architecture remote dispatch — heavy-compute must offload
    # to ubu/htz same as sister Dev/core repos. Without this branch, exit 64
    # at cwd-unmappable fallthrough -> outer wrapper Darwin heavy-compute abort-74.
    for candidate in "$HOME/core/n6-architecture"; do
        [ -d "$candidate" ] && LOCAL_ROOT="$candidate" && break
    done
    REMOTE_ROOT='$HOME/core/n6-architecture'
    SYNC_EXCLUDES=(
        --exclude=.git/
        --exclude='*.log'
        --exclude=.DS_Store
        --exclude=__pycache__/
        --exclude=.claude/
        --exclude=.growth/
        --exclude=reports/history/
        --exclude=build/
    )
    ;;
  *)
    exit 64 ;;
esac

# Relative path from LOCAL_ROOT (case-insensitive strip).
LOCAL_ROOT_LC="$(printf '%s' "$LOCAL_ROOT" | tr '[:upper:]' '[:lower:]')"
REL="${CWD_LC#$LOCAL_ROOT_LC}"
REL="${REL#/}"

if [ "${HEXA_REMOTE_NO_SYNC:-0}" != "1" ]; then
  # ssh 옵션 — rsync 중 네트워크 끊기면 30s 안에 감지 (기본 default 무한 대기 방지).
  # 2026-04-22: ControlPath 을 ~/.ssh/ 밖(/tmp)으로 이동 — Mac TCC 가 ~/.ssh/ctl-* link() 차단 (muxserver_listen EPERM).
  RSYNC_SSH='ssh -o ConnectTimeout=10 -o ServerAliveInterval=10 -o ServerAliveCountMax=3 -o BatchMode=yes -o ControlPath=/tmp/ssh-nexus-%r@%h:%p'
  RSYNC_ERR_FILE="$(mktemp -t hexa_remote_rsync.XXXXXX 2>/dev/null || echo /tmp/hexa_remote_rsync.$$)"
  if ! rsync -aH -e "$RSYNC_SSH" "${SYNC_EXCLUDES[@]}" "$LOCAL_ROOT/" "$HOST:${REMOTE_ROOT#\$HOME/}/" >/dev/null 2>"$RSYNC_ERR_FILE"; then
    rsync_rc=$?
    rsync_last="$(tail -n 1 "$RSYNC_ERR_FILE" 2>/dev/null)"
    rm -f "$RSYNC_ERR_FILE"
    echo "hexa_remote: rsync 실패 ($HOST, rc=$rsync_rc): ${rsync_last:-원인 미상}" >&2
    exit 64
  fi
  rm -f "$RSYNC_ERR_FILE"
fi

quote_args() {
  local out=''
  local a
  for a in "$@"; do
    out+=" $(printf %q "$a")"
  done
  printf '%s' "$out"
}

# P1: 원격 shell EXIT 시 자식 hexa_stage0/hexa.real 정리 (ssh 채널 끊김 → orphan 방지).
REMOTE_TRAP="trap 'rc=\$?; pkill -P \$\$ -f hexa_stage0 2>/dev/null; pkill -P \$\$ -f hexa.real 2>/dev/null; exit \$rc' EXIT INT TERM"
# 2026-04-22: HEXA=$REMOTE_HEXA export — run.hexa 내부 stage 호출 ($HOME/Dev/hexa-lang/hexa 우선 pick)
# 이 ubu1 의 4월14 구빌드로 떨어져 smash/free 가 parser-silent (0 absorption) 되는 것 차단.
# run.hexa 의 hexa_bin() 는 env("HEXA") 를 최우선 — 명시 export 시 모든 inner stage 가 hexa_real 로 통일.
# 2026-04-22 (L14): stage0/hexa_real 을 systemd-run --scope cgroup 으로 wrap — MemoryMax=8G cap.
# ubu1+ubu2 동시 OOM 사고(ubu1 stage0 7.6GB RSS / ubu2 hexa_real 30GB RSS → 호스트 전역 OOM-kill)
# 원인: per-process RAM cap 부재. stage 단위 cgroup MemoryMax=20G / MemoryHigh=16G / TasksMax=512.
# (L7 사고 ubu1 stage0 RSS 7.6GB 관찰 — 정상 범위 6-10G. 20G 는 피크 RSS 대비 2.6× 여유라 reclaim
#  안 발동 → NO_CAP baseline 과 bit-identical perf 유지, 30GB 점유 OOM 은 여전히 차단. L20 참조.
#  초기 12G cap 은 MemoryHigh=10G reclaim stress 로 smash +917 → +21 로 44× perf 저하 관찰 후 bump.)
# htz(root) 는 system scope, ubu1/ubu2(유저) 는 --user scope + XDG_RUNTIME_DIR 필수
# (ssh non-interactive 세션에서 DBUS 소켓 경로 누락 시 systemd-run --user 가 silent fail).
# systemd-run 미설치 또는 XDG_RUNTIME_DIR dir 부재 시 bare exec.
# Override: HEXA_REMOTE_NO_CAP=1 (debug 전용).
if [ "$HOST" = "hetzner" ] || [ "$HOST" = "htz" ]; then
    _SD_CHECK='command -v systemd-run >/dev/null 2>&1'
    _SD_WRAP='systemd-run --scope --quiet -p MemoryMax=20G -p MemoryHigh=16G -p TasksMax=512 --'
else
    _SD_CHECK='command -v systemd-run >/dev/null 2>&1 && [ -d "/run/user/$(id -u)" ]'
    _SD_WRAP='export XDG_RUNTIME_DIR="/run/user/$(id -u)"; systemd-run --user --scope --quiet -p MemoryMax=20G -p MemoryHigh=16G -p TasksMax=512 --'
fi
_ARG_QUOTED="$(quote_args "$@")"
if [ "${HEXA_REMOTE_NO_CAP:-0}" = "1" ]; then
    REMOTE_CMD="$REMOTE_TRAP; cd \"$REMOTE_ROOT${REL:+/$REL}\" && export HEXA=\"$REMOTE_HEXA\" HEXA_LOCAL=1 HEXA_NO_LAUNCHD=1 && $REMOTE_HEXA$_ARG_QUOTED"
else
    REMOTE_CMD="$REMOTE_TRAP; cd \"$REMOTE_ROOT${REL:+/$REL}\" && export HEXA=\"$REMOTE_HEXA\" HEXA_LOCAL=1 HEXA_NO_LAUNCHD=1 && if $_SD_CHECK; then $_SD_WRAP $REMOTE_HEXA$_ARG_QUOTED; else $REMOTE_HEXA$_ARG_QUOTED; fi"
fi

# -T = no pty, ServerAlive = 장시간 compute (drill) 중 네트워크 끊기면 30s 내 감지 후 종료.
# P3: stderr 직통 (2>/dev/null 제거 — 원격 진단정보 surface).
echo "hexa_remote: $HOST 에서 원격 실행 중" >&2
ssh -T -o ServerAliveInterval=10 -o ServerAliveCountMax=3 -o ExitOnForwardFailure=yes \
    -o ControlPath=/tmp/ssh-nexus-%r@%h:%p "$HOST" "$REMOTE_CMD"
ssh_rc=$?
if [ $ssh_rc -ne 0 ]; then
    echo "hexa_remote: 원격 실행 실패 ($HOST, rc=$ssh_rc)" >&2
    # 원격 OOM(137) / SIGTERM(143) → resolver local fallback 강제 (병렬 burst 시 caller 회복)
    case "$ssh_rc" in
        137|143)
            echo "hexa_remote: ⚠ $HOST 원격 OOM/SIGTERM (rc=$ssh_rc) — fallback 신호(64) 전달 (병렬 dispatch 줄이거나 GATE_LOCAL=1 권장)" >&2
            exit 64 ;;
    esac
fi
exit $ssh_rc
