#!/bin/bash
# hexa_remote — rsync + ssh wrapper to run hexa on a remote host (ubu1 default).
# Purpose: AG6 Mac-compute-ZERO — heavy hexa work offloaded to ubu1/hetzner.
#
# Eligibility is decided by the caller (shared/scripts/bin/hexa resolver).
# This script trusts inputs and performs:
#   1. Path mapping: $HOME/Dev/airgenome → ~/airgenome, $HOME/Dev/nexus → ~/Dev/nexus
#   2. Incremental rsync of the project root to the remote
#   3. ssh -T exec of hexa with the same args, at mapped cwd
#
# Env:
#   HEXA_REMOTE_HOST             remote host (default: ubu1)
#   HEXA_REMOTE_BIN              remote hexa path (default: $HOME/.hx/bin/hexa_real)
#   HEXA_REMOTE_NO_SYNC          skip rsync (assume tree already fresh)
#   HEXA_REMOTE_CONNECT_TIMEOUT  ssh ConnectTimeout seconds (default: 8)
#   HEXA_REMOTE_PROBE_RETRY      probe retry count on fail (default: 1)
#   HEXA_REMOTE_PSI_THRESHOLD            global PSI*100 reject ceiling (default: 80 → 8000)
#   HEXA_REMOTE_PSI_THRESHOLD_<HOST>     per-host override (HOST uppercased, e.g.
#                                        HEXA_REMOTE_PSI_THRESHOLD_HETZNER=95,
#                                        HEXA_REMOTE_PSI_THRESHOLD_UBU1=70). Lookup
#                                        precedence: per-host → global → 80. Added by
#                                        ω-network-4 (2026-04-26) so operators can
#                                        calibrate without re-deploying once the PSI log
#                                        accumulates per-host distribution.
#   HEXA_REMOTE_PSI_NO_SCALE=1           Disable RAM-headroom-scaled PSI threshold (ISSUE 3,
#                                        2026-04-27). When unset (default), the per-probe
#                                        effective threshold is computed as
#                                          effective = min(95, base + (avail_gb / 32))
#                                        — htz/hetzner with 122GB free gets +3.8pt, ubu1
#                                        with 30GB gets +0.94pt, ceiling 95 prevents runaway.
#                                        Closes user incident 2026-04-27 where htz PSI=91
#                                        was rejected despite enormous RAM headroom.
#
# Exit 64 → caller should fall back to local (cwd not mappable).

set -u

# Pick host. Priority: HEXA_REMOTE_HOST env → dispatch_state.json compute → ubu1.
# Zero-defect reachability (2026-04-20, 2026-04-22 htz 추가):
#   - multi-host fallback: preferred → ubu1 → ubu2 → htz (host sshd 22/TCP, hexa binary 위치에 직결)
#   - ConnectTimeout 3→8s (heavy load 대응)
#   - ServerAliveInterval 로 BannerTimeout hang 방지
#   - 최초 probe 실패 시 다음 후보로 (이전엔 exit 64 즉시 fallback → Mac SIGKILL)
#   - 2026-04-22: htz(hetzner anima-ax102) 를 자동 fallback 체인 말단에 포함 —
#     ubu1/ubu2 동시 장애(LAN 이슈) 시 compute 복원 경로 확보.
#     (airgenome offload 쪽에서 htz alias 재사용, ssh config Host htz → 157.180.8.154.)
pick_preferred_host() {
    if [ -n "${HEXA_REMOTE_HOST:-}" ]; then
        printf '%s' "$HEXA_REMOTE_HOST"; return
    fi
    # 2026-04-25: dispatch_state.json relocated — nexus shared/ decommission
    # lifted it to repo root. Try current first, then legacy.
    local state=""
    for _cand in "$HOME/core/nexus/dispatch_state.json" "$HOME/Dev/nexus/dispatch_state.json" "$HOME/Dev/nexus/shared/dispatch_state.json"; do
        if [ -r "$_cand" ]; then state="$_cand"; break; fi
    done
    if [ -r "$state" ] && command -v jq >/dev/null 2>&1; then
        local h
        h="$(jq -r '.selection.compute // "ubu1"' "$state" 2>/dev/null)"
        case "$h" in
            ubu1|ubu2) printf '%s' "$h"; return ;;
            none|mac|htz|hetzner|"") ;;
        esac
    fi
    printf 'ubu1'
}
_probe_host() {
    local cand="$1"
    local err rc attempt
    # Env-tunable: HEXA_REMOTE_CONNECT_TIMEOUT (default 8), HEXA_REMOTE_PROBE_RETRY (default 1).
    local ctimeout="${HEXA_REMOTE_CONNECT_TIMEOUT:-8}"
    local retry="${HEXA_REMOTE_PROBE_RETRY:-1}"
    local total=$((retry + 1))
    local reason="unknown"
    # Wave 11 blacklist mechanism RETIRED Sub-AA (2026-04-27).
    # Rationale: persistent /tmp/hexa_remote.blacklist.<host> files (300s TTL)
    # blocked legitimate retries on hosts that recovered quickly (esp. PSI
    # spike artifacts). Per-invocation in-line PSI/RAM probe (below) is the
    # natural rate limiter — every kick fully re-evaluates every host.
    # ubu2 banner timeout (the original Wave 11 motivation) is bounded by
    # HEXA_REMOTE_CONNECT_TIMEOUT (8s) and host-pick fallback chain advances
    # to the next candidate. No persistent state needed.
    # raw#36 problem-solving-triad — fixpoint(stable host) + bracket(RAM headroom).
    # Per-host minimum available RAM (MB) before accepting as compute target.
    # heavy-compute drills have been observed at ~20GB RSS → 24GB min keeps a 4GB
    # margin below systemd MemoryMax=20G cap and prevents ubu2 (32GB total) SIGTERM.
    # Override: HEXA_REMOTE_MIN_RAM_MB (0 disables the check, falling back to
    # legacy behavior).
    local min_ram="${HEXA_REMOTE_MIN_RAM_MB:-24576}"
    attempt=0
    while [ $attempt -lt $total ]; do
        # Combined SSH + RAM + PSI probe in a single round-trip: `echo OK` on host
        # gates sshd responsiveness, `awk /^Mem:/` extracts available MB, and
        # /proc/pressure/memory's "some avg10" is appended on a second line.
        # Output format:
        #   line 1: "OK <avail_mb>"
        #   line 2: "<psi_some_avg10>"  (e.g. "0.00", "12.34"; "0.00" if file absent — macOS)
        # 2026-04-25: LC_ALL=C forced — Korean-locale hosts print "메모리:" instead
        # of "Mem:", breaking the /^Mem:/ match and silently dropping RAM parsing
        # (→ avail=?MB → host wrongly skipped). Observed on ubu1 after 2026-04-24
        # recovery; prior sessions only worked because hetzner defaulted to C locale.
        # L4 (2026-04-25): PSI feedback. /proc/pressure/memory 의 some avg10 (10s
        # 윈도 동안 task 메모리 stall % ratio) 을 같은 ssh round-trip 으로 수집 →
        # 외부 admission block 에서 호스트 활성 메모리 압박 기반 reject 판단.
        # ω-network-8 (2026-04-26): LC_ALL=C on local ssh client — its stderr
        # ("Could not resolve hostname", "Connection timed out", ...) is case-
        # matched at lines 143-157 against English literals. Korean/CJK locale on
        # the Mac would translate these messages and silently mis-classify probe
        # failures. Mirrors line-104 remote-side LC_ALL=C precedent.
        err="$(LC_ALL=C ssh -o ConnectTimeout=$ctimeout -o BatchMode=yes -o ServerAliveInterval=5 \
            -o ServerAliveCountMax=1 \
            -o ControlMaster=no -o ControlPath=none "$cand" \
            'echo OK $(LC_ALL=C free -m 2>/dev/null | awk "/^Mem:/ {print \$7}" | tr -d "[:space:]" || awk "/MemAvailable:/ {print int(\$2/1024); exit}" /proc/meminfo 2>/dev/null || echo 0); awk "/^some/ {gsub(/avg10=/,\"\"); print \$2; exit}" /proc/pressure/memory 2>/dev/null || echo "0.00"; if command -v nvidia-smi >/dev/null 2>&1; then nvidia-smi --query-gpu=memory.free,utilization.gpu --format=csv,noheader,nounits 2>/dev/null | head -1 | tr -d " " || echo "0,0"; else echo "0,0"; fi' 2>&1)"
        rc=$?
        if [ $rc -eq 0 ]; then
            # Parse "OK <avail>" — avail field 2 onwards (robust to extra whitespace).
            local avail psi
            avail="$(printf '%s' "$err" | awk '/^OK/ {print $2}' | head -n1)"
            # PSI: 첫 OK 줄을 제외한 다음 줄. 빈 값이면 미지원 (macOS 등) → "" 로 둠.
            psi="$(printf '%s' "$err" | awk 'NR>1 && $0!="" {print; exit}')"
            # Sub-AG (2026-04-27) + Sub-AY (2026-04-28): GPU probe — 3번째 line.
            # Format: "<gpu_avail_mb>,<gpu_util_pct>" (memory.free,utilization.gpu).
            # 미지원 / 미설치 시 "0,0". RTX 5070 12GB → ~11500MB,0% idle.
            gpu_line="$(printf '%s' "$err" | awk 'NR==3 {print; exit}')"
            gpu_avail="$(printf '%s' "$gpu_line" | awk -F, '{print $1}')"
            gpu_util="$(printf '%s' "$gpu_line" | awk -F, '{print $2}')"
            [ -z "$gpu_avail" ] && gpu_avail="0"
            [ -z "$gpu_util" ] && gpu_util="0"
            # ω-hexa-5 (R5.4): PSI avg10 > 80 hard-reject. 호스트가 심하게
            # saturated 됐는데 RAM avail 만으로 통과시키면 stalls 발생.
            # threshold 80 → integer*100 = 8000 비교. Disable via
            # HEXA_REMOTE_NO_PSI_REJECT=1.
            if [ -n "$psi" ] && [ "${HEXA_REMOTE_NO_PSI_REJECT:-0}" != "1" ]; then
                local _psi_int
                _psi_int="$(awk -v p="$psi" 'BEGIN{printf "%d", p*100}')"
                # ω-network-2 (2026-04-26): per-host PSI threshold calibration —
                # observability instrumentation (Option A). Single threshold 80
                # currently uniform across hetzner (128GB) / ubu1/ubu2 (32GB) / htz.
                # 호스트별 RAM headroom + workload 차이로 80 이 일부 호스트엔
                # 너무 관대 / 다른 호스트엔 과도할 가능성. log path:
                # HEXA_REMOTE_PSI_LOG (default /tmp/hexa_remote_psi.log).
                # TSV: ISO_ts \t host \t psi_avg10 \t threshold \t outcome \t reason.
                # outcome ∈ {reject, accept}. reason: human-readable.
                # ω-network-3 next round: 누적 분포 기반 per-host 임계값 제안.
                # Disable: HEXA_REMOTE_PSI_LOG_OFF=1.
                # ω-network-4 (2026-04-26): per-host env override —
                # HEXA_REMOTE_PSI_THRESHOLD_<HOST_UPPER> (e.g.
                # HEXA_REMOTE_PSI_THRESHOLD_HETZNER=95) wins over the global
                # HEXA_REMOTE_PSI_THRESHOLD; both fall back to 80. Allows operators
                # to calibrate without re-deploying once the analyzer suggests
                # per-host values from the accumulated log. _psi_src is recorded in
                # the PSI emit row so the effective env source is debuggable.
                local _h_upper _psi_threshold _psi_src
                _h_upper="$(printf '%s' "$cand" | tr '[:lower:]' '[:upper:]' | tr -c '[:alnum:]_' '_')"
                local _per_host_var="HEXA_REMOTE_PSI_THRESHOLD_${_h_upper}"
                local _per_host_val="${!_per_host_var:-}"
                if [ -n "$_per_host_val" ]; then
                    _psi_threshold="$_per_host_val"
                    _psi_src="$_per_host_var"
                elif [ -n "${HEXA_REMOTE_PSI_THRESHOLD:-}" ]; then
                    _psi_threshold="$HEXA_REMOTE_PSI_THRESHOLD"
                    _psi_src="HEXA_REMOTE_PSI_THRESHOLD"
                else
                    _psi_threshold="80"
                    _psi_src="default80"
                fi
                # ─── ISSUE 3 (2026-04-27): RAM-headroom-scaled PSI threshold ────
                # Original behavior rejected htz at PSI=91 even though 122GB was
                # free, because the static 80 threshold ignored that PSI on a
                # fat-RAM host doesn't predict OOM the same way as on a 32GB
                # host. New formula:
                #     effective_psi = min(95, base + (avail_gb / 32))
                # The bonus term is a *float* — the *100 integer comparison
                # below preserves sub-point precision. Worked example:
                #     ubu1  (30GB free)  → 80 + 30/32  = 80.94  (≈80, no change)
                #     ubu2  (28GB free)  → 80 + 28/32  = 80.88  (≈80, no change)
                #     htz   (128GB)      → 80 + 128/32 = 84.00  (was rejecting at 80)
                #     hetzner (200GB)    → 80 + 200/32 = 86.25  (was rejecting at 80)
                #     huge (500GB)       → 80 + 500/32 = 95.00  (clamped at ceiling)
                # Bypass: HEXA_REMOTE_PSI_NO_SCALE=1 (testing / debug). Default
                # is opt-in scale ON because it is *strictly more permissive* —
                # never rejects what the static path would accept, only accepts
                # additional fat-RAM cases the static path was over-rejecting.
                # _psi_eff_src records "scaled" vs "static" for log forensics.
                local _psi_eff _psi_eff_int _psi_eff_src
                if [ "${HEXA_REMOTE_PSI_NO_SCALE:-0}" = "1" ]; then
                    _psi_eff="$_psi_threshold"
                    _psi_eff_src="static"
                    _psi_eff_int="$(awk -v t="$_psi_eff" 'BEGIN{printf "%d", t*100}')"
                else
                    # avail is MB → GB as float; bonus = avail_gb / 32 (float).
                    # Both the eff display string AND the *100 integer comparison
                    # are computed in awk to keep precision (PSI is float, e.g. 12.34).
                    # Ceiling 95 clamps any host with absurd headroom.
                    _psi_eff="$(awk -v base="$_psi_threshold" -v avail_mb="${avail:-0}" '
                        BEGIN {
                            avail_gb = avail_mb / 1024.0
                            bonus = avail_gb / 32.0
                            eff = base + bonus
                            if (eff > 95) eff = 95
                            printf "%.2f", eff
                        }')"
                    _psi_eff_int="$(awk -v t="$_psi_eff" 'BEGIN{printf "%d", t*100}')"
                    _psi_eff_src="scaled(base=${_psi_threshold},avail_gb=$(awk -v m="${avail:-0}" 'BEGIN{printf "%.2f", m/1024.0}'))"
                fi
                local _psi_threshold_int
                _psi_threshold_int="$(awk -v t="$_psi_threshold" 'BEGIN{printf "%d", t*100}')"
                local _psi_log="${HEXA_REMOTE_PSI_LOG:-/tmp/hexa_remote_psi.log}"
                local _psi_log_on="${HEXA_REMOTE_PSI_LOG_OFF:-0}"
                _psi_emit() {
                    [ "$_psi_log_on" = "1" ] && return 0
                    local _ts
                    _ts="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo 'unknown')"
                    # ω-network-4: append _psi_src as 7th column so the effective
                    # env source ("HEXA_REMOTE_PSI_THRESHOLD_HETZNER" |
                    # "HEXA_REMOTE_PSI_THRESHOLD" | "default80") is recoverable per
                    # row without re-deriving from environment state.
                    # ISSUE 3 (2026-04-27): col 8 = effective scaled threshold,
                    # col 9 = scaling source ("scaled(base=..)" | "static").
                    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
                        "$_ts" "$cand" "$psi" "$_psi_threshold" "$1" "$2" "$_psi_src" \
                        "$_psi_eff" "$_psi_eff_src" \
                        >> "$_psi_log" 2>/dev/null || true
                }
                if [ "$_psi_int" -gt "$_psi_eff_int" ] 2>/dev/null; then
                    _psi_emit "reject" "PSI avg10=$psi > eff=$_psi_eff (base=$_psi_threshold src=$_psi_src ${_psi_eff_src})"
                    echo "hexa_remote: host=$cand PSI avg10=$psi > eff=$_psi_eff (base=$_psi_threshold src=$_psi_src ${_psi_eff_src}) — skipping saturated host" >&2
                    reason="PSI saturated (avg10=$psi > eff=$_psi_eff base=$_psi_threshold)"
                    rc=1
                    break
                else
                    _psi_emit "accept" "PSI avg10=$psi <= eff=$_psi_eff (base=$_psi_threshold src=$_psi_src ${_psi_eff_src})"
                fi
            fi
            # Accept if RAM check disabled OR avail >= threshold.
            if [ "$min_ram" = "0" ] || { [ -n "$avail" ] && [ "$avail" -ge "$min_ram" ] 2>/dev/null; }; then
                # Wave 12 (2026-04-25): export avail MB to caller for load-aware
                # selection (probe-all + argmax). 비어있으면 0 으로 기록.
                HEXA_REMOTE_LAST_AVAIL="${avail:-0}"
                # L4: export PSI some avg10 (string, e.g. "12.34"). 미지원 호스트 = "".
                HEXA_REMOTE_LAST_PSI="${psi:-}"
                # Sub-AG: export GPU avail MB. 미지원 호스트 = 0.
                HEXA_REMOTE_LAST_GPU_AVAIL="${gpu_avail:-0}"
                # Sub-AY: export GPU utilization % (compute pressure).
                HEXA_REMOTE_LAST_GPU_UTIL="${gpu_util:-0}"
                return 0
            fi
            echo "hexa_remote: host=$cand SSH OK but RAM avail=${avail:-?}MB < ${min_ram}MB threshold (raw#36 bracket) — skipping" >&2
            reason="insufficient RAM (avail=${avail:-?}MB < ${min_ram}MB)"
            rc=1
            break
        fi
        attempt=$((attempt + 1))
    done
    reason="unknown(rc=$rc)"
    case "$err" in
        *"Could not resolve hostname"*|*"Name or service not known"*|*"nodename nor servname"*)
            reason="DNS 해석 실패" ;;
        *"Connection refused"*)
            reason="SSH 거부 (sshd down? 포트 차단?)" ;;
        *"Permission denied"*|*"publickey"*|*"Authentication failed"*)
            reason="인증 실패 (키/agent 확인)" ;;
        *"Connection timed out"*|*"Operation timed out"*|*"timed out"*)
            reason="타임아웃 (네트워크/방화벽)" ;;
        *"Host key verification failed"*)
            reason="호스트 키 불일치" ;;
        *"No route to host"*)
            reason="라우팅 없음" ;;
        *)
            [ -n "$err" ] && reason="$(printf '%s' "$err" | tail -n 1)" ;;
    esac
    echo "hexa_remote: host=$cand 실패: $reason" >&2
    # raw 66 ai-native trailer (per-host probe failure). causal-class derives
    # from the parsed reason; fix candidates ordered by ROI. When all hosts
    # fail, the upstream all-routes-blocked trailer (line ~524) provides the
    # consolidated multi-line block.
    case "$reason" in
        *"DNS"*|*"hostname"*) _ai_class="ssh-fail" ;;
        *"timeout"*|*"타임아웃"*|*"timed out"*) _ai_class="ssh-fail" ;;
        *"인증"*|*"publickey"*|*"Permission denied"*) _ai_class="ssh-fail" ;;
        *"라우팅"*|*"route"*|*"unreachable"*) _ai_class="network-unreachable" ;;
        *"PSI"*|*"saturated"*) _ai_class="fork-exhaustion" ;;
        *"RAM"*|*"insufficient"*) _ai_class="fork-exhaustion" ;;
        *) _ai_class="ssh-fail" ;;
    esac
    echo "reason: ${_ai_class}: ${reason}" >&2
    echo "fix: 1) ssh -v $cand   # verbose probe  2) ssh-add -l && ssh-add ~/.ssh/id_ed25519   # ensure agent key present  3) ping -c1 $cand   # connectivity check" >&2
    # Sub-AA 2026-04-27: blacklist write retired. Probe failure here returns
    # rc != 0 so caller's fallback chain advances to next host candidate; no
    # persistent /tmp file needed. Next invocation fully re-probes — if the
    # underlying issue is transient (PSI spike, banner glitch), recovery is
    # immediate instead of waiting 300s for blacklist TTL.
    return $rc
}

PREFERRED="$(pick_preferred_host)"
# Normalize htz → hetzner (ssh config 의 canonical alias).
[ "$PREFERRED" = "htz" ] && PREFERRED="hetzner"

# 2026-04-25 (raw#36 완전 실행): heavy-compute (drill/smash/free/absolute/
# meta-closure/hyperarithmetic) 는 dispatch_state.json 의 PREFERRED 를
# 무시하고 항상 hetzner (128GB RAM) 우선. ubu1/ubu2 는 32GB total + cgroup
# MemoryMax=20G 에서 smash round peak RSS 가 SIGTERM (rc=137) 유발 — 2026-04-25
# 관측 (ubu2 에서 smash +917 absorptions 후 OOM). hetzner 는 100GB+ headroom.
# Sub-AH (2026-04-27): stash original argv for downstream classify
# (per-host dynamic concurrency needs the same args _classify_job sees).
_NEXUS_ORIG_ARGV=("$@")
_IS_HEAVY_COMPUTE=0
if [ "${1:-}" = "run" ] && [ -n "${2:-}" ]; then
    case "$(basename "$2")" in
        nexus_cli.hexa|nexus.hexa|run.hexa)
            for _hc_a in "${@:3}"; do
                case "$_hc_a" in
                    drill|smash|free|absolute|meta-closure|hyperarithmetic)
                        _IS_HEAVY_COMPUTE=1; break ;;
                esac
            done ;;
    esac
fi
if [ "$_IS_HEAVY_COMPUTE" = "1" ] && [ -z "${HEXA_REMOTE_HOST:-}" ]; then
    PREFERRED="hetzner"
fi

# Sub-AX (2026-04-28): GPU class detection for LB-pick filtering.
# When job is class=gpu (--gpu / --cuda flag OR --engine mk10), LB-pick must
# prefer hosts with actual GPU (gpu_avail > threshold). Otherwise picker
# selects max-avail host (often hetzner = CPU-only) → L8 GPU admission
# rejects → no fallback chain (Sub-AW gap).
# Sub-AX preempts: filter LB candidates by gpu_avail >= GPU threshold when
# class=gpu, before max-avail comparison runs.
_IS_GPU_CLASS=0
if [ "$_IS_HEAVY_COMPUTE" = "1" ]; then
    for _gc_a in "${@:3}"; do
        case "$_gc_a" in
            --gpu|--cuda) _IS_GPU_CLASS=1; break ;;
        esac
    done
    # mk10 engine triggers gpu (Sub-AG _classify_job alignment)
    _gc_prev=""
    for _gc_a in "${@:3}"; do
        if [ "$_gc_prev" = "--engine" ] && [ "$_gc_a" = "mk10" ]; then
            _IS_GPU_CLASS=1; break
        fi
        _gc_prev="$_gc_a"
    done
fi

# Wave 24 / L3 (2026-04-25): per-job memory class — argv 분석으로 small/medium/large
# 분류. L2 의 균일 MIN_AVAIL_MB=4096 가 모든 작업에 동일 cap 을 부과해 cluster
# headroom 사장 (small drill 도 large 와 동일 admission)을 야기. L3 는 cmd /
# seed length / heavy flags 를 보고 클래스 결정 → 클래스별 차등 MIN_AVAIL.
# 결과: stdout 에 "small" | "medium" | "large".
# 분류 매트릭스:
#   - cmd ∈ {omega, absolute, meta-closure, hyperarithmetic} → large
#   - --depth ≥ 8                                            → large
#   - --engine mk10                                          → large
#   - --speculate ≥ 3                                        → large
#   - seed length > 500                                      → large
#   - cmd ∈ {probe, status, canon}                           → small
#   - seed length < 100 AND no --depth                       → small
#   - 그 외                                                  → medium
_classify_job() {
    local _cmd="" _seed="" _depth="" _engine="" _spec="" _gpu=0
    local _i _j
    for ((_i=1; _i<=$#; _i++)); do
        case "${!_i}" in
            drill|omega|surge|smash|free|absolute|meta-closure|hyperarithmetic)
                [ -z "$_cmd" ] && _cmd="${!_i}" ;;
            --seed)     _j=$((_i+1)); _seed="${!_j:-}" ;;
            --depth)    _j=$((_i+1)); _depth="${!_j:-}" ;;
            --engine)   _j=$((_i+1)); _engine="${!_j:-}" ;;
            --speculate) _j=$((_i+1)); _spec="${!_j:-}" ;;
            --gpu|--cuda) _gpu=1 ;;
        esac
    done
    # Sub-AG: gpu 트리거 — 명시 --gpu/--cuda 또는 mk10 engine (CUDA 가속 가정).
    if [ "$_gpu" = "1" ] || [ "$_engine" = "mk10" ]; then
        echo "gpu"; return
    fi
    # large 트리거
    case "$_cmd" in
        omega|absolute|meta-closure|hyperarithmetic) echo "large"; return ;;
    esac
    if [ -n "$_depth" ] && [ "$_depth" -ge 8 ] 2>/dev/null; then echo "large"; return; fi
    if [ -n "$_spec" ] && [ "$_spec" -ge 3 ] 2>/dev/null; then echo "large"; return; fi
    if [ "${#_seed}" -gt 500 ]; then echo "large"; return; fi
    # small 트리거
    case "$_cmd" in
        probe|status|canon) echo "small"; return ;;
    esac
    if [ "${#_seed}" -lt 100 ] && [ -z "$_depth" ]; then echo "small"; return; fi
    # default medium
    echo "medium"
}

# heavy-compute 는 \$HOME/.hx/packages/*/cli/*.hexa (원격 self-contained CLI) 만
# 필요 — local repo rsync 불필요. cwd 가 어떤 case branch 에 매치되든 상관없이
# no-sync + cd \$HOME 으로 통일. hetzner disk 포화 / rsync IO 이슈 차단.
if [ "$_IS_HEAVY_COMPUTE" = "1" ]; then
    HEXA_REMOTE_NO_SYNC=1
fi

# 2026-04-25 (Wave 9): heavy-compute concurrency gate. Mac jetsam SIGKILL
# (rc=137) 은 ssh ClientCount 동시성에 비례. 6-parallel drill 시도가 전원
# rc=137 로 실패 관측 (Wave 8 post-mortem). Wave 9 는 preemptive gate —
# 로컬 측 heavy dispatch 를 최대 N (default 2) 로 제한. macOS 에 flock(1)
# 이 없어 mkdir 원자성으로 lock primitive 구현 (dir 존재 시 mkdir 실패 =
# slot taken). 비-heavy (probe/helpers) 경로는 영향 없음.
# Override: HEXA_REMOTE_CONCURRENCY=N, HEXA_REMOTE_NO_CONCURRENCY=1 bypass,
# HEXA_REMOTE_CONCURRENCY_WAIT=S wait seconds (default 300).
# Wave 22 (2026-04-25): per-host concurrency. 글로벌 single-slot 은 1/3 호스트만
# 활용 (33%) → drill 1개가 hetzner 잡으면 ubu1/ubu2 의 24GB free RAM 도 idle.
# 호스트별 슬롯으로 분리해 활용도 100% (호스트 단위) 회복. PREFERRED 가 아닌
# *실제 picked HOST* 를 prefix 에 사용해야 load-aware (Wave 12) 가 다른 호스트로
# 보낸 케이스도 정확히 격리됨 → 실제 acquire 호출은 HOST 결정 직후 (line ~327 이후).
# Override:
#   HEXA_REMOTE_CONCURRENCY=N            모든 호스트 default (default 1)
#   HEXA_REMOTE_CONCURRENCY_HETZNER=N    hetzner 전용 (default = HEXA_REMOTE_CONCURRENCY)
#   HEXA_REMOTE_CONCURRENCY_UBU1=N       ubu1 전용
#   HEXA_REMOTE_CONCURRENCY_UBU2=N       ubu2 전용
#   HEXA_REMOTE_NO_CONCURRENCY=1         bypass (전체 게이트 비활성)
#   HEXA_REMOTE_CONCURRENCY_WAIT=S       wait 초 (default 300)
#   HEXA_REMOTE_SLOT_MAX_HOLD=S          stale slot max hold (default 3600s, #C)
if [ "$_IS_HEAVY_COMPUTE" = "1" ] && [ "${HEXA_REMOTE_NO_CONCURRENCY:-0}" != "1" ]; then
    _WAIT_S="${HEXA_REMOTE_CONCURRENCY_WAIT:-300}"
    _SLOT_MAX_HOLD="${HEXA_REMOTE_SLOT_MAX_HOLD:-3600}"
    _ACQUIRED=""
    # _per_host_max <host> → echo per-host slot limit.
    # Sub-AH (2026-04-27): mathematical-limit dynamic compute. Old code
    # default=1 wasted hetzner 124GB capacity (only 1 of 4-5 mathematically-
    # available slots used = 75% capacity dormant). Now: floor((avail_mb -
    # safety) / class_min_mb), clamped [1, 8].
    #   Priority: per-host env > global env > dynamic (avail+class) > fallback default 1
    #   Safety margin: 4096MB headroom for system + interpreter RSS
    #   Class min: small=2048 / medium=8192 / large=24576 / gpu=8192 (RAM dim only — VRAM is L8 dim)
    # Examples (live cluster, post-Sub-AF audit):
    #   hetzner avail=122GB large=24GB  → (122000-4096)/24576 = 4.8 → 4 slots
    #   ubu1    avail=25GB  medium=8GB  → (25000-4096)/8192   = 2.5 → 2 slots
    #   ubu2    avail=25GB  medium=8GB  → 2 slots
    #   hetzner avail=122GB small=2GB   → (122000-4096)/2048  = 57.6 → CLAMPED to 8 (over-saturation guard)
    _per_host_max() {
        local _h="$1"
        local _h_uc="$(printf '%s' "$_h" | tr '[:lower:]' '[:upper:]')"
        local _explicit_var="HEXA_REMOTE_CONCURRENCY_${_h_uc}"
        local _explicit="${!_explicit_var:-}"
        if [ -n "$_explicit" ]; then printf '%s' "$_explicit"; return; fi
        if [ -n "${HEXA_REMOTE_CONCURRENCY:-}" ]; then printf '%s' "$HEXA_REMOTE_CONCURRENCY"; return; fi
        # Dynamic — only when probe set _best_avail (post LB-pick).
        # Compute class-min inline (avoid relying on _admit_min_mb which is set later in L3).
        local _cls _cmin
        _cls="$(_classify_job ${_NEXUS_ORIG_ARGV[@]:-})"
        case "$_cls" in
            small)  _cmin=2048 ;;
            medium) _cmin=8192 ;;
            large)  _cmin=24576 ;;
            gpu)    _cmin=8192 ;;
            *)      _cmin=8192 ;;
        esac
        local _avail="${_best_avail:-0}"
        local _safety="${HEXA_REMOTE_PER_HOST_SAFETY_MB:-4096}"
        if [ "$_avail" -gt "$_safety" ] 2>/dev/null && [ "$_cmin" -gt 0 ] 2>/dev/null; then
            local _dyn=$(( (_avail - _safety) / _cmin ))
            [ "$_dyn" -lt 1 ] && _dyn=1
            # Sub-AI (2026-04-27): PSI-aware upper clamp. Old: uniform [1, 8].
            # New: clamp = max(1, 8 - floor(PSI/12)). PSI=physical pressure signal:
            #   PSI 0%  → clamp 8 (full headroom — let dynamic compute pick)
            #   PSI 24% → clamp 6
            #   PSI 48% → clamp 4
            #   PSI 72% → clamp 2
            #   PSI ≥84% → clamp 1 (host near saturation; single concurrent only)
            # _best_psi is set by the LB-pick chain after probe (string e.g. "12.34");
            # if absent / unparsable / negative → fall back to 8 (legacy behavior).
            # Bypass: HEXA_REMOTE_NO_PSI_CLAMP=1 (force legacy [1, 8] uniform).
            # Sub-BS 2026-04-27 (push toward physical limits): make clamp ceiling
            # env-driven. Default base=8 preserves legacy. HEXA_REMOTE_PSI_CLAMP_BASE
            # raises ceiling for hosts with massive RAM headroom (e.g. hetzner 124GB
            # at PSI=0 leaves capacity for 12-16 concurrent dispatches without
            # crossing class_min_mb × dyn_count budget). Per-host override:
            # HEXA_REMOTE_PSI_CLAMP_BASE_<HOST_UC>. Lossless: dyn formula still
            # caps at floor((avail-safety)/cmin), so RAM is the hard limit; PSI
            # clamp is just the safety bracket.
            # Sub-DL 2026-04-27 (per-host sensible defaults): hetzner has 124GB
            # RAM at PSI=0 routinely → 16 concurrent slots is safe (medium-class
            # 8GB×16 = 128GB ≤ 124GB; dyn formula still binds at floor((avail-
            # safety)/cmin) so this only RAISES the ceiling when RAM permits).
            # ubu/ubu2 keep 8 (their 32GB / 8GB-medium = 4 dyn slots anyway).
            # User can still env-override per-host or globally.
            local _default_base=8
            case "$_h" in
                hetzner) _default_base=16 ;;
            esac
            local _clamp_base="${HEXA_REMOTE_PSI_CLAMP_BASE:-$_default_base}"
            local _per_host_clamp_var="HEXA_REMOTE_PSI_CLAMP_BASE_${_h_uc}"
            local _per_host_clamp="${!_per_host_clamp_var:-}"
            [ -n "$_per_host_clamp" ] && _clamp_base="$_per_host_clamp"
            local _clamp_max="$_clamp_base"
            if [ "${HEXA_REMOTE_NO_PSI_CLAMP:-0}" != "1" ] && [ -n "${_best_psi:-}" ]; then
                local _psi_int_clamp
                _psi_int_clamp="$(awk -v p="${_best_psi:-0}" 'BEGIN{printf "%d", p}' 2>/dev/null)"
                if [ -n "$_psi_int_clamp" ] && [ "$_psi_int_clamp" -ge 0 ] 2>/dev/null; then
                    # Linear scale: at PSI=0 → clamp=base; at PSI=96 → clamp=1.
                    # Step = base/12 so PSI=12 reduces by 1 ceiling slot.
                    local _step=$(( _clamp_base / 12 ))
                    [ "$_step" -lt 1 ] && _step=1
                    _clamp_max=$(( _clamp_base - _psi_int_clamp / 12 * _step ))
                    [ "$_clamp_max" -lt 1 ] && _clamp_max=1
                fi
            fi
            [ "$_dyn" -gt "$_clamp_max" ] && _dyn="$_clamp_max"
            printf '%s' "$_dyn"
            return
        fi
        printf '1'
    }
    _acquire_slot() {
        # Args: $1 = host (e.g. hetzner). Sets _ACQUIRED on success.
        _h="$1"
        _N_MAX_H="$(_per_host_max "$_h")"
        _LOCK_DIR_PREFIX="/tmp/nexus_heavy_dispatch.${_h}.slot"
        _i=1
        while [ "$_i" -le "$_N_MAX_H" ]; do
            _ld="${_LOCK_DIR_PREFIX}${_i}.lock"
            if mkdir "$_ld" 2>/dev/null; then
                echo "$$" > "$_ld/pid" 2>/dev/null || true
                _ACQUIRED="$_ld"
                # 프로세스 종료 시 slot 해제 (flock auto-release 대체).
                trap 'rm -rf "$_ACQUIRED" 2>/dev/null || true' EXIT INT TERM
                return 0
            else
                # #C stale detection (Wave 22):
                #   1) pid 파일이 죽은 pid → 회수
                #   2) slot mtime 이 _SLOT_MAX_HOLD (default 3600s) 초과 → 강제 회수
                #      (사유: /loop 무한 drill 이 살아있어도 영구 점유 차단)
                _pid="$(cat "$_ld/pid" 2>/dev/null || echo "")"
                if [ -n "$_pid" ] && ! kill -0 "$_pid" 2>/dev/null; then
                    rm -rf "$_ld" 2>/dev/null || true
                    continue  # same slot 재시도
                fi
                _slot_age="$(( $(date +%s) - $(stat -f %m "$_ld" 2>/dev/null || stat -c %Y "$_ld" 2>/dev/null || date +%s) ))"
                if [ "$_slot_age" -ge "$_SLOT_MAX_HOLD" ] 2>/dev/null; then
                    echo "hexa_remote: stale slot reclaimed (held ${_slot_age}s, pid ${_pid:-?} alive)" >&2
                    rm -rf "$_ld" 2>/dev/null || true
                    continue  # same slot 재시도
                fi
            fi
            _i=$((_i + 1))
        done
        return 1
    }
    # ──────────────────────────────────────────────────────────────────
    # Sub-AK (2026-04-27): GPU concurrent slot tracking. Sub-AG L8 admission
    # checked gpu_avail >= min single-shot — over-commit risk if 4 kicks
    # all admit when only 12GB VRAM exists (each at 8GB threshold). Slot
    # tracking caps concurrent GPU jobs per host at floor((gpu_avail -
    # gpu_safety) / per_job_vram), clamped [1, 4]. Lock prefix
    # /tmp/nexus_gpu_dispatch.<host>.gpu_slot<N>.lock parallel to RAM L1
    # /tmp/nexus_heavy_dispatch.<host>.slot<N>.lock — orthogonal acquire.
    #
    # Math:
    #   per_job_vram default 4096 (typical CUDA inference; train job set
    #     HEXA_REMOTE_GPU_PER_JOB_VRAM_MB=10240 for 10GB workload)
    #   gpu_safety default 1024 (CUDA context + driver overhead)
    #   RTX 5070 12GB free idle → floor((11500-1024)/4096) = 2 slots/host
    # Override: HEXA_REMOTE_GPU_CONCURRENCY_<HOST_UPPER> / GLOBAL.
    _per_host_gpu_max() {
        local _h="$1"
        local _h_uc="$(printf '%s' "$_h" | tr '[:lower:]' '[:upper:]')"
        local _explicit_var="HEXA_REMOTE_GPU_CONCURRENCY_${_h_uc}"
        local _explicit="${!_explicit_var:-}"
        if [ -n "$_explicit" ]; then printf '%s' "$_explicit"; return; fi
        if [ -n "${HEXA_REMOTE_GPU_CONCURRENCY:-}" ]; then printf '%s' "$HEXA_REMOTE_GPU_CONCURRENCY"; return; fi
        local _gpu_avail="${_picked_gpu_avail:-${_best_gpu_avail:-0}}"
        local _gpu_safety="${HEXA_REMOTE_GPU_SAFETY_MB:-1024}"
        local _per_job="${HEXA_REMOTE_GPU_PER_JOB_VRAM_MB:-4096}"
        if [ "$_gpu_avail" -gt "$_gpu_safety" ] 2>/dev/null && [ "$_per_job" -gt 0 ] 2>/dev/null; then
            local _gdyn=$(( (_gpu_avail - _gpu_safety) / _per_job ))
            [ "$_gdyn" -lt 1 ] && _gdyn=1
            [ "$_gdyn" -gt 4 ] && _gdyn=4
            printf '%s' "$_gdyn"
            return
        fi
        printf '1'
    }
    _acquire_gpu_slot() {
        # Args: $1 = host. Sets _GPU_ACQUIRED on success. Mirrors _acquire_slot
        # mechanics: mkdir lockdir + write pid + trap-on-exit cleanup. The trap
        # is APPENDED to the existing _ACQUIRED trap so RAM + GPU slots both
        # release on EXIT.
        _h="$1"
        _N_MAX_GH="$(_per_host_gpu_max "$_h")"
        _GPU_LOCK_PREFIX="/tmp/nexus_gpu_dispatch.${_h}.gpu_slot"
        _gi=1
        while [ "$_gi" -le "$_N_MAX_GH" ]; do
            _gld="${_GPU_LOCK_PREFIX}${_gi}.lock"
            if mkdir "$_gld" 2>/dev/null; then
                echo "$$" > "$_gld/pid" 2>/dev/null || true
                _GPU_ACQUIRED="$_gld"
                # Compose trap with existing _ACQUIRED cleanup. raw 36 fixpoint:
                # both lockdirs released atomically on shell exit.
                trap 'rm -rf "${_ACQUIRED:-}" "${_GPU_ACQUIRED:-}" 2>/dev/null || true' EXIT INT TERM
                return 0
            else
                # Stale-detection mirror of RAM slot pattern.
                _gpid="$(cat "$_gld/pid" 2>/dev/null || echo "")"
                if [ -n "$_gpid" ] && ! kill -0 "$_gpid" 2>/dev/null; then
                    rm -rf "$_gld" 2>/dev/null || true
                    continue
                fi
                _gslot_age="$(( $(date +%s) - $(stat -f %m "$_gld" 2>/dev/null || stat -c %Y "$_gld" 2>/dev/null || date +%s) ))"
                if [ "$_gslot_age" -ge "$_SLOT_MAX_HOLD" ] 2>/dev/null; then
                    echo "hexa_remote: stale GPU slot reclaimed (held ${_gslot_age}s, pid ${_gpid:-?})" >&2
                    rm -rf "$_gld" 2>/dev/null || true
                    continue
                fi
            fi
            _gi=$((_gi + 1))
        done
        return 1
    }
    # 실제 acquire 호출은 host 결정 후 (line ~327 이후) `_gate_acquire_for_host` 에서.
    # 여기선 함수만 정의 — host pick 전에는 어느 슬롯에 속할지 알 수 없음.
    _gate_acquire_for_host() {
        _gh="$1"
        if ! _acquire_slot "$_gh"; then
            _gn="$(_per_host_max "$_gh")"
            echo "hexa_remote: Wave 22 per-host gate — host=$_gh all $_gn slots busy, waiting up to ${_WAIT_S}s" >&2
            _t=0
            while [ "$_t" -lt "$_WAIT_S" ]; do
                sleep 1
                _t=$((_t + 1))
                if _acquire_slot "$_gh"; then
                    echo "hexa_remote: slot acquired on $_gh after ${_t}s" >&2
                    break
                fi
            done
            if [ -z "$_ACQUIRED" ]; then
                printf 'NEXUS_REMOTE_ERROR {"reason":"heavy_concurrency_exceeded","host":"%s","limit":%s,"wait_s":%s,"exit_code":64}\n' "$_gh" "$_gn" "$_WAIT_S" >&2
                exit 64
            fi
        fi
    }
fi

# Build fallback chain — preferred 먼저, 그 다음 hive resource JSON 에서
# scoring_weight DESC 로 정렬한 host 들 (ssh_alias != local).
#
# 2026-04-27: dynamic source-of-truth migration — hive-exec resource_lint --json
# 의 출력에서 kind=host AND ssh_alias != local 만 selecting. scoring_weight DESC
# 로 chain 순서 결정 (hetzner=0.6 < ubu=1.0 < ubu2=0.8 처럼 weight 가 priority).
# JSON 가 비거나 hive-exec 부재 시 legacy chain (hetzner ubu1 ubu2 htz) 으로 fallback.
# Cache: 단일 invocation 동안만 (변수). Override: HEXA_REMOTE_HOST / HEXA_REMOTE_CHAIN.
#
# 2026-04-27 (hetzner-first prior): heavy-compute 의 경우 hetzner (128GB RAM) 가
# OOM 회피에 압도적 우월 — 단순 scoring_weight DESC 가 ubu(1.0) 를 hetzner(0.6) 위로
# 밀지 않게, heavy 인 경우 PREFERRED 를 hetzner 로 line 305 에서 강제했음. 일반
# 경우엔 weight DESC 정렬 그대로 사용.
_HIVE_EXEC_BIN="${HIVE_EXEC:-$HOME/.hx/bin/hive-exec}"
_RESOURCE_PATH="${HIVE_RESOURCE_PATH:-$HOME/core/hive/.resource}"
_RESOURCE_JSON=""
if [ -x "$_HIVE_EXEC_BIN" ] && [ -e "$_RESOURCE_PATH" ]; then
    _RESOURCE_JSON="$("$_HIVE_EXEC_BIN" resource_lint --path "$_RESOURCE_PATH" --json 2>/dev/null || true)"
fi
# Parse out ssh_alias list, weight DESC, kind=host AND ssh_alias!=local.
_DYNAMIC_HOSTS=""
if [ -n "$_RESOURCE_JSON" ]; then
    if command -v jq >/dev/null 2>&1; then
        _DYNAMIC_HOSTS="$(printf '%s' "$_RESOURCE_JSON" \
            | jq -r '[.[] | select(.kind=="host" and .ssh_alias!="local")]
                     | sort_by(-(.scoring_weight // 0))
                     | .[].ssh_alias' 2>/dev/null | tr '\n' ' ')"
    elif command -v python3 >/dev/null 2>&1; then
        _DYNAMIC_HOSTS="$(printf '%s' "$_RESOURCE_JSON" | python3 -c '
import sys, json
try:
    arr = json.load(sys.stdin)
    rows = [e for e in arr if e.get("kind")=="host" and e.get("ssh_alias")!="local"]
    rows.sort(key=lambda e: -(e.get("scoring_weight") or 0))
    print(" ".join(e["ssh_alias"] for e in rows))
except Exception:
    pass
' 2>/dev/null)"
    fi
fi
# Allow operator override (CSV or space-separated). Wins over JSON.
if [ -n "${HEXA_REMOTE_CHAIN:-}" ]; then
    _DYNAMIC_HOSTS="$(printf '%s' "$HEXA_REMOTE_CHAIN" | tr ',' ' ')"
fi
# Fallback: legacy hard-coded chain. Triggers when JSON empty AND no override.
if [ -z "$_DYNAMIC_HOSTS" ]; then
    _DYNAMIC_HOSTS="hetzner ubu1 ubu2 htz"
fi
FALLBACK_CHAIN="$PREFERRED"
for cand in $_DYNAMIC_HOSTS; do
    case " $FALLBACK_CHAIN " in
        *" $cand "*) ;;
        *) FALLBACK_CHAIN="$FALLBACK_CHAIN $cand" ;;
    esac
done

# ─── ISSUE 5 (2026-04-27): structured all-routes-blocked diagnostic trailer ───
# When every external probe path AND the docker fallback (when applicable) are
# blocked, emit a raw 66 ai-native trailer that tells the operator *exactly*
# which artifacts to inspect/clear, instead of the historical cryptic
# 'all-claude-slots-exhausted'. Fields surfaced:
#   - external_blacklist: [retired Sub-AA 2026-04-27] row preserved as boilerplate
#                         pointer so existing operator runbooks parsing the trailer
#                         schema don't break; no persistent host bans exist.
#   - docker_neg_cache:   /tmp/hexa_resolver.connectivity presence + ttl_remaining
#   - slot_pool:          available/cooldown/unknown across the 12 claude slots
#                         (best-effort summary parse from claude_slot_pick --list --json,
#                          falls back to simple dir-existence count)
#   - fix:                 ordered remediation directives (raw 66 / raw 81 contract)
#   - ref:                 raw#ai-native-error-message + nexus/.guide § cross-host parity
# Args: $1 = space-separated FALLBACK_CHAIN, $2 = reason slug.
# Stdout: nothing. Stderr: multi-line trailer.
# Idempotent — pure read-side; no state mutation.
_emit_all_routes_blocked_trailer() {
    local _chain="$1" _reason="$2"
    local _now
    _now="$(date +%s)"
    echo "err hexa_remote/all-routes-blocked" >&2
    # Sub-AA 2026-04-27: external_blacklist row retired.
    # No persistent host blacklist exists — every invocation fully re-probes.
    echo "  external_blacklist: [retired Sub-AA 2026-04-27 — no persistent host bans, every kick re-probes]" >&2
    # docker_neg_cache row (the resolver's connectivity neg-cache file).
    local _dc_file="/tmp/hexa_resolver.connectivity"
    local _dc_ttl="${HEXA_RESOLVER_CONNECTIVITY_TTL:-60}"
    local _dc_row="absent"
    if [ -f "$_dc_file" ]; then
        local _dc_mtime _dc_age _dc_remaining
        _dc_mtime="$(stat -f %m "$_dc_file" 2>/dev/null || stat -c %Y "$_dc_file" 2>/dev/null || echo 0)"
        _dc_age="$(( _now - _dc_mtime ))"
        _dc_remaining="$(( _dc_ttl - _dc_age ))"
        [ "$_dc_remaining" -lt 0 ] 2>/dev/null && _dc_remaining=0
        _dc_row="present(age=${_dc_age}s, ttl_remaining=${_dc_remaining}s)"
    fi
    echo "  docker_neg_cache: $_dc_row" >&2
    # slot_pool row — best-effort. Try hive helper first; fall back to dir count.
    local _slot_row="<unprobed>"
    local _slot_helper="$HOME/core/hive/tool/claude_slot_pick.hexa"
    local _hexa_bin="${HEXA:-$HOME/.hx/bin/hexa}"
    if [ -x "$_hexa_bin" ] && [ -f "$_slot_helper" ]; then
        # Use --list --json; parse summary block. 1s timeout — this is diagnostic,
        # we never block the exit path on it.
        local _slot_json
        _slot_json="$(HEXA_RESOLVER_NO_REROUTE=1 timeout 2 "$_hexa_bin" run "$_slot_helper" --list --json 2>/dev/null || true)"
        if [ -n "$_slot_json" ]; then
            local _avail_n _cool_n _unk_n _total_n
            _avail_n="$(printf '%s' "$_slot_json" | awk -F: '/"available":/ {gsub(/[^0-9]/,"",$2); print $2; exit}')"
            _cool_n="$(printf '%s'  "$_slot_json" | awk -F: '/"session_limit":/ {gsub(/[^0-9]/,"",$2); print $2; exit}')"
            _unk_n="$(printf '%s'   "$_slot_json" | awk -F: '/"unknown":/ {gsub(/[^0-9]/,"",$2); print $2; exit}')"
            _total_n="$(printf '%s' "$_slot_json" | awk -F: '/"total":/ {gsub(/[^0-9]/,"",$2); print $2; exit}')"
            _total_n="${_total_n:-12}"
            _slot_row="${_avail_n:-?}/${_total_n} available, ${_cool_n:-?}/${_total_n} cooldown, ${_unk_n:-?}/${_total_n} unknown"
        fi
    fi
    if [ "$_slot_row" = "<unprobed>" ]; then
        local _slot_dirs
        _slot_dirs="$(ls -1d "$HOME"/.claude-claude* 2>/dev/null | wc -l | tr -d ' ')"
        _slot_row="${_slot_dirs:-0}/12 dirs (helper unreachable)"
    fi
    echo "  slot_pool: $_slot_row" >&2
    # fix block — ordered remediation. Sub-AA: blacklist clear step removed
    # (no persistent state to clear). Failure path is now: connectivity check
    # → slot probe → full bypass.
    echo "  fix:" >&2
    echo "    1) clear neg_cache: rm -f /tmp/hexa_resolver.connectivity" >&2
    echo "    2) probe slots: hexa run $HIVE/tool/claude_slot_pick.hexa --probe-all" >&2
    echo "    3) connectivity check: for h in $_chain; do ssh -o ConnectTimeout=5 -o BatchMode=yes \$h 'echo OK' 2>/dev/null && echo \"\$h: OK\" || echo \"\$h: FAIL\"; done" >&2
    echo "    4) full bypass: HEXA_RESOLVER_NO_REROUTE=1 nexus kick run <topic>" >&2
    echo "  ref: raw:ai-native-error-message + nexus/.guide § Cross-host parity matrix" >&2
    # raw 66 trailer
    echo "reason=$_reason fix=see-block-above" >&2

    # ─── F-RAW77-CASCADE-LEDGER (2026-04-28): raw 77 audit ledger append ───
    # Trailer above is stderr-only ephemeral; raw 77 mandates append-only JSONL
    # for cross-session traceability. raw 25 file-lock pattern (flock + retry)
    # for concurrent writer safety. raw 12 silent-error: ledger failure escalates
    # via stderr warning (best-effort — never blocks exit path of the cascade).
    local _ledger_dir="${HEXA_REMOTE_AUDIT_DIR:-$HOME/core/nexus/state/audit}"
    local _ledger="$_ledger_dir/cascade_blocked_events.jsonl"
    local _iso_ts
    _iso_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    local _host_name
    _host_name="$(hostname 2>/dev/null || echo unknown)"
    # Build fix_steps JSON array (mirrors stderr fix block, machine-readable).
    local _fix_steps
    _fix_steps='["clear neg_cache: rm -f /tmp/hexa_resolver.connectivity","probe slots: hexa run claude_slot_pick.hexa --probe-all","connectivity check: ssh ConnectTimeout=5 BatchMode=yes per host","full bypass: HEXA_RESOLVER_NO_REROUTE=1 nexus kick run <topic>"]'
    # external_blacklist intentionally empty array (Sub-AA 2026-04-27 retired).
    # docker_neg_cache + slot_pool reuse the rows computed above.
    local _chain_json=""
    for _h in $_chain; do
        if [ -z "$_chain_json" ]; then _chain_json="\"$_h\""
        else _chain_json="$_chain_json,\"$_h\""; fi
    done
    local _row
    _row="$(printf '{"ts":"%s","event":"all-routes-blocked","external_blacklist":[],"docker_neg_cache":"%s","slot_pool":"%s","reason":"%s","fallback_chain":[%s],"fix_steps":%s,"ref":"raw 66 + raw 77","host":"%s","agent":"hexa_remote"}' \
        "$_iso_ts" "$_dc_row" "$_slot_row" "$_reason" "$_chain_json" "$_fix_steps" "$_host_name")"
    # mkdir best-effort (raw 65 idempotent).
    mkdir -p "$_ledger_dir" 2>/dev/null || true
    # raw 25 lock pattern: flock with 5s timeout + retry. Falls back to
    # plain append if flock unavailable (macOS default — POSIX append (>>) is
    # atomic for writes under PIPE_BUF, our row fits well within).
    local _ledger_ok=0
    if command -v flock >/dev/null 2>&1; then
        local _attempts=0
        while [ $_attempts -lt 3 ]; do
            if (flock -w 5 9 && printf '%s\n' "$_row" >&9) 9>>"$_ledger" 2>/dev/null; then
                _ledger_ok=1
                break
            fi
            _attempts=$((_attempts + 1))
            sleep 1
        done
    else
        if printf '%s\n' "$_row" >> "$_ledger" 2>/dev/null; then
            _ledger_ok=1
        fi
    fi
    if [ "$_ledger_ok" != "1" ]; then
        # raw 12 silent-error: surface failure on stderr (do not exit non-zero —
        # ledger write is best-effort diagnostic; cascade exit path owns the
        # primary exit code via raw 66 trailer caller).
        echo "  ledger_warn: failed to append raw 77 row to $_ledger" >&2
    fi
}

# 2026-04-22: preflight — parallel 300ms TCP probe of $FALLBACK_CHAIN via
# $HEXA_LANG/gate/remote_preflight.hexa (hexa-lang PR#24). Fast-path exit 64
# when all hosts are down, instead of paying per-host ConnectTimeout×N.
# Disable with HEXA_REMOTE_SKIP_PREFLIGHT=1. Stderr JSON verdict parsing is
# used (preflight's own exit code is informational-only until its exit(74)
# bug is fixed upstream).
_PREFLIGHT_SRC="${HEXA_LANG:-$HOME/core/hexa-lang}/gate/remote_preflight.hexa"
_PREFLIGHT_BIN="${HEXA_BIN:-$HOME/.hx/bin/hexa}"
if [ "${HEXA_REMOTE_SKIP_PREFLIGHT:-0}" != "1" ] \
   && [ -f "$_PREFLIGHT_SRC" ] \
   && [ -x "$_PREFLIGHT_BIN" ]; then
    _pf_csv="$(printf '%s' "$FALLBACK_CHAIN" | tr ' ' ',')"
    _pf_out="$("$_PREFLIGHT_BIN" run "$_PREFLIGHT_SRC" \
        --hosts "$_pf_csv" \
        --timeout-ms "${HEXA_REMOTE_PREFLIGHT_TIMEOUT_MS:-300}" 2>&1 1>/dev/null || true)"
    case "$_pf_out" in
        *'"verdict":"all_unreachable"'*)
            echo "hexa_remote: preflight — all hosts unreachable (tried: $FALLBACK_CHAIN), fast-aborting" >&2
            _pf_hosts_json=""
            for _h in $FALLBACK_CHAIN; do
                if [ -z "$_pf_hosts_json" ]; then _pf_hosts_json="\"$_h\""
                else _pf_hosts_json="$_pf_hosts_json,\"$_h\""; fi
            done
            printf 'NEXUS_REMOTE_ERROR {"hosts_tried":[%s],"reason":"all_unreachable_preflight","exit_code":64}\n' "$_pf_hosts_json" >&2
            # ─── ISSUE 5 (2026-04-27): structured failure cascade trailer ───
            _emit_all_routes_blocked_trailer "$FALLBACK_CHAIN" "all_unreachable_preflight" >&2
            exit 64
            ;;
    esac
fi

HOST=""
# Wave 12 (2026-04-25): load-aware selection. 전체 chain probe 후 healthy 중
# `HEXA_REMOTE_LAST_AVAIL` (probe 가 기록) 최대값인 호스트 pick. PREFERRED 는
# 동일 avail tie-breaker (chain 순서 그대로 PREFERRED 가 먼저 collected 되므로
# 나중 동점 갱신은 무시 — PREFERRED stability 보장).
#   HEXA_REMOTE_LB=first  → Wave 11 이전 동작 (first-healthy short-circuit)
#   HEXA_REMOTE_LB=avail  → Wave 12 default (highest avail RAM)
# 직접 지정 (HEXA_REMOTE_HOST) 은 FALLBACK_CHAIN 앞머리에 있고 preferred=그 값
# 이므로 probe 통과 즉시 선택됨 (Wave 11 이전과 동일 체감).
_LB_MODE="${HEXA_REMOTE_LB:-avail}"
if [ "$_LB_MODE" = "first" ]; then
    for cand in $FALLBACK_CHAIN; do
        HEXA_REMOTE_LAST_PSI=""
        if _probe_host "$cand"; then
            HOST="$cand"
            # L4: capture picked host PSI for admission guard.
            _picked_psi="${HEXA_REMOTE_LAST_PSI:-}"
            [ "$PREFERRED" != "$cand" ] && echo "hexa_remote: $PREFERRED unreachable, using $cand" >&2
            break
        fi
    done
else
    # probe-all + argmax(avail). 실패 호스트는 in-memory 누적만 수행 (Sub-AA
    # 2026-04-27: Wave 11 persistent blacklist 기록 retired — 다음 invocation
    # 도 fully re-probes, transient 실패 (PSI spike, banner glitch) 즉시 회복).
    # L4 (2026-04-25): probe 가 동시에 수집한 PSI some avg10 도 picked host 의
    # `_picked_psi` 로 보존 → 아래 L4 admission 가드가 사용.
    _best_host=""
    _best_avail=-1
    _best_score=-1
    _best_psi=""
    _best_gpu_avail=0
    _best_gpu_util=0
    _healthy_hosts=""
    # Round-robin tier (2026-05-03): when the highest-score host equals the
    # last-picked host, prefer a tier-eligible alternative (score within
    # ±HEXA_REMOTE_TIER_PCT of the best). Closes the monotonic-favor case
    # where score margins of a few percent kept routing to the same host
    # repeatedly. Defaults: tier=10%, last-pick file under /tmp.
    _tier_pct="${HEXA_REMOTE_TIER_PCT:-10}"
    _last_pick_file="${HEXA_REMOTE_LAST_PICK_FILE:-/tmp/hexa_remote_last_pick.txt}"
    _last_pick=""
    [ -f "$_last_pick_file" ] && _last_pick="$(cat "$_last_pick_file" 2>/dev/null | head -1 | tr -d '[:space:]')"
    _best_host_excl_last=""
    _best_score_excl_last=-1
    _best_avail_excl_last=-1
    _best_psi_excl_last=""
    _best_gpu_avail_excl_last=0
    _best_gpu_util_excl_last=0
    # Sub-AX GPU-class threshold for LB-pick filter — match L8 admission
    # default (8192MB) so picker rejects in advance instead of L8 reject
    # without fallback. Override: HEXA_REMOTE_GPU_PICK_MIN_MB.
    _gpu_pick_min="${HEXA_REMOTE_GPU_PICK_MIN_MB:-8192}"
    # Sub-AY (2026-04-28): GPU utilization throttle threshold. Skip hosts
    # with gpu_util > threshold (default 70%). compute pressure analog to
    # Sub-AI RAM PSI clamp. Closes convergence lint D6 GPU-PSI-throttle.
    # Override: HEXA_REMOTE_GPU_UTIL_THRESHOLD (default 70).
    _gpu_util_threshold="${HEXA_REMOTE_GPU_UTIL_THRESHOLD:-70}"
    # Sub-BE (2026-04-28): PSI-aware LB-pick scoring. Old: max(avail_mb).
    # New: max(avail_mb × (100 - PSI_int) / 100). Combines avail + memory
    # pressure ratio into single ready-capacity metric. PSI-saturated host
    # with high avail ranks lower (correctly reflects effective capacity
    # instead of raw free RAM). Bypass: HEXA_REMOTE_LEGACY_LB_PICK=1.
    for cand in $FALLBACK_CHAIN; do
        # 2026-04-28 user directive '로그인 실패건은 작동에서 제외':
        # Skip hosts listed in $HOME/.hx/state/oauth_blacklisted_hosts.jsonl
        # (1 host per JSONL row, "host":"<name>" field). Cleared by
        # oauth_refresh_detector on REFRESH_HEALTHY events. Bypass:
        # HEXA_REMOTE_NO_OAUTH_BLACKLIST=1 (test only).
        if [ "${HEXA_REMOTE_NO_OAUTH_BLACKLIST:-0}" != "1" ] && \
           [ -f $HOME/.hx/state/oauth_blacklisted_hosts.jsonl ]; then
            if grep -q "\"host\":\"$cand\"" $HOME/.hx/state/oauth_blacklisted_hosts.jsonl 2>/dev/null; then
                echo "hexa_remote: oauth-blacklist skip — host=$cand (~/.hx/state/oauth_blacklisted_hosts.jsonl); clear via oauth_refresh_detector REFRESH_HEALTHY" >&2
                continue
            fi
        fi
        HEXA_REMOTE_LAST_AVAIL=""
        HEXA_REMOTE_LAST_PSI=""
        HEXA_REMOTE_LAST_GPU_AVAIL=""
        HEXA_REMOTE_LAST_GPU_UTIL=""
        if _probe_host "$cand"; then
            _cand_avail="${HEXA_REMOTE_LAST_AVAIL:-0}"
            _cand_psi="${HEXA_REMOTE_LAST_PSI:-}"
            _cand_gpu="${HEXA_REMOTE_LAST_GPU_AVAIL:-0}"
            _cand_gpu_util="${HEXA_REMOTE_LAST_GPU_UTIL:-0}"
            # Sub-BF: include score in healthy_hosts log so Sub-BE PSI-aware
            # ranking decision is transparent. Score computed below in pick block.
            _healthy_hosts_pre_score="$_healthy_hosts $cand(avail=${_cand_avail}MB,psi=${_cand_psi:-NA},gpu=${_cand_gpu}MB,gpu_util=${_cand_gpu_util}%"
            # close paren added after _cand_score is computed
            # Sub-AX (2026-04-28): GPU class filter at LB-pick stage.
            # When class=gpu, skip CPU-only / under-threshold hosts so
            # max-avail comparison only runs over GPU-capable candidates.
            # Bypass: HEXA_REMOTE_NO_GPU_PICK_FILTER=1 (legacy avail-only).
            if [ "$_IS_GPU_CLASS" = "1" ] && [ "${HEXA_REMOTE_NO_GPU_PICK_FILTER:-0}" != "1" ]; then
                if [ "$_cand_gpu" -lt "$_gpu_pick_min" ] 2>/dev/null; then
                    echo "hexa_remote: Sub-AX GPU-class LB-pick skip — host=$cand class=gpu gpu_avail=${_cand_gpu}MB < $_gpu_pick_min" >&2
                    continue
                fi
                # Sub-AY (2026-04-28): GPU-PSI throttle — skip GPU host with
                # high compute pressure (gpu_util > threshold). Even if VRAM
                # available, busy GPU degrades dispatch + new workload.
                # Bypass: HEXA_REMOTE_NO_GPU_UTIL_THROTTLE=1.
                if [ "${HEXA_REMOTE_NO_GPU_UTIL_THROTTLE:-0}" != "1" ]; then
                    if [ "$_cand_gpu_util" -gt "$_gpu_util_threshold" ] 2>/dev/null; then
                        echo "hexa_remote: Sub-AY GPU-PSI throttle skip — host=$cand class=gpu gpu_util=${_cand_gpu_util}% > $_gpu_util_threshold%" >&2
                        continue
                    fi
                fi
            fi
            # Sub-BE PSI-aware scoring (default) or legacy max(avail) fallback.
            _cand_psi_int="$(awk -v p="${_cand_psi:-0}" 'BEGIN{printf "%d", p}' 2>/dev/null)"
            [ -z "$_cand_psi_int" ] && _cand_psi_int=0
            [ "$_cand_psi_int" -lt 0 ] 2>/dev/null && _cand_psi_int=0
            [ "$_cand_psi_int" -gt 100 ] 2>/dev/null && _cand_psi_int=100
            if [ "${HEXA_REMOTE_LEGACY_LB_PICK:-0}" = "1" ]; then
                _cand_score="$_cand_avail"
            else
                # score = avail × (100 - PSI_int) / 100 (integer math, no floats).
                _cand_score=$(( _cand_avail * (100 - _cand_psi_int) / 100 ))
            fi
            # Sub-BF: append score to healthy_hosts now that it's computed.
            _healthy_hosts="${_healthy_hosts_pre_score},score=${_cand_score})"
            # Strict `>` — tie 는 chain 순서 먼저 온 쪽 유지 (PREFERRED stability).
            if [ "$_cand_score" -gt "$_best_score" ] 2>/dev/null; then
                _best_score="$_cand_score"
                _best_avail="$_cand_avail"
                _best_psi="$_cand_psi"
                _best_gpu_avail="$_cand_gpu"
                _best_gpu_util="$_cand_gpu_util"
                _best_host="$cand"
            fi
            # Round-robin track: best candidate that ISN'T the last_pick.
            # Used after the loop to swap the winner if best_host == last_pick
            # AND the alternative is within tier_pct of best_score.
            if [ "$cand" != "$_last_pick" ] && [ "$_cand_score" -gt "$_best_score_excl_last" ] 2>/dev/null; then
                _best_score_excl_last="$_cand_score"
                _best_avail_excl_last="$_cand_avail"
                _best_psi_excl_last="$_cand_psi"
                _best_gpu_avail_excl_last="$_cand_gpu"
                _best_gpu_util_excl_last="$_cand_gpu_util"
                _best_host_excl_last="$cand"
            fi
        fi
    done
    # Round-robin tier swap: if best == last_pick AND alternative is within
    # ±tier_pct of best_score, prefer the alternative to spread load. Disable:
    # HEXA_REMOTE_NO_TIER_RR=1.
    if [ "${HEXA_REMOTE_NO_TIER_RR:-0}" != "1" ] \
       && [ -n "$_best_host" ] && [ -n "$_last_pick" ] && [ "$_best_host" = "$_last_pick" ] \
       && [ -n "$_best_host_excl_last" ] && [ "$_best_score" -gt 0 ] 2>/dev/null; then
        _tier_threshold=$(( _best_score * (100 - _tier_pct) / 100 ))
        if [ "$_best_score_excl_last" -ge "$_tier_threshold" ] 2>/dev/null; then
            echo "hexa_remote: tier-rr swap from $_best_host (score=$_best_score, was last_pick) to $_best_host_excl_last (score=$_best_score_excl_last, threshold=$_tier_threshold)" >&2
            _best_host="$_best_host_excl_last"
            _best_score="$_best_score_excl_last"
            _best_avail="$_best_avail_excl_last"
            _best_psi="$_best_psi_excl_last"
            _best_gpu_avail="$_best_gpu_avail_excl_last"
            _best_gpu_util="$_best_gpu_util_excl_last"
        fi
    fi
    # Persist last_pick for the next invocation's round-robin decision.
    [ -n "$_best_host" ] && echo "$_best_host" > "$_last_pick_file" 2>/dev/null
    # Sub-AX fallback: if class=gpu AND no GPU host passed filter, fall
    # through to legacy avail-only pick + warn. Operator can then use
    # HEXA_REMOTE_GPU_MIN_AVAIL_MB=2048 (smaller workload) or NO_GPU_ADMISSION.
    if [ "$_IS_GPU_CLASS" = "1" ] && [ -z "$_best_host" ]; then
        echo "hexa_remote: Sub-AX no GPU-capable host in chain — falling back to avail-only pick (will hit L8 admission later)" >&2
        for cand in $FALLBACK_CHAIN; do
            HEXA_REMOTE_LAST_AVAIL=""
            HEXA_REMOTE_LAST_PSI=""
            HEXA_REMOTE_LAST_GPU_AVAIL=""
            if _probe_host "$cand"; then
                _cand_avail="${HEXA_REMOTE_LAST_AVAIL:-0}"
                if [ "$_cand_avail" -gt "$_best_avail" ] 2>/dev/null; then
                    _best_avail="$_cand_avail"
                    _best_psi="${HEXA_REMOTE_LAST_PSI:-}"
                    _best_gpu_avail="${HEXA_REMOTE_LAST_GPU_AVAIL:-0}"
                    _best_host="$cand"
                fi
            fi
        done
    fi
    if [ -n "$_best_host" ]; then
        HOST="$_best_host"
        _picked_psi="$_best_psi"
        _picked_gpu_avail="$_best_gpu_avail"
        # Sub-BF: log algorithm name reflects active scoring mode (avail vs score).
        _lb_algo=$([ "${HEXA_REMOTE_LEGACY_LB_PICK:-0}" = "1" ] && echo "avail" || echo "score")
        echo "hexa_remote: LB=$_lb_algo pick=$HOST (avail=${_best_avail}MB psi=${_picked_psi:-NA} gpu=${_picked_gpu_avail}MB score=${_best_score}) among:${_healthy_hosts}" >&2
        [ "$PREFERRED" != "$HOST" ] && echo "hexa_remote: $PREFERRED not chosen (load-aware), using $HOST" >&2
    fi
fi

if [ -z "$HOST" ]; then
    # Wave 25 / L6 (2026-04-25): cross-host work-stealing queue. 모든 host 가
    # 동시에 unreachable/busy 면 즉시 abort 대신 큐에 enqueue 후 polling. host
    # 가 풀리면 (slot release / RAM free) 큐 head 가 자동으로 pickup → idle
    # 호스트로 dispatch 합류. 효과: cluster RAM 90% → ~95% 활용도 (큐 대기 시간
    # 감소, dispatch-time 결정 후에도 작업 이동 가능).
    #
    # Env override:
    #   HEXA_REMOTE_NO_QUEUE=1            큐 모드 bypass (기존 즉시 abort)
    #   HEXA_REMOTE_QUEUE_TTL=S           큐 대기 deadline (default 300s)
    #   HEXA_REMOTE_QUEUE_POLL=S          polling 간격 (default 5s)
    #   HEXA_REMOTE_QUEUE_FILE=path       큐 파일 (default /tmp/hexa_remote.queue.tsv)
    #
    # Lock 메커니즘: mkdir-based exclusive lock (atomic across NFS/local).
    # 큐 형식 (TSV): enqueue_ts \t deadline_ts \t job_class \t pid \t cmdline
    if [ "$_IS_HEAVY_COMPUTE" = "1" ] && [ "${HEXA_REMOTE_NO_QUEUE:-0}" != "1" ]; then
        _QUEUE_FILE="${HEXA_REMOTE_QUEUE_FILE:-/tmp/hexa_remote.queue.tsv}"
        _QUEUE_LOCK="${_QUEUE_FILE}.lock"
        _Q_TS="$(date +%s)"
        _Q_TTL="${HEXA_REMOTE_QUEUE_TTL:-300}"
        _Q_POLL="${HEXA_REMOTE_QUEUE_POLL:-5}"
        _Q_DEADLINE=$((_Q_TS + _Q_TTL))
        _Q_CLASS="$(_classify_job "$@" 2>/dev/null || echo unknown)"
        # Acquire lock for enqueue + stale-clean (mkdir is atomic).
        _q_lock_tries=0
        while ! mkdir "$_QUEUE_LOCK" 2>/dev/null; do
            _q_lock_tries=$((_q_lock_tries + 1))
            if [ "$_q_lock_tries" -ge 50 ]; then
                # 5초 (50 * 0.1s) 후에도 lock 못 잡으면 stale 로 판단, 강제 회수.
                _lock_age="$(( $(date +%s) - $(stat -f %m "$_QUEUE_LOCK" 2>/dev/null || stat -c %Y "$_QUEUE_LOCK" 2>/dev/null || date +%s) ))"
                if [ "$_lock_age" -ge 30 ]; then
                    rm -rf "$_QUEUE_LOCK" 2>/dev/null || true
                fi
                break
            fi
            sleep 0.1
        done
        # Stale-clean: deadline 초과 entry 제거 (다른 caller 가 죽었을 수 있음).
        if [ -f "$_QUEUE_FILE" ]; then
            _now="$(date +%s)"
            awk -F'\t' -v now="$_now" '$2 > now {print}' "$_QUEUE_FILE" > "$_QUEUE_FILE.tmp" 2>/dev/null \
                && mv "$_QUEUE_FILE.tmp" "$_QUEUE_FILE"
        fi
        # Append self.
        printf '%s\t%s\t%s\t%s\t%s\n' "$_Q_TS" "$_Q_DEADLINE" "$_Q_CLASS" "$$" "$*" >> "$_QUEUE_FILE"
        rm -rf "$_QUEUE_LOCK" 2>/dev/null || true
        # 큐 entry 자가 정리 trap (자신이 죽거나 deadline 후에도 남으면 곤란).
        trap '
            if mkdir "'"$_QUEUE_LOCK"'" 2>/dev/null; then
                if [ -f "'"$_QUEUE_FILE"'" ]; then
                    awk -F"\t" -v p="'"$$"'" "\$4 != p {print}" "'"$_QUEUE_FILE"'" > "'"$_QUEUE_FILE"'.tmp" 2>/dev/null \
                        && mv "'"$_QUEUE_FILE"'.tmp" "'"$_QUEUE_FILE"'"
                fi
                rm -rf "'"$_QUEUE_LOCK"'" 2>/dev/null || true
            fi
        ' EXIT INT TERM
        echo "hexa_remote: L6 queued (pid=$$ class=$_Q_CLASS ttl=${_Q_TTL}s) — polling every ${_Q_POLL}s for idle host" >&2
        # Polling loop: head pid 가 자기인지 + host 풀렸는지 확인.
        while [ "$(date +%s)" -lt "$_Q_DEADLINE" ]; do
            sleep "$_Q_POLL"
            _head_pid="$(awk -F'\t' 'NR==1 {print $4}' "$_QUEUE_FILE" 2>/dev/null || echo "")"
            if [ "$_head_pid" != "$$" ]; then
                continue  # 아직 head 아님 — 앞순위 작업 처리 대기.
            fi
            # head 라면 host 재탐색.
            for _qcand in $FALLBACK_CHAIN; do
                HEXA_REMOTE_LAST_AVAIL=""
                HEXA_REMOTE_LAST_PSI=""
                if _probe_host "$_qcand"; then
                    _qavail="${HEXA_REMOTE_LAST_AVAIL:-0}"
                    _qmin="${HEXA_REMOTE_MIN_AVAIL_MB:-4096}"
                    if [ "$_qavail" -gt "$_qmin" ] 2>/dev/null; then
                        HOST="$_qcand"
                        _best_avail="$_qavail"
                        _picked_psi="${HEXA_REMOTE_LAST_PSI:-}"
                        # Dequeue self (head).
                        if mkdir "$_QUEUE_LOCK" 2>/dev/null; then
                            if [ -f "$_QUEUE_FILE" ]; then
                                awk -F'\t' -v p="$$" '$4 != p {print}' "$_QUEUE_FILE" > "$_QUEUE_FILE.tmp" 2>/dev/null \
                                    && mv "$_QUEUE_FILE.tmp" "$_QUEUE_FILE"
                            fi
                            rm -rf "$_QUEUE_LOCK" 2>/dev/null || true
                        fi
                        echo "hexa_remote: L6 dequeued — picked $HOST (avail=${_qavail}MB) after $(( $(date +%s) - _Q_TS ))s wait" >&2
                        # trap 은 EXIT 시점에 큐 파일에서 자기 entry 제거 시도하나
                        # 이미 dequeue 되었으므로 no-op (idempotent).
                        break 2  # break polling loop
                    fi
                fi
            done
        done
    fi
    if [ -z "$HOST" ]; then
        echo "hexa_remote: all hosts unreachable (tried: $FALLBACK_CHAIN), falling back to local" >&2
        # AI-native JSON emit — caller (shared/scripts/bin/hexa) parses to decide exit 64 vs 74.
        # Build JSON host array from FALLBACK_CHAIN (space-separated).
        _hosts_json=""
        for _h in $FALLBACK_CHAIN; do
            if [ -z "$_hosts_json" ]; then
                _hosts_json="\"$_h\""
            else
                _hosts_json="$_hosts_json,\"$_h\""
            fi
        done
        printf 'NEXUS_REMOTE_ERROR {"hosts_tried":[%s],"reason":"all_unreachable","exit_code":64}\n' "$_hosts_json" >&2
        # ─── ISSUE 5 (2026-04-27): structured failure cascade trailer ───
        _emit_all_routes_blocked_trailer "$FALLBACK_CHAIN" "all_unreachable" >&2
        exit 64
    fi
fi

# Wave 22 (2026-04-25): per-host slot acquire — 실제 picked HOST 가 결정된 후
# 호출. 호스트별 슬롯 디렉토리 (`/tmp/nexus_heavy_dispatch.<host>.slot<i>.lock`)
# 를 사용하므로 hetzner busy 여도 ubu1/ubu2 는 독립 슬롯으로 즉시 진입.
# Skip: heavy-compute 가 아니거나 NO_CONCURRENCY=1 (게이트 함수 미정의).
if [ "$_IS_HEAVY_COMPUTE" = "1" ] && [ "${HEXA_REMOTE_NO_CONCURRENCY:-0}" != "1" ] && command -v _gate_acquire_for_host >/dev/null 2>&1; then
    _gate_acquire_for_host "$HOST"
fi

# Wave 23 / L2 (2026-04-25): headroom-aware admission. L1 (per-host slot) 은
# 호스트 *수* 만큼 활용도 (33→100%) 만 회복; 단일 호스트 내부 RAM 잔량은 무관심.
# 결과: hetzner cap=80G 인데 free=53G → drill RSS class 가 cap 직전이면 OOM 위험,
# 그렇다고 드릴 미세화 없이 reject 하면 ubu1/ubu2 (24GB free) 도 admission 통과
# 못 해 cluster idle. L2 는 probe 가 측정한 avail RAM (`_best_avail`, MB) 이
# `HEXA_REMOTE_MIN_AVAIL_MB` (default 4096 — stage0 RSS cap + small drill 여유)
# 미만이면 slot 즉시 반납 + exit 64 fallback chain 트리거 (Sub-AA 2026-04-27:
# blacklist 등록 step retired — fallback chain 의 next host 가 fresh-probed).
# Per-host override: HEXA_REMOTE_MIN_AVAIL_MB_HETZNER / _UBU1 / _UBU2.
# Bypass:           HEXA_REMOTE_NO_ADMISSION=1
# Backward-compat:  _best_avail 미세팅 (LB=first 경로 / probe 미실행) 시 skip.
#
# Wave 24 / L3 (2026-04-25): per-job memory class. _classify_job 이 결정한
# class (small/medium/large) 별 default MIN_AVAIL 차등화 → cluster 활용도
# RAM 55% → 70% 목표.
#   small  → 2048MB  (probe/status/canon, short seed → 32GB ubu1/ubu2 도 통과)
#   medium → 8192MB  (default drill, seed<500)
#   large  → 24576MB (omega/absolute, --depth≥8, mk10, --speculate≥3, seed>500)
# 우선순위 (높→낮):
#   1) HEXA_REMOTE_MIN_AVAIL_MB_<HOST>          (host-specific override, 기존)
#   2) HEXA_REMOTE_MIN_AVAIL_MB                 (global override, 기존)
#   3) HEXA_REMOTE_MIN_AVAIL_MB_<SMALL/MEDIUM/LARGE>  (class override, L3 신규)
#   4) class default (2048/8192/24576)          (L3 신규)
if [ "$_IS_HEAVY_COMPUTE" = "1" ] \
   && [ "${HEXA_REMOTE_NO_ADMISSION:-0}" != "1" ] \
   && [ -n "${_best_avail:-}" ] \
   && [ "${_best_avail:-0}" != "-1" ]; then
    # L3: classify and pick class default MIN_AVAIL.
    _job_class="$(_classify_job "$@")"
    case "$_job_class" in
        small)  _class_default_min=2048 ;;
        medium) _class_default_min=8192 ;;
        large)  _class_default_min=24576 ;;
        *)      _class_default_min=4096 ;;
    esac
    _class_uc="$(printf '%s' "$_job_class" | tr '[:lower:]' '[:upper:]')"
    _class_min_var="HEXA_REMOTE_MIN_AVAIL_MB_${_class_uc}"
    eval "_class_min_mb=\${${_class_min_var}:-$_class_default_min}"
    # Host-specific & global override remain higher priority (기존 L2 동작 보존).
    _admit_host_uc="$(printf '%s' "$HOST" | tr '[:lower:]' '[:upper:]')"
    _admit_min_var="HEXA_REMOTE_MIN_AVAIL_MB_${_admit_host_uc}"
    _admit_min_mb="$(eval "printf '%s' \"\${${_admit_min_var}:-\${HEXA_REMOTE_MIN_AVAIL_MB:-$_class_min_mb}}\"")"
    if [ "${_best_avail:-0}" -lt "${_admit_min_mb}" ] 2>/dev/null; then
        echo "hexa_remote: L3 admission reject — host=$HOST class=$_job_class avail=${_best_avail}MB < min=${_admit_min_mb}MB" >&2
        # Slot 즉시 반납 (lock leak 방지). _ACQUIRED 가 비어있어도 안전.
        if [ -n "${_ACQUIRED:-}" ]; then
            rm -rf "$_ACQUIRED" 2>/dev/null || true
            _ACQUIRED=""
        fi
        # Sub-AA 2026-04-27: L3 admission blacklist write retired.
        # exit 64 below alone triggers fallback chain — caller's next host
        # pick is fresh-probed, so transient avail spikes don't ban hosts.
        # AI-native JSON emit — caller 가 fallback chain 진입.
        printf 'NEXUS_REMOTE_ERROR {"host":"%s","avail_mb":%s,"min_mb":%s,"job_class":"%s","reason":"l3_admission_insufficient_ram","exit_code":64}\n' \
            "$HOST" "$_best_avail" "$_admit_min_mb" "$_job_class" >&2
        exit 64
    fi
    # ──────────────────────────────────────────────────────────────────────
    # Sub-AG (2026-04-27): L8 GPU class admission. class=gpu 인 경우 host
    # 의 GPU memory.free (MB) 가 임계 미만이면 reject + fallback chain
    # trigger. 임계는 _classify_job 의 gpu trigger 와 페어 — RTX 5070 12GB
    # 기준 default 8192MB (drill+CUDA inference 가 stage0 로 buffer alloc 시
    # 8GB 여유는 보수). Override:
    #   HEXA_REMOTE_GPU_MIN_AVAIL_MB              (global)
    #   HEXA_REMOTE_GPU_MIN_AVAIL_MB_<HOST_UPPER> (per-host)
    # Bypass: HEXA_REMOTE_NO_GPU_ADMISSION=1
    # 물리적 한계 정합 (raw 36 fixpoint): RTX 5070 VRAM 12GB - workload 4GB
    # ≈ 8GB free 임계 → 동시 dispatch ≤ 1 GPU job per host. 더 작은 모델은
    # HEXA_REMOTE_GPU_MIN_AVAIL_MB=2048 으로 완화.
    if [ "$_job_class" = "gpu" ] && [ "${HEXA_REMOTE_NO_GPU_ADMISSION:-0}" != "1" ]; then
        _gpu_admit_default=8192
        _gpu_admit_host_var="HEXA_REMOTE_GPU_MIN_AVAIL_MB_${_admit_host_uc}"
        _gpu_admit_min_mb="$(eval "printf '%s' \"\${${_gpu_admit_host_var}:-\${HEXA_REMOTE_GPU_MIN_AVAIL_MB:-$_gpu_admit_default}}\"")"
        _picked_gpu_safe="${_picked_gpu_avail:-0}"
        if [ "$_picked_gpu_safe" -lt "$_gpu_admit_min_mb" ] 2>/dev/null; then
            echo "hexa_remote: L8 GPU admission reject — host=$HOST class=$_job_class gpu_avail=${_picked_gpu_safe}MB < min=${_gpu_admit_min_mb}MB" >&2
            if [ -n "${_ACQUIRED:-}" ]; then
                rm -rf "$_ACQUIRED" 2>/dev/null || true
                _ACQUIRED=""
            fi
            # raw 66 ai-native trailer (Sub-W pattern reuse).
            echo "reason: l8-gpu-insufficient: host=$HOST gpu_free=${_picked_gpu_safe}MB < ${_gpu_admit_min_mb}MB" >&2
            echo "fix: 1) check ssh $HOST nvidia-smi for active GPU workload" >&2
            echo "     2) HEXA_REMOTE_GPU_MIN_AVAIL_MB=2048 (smaller model) OR =0 (force-pass)" >&2
            echo "     3) HEXA_REMOTE_NO_GPU_ADMISSION=1 to bypass entirely (CPU fallback)" >&2
            echo "     4) wait + retry — RTX 5070 idle baseline ~226MB used / 12000MB free" >&2
            printf 'NEXUS_REMOTE_ERROR {"host":"%s","gpu_avail_mb":%s,"gpu_min_mb":%s,"job_class":"%s","reason":"l8_gpu_insufficient","exit_code":64}\n' \
                "$HOST" "$_picked_gpu_safe" "$_gpu_admit_min_mb" "$_job_class" >&2
            exit 64
        fi
        echo "hexa_remote: L8 GPU admission pass — host=$HOST class=$_job_class gpu_avail=${_picked_gpu_safe}MB >= min=${_gpu_admit_min_mb}MB" >&2
        # Sub-AK (2026-04-27): GPU concurrent slot acquire. Caps physical
        # over-commit beyond what L8 admission alone permits (admission is
        # single-shot avail check; slot tracks active concurrent jobs).
        if command -v _acquire_gpu_slot >/dev/null 2>&1 && [ "${HEXA_REMOTE_NO_GPU_CONCURRENCY:-0}" != "1" ]; then
            _gpu_max_h="$(_per_host_gpu_max "$HOST")"
            if _acquire_gpu_slot "$HOST"; then
                echo "hexa_remote: L8 GPU slot acquired — host=$HOST slot=${_GPU_ACQUIRED} max_concurrent=${_gpu_max_h}" >&2
            else
                echo "hexa_remote: L8 GPU slot exhausted — host=$HOST max_concurrent=${_gpu_max_h} all in use" >&2
                if [ -n "${_ACQUIRED:-}" ]; then
                    rm -rf "$_ACQUIRED" 2>/dev/null || true
                    _ACQUIRED=""
                fi
                echo "reason: l8-gpu-slot-exhausted: host=$HOST all ${_gpu_max_h} GPU slots busy" >&2
                echo "fix: 1) wait + retry (other GPU jobs holding slots)" >&2
                echo "     2) HEXA_REMOTE_GPU_CONCURRENCY=<n> raise cap (RTX 5070 12GB physical limit)" >&2
                echo "     3) HEXA_REMOTE_NO_GPU_CONCURRENCY=1 bypass slot tracking (admission-only)" >&2
                echo "     4) hexa run tool/cluster_load_audit.hexa  # check GPU util" >&2
                printf 'NEXUS_REMOTE_ERROR {"host":"%s","gpu_max":%s,"job_class":"%s","reason":"l8_gpu_slot_exhausted","exit_code":64}\n' \
                    "$HOST" "$_gpu_max_h" "$_job_class" >&2
                exit 64
            fi
        fi
    fi
    # ──────────────────────────────────────────────────────────────────────
    # Wave 25 / L4 (2026-04-25): cgroup PSI feedback admission throttle.
    # L1-L3 는 dispatch-time *static* admission (작업 시작 전 RAM avail snapshot).
    # L4 는 *post-dispatch live* signal — `/proc/pressure/memory` 의 `some avg10`
    # (최근 10초간 어떤 task 라도 메모리 stall 한 시간 비율 %) 가 임계 초과면
    # 이미 호스트가 메모리 압박 상태이므로 다음 admission 을 보수적으로 reject.
    # avail RAM 만으로 알 수 없는 "free 처럼 보이지만 reclaim 중" 케이스 차단
    # → cluster 활용도 RAM 70% → 82% 목표 (실효 throughput 기준).
    #
    # Class-aware threshold 매트릭스:
    #   small  → some avg10 ≥ 70% reject (관대 — 짧은 작업, peak RSS 낮음)
    #   medium → some avg10 ≥ 50% reject
    #   large  → some avg10 ≥ 30% reject (보수적 — peak RSS 큼, 압박 가속 위험)
    # 우선순위:
    #   1) HEXA_REMOTE_PSI_REJECT_PCT  (global override, 모든 class 적용)
    #   2) class default (70/50/30)
    # macOS 호스트는 /proc/pressure/memory 부재 → probe 가 _picked_psi="" 로 둠
    # → 이 가드 자동 skip (class-aware default 미적용). Mac heavy-compute 는 어차피
    # 차단되어 있어 무영향.
    # Bypass: HEXA_REMOTE_NO_PSI_GATE=1
    if [ "${HEXA_REMOTE_NO_PSI_GATE:-0}" != "1" ] \
       && [ -n "${_picked_psi:-}" ]; then
        _psi_threshold="${HEXA_REMOTE_PSI_REJECT_PCT:-}"
        if [ -z "$_psi_threshold" ]; then
            # nxs-20260425-003 Phase 1 (cycle 38, 2026-04-25):
            # small class default 70 → 85 — 평소 hetzner/htz host load 77~92%
            # 보다 엄격한 70 으로 모든 host reject → docker fallback →
            # drill_zero_yield 발생 (본 세션 cycle 13 evidence). 85 로 상향
            # 하면 일반 host load 통과 가능. user 가 HEXA_REMOTE_PSI_REJECT_PCT
            # explicit set 하면 그대로 우선.
            case "$_job_class" in
                small)  _psi_threshold="85" ;;
                medium) _psi_threshold="65" ;;
                large)  _psi_threshold="45" ;;
                *)      _psi_threshold="65" ;;
            esac
        fi
        # PSI 는 float (e.g. "12.34"). 정수부만 비교 — 임계 자체가 정수 단위라 충분.
        # awk 의 `+0` 으로 숫자 변환 + 부동소수점 자릿수 제거.
        _psi_int="$(printf '%s' "$_picked_psi" | awk -F. '{print $1+0}')"
        if [ -n "$_psi_int" ] && [ "$_psi_int" -ge "$_psi_threshold" ] 2>/dev/null; then
            # ──────────────────────────────────────────────────────────────
            # nxs-20260425-003 Phase 4 / L7 (cycle 52, 2026-04-26):
            # PSI-defer FIFO queue — cross-session drill contention 해결.
            #
            # Background (cycle 51 진단):
            #   다른 Claude 세션 active drill (round 10+) 시 host PSI 97% →
            #   본 세션 dispatch 도 같은 host 진입 시 L4 PSI reject (Phase 1
            #   85% 도 부족) → 모든 host reject → abort. Phase 1 (PSI
            #   threshold) + Phase 4 minimal (lock fast-fail) 만으로 미커버.
            #   (Sub-AA 2026-04-27: 원 narrative "blacklist 모든 host" 표현은
            #    Wave 11 persistent ban 가정 — retired, 현재는 exit 64 fallback.)
            #
            # Mechanism (Mac-side, shared file FIFO + per-host PSI poll):
            #   1) L4 PSI reject 시 즉시 exit 64 대신 /tmp/hexa_remote.psi_queue.<host>.tsv
            #      에 self 등록 (mkdir lock atomic enqueue).
            #   2) Polling loop: head pid=self 이고 PSI 가 threshold 아래로
            #      회복했는지 _probe_host 로 재측정 (HEXA_REMOTE_LAST_PSI 갱신).
            #   3) 회복 시 dequeue + 정상 진행.
            #   4) Deadline (default 300s) 초과 시 dequeue + 기존 exit 64 path
            #      (caller 가 fallback chain 진행). Sub-AA 2026-04-27: deadline
            #      후 blacklist 등록 step retired — next invocation re-probes.
            #
            # Fairness: FIFO head pid 우선 (동시 다 세션 이 같은 host 대기 시
            # enqueue 순서대로 진입). 동일 host 자원 직렬화 → cross-session
            # contention 예측 가능 wait time.
            #
            # 의존도 0 정책: shell script 변경만, 새 helper file/외부 layer
            # 미추가. 기존 mkdir-lock pattern (L6 큐 line 443+) 동일 패턴.
            #
            # Override:
            #   HEXA_REMOTE_NO_PSI_QUEUE=1     L7 비활성 (즉시 exit 64, cycle 51 동작)
            #   HEXA_REMOTE_PSI_QUEUE_TTL=S    deadline (default 300s)
            #   HEXA_REMOTE_PSI_QUEUE_POLL=S   polling 간격 (default 10s)
            # ──────────────────────────────────────────────────────────────
            if [ "${HEXA_REMOTE_NO_PSI_QUEUE:-0}" != "1" ]; then
                _PSI_Q_FILE="/tmp/hexa_remote.psi_queue.${HOST}.tsv"
                _PSI_Q_LOCK="${_PSI_Q_FILE}.lock"
                _PSI_Q_TS="$(date +%s)"
                _PSI_Q_TTL="${HEXA_REMOTE_PSI_QUEUE_TTL:-300}"
                _PSI_Q_POLL="${HEXA_REMOTE_PSI_QUEUE_POLL:-10}"
                _PSI_Q_DEADLINE=$((_PSI_Q_TS + _PSI_Q_TTL))
                # Acquire enqueue lock (atomic mkdir, 5s timeout w/ stale clean).
                _psiq_lock_tries=0
                while ! mkdir "$_PSI_Q_LOCK" 2>/dev/null; do
                    _psiq_lock_tries=$((_psiq_lock_tries + 1))
                    if [ "$_psiq_lock_tries" -ge 50 ]; then
                        _psiq_lock_age="$(( $(date +%s) - $(stat -f %m "$_PSI_Q_LOCK" 2>/dev/null || stat -c %Y "$_PSI_Q_LOCK" 2>/dev/null || date +%s) ))"
                        if [ "$_psiq_lock_age" -ge 30 ]; then
                            rm -rf "$_PSI_Q_LOCK" 2>/dev/null || true
                        fi
                        break
                    fi
                    sleep 0.1
                done
                # Stale-clean: deadline 초과 entry 제거.
                if [ -f "$_PSI_Q_FILE" ]; then
                    _psiq_now="$(date +%s)"
                    awk -F'\t' -v now="$_psiq_now" '$2 > now {print}' "$_PSI_Q_FILE" > "$_PSI_Q_FILE.tmp" 2>/dev/null \
                        && mv "$_PSI_Q_FILE.tmp" "$_PSI_Q_FILE"
                fi
                # Append self: enqueue_ts \t deadline \t class \t pid \t psi_seen
                printf '%s\t%s\t%s\t%s\t%s\n' "$_PSI_Q_TS" "$_PSI_Q_DEADLINE" "$_job_class" "$$" "$_picked_psi" >> "$_PSI_Q_FILE"
                rm -rf "$_PSI_Q_LOCK" 2>/dev/null || true
                # Self-cleanup trap (자기 entry 제거, idempotent w/ dequeue).
                trap '
                    if mkdir "'"$_PSI_Q_LOCK"'" 2>/dev/null; then
                        if [ -f "'"$_PSI_Q_FILE"'" ]; then
                            awk -F"\t" -v p="'"$$"'" "\$4 != p {print}" "'"$_PSI_Q_FILE"'" > "'"$_PSI_Q_FILE"'.tmp" 2>/dev/null \
                                && mv "'"$_PSI_Q_FILE"'.tmp" "'"$_PSI_Q_FILE"'"
                        fi
                        rm -rf "'"$_PSI_Q_LOCK"'" 2>/dev/null || true
                    fi
                    if [ -n "${_ACQUIRED:-}" ]; then rm -rf "$_ACQUIRED" 2>/dev/null || true; fi
                ' EXIT INT TERM
                echo "hexa_remote: L7 PSI-defer queue — host=$HOST class=$_job_class psi=${_picked_psi}% ≥ ${_psi_threshold}% (pid=$$ ttl=${_PSI_Q_TTL}s, polling every ${_PSI_Q_POLL}s)" >&2
                # Polling loop: head pid + PSI 회복 체크.
                _psiq_recovered=0
                while [ "$(date +%s)" -lt "$_PSI_Q_DEADLINE" ]; do
                    sleep "$_PSI_Q_POLL"
                    _psiq_head_pid="$(awk -F'\t' 'NR==1 {print $4}' "$_PSI_Q_FILE" 2>/dev/null || echo "")"
                    if [ "$_psiq_head_pid" != "$$" ]; then
                        continue  # 앞순위 작업 진행 중.
                    fi
                    # head — re-probe PSI.
                    HEXA_REMOTE_LAST_AVAIL=""
                    HEXA_REMOTE_LAST_PSI=""
                    if _probe_host "$HOST"; then
                        _psiq_new_psi="${HEXA_REMOTE_LAST_PSI:-}"
                        _psiq_new_int="$(printf '%s' "$_psiq_new_psi" | awk -F. '{print $1+0}')"
                        if [ -n "$_psiq_new_int" ] && [ "$_psiq_new_int" -lt "$_psi_threshold" ] 2>/dev/null; then
                            # Recovered. Update _picked_psi + _best_avail and dequeue.
                            _picked_psi="$_psiq_new_psi"
                            _best_avail="${HEXA_REMOTE_LAST_AVAIL:-$_best_avail}"
                            if mkdir "$_PSI_Q_LOCK" 2>/dev/null; then
                                if [ -f "$_PSI_Q_FILE" ]; then
                                    awk -F'\t' -v p="$$" '$4 != p {print}' "$_PSI_Q_FILE" > "$_PSI_Q_FILE.tmp" 2>/dev/null \
                                        && mv "$_PSI_Q_FILE.tmp" "$_PSI_Q_FILE"
                                fi
                                rm -rf "$_PSI_Q_LOCK" 2>/dev/null || true
                            fi
                            echo "hexa_remote: L7 dequeued — host=$HOST psi recovered ${_picked_psi}% < ${_psi_threshold}% after $(( $(date +%s) - _PSI_Q_TS ))s wait" >&2
                            _psiq_recovered=1
                            break
                        fi
                    fi
                done
                if [ "$_psiq_recovered" = "1" ]; then
                    : # fall-through to success path below (skip exit 64).
                else
                    # Sub-AA 2026-04-27: L7 PSI deadline blacklist write retired.
                    # exit 64 alone triggers fallback chain — next invocation
                    # gets a fresh PSI snapshot. PSI spikes are by nature transient.
                    echo "hexa_remote: L7 PSI-defer timeout (${_PSI_Q_TTL}s) — host=$HOST psi 회복 실패, fallback chain trigger" >&2
                    if [ -n "${_ACQUIRED:-}" ]; then
                        rm -rf "$_ACQUIRED" 2>/dev/null || true
                        _ACQUIRED=""
                    fi
                    printf 'NEXUS_REMOTE_ERROR {"host":"%s","psi_avg10":"%s","psi_threshold":%s,"job_class":"%s","reason":"l7_psi_defer_timeout","wait_s":%s,"exit_code":64}\n' \
                        "$HOST" "$_picked_psi" "$_psi_threshold" "$_job_class" "$_PSI_Q_TTL" >&2
                    exit 64
                fi
            else
                # Original Phase 1 behavior (NO_PSI_QUEUE=1 bypass).
                # Sub-AA 2026-04-27: L4 PSI reject blacklist write retired.
                echo "hexa_remote: L4 PSI reject — host=$HOST class=$_job_class psi_avg10=${_picked_psi}% ≥ ${_psi_threshold}%" >&2
                if [ -n "${_ACQUIRED:-}" ]; then
                    rm -rf "$_ACQUIRED" 2>/dev/null || true
                    _ACQUIRED=""
                fi
                printf 'NEXUS_REMOTE_ERROR {"host":"%s","psi_avg10":"%s","psi_threshold":%s,"job_class":"%s","reason":"l4_psi_pressure","exit_code":64}\n' \
                    "$HOST" "$_picked_psi" "$_psi_threshold" "$_job_class" >&2
                exit 64
            fi
        fi
    fi
    # Success path — class/min/psi 한 줄 진단 (caller observability).
    echo "hexa_remote: L3+L4 class=$_job_class min_avail=${_admit_min_mb}MB psi=${_picked_psi:-NA}% host=$HOST" >&2

    # ──────────────────────────────────────────────────────────────────────
    # Wave 26 / L5 (2026-04-25): Bayesian predictive admission.
    # L1-L4 는 reactive (호스트 현재 상태 → 정적 임계). L5 는 predictive —
    # 같은 (host, class) 의 과거 dispatch 결과 (rc=137/143 SIGTERM 비율) 를
    # Beta-Bernoulli posterior 로 추정해, false-negative reject 를 줄이면서도
    # 미래 SIGTERM 확률이 높으면 사전 차단. 목표: cluster RAM 활용 82% → 90%+.
    #
    # History TSV (`/tmp/hexa_remote.history.<host>.<class>.tsv`) 형식:
    #   ts<TAB>avail<TAB>psi<TAB>class<TAB>cmd<TAB>seed_len<TAB>pid<TAB>STATE
    #   STATE = "START" | "END_<rc>"
    # 기록 위치: START — L5 가드 통과 직후 / END — exit trap 에서.
    # 길이/파일 회전: append-only TSV. 무한 누적 방지 = 사용자 책임 (또는 별도 cron).
    #   `tail -n WINDOW` 으로 최근 N 만 사용하므로 파일이 커도 읽기 비용은 일정.
    #
    # Posterior: Beta(1,1) uniform prior + Bernoulli likelihood
    #   p_post = (kills + 1) / (total + 2)  ← Laplace smoothing
    # `tail -n WINDOW` END_ 레코드 중 rc∈{137,143} 카운트가 kills.
    #
    # Override:
    #   HEXA_REMOTE_BAYES_WINDOW=N        (default 50) — recent record window
    #   HEXA_REMOTE_BAYES_REJECT_PCT=N    (default 30) — p_post(%) ≥ N → reject
    #   HEXA_REMOTE_BAYES_MIN_SAMPLE=N    (default 5)  — total < N 이면 skip (신뢰 부족)
    #   HEXA_REMOTE_NO_BAYES=1            — gate 비활성
    _HISTORY_FILE="/tmp/hexa_remote.history.${HOST}.${_job_class}.tsv"
    # cmd/seed 추출 — _classify_job 과 동일 알고리즘 inline.
    _l5_cmd=""; _l5_seed=""
    for ((_li=1; _li<=$#; _li++)); do
        case "${!_li}" in
            drill|omega|surge|smash|free|absolute|meta-closure|hyperarithmetic|probe|status|canon)
                [ -z "$_l5_cmd" ] && _l5_cmd="${!_li}" ;;
            --seed) _lj=$((_li+1)); _l5_seed="${!_lj:-}" ;;
        esac
    done
    [ -z "$_l5_cmd" ] && _l5_cmd="?"

    if [ "${HEXA_REMOTE_NO_BAYES:-0}" != "1" ] && [ -r "$_HISTORY_FILE" ]; then
        _bayes_window="${HEXA_REMOTE_BAYES_WINDOW:-50}"
        _bayes_min_sample="${HEXA_REMOTE_BAYES_MIN_SAMPLE:-5}"
        _bayes_threshold="${HEXA_REMOTE_BAYES_REJECT_PCT:-30}"
        _bayes_stats="$(tail -n "$_bayes_window" "$_HISTORY_FILE" 2>/dev/null | awk -F'\t' '
            $8 ~ /^END_/ {
                total++
                rc = substr($8, 5) + 0
                if (rc == 137 || rc == 143) kills++
            }
            END { printf "%d %d", kills+0, total+0 }')"
        _bayes_kills="$(printf '%s' "$_bayes_stats" | awk '{print $1}')"
        _bayes_total="$(printf '%s' "$_bayes_stats" | awk '{print $2}')"
        if [ "${_bayes_total:-0}" -ge "$_bayes_min_sample" ] 2>/dev/null; then
            # p_post(%) = (kills+1) * 100 / (total+2) — integer truncation.
            _bayes_p_pct="$(awk -v k="$_bayes_kills" -v t="$_bayes_total" \
                'BEGIN { printf "%d", (k+1)*100/(t+2) }')"
            if [ "$_bayes_p_pct" -ge "$_bayes_threshold" ] 2>/dev/null; then
                echo "hexa_remote: L5 Bayes reject — host=$HOST class=$_job_class p=${_bayes_p_pct}% (kills=$_bayes_kills/total=$_bayes_total window=$_bayes_window) ≥ ${_bayes_threshold}%" >&2
                # Slot release (L3/L4 reject path 와 동일 cleanup).
                if [ -n "${_ACQUIRED:-}" ]; then
                    rm -rf "$_ACQUIRED" 2>/dev/null || true
                    _ACQUIRED=""
                fi
                # Sub-AA 2026-04-27: L5 Bayes reject blacklist write retired.
                # Bayes window stats (kills/total) provide implicit memory across
                # invocations without persistent host bans.
                printf 'NEXUS_REMOTE_ERROR {"host":"%s","p_pct":%s,"kills":%s,"total":%s,"window":%s,"threshold":%s,"job_class":"%s","reason":"l5_bayes_predicted_kill","exit_code":64}\n' \
                    "$HOST" "$_bayes_p_pct" "$_bayes_kills" "$_bayes_total" "$_bayes_window" "$_bayes_threshold" "$_job_class" >&2
                exit 64
            fi
            echo "hexa_remote: L5 Bayes pass — p=${_bayes_p_pct}% (kills=$_bayes_kills/total=$_bayes_total) < ${_bayes_threshold}%" >&2
        fi
        # else: sample 부족 → silent skip (가드 비활성, 학습 단계).
    fi

    # L5: START record append. 파일 없으면 자동 생성 (>> 가 처리).
    _l5_t_start="$(date +%s)"
    _l5_seed_len="${#_l5_seed}"
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\tSTART\n' \
        "$_l5_t_start" "${_best_avail:-0}" "${_picked_psi:-}" \
        "$_job_class" "$_l5_cmd" "$_l5_seed_len" "$$" \
        >> "$_HISTORY_FILE" 2>/dev/null || true

    # L5: END record on exit. 기존 slot-release trap (line ~278) 과 합쳐 단일 trap 으로
    # 재설정 — bash trap 은 누적되지 않으므로 _ACQUIRED cleanup 도 함께 보존해야 함.
    # 변수 일부는 상위 scope 의 단일값이라 trap 본문에 인라인으로 박아 expansion 시점
    # 차이로 인한 손실 방지.
    _l5_hist_args="${_HISTORY_FILE}"
    _l5_const_prefix="${_best_avail:-0}\t${_picked_psi:-}\t${_job_class}\t${_l5_cmd}\t${_l5_seed_len}\t$$"
    trap '_l5_rc=$?; printf "%s\t'"$_l5_const_prefix"'\tEND_%s\n" "$(date +%s)" "$_l5_rc" >> "'"$_l5_hist_args"'" 2>/dev/null || true; rm -rf "${_ACQUIRED:-}" 2>/dev/null || true; exit $_l5_rc' EXIT INT TERM
fi

# 2026-04-22: 구 default ($HOME/Dev/hexa-lang/hexa) 는 4월14 빌드 — `^` / `&` 비트연산자 파서 미지원.
#   ubu1 기준 $HOME/.hx/bin/hexa_real 은 4월19+ 빌드 — run.hexa line 1048 ($HOME/.hx/packages/nexus/cli/run.hexa FNV-hash) 파싱 성공.
#   rebuild 전까지 default 교체.
REMOTE_HEXA="${HEXA_REMOTE_BIN:-\$HOME/.hx/bin/hexa_real}"

CWD="$(pwd -P)"
# macOS case-insensitive FS: lowercase for detection only; preserve CWD for rsync source.
CWD_LC="$(printf '%s' "$CWD" | tr '[:upper:]' '[:lower:]')"
HOME_LC="$(printf '%s' "$HOME" | tr '[:upper:]' '[:lower:]')"

# 2026-04-27 (r4 5a): SSOT files are Mac-canonical with chflags uchg/uappnd. On
# remote hosts the same files carry chattr +i so rsync's "rename .raw.tmp -> .raw"
# strategy hits EPERM → rsync rc=23 ("partial transfer with errors") → hexa_remote
# exit 64 → Mac docker hard-landing fallback → docker pids-cap fork storm (5b).
# Excluding SSOT files from rsync prevents the entire chain. SSOT canonical state
# is Mac-side; remotes already have their own snapshot via prior dispatch or
# never need them (drill/smash/free runtime does not consume SSOT files).
# Hexa-lang has its own .raw self-format file too — exclude pattern matches both.
SSOT_EXCLUDES=(
    --exclude=.raw
    --exclude=.own
    --exclude=.roadmap
    --exclude=.guide
    --exclude=.ext
    --exclude=.turn
    --exclude=.end
    --exclude=.command
    --exclude=.meta
    --exclude=.chain
    --exclude=.raw-audit
)

case "$CWD_LC" in
  "$HOME_LC/dev/airgenome"|"$HOME_LC/dev/airgenome"/*|"$HOME_LC/core/airgenome"|"$HOME_LC/core/airgenome"/*)
    LOCAL_ROOT="${CWD%%/[Aa]irgenome*}/airgenome"
    # 2026-04-25: ~/core/airgenome added (Dev→core migration). Prefer core/
    # first so CWD_LC prefix strip resolves when both exist.
    for candidate in "$HOME/core/airgenome" "$HOME/Dev/airgenome" "$HOME/dev/airgenome"; do
        [ -d "$candidate" ] && LOCAL_ROOT="$candidate" && break
    done
    REMOTE_ROOT='$HOME/airgenome'
    SYNC_EXCLUDES=("${SSOT_EXCLUDES[@]}"
                   --exclude=archive/v1/ --exclude=data/ --exclude=__pycache__/
                   --exclude=.git/ --exclude='*.log' --exclude=.DS_Store)
    ;;
  "$HOME_LC/dev/nexus"|"$HOME_LC/dev/nexus"/*|"$HOME_LC/core/nexus"|"$HOME_LC/core/nexus"/*)
    # 2026-04-22: $HOME/core/nexus 는 $HOME/Dev/nexus 의 canonical 물리 경로.
    # pwd -P 가 symlink 를 해제해 cwd 는 항상 core/ → LOCAL_ROOT 도 core/ 우선이라야
    # CWD_LC prefix strip (REL) 이 빈 문자열이 되고 REMOTE_ROOT 로 정확 dispatch 된다.
    for candidate in "$HOME/core/nexus" "$HOME/Dev/nexus" "$HOME/dev/nexus"; do
        [ -d "$candidate" ] && LOCAL_ROOT="$candidate" && break
    done
    REMOTE_ROOT='$HOME/Dev/nexus'
    # 2026-04-24: shared/{config,roadmaps,harness/safe_hexa_launchd.sh} 는
    # nexus-local compat symlink. 원격에는 real directory 로 존재 → rsync
    # "could not make way for new symlink" + "cannot delete non-empty directory"
    # code=23 → hexa_remote exit 64 → Mac 래퍼 rc=74 증폭. 세 경로 sync 제외.
    # 원본 config/ roadmaps/ tool/ 은 top-level 로 sync 되므로 정보 손실 없음.
    SYNC_EXCLUDES=("${SSOT_EXCLUDES[@]}"
                   --exclude=.git/ --exclude='*.log' --exclude=.DS_Store
                   --exclude=.runtime/ --exclude=shared/blowup/lens/
                   --exclude=shared/config --exclude=shared/roadmaps
                   --exclude=shared/harness/safe_hexa_launchd.sh)
    ;;
  "$HOME_LC/dev/anima"|"$HOME_LC/dev/anima"/*|"$HOME_LC/core/anima"|"$HOME_LC/core/anima"/*)
    # 2026-04-25: ~/core/anima added (Dev→core migration mirror).
    for candidate in "$HOME/core/anima" "$HOME/Dev/anima" "$HOME/dev/anima"; do
        [ -d "$candidate" ] && LOCAL_ROOT="$candidate" && break
    done
    REMOTE_ROOT='$HOME/anima'
    # anima = 87GB, mostly data/artifacts. Sync only source code paths;
    # exclude large data trees. Local anima-engines/ is ~1.2MB.
    SYNC_EXCLUDES=(
        "${SSOT_EXCLUDES[@]}"
        --exclude=.git/
        --exclude='*.log'
        --exclude=.DS_Store
        --exclude=__pycache__/
        --exclude=ready/
        --exclude=checkpoints/
        --exclude=models/
        --exclude=data/
        --exclude=shared/
        --exclude=logs/
        --exclude=training/
        --exclude=docs/
        --exclude=bench/
        --exclude=.claude-memory/
        --exclude=.growth/
        --exclude=.claude/
    )
    ;;
  "$HOME_LC/core/n6-architecture"|"$HOME_LC/core/n6-architecture"/*)
    # 2026-04-24: n6-architecture remote dispatch — heavy-compute must offload
    # to ubu/htz same as sister Dev/core repos. Without this branch, exit 64
    # at cwd-unmappable fallthrough -> outer wrapper Darwin heavy-compute abort-74.
    for candidate in "$HOME/core/n6-architecture"; do
        [ -d "$candidate" ] && LOCAL_ROOT="$candidate" && break
    done
    REMOTE_ROOT='$HOME/core/n6-architecture'
    SYNC_EXCLUDES=(
        "${SSOT_EXCLUDES[@]}"
        --exclude=.git/
        --exclude='*.log'
        --exclude=.DS_Store
        --exclude=__pycache__/
        --exclude=.claude/
        --exclude=.growth/
        --exclude=reports/history/
        --exclude=build/
    )
    ;;
  "$HOME_LC/core/hive"|"$HOME_LC/core/hive"/*)
    # 2026-04-25: hive cwd mapping — raw 40/42 enforcement. hive 의 gate/lint/tool
    # 호출이 external host 에서 실행돼야 ~/.hx/bin/hexa resolver 가 cwd_unmappable
    # fallback (mac local-flock) 을 회피. SIGKILL 5건 jetsam 사고 (2026-04-25)
    # 직접 원인 — gate hexa_v2 가 mac 에서 누적 RSS 폭주.
    for candidate in "$HOME/core/hive"; do
        [ -d "$candidate" ] && LOCAL_ROOT="$candidate" && break
    done
    REMOTE_ROOT='$HOME/core/hive'
    SYNC_EXCLUDES=(
        "${SSOT_EXCLUDES[@]}"
        --exclude=.git/
        --exclude='*.log'
        --exclude=.DS_Store
        --exclude=__pycache__/
        --exclude=node_modules/
        --exclude=exports/
        --exclude=build/
        --exclude=.hexa-cache/
        --exclude=.claude/
        --exclude=.growth/
    )
    ;;
  "$HOME_LC/core/hexa-lang"|"$HOME_LC/core/hexa-lang"/*)
    # 2026-04-29: hexa-lang cwd mapping — closes the cwd_unmappable infinite
    # fallback loop documented in /private/tmp/hexa_sleep_mode.err (60KB log
    # of NEXUS_REMOTE_ERROR + docker hard-landing cycle, ~30s cadence). Sister
    # to the 5 existing repo cases (airgenome / nexus / anima / n6-architecture
    # / hive). Without this branch, every hexa_remote dispatch with cwd inside
    # ~/core/hexa-lang exit-64 falls through to docker hard-landing — costly
    # because hexa-lang is the canonical compiler+stdlib repo and tools invoke
    # hexa_remote frequently from there.
    for candidate in "$HOME/core/hexa-lang"; do
        [ -d "$candidate" ] && LOCAL_ROOT="$candidate" && break
    done
    REMOTE_ROOT='$HOME/core/hexa-lang'
    SYNC_EXCLUDES=(
        "${SSOT_EXCLUDES[@]}"
        --exclude=.git/
        --exclude='*.log'
        --exclude=.DS_Store
        --exclude=__pycache__/
        --exclude=node_modules/
        --exclude=build/
        --exclude=dist/
        --exclude=.hexa-cache/
        --exclude=hexa.bak_*
        --exclude=hexa-build/
        --exclude=.claude/
        --exclude=.growth/
    )
    ;;
  *)
    # 2026-04-25: unmapped cwd fallback for self-contained binaries.
    # heavy-compute 가 ~ 또는 repo 밖에서 호출돼도 drill/smash/free 는 실행돼야 함.
    # 대상 바이너리가 원격에 이미 설치된 파일 ($HOME/.hx/packages/.../run.hexa 등)
    # 이면 rsync 없이 $HOME 기준으로 원격 실행 (self-contained install).
    # 그 외 cwd 는 proper JSON emit 후 exit 64 — 상위 wrapper 의 hosts_tried parser
    # 가 정확한 진단을 출력하도록.
    _target="${2:-}"
    case "$_target" in
        "$HOME/.hx/packages/"*"/cli/"*.hexa|"$HOME/.hx/packages/"*"/bin/"*.hexa)
            # Self-contained: installed CLI binary. No rsync; cd $HOME on remote.
            # Use CWD as LOCAL_ROOT so REL strips to "" → REMOTE_CMD does cd $HOME
            # (not $HOME/<mac-cwd-rel>, which may not exist on remote).
            LOCAL_ROOT="$CWD"
            REMOTE_ROOT='$HOME'
            SYNC_EXCLUDES=()
            HEXA_REMOTE_NO_SYNC=1
            ;;
        *)
            _cwd_hosts_json=""
            for _h in $FALLBACK_CHAIN; do
                if [ -z "$_cwd_hosts_json" ]; then _cwd_hosts_json="\"$_h\""
                else _cwd_hosts_json="$_cwd_hosts_json,\"$_h\""; fi
            done
            printf 'NEXUS_REMOTE_ERROR {"hosts_tried":[%s],"reason":"cwd_unmappable","cwd":"%s","exit_code":64}\n' "$_cwd_hosts_json" "$CWD" >&2
            exit 64
            ;;
    esac
    ;;
esac

# heavy-compute no-sync override: 어떤 case 가 매치됐든 LOCAL_ROOT 을 CWD 로,
# REMOTE_ROOT 을 \$HOME 으로 강제 → REL="" → cd \$HOME on remote.
if [ "$_IS_HEAVY_COMPUTE" = "1" ]; then
    LOCAL_ROOT="$CWD"
    REMOTE_ROOT='$HOME'
fi

# Relative path from LOCAL_ROOT (case-insensitive strip).
LOCAL_ROOT_LC="$(printf '%s' "$LOCAL_ROOT" | tr '[:upper:]' '[:lower:]')"
REL="${CWD_LC#$LOCAL_ROOT_LC}"
REL="${REL#/}"

# Wave 21 (2026-04-25): docker exec isolation mode. When HEXA_REMOTE_DOCKER=1,
# drill 은 host 의 systemd-run scope 가 아니라 host 위에 떠있는 docker 컨테이너
# (`airgenome-claude`, 8GB cap, network=host) 안에서 실행된다. host RAM 무관 →
# host OOM / sshd banner-timeout 차단. 컨테이너에는 image-baked nexus
# ($HOME/.hx/packages/nexus/cli/run.hexa, HOME=/root) 가 있어 rsync 불요.
# 첫 단계는 opt-in (env=1). 안전성 확인 후 default ON 은 별도 wave.
# Override: HEXA_REMOTE_DOCKER_CONTAINER (default airgenome-claude).
if [ "${HEXA_REMOTE_DOCKER:-0}" = "1" ]; then
    HEXA_REMOTE_NO_SYNC=1
    # 컨테이너 안에는 project tree 가 없음 → cwd /tmp + REMOTE_ROOT=$HOME 강제.
    REMOTE_ROOT='$HOME'
    REL=""
fi

if [ "${HEXA_REMOTE_NO_SYNC:-0}" != "1" ]; then
  # ssh 옵션 — rsync 중 네트워크 끊기면 30s 안에 감지 (기본 default 무한 대기 방지).
  # 2026-04-22: ControlPath 을 ~/.ssh/ 밖(/tmp)으로 이동 — Mac TCC 가 ~/.ssh/ctl-* link() 차단 (muxserver_listen EPERM).
  RSYNC_SSH='ssh -o ConnectTimeout=10 -o ServerAliveInterval=30 -o ServerAliveCountMax=10 -o BatchMode=yes -o ControlMaster=no -o ControlPath=none'
  RSYNC_ERR_FILE="$(mktemp -t hexa_remote_rsync.XXXXXX 2>/dev/null || echo /tmp/hexa_remote_rsync.$$)"
  # --mkpath: receiver 측 parent dir 부재 시 자동 생성 (htz/hetzner ~/core 미존재로 hive
  # dispatch 시 code 11 발생). rsync 3.2.3+ 필요 — 모든 호스트 3.2.7 확인됨.
  rsync -aH --mkpath -e "$RSYNC_SSH" "${SYNC_EXCLUDES[@]}" "$LOCAL_ROOT/" "$HOST:${REMOTE_ROOT#\$HOME/}/" >/dev/null 2>"$RSYNC_ERR_FILE"
  rsync_rc=$?
  # 2026-04-27 (r4 5a): rc=23 graceful path. rc=23 = "partial transfer due to error"
  # — most common cause is EPERM on rename to chattr +i target (immutable SSOT files
  # on remote). With SSOT_EXCLUDES applied above, this should never trigger for SSOT;
  # if it does, the offending files are by definition NOT business-critical for the
  # dispatch (drill/smash/free runtimes don't read SSOT). Log + treat as success
  # rather than cascading to docker hard-landing fork-storm (defect 5b).
  if [ "$rsync_rc" = "23" ]; then
    cp -f "$RSYNC_ERR_FILE" /tmp/hexa_remote_last_rsync_warn.log 2>/dev/null
    rsync_last="$(tail -n 1 "$RSYNC_ERR_FILE" 2>/dev/null)"
    echo "hexa_remote: rsync rc=23 partial-transfer 무시 ($HOST): ${rsync_last:-EPERM on immutable target} [warn: /tmp/hexa_remote_last_rsync_warn.log]" >&2
    rm -f "$RSYNC_ERR_FILE"
    rsync_rc=0
  fi
  if [ "$rsync_rc" -ne 0 ]; then
    # rsync_rc 캡처는 if-block 밖에서. 기존 `if ! rsync; then rsync_rc=$?` 는 항상 0
    # (if-test 통과 결과) 이라 진짜 rc 가 묻혀 진단 불가능했음.
    cp -f "$RSYNC_ERR_FILE" /tmp/hexa_remote_last_rsync_err.log 2>/dev/null
    rsync_last="$(tail -n 1 "$RSYNC_ERR_FILE" 2>/dev/null)"
    rm -f "$RSYNC_ERR_FILE"
    echo "hexa_remote: rsync 실패 ($HOST, rc=$rsync_rc): ${rsync_last:-원인 미상} [full: /tmp/hexa_remote_last_rsync_err.log]" >&2
    # raw 66 ai-native trailer. classify by rsync rc:
    #   23 = partial transfer (typically EPERM on chattr +i target SSOT)
    #   11/12 = filesystem error (parent dir missing → --mkpath should cover)
    #   1/35/255 = ssh / network class
    case "$rsync_rc" in
        23) _rs_class="rsync-eperm" ;;
        11|12) _rs_class="readonly-fs" ;;
        1|35|255) _rs_class="ssh-fail" ;;
        *) _rs_class="dispatch-fail" ;;
    esac
    echo "reason: ${_rs_class}: rsync rc=$rsync_rc on host=$HOST (${rsync_last:-원인 미상})" >&2
    echo "fix: 1) cat /tmp/hexa_remote_last_rsync_err.log   # full rsync stderr  2) ssh $HOST 'lsattr ~/Dev/nexus/.raw 2>/dev/null; ls -lO ~/Dev/nexus/.raw'   # check immutable flags  3) HEXA_REMOTE_NO_SYNC=1 hexa_remote   # skip rsync (assume tree fresh)" >&2
    exit 64
  elif [ -s "$RSYNC_ERR_FILE" ]; then
    # rc=0 + non-empty stderr: tree transfer succeeded but rsync emitted warn
    # (post-run delete pass / --mkpath race / control-channel hiccup). Preserve
    # for diagnosis without triggering Mac fallback.
    cp -f "$RSYNC_ERR_FILE" /tmp/hexa_remote_last_rsync_warn.log 2>/dev/null
  fi
  rm -f "$RSYNC_ERR_FILE"
fi

quote_args() {
  local out=''
  local a
  for a in "$@"; do
    out+=" $(printf %q "$a")"
  done
  printf '%s' "$out"
}

# P1: 원격 shell EXIT 시 자식 hexa_stage0/hexa.real 정리 (ssh 채널 끊김 → orphan 방지).
# Wave 14c (2026-04-25): trap 단순화 — pkill hexa_real 가 병렬 drill 세션 간
# cross-kill → rc=255 유발. systemd-run --scope 가 자체 lifecycle 로 cgroup 내
# 자식 정리하므로 trap 은 exit 코드 보존만. orphan 이슈는 cgroup scope 내 자동 정리 +
# per-host 주기적 sweep (별도) 로 처리.
REMOTE_TRAP="trap 'rc=\$?; exit \$rc' EXIT INT TERM"
# 2026-04-22: HEXA=$REMOTE_HEXA export — run.hexa 내부 stage 호출 ($HOME/Dev/hexa-lang/hexa 우선 pick)
# 이 ubu1 의 4월14 구빌드로 떨어져 smash/free 가 parser-silent (0 absorption) 되는 것 차단.
# run.hexa 의 hexa_bin() 는 env("HEXA") 를 최우선 — 명시 export 시 모든 inner stage 가 hexa_real 로 통일.
# 2026-04-22 (L14): stage0/hexa_real 을 systemd-run --scope cgroup 으로 wrap — MemoryMax=8G cap.
# ubu1+ubu2 동시 OOM 사고(ubu1 stage0 7.6GB RSS / ubu2 hexa_real 30GB RSS → 호스트 전역 OOM-kill)
# 원인: per-process RAM cap 부재. stage 단위 cgroup MemoryMax=20G / MemoryHigh=16G / TasksMax=512.
# (L7 사고 ubu1 stage0 RSS 7.6GB 관찰 — 정상 범위 6-10G. 20G 는 피크 RSS 대비 2.6× 여유라 reclaim
#  안 발동 → NO_CAP baseline 과 bit-identical perf 유지, 30GB 점유 OOM 은 여전히 차단. L20 참조.
#  초기 12G cap 은 MemoryHigh=10G reclaim stress 로 smash +917 → +21 로 44× perf 저하 관찰 후 bump.)
# htz(root) 는 system scope, ubu1/ubu2(유저) 는 --user scope + XDG_RUNTIME_DIR 필수
# (ssh non-interactive 세션에서 DBUS 소켓 경로 누락 시 systemd-run --user 가 silent fail).
# systemd-run 미설치 또는 XDG_RUNTIME_DIR dir 부재 시 bare exec.
# Override: HEXA_REMOTE_NO_CAP=1 (debug 전용).
# Wave 10 (2026-04-25): 호스트별 cgroup cap — hetzner 128GB 에 20G cap 은
# resonance stage SIGKILL (rc=137) 유발. hetzner 는 80G/64G 로 상향, ubu1/ubu2
# (32GB) 는 기존 20G/16G 유지 (raw#36 bracket).
# Override: HEXA_REMOTE_MEM_MAX / HEXA_REMOTE_MEM_HIGH env.
# Wave 26 (2026-04-25): host-side flock — Wave 22 Mac-side slot gate 가 외부
# source (다른 머신 ssh, nested spawn, bypass dispatch) 는 차단 못 함. hetzner
# 124GB 에서 두 hexa_real 동시 진입 = global OOM (project_hetzner_concurrent_oom.md
# 참조: omega scope run-r5c2a8... + drill scope run-r40174d3c... 두 cgroup
# 각 ~67GB RSS → 호스트 한계 돌파 → kernel global_oom kill omega).
# /tmp/hexa_real.lock 은 호스트 자체 advisory file lock — 모든 source 통합.
# Heavy 만 활성: prompt_scan/probe/status/canon 같은 light 는 _IS_HEAVY_COMPUTE=0
# 으로 lock 우회 (light task 가 60s 대기로 사용성 깎이지 않게).
# Override: HEXA_REMOTE_NO_REMOTE_LOCK=1, HEXA_REMOTE_REMOTE_LOCK_WAIT (default 30s).
# nxs-20260425-003 Phase 4 (cycle 45, 2026-04-25): default 60→30 — 본 세션
# cycle 13b 50min hang 같은 long wait 방지. cross-session contention 시 30s
# 후 flock exit 1 → ssh client NEXUS_REMOTE_ERROR (이미 처리). user override
# (HEXA_REMOTE_REMOTE_LOCK_WAIT) 우선 보존.
_LOCK_W="${HEXA_REMOTE_REMOTE_LOCK_WAIT:-30}"
if [ "$_IS_HEAVY_COMPUTE" = "1" ] && [ "${HEXA_REMOTE_NO_REMOTE_LOCK:-0}" != "1" ]; then
    # nxs-20260425-003 Phase 4 (cycle 46, 2026-04-25): flock -E 64 추가 —
    # lock timeout (default exit 1) → exit 64 명시. ssh client 측 NEXUS_REMOTE
    # _ERROR exit_code:64 자동 propagate. silent hang 대신 cross-session
    # contention 명시 fail.
    _REMOTE_LOCK_PREFIX="flock -E 64 -w $_LOCK_W /tmp/hexa_real.lock "
else
    _REMOTE_LOCK_PREFIX=""
fi

if [ "$HOST" = "hetzner" ] || [ "$HOST" = "htz" ]; then
    _MEM_MAX="${HEXA_REMOTE_MEM_MAX:-80G}"
    _MEM_HIGH="${HEXA_REMOTE_MEM_HIGH:-64G}"
    _SD_CHECK='command -v systemd-run >/dev/null 2>&1'
    _SD_WRAP="systemd-run --scope --quiet -p MemoryMax=$_MEM_MAX -p MemoryHigh=$_MEM_HIGH -p TasksMax=512 -- sh -c 'echo 500 > /proc/self/oom_score_adj 2>/dev/null; exec ${_REMOTE_LOCK_PREFIX}\"\$@\"' --"
else
    _MEM_MAX="${HEXA_REMOTE_MEM_MAX:-20G}"
    _MEM_HIGH="${HEXA_REMOTE_MEM_HIGH:-16G}"
    _SD_CHECK='command -v systemd-run >/dev/null 2>&1 && [ -d "/run/user/$(id -u)" ]'
    _SD_WRAP="export XDG_RUNTIME_DIR=\"/run/user/\$(id -u)\"; systemd-run --user --scope --quiet -p MemoryMax=$_MEM_MAX -p MemoryHigh=$_MEM_HIGH -p TasksMax=512 -- sh -c 'echo 500 > /proc/self/oom_score_adj 2>/dev/null; exec ${_REMOTE_LOCK_PREFIX}\"\$@\"' --"
fi
# 2026-04-25: no-sync mode path rewrite — Mac $HOME/.hx/* (e.g. <mac-home>/.hx/
# packages/nexus/cli/run.hexa) 는 원격의 $HOME (hetzner=<remote-root>, ubu=<remote-summer>)
# 에서 유효하지 않음. Mac-home-absolute 를 unquoted literal $HOME/.hx/ 로 재작성
# → printf %q 가 \$HOME 로 escape → 원격 shell 에서 expand.
# sshfs 마운트 우회로 Mac 경로가 remote 에 접근 가능한 호스트 (ubu2 mac_home) 도
# 있지만, hetzner 같은 non-sshfs 호스트는 반드시 path rewrite 필요.
# Path rewrite: Mac-absolute $HOME/.hx/* 는 remote $HOME 이 다르므로 (hetzner=<remote-root>,
# ubu=<remote-summer>) remote shell 에서 expand 돼야 함. printf %q 가 $ 를 \$ 로 escape
# 하면 remote 에서 literal '$HOME' 이 되어 실패 → 해당 arg 는 quote_args 우회,
# "$HOME/.hx/..." 형태 double-quoted remote literal 로 직접 주입.
_ARG_QUOTED=''
for _a in "$@"; do
    case "$_a" in
        "$HOME/.hx/"*)
            _ARG_QUOTED+=" \"\$HOME/.hx/${_a#$HOME/.hx/}\""
            ;;
        *)
            _ARG_QUOTED+=" $(printf %q "$_a")"
            ;;
    esac
done
if [ "${HEXA_REMOTE_DOCKER:-0}" = "1" ]; then
    # Wave 21: docker exec isolation. Inner command runs inside container —
    # container 는 이미 8GB cap (compose memory 제한) 이고 systemd 부재 → SD wrap 불필요.
    # cwd=/tmp (project tree 없음, drill 은 self-contained run.hexa 사용).
    # bash -c '...' 안의 single-quote 보존을 위해 outer 는 double-quote 로 묶고
    # 내부 single-quote 는 안전. $HOME / $REMOTE_HEXA 는 컨테이너 안에서 expand 된다.
    _DOCKER_CONTAINER="${HEXA_REMOTE_DOCKER_CONTAINER:-airgenome-claude}"
    _INNER_CMD="cd /tmp && export HEXA=\"$REMOTE_HEXA\" HEXA_LOCAL=1 HEXA_NO_LAUNCHD=1 && $REMOTE_HEXA$_ARG_QUOTED"
    # docker exec -i (no -t) 로 stdin/stdout 직통. bash -lc 는 PATH 확보.
    REMOTE_CMD="$REMOTE_TRAP; docker exec -i $_DOCKER_CONTAINER bash -lc $(printf %q "$_INNER_CMD")"
elif [ "${HEXA_REMOTE_NO_CAP:-0}" = "1" ]; then
    # R4 BUG#3 fix (2026-04-27): inject HEXA_LANG so `use "self/stdlib/..."` resolves on remote.
    # Mac sets HEXA_LANG globally; remote ssh shells inherit minimal env without it. Fallback chain.
    # BUG#5 RETIRED (2026-04-27): ANTHROPIC_API_KEY env passthrough removed per user directive. OAuth slot pool (~/.claude-claude<N>/) is canonical credential path.
    # 2026-04-28 fix: search order flipped — $HOME/core/hexa-lang FIRST, $HOME/Dev/hexa-lang SECOND.
    # On hetzner, $HOME/Dev/hexa-lang is a stale symlink to /home/hexa-lang (Apr 19) missing
    # ai_err.hexa stdlib; $HOME/core/hexa-lang has the canonical Apr 27 stdlib including ai_err_exit.
    # Old order surfaced "Runtime error: undefined function: ai_err_exit" on remote kicks (×3).
    REMOTE_CMD="$REMOTE_TRAP; cd \"$REMOTE_ROOT${REL:+/$REL}\" && export HEXA=\"$REMOTE_HEXA\" HEXA_LOCAL=1 HEXA_NO_LAUNCHD=1 HEXA_LANG=\"\$(for d in \$HOME/core/hexa-lang \$HOME/Dev/hexa-lang; do [ -d \$d/self/stdlib ] && [ -f \$d/self/stdlib/ai_err.hexa ] && echo \$d && break; done)\" && ${_REMOTE_LOCK_PREFIX}$REMOTE_HEXA$_ARG_QUOTED"
else
    REMOTE_CMD="$REMOTE_TRAP; cd \"$REMOTE_ROOT${REL:+/$REL}\" && export HEXA=\"$REMOTE_HEXA\" HEXA_LOCAL=1 HEXA_NO_LAUNCHD=1 HEXA_LANG=\"\$(for d in \$HOME/core/hexa-lang \$HOME/Dev/hexa-lang; do [ -d \$d/self/stdlib ] && [ -f \$d/self/stdlib/ai_err.hexa ] && echo \$d && break; done)\" && if $_SD_CHECK; then $_SD_WRAP $REMOTE_HEXA$_ARG_QUOTED; else ${_REMOTE_LOCK_PREFIX}$REMOTE_HEXA$_ARG_QUOTED; fi"
fi

# BUG#5 RETIRED (2026-04-27): pre-flight ANTHROPIC_API_KEY warning block removed per user directive.
# OAuth slot pool (~/.claude-claude<N>/) is the canonical credential path; env API key fallback
# is misleading suggestion that LLM dispatch needs env when slot system handles authentication.

# -T = no pty, ServerAlive = 장시간 compute (drill) 중 네트워크 끊기면 30s 내 감지 후 종료.
# P3: stderr 직통 (2>/dev/null 제거 — 원격 진단정보 surface).
#
# 2026-04-25 (fix8): rc=137 은 두 가지 케이스를 모두 가리킨다 —
#   (A) 원격 호스트 OOM/SIGTERM (hetzner/ubu 쪽 hexa_stage0 cgroup cap 초과)
#   (B) Mac 로컬 ssh 클라이언트가 jetsam/SIGKILL 로 죽음 (24GB Mac memory
#       critical pressure + 10 Claude 세션 + load 12+ 2026-04-25 관찰).
# 기존 코드는 (A)/(B) 구분 없이 exit 64 → 상위 hexa wrapper 가 heavy-compute +
# Darwin + all-hosts-fail → exit 74 abort. 실제 원격은 완료됐거나 다른 호스트로
# 옮기면 성공 가능. 휴리스틱: Darwin + loadavg≥8 이면 (B) 로 의심 → next host 1회 retry.
_run_ssh_once() {
    local _host="$1"
    # ω-network-8 (2026-04-26): LC_ALL=C — caller's _run_ssh_with_reconnect (and
    # any future stderr inspector) case-matches English ssh-client error strings.
    LC_ALL=C ssh -T -o ServerAliveInterval=30 -o ServerAliveCountMax=10 -o ExitOnForwardFailure=yes \
        -o ControlMaster=no -o ControlPath=none "$_host" "$REMOTE_CMD"
}

# raw 41 (external-resource-roaming) auto-reconnect retry.
# 2026-04-25: ssh failures with network-class root cause (ConnectTimeout, Network
# unreachable, No route to host, transient TCP reset) are silently fatal in the
# parallel-dispatch path — they immediately fall through to the next host or
# trigger exit 64. raw 41 demands network-blip resilience: retry the *same* host
# with exponential backoff before declaring it unreachable.
#
# Heuristic: only retry on stderr patterns that match transient network faults.
# SSH success (rc=0), remote-side rc!=0, or auth failures are NOT retried (they
# would not improve and waste time / mask real errors).
#
# Backoff: 1s → 2s → 4s, max 3 retries. Total worst case ≈ 7s + ssh setup.
# Disable: HEXA_REMOTE_NO_RECONNECT=1 (debug, or when caller has its own retry).
# Tunable: HEXA_REMOTE_RECONNECT_MAX=N (default 3).
#
# ω-network-1 (2026-04-26): instrumentation only — appends one TSV line per
# attempt (success OR retry OR non-retry exit) to /tmp/hexa_remote_reconnect.log.
# Format: <iso_ts>\t<host>\t<attempt_n>\t<max>\t<rc>\t<err_class>\t<outcome>\t<backoff_s>
#   err_class ∈ {NONE, TIMEOUT, UNREACHABLE, RESET, KEX, DNS, OTHER}
#   outcome   ∈ {SUCCESS, RETRY, NONRETRY_EXIT, EXHAUSTED}
# Disable: HEXA_REMOTE_RECONNECT_LOG=0. Path override: HEXA_REMOTE_RECONNECT_LOG_PATH.
# No behavior change — calibration left as 1s/2s/4s × 3 pending data accumulation
# (raw#41). Future cycle (omega-network-1.next) reads this log to decide A/B tune.
_run_ssh_with_reconnect() {
    local _host="$1"
    local _max="${HEXA_REMOTE_RECONNECT_MAX:-3}"
    local _attempt=0 _backoff=1 _rc _err_tmp
    local _recon_log="${HEXA_REMOTE_RECONNECT_LOG_PATH:-/tmp/hexa_remote_reconnect.log}"
    local _recon_log_on="${HEXA_REMOTE_RECONNECT_LOG:-1}"

    # Emit one TSV row. Args: attempt, rc, err_class, outcome, backoff_s.
    # Failures (disk full, perm) are silently swallowed — instrumentation must
    # never break the dispatch path.
    _recon_log_emit() {
        [ "$_recon_log_on" = "1" ] || return 0
        local _ts
        _ts="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo 'unknown')"
        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
            "$_ts" "$_host" "$1" "$_max" "$2" "$3" "$4" "$5" \
            >> "$_recon_log" 2>/dev/null || true
    }

    if [ "${HEXA_REMOTE_NO_RECONNECT:-0}" = "1" ]; then
        _run_ssh_once "$_host"
        local _rc_one=$?
        _recon_log_emit 0 "$_rc_one" "NONE" "DISABLED" 0
        return "$_rc_one"
    fi

    while :; do
        _err_tmp="$(mktemp -t hexa_remote_recon.XXXXXX 2>/dev/null || echo "/tmp/hexa_remote_recon.$$.$_attempt")"
        # tee preserves stderr to caller and captures for pattern match.
        # ω-network-8 (2026-04-26): LC_ALL=C — _err_tail case-match (lines
        # 1241-1245) tests English ssh-client signatures. Korean/CJK locale
        # would translate "Connection timed out" / "No route to host" → all
        # patterns miss → _is_net=0 → silent non-retry of true network blips.
        LC_ALL=C ssh -T -o ServerAliveInterval=30 -o ServerAliveCountMax=10 -o ExitOnForwardFailure=yes \
            -o ControlMaster=no -o ControlPath=none "$_host" "$REMOTE_CMD" \
            2> >(tee -- "$_err_tmp" >&2)
        _rc=$?
        wait 2>/dev/null || true

        # Success → log + done.
        if [ "$_rc" = "0" ]; then
            _recon_log_emit "$_attempt" "$_rc" "NONE" "SUCCESS" 0
            rm -f "$_err_tmp" 2>/dev/null || true
            return "$_rc"
        fi

        # Inspect stderr for network-class signatures. Anything else (auth,
        # remote rc!=0, SIGKILL on remote) is NOT a reconnect candidate.
        local _is_net=0 _err_tail _err_class="NONE"
        _err_tail="$(tail -n 5 "$_err_tmp" 2>/dev/null)"
        case "$_err_tail" in
            *"Connection timed out"*|*"Operation timed out"*|*"timed out"*) _is_net=1; _err_class="TIMEOUT" ;;
            *"Network is unreachable"*|*"No route to host"*) _is_net=1; _err_class="UNREACHABLE" ;;
            *"Connection reset by peer"*|*"Connection closed by"*) _is_net=1; _err_class="RESET" ;;
            *"kex_exchange_identification"*|*"banner exchange"*) _is_net=1; _err_class="KEX" ;;
            *"Could not resolve hostname"*|*"Name or service not known"*) _is_net=1; _err_class="DNS" ;;
            *) [ "$_rc" = "255" ] && _err_class="OTHER" ;;
        esac

        # Exhausted retries → log EXHAUSTED + return.
        if [ "$_attempt" -ge "$_max" ]; then
            _recon_log_emit "$_attempt" "$_rc" "$_err_class" "EXHAUSTED" 0
            rm -f "$_err_tmp" 2>/dev/null || true
            return "$_rc"
        fi

        # ssh exit 255 = ssh-side failure (transport/protocol); often network.
        # Combined with stderr signature gives high confidence.
        if [ "$_is_net" = "0" ] && [ "$_rc" != "255" ]; then
            _recon_log_emit "$_attempt" "$_rc" "$_err_class" "NONRETRY_EXIT" 0
            rm -f "$_err_tmp" 2>/dev/null || true
            return "$_rc"
        fi

        _attempt=$((_attempt + 1))
        local _err_short
        _err_short="$(printf '%s' "$_err_tail" | tr '\n' '|' | cut -c 1-120)"
        echo "hexa_remote: auto-reconnect retry $_attempt/$_max after rc=$_rc (${_err_short}) — sleeping ${_backoff}s" >&2
        _recon_log_emit "$_attempt" "$_rc" "$_err_class" "RETRY" "$_backoff"
        rm -f "$_err_tmp" 2>/dev/null || true
        sleep "$_backoff"
        _backoff=$((_backoff * 2))
    done
}
_next_host_in_chain() {
    local _cur="$1"
    local _seen=0 _h
    for _h in $FALLBACK_CHAIN; do
        if [ "$_seen" = "1" ]; then
            [ "$_h" != "$_cur" ] && { printf '%s' "$_h"; return; }
        fi
        [ "$_h" = "$_cur" ] && _seen=1
    done
    printf ''
}

echo "hexa_remote: $HOST 에서 원격 실행 중" >&2
_run_ssh_with_reconnect "$HOST"
ssh_rc=$?
if [ $ssh_rc -eq 137 ] || [ $ssh_rc -eq 143 ]; then
    _uname="$(uname -s 2>/dev/null)"
    _loadavg="$(sysctl -n vm.loadavg 2>/dev/null | awk '{print int($2+0)}')"
    _probably_mac_local_kill=0
    if [ "$_uname" = "Darwin" ] && [ "${_loadavg:-0}" -ge 8 ] 2>/dev/null; then
        _probably_mac_local_kill=1
    fi
    _retry_host="$(_next_host_in_chain "$HOST")"
    if [ "$_probably_mac_local_kill" = "1" ] && [ -n "$_retry_host" ]; then
        echo "hexa_remote: ⚠ rc=$ssh_rc + Mac loadavg=$_loadavg (≥8) → local ssh SIGKILL 의심 (jetsam). $_retry_host 로 1회 재시도." >&2
        if _probe_host "$_retry_host"; then
            HOST="$_retry_host"
            echo "hexa_remote: retry host=$HOST" >&2
            _run_ssh_with_reconnect "$HOST"
            ssh_rc=$?
        else
            echo "hexa_remote: retry 후보 $_retry_host unreachable — 재시도 skip" >&2
        fi
    fi
fi
if [ $ssh_rc -ne 0 ]; then
    echo "hexa_remote: 원격 실행 실패 ($HOST, rc=$ssh_rc)" >&2
    case "$ssh_rc" in
        137|143)
            echo "hexa_remote: ⚠ $HOST rc=$ssh_rc (retry exhausted) — fallback 신호(64) 전달 (병렬 dispatch 줄이거나 GATE_LOCAL=1 권장)" >&2
            exit 64 ;;
    esac
fi
exit $ssh_rc
