// nexus/scripts/mac_defense/watchdog.hexa
//
// Mac kernel panic 방어 — apfsd watchdog timeout (91s) 재발 차단.
// 원인 패턴 (2026-04-20 03:33 panic):
//   hexa_stage0 무한 loop → 디스크 I/O 폭주 → apfsd 77% CPU/117s
//   → kernel watchdog 91s timeout → panic → reboot
//
// launchd 가 StartInterval=10 으로 호출하는 single-shot.
// HEXA_LOCAL=1 강제 (Mac 자기 방어이므로 원격 라우팅 금지).
//
// 환경 (선택):
//   MAC_DEFENSE_KILL=1            실제 SIGSTOP/KILL (default 0 = log only)
//   MAC_DEFENSE_CPU_THRESHOLD     hexa_stage0 CPU% 임계 (default 50)
//   MAC_DEFENSE_ETIME_THRESHOLD   hexa_stage0 etime 초 (default 300)
//   MAC_DEFENSE_APFSD_THRESHOLD   apfsd CPU% 임계 (default 40)
//   MAC_DEFENSE_LOAD_MULT         load1 > ncpu*N 알람 (default 8)

use "log"
use "proc"

fn env_int(k: str, dflt: int) -> int {
    let s = env(k)
    if s == "" { return dflt }
    return to_int(s)
}

fn check_hexa_stage0(cpu_th: int, etime_th: int, kill_mode: bool) {
    let runs = scan_hexa_stage0_runaway(cpu_th, etime_th)
    for r in runs {
        let base = "pid=" + r.pid + " cpu=" + to_string(r.cpu) + "% etime=" + to_string(r.etime_sec) + "s comm=" + r.comm
        if r.protected {
            log_line("PROTECTED hexa_stage0 " + base + " (skip)")
        } else {
            if kill_mode {
                kill_runaway(r.pid)
                log_line("KILLED hexa_stage0 runaway " + base)
            } else {
                log_line("DRYRUN hexa_stage0 runaway " + base + " (set MAC_DEFENSE_KILL=1 to act)")
            }
        }
    }
}

fn check_apfsd(th: int, load_str: str) {
    let cpu = apfsd_cpu()
    if cpu >= th {
        log_line("APFSD-HIGH cpu=" + to_string(cpu) + "% threshold=" + to_string(th) + "% load1=" + load_str)
    }
}

fn check_load(mult: int, ncpu_v: int, load_v: float, load_str: str) {
    let load_i = to_int(load_v)
    let threshold = ncpu_v * mult
    if load_i >= threshold {
        log_line("LOAD-HIGH load1=" + load_str + " threshold=" + to_string(threshold) + " (ncpu=" + to_string(ncpu_v) + " × " + to_string(mult) + ")")
    }
}

fn main() {
    // Darwin 외에서는 no-op (Linux watchdog 은 systemd 가 담당)
    let uname = exec("uname -s").trim()
    if uname != "Darwin" { return }

    let cpu_th = env_int("MAC_DEFENSE_CPU_THRESHOLD", 50)
    let etime_th = env_int("MAC_DEFENSE_ETIME_THRESHOLD", 300)
    let apfsd_th = env_int("MAC_DEFENSE_APFSD_THRESHOLD", 40)
    let load_mult = env_int("MAC_DEFENSE_LOAD_MULT", 8)
    let kill_mode = env("MAC_DEFENSE_KILL") == "1"

    let nc = ncpu()
    let lv = load1()
    let load_str = exec("sysctl -n vm.loadavg 2>/dev/null | awk '{print $2}'").trim()

    check_hexa_stage0(cpu_th, etime_th, kill_mode)
    check_apfsd(apfsd_th, load_str)
    check_load(load_mult, nc, lv, load_str)
}

main()
