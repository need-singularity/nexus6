// nexus/scripts/mac_defense/log.hexa
// 책임: 단일 로그 파일 append. 다른 모듈은 log_line(msg) 만 호출.

let LOG_PATH = env("HOME") + "/Library/Logs/mac_defense.log"

fn ts_iso() -> str {
    return exec("date +%Y-%m-%dT%H:%M:%S%z").trim()
}

fn shq(s: str) -> str {
    // single-quote 안에서 ' 만 escape
    return "'" + s.replace("'", "'\\''") + "'"
}

fn log_line(msg: str) {
    let line = ts_iso() + " " + msg
    let cmd = "mkdir -p " + shq(env("HOME") + "/Library/Logs") + " && printf '%s\\n' " + shq(line) + " >> " + shq(LOG_PATH)
    exec(cmd)
}
