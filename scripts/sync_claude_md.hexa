// MOVED → hexa shared/tool/sync.hexa claude_md  (이 파일은 백호환 shim, v2 에서 제거 예정)
// sync_claude_md.hexa — project-claude/*.md → 각 프로젝트 CLAUDE.md 동기화
// 사용: hexa shared/scripts/sync_claude_md.hexa
// ⚠️ 심링크 제거 후 실제 파일로 복사 + 각 프로젝트에 커밋+푸시

let HOME = env("HOME")
let SRC = HOME + "/Dev/nexus/project-claude"
let SCRIPT_DIR = HOME + "/Dev/nexus/scripts"
let STATE_FILE = SCRIPT_DIR + "/.sync_state.json"
let SYNC_KEY = "sync-claude-md"

// --- delta 검출 ---
fn _md5(path: str) -> str {
    return to_string(exec("md5 -q '" + path + "' 2>/dev/null || md5sum '" + path + "' | cut -d' ' -f1")).trim()
}

fn _load_state() -> str {
    if file_exists(STATE_FILE) { return read_file(STATE_FILE) }
    return "{}"
}

fn _get_stored_hash(state_raw: str, key: str) -> str {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = state_raw
    let _ = key
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync_claude_md.hexa:_get_stored_hash. Escalate to user for hexa-native replacement.")
    return ""
}

fn _save_hash(key: str, hash_val: str) {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = _load_state()
    let _ = key
    let _ = hash_val
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync_claude_md.hexa:_save_hash. Escalate to user for hexa-native replacement.")
}

// 소스 해시: project-claude/ 디렉토리 전체 .md 파일
let src_hash = to_string(exec("bash -c \"cat '" + SRC + "/'*.md 2>/dev/null | md5 -q 2>/dev/null || cat '" + SRC + "/'*.md 2>/dev/null | md5sum | cut -d' ' -f1\"")).trim()
let state_raw = _load_state()
let stored = _get_stored_hash(state_raw, SYNC_KEY)

if src_hash == stored && src_hash != "" {
    println("=== CLAUDE.md 동기화: up-to-date (delta skip) ===")
    exit(0)
}
// --- delta 검출 끝 ---

let projects = ["anima", "papers", "void", "hexa-lang", "n6-architecture", "airgenome", "contact"]

let mut changed = 0

for proj in projects {
    let src = SRC + "/" + proj + ".md"
    let dest_dir = HOME + "/Dev/" + proj
    let dest = dest_dir + "/CLAUDE.md"

    // 소스 존재 확인
    if !file_exists(src) { continue }

    // 프로젝트 디렉토리 존재 확인
    let dir_check = to_string(exec("test -d '" + dest_dir + "' && echo 'yes' || echo 'no'")).trim()
    if dir_check != "yes" { continue }

    // 심링크 여부 확인
    let is_link = to_string(exec("test -L '" + dest + "' && echo 'yes' || echo 'no'")).trim()
    if is_link == "yes" {
        exec("rm '" + dest + "'")
        exec("cp '" + src + "' '" + dest + "'")
        println("[" + proj + "] symlink → file")
    } else {
        // 내용 비교
        let diff_result = to_string(exec("diff -q '" + src + "' '" + dest + "' 2>/dev/null && echo 'same' || echo 'diff'")).trim()
        if diff_result == "same" { continue }
        exec("cp '" + src + "' '" + dest + "'")
        println("[" + proj + "] updated")
    }

    // 커밋+푸시
    try {
        exec("bash", ["-c", "cd " + dest_dir + " && git add CLAUDE.md && git commit -m 'sync: CLAUDE.md from nexus/project-claude/" + proj + ".md' && git push"])
        println("[" + proj + "] pushed")
    } catch e {
        println("[" + proj + "] commit/push skipped")
    }
    changed = changed + 1
}

println("--- " + to_string(changed) + " projects synced ---")

// delta 상태 저장
_save_hash(SYNC_KEY, src_hash)
