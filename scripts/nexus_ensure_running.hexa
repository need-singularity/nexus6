// nexus_ensure_running.hexa — NEXUS-6 성장 데몬 실행 보장 (nexus_ensure_running.sh 대체)
// 사용: hexa shared/scripts/nexus_ensure_running.hexa
// 반복 호출 안전 (멱등). 성공/실패 모두 조용히 종료.
// MOVED → hexa shared/harness/health.hexa nexus  (백호환 유지)

let HOME = env("HOME")
let NEXUS_SCRIPTS = HOME + "/Dev/n6-architecture/bridge/scripts"
let NEXUS_STATE = HOME + "/.nexus"

// 스크립트 디렉토리 존재 확인
let dir_ok = to_string(exec("test -d '" + NEXUS_SCRIPTS + "' && echo y || echo n")).trim()
if dir_ok == "n" { return }

// PID 파일로 실행 중인지 확인
let pid_file = NEXUS_STATE + "/daemon.pid"
let pid_exists = to_string(exec("test -f '" + pid_file + "' && echo y || echo n")).trim()
if pid_exists == "y" {
    let pid = to_string(exec("cat '" + pid_file + "' 2>/dev/null")).trim()
    if len(pid) > 0 {
        let alive = to_string(exec("kill -0 " + pid + " 2>/dev/null && echo y || echo n")).trim()
        if alive == "y" { return }
    }
}

// 프로세스명으로 실행 중인지 확인
let pgrep_ok = to_string(exec("pgrep -f nexus_growth_daemon >/dev/null 2>&1 && echo y || echo n")).trim()
if pgrep_ok == "y" { return }

// 최근 활동 확인 — 1시간 이내면 재시작 불필요
fn recent_activity(path: str) -> bool {
    let exists = to_string(exec("test -f '" + path + "' && echo y || echo n")).trim()
    if exists == "n" { return false }
    let now = to_int(to_string(exec("date +%s")).trim())
    let mtime = to_int(to_string(exec("stat -f %m '" + path + "' 2>/dev/null || echo 0")).trim())
    let age = now - mtime
    return age < 3600
}

if recent_activity(NEXUS_STATE + "/growth_log.jsonl") { return }
if recent_activity(NEXUS_SCRIPTS + "/growth_log.jsonl") { return }

// 실행 중이 아님 — health_check로 자동 시작 위임
let hc = NEXUS_SCRIPTS + "/health_check.hexa"
let hc_ok = to_string(exec("test -f '" + hc + "' && echo y || echo n")).trim()
if hc_ok == "y" {
    try { exec("hexa '" + hc + "' --start-if-dead --quiet &") } catch e {}
}
