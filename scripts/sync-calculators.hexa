// MOVED → hexa shared/tool/sync.hexa calculators  (이 파일은 백호환 shim, v2 에서 제거 예정)
// sync-calculators.hexa — 계산기 레지스트리 전 리포 동기화 (sync-calculators.sh 대체)
// 사용: hexa shared/scripts/sync-calculators.hexa
// 원본: TECS-L/.shared/ 스캔 결과 → 각 리포 README 마커 내 주입 + 커밋+푸시

let HOME = env("HOME")
let SCRIPT_DIR = HOME + "/core/nexus/scripts"
let BASE = HOME + "/core/nexus/shared"
let PARENT = HOME + "/Dev"
let STATE_FILE = SCRIPT_DIR + "/.sync_state.json"
let SYNC_KEY = "sync-calculators"

// --- delta 검출 ---
fn _md5(path: str) -> str {
    return to_string(exec("md5 -q '" + path + "' 2>/dev/null || md5sum '" + path + "' | cut -d' ' -f1")).trim()
}

fn _load_state() -> str {
    if file_exists(STATE_FILE) { return read_file(STATE_FILE) }
    return "{}"
}

fn _get_stored_hash(state_raw: str, key: str) -> str {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = state_raw
    let _ = key
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync-calculators.hexa:_get_stored_hash. Escalate to user for hexa-native replacement.")
    return ""
}

fn _save_hash(key: str, hash_val: str) {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = _load_state()
    let _ = key
    let _ = hash_val
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync-calculators.hexa:_save_hash. Escalate to user for hexa-native replacement.")
}

// 소스 파일 해시: scan-calculators.py (주 소스)
let scan_py = SCRIPT_DIR + "/scan-calculators.py"
let src_hash = if file_exists(scan_py) { _md5(scan_py) } else { "missing" }

let state_raw = _load_state()
let stored = _get_stored_hash(state_raw, SYNC_KEY)

if src_hash == stored && src_hash != "missing" {
    println("=== 계산기 레지스트리 동기화: up-to-date (delta skip) ===")
    exit(0)
}
// --- delta 검출 끝 ---

let MARKER_START = "<!-- SHARED:CALCULATORS:START -->"
let MARKER_END = "<!-- SHARED:CALCULATORS:END -->"

println("=== 계산기 레지스트리 동기화 ===")
println("")

// 1단계: 리포 스캔
println("[1/3] 리포 스캔 중...")
// R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
// Original: /usr/bin/python3 scan-calculators.py --markdown --save
eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync-calculators.hexa:scan-calculators.py. Escalate to user for hexa-native replacement.")
let content = ""

if len(content) == 0 {
    println("오류: 스캔 결과 없음")
    exit(1)
}
println("  레지스트리 저장: .shared/config/calculators.json")
println("")

// 마커 기반 파일 동기화
fn sync_file(file: str, label: str, marker_start: str, marker_end: str, new_content: str) -> bool {
    println("[" + label + "]")
    let exists = to_string(exec("test -f '" + file + "' && echo y || echo n")).trim()
    if exists == "n" {
        println("  SKIP: " + file + " 없음")
        return false
    }
    let text = try { read_file(file) } catch e { println("  SKIP: 읽기 실패"); return false }
    if text.contains(marker_start) == false {
        println("  SKIP: 마커 없음")
        return false
    }
    let before = text.split(marker_start)[0] + marker_start
    let after_parts = text.split(marker_end)
    let after = if after_parts.len() >= 2 { marker_end + after_parts[1] } else { marker_end }
    let updated = before + "\n" + new_content + "\n" + after
    try { write_file(file, updated) } catch e { println("  SKIP: 쓰기 실패"); return false }
    println("  동기화: " + file)
    return true
}

// 커밋+푸시
fn commit_and_push(repo_dir: str, repo_name: str, files: str) {
    let diff = to_string(exec("bash -c 'cd " + repo_dir + " && git diff --quiet " + files + " 2>/dev/null && echo same || echo diff'")).trim()
    if diff == "same" {
        println("  변경 없음")
        return
    }
    try {
        exec("bash", ["-c", "cd " + repo_dir + " && git add " + files + " && git pull --rebase --quiet 2>/dev/null; git commit -m '동기화: TECS-L 계산기 레지스트리' && git push"])
        println("  푸시 완료!")
    } catch e {
        println("  커밋/푸시 스킵")
    }
}

// 2단계: README 동기화
println("[2/3] README 테이블 동기화 중...")

sync_file(BASE + "/README.md", "TECS-L", MARKER_START, MARKER_END, content)
commit_and_push(BASE, "TECS-L", "README.md")

sync_file(PARENT + "/anima/README.md", "anima", MARKER_START, MARKER_END, content)
commit_and_push(PARENT + "/anima", "anima", "README.md")

sync_file(PARENT + "/SEDI/README.md", "SEDI", MARKER_START, MARKER_END, content)
commit_and_push(PARENT + "/SEDI", "SEDI", "README.md")

// CANON 동기화
let n6_dir = PARENT + "/canon"
let n6_ok = to_string(exec("test -d '" + n6_dir + "' && echo y || echo n")).trim()
if n6_ok == "y" {
    println("[CANON] TECS-L 계산기 동기화 중...")
    sync_file(n6_dir + "/README.md", "CANON", MARKER_START, MARKER_END, content)
    try {
        exec("bash", ["-c", "cd " + n6_dir + " && git add tools/ README.md 2>/dev/null && git diff --cached --quiet 2>/dev/null || (git pull --rebase --quiet 2>/dev/null; git commit -m '동기화: TECS-L 계산기 공유 레지스트리' && git push)"])
    } catch e {}
}

// 3단계: SEDI 역동기화
println("")
println("[3/5] 역동기화: SEDI -> TECS-L...")
let sedi_dir = PARENT + "/sedi"
let sedi_ok = to_string(exec("test -d '" + sedi_dir + "' && echo y || echo n")).trim()
if sedi_ok == "y" {
    let sedi_grades = sedi_dir + "/data/sedi-grades.json"
    let sg_ok = to_string(exec("test -f '" + sedi_grades + "' && echo y || echo n")).trim()
    if sg_ok == "y" {
        exec("cp '" + sedi_grades + "' '" + SCRIPT_DIR + "/sedi-grades.json'")
        println("  SEDI 등급 동기화 완료")
    }
}

// 4단계: n6 역동기화
println("")
println("[4/5] 역동기화: n6 -> TECS-L...")
if n6_ok == "y" {
    let atlas_src = n6_dir + "/docs/atlas-constants.md"
    let at_ok = to_string(exec("test -f '" + atlas_src + "' && echo y || echo n")).trim()
    if at_ok == "y" {
        exec("cp '" + atlas_src + "' '" + SCRIPT_DIR + "/n6-atlas-constants.md'")
        println("  아틀라스 상수 동기화 완료")
    }
}

println("")
println("[5/5] 완료!")

// R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
// Original: /usr/bin/python3 scan-calculators.py --summary
eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync-calculators.hexa:scan-calculators.py --summary. Escalate to user for hexa-native replacement.")

