// MOVED → hexa shared/tool/sync.hexa math_atlas  (이 파일은 백호환 shim, v2 에서 제거 예정)
// sync-math-atlas.hexa — 수학 아틀라스 전 리포 동기화 (sync-math-atlas.sh 대체)
// TECS-L, anima, SEDI 가설 파일 스캔 -> 통합 아틀라스 빌드 -> README 마커 주입
// 사용: hexa shared/scripts/sync-math-atlas.hexa

let HOME = env("HOME")
let SCRIPT_DIR = HOME + "/Dev/nexus/scripts"
let BASE = HOME + "/Dev/nexus/shared"
let PARENT = HOME + "/Dev"
let STATE_FILE = SCRIPT_DIR + "/.sync_state.json"
let SYNC_KEY = "sync-math-atlas"

// --- delta 검출 ---
fn _md5(path: str) -> str {
    return to_string(exec("md5 -q '" + path + "' 2>/dev/null || md5sum '" + path + "' | cut -d' ' -f1")).trim()
}

fn _load_state() -> str {
    if file_exists(STATE_FILE) { return read_file(STATE_FILE) }
    return "{}"
}

fn _get_stored_hash(state_raw: str, key: str) -> str {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = state_raw
    let _ = key
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync-math-atlas.hexa:_get_stored_hash. Escalate to user for hexa-native replacement.")
    return ""
}

fn _save_hash(key: str, hash_val: str) {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = _load_state()
    let _ = key
    let _ = hash_val
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync-math-atlas.hexa:_save_hash. Escalate to user for hexa-native replacement.")
}

// 소스 해시: scan_math_atlas.py (주 빌드 스크립트)
let scan_py = SCRIPT_DIR + "/scan_math_atlas.py"
let src_hash = if file_exists(scan_py) { _md5(scan_py) } else { "missing" }

let state_raw = _load_state()
let stored = _get_stored_hash(state_raw, SYNC_KEY)

if src_hash == stored && src_hash != "missing" {
    println("=== 수학 아틀라스 동기화: up-to-date (delta skip) ===")
    exit(0)
}
// --- delta 검출 끝 ---

let MARKER_START = "<!-- SHARED:ATLAS:START -->"
let MARKER_END = "<!-- SHARED:ATLAS:END -->"

println("=== 수학 아틀라스 동기화 ===")
println("")

// 1단계: 아틀라스 빌드
println("[1/3] 아틀라스 빌드 중...")
// R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
// Original: /usr/bin/python3 scan_math_atlas.py --save --summary
eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync-math-atlas.hexa:scan_math_atlas.py --save. Escalate to user for hexa-native replacement.")
println("")

// 2단계: README 마커 동기화
println("[2/3] README 마커 동기화 중...")
// R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
// Original: /usr/bin/python3 scan_math_atlas.py --readme-summary
eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync-math-atlas.hexa:scan_math_atlas.py --readme-summary. Escalate to user for hexa-native replacement.")
let summary = ""

fn sync_readme(file: str, label: str, marker_start: str, marker_end: str, new_content: str) {
    println("[" + label + "]")
    let exists = to_string(exec("test -f '" + file + "' && echo y || echo n")).trim()
    if exists == "n" {
        println("  SKIP: " + file + " 없음")
        return
    }
    let text = try { read_file(file) } catch e { println("  SKIP: 읽기 실패"); return }
    if text.contains(marker_start) == false {
        println("  SKIP: 마커 없음")
        return
    }
    let before = text.split(marker_start)[0] + marker_start
    let after_parts = text.split(marker_end)
    let after = if after_parts.len() >= 2 { marker_end + after_parts[1] } else { marker_end }
    let updated = before + "\n" + new_content + "\n" + after
    try { write_file(file, updated) } catch e { println("  SKIP: 쓰기 실패"); return }
    println("  동기화: " + file)
}

sync_readme(BASE + "/README.md", "TECS-L", MARKER_START, MARKER_END, summary)
sync_readme(PARENT + "/anima/README.md", "anima", MARKER_START, MARKER_END, summary)
sync_readme(PARENT + "/SEDI/README.md", "SEDI", MARKER_START, MARKER_END, summary)

println("")

// 3단계: 생성 파일 커밋
println("[3/3] 커밋 중...")
let atlas_files = ".shared/discovery/math_atlas.json .shared/n6/math_atlas.db .shared/n6/math_atlas.dot"
let diff = to_string(exec("bash -c 'cd " + BASE + " && git diff --quiet " + atlas_files + " 2>/dev/null && git diff --cached --quiet " + atlas_files + " 2>/dev/null && echo same || echo diff'")).trim()

if diff == "diff" {
    try {
        exec("bash", ["-c", "cd " + BASE + " && git add " + atlas_files + " && git commit -m '수학 아틀라스 갱신 (" + to_string(exec("date +%Y-%m-%d")).trim() + ")'"])
        println("  커밋 완료!")
    } catch e {
        println("  커밋 스킵")
    }
} else {
    println("  변경 없음")
}

println("")
println("완료!")

// delta 상태 저장
_save_hash(SYNC_KEY, src_hash)
