// index_verified_constants.hexa — verified_constants.jsonl 도메인 인덱스 빌더
// 사용: hexa shared/scripts/index_verified_constants.hexa
// 출력: shared/discovery/verified_constants.idx.json
//
// 19MB / 100K 라인 전체 로드 회피 → 도메인(project) 기반 line-range 인덱스 생성
// lazy-load 헬퍼(verified_constants_loader.hexa.inc)가 이 인덱스를 소비

fn main() {
    let home = exec("printenv HOME").trim()
    let shared = home + "/core/nexus/shared"
    let src = shared + "/discovery/verified_constants.jsonl"
    let idx_out = shared + "/discovery/verified_constants.idx.json"

    // 파일 존재 확인
    let exists = exec("test -f '" + src + "' && echo y || echo n").trim()
    if exists != "y" {
        println("ERROR: " + src + " not found")
        return
    }

    // source mtime (epoch seconds)
    let mtime = exec("stat -f '%m' '" + src + "' 2>/dev/null || stat -c '%Y' '" + src + "' 2>/dev/null").trim()

    println("[index] scanning " + src + " ...")

    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    // Original: python3 single-pass scanner of verified_constants.jsonl → idx.json (domain line-ranges)
    let _ = src
    let _ = idx_out
    let _ = mtime
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at index_verified_constants.hexa:main. Escalate to user for hexa-native replacement.")
    println("[index] skipped — R37/AN13/L3-PY python3 block")
}

main()
