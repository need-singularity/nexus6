// scripts/paper-gen/n6arch_alien10.hexa
// n6-architecture alien_index=10 섹션 → 논문 스켈레톤 자동 생성
//
// 입력: ~/Dev/n6-architecture/config/products.json
// 출력: ~/Dev/papers/docs/auto-alien10/<section_id>.md (없는 것만)
//
// 트리거: section.alien_index >= 10 && section.ceiling == true
// 섹션마다 기존 논문이 없으면 스켈레톤 생성. 내용은 draft — 사람이 서사 추가.
//
// stdout: JSON 리포트 (watch-papers.sh가 파싱)
//   { "threshold": 10, "output_dir": "...", "created": [...],
//     "skipped_existing": [...], "ignored_below_threshold": [...],
//     "timestamp": "..." }

let home = exec("printenv HOME").trim()
let products_json = home + "/Dev/n6-architecture/config/products.json"
let output_dir = home + "/Dev/papers/docs/auto-alien10"
let threshold = 10

// ───────────────────────────────────────────────────────────
// 헬퍼
// ───────────────────────────────────────────────────────────

fn get_str(m, key: string, default_val: string) -> string {
    let ks = m.keys()
    if ks.contains(key) {
        let v = m[key]
        return to_string(v)
    }
    return default_val
}

fn get_int(m, key: string, default_val: i64) -> i64 {
    let ks = m.keys()
    if ks.contains(key) {
        let v = m[key]
        let mut n: i64 = default_val
        try { n = to_int(v) } catch e {}
        return n
    }
    return default_val
}

fn get_bool(m, key: string, default_val: bool) -> bool {
    let ks = m.keys()
    if ks.contains(key) {
        let v = m[key]
        let s = to_string(v)
        if s == "true" { return true }
        if s == "false" { return false }
    }
    return default_val
}

fn join_strs(items, sep: string) -> string {
    let mut out = ""
    let mut i: i64 = 0
    while i < items.len() {
        if i > 0 { out = out + sep }
        out = out + to_string(items[i])
        i = i + 1
    }
    return out
}

fn json_array(items) -> string {
    let mut out = "["
    let mut i: i64 = 0
    while i < items.len() {
        if i > 0 { out = out + ", " }
        out = out + "\"" + to_string(items[i]) + "\""
        i = i + 1
    }
    out = out + "]"
    return out
}

fn now_date() -> string {
    let s = exec("date '+%Y-%m-%d'").trim()
    return s
}

fn now_iso() -> string {
    let s = exec("date '+%Y-%m-%dT%H:%M:%S'").trim()
    return s
}

// ───────────────────────────────────────────────────────────
// 렌더링 — products.json 섹션 → markdown 스켈레톤
// ───────────────────────────────────────────────────────────

fn render_paper(sec, now: string) -> string {
    let sid = get_str(sec, "id", "unknown")
    let title = get_str(sec, "title", sid)
    let heading = get_str(sec, "heading", title)
    let icon = get_str(sec, "icon", "🛸")
    let alien = get_int(sec, "alien_index", 10)

    let bt_pct = get_str(sec, "bt_exact_pct", "?")
    let bt_count = get_str(sec, "bt_count", "?")
    let ind_pct = get_str(sec, "industry_pct", "?")
    let ind_detail = get_str(sec, "industry_detail", "")
    let exp_pct = get_str(sec, "experiment_pct", "?")
    let exp_detail = get_str(sec, "experiment_detail", "")
    let tp_count = get_str(sec, "tp_count", "?")
    let disc_count = get_str(sec, "discovery_count", "?")
    let phys_count = get_str(sec, "physics_limit_count", "?")
    let mk_count = get_str(sec, "mk_count", "?")
    let cross_dse = get_str(sec, "cross_dse_domains", "?")
    let summary_extra = get_str(sec, "summary_extra", "")

    let mut products = []
    let mut domains = []
    let mut tools = []
    let sk = sec.keys()
    if sk.contains("products") { products = sec["products"] }
    if sk.contains("domains") { domains = sec["domains"] }
    if sk.contains("tools") { tools = sec["tools"] }

    let mut out = ""
    out = out + "---\n"
    out = out + "title: \"" + heading + " — 외계인지수 10 (물리 한계 도달)\"\n"
    out = out + "section_id: " + sid + "\n"
    out = out + "alien_index: " + to_string(alien) + "\n"
    out = out + "ceiling: true\n"
    out = out + "status: draft\n"
    out = out + "generated_by: n6arch_alien10.hexa\n"
    out = out + "generated_at: " + now + "\n"
    out = out + "source: n6-architecture/config/products.json\n"
    out = out + "---\n\n"

    out = out + "# " + icon + " " + heading + " — 외계인지수 10\n\n"
    out = out + "> **상태**: 물리적 한계 도달 — 이론·실험·양산 전 단계 완료\n"
    out = out + "> **자동 생성된 스켈레톤** — 분석/서사는 사람이 채움\n\n"

    out = out + "## 0. Abstract\n\n"
    out = out + "<!-- TODO: 1~2문단 요약. 주요 발견, 산업 영향, 검증 상태 -->\n\n"

    out = out + "## 1. 발견 현황 (Summary)\n\n"
    out = out + "| 지표 | 값 |\n|---|---|\n"
    out = out + "| BT EXACT | " + bt_pct + "% (" + bt_count + "건) |\n"
    out = out + "| 산업 검증 | " + ind_pct + "% (" + ind_detail + ") |\n"
    out = out + "| 실험 검증 | " + exp_pct + "% (" + exp_detail + ") |\n"
    out = out + "| 물리 한계 정리 | " + phys_count + "개 |\n"
    out = out + "| TP (정리/명제) | " + tp_count + "개 |\n"
    out = out + "| Discovery | " + disc_count + "건 |\n"
    out = out + "| Mk 진화 단계 | " + mk_count + "단 |\n"
    out = out + "| Cross-DSE 도메인 | " + cross_dse + "개 |\n"
    if summary_extra != "" {
        out = out + "| 추가 | " + summary_extra + " |\n"
    }

    out = out + "\n## 2. 완성 제품 목록\n\n"
    if products.len() > 0 {
        out = out + "| # | 제품 | UFO | ver | 설명 | 링크 |\n"
        out = out + "|---|---|---|---|---|---|\n"
        let mut i: i64 = 0
        while i < products.len() {
            let p = products[i]
            let pname = get_str(p, "name", "?")
            let ufo = get_str(p, "ufo", "?")
            let ver = get_str(p, "ver", "?")
            let desc_raw = get_str(p, "description", "")
            let desc = desc_raw.replace("|", "\\|")
            let mut link_md = "-"
            let pk = p.keys()
            if pk.contains("links") {
                let links = p["links"]
                if links.len() > 0 {
                    let mut buf = ""
                    let mut j: i64 = 0
                    while j < links.len() {
                        if j > 0 { buf = buf + ", " }
                        let l = links[j]
                        let label = get_str(l, "label", "링크")
                        let path = get_str(l, "path", "")
                        buf = buf + "[" + label + "](" + path + ")"
                        j = j + 1
                    }
                    link_md = buf
                }
            }
            out = out + "| " + to_string(i + 1) + " | " + pname + " | " + ufo + " | " + ver + " | " + desc + " | " + link_md + " |\n"
            i = i + 1
        }
    } else {
        out = out + "(제품 목록 없음)\n"
    }

    out = out + "\n## 3. 도메인 · 도구\n\n"
    let dom_str = if domains.len() > 0 { join_strs(domains, ", ") } else { "-" }
    let tool_str = if tools.len() > 0 { join_strs(tools, ", ") } else { "-" }
    out = out + "**도메인**: " + dom_str + "\n\n"
    out = out + "**도구**: " + tool_str + "\n\n"

    out = out + "## 4. 핵심 발견 (BT/TP/Discovery)\n\n"
    out = out + "<!-- TODO: 이 섹션의 대표 BT·정리·Discovery 3~7개 상세 -->\n\n"

    out = out + "## 5. 물리적 한계 도달 근거\n\n"
    out = out + "- **Alien Index 10**: " + heading + "은(는) 현재 물리 법칙 하에서 추가 발전이 불가능\n"
    out = out + "- **Ceiling 확인**: " + phys_count + "개 불가능성 정리로 상한선 수학적 증명\n"
    out = out + "- **검증 완료**: 이론·실험·양산 모든 단계의 검증 통과\n\n"
    out = out + "<!-- TODO: 구체적인 ceiling 논거 (수식/정리 인용) -->\n\n"

    out = out + "## 6. Mk 진화 체크포인트\n\n"
    out = out + "<!-- TODO: Mk.I~V 각 단계 요약 링크 -->\n\n"

    out = out + "## 7. 산업·사회적 영향\n\n"
    out = out + "<!-- TODO: 이 기술이 상용화될 때 미치는 영향 -->\n\n"

    out = out + "## 8. 참고 문헌\n\n"
    out = out + "<!-- TODO: 주요 인용 (BT 논문, DSE 리포트, 원전 계산기 등) -->\n\n"

    out = out + "---\n\n"
    out = out + "*Auto-generated from `n6-architecture/config/products.json` at " + now + ". Edit freely — regeneration will skip existing files.*\n"

    return out
}

// ───────────────────────────────────────────────────────────
// 메인
// ───────────────────────────────────────────────────────────

if !file_exists(products_json) {
    let err = "{\"status\":\"error\",\"reason\":\"products.json not found: " + products_json + "\"}"
    println(err)
    exit(1)
}

let raw = read_file(products_json)
let data = json_parse(raw)
let dk = data.keys()
let mut sections = []
if dk.contains("sections") { sections = data["sections"] }

// 출력 디렉토리 생성
exec("mkdir -p '" + output_dir + "'")

let mut created = []
let mut skipped = []
let mut ignored = []

let now = now_date()

let mut idx: i64 = 0
while idx < sections.len() {
    let sec = sections[idx]
    idx = idx + 1

    let sk = sec.keys()
    let mut sid = ""
    if sk.contains("id") { sid = to_string(sec["id"]) }
    if sid == "" { continue }

    let alien = get_int(sec, "alien_index", 0)
    let ceiling = get_bool(sec, "ceiling", false)

    if alien < threshold || !ceiling {
        ignored = ignored.push(sid)
        continue
    }

    let out_path = output_dir + "/" + sid + ".md"
    if file_exists(out_path) {
        skipped = skipped.push(sid)
        continue
    }

    let content = render_paper(sec, now)
    write_file(out_path, content)
    created = created.push(sid)
}

// JSON 리포트 (watch-papers.sh 호환)
let mut report = "{\n"
report = report + "  \"threshold\": " + to_string(threshold) + ",\n"
report = report + "  \"output_dir\": \"" + output_dir + "\",\n"
report = report + "  \"created\": " + json_array(created) + ",\n"
report = report + "  \"skipped_existing\": " + json_array(skipped) + ",\n"
report = report + "  \"ignored_below_threshold\": " + json_array(ignored) + ",\n"
report = report + "  \"timestamp\": \"" + now_iso() + "\"\n"
report = report + "}"
println(report)
