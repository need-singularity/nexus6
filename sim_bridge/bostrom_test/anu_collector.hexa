// anu_collector.hexa — ANU QRNG byte stream collector for Bostrom test
//
// 목표: n_req 의 ANU 샘플을 수집. 1 req/min 절대 준수.
// ANU 먼저, 실패 시 full gap(65s) 기다린 후 재시도.
// 연속 MAX_FAIL 번 실패하면 urandom 로 폴백하되 "urandom" 태그.
// 캐시 60s 이내면 재사용 (이전 mtime 과 다를 때만).
//
// 사용:
//   hexa anu_collector.hexa <out_hex_file> <n_requests> [gap_sec=65] [max_fail=3]

let _args = args()
if _args.len() < 4 {
    println("usage: anu_collector.hexa <out_hex> <n_req> [gap_sec] [max_fail]")
    exit(1)
}
let out_hex = _args[2]
let n_req = to_int(_args[3])
let mut gap_sec: i64 = 65
if _args.len() >= 5 { gap_sec = to_int(_args[4]) }
let mut max_fail: i64 = 3
if _args.len() >= 6 { max_fail = to_int(_args[5]) }

let meta_path = out_hex + ".meta.jsonl"
let cache_path = env_var("HOME") + "/Dev/nexus/shared/sim_bridge/godel_q/.anu_cache.bin"

fn now_epoch() -> i64 {
    let mut r = ""
    try { r = to_string(exec("date +%s")).trim() } catch e { r = "0" }
    let mut v: i64 = 0
    try { v = to_int(r) } catch e { v = 0 }
    return v
}

fn cache_mtime(path: string) -> i64 {
    let mut r = ""
    try { r = to_string(exec("stat -f '%m' '" + path + "' 2>/dev/null || stat -c '%Y' '" + path + "' 2>/dev/null")).trim() } catch e { r = "0" }
    if r.len() == 0 { return 0 }
    let mut v: i64 = 0
    try { v = to_int(r) } catch e { v = 0 }
    return v
}

fn read_cache_if_fresh(path: string, max_age: i64, prev_mtime: i64) -> string {
    let m = cache_mtime(path)
    if m == prev_mtime { return "" }
    let age = now_epoch() - m
    if age > max_age { return "" }
    let mut c = ""
    try { c = read_file(path).trim() } catch e { c = "" }
    if c.len() < 128 { return "" }
    return c.substring(0, 128)
}

fn fetch_anu(cache: string) -> string {
    // R37/AN13/L3-PY violation — python3 JSON parser for ANU QRNG stubbed 2026-04-18
    // Original: curl ... | /usr/bin/python3 -c "import sys,json; ..." (hex-encode 64 bytes)
    // No-op: return "" → caller falls back to fetch_urandom() path.
    eprintln("[R37] anu_collector.fetch_anu: python3 JSON parser disabled; using urandom fallback.")
    return ""
}

fn fetch_urandom() -> string {
    let mut hex = ""
    try { hex = to_string(exec("head -c 64 /dev/urandom | od -An -vtx1 | tr -d ' \\n'")).trim() } catch e { hex = "" }
    if hex.len() < 128 { return "" }
    return hex.substring(0, 128)
}

fn do_sleep(secs: i64) {
    if secs <= 0 { return }
    try { exec("sleep " + to_string(secs)) } catch e {}
}

// ─── init output ───
try { write_file(out_hex, "") } catch e {}
try { write_file(meta_path, "") } catch e {}

let mut prev_cache_mtime: i64 = 0
let mut consecutive_fail: i64 = 0
let t_start = now_epoch()
println("# bostrom collector start: n_req=" + to_string(n_req) + " gap=" + to_string(gap_sec) + "s max_fail=" + to_string(max_fail))

let mut i: i64 = 0
while i < n_req {
    // 1) try cache (fresh <60s, mtime differs from last)
    let cached = read_cache_if_fresh(cache_path, 55, prev_cache_mtime)
    let mut hex = ""
    let mut src = ""
    if cached.len() >= 128 {
        hex = cached
        src = "cache"
        prev_cache_mtime = cache_mtime(cache_path)
        consecutive_fail = 0
    } else {
        // 2) direct ANU fetch
        let anu = fetch_anu(cache_path)
        if anu.len() >= 128 {
            hex = anu
            src = "anu"
            prev_cache_mtime = cache_mtime(cache_path)
            consecutive_fail = 0
        } else {
            // 3) failed — retry after gap unless we exceed max_fail
            consecutive_fail = consecutive_fail + 1
            println("ANU fail #" + to_string(consecutive_fail) + " (i=" + to_string(i) + ") waiting " + to_string(gap_sec) + "s")
            if consecutive_fail > max_fail {
                // fallback urandom — tagged
                let ur = fetch_urandom()
                if ur.len() >= 128 {
                    hex = ur
                    src = "urandom"
                    consecutive_fail = 0
                }
            } else {
                do_sleep(gap_sec)
                continue
            }
        }
    }

    if hex.len() < 128 {
        println("HARD FAIL i=" + to_string(i))
        break
    }

    let now = now_epoch()
    let line = "{\"i\":" + to_string(i) + ",\"t\":" + to_string(now) + ",\"src\":\"" + src + "\",\"hex\":\"" + hex + "\"}\n"
    try {
        let prev = read_file(out_hex)
        write_file(out_hex, prev + hex)
    } catch e {
        try { write_file(out_hex, hex) } catch e2 {}
    }
    try {
        let prev = read_file(meta_path)
        write_file(meta_path, prev + line)
    } catch e {
        try { write_file(meta_path, line) } catch e2 {}
    }
    println("req=" + to_string(i) + " src=" + src + " t=" + to_string(now - t_start))
    i = i + 1

    // sleep between requests (only for ANU; cache paths are cheap)
    if src == "anu" {
        do_sleep(gap_sec)
    } else if src == "urandom" {
        do_sleep(gap_sec)
    }
}

println("# done. total_bytes=" + to_string(i * 64) + " duration_s=" + to_string(now_epoch() - t_start))
