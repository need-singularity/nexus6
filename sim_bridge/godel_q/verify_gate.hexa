// verify_gate.hexa — verify a mutated candidate.
// Usage: hexa verify_gate.hexa <candidate_path> <baseline_output_hash>
//
// Checks (ordered, short-circuit):
//   1. parse — `hexa parse <candidate>` exit 0
//   2. run   — `hexa run <candidate>` produces stdout (timeout 10s)
//   3. output_diff — stdout hash != error AND (diff OR same counts as success)
//   4. metric_delta — sum of |r1| + |r2| + |r3| parsed from stdout vs baseline.
//      positive delta = interesting (reward); negative = still accept (Schmidhuber
//      "proof" loop is baseline≥, but MVP accepts any non-error mutation to surface
//      evolution candidates).
//
// Output TSV: "parse_ok=X\tout_ok=Y\tmetric=Z\thash=H\taccept=A"

fn md5_of(s: string) -> string {
    let mut r = ""
    try {
        // write to tmp + md5 via shell; avoids hexa-lang hash lib
        let tmp = "/tmp/.godelq_hash.txt"
        write_file(tmp, s)
        r = to_string(exec("md5 -q " + tmp + " 2>/dev/null || md5sum " + tmp + " | awk '{print $1}'")).trim()
    } catch e { r = "" }
    return r
}

fn parse_metric(stdout: string) -> i64 {
    // r1=X r2=Y r3=Z  → return |X|+|Y|+|Z|
    let mut total = 0
    let parts = stdout.split(" ")
    let mut i = 0
    while i < parts.len() {
        let p = parts[i].trim()
        let kv = p.split("=")
        if kv.len() == 2 {
            let k = kv[0].trim()
            if k == "r1" || k == "r2" || k == "r3" {
                let mut v = 0
                try { v = to_int(kv[1].trim()) } catch e { v = 0 }
                if v < 0 { v = 0 - v }
                total = total + v
            }
        }
        i = i + 1
    }
    return total
}

let _args = args()
if _args.len() < 3 {
    println("ERROR: need candidate path")
    exit(1)
}
let cand = _args[2]
let mut baseline_metric = 0
if _args.len() >= 4 {
    try { baseline_metric = to_int(_args[3]) } catch e { baseline_metric = 0 }
}

// 1. parse check via `hexa parse`
let mut parse_rc = 1
let parse_out = to_string(exec("HEXA_LOCAL=1 HEXA_NO_LAUNCHD=1 " + env_var("HOME") + "/Dev/nexus/shared/bin/hexa parse " + cand + " 2>&1 ; echo __RC__=$?"))
if parse_out.contains("__RC__=0") { parse_rc = 0 }

if parse_rc != 0 {
    println("parse_ok=0\tout_ok=0\tmetric=0\thash=PARSE_FAIL\taccept=0")
    exit(0)
}

// 2. run with timeout 10s
let run_cmd = "HEXA_LOCAL=1 HEXA_NO_LAUNCHD=1 timeout 10 " + env_var("HOME") + "/Dev/nexus/shared/bin/hexa run " + cand + " 2>&1"
let mut stdout = ""
try { stdout = to_string(exec(run_cmd)) } catch e { stdout = "" }
stdout = stdout.trim()

let mut out_ok = 0
if stdout.len() > 0 && !stdout.contains("error[") && !stdout.contains("ERROR:") && !stdout.contains("panic") {
    out_ok = 1
}

if out_ok == 0 {
    println("parse_ok=1\tout_ok=0\tmetric=0\thash=RUN_FAIL\taccept=0")
    exit(0)
}

let metric = parse_metric(stdout)
let hash = md5_of(stdout)

// 3. accept rule: non-error output + metric >= baseline (or baseline==0)
let mut accept = 0
if baseline_metric == 0 {
    accept = 1
} else {
    if metric >= baseline_metric { accept = 1 }
}

println("parse_ok=1\tout_ok=1\tmetric=" + to_string(metric) + "\thash=" + hash + "\taccept=" + to_string(accept))
