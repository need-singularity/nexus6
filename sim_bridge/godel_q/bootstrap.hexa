// bootstrap.hexa — Gödel-Quantum-Schmidhuber main loop.
// Pulls ANU bytes → picks mutation → applies to sandbox copy → verifies
// → logs. DOES NOT commit or touch original files outside this loop.
//
// Usage: hexa bootstrap.hexa [max_iters] [run_id]
//   max_iters default 20 (override up to 100)
//   run_id default = current timestamp

fn ts_id() -> string {
    let mut r = ""
    try { r = to_string(exec("date +%Y%m%d-%H%M%S")).trim() } catch e { r = "0" }
    return r
}

fn sha_hex(s: string) -> string {
    let mut r = ""
    try {
        let tmp = "/tmp/.godelq_sha.txt"
        write_file(tmp, s)
        r = to_string(exec("shasum -a 1 " + tmp + " 2>/dev/null | awk '{print $1}'")).trim()
    } catch e { r = "" }
    return r
}

// Consume 4 hex bytes (8 chars) from a 128-char ANU hex blob.
// If pos overruns, refetch a fresh blob.
fn ensure_blob(pos_ref: i64, max_len: i64) -> bool {
    return pos_ref + 8 <= max_len
}

let _args = args()
let mut max_iters = 20
if _args.len() >= 3 {
    try { max_iters = to_int(_args[2]) } catch e { max_iters = 20 }
}
if max_iters > 100 { max_iters = 100 }
if max_iters < 1 { max_iters = 1 }

let mut run_id = ts_id()
if _args.len() >= 4 { run_id = _args[3] }

let home = env_var("HOME")
let base = home + "/Dev/nexus/shared/sim_bridge/godel_q"
let src = base + "/mutation_target.hexa"
let run_dir = base + "/runs/" + run_id
try { exec("mkdir -p " + run_dir) } catch e {}
let log_path = run_dir + "/mutations.jsonl"
let sandbox = run_dir + "/candidate.hexa"

// hexa binary
let hx = home + "/Dev/nexus/shared/bin/hexa"
let picker = base + "/mutation_picker.hexa"
let mutator = base + "/mutator.hexa"
let gate = base + "/verify_gate.hexa"

// baseline
let base_cmd = "HEXA_LOCAL=1 HEXA_NO_LAUNCHD=1 " + hx + " run " + gate + " " + src + " 0 2>/dev/null"
let base_out = to_string(exec(base_cmd)).trim()
let mut baseline_metric = 0
let mut baseline_hash = ""
let bparts = base_out.split("\t")
let mut bi = 0
while bi < bparts.len() {
    let p = bparts[bi]
    let eq = p.index_of("=")
    if eq > 0 {
        let k = p.substring(0, eq).trim()
        let v = p.substring(eq + 1, p.len()).trim()
        if k == "metric" {
            try { baseline_metric = to_int(v) } catch e { baseline_metric = 0 }
        }
        if k == "hash" { baseline_hash = v }
    }
    bi = bi + 1
}

println("[bootstrap] run_id=" + run_id + " max_iters=" + to_string(max_iters))
println("[bootstrap] baseline metric=" + to_string(baseline_metric) + " hash=" + baseline_hash)
println("[bootstrap] log=" + log_path)

// header line
let hdr = "{\"event\":\"start\",\"run_id\":\"" + run_id + "\",\"max_iters\":" + to_string(max_iters) + ",\"baseline_metric\":" + to_string(baseline_metric) + ",\"baseline_hash\":\"" + baseline_hash + "\"}"
try { write_file(log_path, hdr + "\n") } catch e {}

// counters
let mut n_try = 0
let mut n_applied = 0
let mut n_parse_ok = 0
let mut n_metric_up = 0
let mut n_accept = 0
let mut anu_bytes = 0

// running blob + position
let mut blob = ""
let mut pos = 0
let anu_cmd = "HEXA_LOCAL=1 HEXA_NO_LAUNCHD=1 " + hx + " run " + base + "/anu_source.hexa 2>/dev/null"

let mut iter = 1
while iter <= max_iters {
    // get 4 bytes (8 hex chars)
    if blob.len() < pos + 8 {
        let mut b = ""
        try { b = to_string(exec(anu_cmd)).trim() } catch e { b = "" }
        if b.len() < 128 {
            println("[iter " + to_string(iter) + "] ANU fetch failed; skip")
            iter = iter + 1
            continue
        }
        blob = b
        pos = 0
    }
    let bytes_hex = blob.substring(pos, pos + 8)
    pos = pos + 8
    anu_bytes = anu_bytes + 4

    // pick
    let pick_cmd = "HEXA_LOCAL=1 HEXA_NO_LAUNCHD=1 " + hx + " run " + picker + " " + bytes_hex + " 2>/dev/null"
    let pick_out = to_string(exec(pick_cmd)).trim()
    let pparts = pick_out.split("\t")
    if pparts.len() < 3 {
        println("[iter " + to_string(iter) + "] pick fail: " + pick_out)
        iter = iter + 1
        continue
    }
    let line = pparts[0]
    let op = pparts[1]
    let mag = pparts[2]

    // mutate into sandbox
    let mut_cmd = "HEXA_LOCAL=1 HEXA_NO_LAUNCHD=1 " + hx + " run " + mutator + " " + src + " " + sandbox + " " + line + " " + op + " " + mag + " 2>/dev/null"
    let mut_out = to_string(exec(mut_cmd)).trim()
    n_try = n_try + 1

    let mut applied = 0
    let mparts = mut_out.split("\t")
    let mut old_src = ""
    let mut new_src = ""
    let mut mi = 0
    while mi < mparts.len() {
        let p = mparts[mi]
        let eq = p.index_of("=")
        if eq > 0 {
            let k = p.substring(0, eq)
            let v = p.substring(eq + 1, p.len())
            if k == "applied" {
                try { applied = to_int(v.trim()) } catch e { applied = 0 }
            }
            if k == "old" { old_src = v }
            if k == "new" { new_src = v }
        }
        mi = mi + 1
    }
    if applied == 1 { n_applied = n_applied + 1 }

    // verify
    let gate_cmd = "HEXA_LOCAL=1 HEXA_NO_LAUNCHD=1 " + hx + " run " + gate + " " + sandbox + " " + to_string(baseline_metric) + " 2>/dev/null"
    let gate_out = to_string(exec(gate_cmd)).trim()
    let gparts = gate_out.split("\t")
    let mut parse_ok = 0
    let mut out_ok = 0
    let mut metric = 0
    let mut out_hash = ""
    let mut accept = 0
    let mut gi = 0
    while gi < gparts.len() {
        let p = gparts[gi]
        let eq = p.index_of("=")
        if eq > 0 {
            let k = p.substring(0, eq).trim()
            let v = p.substring(eq + 1, p.len()).trim()
            if k == "parse_ok" {
                try { parse_ok = to_int(v) } catch e { parse_ok = 0 }
            }
            if k == "out_ok" {
                try { out_ok = to_int(v) } catch e { out_ok = 0 }
            }
            if k == "metric" {
                try { metric = to_int(v) } catch e { metric = 0 }
            }
            if k == "hash" { out_hash = v }
            if k == "accept" {
                try { accept = to_int(v) } catch e { accept = 0 }
            }
        }
        gi = gi + 1
    }
    if parse_ok == 1 { n_parse_ok = n_parse_ok + 1 }
    let delta = metric - baseline_metric
    if delta > 0 && out_ok == 1 && applied == 1 { n_metric_up = n_metric_up + 1 }
    // effective accept: mutation actually changed source AND run succeeded AND gate OK
    let mut eff_accept = 0
    if applied == 1 && out_ok == 1 && accept == 1 { eff_accept = 1 }
    if eff_accept == 1 { n_accept = n_accept + 1 }

    // escape double-quotes in old/new for JSON safety
    let old_esc = old_src.replace("\\", "\\\\").replace("\"", "\\\"")
    let new_esc = new_src.replace("\\", "\\\\").replace("\"", "\\\"")

    let entry = "{\"iter\":" + to_string(iter) + ",\"anu_hex\":\"" + bytes_hex + "\",\"line\":" + line + ",\"op\":\"" + op + "\",\"mag\":\"" + mag + "\",\"applied\":" + to_string(applied) + ",\"parse_ok\":" + to_string(parse_ok) + ",\"out_ok\":" + to_string(out_ok) + ",\"metric\":" + to_string(metric) + ",\"delta\":" + to_string(delta) + ",\"hash\":\"" + out_hash + "\",\"accept\":" + to_string(eff_accept) + ",\"old\":\"" + old_esc + "\",\"new\":\"" + new_esc + "\"}"
    try { append_file(log_path, entry + "\n") } catch e {}

    if iter == 1 || iter == max_iters || (iter - ((iter / 5) * 5)) == 0 {
        println("[iter " + to_string(iter) + "] anu=" + bytes_hex + " line=" + line + " op=" + op + " mag=" + mag + " applied=" + to_string(applied) + " parse=" + to_string(parse_ok) + " out=" + to_string(out_ok) + " metric=" + to_string(metric) + " Δ=" + to_string(delta) + " accept=" + to_string(accept))
    }

    iter = iter + 1
}

// summary
let summ = "{\"event\":\"end\",\"run_id\":\"" + run_id + "\",\"n_try\":" + to_string(n_try) + ",\"n_applied\":" + to_string(n_applied) + ",\"n_parse_ok\":" + to_string(n_parse_ok) + ",\"n_metric_up\":" + to_string(n_metric_up) + ",\"n_accept\":" + to_string(n_accept) + ",\"anu_bytes\":" + to_string(anu_bytes) + "}"
try { append_file(log_path, summ + "\n") } catch e {}

println("")
println("=== summary run_id=" + run_id + " ===")
println("try=" + to_string(n_try) + " applied=" + to_string(n_applied) + " parse_ok=" + to_string(n_parse_ok) + " metric_up=" + to_string(n_metric_up) + " accept=" + to_string(n_accept) + " anu_bytes=" + to_string(anu_bytes))
println("log: " + log_path)
