// topology_universe.hexa — selectable-topology ANU-Time universe sim
//
// Implements 6 spatial topologies as selectable lattice substrate:
//   flat        — 1D circular S¹ (legacy mini_world, σ²=64)
//   t2          — 2D torus T² (8×8 grid, periodic both axes)
//   t3          — 3D torus T³ (4×4×4 grid, periodic all axes)
//   s2          — 2-sphere S² via cube projection (closed, non-flat)
//   s3          — 3-sphere S³ via 4×4×4 antipodal identification (closed traversable)
//   klein       — Klein bottle (closed non-orientable, 8×8 with one twist)
//
// 선택 인터페이스:
//   환경변수:  NEXUS_UNIVERSE_TOPOLOGY={flat|t2|t3|s2|s3|klein}
//   CLI:       hexa topology_universe.hexa <max_ticks> <topology> [run_dir]
//   selftest:  hexa topology_universe.hexa --selftest
//
// 진화 (evolution) 모드 — closed-traversable → toroidal 같은 topology 변환:
//   환경변수:  NEXUS_UNIVERSE_EVOLVE_FROM=s3 NEXUS_UNIVERSE_EVOLVE_TO=t3 NEXUS_UNIVERSE_EVOLVE_AT=50
//   CLI:       hexa topology_universe.hexa <max_ticks> evolve <from> <to> <transition_tick>
//   동작:      tick < transition 시 from 의 neighbor 사용, 이후 to 의 neighbor 사용
//              (sharp transition; smooth blend 는 extension 가능)
//   canonical: s3-to-t3 진화 = "통과가능한 닫힌 우주 → 도넛 우주" 전형 시퀀스
//
// raw policy:
//   raw 9 hexa-only · raw 65 operation-idempotency (re-run = identical fingerprint per topology+seed)
//   raw 91 C3 honest-disclosure (failure mode emit) · raw 108 absorption-channel
//
// witness fingerprint (state_hash after deterministic seed=6, byte stream [0,1,2,...,N-1]):
//   flat → t2 → t3 → s2 → s3 → klein 가 서로 distinct (topology effects measurable)

const SIGMA_SQ: i64 = 64
const SCALE: i64 = 65536
const TAU_MIX: i64 = 4

// ── topology dispatch table ─────────────────────────────────
// topology id 정수화 (string compare 비용 회피)
const TOPO_FLAT: i64 = 0
const TOPO_T2: i64 = 1
const TOPO_T3: i64 = 2
const TOPO_S2: i64 = 3
const TOPO_S3: i64 = 4
const TOPO_KLEIN: i64 = 5

fn topology_id(name: string) -> i64 {
    if name == "flat" { return TOPO_FLAT }
    if name == "t2" { return TOPO_T2 }
    if name == "t3" { return TOPO_T3 }
    if name == "s2" { return TOPO_S2 }
    if name == "s3" { return TOPO_S3 }
    if name == "klein" { return TOPO_KLEIN }
    return 0 - 1
}

fn topology_name(id: i64) -> string {
    if id == TOPO_FLAT { return "flat" }
    if id == TOPO_T2 { return "t2" }
    if id == TOPO_T3 { return "t3" }
    if id == TOPO_S2 { return "s2" }
    if id == TOPO_S3 { return "s3" }
    if id == TOPO_KLEIN { return "klein" }
    return "unknown"
}

fn topology_describe(id: i64) -> string {
    if id == TOPO_FLAT { return "1D circular S^1 (legacy, sigma_sq=64 ring)" }
    if id == TOPO_T2 { return "2-torus T^2 (8x8 grid, periodic both axes, traversable closed flat)" }
    if id == TOPO_T3 { return "3-torus T^3 (4x4x4 grid, periodic all axes, traversable closed flat)" }
    if id == TOPO_S2 { return "2-sphere S^2 (cube projection 8x8, closed non-flat)" }
    if id == TOPO_S3 { return "3-sphere S^3 (4x4x4 antipodal identification, closed traversable curved)" }
    if id == TOPO_KLEIN { return "Klein bottle (8x8, closed non-orientable, one twist axis)" }
    return "invalid"
}

// ── topology-aware neighbor lookup ──────────────────────────
// 각 topology 별 (i, neighbor_axis) → neighbor index 반환. axis ∈ {0=left, 1=right}.
//   flat:   1D ring index (i±1) mod 64
//   t2:     8x8 grid, 4 neighbors but here use (left, right) on row+col interleaved
//   t3:     4x4x4 cube, neighbor axis interleaves x/y/z
//   s2:     cube-projection sphere (cube faces 8 cells, 8 sides) — neighbor across cube face
//   s3:     antipodal identification (i ↔ (i+32)%64 + lattice neighbor)
//   klein:  T² with one axis identified with twist (i.e., (x,y) ~ (x+8, -y mod 8))

fn _neighbor_flat(i: i64, axis: i64) -> i64 {
    if axis == 0 { return (i + SIGMA_SQ - 1) % SIGMA_SQ }
    return (i + 1) % SIGMA_SQ
}

fn _neighbor_t2(i: i64, axis: i64) -> i64 {
    // 8x8 row-major: x=i%8, y=i/8
    let x = i % 8
    let y = i / 8
    if axis == 0 {
        // left in x direction
        let xm = (x + 7) % 8
        return y * 8 + xm
    }
    // axis 1: down in y direction
    let ym = (y + 1) % 8
    return ym * 8 + x
}

fn _neighbor_t3(i: i64, axis: i64) -> i64 {
    // 4x4x4 row-major: x=i%4, y=(i/4)%4, z=i/16
    let x = i % 4
    let y = (i / 4) % 4
    let z = i / 16
    if axis == 0 {
        let xm = (x + 3) % 4
        return z * 16 + y * 4 + xm
    }
    if axis == 1 {
        let ym = (y + 3) % 4
        return z * 16 + ym * 4 + x
    }
    let zm = (z + 3) % 4
    return zm * 16 + y * 4 + x
}

fn _neighbor_s2(i: i64, axis: i64) -> i64 {
    // S^2 via 6-face cube embedding, but discrete grid 8x8 with pole identification:
    //   row 0 (y=0) all map to north pole — neighbor is anywhere on row 1 mod 8
    //   row 7 (y=7) all map to south pole — neighbor is anywhere on row 6 mod 8
    //   else: T^2-like but with pole convergence
    let x = i % 8
    let y = i / 8
    if axis == 0 {
        // longitudinal (around equator)
        let xm = (x + 7) % 8
        return y * 8 + xm
    }
    // latitudinal — cap at poles
    if y == 0 { return 1 * 8 + ((x + 4) % 8) }   // north pole → opposite side row 1
    if y == 7 { return 6 * 8 + ((x + 4) % 8) }   // south pole → opposite side row 6
    let ym = (y + 1) % 8
    return ym * 8 + x
}

fn _neighbor_s3(i: i64, axis: i64) -> i64 {
    // S^3 via 4x4x4 with antipodal identification: i ~ (i+32) mod 64 = (a, -a) pair
    // For neighbor: standard T^3 neighbor THEN antipodal-quotient (project to fundamental domain [0,32))
    let i_q = i % 32   // fundamental domain (lower half)
    let x = i_q % 4
    let y = (i_q / 4) % 4
    let z = i_q / 16
    if axis == 0 {
        let xm = (x + 3) % 4
        return z * 16 + y * 4 + xm
    }
    if axis == 1 {
        let ym = (y + 3) % 4
        return z * 16 + ym * 4 + x
    }
    if axis == 2 {
        let zm = (z + 3) % 4
        return zm * 16 + y * 4 + x
    }
    // axis 3: antipodal hop (S^3 specific, uses upper half)
    return i_q + 32
}

fn _neighbor_klein(i: i64, axis: i64) -> i64 {
    // Klein bottle via 8x8: x is ordinary periodic, y has twist — (x,y+8) ~ (-x mod 8, y)
    let x = i % 8
    let y = i / 8
    if axis == 0 {
        let xm = (x + 7) % 8
        return y * 8 + xm
    }
    // axis 1: y wrap with twist
    let yn = (y + 1) % 8
    if yn == 0 {
        // twist: x flipped
        let xt = (8 - x) % 8
        return yn * 8 + xt
    }
    return yn * 8 + x
}

fn topology_neighbor(i: i64, axis: i64, topo: i64) -> i64 {
    if topo == TOPO_FLAT { return _neighbor_flat(i, axis) }
    if topo == TOPO_T2 { return _neighbor_t2(i, axis) }
    if topo == TOPO_T3 { return _neighbor_t3(i, axis) }
    if topo == TOPO_S2 { return _neighbor_s2(i, axis) }
    if topo == TOPO_S3 { return _neighbor_s3(i, axis) }
    if topo == TOPO_KLEIN { return _neighbor_klein(i, axis) }
    return _neighbor_flat(i, axis)
}

// ── world state ─────────────────────────────────────────────
let mut __mw_x: [i64] = []
let mut __mw_tick: i64 = 0

fn mw_init(seed: i64) {
    let mut xs: [i64] = []
    let mut i = 0
    while i < SIGMA_SQ {
        let v = (seed * 1103 + i * 37 + 17) % SCALE
        let mut vv = v
        if vv < 0 { vv = 0 - vv }
        xs = xs + [vv]
        i = i + 1
    }
    __mw_x = xs
    __mw_tick = 0
}

fn _coord_hash(i: i64) -> i64 {
    let h = (i * 131 + 73) % 251
    return h + 5
}

// topology-aware step: phase 1 = additive injection, phase 2 = topology-aware diffusion
fn mw_step(byte: i64, topo: i64) {
    if byte < 0 { return }
    let mut b = byte
    if b > 255 { b = b % 256 }

    // Phase 1: additive injection
    let mut xs1: [i64] = []
    let mut i = 0
    while i < SIGMA_SQ {
        let h = _coord_hash(i)
        let mut v = __mw_x[i]
        v = v + b * h + (__mw_tick % 31)
        if v < 0 { v = 0 - v }
        v = v % SCALE
        xs1 = xs1 + [v]
        i = i + 1
    }

    // Phase 2: τ=4 diffusion via topology-aware neighbor
    let mut cur = xs1
    let mut layer = 0
    while layer < TAU_MIX {
        let mut xs2: [i64] = []
        let mut j = 0
        while j < SIGMA_SQ {
            // axis selection: alternate per layer to traverse all dims
            let axis = layer % 3   // up to 3 axes (handles t3/s3)
            let k_prev = topology_neighbor(j, axis, topo)
            let mut left: i64 = 0
            if k_prev >= 0 && k_prev < SIGMA_SQ { left = cur[k_prev] }
            let right = cur[j]
            let mix = (left * 7 + right + layer * 13) % SCALE
            xs2 = xs2 + [mix]
            j = j + 1
        }
        cur = xs2
        layer = layer + 1
    }
    __mw_x = cur
    __mw_tick = __mw_tick + 1
}

fn mw_state_hash() -> i64 {
    let mut h: i64 = 0
    let mut i = 0
    while i < SIGMA_SQ {
        let v = __mw_x[i]
        h = (h * 33 + v) % 9999999967
        i = i + 1
    }
    return h
}

// ── evolution step ──────────────────────────────────────────
// tick-based topology dispatch: tick < transition → from, else → to.
// Captures closed-traversable → toroidal phase change (e.g. s3 → t3).

fn mw_step_evolve(byte: i64, tick: i64, transition: i64, topo_from: i64, topo_to: i64) {
    let mut topo = topo_from
    if tick >= transition { topo = topo_to }
    mw_step(byte, topo)
}

// ── selftest ────────────────────────────────────────────────
// Deterministic byte stream + seed=6 across 6 topologies + evolution scenario;
// assert fingerprints distinct AND evolution result distinct from both endpoints.

fn _selftest_run(topo_name: string) -> i64 {
    let topo = topology_id(topo_name)
    if topo < 0 { return 0 - 1 }
    mw_init(6)
    let mut k = 0
    while k < 32 {
        let byte = (k * 17 + 7) % 256
        mw_step(byte, topo)
        k = k + 1
    }
    return mw_state_hash()
}

fn _selftest_evolve(from_name: string, to_name: string, transition: i64) -> i64 {
    let topo_from = topology_id(from_name)
    let topo_to = topology_id(to_name)
    if topo_from < 0 { return 0 - 1 }
    if topo_to < 0 { return 0 - 1 }
    mw_init(6)
    let mut k = 0
    while k < 32 {
        let byte = (k * 17 + 7) % 256
        mw_step_evolve(byte, k, transition, topo_from, topo_to)
        k = k + 1
    }
    return mw_state_hash()
}

fn run_selftest() {
    println("[topology_universe] --selftest")
    let names = ["flat", "t2", "t3", "s2", "s3", "klein"]
    let mut hashes: [i64] = []
    let mut i = 0
    while i < names.len() {
        let h = _selftest_run(names[i])
        hashes = hashes + [h]
        println("  topology=" + names[i] + "  state_hash=" + to_string(h) + "  desc=" + topology_describe(topology_id(names[i])))
        i = i + 1
    }
    // verify all hashes distinct
    let mut a = 0
    let mut all_distinct = true
    while a < hashes.len() {
        let mut b = a + 1
        while b < hashes.len() {
            if hashes[a] == hashes[b] {
                all_distinct = false
                println("  COLLISION: " + names[a] + " == " + names[b] + " (hash=" + to_string(hashes[a]) + ")")
            }
            b = b + 1
        }
        a = a + 1
    }
    // re-run flat twice — assert idempotent (raw 65)
    let h1 = _selftest_run("flat")
    let h2 = _selftest_run("flat")
    let idempotent = h1 == h2
    if !idempotent {
        println("  RAW-65-VIOLATION flat re-run h1=" + to_string(h1) + " h2=" + to_string(h2))
    }
    // evolution case: s3 → t3 ("closed-traversable → toroidal" canonical)
    // transition late (24 of 32) so post-transition mixing doesn't fully dominate
    let h_s3_only = _selftest_run("s3")
    let h_t3_only = _selftest_run("t3")
    let h_evolve_24 = _selftest_evolve("s3", "t3", 24)
    let h_evolve_24_idem = _selftest_evolve("s3", "t3", 24)
    let h_evolve_8 = _selftest_evolve("s3", "t3", 8)
    let evolve_24_distinct = h_evolve_24 != h_s3_only && h_evolve_24 != h_t3_only
    let evolve_8_distinct = h_evolve_8 != h_s3_only && h_evolve_8 != h_t3_only
    let evolve_24_idem = h_evolve_24 == h_evolve_24_idem
    let evolve_distinct = evolve_24_distinct || evolve_8_distinct
    let evolve_idem = evolve_24_idem
    println("  evolve s3→t3@24  hash=" + to_string(h_evolve_24) + "  distinct_from_endpoints=" + to_string(evolve_24_distinct) + "  idempotent=" + to_string(evolve_24_idem))
    println("  evolve s3→t3@8   hash=" + to_string(h_evolve_8) + "  distinct_from_endpoints=" + to_string(evolve_8_distinct))
    let pass = all_distinct && idempotent && evolve_distinct && evolve_idem
    if pass {
        println("__TOPOLOGY_UNIVERSE_SELFTEST__ PASS topologies=" + to_string(names.len()) + " idempotent=true distinct=true evolve=true")
    } else {
        println("__TOPOLOGY_UNIVERSE_SELFTEST__ FAIL all_distinct=" + to_string(all_distinct) + " idempotent=" + to_string(idempotent) + " evolve_distinct=" + to_string(evolve_distinct) + " evolve_idem=" + to_string(evolve_idem))
    }
}

// ── main ────────────────────────────────────────────────────
let _args = args()

// --selftest
let mut is_selftest = false
let mut i_arg = 0
while i_arg < _args.len() {
    if _args[i_arg] == "--selftest" { is_selftest = true }
    i_arg = i_arg + 1
}

if is_selftest {
    run_selftest()
} else {
    // CLI / env topology + evolution selection
    let mut max_ticks: i64 = 100
    let mut topo_name: string = "flat"
    let mut evolve_mode: bool = false
    let mut evolve_from_name: string = "s3"
    let mut evolve_to_name: string = "t3"
    let mut evolve_at: i64 = 0

    if _args.len() >= 3 {
        try { max_ticks = to_int(_args[2]) } catch e { max_ticks = 100 }
    }

    // CLI evolution mode: hexa topology_universe.hexa <ticks> evolve <from> <to> <at>
    if _args.len() >= 7 && _args[3] == "evolve" {
        evolve_mode = true
        evolve_from_name = _args[4]
        evolve_to_name = _args[5]
        try { evolve_at = to_int(_args[6]) } catch e { evolve_at = max_ticks / 2 }
    } else if _args.len() >= 4 {
        topo_name = _args[3]
    } else {
        // env fallback (single-topology + evolution-via-env)
        let mut env_topo = ""
        try { env_topo = to_string(exec("printenv NEXUS_UNIVERSE_TOPOLOGY")).trim() } catch e { env_topo = "" }
        if env_topo.len() > 0 { topo_name = env_topo }

        let mut env_from = ""
        let mut env_to = ""
        let mut env_at = ""
        try { env_from = to_string(exec("printenv NEXUS_UNIVERSE_EVOLVE_FROM")).trim() } catch e { env_from = "" }
        try { env_to = to_string(exec("printenv NEXUS_UNIVERSE_EVOLVE_TO")).trim() } catch e { env_to = "" }
        try { env_at = to_string(exec("printenv NEXUS_UNIVERSE_EVOLVE_AT")).trim() } catch e { env_at = "" }
        if env_from.len() > 0 && env_to.len() > 0 {
            evolve_mode = true
            evolve_from_name = env_from
            evolve_to_name = env_to
            if env_at.len() > 0 {
                try { evolve_at = to_int(env_at) } catch e { evolve_at = max_ticks / 2 }
            } else {
                evolve_at = max_ticks / 2
            }
        }
    }

    if evolve_mode {
        let topo_from = topology_id(evolve_from_name)
        let topo_to = topology_id(evolve_to_name)
        if topo_from < 0 || topo_to < 0 {
            println("[topology_universe] ERROR evolve invalid topology from=" + evolve_from_name + " to=" + evolve_to_name)
            println("  reason: validation-fail unknown-topology-in-evolve-pair")
            println("  fix: 1) use {flat,t2,t3,s2,s3,klein}  2) canonical: NEXUS_UNIVERSE_EVOLVE_FROM=s3 NEXUS_UNIVERSE_EVOLVE_TO=t3 NEXUS_UNIVERSE_EVOLVE_AT=50")
        } else {
            println("[topology_universe] start max_ticks=" + to_string(max_ticks) + " evolve mode from=" + evolve_from_name + " → to=" + evolve_to_name + " at_tick=" + to_string(evolve_at))
            println("  from_desc=" + topology_describe(topo_from))
            println("  to_desc=" + topology_describe(topo_to))
            mw_init(6)
            let mut tau: i64 = 0
            while tau < max_ticks {
                let byte = (tau * 17 + 7) % 256
                mw_step_evolve(byte, tau, evolve_at, topo_from, topo_to)
                tau = tau + 1
            }
            let final_hash = mw_state_hash()
            println("[topology_universe] done tau=" + to_string(tau) + " evolve=" + evolve_from_name + "→" + evolve_to_name + "@" + to_string(evolve_at) + " final_state_hash=" + to_string(final_hash))
        }
    } else {
        let topo = topology_id(topo_name)
        if topo < 0 {
            println("[topology_universe] ERROR unknown topology=" + topo_name)
            println("  valid: flat | t2 | t3 | s2 | s3 | klein")
            println("  reason: validation-fail invalid-topology-name")
            println("  fix: 1) use one of {flat,t2,t3,s2,s3,klein}  2) NEXUS_UNIVERSE_TOPOLOGY=t3 hexa topology_universe.hexa <max_ticks>  3) hexa topology_universe.hexa <ticks> evolve s3 t3 50  4) hexa topology_universe.hexa --selftest")
        } else {
            println("[topology_universe] start max_ticks=" + to_string(max_ticks) + " topology=" + topo_name + " desc=" + topology_describe(topo))
            mw_init(6)
            let mut tau: i64 = 0
            while tau < max_ticks {
                let byte = (tau * 17 + 7) % 256
                mw_step(byte, topo)
                tau = tau + 1
            }
            let final_hash = mw_state_hash()
            println("[topology_universe] done tau=" + to_string(tau) + " topology=" + topo_name + " final_state_hash=" + to_string(final_hash))
        }
    }
}
