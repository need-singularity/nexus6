// universe_pipeline.hexa — Stage 1-5 unified runner
//
// Single-topology integrated pipeline: runs all 5 Stage modules sequentially
// and emits unified observable matrix. Built post-iter-21 cross-stage validation
// to replace ad-hoc shell-loop sweeps with one canonical runner.
//
// raw 91 C3 honest: this DOES NOT cross-feed Stage outputs (e.g., quantum
// amplitude → Lorentz causality input). Each Stage runs INDEPENDENTLY on the
// same topology + seed. The pipeline is for OBSERVABLE COMPARISON not state
// propagation. State-propagation pipeline is a separate Stage 6 candidate.
//
// Usage:
//   hexa universe_pipeline.hexa <topology> [ticks=50]
//   hexa universe_pipeline.hexa --selftest
//   hexa universe_pipeline.hexa list-topo

const PIPE_SIGMA: i64 = 64
const PIPE_HBAR: i64 = 100
const PIPE_LSCALE: i64 = 65536
const PIPE_LHIST: i64 = 4
const PIPE_FDT: i64 = 100
const PIPE_FSCALE: i64 = 1000

const PT_FLAT: i64 = 0
const PT_T3: i64 = 2
const PT_S3: i64 = 4
const PT_BLACKHOLE: i64 = 6
const PT_WORMHOLE: i64 = 7

fn _ptopo_id(name: string) -> i64 {
    if name == "flat" { return PT_FLAT }
    if name == "t3" { return PT_T3 }
    if name == "s3" { return PT_S3 }
    if name == "blackhole" { return PT_BLACKHOLE }
    if name == "wormhole" { return PT_WORMHOLE }
    return 0 - 1
}

fn _pneighbor_t3(i: i64, axis: i64) -> i64 {
    let x = i % 4
    let y = (i / 4) % 4
    let z = i / 16
    if axis == 0 { let xm = (x + 3) % 4; return z * 16 + y * 4 + xm }
    if axis == 1 { let ym = (y + 3) % 4; return z * 16 + ym * 4 + x }
    let zm = (z + 3) % 4
    return zm * 16 + y * 4 + x
}

fn _pneighbor(i: i64, axis: i64, topo: i64) -> i64 {
    if topo == PT_FLAT {
        if axis == 0 { return (i + PIPE_SIGMA - 1) % PIPE_SIGMA }
        return (i + 1) % PIPE_SIGMA
    }
    if topo == PT_S3 {
        let i_q = i % 32
        let x = i_q % 4
        let y = (i_q / 4) % 4
        let z = i_q / 16
        if axis == 0 { let xm = (x + 3) % 4; return z * 16 + y * 4 + xm }
        if axis == 1 { let ym = (y + 3) % 4; return z * 16 + ym * 4 + x }
        if axis == 2 { let zm = (z + 3) % 4; return zm * 16 + y * 4 + x }
        return i_q + 32
    }
    if topo == PT_BLACKHOLE {
        let i_BH: i64 = 21
        if i == i_BH { return i_BH }
        let x = i % 4
        let y = (i / 4) % 4
        let z = i / 16
        let mut dx = x - 1; if dx < 0 { dx = 0 - dx }
        let mut dy = y - 1; if dy < 0 { dy = 0 - dy }
        let mut dz = z - 1; if dz < 0 { dz = 0 - dz }
        let d = dx + dy + dz
        if d <= 1 {
            let mut nx = x; let mut ny = y; let mut nz = z
            if axis == 0 { if x > 1 { nx = x - 1 } else if x < 1 { nx = x + 1 } }
            else if axis == 1 { if y > 1 { ny = y - 1 } else if y < 1 { ny = y + 1 } }
            else { if z > 1 { nz = z - 1 } else if z < 1 { nz = z + 1 } }
            return nz * 16 + ny * 4 + nx
        }
        return _pneighbor_t3(i, axis)
    }
    if topo == PT_WORMHOLE {
        if axis >= 3 {
            if i < 32 { let off = i % 8; return 32 + ((i + off) % 32) }
            let i2 = i - 32; let off = i2 % 8; return (i2 + off) % 32
        }
        let base = if i < 32 { 0 } else { 32 }
        let r = i - base
        let x = r % 4; let y = (r / 4) % 4; let z = r / 16
        if axis == 0 { let xm = (x + 3) % 4; return base + z * 16 + y * 4 + xm }
        if axis == 1 { let ym = (y + 3) % 4; return base + z * 16 + ym * 4 + x }
        let zm = (z + 1) % 2
        return base + zm * 16 + y * 4 + x
    }
    return _pneighbor_t3(i, axis)
}

fn run_stage1_quantum(topo: i64, ticks: i64) -> [i64] {
    let mut re: [i64] = []
    let mut im: [i64] = []
    let mut i = 0
    while i < PIPE_SIGMA {
        let mut d = i - 32; if d < 0 { d = 0 - d }
        let denom = 1 + (d * d) / 4
        let mut v: i64 = 10000 / denom
        v = v + (6 * 17 + i * 3) % 100
        if v < 0 { v = 0 - v }
        re = re + [v]; im = im + [0]
        i = i + 1
    }
    let mut t = 0
    while t < ticks {
        let mut new_re: [i64] = []
        let mut new_im: [i64] = []
        i = 0
        while i < PIPE_SIGMA {
            let mut sum_re: i64 = 0
            let mut sum_im: i64 = 0
            let mut a = 0
            while a < 3 {
                let j = _pneighbor(i, a, topo)
                if j >= 0 && j < PIPE_SIGMA { sum_re = sum_re + re[j]; sum_im = sum_im + im[j] }
                a = a + 1
            }
            let lap_re = sum_re - 3 * re[i]
            let lap_im = sum_im - 3 * im[i]
            new_re = new_re + [re[i] + (PIPE_HBAR * lap_im) / 10000]
            new_im = new_im + [im[i] - (PIPE_HBAR * lap_re) / 10000]
            i = i + 1
        }
        re = new_re; im = new_im
        t = t + 1
    }
    let mut norm2: i64 = 0
    let mut weight_a: i64 = 0
    let mut weight_b: i64 = 0
    let mut h: i64 = 0
    i = 0
    while i < PIPE_SIGMA {
        let p = (re[i] * re[i] + im[i] * im[i]) / 10000
        norm2 = norm2 + p
        if i < 32 { weight_a = weight_a + p } else { weight_b = weight_b + p }
        h = (h * 33 + re[i]) % 9999999967
        h = (h * 33 + im[i]) % 9999999967
        i = i + 1
    }
    let total = weight_a + weight_b
    let split = if total > 0 { (weight_a * 1000) / total } else { 0 }
    return [norm2, h, split]
}

fn run_stage2_lorentz(topo: i64, ticks: i64) -> [i64] {
    let mut hist: [i64] = []
    let mut k = 0
    while k < PIPE_SIGMA * PIPE_LHIST {
        let i = k % PIPE_SIGMA
        let mut d = i - 32; if d < 0 { d = 0 - d }
        let v = (PIPE_LSCALE / (1 + d * d)) + (6 * 13 + i * 7) % 100
        hist = hist + [v]
        k = k + 1
    }
    let mut t_now: i64 = 0
    let mut tick = 0
    while tick < ticks {
        t_now = (t_now + 1) % PIPE_LHIST
        let mut new_buf: [i64] = []
        k = 0
        while k < PIPE_SIGMA * PIPE_LHIST { new_buf = new_buf + [hist[k]]; k = k + 1 }
        let mut i = 0
        while i < PIPE_SIGMA {
            let t1_idx = (t_now - 1 + PIPE_LHIST * 2) % PIPE_LHIST
            let t2_idx = (t_now - 2 + PIPE_LHIST * 2) % PIPE_LHIST
            let prev = hist[t1_idx * PIPE_SIGMA + i]
            let prev2 = hist[t2_idx * PIPE_SIGMA + i]
            let time_term = 0 - prev + prev2 / 4
            let mut sum_n: i64 = 0
            let mut a = 0
            while a < 3 {
                let j = _pneighbor(i, a, topo)
                sum_n = sum_n + hist[t1_idx * PIPE_SIGMA + j]
                a = a + 1
            }
            let space_term = sum_n / 3
            let mut nv = (time_term + space_term + PIPE_LSCALE) % PIPE_LSCALE
            if nv < 0 { nv = nv + PIPE_LSCALE }
            new_buf[t_now * PIPE_SIGMA + i] = nv
            i = i + 1
        }
        hist = new_buf
        tick = tick + 1
    }
    let mut h: i64 = 0
    let mut e: i64 = 0
    let mut i = 0
    while i < PIPE_SIGMA {
        let v = hist[t_now * PIPE_SIGMA + i]
        h = (h * 33 + v) % 9999999967
        e = e + (v * v) / PIPE_LSCALE
        i = i + 1
    }
    return [h, e, 0]
}

fn run_stage3_field(topo: i64, ticks: i64) -> [i64] {
    let mut phi: [i64] = []
    let mut pi: [i64] = []
    let mut i = 0
    while i < PIPE_SIGMA {
        let mut d = i - 32; if d < 0 { d = 0 - d }
        phi = phi + [(PIPE_FSCALE / (1 + d * d / 2)) + (6 * 11 + i * 5) % 50]
        pi = pi + [(6 * 7 + i * 3) % 30]
        i = i + 1
    }
    let m2: i64 = 100
    let mut t = 0
    while t < ticks {
        let mut force: [i64] = []
        i = 0
        while i < PIPE_SIGMA {
            let mut sum_n: i64 = 0
            let mut a = 0
            while a < 3 { sum_n = sum_n + phi[_pneighbor(i, a, topo)]; a = a + 1 }
            let lap = sum_n - 3 * phi[i]
            let dV = m2 * phi[i] / PIPE_FSCALE
            force = force + [lap - dV]
            i = i + 1
        }
        let mut pi_half: [i64] = []
        let mut new_phi: [i64] = []
        i = 0
        while i < PIPE_SIGMA {
            let pi_h = pi[i] + (PIPE_FDT * force[i]) / (2 * PIPE_FSCALE)
            pi_half = pi_half + [pi_h]
            new_phi = new_phi + [phi[i] + (PIPE_FDT * pi_h) / PIPE_FSCALE]
            i = i + 1
        }
        let mut force_new: [i64] = []
        i = 0
        while i < PIPE_SIGMA {
            let mut sum_n: i64 = 0
            let mut a = 0
            while a < 3 { sum_n = sum_n + new_phi[_pneighbor(i, a, topo)]; a = a + 1 }
            let lap = sum_n - 3 * new_phi[i]
            let dV = m2 * new_phi[i] / PIPE_FSCALE
            force_new = force_new + [lap - dV]
            i = i + 1
        }
        let mut new_pi: [i64] = []
        i = 0
        while i < PIPE_SIGMA {
            new_pi = new_pi + [pi_half[i] + (PIPE_FDT * force_new[i]) / (2 * PIPE_FSCALE)]
            i = i + 1
        }
        phi = new_phi; pi = new_pi
        t = t + 1
    }
    let mut H: i64 = 0
    let mut h: i64 = 0
    i = 0
    while i < PIPE_SIGMA {
        let T = (pi[i] * pi[i]) / (2 * PIPE_FSCALE)
        let phi2 = (phi[i] * phi[i]) / PIPE_FSCALE
        let V = m2 * phi2 / (2 * PIPE_FSCALE)
        H = H + T + V
        h = (h * 33 + phi[i]) % 9999999967
        h = (h * 33 + pi[i]) % 9999999967
        i = i + 1
    }
    return [H, h, 0]
}

fn run_stage4_anchor(topo: i64, ticks: i64) -> [i64] {
    let mut phi: [i64] = []
    let mut pi: [i64] = []
    let mut i = 0
    while i < PIPE_SIGMA {
        let mut d = i - 32; if d < 0 { d = 0 - d }
        phi = phi + [(1000 / (1 + d * d / 2 + 1)) + (6 * 11 + i * 5) % 50]
        pi = pi + [(6 * 7 + i * 3) % 30]
        i = i + 1
    }
    let m2: i64 = 100
    let mut t = 0
    while t < ticks {
        let mut force: [i64] = []
        i = 0
        while i < PIPE_SIGMA {
            let mut sum_n: i64 = 0
            let mut a = 0
            while a < 3 { sum_n = sum_n + phi[_pneighbor(i, a, topo)]; a = a + 1 }
            let lap = sum_n - 3 * phi[i]
            let dV = m2 * phi[i] / 1000
            force = force + [lap - dV]
            i = i + 1
        }
        let mut new_phi: [i64] = []
        let mut new_pi: [i64] = []
        i = 0
        while i < PIPE_SIGMA {
            let pi_half = pi[i] + force[i] / 20
            new_pi = new_pi + [pi_half]
            new_phi = new_phi + [phi[i] + pi_half / 10]
            i = i + 1
        }
        phi = new_phi; pi = new_pi
        t = t + 1
    }
    let mut sum_corr: i64 = 0
    let mut count: i64 = 0
    i = 0
    while i < PIPE_SIGMA - 1 {
        let prod = (phi[i] * phi[i + 1]) / 1000
        sum_corr = sum_corr + prod
        count = count + 1
        i = i + 1
    }
    let avg = if count > 0 { sum_corr / count } else { 0 }
    let mut clamped = avg
    if clamped < 0 { clamped = 0 }
    if clamped > 1000 { clamped = 1000 }
    let n_s_proxy = 9500 + (clamped * 400) / 1000
    let mut diff = n_s_proxy - 9649
    let normalized = diff / 42
    let chi2_n_s = normalized * normalized
    return [n_s_proxy, chi2_n_s, 0]
}

fn run_stage5_scale(ticks: i64) -> [i64] {
    let L: i64 = 10
    let n: i64 = 1000
    let mut state: [i64] = []
    let mut i = 0
    while i < n {
        let mut d = i - n / 2; if d < 0 { d = 0 - d }
        state = state + [(1000 / (1 + d * d / 4 + 1)) + (6 * 11 + i * 5) % 50]
        i = i + 1
    }
    let mut t = 0
    while t < ticks {
        let mut new_st: [i64] = []
        i = 0
        while i < n {
            let x = i % L; let y = (i / L) % L; let z = i / (L * L)
            let xm = (x + L - 1) % L
            let ym = (y + L - 1) % L
            let zm = (z + L - 1) % L
            let n_left = z * L * L + y * L + xm
            let n_back = z * L * L + ym * L + x
            let n_down = zm * L * L + y * L + x
            let avg = (state[n_left] + state[n_back] + state[n_down]) / 3
            let mut v = (state[i] + avg) / 2 + (t % 31)
            if v < 0 { v = 0 - v }
            v = v % 1000
            new_st = new_st + [v]
            i = i + 1
        }
        state = new_st
        t = t + 1
    }
    let mut e: i64 = 0
    let mut h: i64 = 0
    i = 0
    while i < n {
        e = e + (state[i] * state[i]) / 1000
        h = (h * 33 + state[i]) % 9999999967
        i = i + 1
    }
    return [h, e, n]
}

fn run_pipeline(topo_name: string, ticks: i64) {
    let topo = _ptopo_id(topo_name)
    if topo < 0 {
        println("[universe_pipeline] ERROR unknown topology=" + topo_name)
        println("  valid: flat | t3 | s3 | blackhole | wormhole")
        return
    }
    println("[universe_pipeline] topology=" + topo_name + " ticks=" + to_string(ticks))
    let s1 = run_stage1_quantum(topo, ticks)
    println("  Stage 1 quantum: norm2=" + to_string(s1[0]) + " hash=" + to_string(s1[1]) + " split=" + to_string(s1[2]) + "per-mille")
    let s2 = run_stage2_lorentz(topo, ticks)
    println("  Stage 2 lorentz: hash=" + to_string(s2[0]) + " energy=" + to_string(s2[1]))
    let s3 = run_stage3_field(topo, ticks)
    println("  Stage 3 field: H=" + to_string(s3[0]) + " hash=" + to_string(s3[1]))
    let s4 = run_stage4_anchor(topo, ticks)
    println("  Stage 4 anchor: n_s_proxy=" + to_string(s4[0]) + " chi2_n_s=" + to_string(s4[1]) + " (Planck ref=9649 sigma=42)")
    let s5 = run_stage5_scale(ticks)
    println("  Stage 5 scale: cells=" + to_string(s5[2]) + " hash=" + to_string(s5[0]) + " energy=" + to_string(s5[1]))
    let composite = (s1[1] ^ s2[0] ^ s3[1] ^ s5[0]) % 9999999967
    println("  composite-fingerprint(s1.hash XOR s2.hash XOR s3.hash XOR s5.hash) = " + to_string(composite))
    println("  raw 91 C3 honest: stages run INDEPENDENTLY (same topo+seed, no state cross-feed)")
}

fn run_pipeline_selftest() {
    println("[universe_pipeline] --selftest (5 topologies x 5 stages)")
    let topos = ["flat", "t3", "s3", "blackhole", "wormhole"]
    let mut composites: [i64] = []
    let mut i = 0
    while i < topos.len() {
        let topo = _ptopo_id(topos[i])
        let s1 = run_stage1_quantum(topo, 16)
        let s2 = run_stage2_lorentz(topo, 16)
        let s3 = run_stage3_field(topo, 16)
        let s4 = run_stage4_anchor(topo, 16)
        let s5 = run_stage5_scale(16)
        let composite = (s1[1] ^ s2[0] ^ s3[1] ^ s5[0]) % 9999999967
        composites = composites + [composite]
        println("  topo=" + topos[i] + ": s1.norm2=" + to_string(s1[0]) + " s4.n_s=" + to_string(s4[0]) + " s4.chi2=" + to_string(s4[1]) + " composite=" + to_string(composite))
        i = i + 1
    }
    let mut a = 0
    let mut all_distinct = true
    while a < composites.len() {
        let mut b = a + 1
        while b < composites.len() {
            if composites[a] == composites[b] {
                all_distinct = false
                println("  COLLISION " + topos[a] + " == " + topos[b])
            }
            b = b + 1
        }
        a = a + 1
    }
    if all_distinct {
        println("__UNIVERSE_PIPELINE_SELFTEST__ PASS topologies=5 stages=5 composite-distinct=true")
    } else {
        println("__UNIVERSE_PIPELINE_SELFTEST__ FAIL composite-distinct=false")
    }
}

let _pargs = args()
let mut p_is_selftest = false
let mut p_is_list = false
let mut p_arg_i = 0
while p_arg_i < _pargs.len() {
    if _pargs[p_arg_i] == "--selftest" { p_is_selftest = true }
    if _pargs[p_arg_i] == "list-topo" { p_is_list = true }
    p_arg_i = p_arg_i + 1
}

if p_is_selftest {
    run_pipeline_selftest()
} else if p_is_list {
    println("topologies: flat | t3 | s3 | blackhole | wormhole")
    println("stages: 1 quantum-amplitude | 2 Lorentz-causal | 3 field-action | 4 empirical-anchor | 5 scale-up")
} else {
    let mut p_topo_name: string = "t3"
    let mut p_ticks: i64 = 50
    if _pargs.len() >= 3 { p_topo_name = _pargs[2] }
    if _pargs.len() >= 4 {
        try { p_ticks = to_int(_pargs[3]) } catch e { p_ticks = 50 }
    }
    run_pipeline(p_topo_name, p_ticks)
}
