// pure_hexa_buffer.hexa — shell-out-free byte buffer
//
// Hypothesis: the ~30ms per-tick floor came from
//   1. `printf '%d' 0x..`  per byte                                (shell exec)
//   2. `head -c N /dev/urandom | od -An -vtx1 | tr -d ' '` per refresh
// Replacing per-byte shell-out with a hexa-native hex→int parser should
// collapse the floor by ~2 orders of magnitude, exposing whatever
// genuine sub-ms jitter exists underneath.
//
// Design:
//   - ONE urandom fetch at start (N*2 hex chars) → __hex
//   - per-byte: substring(off, off+2) + manual hex-pair → int (in-hexa)
//   - (curl-out for ANU remains necessary — flagged in summary)
//
// Usage: hexa pure_hexa_buffer.hexa <n_ticks> <run_dir> [source]
//   source ∈ "urandom" (default) | "anu_prefetch_then_iterate"
//   n_ticks: <= 500

let _args = args()
let mut n_ticks: i64 = 200
let mut run_dir: string = ""
let mut src_mode: string = "urandom"

if _args.len() >= 3 { try { n_ticks = to_int(_args[2]) } catch e { n_ticks = 200 } }
if _args.len() >= 4 { run_dir = _args[3] }
if _args.len() >= 5 { src_mode = _args[4] }

if n_ticks < 10 { n_ticks = 10 }
if n_ticks > 2000 { n_ticks = 2000 }

if run_dir.len() == 0 {
    let mut home = ""
    try { home = to_string(exec("printenv HOME")).trim() } catch e { home = "" }
    run_dir = home + "/Dev/nexus/shared/sim_bridge/anu_time/experiments/streaming/_run_purehexa"
}
try { let _m = exec("mkdir -p '" + run_dir + "'") } catch e {}

// ─── timing ───
fn now_ns() -> i64 {
    // R37/AN13/L3-PY violation — python3 time.time_ns() stubbed 2026-04-18
    let mut r = ""
    try { r = to_string(exec("date +%s%N 2>/dev/null")).trim() } catch e { r = "0" }
    let mut v: i64 = 0
    try { v = to_int(r) } catch e { v = 0 }
    return v
}

fn now_epoch() -> i64 {
    let mut r = ""
    try { r = to_string(exec("date +%s")).trim() } catch e { r = "0" }
    let mut v: i64 = 0
    try { v = to_int(r) } catch e { v = 0 }
    return v
}

// ─── PURE-HEXA hex char → int (no shell) ───
fn hex_char_val(c: string) -> i64 {
    // c is one-char substring; compare string equality
    if c == "0" { return 0 }
    if c == "1" { return 1 }
    if c == "2" { return 2 }
    if c == "3" { return 3 }
    if c == "4" { return 4 }
    if c == "5" { return 5 }
    if c == "6" { return 6 }
    if c == "7" { return 7 }
    if c == "8" { return 8 }
    if c == "9" { return 9 }
    if c == "a" { return 10 }
    if c == "b" { return 11 }
    if c == "c" { return 12 }
    if c == "d" { return 13 }
    if c == "e" { return 14 }
    if c == "f" { return 15 }
    if c == "A" { return 10 }
    if c == "B" { return 11 }
    if c == "C" { return 12 }
    if c == "D" { return 13 }
    if c == "E" { return 14 }
    if c == "F" { return 15 }
    return 0
}

fn hex_pair_int(h2: string) -> i64 {
    if h2.len() < 2 { return 0 }
    let hi = hex_char_val(h2.substring(0, 1))
    let lo = hex_char_val(h2.substring(1, 2))
    return hi * 16 + lo
}

// ─── single bulk prefetch (one shell-out allowed) ───
fn fetch_bulk_urandom(n_bytes: i64) -> string {
    // Mark: one-shot shell call, amortised over all ticks.
    let tmp = "/tmp/purebuf_ur." + to_string(now_epoch()) + ".hex"
    let cmd = "head -c " + to_string(n_bytes) + " /dev/urandom | od -An -vtx1 | tr -d ' \\n' > " + tmp + "; cat " + tmp + "; rm -f " + tmp
    let mut hex = ""
    try { hex = to_string(exec(cmd)).trim() } catch e { hex = "" }
    let need = n_bytes * 2
    if hex.len() < need { return "" }
    return hex.substring(0, need)
}

fn fetch_bulk_anu(n_bytes: i64) -> string {
    // R37/AN13/L3-PY violation — python3 JSON parser for ANU QRNG stubbed 2026-04-18
    // Original: curl ... | /usr/bin/python3 -c "import sys,json; ..." (hex-encode up to 1024 bytes)
    // No-op: return "" → caller falls back to urandom path / reports empty buffer.
    eprintln("[R37] pure_hexa_buffer.fetch_bulk_anu: python3 JSON parser disabled; caller should use urandom path.")
    return ""
}

// ─── main ───
let log_path = run_dir + "/log.jsonl"
let meta_path = run_dir + "/meta.json"

try { write_file(log_path, "") } catch e {}

println("[pure] n_ticks=" + to_string(n_ticks) + " src=" + src_mode + " run=" + run_dir)

let start_epoch = now_epoch()
let start_ns = now_ns()
let fetch_ns0 = now_ns()
let mut hexbuf = ""
if src_mode == "anu_prefetch_then_iterate" {
    hexbuf = fetch_bulk_anu(n_ticks)
    if hexbuf.len() == 0 {
        println("[pure] ANU prefetch failed → urandom")
        hexbuf = fetch_bulk_urandom(n_ticks)
    }
} else {
    hexbuf = fetch_bulk_urandom(n_ticks)
}
let fetch_ns1 = now_ns()
let fetch_wall_ns = fetch_ns1 - fetch_ns0

if hexbuf.len() < n_ticks * 2 {
    println("[pure] ABORT prefetch too small: " + to_string(hexbuf.len() / 2) + " bytes < " + to_string(n_ticks))
    let m = "{\"mode\":\"pure_hexa\",\"error\":\"prefetch_short\",\"n_ticks\":" + to_string(n_ticks) + "}\n"
    try { write_file(meta_path, m) } catch e {}
    exit(1)
}

let meta_json = "{\"mode\":\"pure_hexa\",\"src\":\"" + src_mode + "\",\"n_ticks\":" + to_string(n_ticks) + ",\"start_epoch\":" + to_string(start_epoch) + ",\"prefetch_wall_ns\":" + to_string(fetch_wall_ns) + "}\n"
try { write_file(meta_path, meta_json) } catch e {}

// --- PASS 1: bulk iterate WITHOUT now_ns() inside loop → measure true floor ---
// Any now_ns() call invokes python3 shell-out (~30ms). Including it per-tick makes
// per-tick dt dominated by the measurement itself. Instead, time the bulk loop.
let bulk_t0 = now_ns()
let mut bytes_all: [i64] = []
let mut i: i64 = 0
while i < n_ticks {
    let off = i * 2
    let h2 = hexbuf.substring(off, off + 2)
    let b = hex_pair_int(h2)
    bytes_all = bytes_all + [b]
    i = i + 1
}
let bulk_t1 = now_ns()
let bulk_iter_ns = bulk_t1 - bulk_t0
let per_tick_ns = bulk_iter_ns / n_ticks

// --- PASS 2: write log with amortised per-tick dt + full byte value ---
let mut j: i64 = 0
let t_base = bulk_t0
while j < n_ticks {
    let t_est = t_base + j * per_tick_ns
    let line = "{\"i\":" + to_string(j) + ",\"t_ns_est\":" + to_string(t_est) + ",\"dt_ns_amort\":" + to_string(per_tick_ns) + ",\"byte\":" + to_string(bytes_all[j]) + "}\n"
    try { append_file(log_path, line) } catch e {}
    if j % 50 == 0 {
        println("[j=" + to_string(j) + "] byte=" + to_string(bytes_all[j]))
    }
    j = j + 1
}

let end_ns = now_ns()
let fmeta = "{\"mode\":\"pure_hexa\",\"src\":\"" + src_mode + "\",\"n_ticks\":" + to_string(n_ticks) + ",\"prefetch_wall_ns\":" + to_string(fetch_wall_ns) + ",\"bulk_iter_ns\":" + to_string(bulk_iter_ns) + ",\"per_tick_ns_amort\":" + to_string(per_tick_ns) + ",\"total_wall_ns\":" + to_string(end_ns - start_ns) + "}\n"
try { write_file(meta_path, fmeta) } catch e {}
println("[pure] done n=" + to_string(i) + " bulk_iter_ms=" + to_string(bulk_iter_ns / 1000000) + " per_tick_ns=" + to_string(per_tick_ns))
