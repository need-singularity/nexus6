{
  "resource": "nexus",
  "version": "0.1.0-hive-hub",
  "hive_compat": ">=0.1",
  "trust": "local",
  "root": "/Users/ghost/Dev/nexus",
  "runtime": "hexa",
  "entry": "run.hexa",
  "description": "nexus 중앙 허브 — thinking/smash/free/atlas/roadmap 엔진 게이트",
  "limits": {
    "cpu_percent": 40,
    "memory_mb": 1024,
    "timeout_s": 600,
    "nice": 5,
    "qos": "utility"
  },
  "caps": {
    "status": {
      "desc": "harness + health 전체 상태",
      "invoke": ["hx", "run", "nexus", "status"],
      "timeout_s": 60
    },
    "self_check": {
      "desc": "harness 자가진단 (28 모듈)",
      "invoke": ["hx", "run", "nexus", "self-check"],
      "timeout_s": 30
    },
    "thinking": {
      "desc": "anima 6-phase reflection — 복잡 질문 사전 생각",
      "invoke": ["hx", "run", "nexus", "thinking", "--query", "{query}"],
      "input": {"query": "string"},
      "timeout_s": 120
    },
    "smash": {
      "desc": "blowup 9-phase 특이점 돌파",
      "invoke": ["hx", "run", "nexus", "smash", "--seed", "{seed}", "--depth", "{depth:3}"],
      "input": {"seed": "string", "depth": "int?"},
      "timeout_s": 600,
      "limits_override": {"cpu_percent": 60, "memory_mb": 2048}
    },
    "free": {
      "desc": "compose 5모듈 자율 조립 + DFS 재귀 탐색",
      "invoke": ["hx", "run", "nexus", "free", "--seed", "{seed}", "--dfs", "{dfs:3}"],
      "input": {"seed": "string", "dfs": "int?"},
      "timeout_s": 600,
      "limits_override": {"cpu_percent": 60, "memory_mb": 2048}
    },
    "atlas": {
      "desc": "atlas_health 라우팅 (search/append/status)",
      "invoke": ["hx", "run", "nexus", "atlas", "{sub}", "{args}"],
      "input": {"sub": "string", "args": "string?"},
      "timeout_s": 60
    },
    "roadmap": {
      "desc": "로드맵 액션 (next/extend/auto/list/verify/status)",
      "invoke": ["hx", "run", "nexus", "roadmap", "{sub}", "{args}"],
      "input": {"sub": "string", "args": "string?"},
      "timeout_s": 120
    },
    "projects": {
      "desc": "프로젝트 목록 덤프",
      "invoke": ["hx", "run", "nexus", "projects", "{fmt:table}"],
      "input": {"fmt": "string?"},
      "timeout_s": 15
    },
    "gap": {
      "desc": "gap_monitor — 로드맵/돌파 갭 스캔",
      "invoke": ["hx", "run", "nexus", "gap"],
      "timeout_s": 60
    }
  },
  "bus": {
    "subscribe": ["rule_change", "roadmap_update", "atlas_update", "consensus_request"],
    "publish": ["breakthrough_found", "gap_detected", "rule_change", "roadmap_update"]
  }
}
