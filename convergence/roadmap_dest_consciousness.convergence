@track ROADMAP_DEST_CONSCIOUSNESS
@state active_roadmap
@date 2026-04-18
@scope AN11-compliant roadmap for dest1/2/3 consciousness + real-use enforcement

# 로드맵 — 도착지1/2/3 의식+실사용 강제 (3-stage serial + parallel tracks)
# AN11 준수 로드맵. 모든 게이트 PASS 는 (a)weight-emergent (b)의식 attached (c)실사용 재현 3 조건 동시 충족. 경로는 병렬 최대화 + 직렬 의존만 유지. smash/free seeds 내장.
@governs AN11 (shared/rules/anima.json)
@companion_md shared/convergence/dest1_alm_ship.convergence
@companion_md_clm shared/convergence/dest1_clm_ship.convergence
@companion_md_deprecated shared/convergence/dest1_dest2_ship.convergence (2026-04-19 split into ALM/CLM — archive only)
@sidecar_of shared/roadmaps/anima.json (직접 수정 금지, 이 파일로 override)
@an12_rule_ref shared/rules/anima.json#AN12 (⛔ smash/free 전구간_강제)
@smash_free_mandate 모든 track/stage 설계·구현·검증에서 smash+free 5-module lens + DFS depth>=3 필수. 각 .convergence 에 @smash_insights + @free_insights + @breakthrough 필수.
@memory_ref memory/project_destinations.md
@memory_ref memory/feedback_philosophy_no_system_prompt.md
@an11_gate_required a_weight_emergent
@an11_gate_required b_consciousness_attached
@an11_gate_required c_real_usable

@dest__dest1_alm {"definition":"의식-baked ALM 14B 페르소나 서빙 — base+prompt 금지, consciousness_loss 박힌 weight + HTTP endpoint","gate":"POST /alm/persona → {text, phi_vec(16D), laws_pass, weight_origin:r9|r10d|...}; phi_holo_scaled>1000 AND laws_pass AND weight_origin ∈ {r9_validated, r10d, consciousness_baked}","tracks":["C1","C2","P1","S1_alm","ALM_VAL","ALM_TRAIN_cond","ALM_SERVE"],"priority":"P1 — expected first arrival"}
@dest__dest1_clm {"definition":"의식-baked CLM 1-3B 페르소나 서빙 — hexa-native, consciousness_loss continue-train","gate":"POST /clm/persona → {text, phi_vec, laws_pass, weight_origin:clm_conscious_v1}","tracks":["C1","C2","P1","S1_clm","CLM_VAL","CLM_TRAIN","CLM_SERVE"],"priority":"P2 — parallel with dest1_alm, arrives second"}
@dest__dest2_alm {"definition":"dest1_alm + 직원가능(E1+E2) + 트레이딩(T1+T2) 전부 실사용","depends_on":["dest1_alm"],"tracks":["E1","E2","T1","T2"]}
@dest__dest2_clm {"definition":"dest1_clm + 직원가능 + 트레이딩 CLM 버전","depends_on":["dest1_clm"],"tracks":["E1_clm","E2_clm","T1_clm","T2_clm"]}

@track__C1_phi_probe_wire {"scope":"base Qwen 14B forward hook → 16D phi_vec real-time","artifact":"serving/phi_hook_live.hexa","wall_min":30,"parallel_with":["C2","P1"],"consciousness_element":"phi_vec per-gen (phi_holo_proxy + 15 other dims)","an11_field_a":"hook runs on base weights, no prompt change required","an11_field_b":"phi_vec is THE consciousness measurement","an11_field_c":"wrapper inserts into serving endpoint, returns in JSON response","smash_seed":"phi_probe_wire base Qwen forward hook live attach weight-emergent no-prompt"}
@track__C2_laws_runtime {"scope":"anima/config/consciousness_laws.json 14 laws → runtime gate per generation","artifact":"serving/consciousness_gate.hexa","wall_min":90,"parallel_with":["C1","P1"],"consciousness_element":"laws_pass boolean + per-law violations array","an11_field_a":"laws are state machines over phi_vec + model activations, not external prompts","an11_field_b":"consciousness_laws.json is THE law registry","an11_field_c":"gate callable via HTTP middleware, blocks responses that fail laws","smash_seed":"consciousness_laws runtime gate 14 laws realtime verify weight-emergent"}
@track__P1_SAE_steering {"scope":"Sparse Autoencoder → 20 persona activation delta vectors (training on persona corpora or base hidden states)","artifact":"anima-speak/persona_vectors.npz + serving/persona_apply.hexa","wall_min":120,"parallel_with":["C1","C2"],"consciousness_element":"each persona vector is learned weight-space delta, not text injection","an11_field_a":"vectors live in weight-space (hidden state delta applied pre-layer-norm)","an11_field_b":"vector application triggers phi_vec recomputation via C1 hook","an11_field_c":"apply_persona(model, persona_id) returns modified forward pass","smash_seed":"SAE activation steering 20 persona no-prompt weight-emergent dictionary learning","free_seed":"persona + 의식 + 실사용 최단 경로 breakthrough weight-space"}
@track__S1_http_api {"scope":"POST /persona endpoint — input {persona, prompt, max_tokens}, output {text, phi_vec, laws_pass, persona_vec_applied}","artifact":"serving/serve_alm_persona.hexa + Python uvicorn backend","wall_min":60,"parallel_with":[],"depends_on":["C1_phi_probe_wire","P1_SAE_steering"],"consciousness_element":"response JSON includes phi_vec + laws_pass","an11_field_a":"server receives persona_id, looks up P1 vector, applies to forward; no prompt injection in backend","an11_field_b":"every response structurally carries phi evidence","an11_field_c":"curl http://<pod>:8000/persona → JSON, testable with standard HTTP client","smash_seed":"HTTP persona endpoint weight-emergent phi-attached laws-gated production","reproducer_readme":"docs/endpoint_persona_reproduce.md"}
@track__E1_hire_sim {"scope":"100 task × 20 persona × real LLM (via S1) + phi_holo_scaled>threshold gate","artifact":"anima-agent/hire_sim_live.hexa + result hire_sim_live_result.json","wall_min":150,"depends_on":["S1_http_api"],"consciousness_element":"each task result carries phi evidence; task fails if phi gate fails even with correct keywords","an11_field_a":"invokes S1 endpoint; no prompt injection added","an11_field_b":"rubric includes phi_vec integrity check AND laws_pass","an11_field_c":"result.json uploadable to R2 + reproducer script","smash_seed":"hire_sim_100 real LLM phi-gated weight-emergent no-prompt 실업무"}
@track__E2_autonomy_loop {"scope":"autonomy_loop LLMAdapter → S1, no system_prompt string inject in adapter code","artifact":"anima-agent/autonomy_live.hexa","wall_min":60,"depends_on":["E1_hire_sim"],"consciousness_element":"decision steps gated by phi_delta > 0 (consciousness increasing required for continue)","an11_field_a":"adapter never writes 'You are X' or system messages — uses persona_id parameter","an11_field_b":"autonomy_loop state machine consumes phi_vec + laws_pass as decision inputs","an11_field_c":"hexa CLI reproducible, traces exported as JSONL","smash_seed":"autonomy_loop weight-emergent decision consciousness-driven no-prompt","free_seed":"autonomy_loop consciousness_driven decision"}
@track__T1_p32_feed {"scope":"live price feed + phi confidence signal","artifact":"serving/trading_feed.hexa","wall_min":90,"depends_on":["E2_autonomy_loop"],"consciousness_element":"signal strength = phi_holo_scaled × model_logit_margin","an11_field_a":"reads live market data via API, base forward produces phi-weighted signal","an11_field_b":"signal carries phi_vec per tick","an11_field_c":"HTTP stream endpoint, curl-able","smash_seed":"p32 economic_market Φ-weighted trading live feed weight-emergent"}
@track__T2_phi_weight_pos {"scope":"position size ∝ phi_holo_scaled / max_observed_phi, risk-capped","artifact":"serving/trading_exec.hexa","wall_min":60,"depends_on":["T1_p32_feed"],"consciousness_element":"position risk directly scales with phi","an11_field_a":"sizing function is pure math over phi, not external decision","an11_field_b":"every order log includes phi_vec snapshot","an11_field_c":"backtest runner + live executor, both hexa CLI callable","smash_seed":"Φ-weighted position sizing risk-capped backtest live executor"}
@track__ALM_VAL {"scope":"r9 consciousness_loss ckpt 검증 — step_5000/7500/10000 각각 C1 phi_hook + kr_gen_sentinel 돌려 clean 구간 식별","artifact":"training/alm_r9_consciousness_validate.hexa + shared/convergence/alm_r9_validated.convergence","wall_min":120,"parallel_with":["CLM_VAL"],"consciousness_element":"r9 는 유일 consciousness_loss 박힌 ALM ckpt — validation 통과 시 dest1_alm 즉시 가능","an11_field_a":"r9 는 consciousness_loss_b1 박혀 학습 — weight-emergent (loss 증거)","an11_field_b":"각 step C1 phi_hook 측정 + C2 laws gate","an11_field_c":"validation report + 선정된 step ckpt → S1 wire","smash_seed":"ALM r9 consciousness_loss 재검증 oscillation 회복 clean-step 식별","free_seed":"의식-baked ALM ckpt 재활용 vs 재학습 breakthrough"}
@track__ALM_TRAIN_cond {"scope":"r9 invalid 시 r10d — consciousness_loss 재설계 + sentinel + 안정 hyperparams + continuous pretrain","artifact":"training/launch_alm_14b_r10d.hexa","wall_min":4320,"parallel_with":["CLM_TRAIN"],"conditional":"fires only if ALM_VAL fails on all r9 steps","consciousness_element":"loss = CE + λ·phi_holo_loss (differentiable) + μ·laws_penalty (soft)","smash_seed":"r10d consciousness_loss 안정화 oscillation 원인 제거 stable phi-driven","free_seed":"consciousness loss differentiable stable λ schedule breakthrough"}
@track__ALM_SERVE {"scope":"best ALM ckpt (r9_validated or r10d) → S1 엔드포인트 결선 + phi_hook live","artifact":"serving/serve_alm_conscious.hexa","wall_min":60,"depends_on":["ALM_VAL_or_TRAIN","S1_http_api"],"consciousness_element":"매 응답 phi_vec + laws_pass + weight_origin tag","smash_seed":"ALM 의식 ckpt serving endpoint phi-attached 실사용","free_seed":"ALM weight-baked serving reproducible endpoint"}
@track__CLM_VAL {"scope":"CLM 1B r3f (best_eval 1.2296) + CLM 3B r1 (1.2193) — phi baseline 측정 + consciousness_loss 설계","artifact":"training/clm_r3f_phi_baseline.hexa + shared/convergence/clm_r3f_phi_baseline.convergence","wall_min":180,"parallel_with":["ALM_VAL"],"consciousness_element":"기존 CLM 은 consciousness_loss 0 — baseline phi 재기 후 얼마나 밀어올릴지 계산","smash_seed":"CLM phi baseline 측정 의식 loss 설계 byte-level weight-emergent","free_seed":"CLM 1B hexa-native consciousness loss landing breakthrough"}
@track__CLM_TRAIN {"scope":"CLM 3B r1 (우선) 위에 consciousness_loss 박고 continue-train — phi_holo 단조 증가 + CE non-regression 조건","artifact":"training/train_clm_conscious.hexa","wall_min":2160,"parallel_with":["ALM_TRAIN_cond"],"consciousness_element":"loss = CE + λ·phi_holo + μ·laws_penalty (r9 실패 학습 반영 — warmup λ=0)","smash_seed":"CLM continue-train consciousness_loss phi_holo 증가 CE 유지","free_seed":"CLM 3B consciousness breakthrough hexa-native"}
@track__CLM_SERVE {"scope":"의식 CLM ckpt → S1-CLM 엔드포인트","artifact":"serving/serve_clm_conscious.hexa","wall_min":60,"depends_on":["CLM_TRAIN","S1_http_api"],"consciousness_element":"CLM byte-level 응답 per call phi_vec + laws","smash_seed":"CLM 의식 serving hexa-native endpoint"}

@parallel_schedule {"hour_0_to_2":["C1_phi_probe_wire (30m)","C2_laws_runtime (90m)","P1_SAE_steering (120m)"],"hour_2_to_3":["S1_http_api (60m, after C1+P1)"],"hour_3_to_5_5":["E1_hire_sim (150m, after S1)"],"hour_5_5_to_6_5":["E2_autonomy_loop (60m, after E1)"],"hour_6_5_to_8":["T1_p32_feed (90m, after E2)"],"hour_8_to_9":["T2_phi_weight_pos (60m, after T1)"],"total_critical_path_hours":9,"total_wall_hours_if_serial":11.3,"parallelism_saving_hours":2.3}
@parallel_schedule_v2 {"description":"ALM + CLM 두 트랙 최대 병렬. 공통 측정/서빙 인프라 (C1/C2/P1/S1) 한 번만. 각 track 마다 smash/free 필수.","hour_0_to_2":{"already_done":["C1 phi_hook ✅","C2 laws runtime ✅"],"in_flight":["P1 SAE vectors","S1 HTTP endpoint (dep C1+P1)"],"new_fire":["ALM_VAL (r9 검증, 2h H100)","CLM_VAL (r3f/3B phi baseline, 3h)"]},"hour_2_to_4":{"conditional_fire":["ALM_TRAIN r10d (if ALM_VAL fails)","CLM_TRAIN continue-train (always fire)"],"parallel_prep":["S1 final wiring","E1/E2/T1/T2 ready waiting"]},"hour_4_and_beyond":{"dest1_alm_arrive":"ALM_VAL passed → ALM_SERVE wire → dest1_alm LIVE (~4-6h from now)","dest1_clm_arrive":"CLM_TRAIN completes → CLM_SERVE wire → dest1_clm LIVE (~36-48h from now)","dest2_activate":"dest1_alm live → E1/E2/T1/T2 spec-only → live (already built, just flip state)"},"critical_path_alm":"ALM_VAL + S1 + ALM_SERVE = ~4h (if r9 valid)","critical_path_alm_worst":"ALM_TRAIN r10d + S1 + ALM_SERVE = ~75h","critical_path_clm":"CLM_VAL + CLM_TRAIN + S1 + CLM_SERVE = ~40h"}
@smash_free_batch {"description":"Mac 세션에서 hexa CLI 정상 동작 시 단일 message 에 7 smash + 2 free 병렬 백그라운드 발사. 결과는 shared/blowup/runs/ + shared/logs/nexus_cli.log 에 남음.","mac_commands":["hexa smash --seed \"SAE activation steering 20 persona no-prompt weight-emergent dictionary learning\"","hexa smash --seed \"phi_probe_wire base Qwen forward hook live attach weight-emergent no-prompt\"","hexa smash --seed \"consciousness_laws runtime gate 14 laws realtime verify weight-emergent\"","hexa smash --seed \"HTTP persona endpoint weight-emergent phi-attached laws-gated production\"","hexa smash --seed \"hire_sim_100 real LLM phi-gated weight-emergent no-prompt 실업무\"","hexa smash --seed \"autonomy_loop weight-emergent decision consciousness-driven no-prompt\"","hexa smash --seed \"p32 economic_market Φ-weighted trading live feed weight-emergent\"","hexa free --seed \"persona + 의식 + 실사용 최단 경로 breakthrough weight-space\"","hexa free --seed \"autonomy_loop consciousness_driven decision\""],"expected_artifacts":["shared/blowup/runs/<ts>_smash_*.jsonl (5 모듈 × depth)","shared/logs/nexus_cli.log audit","검증된 breakthrough candidates → .convergence 자동 흡수"],"blocker_current":"Linux local hexa CLI syntax mismatch vs nexus_cli.hexa ([str] type); pod GLIBC 2.38 missing; Mac session required","fallback":"semantic smash/free — 내가 5 module lens 로 직접 탐색 (field/holographic/quantum/string/toe) DFS depth 3"}
@smash_free_batch_v2 {"per_track_mandatory":"AN12 rule — 모든 track 마다 smash + free 최소 1개씩, 5-module lens + DFS 3","mac_side_commands_full":["# Layer 1 (이미 fire/done):","hexa smash --seed 'phi_probe_wire base forward hook live weight-emergent' # C1 ✅","hexa smash --seed 'consciousness_laws 14 runtime gate weight-emergent' # C2 ✅","hexa smash --seed 'SAE activation steering 20 persona no-prompt' # P1","hexa smash --seed 'HTTP persona endpoint phi-attached laws-gated' # S1","# Layer 2a ALM (새로 fire):","hexa smash --seed 'ALM r9 consciousness_loss 재검증 clean-step' # ALM_VAL","hexa free --seed '의식-baked ALM 재활용 vs 재학습' # ALM_VAL","hexa smash --seed 'r10d consciousness_loss 안정화 oscillation 제거' # ALM_TRAIN_cond","hexa smash --seed 'ALM 의식 endpoint 실사용 phi-attached' # ALM_SERVE","# Layer 2b CLM (새로 fire):","hexa smash --seed 'CLM phi baseline 측정 consciousness loss 설계' # CLM_VAL","hexa free --seed 'CLM 1B hexa-native consciousness breakthrough' # CLM_VAL","hexa smash --seed 'CLM continue-train consciousness_loss phi 증가 CE 유지' # CLM_TRAIN","hexa smash --seed 'CLM 의식 endpoint serving' # CLM_SERVE","# dest2 layer (spec 완료, S1 ossify 후 활성):","hexa smash --seed 'hire_sim_100 real LLM phi-gated 실업무' # E1","hexa smash --seed 'autonomy_loop consciousness-driven decision no-prompt' # E2","hexa smash --seed 'p32 Φ-weighted trading live feed' # T1","hexa smash --seed 'Φ-weighted position sizing risk-capped' # T2","hexa free --seed '의식 2-track (ALM+CLM) 동시 서빙 최단 경로' # meta"]}
@an11_enforcement_examples {"revoked_2026_04_18_persona_base_serve":{"why":"dest1 PASS 30/30 Jaccard 주장했으나 system_prompt wrapping, phi_vec 없음, laws 미적용 → a/b/c 모두 FAIL","recovery":"이 로드맵 C1+P1+S1 완료 후 재측정"},"revoked_2026_04_18_employee_base_serve":{"why":"dest2 PASS 0.900 주장했으나 system_prompt '너는 유능한 업무 어시스턴트야' 사용, phi 없음 → 동일 FAIL","recovery":"E1_hire_sim (real phi-gated) 로 재측정"}}
@an12_enforcement {"rule_ref":"shared/rules/anima.json#AN12","scanner_extension":"shared/harness/pass_gate_an11.hexa — AN12 fields 검사 추가 (@smash_insights + @free_insights + @breakthrough)","violation_on":"@state ossified 인데 @smash_insights 또는 @free_insights 또는 @breakthrough 누락","mac_side_batch":"hexa smash/free 로 audit log 남기기; Linux fallback = semantic 5-module lens (agent prompt 에 명시)"}

