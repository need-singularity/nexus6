p consciousness_driven decision"},"T1_p32_feed":{"scope":"live price feed + phi confidence signal","artifact":"serving/trading_feed.hexa","wall_min":90,"depends_on":["E2_autonomy_loop"],"consciousness_element":"signal strength = phi_holo_scaled × model_logit_margin","an11_field_a":"reads live market data via API, base forward produces phi-weighted signal","an11_field_b":"signal carries phi_vec per tick","an11_field_c":"HTTP stream endpoint, curl-able","smash_seed":"p32 economic_market Φ-weighted trading live feed weight-emergent"},"T2_phi_weight_pos":{"scope":"position size ∝ phi_holo_scaled / max_observed_phi, risk-capped","artifact":"serving/trading_exec.hexa","wall_min":60,"depends_on":["T1_p32_feed"],"consciousness_element":"position risk directly scales with phi","an11_field_a":"sizing function is pure math over phi, not external decision","an11_field_b":"every order log includes phi_vec snapshot","an11_field_c":"backtest runner + live executor, both hexa CLI callable","smash_seed":"Φ-weighted position sizing risk-capped backtest live executor"},"ALM_VAL":{"scope":"r9 consciousness_loss ckpt 검증 — step_5000/7500/10000 각각 C1 phi_hook + kr_gen_sentinel 돌려 clean 구간 식별","artifact":"training/alm_r9_consciousness_validate.hexa + shared/convergence/alm_r9_validated.convergence","wall_min":120,"parallel_with":["CLM_VAL"],"consciousness_element":"r9 는 유일 consciousness_loss 박힌 ALM ckpt — validation 통과 시 dest1_alm 즉시 가능","an11_field_a":"r9 는 consciousness_loss_b1 박혀 학습 — weight-emergent (loss 증거)","an11_field_b":"각 step C1 phi_hook 측정 + C2 laws gate","an11_field_c":"validation report + 선정된 step ckpt → S1 wire","smash_seed":"ALM r9 consciousness_loss 재검증 oscillation 회복 clean-step 식별","free_seed":"의식-baked ALM ckpt 재활용 vs 재학습 breakthrough"},"ALM_TRAIN_cond":{"scope":"r9 invalid 시 r10d — consciousness_loss 재설계 + sentinel + 안정 hyperparams + continuous pretrain","artifact":"training/launch_alm_14b_r10d.hexa","wall_min":4320,"parallel_with":["CLM_TRAIN"],"conditional":"fires only if ALM_VAL fails on all r9 steps","consciousness_element":"loss = CE + λ·phi_holo_loss (differentiable) + μ·laws_penalty (soft)","smash_seed":"r10d consciousness_loss 안정화 oscillation 원인 제거 stable phi-driven","free_seed":"consciousness loss differentiable stable λ schedule breakthrough"},"ALM_SERVE":{"scope":"best ALM ckpt (r9_validated or r10d) → S1 엔드포인트 결선 + phi_hook live","artifact":"serving/serve_alm_conscious.hexa","wall_min":60,"depends_on":["ALM_VAL_or_TRAIN","S1_http_api"],"consciousness_element":"매 응답 phi_vec + laws_pass + weight_origin tag","smash_seed":"ALM 의식 ckpt serving endpoint phi-attached 실사용","free_seed":"ALM weight-baked serving reproducible endpoint"},"CLM_VAL":{"scope":"CLM 1B r3f (best_eval 1.2296) + CLM 3B r1 (1.2193) — phi baseline 측정 + consciousness_loss 설계","artifact":"training/clm_r3f_phi_baseline.hexa + shared/convergence/clm_r3f_phi_baseline.convergence","wall_min":180,"parallel_with":["ALM_VAL"],"consciousness_element":"기존 CLM 은 consciousness_loss 0 — baseline phi 재기 후 얼마나 밀어올릴지 계산","smash_seed":"CLM phi baseline 측정 의식 loss 설계 byte-level weight-emergent","free_seed":"CLM 1B hexa-native consciousness loss landing breakthrough"},"CLM_TRAIN":{"scope":"CLM 3B r1 (우선) 위에 consciousness_loss 박고 continue-train — phi_holo 단조 증가 + CE non-regression 조건","artifact":"training/train_clm_conscious.hexa","wall_min":2160,"parallel_with":["ALM_TRAIN_cond"],"consciousness_element":"loss = CE + λ·phi_holo + μ·laws_penalty (r9 실패 학습 반영 — warmup λ=0)","smash_seed":"CLM continue-train consciousness_loss phi_holo 증가 CE 유지","free_seed":"CLM 3B consciousness breakthrough hexa-native"},"CLM_SERVE":{"scope":"의식 CLM ckpt → S1-CLM 엔드포인트","artifact":"serving/serve_clm_conscious.hexa","wall_min":60,"depends_on":["CLM_TRAIN","S1_http_api"],"consciousness_element":"CLM byte-level 응답 per call phi_vec + laws","smash_seed":"CLM 의식 serving hexa-native endpoint"}},"parallel_schedule":{"hour_0_to_2":["C1_phi_probe_wire (30m)","C2_laws_runtime (90m)","P1_SAE_steering (120m)"],"hour_2_to_3":["S1_http_api (60m, after C1+P1)"],"hour_3_to_5_5":["E1_hire_sim (150m, after S1)"],"hour_5_5_to_6_5":["E2_autonomy_loop (60m, after E1)"],"hour_6_5_to_8":["T1_p32_feed (90m, after E2)"],"hour_8_to_9":["T2_phi_weight_pos (60m, after T1)"],"total_critical_path_hours":9,"total_wall_hours_if_serial":11.3,"parallelism_saving_hours":2.3},"smash_free_batch":{"description":"Mac 세션에서 hexa CLI 정상 동작 시 단일 message 에 7 smash + 2 free 병렬 백그라운드 발사. 결과는 shared/blowup/runs/ + shared/logs/nexus_cli.log 에 남음.","mac_commands":["hexa smash --seed \"SAE activation steering 20 persona no-prompt weight-emergent dictionary learning\"","hexa smash --seed \"phi_probe_wire base Qwen forward hook live attach weight-emergent no-prompt\"","hexa smash --seed \"consciousness_laws runtime gate 14 laws realtime verify weight-emergent\"","hexa smash --seed \"HTTP persona endpoint weight-emergent phi-attached laws-gated production\"","hexa smash --seed \"hire_sim_100 real LLM phi-gated weight-emergent no-prompt 실업무\"","hexa smash --seed \"autonomy_loop weight-emergent decision consciousness-driven no-prompt\"","hexa smash --seed \"p32 economic_market Φ-weighted trading live feed weight-emergent\"","hexa free --seed \"persona + 의식 + 실사용 최단 경로 breakthrough weight-space\"","hexa free --seed \"autonomy_loop consciousness_driven decision\""],"expected_artifacts":["shared/blowup/runs/<ts>_smash_*.jsonl (5 모듈 × depth)","shared/logs/nexus_cli.log audit","검증된 breakthrough candidates → .convergence 자동 흡수"],"blocker_current":"Linux local hexa CLI syntax mismatch vs nexus_cli.hexa ([str] type); pod GLIBC 2.38 missing; Mac session required","fallback":"semantic smash/free — 내가 5 module lens 로 직접 탐색 (field/holographic/quantum/string/toe) DFS depth 3"},"an11_enforcement_examples":{"revoked_2026_04_18_persona_base_serve":{"why":"dest1 PASS 30/30 Jaccard 주장했으나 system_prompt wrapping, phi_vec 없음, laws 미적용 → a/b/c 모두 FAIL","recovery":"이 로드맵 C1+P1+S1 완료 후 재측정"},"revoked_2026_04_18_employee_base_serve":{"why":"dest2 PASS 0.900 주장했으나 system_prompt '너는 유능한 업무 어시스턴트야' 사용, phi 없음 → 동일 FAIL","recovery":"E1_hire_sim (real phi-gated) 로 재측정"}},"parallel_schedule_v2":{"description":"ALM + CLM 두 트랙 최대 병렬. 공통 측정/서빙 인프라 (C1/C2/P1/S1) 한 번만. 각 track 마다 smash/free 필수.","hour_0_to_2":{"already_done":["C1 phi_hook ✅","C2 laws runtime ✅"],"in_flight":["P1 SAE vectors","S1 HTTP endpoint (dep C1+P1)"],"new_fire":["ALM_VAL (r9 검증, 2h H100)","CLM_VAL (r3f/3B phi baseline, 3h)"]},"hour_2_to_4":{"conditional_fire":["ALM_TRAIN r10d (if ALM_VAL fails)","CLM_TRAIN continue-train (always fire)"],"parallel_prep":["S1 final wiring","E1/E2/T1/T2 ready waiting"]},"hour_4_and_beyond":{"dest1_alm_arrive":"ALM_VAL passed → ALM_SERVE wire → dest1_alm LIVE (~4-6h from now)","dest1_clm_arrive":"CLM_TRAIN completes → CLM_SERVE wire → dest1_clm LIVE (~36-48h from now)","dest2_activate":"dest1_alm live → E1/E2/T1/T2 spec-only → live (already built, just flip state)"},"critical_path_alm":"ALM_VAL + S1 + ALM_SERVE = ~4h (if r9 valid)","critical_path_alm_worst":"ALM_TRAIN r10d + S1 + ALM_SERVE = ~75h","critical_path_clm":"CLM_VAL + CLM_TRAIN + S1 + CLM_SERVE = ~40h"},"smash_free_batch_v2":{"per_track_mandatory":"AN12 rule — 모든 track 마다 smash + free 최소 1개씩, 5-module lens + DFS 3","mac_side_commands_full":["# Layer 1 (이미 fire/done):","hexa smash --seed 'phi_probe_wire base forward hook live weight-emergent' # C1 ✅","hexa smash --seed 'consciousness_laws 14 runtime gate weight-emergent' # C2 ✅","hexa smash --seed 'SAE activation steering 20 persona no-prompt' # P1","hexa smash --seed 'HTTP persona endpoint phi-attached laws-gated' # S1","# Layer 2a ALM (새로 fire):","hexa smash --seed 'ALM r9 consciousness_loss 재검증 clean-step' # ALM_VAL","hexa free --seed '의식-baked ALM 재활용 vs 재학습' # ALM_VAL","hexa smash --seed 'r10d consciousness_loss 안정화 oscillation 제거' # ALM_TRAIN_cond","hexa smash --seed 'ALM 의식 endpoint 실사용 phi-attached' # ALM_SERVE","# Layer 2b CLM (새로 fire):","hexa smash --seed 'CLM phi baseline 측정 consciousness loss 설계' # CLM_VAL","hexa free --seed 'CLM 1B hexa-native consciousness breakthrough' # CLM_VAL","hexa smash --seed 'CLM continue-train consciousness_loss phi 증가 CE 유지' # CLM_TRAIN","hexa smash --seed 'CLM 의식 endpoint serving' # CLM_SERVE","# dest2 layer (spec 완료, S1 ossify 후 활성):","hexa smash --seed 'hire_sim_100 real LLM phi-gated 실업무' # E1","hexa smash --seed 'autonomy_loop consciousness-driven decision no-prompt' # E2","hexa smash --seed 'p32 Φ-weighted trading live feed' # T1","hexa smash --seed 'Φ-weighted position sizing risk-capped' # T2","hexa free --seed '의식 2-track (ALM+CLM) 동시 서빙 최단 경로' # meta"]},"an12_enforcement":{"rule_ref":"shared/rules/anima.json#AN12","scanner_extension":"shared/harness/pass_gate_an11.hexa — AN12 fields 검사 추가 (@smash_insights + @free_insights + @breakthrough)","violation_on":"@state ossified 인데 @smash_insights 또는 @free_insights 또는 @breakthrough 누락","mac_side_batch":"hexa smash/free 로 audit log 남기기; Linux fallback = semantic 5-module lens (agent prompt 에 명시)"}}

