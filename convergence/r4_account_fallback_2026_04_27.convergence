# new module surface (Phase 2)

@module hive/packages/coding-agent/src/core/account-fallback.ts
@exports
  - interface AccountFailure {slotName, failureClass, rawError, exitCode}
  - type AccountFailureClass = "auth-expired" | "rate-limit" | "auth-revoked" | "network" | "unknown"
  - interface AccountFallbackOptions {maxRetries=3, cooldownSeconds=1800, alreadyAttempted, slotPickBin, auditPath, now, spawnSyncImpl}
  - interface AccountFallbackResult {nextSlot, nextConfigDir, cooldownApplied, exhaustedSlots, trailer?}
  - interface PoolHealthRow {slot, healthy, reason}
  - async function pickNextSlot(failure, opts) → AccountFallbackResult
  - async function probePool(opts) → PoolHealthRow[]
  - function classifyFailure(stderr, stdoutTail, exitCode) → AccountFailureClass
  - function isFallbackCandidate(reason, errorText) → bool
  - function parseSlotPickSentinel(stderr) → {verdict, slot, reason}
  - function formatPoolExhaustedTrailer(exhausted) → string (raw 66 ai-native trailer)
  - const ACCOUNT_FALLBACK_DEFAULTS (frozen)
@constraints
  - ZERO direct HTTP calls
  - ZERO @anthropic-ai/sdk import
  - ZERO ANTHROPIC_API_KEY reference
  - SHELLS OUT to claude_slot_pick.hexa (canonical writer per Sub-J)
@audit_schema raw 77 / raw 85 JSONL row at /Users/ghost/core/nexus/.raw-audit
  schema=account_fallback.v1
  ops=slot-fallback / slot-fallback-rotated / slot-fallback-exhausted

