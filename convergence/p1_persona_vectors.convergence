@selftest_summary mean_shift_vs_baseline=0.917 min_shift=0.797 mean_inter_persona=0.804 min_inter=0.516
@selftest_pass_shift_ge_0.15 true
@selftest_pass_inter_ge_0.20 true
@selftest_prompts continuation-style: "내가 한마디 하자면," / "그 사건에 대해 말하자면," / "나는 말했다. \""
@selftest_no_system_prompt true  // AN11 compliance — only user continuation text tokenized
@selftest_no_persona_token true  // no persona name appears in any prompt

