# Phase 2 — Router implementation

@artifact /Users/ghost/core/hive/packages/coding-agent/src/core/hive-cli-router.ts (new)
@surface
  - HiveCLIRequest { prompt, model?, parentSessionId?, stream?, systemPrompt?, maxTokens? }
  - HiveCLIResponse { text, sessionId, finishReason, usage? }
  - callViaHiveCLI(req, options?) — single-shot Claude invocation
  - HiveCLIRouterError carrying raw 66 trailer
  - formatRaw66Trailer / parseHiveStdout / resolveHiveBin exported
@spawn_pattern `hive --no-session -p '<prompt>' [--model M] [--system-prompt S] [--max-output-tokens N]`
@env_scrub spawned env strips ANTHROPIC_API_KEY + ANTHROPIC_AUTH_TOKEN; sets HIVE_PARENT_SID for raw 44 propagation
@trace stderr line `hive-cli-router: invoked via=<bin> sid=<sid> args=<n>` when HIVE_CLI_ROUTER_TRACE=1
@failure_modes
  - hive-cli-fail (generic non-zero exit)
  - claude-cli-not-found (ENOENT or stderr matches "claude.*not (found|installed)")
  - provider-extension-broken (stderr matches /extension|provider/)
  - parser-failure (empty stdout on exit 0)
  - timeout (HIVE_CLI_TIMEOUT_MS, default 300000)
  - abort (AbortSignal triggered)

