// prompt_scan.hexa вҖ” мӮ¬мҡ©мһҗ н”„лЎ¬н”„нҠё лӘ…л № нӮӨмӣҢл“ң к°җм§Җ (UserPromptSubmit нӣ… лҢҖмІҙ)
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
// м—ӯн• : cmd-dispatch + go-parallel + nexus-prompt-scan лЎңм§Ғ нҶөн•©
// usage: hexa run shared/tool/prompt_scan.hexa "<user_text>"
// output: нӮӨмӣҢл“ң л§Өм№ӯ мӢң systemMessage/м•ҢлҰј stdout. лҜёл§Өм№ӯмқҙл©ҙ л¬ҙм¶ңл Ҙ.

let HOME = env("HOME")
let HEXA = HOME + "/Dev/nexus/bin/hexa"
let HARNESS = HOME + "/Dev/nexus/harness"
let CMDS_JSON = HOME + "/Dev/nexus/config/commands.json"

// в”Җв”Җв”Җ freshness мәҗмӢң вҖ” idempotent н•ҳмң„ check л°ҳліө skip в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// к°Ғ sub-module нҳём¶ң м „м—җ fresh нҷ•мқё вҶ’ TTL лӮҙл©ҙ skip.
// л¬ҙнҡЁнҷ”лҠ” к°Ғ лӘЁл“Ҳ мһҗмІҙмқҳ лӮҙл¶Җ мғҒнғң ліҖкІҪ мӢң мһҗм—° л§ҢлЈҢ (нҢҢмқј мӮӯм ң or TTL кІҪкіј).
// л§Ө prompt лӢ№ ~1-2мҙҲ м Ҳк°җ (7к°ң мӨ‘ 3к°ңк°Җ 200-400ms hexa startup).
// OPT-P8-4: file_exists() guard before exec (skip shell when file absent)
fn is_fresh(tag: str, ttl_sec: i64) -> bool {
    let path = "/tmp/prompt_scan_fresh_" + tag
    if file_exists(path) == false { return false }
    let age = to_string(exec("echo $(( $(date +%s) - $(stat -f%m " + path + " 2>/dev/null) ))")).trim()  // @allow-bare-exec
    if age == "" { return false }
    let mut age_i = 999
    try { age_i = to_int(age) } catch e {}
    if age_i < ttl_sec { return true }
    return false
}

// OPT-P8-3: exec("touch") вҶ’ write_file() builtin (subprocess eliminated)
fn mark_fresh(tag: str) {
    let path = "/tmp/prompt_scan_fresh_" + tag
    try { write_file(path, "") } catch e {}
}

// commands.json SSOT лҸҷм Ғ лЎңл“ң вҖ” кіөмҡ© + project_specific[git basename] лЁём§Җ.
// н•ҳл“ңмҪ”л”© лҜёлҹ¬ кёҲм§Җ (R36 нӣ„ліҙ, drift 0).
fn load_cmds_from_ssot() {
    let mut cmds = []

    // кіөмҡ© commands
    let q1 = "/usr/bin/jq -r '.commands | to_entries[] | \"\\(.key)\\t\\(.value.keywords | join(\"|\"))\"' '" + CMDS_JSON + "' 2>/dev/null"
    let out1 = to_string(exec(q1)).trim()  // @allow-bare-exec
    for line in out1.split("\n") {
        if line.len() == 0 { continue }
        let parts = line.split("\t")
        if parts.len() >= 2 {
            cmds = cmds.push([parts[0], parts[1]])
        }
    }

    // н”„лЎңм қнҠёлі„ (git basename кё°л°ҳ)
    let proj = to_string(exec("basename \"$(git rev-parse --show-toplevel 2>/dev/null)\" 2>/dev/null")).trim()  // @allow-bare-exec
    if proj.len() > 0 {
        let q2 = "/usr/bin/jq -r --arg p '" + proj + "' '.project_specific[$p] // {} | to_entries[] | \"\\(.key)\\t\\(.value.keywords | join(\"|\"))\"' '" + CMDS_JSON + "' 2>/dev/null"
        let out2 = to_string(exec(q2)).trim()  // @allow-bare-exec
        for line in out2.split("\n") {
            if line.len() == 0 { continue }
            let parts = line.split("\t")
            if parts.len() >= 2 {
                cmds = cmds.push([parts[0], parts[1]])
            }
        }
    }

    return cmds
}

// H-PROJ-ALL вҖ” м „мІҙ/н”„лЎңм қнҠё лӘ©лЎқ/м •лҰ¬/м„Өкі„ л§ҘлқҪ л°ңнҷ” мӢң projects.json лҚ°мқҙн„° мһҗлҸҷ мЈјмһ…
// мҪ”л“ң мҲҳмӨҖ к°•м ң: hint л§Ң мЈјм§Җ м•Ҡкі  projects_list.hexa table м¶ңл Ҙмқ„ stdout м—җ мӢӨм ң dump
// мҡ°нҡҢ: env NEXUS_PROJ_ALL_OK=1 лҳҗлҠ” '@allow-proj-all' нҶ нҒ°
// SSOT: shared/config/projects.json (schema 4) + shared/tool/projects_list.hexa
fn check_proj_all(lower: str) {
    if env("NEXUS_PROJ_ALL_OK") == "1" { return }
    if lower.contains("@allow-proj-all") { return }
    let kws = [
        "м „мІҙ н”„лЎңм қнҠё",
        "лӘЁл“  н”„лЎңм қнҠё",
        "н”„лЎңм қнҠё м „л¶Җ",
        "н”„лЎңм қнҠё лӘ©лЎқ",
        "н”„лЎңм қнҠё лҰ¬мҠӨнҠё",
        "н”„лЎңм қнҠё м •лҰ¬",
        "н”„лЎңм қнҠё м„Өкі„",
        "н”„лЎңм қнҠё лӢӨмӢң",
        "all projects",
        "every project",
        "project list"
    ]
    for k in kws {
        if lower.contains(k) {
            println("[H-PROJ-ALL] SSOT: shared/config/projects.json вҖ” projects_list.hexa table auto-dump")
            let cmd = HEXA + " run " + HARNESS + "/projects_list.hexa table 2>&1"
            let out = to_string(exec(cmd)).trim()  // @allow-bare-exec
            if out.len() > 0 { println(out) }
            return
        }
    }
}

// H-NOHOOK / AG10 вҖ” л°ңнҷ”м—җ hook/skill/MCP-UI/settings UI нӮӨмӣҢл“ң к°җм§Җ мӢң мӮ¬м „ м°ЁлӢЁ
// м •мұ…: Claude Code harness-UI л Ҳмқҙм–ҙ (hooks/skills/settings.json-hooks/MCP мҠ№мқё UI/update-config) мӮ¬мҡ©В·мһ‘м„ұ кёҲм§Җ.
//       лӘЁл“  мһҗлҸҷ к°•м ңлҠ” hexa-only raw к·ңм№ҷ 2мёөл§Ң вҖ” (1) $NEXUS/rules/airgenome.json AG* (2) $NEXUS/tool/enforcement_registry.json H-* + prompt_scan.hexa/pre_tool_guard.hexa/lint.hexa кө¬нҳ„.
// мҡ°нҡҢ: NEXUS_HOOK_OK=1 env лҳҗлҠ” кІҪлЎң/н…ҚмҠӨнҠём—җ '@allow-hook' нҶ нҒ°.
// SSOT: $NEXUS/tool/enforcement_registry.json (rules[] .id=="H-NOHOOK"), $NEXUS/rules/airgenome.json (AG10)
fn check_no_hook_keyword(lower: str) {
    if env("NEXUS_HOOK_OK") == "1" { return }
    if lower.contains("@allow-hook") { return }
    let kws = [
        "нӣ… ",
        " нӣ…",
        "нӣ…мқ„",
        "нӣ…м—җ",
        "нӣ…мңјлЎң",
        "нӣ… мӢңмҠӨн…ң",
        "нӣ… л§Ң",
        "нӣ… м¶”к°Җ",
        "нӣ… мғқм„ұ",
        " hook ",
        " hookмқ„",
        " hookмңјлЎң",
        "hook м¶”к°Җ",
        "hook мғқм„ұ",
        "claude code cli hook",
        "settings.json hooks",
        "settings hooks",
        "pre-commit hook",
        "post-commit hook",
        "pretooluse",
        "posttooluse",
        "userpromptsubmit",
        "stop hook",
        "precompact hook",
        "core.hookspath",
        "skill мһ‘м„ұ",
        "skill л§Ң",
        "skill мғқм„ұ",
        "skillмқ„",
        "skill м¶”к°Җ",
        ".claude/skills",
        "claude code skill",
        "update-config",
        "/loop skill",
        "mcp мҠ№мқё",
        "mcp н”„лЎ¬н”„нҠё",
        "mcp approval",
        "enabledmcpjsonservers",
        "enableallprojectmcpservers",
        "mcp мһҗлҸҷмҠ№мқё",
        "mcp мһҗлҸҷ мҠ№мқё",
        "claude.md мһ‘м„ұ",
        "claude.md л§Ң",
        "claude.md мғқм„ұ",
        "claude.md м¶”к°Җ",
        "claude.md нҺём§‘",
        "claude.md мҲҳм •",
        "claude.md м—…лҚ°мқҙнҠё",
        "claude.md м—җ м¶”к°Җ",
        "claude.mdм—җ м¶”к°Җ",
        "/init",
        "claude code init"
    ]
    for k in kws {
        if lower.contains(k) {
            println("[H-NOHOOK/AG10] hook/skill/MCP-UI/settings/CLAUDE.md/init л°ңнҷ” к°җм§Җ вҖ” Claude Code harness UI (hooks/skills/settings.json-hooks/MCP мҠ№мқё UI/update-config/CLAUDE.md мһ‘м„ұ/init) кёҲм§Җ. hexa-only raw к·ңм№ҷ 2мёөмңјлЎңл§Ң н•ҙкІ°: (1) $NEXUS/rules/airgenome.json AG* нҺём§‘ (2) $NEXUS/tool/enforcement_registry.json H-* + prompt_scan.hexa/pre_tool_guard.hexa/lint.hexa нҷ•мһҘ. CLAUDE.md лҠ” м •мұ… мЈјмһ… кёҲм§Җ вҖ” AG*/H-* JSON л§Ң. к°•м ң мЎ°нҡҢ: jq '.rules[] | select(.id==\"H-NOHOOK\")' $NEXUS/tool/enforcement_registry.json | мҡ°нҡҢ: NEXUS_HOOK_OK=1")
            return
        }
    }
}

fn main() {
    // argv м •к·ңнҷ” вҖ” Mac/Linux-stage1 prefix нҺём°Ё нқЎмҲҳ (shared/blowup/lib/argv.hexa.inc м°ёмЎ°).
    let _raw_argv = args()
    let mut _script_idx: i64 = -1
    let mut _scan_i: i64 = 0
    while _scan_i < _raw_argv.len() {
        if to_string(_raw_argv[_scan_i]).ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let _user_start = if _script_idx >= 0 { _script_idx + 1 } else {
        if _raw_argv.len() >= 3 && (to_string(_raw_argv[1]) == "run" || to_string(_raw_argv[1]) == "eval") { 3 } else { 2 }
    }
    let _script_token = if _script_idx >= 0 { _raw_argv[_script_idx] } else { "" }
    let mut argv = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if argv.len() < 3 { return }
    let user_text = argv[2]
    let lower = user_text.trim().to_lower()
    if lower.len() == 0 { return }

    // H-ERR-DRAIN вҖ” errors.jsonl open м№ҙмҡҙнҠё мһ„кі„м№ҳ мҙҲкіј мӢң drain кІҪкі 
    // 30s TTL: drain мғҒнғңлҠ” Claude к°Җ мӢӨм ң fix мһ‘м—… н•ҙм•ј ліҖн•Ё вҶ’ 30s лӮҙ лҸҷмқј кІ°кіј.
    if env("NEXUS_DRAIN_OK") != "1" && is_fresh("drain", 30) == false {
        let drain_cmd = HEXA + " run " + HARNESS + "/errors.hexa drain_check 10 2>&1"
        let drain_out = to_string(exec(drain_cmd)).trim()  // @allow-bare-exec
        if drain_out.len() > 0 { println(drain_out) }
        mark_fresh("drain")
    }

    // H-GIT-FRESH вҖ” 30л¶„ stale мӢң fetch + origin drift alert (м„ём…ҳ к°„ commit мӨ‘ліө л°©м§Җ)
    // 60s TTL: лӮҙл¶Җм ҒмңјлЎң мқҙлҜё 30л¶„ stale throttle мһҲмқҢ вҶ’ hexa startup л§Ң м Ҳк°җ.
    if is_fresh("git_fresh", 60) == false {
        let gf_cmd = HEXA + " run " + HARNESS + "/git_fresh.hexa check 2>&1"
        let gf_out = to_string(exec(gf_cmd)).trim()  // @allow-bare-exec
        if gf_out.len() > 0 { println(gf_out) }
        mark_fresh("git_fresh")
    }

    // H-LOOP-REPORT вҖ” SKILL (/loop) вҶ’ HARNESS к°•м ң м§‘н–ү.
    //   м§Ғм „ loop мӮ¬мқҙнҒҙмқҙ NEXT_AFTER лҘј emit н–ҲлҠ”лҚ° Claude ліҙкі м—җ лҜёл°ҳмҳҒ мӢң stderr WARN + stdout к°•м ң м§ҖмӢң.
    //   bash мҠӨнҒ¬лҰҪнҠёлқј hexa startup м—ҶмқҢ вҶ’ мәҗмӢң мғқлһө, мӣҗліё мң м§Җ.
    let lr_cmd = "bash " + HARNESS + "/loop_report verify 2>&1"
    let lr_out = to_string(exec(lr_cmd)).trim()  // @allow-bare-exec
    if lr_out.len() > 0 { println(lr_out) }

    // H-SESSION-REGISTRY вҖ” м„ём…ҳ manifest к°ұмӢ  + лӢӨлҘё нҷңм„ұ м„ём…ҳ л…ём¶ң
    // 30s TTL: м„ём…ҳ heartbeat мқҖ 30s мқҙлӮҙ мӨ‘ліөн•ҙлҸ„ л¬ҙмқҳлҜё, peers лӘ©лЎқлҸ„ 30s м•Ҳм •.
    if is_fresh("session_reg", 30) == false {
        exec(HEXA + " run " + HARNESS + "/session_registry.hexa register nexus harness prompt_in >/dev/null 2>&1")  // @allow-bare-exec
        let peers_cmd = HEXA + " run " + HARNESS + "/session_registry.hexa peers 2>&1 1>/dev/null"
        let peers_out = to_string(exec(peers_cmd)).trim()  // @allow-bare-exec
        if peers_out.len() > 0 { println(peers_out) }
        mark_fresh("session_reg")
    }

    // H-BROADCAST вҖ” мөңк·ј 5л¶„ shared/ ліҖкІҪ tail (cross-project к°ҖмӢңнҷ”)
    // 20s TTL: 5л¶„ мңҲлҸ„ tail мқҙлқј 20s кІ№м№Ё н—Ҳмҡ©н•ҙлҸ„ лҶ“м№  мқҙлІӨнҠё кұ°мқҳ м—ҶмқҢ.
    if is_fresh("broadcast", 20) == false {
        let bc_cmd = HEXA + " run " + HARNESS + "/broadcast.hexa tail 300 2>&1"
        let bc_out = to_string(exec(bc_cmd)).trim()  // @allow-bare-exec
        if bc_out.len() > 0 { println(bc_out) }
        mark_fresh("broadcast")
    }

    // H-SECURITY вҖ” passive secret/path мҠӨмә” (мӢӨнҢЁ л¬ҙмӢң, ліёмІҙ мҳҒн–Ҙ X)
    // мәҗмӢң мғқлһө: л§Ө prompt лӮҙмҡ©мқҙ лӢӨлҘҙлҜҖлЎң idempotent м•„лӢҳ.
    let sec_text = user_text.replace("\"", "\\\"")
    exec(HEXA + " run " + HARNESS + "/security_scan.hexa prompt \"" + sec_text + "\" 2>/dev/null")  // @allow-bare-exec

    // H-PROJ-ALL нһҢнҠё (info, л№„лё”лЎңнӮ№, 1нҡҢл§Ң)
    check_proj_all(lower)

    // H-NOHOOK нӮӨмӣҢл“ң к°җм§Җ (info, pre_tool_guard к°Җ мӢӨм ң м°ЁлӢЁ лӢҙлӢ№)
    check_no_hook_keyword(lower)

    let cmds = load_cmds_from_ssot()
    if cmds.len() == 0 { return }  // SSOT лЎңл“ң мӢӨнҢЁ мӢң silent (jq лҲ„лқҪ л“ұ)

    let mut matched = ""
    let mut matched_kw = ""
    for cmd in cmds {
        let kws = cmd[1].split("|")
        for kw in kws {
            if lower.contains(kw) {
                matched = cmd[0]
                matched_kw = kw
                break
            }
        }
        if matched.len() > 0 { break }
    }

    if matched == "" { return }

    // seed м¶”м¶ң (нӮӨмӣҢл“ң м ңкұ°)
    let mut seed = ""
    let parts = user_text.split(matched_kw)
    let mut s = ""
    for p in parts {
        let tr = p.trim()
        if tr.len() > 0 {
            if s.len() > 0 { s = s + " " }
            s = s + tr
        }
    }
    seed = s

    // м¶ңл Ҙ вҖ” Claudeм—җкІҢ нһҢнҠё м „лӢ¬
    let mut msg = "[CMD] " + matched
    if seed.len() > 0 { msg = msg + " | seed='" + seed + "'" }
    msg = msg + " | SSOT: shared/config/commands.json | gate: shared/tool/cmd_gate.hexa"

    // cmd_gate мӮ¬м „ мӢӨн–ү (seed н’Ҳм§Ҳ нһҢнҠё)
    if matched == "smash" || matched == "free_dfs" {
        let cmd_name = matched
        let gate_cmd = HEXA + " run " + HARNESS + "/cmd_gate.hexa " + cmd_name + " '" + seed.replace("'", "") + "' 2>&1"
        let gate_out = to_string(exec(gate_cmd)).trim()  // @allow-bare-exec
        if gate_out.contains("REJECT") {
            msg = msg + "\n[GATE HINT] " + gate_out
        }
    }

    println(msg)

    // R35 H-MINPATH: 'go'/'к°Җмһҗ'/'м§„н–ү' к°җм§Җ мӢң мөңмҶҢ кІҪлЎң SSOT м Ғмҡ© hint
    if matched == "go" || matched == "keep" {
        println("[H-MINPATH] мөңмҶҢ кІҪлЎң SSOT м Ғмҡ© вҖ” м§Ғм „ мҳөм…ҳ мӨ‘ decision_order(blocker=0 вҶ’ stepsвҶ‘min вҶ’ locвҶ‘min вҶ’ мІ«лІҲм§ё) мһҗлҸҷ н”Ҫ + мҰүмӢң мӢӨн–ү. м¶”к°Җ нҷ•мқё/мһ¬м§Ҳл¬ё кёҲм§Җ. SSOT: shared/tool/minimal_path.json")
    }
}

main()
