// prompt_scan.hexa — 사용자 프롬프트 명령 키워드 감지 (UserPromptSubmit 훅 대체)
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
// 역할: cmd-dispatch + go-parallel + nexus-prompt-scan 로직 통합
// usage: hexa run shared/tool/prompt_scan.hexa "<user_text>"
// output: 키워드 매칭 시 systemMessage/알림 stdout. 미매칭이면 무출력.

let HOME = env("HOME")
let HEXA = HOME + "/Dev/nexus/bin/hexa"
let HARNESS = HOME + "/Dev/nexus/harness"
let CMDS_JSON = HOME + "/Dev/nexus/config/commands.json"

// ─── freshness 캐시 — idempotent 하위 check 반복 skip ──────────────
// 각 sub-module 호출 전에 fresh 확인 → TTL 내면 skip.
// 무효화는 각 모듈 자체의 내부 상태 변경 시 자연 만료 (파일 삭제 or TTL 경과).
// 매 prompt 당 ~1-2초 절감 (7개 중 3개가 200-400ms hexa startup).
// OPT-P8-4: file_exists() guard before exec (skip shell when file absent)
fn is_fresh(tag: str, ttl_sec: i64) -> bool {
    let path = "/tmp/prompt_scan_fresh_" + tag
    if file_exists(path) == false { return false }
    let age = to_string(exec("echo $(( $(date +%s) - $(stat -f%m " + path + " 2>/dev/null) ))")).trim()  // @allow-bare-exec
    if age == "" { return false }
    let mut age_i = 999
    try { age_i = to_int(age) } catch e {}
    if age_i < ttl_sec { return true }
    return false
}

// OPT-P8-3: exec("touch") → write_file() builtin (subprocess eliminated)
fn mark_fresh(tag: str) {
    let path = "/tmp/prompt_scan_fresh_" + tag
    try { write_file(path, "") } catch e {}
}

// commands.json SSOT 동적 로드 — 공용 + project_specific[git basename] 머지.
// 하드코딩 미러 금지 (R36 후보, drift 0).
fn load_cmds_from_ssot() {
    let mut cmds = []

    // 공용 commands
    let q1 = "/usr/bin/jq -r '.commands | to_entries[] | \"\\(.key)\\t\\(.value.keywords | join(\"|\"))\"' '" + CMDS_JSON + "' 2>/dev/null"
    let out1 = to_string(exec(q1)).trim()  // @allow-bare-exec
    for line in out1.split("\n") {
        if line.len() == 0 { continue }
        let parts = line.split("\t")
        if parts.len() >= 2 {
            cmds = cmds.push([parts[0], parts[1]])
        }
    }

    // 프로젝트별 (git basename 기반)
    let proj = to_string(exec("basename \"$(git rev-parse --show-toplevel 2>/dev/null)\" 2>/dev/null")).trim()  // @allow-bare-exec
    if proj.len() > 0 {
        let q2 = "/usr/bin/jq -r --arg p '" + proj + "' '.project_specific[$p] // {} | to_entries[] | \"\\(.key)\\t\\(.value.keywords | join(\"|\"))\"' '" + CMDS_JSON + "' 2>/dev/null"
        let out2 = to_string(exec(q2)).trim()  // @allow-bare-exec
        for line in out2.split("\n") {
            if line.len() == 0 { continue }
            let parts = line.split("\t")
            if parts.len() >= 2 {
                cmds = cmds.push([parts[0], parts[1]])
            }
        }
    }

    return cmds
}

// H-PROJ-ALL — 전체/프로젝트 목록/정리/설계 맥락 발화 시 projects.json 데이터 자동 주입
// 코드 수준 강제: hint 만 주지 않고 projects_list.hexa table 출력을 stdout 에 실제 dump
// 우회: env NEXUS_PROJ_ALL_OK=1 또는 '@allow-proj-all' 토큰
// SSOT: shared/config/projects.json (schema 4) + shared/tool/projects_list.hexa
fn check_proj_all(lower: str) {
    if env("NEXUS_PROJ_ALL_OK") == "1" { return }
    if lower.contains("@allow-proj-all") { return }
    let kws = [
        "전체 프로젝트",
        "모든 프로젝트",
        "프로젝트 전부",
        "프로젝트 목록",
        "프로젝트 리스트",
        "프로젝트 정리",
        "프로젝트 설계",
        "프로젝트 다시",
        "all projects",
        "every project",
        "project list"
    ]
    for k in kws {
        if lower.contains(k) {
            println("[H-PROJ-ALL] SSOT: shared/config/projects.json — projects_list.hexa table auto-dump")
            let cmd = HEXA + " run " + HARNESS + "/projects_list.hexa table 2>&1"
            let out = to_string(exec(cmd)).trim()  // @allow-bare-exec
            if out.len() > 0 { println(out) }
            return
        }
    }
}

// H-NOHOOK / AG10 — 발화에 hook/skill/MCP-UI/settings UI 키워드 감지 시 사전 차단
// 정책: Claude Code harness-UI 레이어 (hooks/skills/settings.json-hooks/MCP 승인 UI/update-config) 사용·작성 금지.
//       모든 자동 강제는 hexa-only raw 규칙 2층만 — (1) $NEXUS/rules/airgenome.json AG* (2) $NEXUS/tool/enforcement_registry.json H-* + prompt_scan.hexa/pre_tool_guard.hexa/lint.hexa 구현.
// 우회: NEXUS_HOOK_OK=1 env 또는 경로/텍스트에 '@allow-hook' 토큰.
// SSOT: $NEXUS/tool/enforcement_registry.json (rules[] .id=="H-NOHOOK"), $NEXUS/rules/airgenome.json (AG10)
fn check_no_hook_keyword(lower: str) {
    if env("NEXUS_HOOK_OK") == "1" { return }
    if lower.contains("@allow-hook") { return }
    let kws = [
        "훅 ",
        " 훅",
        "훅을",
        "훅에",
        "훅으로",
        "훅 시스템",
        "훅 만",
        "훅 추가",
        "훅 생성",
        " hook ",
        " hook을",
        " hook으로",
        "hook 추가",
        "hook 생성",
        "claude code cli hook",
        "settings.json hooks",
        "settings hooks",
        "pre-commit hook",
        "post-commit hook",
        "pretooluse",
        "posttooluse",
        "userpromptsubmit",
        "stop hook",
        "precompact hook",
        "core.hookspath",
        "skill 작성",
        "skill 만",
        "skill 생성",
        "skill을",
        "skill 추가",
        ".claude/skills",
        "claude code skill",
        "update-config",
        "/loop skill",
        "mcp 승인",
        "mcp 프롬프트",
        "mcp approval",
        "enabledmcpjsonservers",
        "enableallprojectmcpservers",
        "mcp 자동승인",
        "mcp 자동 승인",
        "claude.md 작성",
        "claude.md 만",
        "claude.md 생성",
        "claude.md 추가",
        "claude.md 편집",
        "claude.md 수정",
        "claude.md 업데이트",
        "claude.md 에 추가",
        "claude.md에 추가",
        "/init",
        "claude code init"
    ]
    for k in kws {
        if lower.contains(k) {
            println("[H-NOHOOK/AG10] hook/skill/MCP-UI/settings/CLAUDE.md/init 발화 감지 — Claude Code harness UI (hooks/skills/settings.json-hooks/MCP 승인 UI/update-config/CLAUDE.md 작성/init) 금지. hexa-only raw 규칙 2층으로만 해결: (1) $NEXUS/rules/airgenome.json AG* 편집 (2) $NEXUS/tool/enforcement_registry.json H-* + prompt_scan.hexa/pre_tool_guard.hexa/lint.hexa 확장. CLAUDE.md 는 정책 주입 금지 — AG*/H-* JSON 만. 강제 조회: jq '.rules[] | select(.id==\"H-NOHOOK\")' $NEXUS/tool/enforcement_registry.json | 우회: NEXUS_HOOK_OK=1")
            return
        }
    }
}

fn main() {
    // argv 정규화 — Mac/Linux-stage1 prefix 편차 흡수 (shared/blowup/lib/argv.hexa.inc 참조).
    let _raw_argv = args()
    let mut _script_idx: i64 = -1
    let mut _scan_i: i64 = 0
    while _scan_i < _raw_argv.len() {
        if to_string(_raw_argv[_scan_i]).ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let _user_start = if _script_idx >= 0 { _script_idx + 1 } else {
        if _raw_argv.len() >= 3 && (to_string(_raw_argv[1]) == "run" || to_string(_raw_argv[1]) == "eval") { 3 } else { 2 }
    }
    let _script_token = if _script_idx >= 0 { _raw_argv[_script_idx] } else { "" }
    let mut argv = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if argv.len() < 3 { return }
    let user_text = argv[2]
    let lower = user_text.trim().to_lower()
    if lower.len() == 0 { return }

    // AG10 SESSION BANNER — ai-native English gate, emitted at the TOP of every prompt-scan output.
    // Replaces deleted CLAUDE.md session-start context. Cache TTL 1800s — roughly once per active session/30m-idle resume.
    // SSOT: $NEXUS/rules/airgenome.json (AG10).
    if is_fresh("ag10_banner", 1800) == false {
        println("[AG10] hexa-only harness gate — DO NOT create CLAUDE.md, Claude Code hooks, or .claude/skills/ files. All automation and policy enforcement lives in raw rules only: edit $NEXUS/rules/airgenome.json (AG*) and $NEXUS/tool/enforcement_registry.json (H-*); implement handlers in prompt_scan.hexa / pre_tool_guard.hexa / lint.hexa. Bypass: NEXUS_HOOK_OK=1 (explicit user approval only).")
        mark_fresh("ag10_banner")
    }

    // H-ERR-DRAIN — errors.jsonl open 카운트 임계치 초과 시 drain 경고
    // 30s TTL: drain 상태는 Claude 가 실제 fix 작업 해야 변함 → 30s 내 동일 결과.
    if env("NEXUS_DRAIN_OK") != "1" && is_fresh("drain", 30) == false {
        let drain_cmd = HEXA + " run " + HARNESS + "/errors.hexa drain_check 10 2>&1"
        let drain_out = to_string(exec(drain_cmd)).trim()  // @allow-bare-exec
        if drain_out.len() > 0 { println(drain_out) }
        mark_fresh("drain")
    }

    // H-GIT-FRESH — 30분 stale 시 fetch + origin drift alert (세션 간 commit 중복 방지)
    // 60s TTL: 내부적으로 이미 30분 stale throttle 있음 → hexa startup 만 절감.
    if is_fresh("git_fresh", 60) == false {
        let gf_cmd = HEXA + " run " + HARNESS + "/git_fresh.hexa check 2>&1"
        let gf_out = to_string(exec(gf_cmd)).trim()  // @allow-bare-exec
        if gf_out.len() > 0 { println(gf_out) }
        mark_fresh("git_fresh")
    }

    // H-LOOP-REPORT — SKILL (/loop) → HARNESS 강제 집행.
    //   직전 loop 사이클이 NEXT_AFTER 를 emit 했는데 Claude 보고에 미반영 시 stderr WARN + stdout 강제 지시.
    //   bash 스크립트라 hexa startup 없음 → 캐시 생략, 원본 유지.
    let lr_cmd = "bash " + HARNESS + "/loop_report verify 2>&1"
    let lr_out = to_string(exec(lr_cmd)).trim()  // @allow-bare-exec
    if lr_out.len() > 0 { println(lr_out) }

    // H-SESSION-REGISTRY — 세션 manifest 갱신 + 다른 활성 세션 노출
    // 30s TTL: 세션 heartbeat 은 30s 이내 중복해도 무의미, peers 목록도 30s 안정.
    if is_fresh("session_reg", 30) == false {
        exec(HEXA + " run " + HARNESS + "/session_registry.hexa register nexus harness prompt_in >/dev/null 2>&1")  // @allow-bare-exec
        let peers_cmd = HEXA + " run " + HARNESS + "/session_registry.hexa peers 2>&1 1>/dev/null"
        let peers_out = to_string(exec(peers_cmd)).trim()  // @allow-bare-exec
        if peers_out.len() > 0 { println(peers_out) }
        mark_fresh("session_reg")
    }

    // H-BROADCAST — 최근 5분 shared/ 변경 tail (cross-project 가시화)
    // 20s TTL: 5분 윈도 tail 이라 20s 겹침 허용해도 놓칠 이벤트 거의 없음.
    if is_fresh("broadcast", 20) == false {
        let bc_cmd = HEXA + " run " + HARNESS + "/broadcast.hexa tail 300 2>&1"
        let bc_out = to_string(exec(bc_cmd)).trim()  // @allow-bare-exec
        if bc_out.len() > 0 { println(bc_out) }
        mark_fresh("broadcast")
    }

    // H-SECURITY — passive secret/path 스캔 (실패 무시, 본체 영향 X)
    // 캐시 생략: 매 prompt 내용이 다르므로 idempotent 아님.
    let sec_text = user_text.replace("\"", "\\\"")
    exec(HEXA + " run " + HARNESS + "/security_scan.hexa prompt \"" + sec_text + "\" 2>/dev/null")  // @allow-bare-exec

    // H-PROJ-ALL 힌트 (info, 비블로킹, 1회만)
    check_proj_all(lower)

    // H-NOHOOK 키워드 감지 (info, pre_tool_guard 가 실제 차단 담당)
    check_no_hook_keyword(lower)

    let cmds = load_cmds_from_ssot()
    if cmds.len() == 0 { return }  // SSOT 로드 실패 시 silent (jq 누락 등)

    let mut matched = ""
    let mut matched_kw = ""
    for cmd in cmds {
        let kws = cmd[1].split("|")
        for kw in kws {
            if lower.contains(kw) {
                matched = cmd[0]
                matched_kw = kw
                break
            }
        }
        if matched.len() > 0 { break }
    }

    if matched == "" { return }

    // seed 추출 (키워드 제거)
    let mut seed = ""
    let parts = user_text.split(matched_kw)
    let mut s = ""
    for p in parts {
        let tr = p.trim()
        if tr.len() > 0 {
            if s.len() > 0 { s = s + " " }
            s = s + tr
        }
    }
    seed = s

    // 출력 — Claude에게 힌트 전달
    let mut msg = "[CMD] " + matched
    if seed.len() > 0 { msg = msg + " | seed='" + seed + "'" }
    msg = msg + " | SSOT: shared/config/commands.json | gate: shared/tool/cmd_gate.hexa"

    // cmd_gate 사전 실행 (seed 품질 힌트)
    if matched == "smash" || matched == "free_dfs" {
        let cmd_name = matched
        let gate_cmd = HEXA + " run " + HARNESS + "/cmd_gate.hexa " + cmd_name + " '" + seed.replace("'", "") + "' 2>&1"
        let gate_out = to_string(exec(gate_cmd)).trim()  // @allow-bare-exec
        if gate_out.contains("REJECT") {
            msg = msg + "\n[GATE HINT] " + gate_out
        }
    }

    println(msg)

    // R35 H-MINPATH: 'go'/'가자'/'진행' 감지 시 최소 경로 SSOT 적용 hint
    if matched == "go" || matched == "keep" {
        println("[H-MINPATH] 최소 경로 SSOT 적용 — 직전 옵션 중 decision_order(blocker=0 → steps↑min → loc↑min → 첫번째) 자동 픽 + 즉시 실행. 추가 확인/재질문 금지. SSOT: shared/tool/minimal_path.json")
    }
}

main()
