// rules_loader.hexa — GOV-P8-1 rules binary index + fast lookup
// @allow-bare-exec
// @no-sandbox
//
// SSOT: shared/rules/{common,nexus,anima,n6-architecture,hexa-lang,void,airgenome,papers,contact}.json
// Binary index: shared/rules/.rules_index.jsonl  (flat {rule_id, project, severity, layer, pattern})
//
// Usage:
//   hexa run rules_loader.hexa build           — rebuild .rules_index.jsonl
//   hexa run rules_loader.hexa lookup <rule_id>  — O(1)-ish lookup (grep)
//   hexa run rules_loader.hexa count           — 엔트리 수
//   hexa run rules_loader.hexa list <project>  — 프로젝트 룰 id 나열
//
// 규약: 성공 조용 (count/lookup 은 stdout 1 line), 실패 stderr.

let HOME = env("HOME")
let NEXUS_ROOT = HOME + "/core/nexus"
let RULES_DIR = NEXUS_ROOT + "/rules"
let INDEX = RULES_DIR + "/.rules_index.jsonl"

// 등록된 project 파일 (common 은 all-project, 나머지는 project-local)
let PROJECT_FILES = [
    "common.json",
    "nexus.json",
    "anima.json",
    "n6-architecture.json",
    "hexa-lang.json",
    "void.json",
    "airgenome.json",
    "papers.json",
    "contact.json",
    "convergence_ops.json"
]

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    return to_int(first)
}

fn now_iso() -> string {
    return _str(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()  // @allow-bare-exec
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", " ")
    r = r.replace("\r", " ")
    r = r.replace("\t", " ")
    return r
}

// 한 룰의 level("🔴"/"⛔"/...) 을 severity(block|error|warn|info) 로 변환.
// level 기호는 시각적, severity 는 하네스 분류 키.
fn level_to_severity(level: string) -> string {
    if level == "" { return "info" }
    // 가장 자주 쓰이는 패턴
    if level.index_of("⛔") >= 0 { return "block" }
    if level.index_of("🔴") >= 0 { return "error" }
    if level.index_of("🟡") >= 0 { return "warn" }
    if level.index_of("🟢") >= 0 { return "info" }
    if level.index_of("★") >= 0 { return "info" }
    return "info"
}

// pattern 은 rule 텍스트에서 첫 ~60byte 발췌 (인덱스 요약용).
// 한글 등 multibyte 중간 cut 은 json 파싱은 OK 이지만 보기 위해 공백에서 자름.
fn summarize(rule_text: string) -> string {
    let t = rule_text.trim()
    if t == "" { return "" }
    let n = len(t)
    if n <= 60 { return t }
    // 60~80 byte 구간에서 마지막 공백 찾아 끊기
    let mut cut: i64 = 60
    let mut i: i64 = 60
    let upper = if n < 90 { n } else { 90 }
    while i < upper {
        if t.substring(i, i + 1) == " " { cut = i; break }
        i = i + 1
    }
    return t.substring(0, cut)
}

// {project}.json 에서 rules 배열 추출 후 index 라인들 반환 (jq 사용).
// layer:
//   common.json        → "common"
//   convergence_ops.json → "ops"
//   나머지              → project 이름 (파일명 stem)
fn index_lines_from_file(filename: string) -> string {
    let full = RULES_DIR + "/" + filename
    if !file_exists(full) { return "" }

    // 레이어/프로젝트 추출
    let mut project = filename.replace(".json", "")
    let mut layer = project
    if project == "common" { layer = "common" }
    if project == "convergence_ops" { layer = "ops" }

    // jq 로 각 rule → {id, level, rule, applies_to} TSV 변환.
    // rule 텍스트 내부 tab/newline 은 pre-strip.
    let cmd = "/usr/bin/jq -r '.rules[]? | [.id // \"\", .level // \"\", " +
              "((.rule // \"\") | gsub(\"[\\n\\r\\t]\"; \" \")), " +
              "(.applies_to // \"\")] | @tsv' '" + full + "' 2>/dev/null"
    let raw = _str(exec(cmd))  // @allow-bare-exec
    if raw.trim() == "" { return "" }

    let mut out = ""
    let ts = now_iso()
    for ln in raw.split("\n") {
        let line = _str(ln)
        if line == "" { continue }
        let parts = line.split("\t")
        if parts.len() < 3 { continue }
        let rid = _str(parts[0]).trim()
        if rid == "" { continue }
        let level = _str(parts[1]).trim()
        let rule_text = _str(parts[2]).trim()
        let mut applies = ""
        if parts.len() > 3 { applies = _str(parts[3]).trim() }
        if applies == "" { applies = "project" }
        let sev = level_to_severity(level)
        let pat = summarize(rule_text)
        let row = "{\"id\":\"" + json_escape(rid) + "\"," +
                  "\"project\":\"" + json_escape(project) + "\"," +
                  "\"layer\":\"" + json_escape(layer) + "\"," +
                  "\"severity\":\"" + sev + "\"," +
                  "\"level\":\"" + json_escape(level) + "\"," +
                  "\"applies_to\":\"" + json_escape(applies) + "\"," +
                  "\"pattern\":\"" + json_escape(pat) + "\"," +
                  "\"src\":\"" + filename + "\"," +
                  "\"ts\":\"" + ts + "\"}"
        out = out + row + "\n"
    }
    return out
}

fn cmd_build() {
    let mut accum = ""
    let mut file_count: i64 = 0
    let mut rule_count: i64 = 0
    for f in PROJECT_FILES {
        let fname = _str(f)
        let part = index_lines_from_file(fname)
        if part == "" { continue }
        file_count = file_count + 1
        for ln in part.split("\n") {
            if _str(ln).trim() != "" { rule_count = rule_count + 1 }
        }
        accum = accum + part
    }
    try { write_file(INDEX, accum) } catch e {
        eprintln("[rules_loader] write fail: " + INDEX)
        return
    }
    println("[rules_loader] built " + to_string(rule_count) + " rules from " +
            to_string(file_count) + " files → " + INDEX)
}

fn cmd_count() {
    if !file_exists(INDEX) {
        println("0")
        return
    }
    let out = _str(exec("grep -c '^{' '" + INDEX + "' 2>/dev/null")).trim()  // @allow-bare-exec
    println(to_string(_to_int0(out)))
}

fn cmd_lookup(argv: [string]) {
    if argv.len() < 4 {
        eprintln("usage: lookup <rule_id>")
        return
    }
    let rid = argv[3]
    if !file_exists(INDEX) {
        eprintln("[rules_loader] index missing — run: build")
        return
    }
    let cmd = "grep '\"id\":\"" + rid + "\"' '" + INDEX + "' 2>/dev/null | head -5"
    let out = _str(exec(cmd)).trim()  // @allow-bare-exec
    if out == "" {
        eprintln("[rules_loader] not found: " + rid)
        return
    }
    println(out)
}

fn cmd_list(argv: [string]) {
    if argv.len() < 4 {
        eprintln("usage: list <project>")
        return
    }
    let proj = argv[3]
    if !file_exists(INDEX) {
        eprintln("[rules_loader] index missing — run: build")
        return
    }
    let cmd = "grep '\"project\":\"" + proj + "\"' '" + INDEX +
              "' 2>/dev/null | /usr/bin/jq -r '.id + \"\\t\" + .severity + \"\\t\" + .pattern' 2>/dev/null"
    let out = _str(exec(cmd)).trim()  // @allow-bare-exec
    if out == "" {
        eprintln("[rules_loader] no rules for project: " + proj)
        return
    }
    println(out)
}

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    if argv.len() < 3 {
        eprintln("usage: rules_loader.hexa <build|count|lookup|list> [args]")
        return
    }
    let cmd = argv[2]
    if cmd == "build" { cmd_build() }
    else if cmd == "count" { cmd_count() }
    else if cmd == "lookup" { cmd_lookup(argv) }
    else if cmd == "list" { cmd_list(argv) }
    else { eprintln("unknown cmd: " + cmd) }
}
