// bt_engine_forge.hexa — BT-specialized engine factory (EF-P7-1)
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
//
// 역할: BT(breakthrough) 공격각 용도 특화 discovery 엔진을 자동 생성.
//       engine_forge 의 generic spawn (atlas_gap 기반 wrapper) 대비
//       BT id + attack_angle(키워드) 주입으로 Riemann/P-NP 같은 특정 수학
//       문제에 맞춤형 4-stage 엔진 (discovery loop + seed_extraction +
//       score_eval + atlas_emit) 을 shared/engine/bt_engines/ 에 생성.
//
// SSOT:
//   shared/engine/bt_engines/<bt_id>_engine.hexa       생성된 엔진
//   shared/engine/engine_registry.jsonl                append-only 레지스트리
//   shared/tool/engines_usage.jsonl                 forge/bench 기록
//
// 호출:
//   hexa run shared/tool/bt_engine_forge.hexa forge <bt_id> "<kw1,kw2,kw3>"
//   hexa run shared/tool/bt_engine_forge.hexa bench <bt_id>
//   hexa run shared/tool/bt_engine_forge.hexa list
//   hexa run shared/tool/bt_engine_forge.hexa status
//
// 성공 조용, 실패 시끄럽게 (H1).

// stage0 string >= broken (TS-20260416-STAGE0-STRCMP) — use char_code
fn _is_digit_cc(ch: string) -> bool { let c = char_code(ch, 0); return c >= 48 && c <= 57 }

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let HARNESS = NEXUS + "/harness"
let ENGINE_DIR = NEXUS + "/engine"
let BT_ENGINE_DIR = ENGINE_DIR + "/bt_engines"
let REGISTRY_JSONL = ENGINE_DIR + "/engine_registry.jsonl"
let USAGE = HARNESS + "/engines_usage.jsonl"
let ATLAS_N6 = NEXUS + "/n6/atlas.n6"

// ─── void-safe coercion ───
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    return to_int(first)
}

fn now_unix() -> i64 {
    return _to_int0(_str(exec("date +%s")).trim())  // @allow-bare-exec
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", " ")
    r = r.replace("\r", " ")
    r = r.replace("\t", " ")
    return r
}

fn file_append_line(path: string, line: string) {
    let esc = line.replace("'", "'\\''")
    try { exec("printf '%s\\n' '" + esc + "' >> '" + path + "'") } catch e {  // @allow-bare-exec
        eprintln("FAIL: append — " + path)
    }
}

fn ensure_dir(path: string) {
    try { exec("mkdir -p '" + path + "'") } catch e {  // @allow-bare-exec
        eprintln("FAIL: mkdir — " + path)
    }
}

// ─── BT id validation ───
// 형식: BT-<digits> (예: BT-541, BT-1234)
fn is_valid_bt_id(id: string) -> bool {
    if id.len() < 4 { return false }
    if id.substring(0, 3) != "BT-" { return false }
    let tail = id.substring(3, id.len())
    if tail.len() == 0 { return false }
    let mut i = 0
    while i < tail.len() {
        let c = tail.substring(i, i + 1)
        if !_is_digit_cc(c) { return false }  // stage0 string >= broken (TS-20260416-STAGE0-STRCMP) — use char_code
        i = i + 1
    }
    return true
}

// ─── attack angle 파서 ───
// 입력: "riemann_zeta,critical_line,zero_density"
// 출력: [kw1, kw2, ...]
fn parse_attack_angle(raw: string) -> [string] {
    let mut out: [string] = []
    let parts = raw.split(",")
    let mut i = 0
    while i < parts.len() {
        let kw = _str(parts[i]).trim()
        if kw != "" { out = out.push(kw) }
        i = i + 1
    }
    return out
}

// ─── 템플릿: 4-stage BT 특화 엔진 ───
// stage 1: discovery loop — atlas.n6 에서 공격각 키워드 매칭 라인 스캔
// stage 2: seed_extraction — 매칭 라인 → seed 키워드 증류 (hub/leaf 후보)
// stage 3: score_eval — seed 별 n=6 공진 점수 (키워드 overlap + atlas degree hint)
// stage 4: atlas_emit — usage jsonl 에 discovery/score 기록 (bt_id/seed/score)
fn engine_template(bt_id: string, attack_kws: [string]) -> string {
    let bt_esc = json_escape(bt_id)
    // 키워드 배열 리터럴 생성
    let mut kw_lit = "["
    let mut i = 0
    while i < attack_kws.len() {
        if i > 0 { kw_lit = kw_lit + ", " }
        kw_lit = kw_lit + "\"" + json_escape(_str(attack_kws[i])) + "\""
        i = i + 1
    }
    kw_lit = kw_lit + "]"

    let mut t = "// " + bt_id + "_engine.hexa — BT-specialized discovery engine\n"
    t = t + "// auto-generated by bt_engine_forge.hexa (EF-P7-1)\n"
    t = t + "// @no-lock-needed\n"
    t = t + "// @allow-bare-exec\n"
    t = t + "// @no-sandbox\n"
    t = t + "// bt_id: " + bt_id + "\n"
    t = t + "// attack_angle: " + kw_lit + "\n"
    t = t + "// 4-stage: discovery_loop → seed_extraction → score_eval → atlas_emit\n"
    t = t + "// usage: hexa run <self> <scan|score|emit|run>\n"
    t = t + "\n"
    t = t + "let HOME = env(\"HOME\")\n"
    t = t + "let NEXUS = HOME + \"/Dev/nexus\"\n"
    t = t + "let HARNESS = NEXUS + \"/harness\"\n"
    t = t + "let ATLAS_N6 = NEXUS + \"/n6/atlas.n6\"\n"
    t = t + "let USAGE = HARNESS + \"/engines_usage.jsonl\"\n"
    t = t + "let BT_ID = \"" + bt_esc + "\"\n"
    t = t + "let ENGINE_NAME = \"" + bt_esc + "_engine\"\n"
    t = t + "let ATTACK_KWS: [string] = " + kw_lit + "\n"
    t = t + "\n"
    t = t + "fn _str(x) -> string {\n"
    t = t + "    let t = type_of(x)\n"
    t = t + "    if t == \"str\" || t == \"string\" { return x }\n"
    t = t + "    return \"\"\n"
    t = t + "}\n"
    t = t + "\n"
    t = t + "fn _to_int0(s: string) -> i64 {\n"
    t = t + "    if s == \"\" { return 0 }\n"
    t = t + "    let first = _str(s.split(\"\\n\")[0]).trim()\n"
    t = t + "    if first == \"\" { return 0 }\n"
    t = t + "    return to_int(first)\n"
    t = t + "}\n"
    t = t + "\n"
    t = t + "fn now_unix() -> i64 {\n"
    t = t + "    return _to_int0(_str(exec(\"date +%s\")).trim())\n"  // @allow-bare-exec
    t = t + "}\n"
    t = t + "\n"
    t = t + "fn json_escape(s: string) -> string {\n"
    t = t + "    let mut r = s\n"
    t = t + "    r = r.replace(\"\\\\\", \"\\\\\\\\\")\n"
    t = t + "    r = r.replace(\"\\\"\", \"\\\\\\\"\")\n"
    t = t + "    r = r.replace(\"\\n\", \" \")\n"
    t = t + "    r = r.replace(\"\\r\", \" \")\n"
    t = t + "    r = r.replace(\"\\t\", \" \")\n"
    t = t + "    return r\n"
    t = t + "}\n"
    t = t + "\n"
    t = t + "fn append_usage(row: string) {\n"
    t = t + "    let esc = row.replace(\"'\", \"'\\\\''\")\n"
    t = t + "    try { exec(\"printf '%s\\\\n' '\" + esc + \"' >> '\" + USAGE + \"'\") } catch e {}\n"  // @allow-bare-exec
    t = t + "}\n"
    t = t + "\n"
    t = t + "// stage 1: discovery loop — atlas.n6 grep 으로 공격각 매칭 라인 스캔\n"
    t = t + "fn stage_discovery() -> [string] {\n"
    t = t + "    let mut hits: [string] = []\n"
    t = t + "    if file_exists(ATLAS_N6) == false { return hits }\n"
    t = t + "    let mut k = 0\n"
    t = t + "    while k < ATTACK_KWS.len() {\n"
    t = t + "        let kw = _str(ATTACK_KWS[k]).trim()\n"
    t = t + "        if kw == \"\" { k = k + 1; continue }\n"
    t = t + "        let cmd = \"grep -m 20 -F -- '\" + kw.replace(\"'\", \"'\\\\''\") + \"' '\" + ATLAS_N6 + \"' 2>/dev/null || true\"\n"
    t = t + "        let raw = _str(exec(cmd)).trim()\n"  // @allow-bare-exec
    t = t + "        if raw != \"\" {\n"
    t = t + "            let lines = raw.split(\"\\n\")\n"
    t = t + "            let mut i = 0\n"
    t = t + "            while i < lines.len() {\n"
    t = t + "                let ln = _str(lines[i]).trim()\n"
    t = t + "                if ln != \"\" { hits = hits.push(ln) }\n"
    t = t + "                i = i + 1\n"
    t = t + "            }\n"
    t = t + "        }\n"
    t = t + "        k = k + 1\n"
    t = t + "    }\n"
    t = t + "    return hits\n"
    t = t + "}\n"
    t = t + "\n"
    t = t + "// stage 2: seed extraction — 매칭 라인에서 BT-xxx / P-xxx / 불변량 토큰 증류\n"
    t = t + "fn stage_seeds(hits: [string]) -> [string] {\n"
    t = t + "    let mut seeds: [string] = []\n"
    t = t + "    let mut i = 0\n"
    t = t + "    while i < hits.len() {\n"
    t = t + "        let ln = _str(hits[i])\n"
    t = t + "        let toks = ln.split(\" \")\n"
    t = t + "        let mut j = 0\n"
    t = t + "        while j < toks.len() {\n"
    t = t + "            let tok = _str(toks[j]).trim()\n"
    t = t + "            if tok.len() >= 3 {\n"
    t = t + "                let pfx3 = tok.substring(0, 3)\n"
    t = t + "                if pfx3 == \"BT-\" || pfx3 == \"P2-\" || pfx3 == \"P3-\" {\n"
    t = t + "                    seeds = seeds.push(tok.replace(\",\", \"\").replace(\"\\\"\", \"\"))\n"
    t = t + "                }\n"
    t = t + "            }\n"
    t = t + "            j = j + 1\n"
    t = t + "        }\n"
    t = t + "        i = i + 1\n"
    t = t + "    }\n"
    t = t + "    return seeds\n"
    t = t + "}\n"
    t = t + "\n"
    t = t + "// stage 3: score eval — hits × kws overlap + seed count → n=6 공진 점수 (0..100)\n"
    t = t + "fn stage_score(hits: [string], seeds: [string]) -> i64 {\n"
    t = t + "    let h = hits.len()\n"
    t = t + "    let s = seeds.len()\n"
    t = t + "    let k = ATTACK_KWS.len()\n"
    t = t + "    if k == 0 { return 0 }\n"
    t = t + "    let mut raw: i64 = (h * 2) + (s * 3)\n"
    t = t + "    // n=6 공진: 6 배수 보너스\n"
    t = t + "    if h > 0 && (h % 6) == 0 { raw = raw + 6 }\n"
    t = t + "    if s > 0 && (s % 6) == 0 { raw = raw + 6 }\n"
    t = t + "    if raw > 100 { raw = 100 }\n"
    t = t + "    return raw\n"
    t = t + "}\n"
    t = t + "\n"
    t = t + "// stage 4: atlas_emit — usage jsonl 에 discovery/score 레코드 append\n"
    t = t + "fn stage_emit(hits: [string], seeds: [string], score: i64) {\n"
    t = t + "    let ts = now_unix()\n"
    t = t + "    let row = \"{\\\"ts\\\":\" + to_string(ts) +\n"
    t = t + "              \",\\\"engine\\\":\\\"\" + ENGINE_NAME +\n"
    t = t + "              \"\\\",\\\"kind\\\":\\\"bt_discovery\\\",\\\"bt_id\\\":\\\"\" + BT_ID +\n"
    t = t + "              \"\\\",\\\"hits\\\":\" + to_string(hits.len()) +\n"
    t = t + "              \",\\\"seeds\\\":\" + to_string(seeds.len()) +\n"
    t = t + "              \",\\\"score\\\":\" + to_string(score) + \"}\"\n"
    t = t + "    append_usage(row)\n"
    t = t + "}\n"
    t = t + "\n"
    t = t + "fn cmd_run() {\n"
    t = t + "    let hits = stage_discovery()\n"
    t = t + "    let seeds = stage_seeds(hits)\n"
    t = t + "    let score = stage_score(hits, seeds)\n"
    t = t + "    stage_emit(hits, seeds, score)\n"
    t = t + "    println(ENGINE_NAME + \": hits=\" + to_string(hits.len()) +\n"
    t = t + "            \" seeds=\" + to_string(seeds.len()) +\n"
    t = t + "            \" score=\" + to_string(score))\n"
    t = t + "}\n"
    t = t + "\n"
    t = t + "fn cmd_scan() {\n"
    t = t + "    let hits = stage_discovery()\n"
    t = t + "    println(ENGINE_NAME + \": scan hits=\" + to_string(hits.len()))\n"
    t = t + "}\n"
    t = t + "\n"
    t = t + "fn cmd_score() {\n"
    t = t + "    let hits = stage_discovery()\n"
    t = t + "    let seeds = stage_seeds(hits)\n"
    t = t + "    let score = stage_score(hits, seeds)\n"
    t = t + "    println(ENGINE_NAME + \": score=\" + to_string(score))\n"
    t = t + "}\n"
    t = t + "\n"
    t = t + "fn cmd_emit() {\n"
    t = t + "    let hits = stage_discovery()\n"
    t = t + "    let seeds = stage_seeds(hits)\n"
    t = t + "    let score = stage_score(hits, seeds)\n"
    t = t + "    stage_emit(hits, seeds, score)\n"
    t = t + "    println(ENGINE_NAME + \": emit ok score=\" + to_string(score))\n"
    t = t + "}\n"
    t = t + "\n"
    t = t + "fn main() {\n"
    t = t + "    let argv = args()\n"
    t = t + "    let mut mode = \"run\"\n"
    t = t + "    if argv.len() >= 3 { mode = _str(argv[2]).trim() }\n"
    t = t + "    if mode == \"run\" { cmd_run() }\n"
    t = t + "    else if mode == \"scan\" { cmd_scan() }\n"
    t = t + "    else if mode == \"score\" { cmd_score() }\n"
    t = t + "    else if mode == \"emit\" { cmd_emit() }\n"
    t = t + "    else {\n"
    t = t + "        eprintln(\"usage: \" + ENGINE_NAME + \" <run|scan|score|emit>\")\n"
    t = t + "        exit(2)\n"
    t = t + "    }\n"
    t = t + "}\n"
    t = t + "\n"
    t = t + "main()\n"
    return t
}

// ─── forge 커맨드: BT id + attack angle → 엔진 .hexa 생성 + registry append ───
fn cmd_forge(argv: [string]) {
    if argv.len() < 5 {
        eprintln("usage: forge <bt_id> \"<kw1,kw2,...>\"")
        exit(2)
    }
    let bt_id = _str(argv[3]).trim()
    let angle_raw = _str(argv[4]).trim()
    if bt_id == "" { eprintln("REJECT: empty bt_id"); exit(2) }
    if is_valid_bt_id(bt_id) == false {
        eprintln("REJECT: invalid bt_id '" + bt_id + "' (expected BT-<digits>)")
        exit(2)
    }
    if angle_raw == "" {
        eprintln("REJECT: empty attack_angle")
        exit(2)
    }
    let kws = parse_attack_angle(angle_raw)
    if kws.len() == 0 {
        eprintln("REJECT: no keywords parsed from '" + angle_raw + "'")
        exit(2)
    }

    ensure_dir(BT_ENGINE_DIR)
    let dst = BT_ENGINE_DIR + "/" + bt_id + "_engine.hexa"
    if file_exists(dst) {
        eprintln("REJECT: already forged — " + dst)
        exit(2)
    }

    let content = engine_template(bt_id, kws)
    try { write_file(dst, content) } catch e {
        eprintln("FAIL: write " + dst)
        exit(1)
    }

    let ts = now_unix()
    let engine_name = bt_id + "_engine"
    // attack_angle 재구성 (comma join)
    let mut angle_json = ""
    let mut i = 0
    while i < kws.len() {
        if i > 0 { angle_json = angle_json + "," }
        angle_json = angle_json + _str(kws[i])
        i = i + 1
    }

    let reg_row = "{\"ts\":" + to_string(ts) +
                  ",\"name\":\"" + json_escape(engine_name) +
                  "\",\"score\":0,\"auto_spawned\":true,\"bt_parent\":\"" + json_escape(bt_id) +
                  "\",\"attack_angle\":\"" + json_escape(angle_json) +
                  "\",\"path\":\"shared/engine/bt_engines/" + json_escape(bt_id) + "_engine.hexa\"}"
    file_append_line(REGISTRY_JSONL, reg_row)

    let usage_row = "{\"ts\":" + to_string(ts) +
                    ",\"engine\":\"" + json_escape(engine_name) +
                    "\",\"kind\":\"forged\",\"bt_parent\":\"" + json_escape(bt_id) +
                    "\",\"score\":0,\"path\":\"shared/engine/bt_engines/" + json_escape(bt_id) + "_engine.hexa\"}"
    file_append_line(USAGE, usage_row)

    let loc = to_string(content.split("\n").len())
    println("forged: " + dst + " (LOC=" + loc + " kws=" + to_string(kws.len()) + ")")
}

// ─── bench 커맨드: 엔진 실행 → score 수집 → usage bench 기록 ───
fn cmd_bench(argv: [string]) {
    if argv.len() < 4 {
        eprintln("usage: bench <bt_id>")
        exit(2)
    }
    let bt_id = _str(argv[3]).trim()
    if is_valid_bt_id(bt_id) == false {
        eprintln("REJECT: invalid bt_id '" + bt_id + "'")
        exit(2)
    }
    let engine_name = bt_id + "_engine"
    let path = BT_ENGINE_DIR + "/" + bt_id + "_engine.hexa"
    if file_exists(path) == false {
        eprintln("REJECT: engine missing — " + path + " (forge 먼저)")
        exit(2)
    }
    let hexa_bin = NEXUS + "/bin/hexa"
    let cmd = hexa_bin + " run '" + path + "' score 2>&1"
    let raw = _str(exec(cmd)).trim()  // @allow-bare-exec
    // 출력 형식: "<engine_name>: score=<N>"
    let mut score: i64 = 0
    let tag = "score="
    let idx = raw.index_of(tag)
    if idx >= 0 {
        let tail = raw.substring(idx + tag.len(), raw.len())
        score = _to_int0(tail)
    }
    let ts = now_unix()
    let row = "{\"ts\":" + to_string(ts) +
              ",\"engine\":\"" + json_escape(engine_name) +
              "\",\"kind\":\"bench\",\"bt_parent\":\"" + json_escape(bt_id) +
              "\",\"score\":" + to_string(score) + "}"
    file_append_line(USAGE, row)
    println("bench: " + engine_name + " score=" + to_string(score))
}

// ─── list 커맨드: registry_jsonl tail ───
fn cmd_list(argv: [string]) {
    if file_exists(REGISTRY_JSONL) == false {
        println("list: registry empty (no forged engines)")
        return
    }
    let raw = _str(exec("tail -50 '" + REGISTRY_JSONL + "' 2>/dev/null")).trim()  // @allow-bare-exec
    if raw == "" {
        println("list: registry empty")
        return
    }
    println(raw)
}

// ─── status 커맨드: forged count + recent bench ───
fn cmd_status(argv: [string]) {
    let mut forged: i64 = 0
    if file_exists(REGISTRY_JSONL) {
        let c = _str(exec("wc -l < '" + REGISTRY_JSONL + "' 2>/dev/null")).trim()  // @allow-bare-exec
        forged = _to_int0(c)
    }
    let mut bench_24h: i64 = 0
    let now = now_unix()
    let day = now - 86400
    if file_exists(USAGE) {
        let raw = _str(exec("grep '\"kind\":\"bench\"' '" + USAGE + "' 2>/dev/null | tail -200")).trim()  // @allow-bare-exec
        if raw != "" {
            let lines = raw.split("\n")
            let mut i = 0
            while i < lines.len() {
                let ln = _str(lines[i]).trim()
                if ln == "" { i = i + 1; continue }
                // ts 필드 — 쉼표/중괄호 전까지 숫자만 추출
                let tag = "\"ts\":"
                let idx = ln.index_of(tag)
                if idx >= 0 {
                    let tail = ln.substring(idx + tag.len(), ln.len())
                    let mut end: i64 = 0
                    while end < tail.len() {
                        let c = tail.substring(end, end + 1)
                        if c == "," || c == "}" || c == " " { break }
                        end = end + 1
                    }
                    let num = tail.substring(0, end).trim()
                    if num.len() > 0 {
                        let mut ok = true
                        let mut j = 0
                        while j < num.len() {
                            let d = num.substring(j, j + 1)
                            if !_is_digit_cc(d) { ok = false; break }  // stage0 string >= broken (TS-20260416-STAGE0-STRCMP) — use char_code
                            j = j + 1
                        }
                        if ok {
                            let ts = to_int(num)
                            if ts >= day { bench_24h = bench_24h + 1 }
                        }
                    }
                }
                i = i + 1
            }
        }
    }
    let mut files: i64 = 0
    if file_exists(BT_ENGINE_DIR) {
        let c = _str(exec("ls '" + BT_ENGINE_DIR + "' 2>/dev/null | grep -c '_engine\\.hexa$' || echo 0")).trim()  // @allow-bare-exec
        files = _to_int0(c)
    }
    println("bt_engine_forge: registry=" + to_string(forged) +
            " files=" + to_string(files) +
            " bench_24h=" + to_string(bench_24h))
}

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    if argv.len() < 3 {
        eprintln("usage: bt_engine_forge <forge|bench|list|status> [args...]")
        exit(2)
    }
    let mode = _str(argv[2]).trim()
    if mode == "forge" { cmd_forge(argv) }
    else if mode == "bench" { cmd_bench(argv) }
    else if mode == "list" { cmd_list(argv) }
    else if mode == "status" { cmd_status(argv) }
    else {
        eprintln("REJECT: unknown mode '" + mode + "' — modes: forge|bench|list|status")
        exit(2)
    }
}

main()
