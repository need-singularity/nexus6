// gap_monitor.hexa — L7_GAP: 공통 로드맵 gap 자동 유지 훅
// @allow-bare-exec
// @no-sandbox
//
// 모든 프로젝트(7) loop iteration 마다 실행. 3 단계 파이프라인:
//   1. roadmap_guard gap                      stub/missing 재스캔 → roadmap_gaps.jsonl
//   2. breakthrough auto                      blocking gap 에 sub-roadmap 자동 생성
//   3. breakthrough refresh all               task.status 재계산 + JSON 저장
//
// SSOT:
//   in:   shared/roadmaps/*.json + shared/config/projects.json + loop/*.json
//   out:  shared/tool/roadmap_gaps.jsonl  +  shared/roadmaps/breakthroughs/*.json
//         shared/tool/gap_monitor.log (가장 최근 실행 로그)
//
// exit: 항상 0 (모니터링 훅 — loop 차단 없음). 실패 요약은 stderr.

fn main() {
    let HOME = env("HOME")
    let NEXUS = HOME + "/Dev/nexus"
    let HX = HOME + "/Dev/hexa-lang/hexa"
    let LOG = NEXUS + "/tool/gap_monitor.log"
    let GUARD = NEXUS + "/tool/roadmap_guard.hexa"
    let BT = NEXUS + "/tool/breakthrough.hexa"

    // 1) gap scan
    let _ = exec(HX + " " + GUARD + " gap > " + LOG + " 2>&1")  // @allow-bare-exec

    // 2) auto-generate breakthroughs (새 blocking gap 있으면 sub-roadmap 생성)
    let _ = exec(HX + " " + BT + " auto >> " + LOG + " 2>&1")  // @allow-bare-exec

    // 3) refresh task.status
    let _ = exec(HX + " " + BT + " refresh all >> " + LOG + " 2>&1")  // @allow-bare-exec

    // 4) 요약 — roadmap_gaps.jsonl blocking + overall done/total (temp .py)
    let py = "import json, os\n" +
        "gaps_path = '" + NEXUS + "/tool/roadmap_gaps.jsonl'\n" +
        "bt_dir = '" + NEXUS + "/config/roadmaps/breakthroughs'\n" +
        "blocking = 0\n" +
        "proj_count = {}\n" +
        "seen = set()\n" +
        "if os.path.exists(gaps_path):\n" +
        "    for ln in open(gaps_path):\n" +
        "        ln = ln.strip()\n" +
        "        if not ln: continue\n" +
        "        try: g = json.loads(ln)\n" +
        "        except: continue\n" +
        "        if not g.get('blocking'): continue\n" +
        "        k = (g.get('project'), g.get('source'), g.get('key'), g.get('file'), g.get('kind'))\n" +
        "        if k in seen: continue\n" +
        "        seen.add(k)\n" +
        "        blocking += 1\n" +
        "        proj_count[g['project']] = proj_count.get(g['project'],0)+1\n" +
        "done = 0\n" +
        "total = 0\n" +
        "if os.path.exists(bt_dir):\n" +
        "    for ff in os.listdir(bt_dir):\n" +
        "        if not ff.endswith('.json'): continue\n" +
        "        try: d = json.load(open(os.path.join(bt_dir, ff)))\n" +
        "        except: continue\n" +
        "        for t in d.get('tasks', []):\n" +
        "            total += 1\n" +
        "            if t.get('status') == 'done': done += 1\n" +
        "print(f'L7_GAP blocking={blocking} ({proj_count}) breakthroughs_done={done}/{total}')\n"
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    // Original: write /tmp/gap_monitor_sum.py + /usr/bin/python3 exec for gap/breakthrough summary
    let _ = py
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at gap_monitor.hexa:main. Escalate to user for hexa-native replacement.")
    exit(1)
}

main()
