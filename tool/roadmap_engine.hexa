// roadmap_engine.hexa — TOC+A* shortest-breakthrough-path scheduler
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
//
// ═══════════════════════════════════════════════════════════════════════════
// PURPOSE
//   로드맵(DAG) 에서 S0 → G 까지의 최단시간 돌파 경로 T* 를 계산.
//   지배병목 b*(S) 추적 → Bellman 의 min-max 최적화.
//   실시간 진행을 ASCII vertical flowchart + JSONL events 로 출력.
//
// 이론 (user-agreed):
//   T*(S0→G) = inf_π  Σ_k  max_{i∈Ω}  c_i(S_k^π)       Theory-of-Constraints 의 total throughput
//       Ω = {build, exp, learn, boot, verify}
//       c_build  = span(DAG(S))            (Brent T∞)
//       c_exp    = T_trial / p_success     (bandit)
//       c_learn  = T0 · (1−η)^k            (Wright)
//       c_boot   = T_gap / N_uses          (amortized)
//       c_verify = K(G|S) / C_channel      (Shannon-Fano)
//
//   Bellman dynamics:
//       V*(S) = min_a [ b_a(S) + V*(f(S,a)) ],  V*(G) = 0
//       π*(S) = argmin_a [...]
//
//   η-convergence test:
//       η_k = 1 − b(S_{k+1}) / b(S_k)
//       η > 0 ⟹ T* < ∞  (Kurzweil-style accelerating)
//       η = 0 ⟹ divergence → replan
//
//   Kahn + Brent (blocking minimization):
//       T_wall* = Σ b(S_k)   ⟺   ∀t |R(t)| ≥ 1
//       soft edges droppable; hard edges preserved.
//
// SSOT
//   input : <roadmap>.json   (shared/roadmaps/schema.json 참조)
//   out   : stdout ASCII flowchart + (선택) JSONL events to file
//
// CLI
//   hexa run roadmap_engine.hexa <roadmap.json>                          # one-shot plan+view
//   hexa run roadmap_engine.hexa <roadmap.json> --watch [--interval=1]   # 5s watchdog loop
//   hexa run roadmap_engine.hexa <roadmap.json> --events=<out.jsonl>     # append events
//   hexa run roadmap_engine.hexa <roadmap.json> --dispatch               # plan only (JSON)
//   hexa run roadmap_engine.hexa <roadmap.json> --selftest               # example 시뮬레이션
//
// exit: 0 success / 1 schedule fail (η=0 divergence) / 2 usage error / 3 parse error
// ═══════════════════════════════════════════════════════════════════════════

let HOME = env("HOME")
let NEXUS = HOME + "/core/nexus"
let HARNESS = NEXUS + "/harness"
let ROADMAPS = NEXUS + "/roadmaps"

// ── void-safe coercion ────────────────────────────────────────────────────
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

// f64 → i64 (truncate, to_int invalid-literal trap 회피)
fn f_to_i(x: f64) -> i64 {
    let s = to_string(x)
    let dot = s.index_of(".")
    let body = if dot >= 0 { s.substring(0, dot) } else { s }
    if body == "" || body == "-" { return 0 }
    return to_int(body)
}

// hexa stage0 string '>=/<=' 반환 void → is_digit/is_num_char 헬퍼로 대체.
fn is_digit(c: string) -> bool {
    return c == "0" || c == "1" || c == "2" || c == "3" || c == "4"
        || c == "5" || c == "6" || c == "7" || c == "8" || c == "9"
}

fn is_num_char(c: string) -> bool {
    if is_digit(c) { return true }
    return c == "." || c == "-" || c == "+" || c == "e" || c == "E"
}

fn _now_ms() -> i64 {
    let s = _str(exec("date +%s%N 2>/dev/null || date +%s000000000")).trim()  // @allow-bare-exec
    if s.len() == 0 { return 0 }
    // first contiguous digits
    let mut n: i64 = 0
    let mut i: i64 = 0
    while i < s.len() {
        let c = s.substring(i, i + 1)
        if is_digit(c) { n = n * 10 + (to_int(c)) }
        else { return n / 1000000 }
        i = i + 1
    }
    return n / 1000000
}

fn _ts_iso() -> string {
    return _str(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()  // @allow-bare-exec
}

// ── text-based JSON field extract (json_parse 회피, P9/void trap 대응) ────
// 규칙: hexa json_parse 는 void return trap 있음. 본 엔진은 로드맵 스키마가 고정
// 이라 필드 추출을 string-search 기반으로 한다. 모든 JSON 값은 double-quote 로
// 감싸져 있다고 가정 (schema 가 문자열/숫자 두 타입만 씀).
fn _find_after(hay: string, needle: string, from: i64) -> i64 {
    let mut i = from
    let nl = needle.len()
    let hl = hay.len()
    while i + nl <= hl {
        if hay.substring(i, i + nl) == needle { return i }
        i = i + 1
    }
    return -1
}

// "key":"value"  또는  "key": "value"   (공백 허용)
fn json_str_at(body: string, key: string, from: i64) -> [string] {
    // returns [value, next_pos_or_-1]
    let k = "\"" + key + "\""
    let ki = _find_after(body, k, from)
    if ki < 0 { return ["", "-1"] }
    let mut i = ki + k.len()
    // skip ws + ':' + ws
    while i < body.len() {
        let c = body.substring(i, i + 1)
        if c == " " || c == "\t" || c == "\n" || c == "\r" || c == ":" { i = i + 1 }
        else { break }
    }
    if i >= body.len() { return ["", "-1"] }
    if body.substring(i, i + 1) != "\"" { return ["", "-1"] }
    // read until unescaped quote
    let start = i + 1
    let mut j = start
    while j < body.len() {
        let c = body.substring(j, j + 1)
        if c == "\\" { j = j + 2; continue }
        if c == "\"" { break }
        j = j + 1
    }
    if j >= body.len() { return ["", "-1"] }
    let v = body.substring(start, j)
    return [v, to_string(j + 1)]
}

fn json_num_at(body: string, key: string, from: i64) -> [string] {
    let k = "\"" + key + "\""
    let ki = _find_after(body, k, from)
    if ki < 0 { return ["", "-1"] }
    let mut i = ki + k.len()
    while i < body.len() {
        let c = body.substring(i, i + 1)
        if c == " " || c == "\t" || c == "\n" || c == "\r" || c == ":" { i = i + 1 }
        else { break }
    }
    let start = i
    while i < body.len() {
        let c = body.substring(i, i + 1)
        if is_num_char(c) { i = i + 1 }
        else { break }
    }
    if i == start { return ["", "-1"] }
    return [body.substring(start, i), to_string(i)]
}

fn json_str(body: string, key: string) -> string {
    let r = json_str_at(body, key, 0)
    return _str(r[0])
}

fn json_num(body: string, key: string) -> f64 {
    let r = json_num_at(body, key, 0)
    let s = _str(r[0])
    if s.len() == 0 { return 0.0 }
    return to_float(s)
}

// ── deps 배열 추출 ("deps":["a","b",...]) ────────────────────────────────
fn json_str_array(body: string, key: string) -> [string] {
    let k = "\"" + key + "\""
    let ki = _find_after(body, k, 0)
    if ki < 0 { return [] }
    let mut i = ki + k.len()
    while i < body.len() {
        let c = body.substring(i, i + 1)
        if c == " " || c == "\t" || c == "\n" || c == "\r" || c == ":" { i = i + 1 }
        else { break }
    }
    if i >= body.len() || body.substring(i, i + 1) != "[" { return [] }
    i = i + 1
    let mut out: [string] = []
    let mut depth: i64 = 1
    while i < body.len() && depth > 0 {
        let c = body.substring(i, i + 1)
        if c == "]" { depth = depth - 1; if depth == 0 { break }; i = i + 1; continue }
        if c == "[" { depth = depth + 1; i = i + 1; continue }
        if c == "\"" {
            let start = i + 1
            let mut j = start
            while j < body.len() {
                let cj = body.substring(j, j + 1)
                if cj == "\\" { j = j + 2; continue }
                if cj == "\"" { break }
                j = j + 1
            }
            if j < body.len() {
                out = out.push(body.substring(start, j))
                i = j + 1
                continue
            } else { break }
        }
        i = i + 1
    }
    return out
}

// ── nodes[] 블록 단위 split: "nodes":[ {...}, {...} ] ────────────────────
// 각 {...} object 를 문자열로 반환 (중첩 {} depth 추적, 문자열 내 '{' 무시).
fn split_nodes(body: string) -> [string] {
    let tag = "\"nodes\""
    let ti = _find_after(body, tag, 0)
    if ti < 0 { return [] }
    let mut i = ti + tag.len()
    while i < body.len() {
        let c = body.substring(i, i + 1)
        if c == " " || c == "\t" || c == "\n" || c == "\r" || c == ":" { i = i + 1 }
        else { break }
    }
    if i >= body.len() || body.substring(i, i + 1) != "[" { return [] }
    i = i + 1
    let mut out: [string] = []
    let mut depth: i64 = 0
    let mut start: i64 = -1
    let mut in_str: bool = false
    while i < body.len() {
        let c = body.substring(i, i + 1)
        // hexa stage0: nested `continue` under multi-level `if` can fall-through
        // (observed: `if in_str { if c=="\"" {...continue} i=i+1 continue }` both fire).
        // Workaround: if-elif chain + single i-advance tail.
        let mut handled: bool = false
        if in_str {
            if c == "\\" { i = i + 2; handled = true }
            else if c == "\"" { in_str = false; i = i + 1; handled = true }
            else { i = i + 1; handled = true }
        }
        if handled == false {
            if c == "\"" { in_str = true; i = i + 1; handled = true }
            else if c == "{" {
                if depth == 0 { start = i }
                depth = depth + 1
                i = i + 1
                handled = true
            }
            else if c == "}" {
                depth = depth - 1
                if depth == 0 && start >= 0 {
                    out = out.push(body.substring(start, i + 1))
                    start = -1
                }
                i = i + 1
                handled = true
            }
            else if c == "]" && depth == 0 { break }
            else { i = i + 1 }
        }
    }
    return out
}

// ── Node struct ──────────────────────────────────────────────────────────
struct Node {
    id: string,
    name: string,
    ntype: string,     // build|exp|learn|boot|verify|seed|goal
    cost: f64,
    p_success: f64,    // exp
    eta: f64,          // learn
    n_uses: i64,       // boot
    deps: [string],
    soft_deps: [string],
    status: string,    // todo|in_progress|done|blocked|failed
    progress: f64
}

fn parse_node(raw: string) -> Node {
    let id = json_str(raw, "id")
    let mut name = json_str(raw, "name")
    if name == "" { name = id }
    let mut ntype = json_str(raw, "type")
    if ntype == "" { ntype = "build" }
    let cost = json_num(raw, "cost")
    let p = json_num(raw, "p_success")
    let p2 = if p <= 0.0 { 1.0 } else { p }
    let eta = json_num(raw, "eta")
    let nu = json_num(raw, "n_uses")
    let nu_i: i64 = if nu <= 0.0 { 1 } else { f_to_i(nu) }
    // Blocking Min #12: hard_deps[] preferred; fall back to deps[] (backward compat).
    let hard_raw = json_str_array(raw, "hard_deps")
    let deps_raw = json_str_array(raw, "deps")
    let deps = if hard_raw.len() > 0 { hard_raw } else { deps_raw }
    let soft = json_str_array(raw, "soft_deps")
    let mut st = json_str(raw, "status")
    if st == "" { st = "todo" }
    let pg = json_num(raw, "progress")
    return Node {
        id: id, name: name, ntype: ntype,
        cost: cost, p_success: p2, eta: eta, n_uses: nu_i,
        deps: deps, soft_deps: soft,
        status: st, progress: pg
    }
}

// ── Roadmap graph ────────────────────────────────────────────────────────
struct Roadmap {
    id: string,
    goal: string,
    start: string,
    K_target: f64,
    C_channel: f64,
    updated: string,
    description: string,
    nodes: [Node]
}

fn load_roadmap(path: string) -> Roadmap {
    if file_exists(path) == false {
        eprintln("REJECT: roadmap not found: " + path)
        exit(3)
    }
    let body = _str(read_file(path))
    if body.len() == 0 {
        eprintln("REJECT: empty roadmap: " + path)
        exit(3)
    }
    // _meta 서브블록만 추출하여 파싱 노이즈 줄이기 (nodes 내부에도 id/status 있음)
    let meta_idx = _find_after(body, "\"_meta\"", 0)
    let mut meta_body = body
    if meta_idx >= 0 {
        // find { after _meta
        let mut mi = meta_idx
        while mi < body.len() && body.substring(mi, mi + 1) != "{" { mi = mi + 1 }
        if mi < body.len() {
            let start = mi
            let mut depth: i64 = 0
            let mut in_str: bool = false
            let mut end = mi
            let mut done_meta: bool = false
            while end < body.len() && done_meta == false {
                let c = body.substring(end, end + 1)
                // hexa stage0 continue fall-through guard
                let mut handled: bool = false
                if in_str {
                    if c == "\\" { end = end + 2; handled = true }
                    else if c == "\"" { in_str = false; end = end + 1; handled = true }
                    else { end = end + 1; handled = true }
                }
                if handled == false {
                    if c == "\"" { in_str = true; end = end + 1 }
                    else if c == "{" { depth = depth + 1; end = end + 1 }
                    else if c == "}" {
                        depth = depth - 1
                        if depth == 0 { end = end + 1; done_meta = true }
                        else { end = end + 1 }
                    }
                    else { end = end + 1 }
                }
            }
            meta_body = body.substring(start, end)
        }
    }
    let rid = json_str(meta_body, "id")
    let goal = json_str(meta_body, "goal")
    let start = json_str(meta_body, "start")
    let K = json_num(meta_body, "K_target")
    let C = json_num(meta_body, "C_channel")
    let updated = json_str(meta_body, "updated")
    let desc = json_str(meta_body, "description")
    let node_blocks = split_nodes(body)
    let mut nodes: [Node] = []
    let mut i: i64 = 0
    while i < node_blocks.len() {
        let n = parse_node(_str(node_blocks[i]))
        if n.id.len() > 0 { nodes = nodes.push(n) }
        i = i + 1
    }
    return Roadmap {
        id: rid, goal: goal, start: start,
        K_target: K, C_channel: C, updated: updated, description: desc,
        nodes: nodes
    }
}

// ── indexing helpers ─────────────────────────────────────────────────────
fn idx_of(nodes: [Node], nid: string) -> i64 {
    let mut i: i64 = 0
    while i < nodes.len() {
        if nodes[i].id == nid { return i }
        i = i + 1
    }
    return -1
}

fn is_done(st: string) -> bool {
    return st == "done" || st == "complete" || st == "aborted" || st == "skipped"
}

// ── effective cost c_i(S) per Ω category ─────────────────────────────────
// build   → cost (Brent span; DAG span 은 schedule 에서 composed)
// exp     → cost / p_success
// learn   → cost · (1-η)^k ;  k=0 here (log 없음), 그대로 사용
// boot    → cost / max(1, n_uses)
// verify  → K_target / max(0.01, C_channel)   (cost 를 기반 가중)
// seed    → 0
// goal    → cost (보통 0)
fn effective_cost(n: Node, K: f64, C: f64) -> f64 {
    let t = n.ntype
    if t == "seed" { return 0.0 }
    if t == "goal" { return n.cost }
    if t == "exp" {
        let p = if n.p_success <= 0.0 { 1.0 } else { n.p_success }
        return n.cost / p
    }
    if t == "learn" {
        let e = if n.eta < 0.0 { 0.0 } else { n.eta }
        let f = 1.0 - e
        return n.cost * f
    }
    if t == "boot" {
        let nu = if n.n_uses < 1 { 1 } else { n.n_uses }
        return n.cost / to_float(to_string(nu))
    }
    if t == "verify" {
        let k = if K <= 0.0 { 1.0 } else { K }
        let c = if C <= 0.0 { 1.0 } else { C }
        // K/C 계수로 cost 스케일. 본래 c_verify = K/C (분자=정보량, 분모=채널용량)
        return (k / c) + (n.cost * 0.25)
    }
    // build (default): Brent — cost 그대로 (span 은 critical path 에서 합산)
    return n.cost
}

// 지배병목 카테고리 라벨 (Ω 원소 중 argmax c_i)
fn dominant_bottleneck(n: Node, K: f64, C: f64) -> string {
    // 본 MVP 는 노드당 type 1개만 할당 → 그대로 반환
    return n.ntype
}

// ── remaining cost (남은 비용; done 이면 0, in_progress 면 (1-progress)*c) ─
fn remaining_cost(n: Node, K: f64, C: f64) -> f64 {
    if is_done(n.status) { return 0.0 }
    let c = effective_cost(n, K, C)
    if n.status == "in_progress" {
        let p = if n.progress < 0.0 { 0.0 } else { if n.progress > 1.0 { 1.0 } else { n.progress } }
        return c * (1.0 - p)
    }
    return c
}

// ── CPM / V*(S) via topological longest-path from each node to goal ──────
// V*(n) = cost(n)_remaining + max_{child}( V*(child) )   (serial DAG critical-path)
// 병렬 attack (여러 children 동시 가능) → max (Brent T∞).
// 단, hard deps 는 preserve. soft_deps 는 별도 표시.
fn children_of(nodes: [Node], nid: string) -> [string] {
    let mut out: [string] = []
    let mut i: i64 = 0
    while i < nodes.len() {
        let n = nodes[i]
        let mut j: i64 = 0
        while j < n.deps.len() {
            if _str(n.deps[j]) == nid { out = out.push(n.id); break }
            j = j + 1
        }
        i = i + 1
    }
    return out
}

fn parents_of(node: Node) -> [string] {
    return node.deps
}

// children indices on (deps ∪ soft_deps) — Tarjan SCC contracts soft cycles
// (e.g., diamond B↔C) so vstar's longest-path matches r4_replan.py.
fn _kids_idx_all(nodes: [Node], ni: i64) -> [i64] {
    let mut out: [i64] = []; let me = nodes[ni].id; let mut k: i64 = 0
    while k < nodes.len() {
        let m = nodes[k]; let mut hit: bool = false; let mut j: i64 = 0
        while j < m.deps.len() { if _str(m.deps[j]) == me { hit = true; break }; j = j + 1 }
        let mut j2: i64 = 0
        while hit == false && j2 < m.soft_deps.len() { if _str(m.soft_deps[j2]) == me { hit = true }; j2 = j2 + 1 }
        if hit { out = out.push(k) }
        k = k + 1
    }
    return out
}

// Tarjan SCC (iterative) — comp[i] = scc id of node i. Mirrors r4_replan.py:_tarjan_scc.
fn _scc_of(nodes: [Node]) -> [i64] {
    let N = nodes.len()
    let mut idx: [i64] = []; let mut low: [i64] = []; let mut on: [bool] = []; let mut comp: [i64] = []
    let mut i0: i64 = 0
    while i0 < N { idx = idx.push(-1); low = low.push(0); on = on.push(false); comp = comp.push(-1); i0 = i0 + 1 }
    let mut stk: [i64] = []; let mut wk: [i64] = []; let mut wi: [i64] = []
    let mut cnt: i64 = 0; let mut sid: i64 = 0; let mut root: i64 = 0
    while root < N {
        if idx[root] < 0 {
            wk = wk.push(root); wi = wi.push(0)
            idx[root] = cnt; low[root] = cnt; cnt = cnt + 1; stk = stk.push(root); on[root] = true
            while wk.len() > 0 {
                let v = wk[wk.len() - 1]; let kids = _kids_idx_all(nodes, v); let it = wi[wi.len() - 1]
                if it < kids.len() {
                    let w = kids[it]; wi[wi.len() - 1] = it + 1
                    if idx[w] < 0 {
                        idx[w] = cnt; low[w] = cnt; cnt = cnt + 1; stk = stk.push(w); on[w] = true
                        wk = wk.push(w); wi = wi.push(0)
                    } else if on[w] && idx[w] < low[v] { low[v] = idx[w] }
                } else {
                    if low[v] == idx[v] {
                        let mut pop: bool = true
                        while pop {
                            let w2 = stk[stk.len() - 1]; let mut ns: [i64] = []; let mut si: i64 = 0
                            while si < stk.len() - 1 { ns = ns.push(stk[si]); si = si + 1 }
                            stk = ns; on[w2] = false; comp[w2] = sid
                            if w2 == v { pop = false }
                        }
                        sid = sid + 1
                    }
                    let mut nw: [i64] = []; let mut ni2: [i64] = []; let mut zi: i64 = 0
                    while zi < wk.len() - 1 { nw = nw.push(wk[zi]); ni2 = ni2.push(wi[zi]); zi = zi + 1 }
                    wk = nw; wi = ni2
                    if wk.len() > 0 { let p = wk[wk.len() - 1]; if low[v] < low[p] { low[p] = low[v] } }
                }
            }
        }
        root = root + 1
    }
    return comp
}

// V*(n) — SCC-contracted longest-path. Soft-cycle members serial-sum into supernode.
fn vstar(nodes: [Node], nid: string, K: f64, C: f64) -> f64 {
    let ni0 = idx_of(nodes, nid)
    if ni0 < 0 { return 0.0 }
    let comp = _scc_of(nodes)
    let mut nscc: i64 = 0; let mut ii: i64 = 0
    while ii < comp.len() { if comp[ii] + 1 > nscc { nscc = comp[ii] + 1 }; ii = ii + 1 }
    let mut sc: [f64] = []; let mut memo: [f64] = []; let mut mset: [bool] = []; let mut s0: i64 = 0
    while s0 < nscc { sc = sc.push(0.0); memo = memo.push(0.0); mset = mset.push(false); s0 = s0 + 1 }
    let mut k0: i64 = 0
    while k0 < nodes.len() { sc[comp[k0]] = sc[comp[k0]] + remaining_cost(nodes[k0], K, C); k0 = k0 + 1 }
    return _vstar_super(nodes, comp, sc, comp[ni0], memo, mset)
}

fn _vstar_super(nodes: [Node], comp: [i64], sc: [f64], sid: i64, memo: [f64], mset: [bool]) -> f64 {
    if mset[sid] { return memo[sid] }
    mset[sid] = true; memo[sid] = 0.0
    let mut best: f64 = 0.0; let mut k: i64 = 0
    while k < nodes.len() {
        if comp[k] == sid {
            let kids = _kids_idx_all(nodes, k); let mut ci: i64 = 0
            while ci < kids.len() {
                let csid = comp[kids[ci]]
                if csid != sid { let v = _vstar_super(nodes, comp, sc, csid, memo, mset); if v > best { best = v } }
                ci = ci + 1
            }
        }
        k = k + 1
    }
    memo[sid] = sc[sid] + best
    return memo[sid]
}

// 계산 원샷 — Roadmap 전체에 대해 V*(start..goal) 산출
struct ScheduleResult {
    T_star: f64,           // V*(start) = S0→G 최단시간 (min)
    bottleneck_node: string,
    bottleneck_category: string,
    bottleneck_cost: f64,
    eta_current: f64,      // η = 1 - b(Sk+1)/b(Sk)  간이: 직전 bottleneck 대비 현재 감소율
    ready_set: [string],   // 현재 실행 가능 (deps done) 노드들
    in_progress: [string], // status=in_progress
    done: [string],
    todo: [string],
    blocked: [string],
    soft_drop_candidates: [string],  // 블로킹 유발 soft_dep 유니크
    progress_frac: f64,    // 완료 비중 (done count / total)
    replan_needed: bool
}

fn schedule(rm: Roadmap) -> ScheduleResult {
    let K = rm.K_target
    let C = rm.C_channel
    let nodes = rm.nodes

    // start 추정: 없으면 indeg=0 인 첫 노드
    let mut start_id = rm.start
    if start_id == "" {
        let mut i: i64 = 0
        while i < nodes.len() {
            if nodes[i].deps.len() == 0 { start_id = nodes[i].id; break }
            i = i + 1
        }
    }

    // V*(start) — DAG critical path (노드 < 200 충분)
    let T = vstar(nodes, start_id, K, C)

    // ready/in_progress/done/todo/blocked 분류
    let mut ready: [string] = []
    let mut inp: [string] = []
    let mut done_l: [string] = []
    let mut todo_l: [string] = []
    let mut blocked_l: [string] = []
    let mut i: i64 = 0
    while i < nodes.len() {
        let n = nodes[i]
        if is_done(n.status) { done_l = done_l.push(n.id) }
        else if n.status == "in_progress" { inp = inp.push(n.id) }
        else if n.status == "blocked" || n.status == "failed" { blocked_l = blocked_l.push(n.id) }
        else { todo_l = todo_l.push(n.id) }
        // ready: 시작 가능 (deps 전원 done && status == "todo" — in_progress/done 제외)
        if n.status == "todo" || n.status == "planned" {
            let mut all_done: bool = true
            let mut j: i64 = 0
            while j < n.deps.len() {
                let pi = idx_of(nodes, _str(n.deps[j]))
                if pi < 0 { all_done = false; break }
                if is_done(nodes[pi].status) == false { all_done = false; break }
                j = j + 1
            }
            if all_done { ready = ready.push(n.id) }
        }
        i = i + 1
    }

    // dominant bottleneck: ready ∪ in_progress 중 max effective cost 노드
    let mut bn_id: string = ""
    let mut bn_cost: f64 = -1.0
    let mut bn_cat: string = ""
    let mut k2: i64 = 0
    while k2 < inp.len() {
        let ni = idx_of(nodes, _str(inp[k2]))
        if ni >= 0 {
            let c = remaining_cost(nodes[ni], K, C)
            if c > bn_cost { bn_cost = c; bn_id = nodes[ni].id; bn_cat = nodes[ni].ntype }
        }
        k2 = k2 + 1
    }
    let mut k3: i64 = 0
    while k3 < ready.len() {
        let ni = idx_of(nodes, _str(ready[k3]))
        if ni >= 0 {
            let c = remaining_cost(nodes[ni], K, C)
            if c > bn_cost { bn_cost = c; bn_id = nodes[ni].id; bn_cat = nodes[ni].ntype }
        }
        k3 = k3 + 1
    }

    // η: (지난 완료 노드 평균 비용 vs 현재 bottleneck) — 간이 학습률.
    // done 노드 평균 비용 b_prev, 현재 bn_cost b_cur → η = 1 - b_cur/b_prev
    // done 없으면 0.0 (pre-baseline).
    let mut sum_prev: f64 = 0.0
    let mut cnt_prev: f64 = 0.0
    let mut k4: i64 = 0
    while k4 < done_l.len() {
        let ni = idx_of(nodes, _str(done_l[k4]))
        if ni >= 0 {
            let c = effective_cost(nodes[ni], K, C)
            if c > 0.0 { sum_prev = sum_prev + c; cnt_prev = cnt_prev + 1.0 }
        }
        k4 = k4 + 1
    }
    let mut eta: f64 = 0.0
    if cnt_prev > 0.0 && bn_cost > 0.0 {
        let avg = sum_prev / cnt_prev
        if avg > 0.0 { eta = 1.0 - (bn_cost / avg) }
    }

    // replan trigger: η ≤ 0 && todo>0 && in_progress>0 (학습률 정체)
    let replan: bool = (eta <= 0.0) && (todo_l.len() > 0) && ((inp.len() > 0) || (ready.len() > 1))

    // soft drop candidates: soft_deps 가 non-empty 인 노드들의 soft_dep target
    let mut softs: [string] = []
    let mut kk: i64 = 0
    while kk < nodes.len() {
        let n = nodes[kk]
        let mut jj: i64 = 0
        while jj < n.soft_deps.len() {
            let sd = _str(n.soft_deps[jj])
            // dedupe
            let mut exists: bool = false
            let mut ll: i64 = 0
            while ll < softs.len() {
                if _str(softs[ll]) == sd { exists = true; break }
                ll = ll + 1
            }
            if exists == false { softs = softs.push(sd) }
            jj = jj + 1
        }
        kk = kk + 1
    }

    let total = to_float(to_string(nodes.len()))
    let prog = if total == 0.0 { 0.0 } else { to_float(to_string(done_l.len())) / total }

    return ScheduleResult {
        T_star: T,
        bottleneck_node: bn_id,
        bottleneck_category: bn_cat,
        bottleneck_cost: if bn_cost < 0.0 { 0.0 } else { bn_cost },
        eta_current: eta,
        ready_set: ready,
        in_progress: inp,
        done: done_l,
        todo: todo_l,
        blocked: blocked_l,
        soft_drop_candidates: softs,
        progress_frac: prog,
        replan_needed: replan
    }
}

// ── ASCII vertical flowchart renderer ────────────────────────────────────
// Glyphs: ● done / ▶ in_progress / ○ todo / ✗ failed / ★ goal / ⟲ replan / ◆ decision / ║ parallel
// Layout: header → done-fold → current window (10 row) → todo-fold → goal.
fn glyph_for(n: Node) -> string {
    if n.ntype == "goal" { return "★" }
    if n.status == "in_progress" { return "▶" }
    if is_done(n.status) { return "●" }
    if n.status == "failed" { return "✗" }
    if n.status == "blocked" { return "⊘" }
    if n.ntype == "exp" { return "◆" }   // decision-ish
    return "○"
}

fn fmt_min(x: f64) -> string {
    // round to 1 decimal; if .0 omit
    let scaled = x * 10.0
    let r = f_to_i(scaled + 0.5)
    let whole = r / 10
    let frac = r - (whole * 10)
    if frac == 0 { return to_string(whole) + "m" }
    return to_string(whole) + "." + to_string(frac) + "m"
}

fn fmt_eta(e: f64) -> string {
    // 2-decimal signed
    let sign = if e < 0.0 { "-" } else { "+" }
    let v = if e < 0.0 { 0.0 - e } else { e }
    let scaled = (v * 100.0) + 0.5
    let r = f_to_i(scaled)
    let whole = r / 100
    let frac = r - (whole * 100)
    let mut fs = to_string(frac)
    if frac < 10 { fs = "0" + fs }
    return sign + to_string(whole) + "." + fs
}

fn pct(f: f64) -> string {
    let r = f_to_i((f * 100.0) + 0.5)
    return to_string(r) + "%"
}

fn render_node_line(n: Node, K: f64, C: f64) -> string {
    let g = glyph_for(n)
    let name = if n.name.len() > 22 { n.name.substring(0, 19) + "..." } else { n.name }
    let mut line = g + " " + name
    // pad name to 24 cols
    while line.len() < 26 { line = line + " " }
    // annotation
    if is_done(n.status) {
        line = line + "✓ " + fmt_min(effective_cost(n, K, C))
    } else if n.status == "in_progress" {
        line = line + pct(n.progress) + " b*=" + n.ntype + " rem=" + fmt_min(remaining_cost(n, K, C))
    } else if n.ntype == "goal" {
        if K > 0.0 && n.name.contains("K=") == false { line = line + "K=" + to_string(f_to_i(K)) + "b" }
    } else {
        line = line + "— b*=" + n.ntype + " cost=" + fmt_min(effective_cost(n, K, C))
    }
    return line
}

fn render_parallel_group(rm: Roadmap, ids: [string]) -> [string] {
    // boxed 3-column layout
    let mut out: [string] = []
    out = out.push("┌──attack parallel───┐")
    let mut cell = "├"
    let mut i: i64 = 0
    while i < ids.len() {
        let id = _str(ids[i])
        let ni = idx_of(rm.nodes, id)
        if ni >= 0 {
            let n = rm.nodes[ni]
            let g = glyph_for(n)
            let mut name = n.id
            if name.len() > 4 { name = name.substring(0, 4) }
            while name.len() < 4 { name = name + " " }
            cell = cell + "─" + name + "──" + g
            if i < ids.len() - 1 { cell = cell + "┬" } else { cell = cell + "─┤" }
        }
        i = i + 1
    }
    out = out.push(cell)
    // progress row
    let mut pr = "│"
    let mut j: i64 = 0
    while j < ids.len() {
        let id = _str(ids[j])
        let ni = idx_of(rm.nodes, id)
        if ni >= 0 {
            let n = rm.nodes[ni]
            let mut tag = ""
            if is_done(n.status) { tag = "  ✓   " }
            else if n.status == "in_progress" {
                let pp = pct(n.progress)
                tag = " " + pp
                while tag.len() < 6 { tag = tag + " " }
            } else { tag = "  ○   " }
            pr = pr + tag + "│"
        }
        j = j + 1
    }
    out = out.push(pr)
    let mut tail = "└"
    let mut k: i64 = 0
    while k < ids.len() {
        tail = tail + "──────"
        if k < ids.len() - 1 { tail = tail + "┴" } else { tail = tail + "┘" }
        k = k + 1
    }
    out = out.push(tail)
    return out
}

// 부모 교차 그룹 찾기: 같은 부모 가진 todo/in_progress 노드 ≥ 2 → parallel 그룹
fn find_parallel_groups(rm: Roadmap) -> [string] {
    // returns flat list "parent|id1,id2,id3" — 각 parent 에 대해 2+ children
    let mut out: [string] = []
    let mut i: i64 = 0
    while i < rm.nodes.len() {
        let parent = rm.nodes[i]
        let kids = children_of(rm.nodes, parent.id)
        if kids.len() >= 2 {
            // at least 2 non-done
            let mut non_done: [string] = []
            let mut k: i64 = 0
            while k < kids.len() {
                let ni = idx_of(rm.nodes, _str(kids[k]))
                if ni >= 0 && is_done(rm.nodes[ni].status) == false {
                    non_done = non_done.push(_str(kids[k]))
                }
                k = k + 1
            }
            // 전체 kids 가 parallel group (완료 포함 display)
            if kids.len() >= 2 {
                let mut joined = parent.id + "|"
                let mut kk: i64 = 0
                while kk < kids.len() {
                    joined = joined + _str(kids[kk])
                    if kk < kids.len() - 1 { joined = joined + "," }
                    kk = kk + 1
                }
                out = out.push(joined)
            }
        }
        i = i + 1
    }
    return out
}

fn in_any_group(id: string, groups: [string]) -> bool {
    let mut i: i64 = 0
    while i < groups.len() {
        let g = _str(groups[i])
        let pi = g.index_of("|")
        if pi > 0 {
            let tail = g.substring(pi + 1, g.len())
            let ids = tail.split(",")
            let mut j: i64 = 0
            while j < ids.len() {
                if _str(ids[j]) == id { return true }
                j = j + 1
            }
        }
        i = i + 1
    }
    return false
}

fn group_for_parent(parent: string, groups: [string]) -> string {
    let mut i: i64 = 0
    while i < groups.len() {
        let g = _str(groups[i])
        let pi = g.index_of("|")
        if pi > 0 {
            if g.substring(0, pi) == parent { return g }
        }
        i = i + 1
    }
    return ""
}

// 메인 렌더러
fn render_flowchart(rm: Roadmap, sched: ScheduleResult) -> string {
    let mut lines: [string] = []
    // header
    let hdr = "▼Roadmap  " + rm.id + "  S₀→" + rm.goal + "  T*=" + fmt_min(sched.T_star) + "  η̂=" + fmt_eta(sched.eta_current) + "  b*=" + sched.bottleneck_category + "(" + sched.bottleneck_node + ")"
    lines = lines.push(hdr)
    lines = lines.push("│")
    // fold done if many (>3)
    let done_n = sched.done.len()
    let todo_n = sched.todo.len()
    let groups = find_parallel_groups(rm)

    // topological walk from start
    let mut visited: [string] = []
    let mut stack: [string] = [rm.start]
    if rm.start == "" && rm.nodes.len() > 0 {
        // fallback to first indeg=0
        let mut ii: i64 = 0
        while ii < rm.nodes.len() {
            if rm.nodes[ii].deps.len() == 0 { stack = [rm.nodes[ii].id]; break }
            ii = ii + 1
        }
    }

    // BFS-like traversal preserving dependency order
    let mut walk_order: [string] = []
    let mut seen: [string] = []
    let mut q: [string] = stack
    while q.len() > 0 {
        let cur = _str(q[0])
        // pop head
        let mut nq: [string] = []
        let mut i2: i64 = 1
        while i2 < q.len() { nq = nq.push(_str(q[i2])); i2 = i2 + 1 }
        q = nq
        // skip if visited
        let mut already: bool = false
        let mut j2: i64 = 0
        while j2 < seen.len() {
            if _str(seen[j2]) == cur { already = true; break }
            j2 = j2 + 1
        }
        if already { continue }
        // check all deps visited — else postpone
        let ni = idx_of(rm.nodes, cur)
        if ni < 0 { continue }
        let node = rm.nodes[ni]
        let mut deps_ok: bool = true
        let mut dj: i64 = 0
        while dj < node.deps.len() {
            let dep_id = _str(node.deps[dj])
            let mut dep_seen: bool = false
            let mut sk: i64 = 0
            while sk < seen.len() {
                if _str(seen[sk]) == dep_id { dep_seen = true; break }
                sk = sk + 1
            }
            if dep_seen == false { deps_ok = false; break }
            dj = dj + 1
        }
        if deps_ok == false {
            // push back (with safety counter — prevent infinite loop on cycles)
            q = q.push(cur)
            if q.len() > rm.nodes.len() * 4 { break }
            continue
        }
        walk_order = walk_order.push(cur)
        seen = seen.push(cur)
        // enqueue children
        let kids = children_of(rm.nodes, cur)
        let mut ck: i64 = 0
        while ck < kids.len() {
            q = q.push(_str(kids[ck]))
            ck = ck + 1
        }
    }

    let dbg2 = env("ROADMAP_DBG")
    if dbg2 == "1" {
        eprintln("[walk_order] " + walk_order.join(","))
        eprintln("[groups] " + groups.join(" ; "))
    }

    // render in walk order, collapsing parallel groups
    let mut rendered_groups: [string] = []
    let mut done_emitted: i64 = 0
    let mut total_done_visible: i64 = 3
    let mut fold_emitted: bool = false
    let mut i3: i64 = 0
    while i3 < walk_order.len() {
        let cur = _str(walk_order[i3])
        let ni = idx_of(rm.nodes, cur)
        if ni < 0 { i3 = i3 + 1; continue }
        let n = rm.nodes[ni]

        // parallel group collapse: if cur 는 children-group 의 첫 멤버이며 부모 이미 출력됨
        if in_any_group(cur, groups) {
            // find group this node belongs to
            let mut parent_id = ""
            let mut gg: i64 = 0
            while gg < groups.len() {
                let gs = _str(groups[gg])
                let pi = gs.index_of("|")
                if pi > 0 {
                    let tail = gs.substring(pi + 1, gs.len())
                    let ids = tail.split(",")
                    let mut jj: i64 = 0
                    while jj < ids.len() {
                        if _str(ids[jj]) == cur {
                            parent_id = gs.substring(0, pi)
                            break
                        }
                        jj = jj + 1
                    }
                }
                if parent_id.len() > 0 { break }
                gg = gg + 1
            }
            // already rendered?
            let mut already2: bool = false
            let mut rg: i64 = 0
            while rg < rendered_groups.len() {
                if _str(rendered_groups[rg]) == parent_id { already2 = true; break }
                rg = rg + 1
            }
            if already2 {
                i3 = i3 + 1
                continue
            } else {
                // render group
                let gstr = group_for_parent(parent_id, groups)
                let pi2 = gstr.index_of("|")
                if pi2 > 0 {
                    let tail2 = gstr.substring(pi2 + 1, gstr.len())
                    let gids = tail2.split(",")
                    let block = render_parallel_group(rm, gids)
                    let mut bi: i64 = 0
                    while bi < block.len() { lines = lines.push(_str(block[bi])); bi = bi + 1 }
                    lines = lines.push("│")
                }
                rendered_groups = rendered_groups.push(parent_id)
                i3 = i3 + 1
                continue
            }
        }

        // done fold: 초기 done 노드 3 초과 시 ▼ 접기
        if is_done(n.status) && done_n > total_done_visible && done_emitted >= total_done_visible && fold_emitted == false {
            lines = lines.push("▼완료 " + to_string(done_n - total_done_visible) + "개 더 (접힘)")
            lines = lines.push("│")
            fold_emitted = true
            i3 = i3 + 1
            continue
        }

        let line = render_node_line(n, rm.K_target, rm.C_channel)
        lines = lines.push(line)
        lines = lines.push("│")
        if is_done(n.status) && fold_emitted == false { done_emitted = done_emitted + 1 }

        i3 = i3 + 1
    }

    // replan / drop annotations
    if sched.replan_needed {
        lines = lines.push("⟲ REPLAN hint — η ≤ 0 (학습률 정체). soft_deps drop 고려:")
        let mut si: i64 = 0
        while si < sched.soft_drop_candidates.len() {
            lines = lines.push("   · " + _str(sched.soft_drop_candidates[si]))
            si = si + 1
        }
    }
    // soft drop candidate hint (항상 출력 — 사용자 가시성)
    if sched.soft_drop_candidates.len() > 0 {
        lines = lines.push("   (soft_deps drop 후보: " + sched.soft_drop_candidates.join(", ") + ")")
    }

    // footer counts
    lines = lines.push("")
    lines = lines.push("summary: done=" + to_string(sched.done.len()) + " inp=" + to_string(sched.in_progress.len()) + " ready=" + to_string(sched.ready_set.len()) + " todo=" + to_string(sched.todo.len()) + " blocked=" + to_string(sched.blocked.len()) + " total=" + to_string(rm.nodes.len()) + " progress=" + pct(sched.progress_frac))

    let mut out = ""
    let mut oi: i64 = 0
    while oi < lines.len() {
        out = out + _str(lines[oi]) + "\n"
        oi = oi + 1
    }
    return out
}

// ── JSONL event emitter ──────────────────────────────────────────────────
fn escape_json(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "\\r")
    r = r.replace("\t", "\\t")
    return r
}

fn emit_event(kind: string, rm_id: string, payload: string, out_path: string) {
    let line = "{\"ts\":\"" + _ts_iso() + "\",\"roadmap\":\"" + escape_json(rm_id) + "\",\"kind\":\"" + escape_json(kind) + "\"," + payload + "}"
    if out_path == "" {
        println(line)
    } else {
        // ensure dir
        let mut last: i64 = -1
        let mut ii: i64 = 0
        while ii < out_path.len() {
            if out_path.substring(ii, ii + 1) == "/" { last = ii }
            ii = ii + 1
        }
        if last > 0 {
            let dir = out_path.substring(0, last)
            let _ = exec("mkdir -p '" + dir + "' 2>/dev/null")  // @allow-bare-exec
        }
        append_file(out_path, line + "\n")
    }
}

fn emit_schedule_events(rm: Roadmap, sched: ScheduleResult, out_path: string) {
    // Plan event
    let plan = "\"T_star\":" + to_string(sched.T_star) + ",\"bottleneck_node\":\"" + escape_json(sched.bottleneck_node) + "\",\"bottleneck_category\":\"" + escape_json(sched.bottleneck_category) + "\",\"bottleneck_cost\":" + to_string(sched.bottleneck_cost) + ",\"eta\":" + to_string(sched.eta_current) + ",\"progress\":" + to_string(sched.progress_frac) + ",\"replan_needed\":" + to_string(sched.replan_needed)
    emit_event("Plan", rm.id, plan, out_path)
    // NodeStart for each in_progress
    let mut i: i64 = 0
    while i < sched.in_progress.len() {
        let nid = _str(sched.in_progress[i])
        let ni = idx_of(rm.nodes, nid)
        if ni >= 0 {
            let n = rm.nodes[ni]
            let p = "\"node\":\"" + escape_json(n.id) + "\",\"type\":\"" + escape_json(n.ntype) + "\",\"progress\":" + to_string(n.progress)
            emit_event("NodeStart", rm.id, p, out_path)
        }
        i = i + 1
    }
    // NodeComplete for each done (most recent 3 only to avoid spam)
    let lim = if sched.done.len() > 3 { 3 } else { sched.done.len() }
    let mut k: i64 = 0
    let start_k = sched.done.len() - lim
    while k < lim {
        let idx = start_k + k
        let nid = _str(sched.done[idx])
        let ni = idx_of(rm.nodes, nid)
        if ni >= 0 {
            let n = rm.nodes[ni]
            let p = "\"node\":\"" + escape_json(n.id) + "\",\"type\":\"" + escape_json(n.ntype) + "\""
            emit_event("NodeComplete", rm.id, p, out_path)
        }
        k = k + 1
    }
    // BottleneckShift / Replan
    let p2 = "\"node\":\"" + escape_json(sched.bottleneck_node) + "\",\"category\":\"" + escape_json(sched.bottleneck_category) + "\",\"cost\":" + to_string(sched.bottleneck_cost)
    emit_event("BottleneckShift", rm.id, p2, out_path)
    if sched.replan_needed {
        let mut drop_list = ""
        let mut s: i64 = 0
        while s < sched.soft_drop_candidates.len() {
            if s > 0 { drop_list = drop_list + "," }
            drop_list = drop_list + "\"" + escape_json(_str(sched.soft_drop_candidates[s])) + "\""
            s = s + 1
        }
        let p3 = "\"eta\":" + to_string(sched.eta_current) + ",\"soft_drop_candidates\":[" + drop_list + "]"
        emit_event("Replan", rm.id, p3, out_path)
    }
}

// ── Blocking Min #12 hook: drain_while_wait ─────────────────────────────
// T_wall* = Σ b(S_k) + Σ max(0, τ_wait_k − r_k)  (r_k = drain candidates)
// Invariant: ∀t  |R(t)| ≥ 1  (ready or drain always non-empty while todo>0)
//
// Since schedule() only puts a node in ready_set when all its hard deps are
// done, and in_progress nodes already had their deps done when started,
// independence reduces to direct non-mutual-dependency: r ∉ w.deps ∧ w ∉ r.deps.
fn try_drain_while_wait(nodes: [Node], waiting_ids: [string], ready_ids: [string]) -> [string] {
    if waiting_ids.len() == 0 { return ready_ids }
    let mut out: [string] = []
    let mut i: i64 = 0
    while i < ready_ids.len() {
        let rid = _str(ready_ids[i])
        let ri = idx_of(nodes, rid)
        if ri < 0 { i = i + 1; continue }
        let r = nodes[ri]
        let mut independent: bool = true
        let mut w: i64 = 0
        while w < waiting_ids.len() && independent {
            let wid = _str(waiting_ids[w])
            let wi = idx_of(nodes, wid)
            if wi >= 0 {
                let wn = nodes[wi]
                // r depends on w?
                let mut k: i64 = 0
                while k < r.deps.len() {
                    if _str(r.deps[k]) == wid { independent = false; break }
                    k = k + 1
                }
                // w depends on r?
                if independent {
                    let mut kk: i64 = 0
                    while kk < wn.deps.len() {
                        if _str(wn.deps[kk]) == rid { independent = false; break }
                        kk = kk + 1
                    }
                }
            }
            w = w + 1
        }
        if independent { out = out.push(rid) }
        i = i + 1
    }
    return out
}

// ── dispatch plan (JSON output) ──────────────────────────────────────────
fn dispatch_plan(rm: Roadmap, sched: ScheduleResult) -> string {
    let mut ready_json = ""
    let mut i: i64 = 0
    while i < sched.ready_set.len() {
        if i > 0 { ready_json = ready_json + "," }
        ready_json = ready_json + "\"" + escape_json(_str(sched.ready_set[i])) + "\""
        i = i + 1
    }
    let mut inp_json = ""
    let mut j: i64 = 0
    while j < sched.in_progress.len() {
        if j > 0 { inp_json = inp_json + "," }
        inp_json = inp_json + "\"" + escape_json(_str(sched.in_progress[j])) + "\""
        j = j + 1
    }
    // Blocking Min #12: drain candidates during waits (invariant |R(t)| ≥ 1)
    let drain = try_drain_while_wait(rm.nodes, sched.in_progress, sched.ready_set)
    let mut drain_json = ""
    let mut d: i64 = 0
    while d < drain.len() {
        if d > 0 { drain_json = drain_json + "," }
        drain_json = drain_json + "\"" + escape_json(_str(drain[d])) + "\""
        d = d + 1
    }
    return "{\"roadmap\":\"" + escape_json(rm.id) + "\",\"goal\":\"" + escape_json(rm.goal) + "\",\"T_star\":" + to_string(sched.T_star) + ",\"bottleneck\":{\"node\":\"" + escape_json(sched.bottleneck_node) + "\",\"category\":\"" + escape_json(sched.bottleneck_category) + "\",\"cost\":" + to_string(sched.bottleneck_cost) + "},\"eta\":" + to_string(sched.eta_current) + ",\"progress\":" + to_string(sched.progress_frac) + ",\"replan_needed\":" + to_string(sched.replan_needed) + ",\"ready\":[" + ready_json + "],\"in_progress\":[" + inp_json + "],\"drain_while_wait\":[" + drain_json + "]}"
}

// ── selftest (mock parallel/failure/replan scenarios) ────────────────────
fn selftest() {
    println("[selftest] loading example.json")
    let path = ROADMAPS + "/example.json"
    if file_exists(path) == false {
        eprintln("REJECT: example missing: " + path)
        exit(3)
    }
    let rm = load_roadmap(path)
    println("[selftest] parsed nodes=" + to_string(rm.nodes.len()))
    let s = schedule(rm)
    println("[selftest] T*=" + fmt_min(s.T_star) + "  eta=" + fmt_eta(s.eta_current) + "  bn=" + s.bottleneck_node + "(" + s.bottleneck_category + ")  ready=" + to_string(s.ready_set.len()) + "  replan=" + to_string(s.replan_needed))
    println(render_flowchart(rm, s))
    println("[selftest] dispatch plan:")
    println(dispatch_plan(rm, s))
    println("[selftest] emitting events to /tmp/roadmap_selftest.jsonl")
    let ev = "/tmp/roadmap_selftest.jsonl"
    let _ = exec("rm -f " + ev)  // @allow-bare-exec
    emit_schedule_events(rm, s, ev)
    let tail = _str(exec("wc -l < " + ev + " 2>/dev/null")).trim()  // @allow-bare-exec
    println("[selftest] events appended: " + tail + " lines")
    println("[selftest] OK")
    exit(0)
}

// ── watchdog (N-tick interval re-read + re-render, default 5 ticks × 1s) ─
fn watch(path: string, interval_s: i64, events_path: string, max_ticks: i64) {
    let mut tick: i64 = 0
    let mt = if max_ticks <= 0 { 5 } else { max_ticks }
    // NEXUS_NO_CLEAR=1 → TTY 제거 안 함 (로그 수집)
    let keep_log = env("NEXUS_NO_CLEAR")
    while tick < mt {
        let rm = load_roadmap(path)
        let s = schedule(rm)
        if keep_log != "1" {
            let _ = exec("clear 2>/dev/null")  // @allow-bare-exec
        }
        println("═══ roadmap_engine watch  tick=" + to_string(tick + 1) + "/" + to_string(mt) + "  @ " + _ts_iso() + " ═══")
        println(render_flowchart(rm, s))
        if events_path != "" { emit_schedule_events(rm, s, events_path) }
        sleep(interval_s * 1000)
        tick = tick + 1
    }
}

// ── main ─────────────────────────────────────────────────────────────────
fn main() {
    let argv = args()
    // args() includes interp args — hexa 관례: 앞 2개 skip
    let mut a: [string] = []
    let mut ai: i64 = 2
    while ai < argv.len() {
        a = a.push(_str(argv[ai]))
        ai = ai + 1
    }

    if a.len() == 0 {
        // default: try env ROADMAP or example.json
        let env_rm = _str(env("ROADMAP"))
        let path = if env_rm != "" { env_rm } else { ROADMAPS + "/example.json" }
        if file_exists(path) == false {
            eprintln("usage: roadmap_engine <roadmap.json> [--watch] [--events=<out>] [--dispatch] [--selftest]")
            exit(2)
        }
        a = [path]
    }

    // flag parse
    let mut path = ""
    let mut watch_mode: bool = false
    let mut events: string = ""
    let mut dispatch_only: bool = false
    let mut selftest_mode: bool = false
    let mut interval_s: i64 = 1
    let mut k: i64 = 0
    while k < a.len() {
        let arg = _str(a[k])
        if arg == "--watch" { watch_mode = true }
        else if arg.starts_with("--events=") { events = arg.substring(9, arg.len()) }
        else if arg == "--dispatch" { dispatch_only = true }
        else if arg == "--selftest" { selftest_mode = true }
        else if arg.starts_with("--interval=") {
            let s = arg.substring(11, arg.len())
            interval_s = to_int(s)
            if interval_s < 1 { interval_s = 1 }
        }
        else if arg == "--help" || arg == "-h" {
            println("usage: roadmap_engine <roadmap.json> [--watch] [--events=<path>] [--dispatch] [--selftest]")
            exit(0)
        }
        else if arg.starts_with("--") {
            eprintln("WARN: unknown flag: " + arg)
        }
        else {
            if path == "" { path = arg }
        }
        k = k + 1
    }

    if selftest_mode { selftest() }

    if path == "" { path = ROADMAPS + "/example.json" }

    if watch_mode {
        // default: 5 ticks × interval_s
        watch(path, interval_s, events, 5)
        exit(0)
    }

    let rm = load_roadmap(path)
    let s = schedule(rm)

    if dispatch_only {
        println(dispatch_plan(rm, s))
        if events != "" { emit_schedule_events(rm, s, events) }
        exit(0)
    }

    // one-shot: render + optional events
    println(render_flowchart(rm, s))
    if events != "" { emit_schedule_events(rm, s, events) }

    // exit code based on divergence
    if s.replan_needed && s.ready_set.len() == 0 && s.in_progress.len() == 0 {
        eprintln("WARN: η ≤ 0 and nothing actionable — replan required")
        exit(1)
    }
    exit(0)
}

main()
