// handoff_write.hexa — 세션 handoff MD 생성 (이벤트/임계치 공통 writer)
// @no-lock-needed
// @no-sandbox
// 저장 위치: ~/.claude-claude10/projects/-<cwd-with-dashes>/memory/handoff-latest.md
// 내용: session_id, branch, HEAD, git delta, last-N user/assistant text, next-actions
//
// 호출: hexa handoff_write.hexa [reason]   reason ∈ commit|checkpoint|handoff|emergency|manual

let HOME = env("HOME")
let MEM_ROOT = HOME + "/.claude-claude10/projects"
let CONFIG = HOME + "/core/nexus/config/cli_budget.json"

fn cwd_to_dash(cwd: str) -> str {
    let mut s = ""
    let mut i = 0
    while i < cwd.len() {
        let ch = cwd.substring(i, i + 1)
        if ch == "/" { s = s + "-" } else { s = s + ch }
        i = i + 1
    }
    return s
}

fn cmd_out(cmd: str) -> str {
    return to_string(exec(cmd)).trim()
}

fn json_number(raw: str, key: str) -> i64 {
    let tag = "\"" + key + "\""
    if raw.contains(tag) == false { return 0 }
    let after = raw.split(tag)[1]
    let parts = after.split(":")
    if parts.len() < 2 { return 0 }
    let mut s = parts[1].trim()
    let mut end = 0
    while end < s.len() {
        let c = s.substring(end, end + 1)
        if c == "," || c == "}" || c == "\n" { break }
        end = end + 1
    }
    let num = s.substring(0, end).trim()
    return to_int(num)
}

fn get_tail_messages(jsonl_path: str, n: i64) -> str {
    if jsonl_path.len() == 0 { return "" }
    let cmd = "tail -n 200 '" + jsonl_path + "' 2>/dev/null"
    let raw = cmd_out(cmd)
    if raw.len() == 0 { return "" }
    let lines = raw.split("\n")
    let mut user_prompts = []
    let mut i = 0
    while i < lines.len() {
        let ln = lines[i]
        if ln.contains("\"type\":\"user\"") && ln.contains("\"content\"") {
            let c_idx = ln.split("\"content\":")
            if c_idx.len() >= 2 {
                let raw_c = c_idx[1]
                if raw_c.starts_with("\"") {
                    let inner = raw_c.split("\"")
                    if inner.len() >= 2 {
                        let text = inner[1]
                        if text.len() > 0 && text.len() < 500 {
                            user_prompts = user_prompts + [text]
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    let start = if user_prompts.len() > n { user_prompts.len() - n } else { 0 }
    let mut out = ""
    let mut j = start
    while j < user_prompts.len() {
        out = out + "- " + user_prompts[j] + "\n"
        j = j + 1
    }
    return out
}

fn main() {
    // args() returns [hexa_bin, script_path, user_arg1, ...]
    let args_list = args()
    let reason = if args_list.len() > 2 { args_list[2] } else { "manual" }

    let cwd = cmd_out("pwd")
    if cwd.len() == 0 { exit(0) }

    let dash = cwd_to_dash(cwd)
    let proj_dir = MEM_ROOT + "/" + dash
    let mem_dir = proj_dir + "/memory"

    // 메모리 디렉토리 없으면 skip (해당 프로젝트가 memory 시스템 쓰지 않음)
    if file_exists(mem_dir) == false { exit(0) }

    let handoff_path = mem_dir + "/handoff-latest.md"

    // 세션 JSONL (최신)
    let jsonl = cmd_out("ls -t " + proj_dir + "/*.jsonl 2>/dev/null | head -1")
    let session_id = if jsonl.len() > 0 {
        let base = cmd_out("basename '" + jsonl + "' .jsonl")
        base
    } else { "unknown" }

    // git state
    let branch = cmd_out("git rev-parse --abbrev-ref HEAD 2>/dev/null")
    let head = cmd_out("git log -1 --oneline 2>/dev/null")
    let dirty = cmd_out("git status --short 2>/dev/null | head -20")
    let diff_stat = cmd_out("git diff --stat HEAD 2>/dev/null | tail -20")

    // timestamp
    let ts = cmd_out("date -u +%Y-%m-%dT%H:%M:%SZ")

    // usage (last entry)
    let last_usage = cmd_out("grep -o '\"usage\":{[^}]*}' '" + jsonl + "' 2>/dev/null | tail -1")
    let in_tokens = json_number(last_usage, "input_tokens")
    let out_tokens = json_number(last_usage, "output_tokens")
    let cache_read = json_number(last_usage, "cache_read_input_tokens")
    let cache_create = json_number(last_usage, "cache_creation_input_tokens")

    // tail user prompts
    let tail_md = get_tail_messages(jsonl, 10)

    let mut md = "---\n"
    md = md + "name: Session handoff (latest)\n"
    md = md + "description: 자동 생성 handoff — " + reason + " 트리거 시점의 진행 상태. 다음 세션이 이어받을 스냅샷\n"
    md = md + "type: project\n"
    md = md + "updated: " + ts + "\n"
    md = md + "reason: " + reason + "\n"
    md = md + "session: " + session_id + "\n"
    md = md + "---\n\n"
    md = md + "## Session\n"
    md = md + "- ts: " + ts + "\n"
    md = md + "- reason: " + reason + "\n"
    md = md + "- session_id: " + session_id + "\n"
    md = md + "- cwd: " + cwd + "\n\n"
    md = md + "## Git\n"
    md = md + "- branch: " + branch + "\n"
    md = md + "- HEAD: " + head + "\n\n"
    md = md + "### dirty (git status --short, 상위 20)\n```\n" + dirty + "\n```\n\n"
    md = md + "### diff stat (vs HEAD, 하위 20)\n```\n" + diff_stat + "\n```\n\n"
    md = md + "## Usage (last entry)\n"
    md = md + "- input_tokens: " + to_string(in_tokens) + "\n"
    md = md + "- output_tokens: " + to_string(out_tokens) + "\n"
    md = md + "- cache_read: " + to_string(cache_read) + "\n"
    md = md + "- cache_creation: " + to_string(cache_create) + "\n\n"
    md = md + "## Last user prompts (tail 10)\n" + tail_md + "\n"
    md = md + "## Resume hint\n다음 세션 — 위 dirty 파일 + 최근 프롬프트 요약 참조. commit 안 된 변경 우선 검토.\n"

    write_file(handoff_path, md)

    // MEMORY.md 에 등록 (idempotent)
    let mem_index = mem_dir + "/MEMORY.md"
    if file_exists(mem_index) {
        let raw = read_file(mem_index)
        if raw.contains("handoff-latest.md") == false {
            append_file(mem_index, "- [Session handoff](handoff-latest.md) — 최근 세션 handoff (자동)\n")
        }
    }

    eprintln("HANDOFF-WRITE: " + handoff_path + " (" + reason + ")")
}

main()
