// signals_to_dot.hexa — A15
// atlas.signals.n6 → GraphViz .dot 파일 출력
// 노드: sig_id (색 = 등급) / edge: cross_repo 링크
// 실행: hexa run $NEXUS/tool/signals_to_dot.hexa [output=/tmp/signals.dot]

let HOME = env("HOME")
let NEXUS = HOME + "/core/nexus"
let SIGNALS = NEXUS + "/n6/atlas.signals.n6"
let DEFAULT_OUT = NEXUS + "/n6/signals/atlas.signals.n6.dot"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn now_iso() -> string {
    let r = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    return _str(r).trim()
}

fn shell_quote(s: string) -> string {
    let escaped = s.replace("'", "'\\''")
    return "'" + escaped + "'"
}

// grade → color
fn grade_color(grade_line: string) -> string {
    if grade_line.contains("[M10*]") { return "gold" }
    if grade_line.contains("[M10]") { return "green" }
    if grade_line.contains("[M9]") { return "cyan" }
    if grade_line.contains("[M7!]") { return "red" }
    if grade_line.contains("[M7]") { return "orange" }
    if grade_line.contains("[MN]") { return "gray" }
    return "white"
}

// repo tag (간이 — NX/N6/AN/CROSS)
fn repo_tag(line: string) -> string {
    if line.contains("[CROSS") { return "CROSS" }
    if line.contains("[NX") { return "NX" }
    if line.contains("[N6") { return "N6" }
    if line.contains("[AN") { return "AN" }
    return "?"
}

// ─── 메인 ───
let a = args()
let mut out_path = DEFAULT_OUT
if a.len() >= 3 { out_path = a[2] }

println("signals_to_dot: out=" + out_path + " ts=" + now_iso())

if file_exists(SIGNALS) == false {
    println("  FAIL: signals 없음")
    exit(1)
}

// 전체 @S 라인 읽기
let head_cmd = "grep '^@S ' '" + SIGNALS + "'"
let r = exec(head_cmd)
let text = _str(r)
let lines = text.split("\n")

let mut node_count: i64 = 0
let mut edge_count: i64 = 0

let mut dot = "digraph atlas_signals {\n"
dot = dot + "  rankdir=LR;\n"
dot = dot + "  node [shape=box, style=filled, fontsize=9];\n"
dot = dot + "  edge [color=\"#888888\"];\n"
dot = dot + "  label=\"atlas.signals.n6 — " + now_iso() + "\";\n"
dot = dot + "  labelloc=t;\n\n"

// 노드들
let mut i = 0
let mut sig_ids: [string] = []
while i < lines.len() {
    let line = _str(lines[i]).trim()
    if line == "" { i = i + 1; continue }
    // "@S SIG-... = ..."
    let parts = line.split(" ")
    if parts.len() < 3 { i = i + 1; continue }
    let sid = _str(parts[1])
    if sid == "" { i = i + 1; continue }
    sig_ids = sig_ids + [sid]

    let color = grade_color(line)
    let repo = repo_tag(line)
    // id 에 안전한 dot 식별자 변환 (- → _)
    let dot_id = sid.replace("-", "_")
    dot = dot + "  " + dot_id + " [label=\"" + sid + "\\n[" + repo + "]\", fillcolor=" + color + "];\n"
    node_count = node_count + 1
    i = i + 1
}

dot = dot + "\n"

// edges — cross_repo: [...] 라인 파싱 (블록 단위)
// grep 로 "cross_repo: " 라인만 추출해서 parent sig_id 매핑은 awk 로 블록
let awk_cmd = "awk '" +
  "/^@S / { id = $2; next } " +
  "/cross_repo:/ { " +
  "  match($0, /\\[[^\\]]+\\]/); if (RLENGTH > 2) { " +
  "    s = substr($0, RSTART+1, RLENGTH-2); " +
  "    gsub(/ /, \"\", s); " +
  "    n = split(s, arr, \",\"); " +
  "    for (k=1; k<=n; k++) if (arr[k] != \"\") print id \"\\t\" arr[k] " +
  "  } " +
  "}' '" + SIGNALS + "'"
let er = exec(awk_cmd)
let elines = _str(er).split("\n")

let mut ei = 0
while ei < elines.len() {
    let line = _str(elines[ei]).trim()
    if line == "" { ei = ei + 1; continue }
    let parts = line.split("\t")
    if parts.len() >= 2 {
        let a2 = _str(parts[0]).replace("-", "_")
        let b2 = _str(parts[1]).replace("-", "_")
        if a2 != "" && b2 != "" {
            dot = dot + "  " + a2 + " -> " + b2 + ";\n"
            edge_count = edge_count + 1
        }
    }
    ei = ei + 1
}

dot = dot + "}\n"

try {
    write_file(out_path, dot)
    println("  PASS nodes=" + to_string(node_count) + " edges=" + to_string(edge_count))
    println("  view: dot -Tpng " + out_path + " -o /tmp/signals.png")
} catch e {
    println("  FAIL: write error")
    exit(1)
}
