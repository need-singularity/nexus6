#!hexa strict
// tool/check_router.hexa — nexus check 분야 dispatcher (다중 도메인 fan-out + 결과 집계)
//
// @tool(slug="check_router", desc="multi-domain verification dispatcher (math/physics/bio/sim/qrng/brain/consciousness/phi/learning/phenomenology/law/integrity/meta)")
// @usage(HEXA_ARGV='--physics --conservation' hexa run tool/check_router.hexa)
// @exit_codes(0=PASS, 1=usage, 2=verify FAIL)
// @sentinel(__NEXUS_CHECK__ <PASS|FAIL> math=<R> physics=<R> bio=<R> sim=<R> qrng=<R> brain=<R> consciousness=<R> phi=<R> learning=<R> phenomenology=<R> law=<R> integrity=<R> meta=<R>)
//
// 재귀 spec: shared/n6/docs/meta_atlas_recursive.md
//   - Level 0 (atlas.n6): 검증 결과 witness append 대상
//   - Level 1 (meta_atlas.n6): 분야별 PASS율·횟수가 메타엔트리 후보
// ai-native doc: shared/docs/nexus_check.ai.md
// 3-tier: core(engine/nexus_cli.hexa cmd_check) ← module(this + check_<domain>.hexa) ← ai-native doc

fn _argv() -> array {
    let raw = to_string(exec("printf '%s' \"${HEXA_ARGV:-}\""))
    let parts = split(raw, " ")
    let mut out = []
    let mut k = 0
    while k < len(parts) {
        if len(parts[k]) > 0 { out.push(parts[k]) }
        k = k + 1
    }
    return out
}

fn _has(a: array, f: string) -> bool {
    let mut i = 0
    while i < len(a) {
        if a[i] == f { return true }
        i = i + 1
    }
    return false
}

let NEXUS = "/Users/ghost/core/nexus"

let DOMAINS = ["math", "physics", "bio", "sim", "qrng", "brain",
               "consciousness", "phi", "learning", "phenomenology",
               "law", "integrity", "meta"]

fn run_domain(domain: string, fwd: string, quiet: bool) -> string {
    let path = NEXUS + "/tool/check_" + domain + ".hexa"
    if !file_exists(path) {
        if !quiet { println("[" + domain + "] SKIP (backend not implemented)") }
        return "SKIP"
    }
    let mut hxa = fwd
    if quiet {
        if len(hxa) > 0 { hxa = hxa + " " }
        hxa = hxa + "--quiet"
    }
    let cmd = "HEXA_ARGV='" + hxa + "' hexa run " + path + " 2>&1"
    let out = to_string(exec(cmd))
    if !quiet { println(out.trim()) }
    let lines = split(out, "\n")
    let mut last = ""
    for l in lines {
        let tl = l.trim()
        if len(tl) > 0 { last = tl }
    }
    if last.index_of("PASS") >= 0 { return "PASS" }
    if last.index_of("FAIL") >= 0 { return "FAIL" }
    return "FAIL"
}

let ARGS = _argv()
let QUIET = _has(ARGS, "--quiet")

if _has(ARGS, "--help") || _has(ARGS, "-h") {
    println("usage: HEXA_ARGV='[domain flags] [sub flags]' hexa run tool/check_router.hexa")
    println("  domains: --math --physics --bio --sim --qrng --brain")
    println("           --consciousness --phi --learning --phenomenology --law --integrity --meta")
    println("           --all (default if none specified)")
    println("  sub flags forwarded to backend (e.g., --dimensional --conservation --anchor)")
    println("  output: __NEXUS_CHECK__ <PASS|FAIL> dom1=<R> dom2=<R> ...")
    return
}

// 선택된 도메인 수집
let mut selected = []
let mut i = 0
while i < len(DOMAINS) {
    let d = DOMAINS[i]
    if _has(ARGS, "--" + d) { selected.push(d) }
    i = i + 1
}

let do_all = _has(ARGS, "--all") || (len(selected) == 0)
if do_all {
    selected = []
    let mut k = 0
    while k < len(DOMAINS) {
        selected.push(DOMAINS[k])
        k = k + 1
    }
}

// 도메인/제어 플래그 제외 후 sub-flag forwarding
let mut fwd = ""
let mut j = 0
while j < len(ARGS) {
    let arg = ARGS[j]
    let mut is_meta = false
    if arg == "--all" || arg == "--quiet" || arg == "--json" || arg == "--help" || arg == "-h" {
        is_meta = true
    }
    let mut m = 0
    while m < len(DOMAINS) {
        if arg == "--" + DOMAINS[m] { is_meta = true }
        m = m + 1
    }
    if !is_meta {
        if len(fwd) > 0 { fwd = fwd + " " }
        fwd = fwd + arg
    }
    j = j + 1
}

let mut results = []
let mut overall_pass = true
let mut s = 0
while s < len(selected) {
    let dom = selected[s]
    let r = run_domain(dom, fwd, QUIET)
    results.push(dom + "=" + r)
    if r == "FAIL" { overall_pass = false }
    s = s + 1
}

let mut verdict = "PASS"
if !overall_pass { verdict = "FAIL" }
let mut sline = "__NEXUS_CHECK__ " + verdict
let mut k2 = 0
while k2 < len(results) {
    sline = sline + " " + results[k2]
    k2 = k2 + 1
}
println(sline)
if !overall_pass { exit(2) }
