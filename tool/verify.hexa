// verify.hexa — 하네스 verify 라우터 (검증 기능 통합, 본문 위임)
// @allow-bare-exec
// @no-sandbox
// modes: list | v-const | sync-diff | atlas [--verbose] | all [--verbose]
// delegates:
//   v-const   → shared/tool/lint.hexa --all  (stderr grep "V-CONST")
//   sync-diff → shared/tool/sync.hexa diff
//   atlas     → shared/n6/atlas_health.hexa
// 원칙: 본체 4개 (.hexa) 는 read-only, 라우팅만 담당

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let HEXA = NEXUS + "/bin/hexa"
let LINT = NEXUS + "/tool/lint.hexa"
let SYNC = NEXUS + "/tool/sync.hexa"
let ATLAS_HEALTH = NEXUS + "/n6/atlas_health.hexa"

fn print_list() {
    println("verify modes:")
    println("  v-const    — verified_constants.jsonl 직접 write 차단 (lint V-CONST 룰) → " + LINT)
    println("  sync-diff  — sync src vs dst hash drift 리포트 → " + SYNC + " diff")
    println("  atlas      — atlas.n6 formula/orphan/dup 헬스체크 → " + ATLAS_HEALTH)
    println("  all        — 위 3종 순차 실행, PASS/FAIL 집계")
    println("  list       — 이 목록")
    println("flags: --verbose|-v")
}

fn run_v_const(rest: [str]) -> i64 {
    if file_exists(LINT) == false {
        eprintln("REJECT: lint not found: " + LINT)
        return 2
    }
    let mut verbose = false
    for a in rest {
        if a == "--verbose" || a == "-v" { verbose = true }
    }
    // lint.hexa 는 rule 필터 미지원 → --all 실행 후 stderr 에서 "V-CONST" 만 추출
    let cmd = HEXA + " run " + LINT + " --all 2>&1 | grep 'V-CONST' || true"
    let out = to_string(exec(cmd))  // @allow-bare-exec
    let trimmed = out.trim()
    if verbose {
        println("=== verify:v-const ===")
        println("  delegate:  " + LINT + " --all (filter: V-CONST)")
    }
    if trimmed.len() == 0 {
        if verbose { println("  status:    OK (0 violations)") }
        return 0
    }
    // violations 있음 — 출력 후 반환
    print(out)
    let lines = trimmed.split("\n")
    let mut cnt = 0
    for _l in lines { cnt = cnt + 1 }
    if verbose { println("  status:    WARN (" + to_string(cnt) + " hits)") }
    // V-CONST 는 warn 레벨 — exit 1 (실패로 집계하되 block 아님)
    return 1
}

fn run_sync_diff(rest: [str]) -> i64 {
    if file_exists(SYNC) == false {
        eprintln("REJECT: sync not found: " + SYNC)
        return 2
    }
    let mut verbose = false
    for a in rest {
        if a == "--verbose" || a == "-v" { verbose = true }
    }
    let cmd = HEXA + " run " + SYNC + " diff 2>&1"
    let out = to_string(exec(cmd))  // @allow-bare-exec
    if out.trim().len() > 0 { print(out) }
    // drift 검출 시 1, 전부 same 이면 0
    if out.contains(" drift ") {
        if verbose { println("  status:    WARN (drift detected)") }
        return 1
    }
    if verbose { println("  status:    OK (no drift)") }
    return 0
}

fn run_atlas(rest: [str]) -> i64 {
    if file_exists(ATLAS_HEALTH) == false {
        eprintln("REJECT: atlas_health not found: " + ATLAS_HEALTH)
        return 2
    }
    let mut cmd = HEXA + " run " + ATLAS_HEALTH
    for a in rest {
        let safe = a.replace("\"", "\\\"")
        cmd = cmd + " \"" + safe + "\""
    }
    let out = to_string(exec(cmd + " 2>&1"))  // @allow-bare-exec
    if out.trim().len() > 0 { print(out) }
    // atlas_health 판정 마커 (health.hexa 와 동일 기준)
    if out.contains("real orphans:  0") && out.contains("dup data lines:0") && out.contains("malformed:     0") && out.contains("formula errors:0") {
        return 0
    }
    return 1
}

fn run_all(rest: [str]) -> i64 {
    println("=== verify:all ===")
    println("--- [1/3] v-const ---")
    let c1 = run_v_const(rest)
    println("")
    println("--- [2/3] sync-diff ---")
    let c2 = run_sync_diff(rest)
    println("")
    println("--- [3/3] atlas ---")
    let c3 = run_atlas(rest)
    println("")
    // 집계 — 각 34/33/33 총 100
    let s1 = if c1 == 0 { 34 } else { 0 }
    let s2 = if c2 == 0 { 33 } else { 0 }
    let s3 = if c3 == 0 { 33 } else { 0 }
    let total = s1 + s2 + s3
    println("=== summary ===")
    println("  v-const:   " + (if c1 == 0 { "OK" } else { "WARN" }) + " (" + to_string(s1) + "/34)")
    println("  sync-diff: " + (if c2 == 0 { "OK" } else { "WARN" }) + " (" + to_string(s2) + "/33)")
    println("  atlas:     " + (if c3 == 0 { "OK" } else { "WARN" }) + " (" + to_string(s3) + "/33)")
    println("  total:     " + to_string(total) + "/100")
    if total == 100 { return 0 }
    return 1
}

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    if argv.len() < 3 {
        print_list()
        return
    }
    let mode = argv[2].trim().to_lower()
    let mut rest = []
    let mut i = 3
    while i < argv.len() {
        rest = rest.push(argv[i])
        i = i + 1
    }
    if mode == "list" || mode == "-h" || mode == "--help" || mode == "help" {
        print_list()
        return
    }
    if mode == "v-const" {
        let c = run_v_const(rest)
        exit(c)
    }
    if mode == "sync-diff" {
        let c = run_sync_diff(rest)
        exit(c)
    }
    if mode == "atlas" {
        let c = run_atlas(rest)
        exit(c)
    }
    if mode == "all" {
        let c = run_all(rest)
        exit(c)
    }
    eprintln("REJECT: unknown mode '" + mode + "' — modes: list|v-const|sync-diff|atlas|all")
    exit(2)
}

main()
