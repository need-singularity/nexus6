// signal_meta_retroactive_tag.hexa — K3 Retroactive tag
// 신규 태그 (예: RESONATE, FUSION-CANDIDATE) 를 기존 signals 에 재부착 제안
// dry-run: grep 매칭 결과만 staging append, 실제 atlas 수정 없음
// 실행: hexa run $NEXUS/tool/signal_meta_retroactive_tag.hexa

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let SIGNALS = NEXUS + "/n6/atlas.signals.n6"
let STAGE = NEXUS + "/n6/staging/atlas.signals.staging.meta.n6"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    let mut v: i64 = 0
    try { v = to_int(first) } catch e { v = 0 }
    return v
}

fn now_iso() -> string {
    let r = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    return _str(r).trim()
}

fn grep_count(pat: string) -> i64 {
    let cmd = "{ grep -c -E '" + pat + "' '" + SIGNALS + "' 2>/dev/null || true; }"
    let r = exec(cmd)
    return _to_int0(_str(r).trim().split("\n")[0])
}

if file_exists(SIGNALS) == false {
    println("FAIL: atlas.signals.n6 없음")
    exit(1)
}

println("signal_meta_retroactive_tag: " + now_iso())

// 제안 태그 1: RESONATE (resonance_n6 이 null 아닌 signals)
let resonate_count = grep_count("resonance_n6: \"")
println("  RESONATE 후보 (resonance_n6 보유) = " + to_string(resonate_count))

// 제안 태그 2: PREDICTS-UNVERIFIED (predicts 있지만 [M7]/[M?] 등급)
let pred_m7 = grep_count("^@S .*\\[M7\\] ")
println("  PREDICTS-UNVERIFIED 후보 [M7] = " + to_string(pred_m7))

// 제안 태그 3: FUSION-CANDIDATE (cross_repo 있지만 [CROSS] tag 없음)
let cross_field = grep_count("^  cross_repo:")
let cross_tag = grep_count("^@S .*\\[CROSS")
let fusion_cand = cross_field - cross_tag
if fusion_cand < 0 { let fusion_cand = 0 }
println("  FUSION-CANDIDATE 후보 (cross_repo 필드 - CROSS tag) = " + to_string(fusion_cand))

let sig_id = "SIG-META-702"
let stmt = "retroactive tag 제안 3종: RESONATE=" + to_string(resonate_count) + " PREDICTS-UNV=" + to_string(pred_m7) + " FUSION-CAND=" + to_string(fusion_cand)

let block = "@S " + sig_id + " = " + stmt + " :: signal [NX,CROSS] [META,GAP] [M7] [E2]\n" +
            "  \"K3 retroactive tag. 기존 signals 에 신규 태그 재부착 dry-run. 실제 atlas 수정 없이 후보만 집계\"\n" +
            "  refs: [nexus:shared/tool/signal_meta_retroactive_tag.hexa]\n" +
            "  predicts: [\"RESONATE 태그 적용 시 M9+ 80% 이상\", \"FUSION-CAND 적용 시 [CROSS] tag 21건 추가\"]\n" +
            "  witness: 1\n" +
            "  resonance_n6: null\n" +
            "  discovered_in: nexus/session-meta-k3\n" +
            "  discovered_at: " + now_iso() + "\n" +
            "  <- K3 retroactive tag autonomous\n\n"

let cmd = "cat >> '" + STAGE + "' << 'EOF'\n" + block + "EOF"
exec(cmd)
println("  → staging append: " + STAGE)
println("PASS: K3 retroactive tag 제안 기록")
