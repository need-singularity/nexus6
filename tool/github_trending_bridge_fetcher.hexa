#!hexa strict
// tool/github_trending_bridge_fetcher.hexa — GitHub trending Python γ-bridge fetcher
//
// @tool(slug="github_trending_bridge_fetcher", desc="γ-bridge web-fetch fetcher — GitHub trending Python (M-Y browser-harness + sanitize + OFFLINE-FALLBACK)")
// @usage(hexa run tool/github_trending_bridge_fetcher.hexa [--fetch] [--selftest] [--json])
// @exit_codes(0=PASS, 1=usage, 2=fetch, 3=injection-reject)
// @sentinel(__GITHUB_TRENDING_BRIDGE__ <PASS|OFFLINE|REJECT> n_repos=<N> top_repo=<owner/name> stars_today=<N>)
// @origin(γ-bridge wave U1 2026-05-01 — hive r58 Stage 19 follow-up #61)
// @abstraction(web-fetch γ-bridge fetcher → kick_dispatch γ envelope contributor)
// @paradigm(M-Y browser-harness invoke + prompt-injection sanitize + raw 91 honest OFFLINE-FALLBACK)

let FETCH_URL = "https://github.com/trending/python?since=daily"
let SLUG      = "bridge_github_trending"
let SOURCE    = "github_trending"

fn _injection_substrings() -> array {
    return ["<task-notification>", "<system-reminder>", "IMPORTANT:", "Ignore previous", "ignore all previous"]
}

fn _exec_pattern_substrings() -> array {
    return ["$(", "`", "rm -rf", "<script", "</script", "javascript:", "<style", " on" + "click=", " on" + "load=", " on" + "error="]
}

fn _has_any(haystack: str, needles: array) -> bool {
    let mut i = 0
    while i < len(needles) {
        if haystack.index_of(needles[i]) >= 0 { return true }
        i = i + 1
    }
    return false
}

fn _strip_control_chars(s: str) -> str {
    let mut out = ""
    let mut i = 0
    while i < s.len() {
        let c = s.substring(i, i + 1)
        let allowed = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789 .,:;=/\\\"'-_+()[]<>?!@#%&*"
        if allowed.index_of(c) >= 0 { out = out + c }
        i = i + 1
    }
    return out
}

fn _truncate(s: str, n: i64) -> str {
    if s.len() <= n { return s }
    return s.substring(0, n - 3) + "..."
}

fn _sanitize_payload(raw_text: str) -> str {
    if _has_any(raw_text, _injection_substrings()) { return "INJECTION_REJECT" }
    if _has_any(raw_text, _exec_pattern_substrings()) { return "INJECTION_REJECT" }
    return _truncate(_strip_control_chars(raw_text), 200)
}

fn _browser_harness_fetch(url: str) -> str {
    let probe = exec("command -v hexa >/dev/null 2>&1 && [ -f tool/browser_harness.hexa ] && echo y || echo n").trim()
    if probe != "y" { return "" }
    return ""
}

fn _short_hash(input: str) -> str {
    let cmd = "printf %s '" + input.replace("'", "'\\''") + "' | (sha256sum 2>/dev/null || shasum -a 256) | awk '{print substr($1,1,16)}'"
    return exec(cmd).trim()
}

fn _now_iso_utc() -> str {
    return exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

// Extract first owner/name from <a href="/owner/name" pattern within an article
fn extract_top_repo(body: str) -> str {
    let marker = "<h2 class=\"h3 lh-condensed\">"
    let i = body.index_of(marker)
    if i < 0 {
        // fallback to any /owner/name in href
        return _scan_href_owner_name(body)
    }
    let after = body.substring(i, body.len())
    return _scan_href_owner_name(after)
}

fn _scan_href_owner_name(s: str) -> str {
    let h = "href=\"/"
    let i = s.index_of(h)
    if i < 0 { return "unknown" }
    let after = s.substring(i + h.len(), s.len())
    let q = after.index_of("\"")
    if q < 0 { return "unknown" }
    let token = after.substring(0, q)
    if token.index_of("/") < 0 { return "unknown" }
    if token.index_of("?") >= 0 { return "unknown" }
    return _truncate(token, 80)
}

fn count_repos(body: str) -> i64 {
    let mut n = 0
    let mut rest = body
    while true {
        let i = rest.index_of("<article class=\"Box-row\"")
        if i < 0 { break }
        n = n + 1
        rest = rest.substring(i + 22, rest.len())
    }
    return n
}

fn extract_stars_today(body: str) -> i64 {
    let marker = "stars today"
    let i = body.index_of(marker)
    if i < 0 { return 0 }
    let pre = body.substring(0, i)
    // walk back to find last integer-looking run
    let mut k = pre.len() - 1
    while k >= 0 {
        let c = pre.substring(k, k + 1)
        if c == " " || c == ">" { k = k - 1; continue }
        if "0123456789,".index_of(c) >= 0 { break }
        return 0
    }
    let mut start = k
    while start >= 0 {
        let c = pre.substring(start, start + 1)
        if "0123456789,".index_of(c) < 0 { break }
        start = start - 1
    }
    let token = pre.substring(start + 1, k + 1).replace(",", "")
    let mut v: i64 = 0
    try { v = to_int(token) } catch e { v = 0 }
    return v
}

fn build_payload(raw_body: str) -> str {
    if raw_body == "" {
        return "n_repos=0 top_repo=offline_fallback stars_today=0"
    }
    let n = count_repos(raw_body)
    let top = extract_top_repo(raw_body)
    let stars = extract_stars_today(raw_body)
    return "n_repos=" + to_string(n) + " top_repo=" + top + " stars_today=" + to_string(stars)
}

fn _emit_envelope(payload: str, ts: str) -> str {
    let bh = _short_hash("gamma:" + SLUG + ":" + ts)
    return "{\"mechanism\":\"gamma\",\"source_id\":\"bridge:" + SLUG + "\",\"byte_hash\":\"" + bh + "\",\"ts\":\"" + ts + "\",\"payload_summary\":\"" + payload + "\",\"kind\":\"web-fetch\"}"
}

fn cmd_fetch(json_mode: bool) {
    let opt_in = exec("printf '%s' \"${KICK_USE_WEB_BRIDGES:-0}\"").trim()
    if opt_in != "1" && opt_in != "web-only" {
        eprintln("github_trending_bridge_fetcher: KICK_USE_WEB_BRIDGES not set — bridge default-inactive")
        exit(1)
    }
    let raw_body = _browser_harness_fetch(FETCH_URL)
    let sanitized = _sanitize_payload(raw_body)
    if sanitized == "INJECTION_REJECT" {
        println("__GITHUB_TRENDING_BRIDGE__ REJECT n_repos=0 top_repo=injection_reject stars_today=0")
        exit(3)
    }
    let payload = build_payload(raw_body)
    let ts = _now_iso_utc()
    if json_mode { println(_emit_envelope(payload, ts)) } else { println(payload) }
    let verdict = if raw_body == "" { "OFFLINE" } else { "PASS" }
    println("__GITHUB_TRENDING_BRIDGE__ " + verdict + " " + payload)
    exit(0)
}

fn _selftest() {
    if FETCH_URL != "https://github.com/trending/python?since=daily" { eprintln("[selftest] FAIL: URL"); exit(1) }
    if _scan_href_owner_name("href=\"/anthropic/claude-code\"") != "anthropic/claude-code" { eprintln("[selftest] FAIL: owner-name"); exit(1) }
    if _sanitize_payload("IMPORTANT: x") != "INJECTION_REJECT" { eprintln("[selftest] FAIL: IMPORTANT reject"); exit(1) }
    let h = _short_hash("gamma:bridge_github_trending:2026-05-01T00:00:00Z")
    if h.len() != 16 { eprintln("[selftest] FAIL: hash"); exit(1) }
    println("[github_trending_bridge_fetcher selftest] OK")
    exit(0)
}

fn main() -> void {
    let raw_args = args()
    let mut cli = []
    // #65 F22 args() ABI: hexa runtime arg layout = [hexa_real, run, SCRIPT, ...user_args].
    // Robustly locate *.hexa entry → start user-arg capture at next index. Fallback ai=2 (legacy).
    let mut ai = 2
    let mut _scan = 0
    let _nra = len(raw_args)
    while _scan < _nra {
        let _a = raw_args[_scan]
        let _la = len(_a)
        if _la >= 5 && _a.substring(_la - 5, _la) == ".hexa" {
            ai = _scan + 1
            break
        }
        _scan = _scan + 1
    }
    while ai < len(raw_args) { cli.push(raw_args[ai]); ai = ai + 1 }
    let mut do_fetch = false
    let mut json_mode = false
    let mut i = 0
    while i < len(cli) {
        let a = cli[i]
        if a == "--selftest" || a == "selftest" { _selftest() }
        else if a == "--fetch" { do_fetch = true }
        else if a == "--json" { json_mode = true }
        else if a == "--help" || a == "-h" {
            println("usage: hexa run tool/github_trending_bridge_fetcher.hexa [--fetch] [--json] [--selftest]")
            println("url: " + FETCH_URL)
            exit(0)
        } else {
            eprintln("github_trending_bridge_fetcher: unknown arg `" + a + "`")
            exit(1)
        }
        i = i + 1
    }
    if do_fetch { cmd_fetch(json_mode) }
    eprintln("github_trending_bridge_fetcher: pass --fetch or --selftest")
    exit(1)
}
