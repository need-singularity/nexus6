#!hexa strict
// tool/check_brain.hexa — nexus check 뇌 분야 백엔드 (hexa-brain external sibling wrapper)
//
// @tool(slug="check_brain", desc="brain domain — wraps hexa-brain external sibling CLI selftest aggregator + jsonl-audit")
// @usage(HEXA_ARGV='' hexa run tool/check_brain.hexa)
// @exit_codes(0=PASS, 1=usage, 2=verify FAIL)
// @sentinel(__NEXUS_CHECK_BRAIN__ <PASS|FAIL> eeg_selftest=<R> jsonl_audit=<R>)
// @origin(hexa-brain external sibling wrapper — see docs/nexus_check.ai.md migration policy)
//
// hexa-brain repo 본체는 read-only — 본 파일은 cross-repo exec wrapper 로만 작동.
// 동작 모델:
//   1) hexa-brain/bin/hexa-brain eeg selftest   →  8 backend synthetic selftest
//      성공 sentinel = "verdict: ALL_BACKENDS_SELFTEST_PASS" (rc=0)
//   2) hexa-brain/bin/hexa-brain core jsonl-audit --selftest
//      성공 sentinel = "selftest: OK" (rc=0)
// hexa-brain 가 외부 sibling 부재/비실행 가능 시 SKIP 반환.

fn _argv() -> array {
    let raw = to_string(exec("printf '%s' \"${HEXA_ARGV:-}\""))
    let parts = split(raw, " ")
    let mut out = []
    let mut k = 0
    while k < len(parts) { if len(parts[k]) > 0 { out.push(parts[k]) }; k = k + 1 }
    return out
}

fn _has(a: array, f: string) -> bool {
    let mut i = 0
    while i < len(a) { if a[i] == f { return true }; i = i + 1 }
    return false
}

let HEXA_BRAIN = "/Users/ghost/core/hexa-brain"
let HEXA_BRAIN_BIN = HEXA_BRAIN + "/bin/hexa-brain"
let ARGS = _argv()
let QUIET = _has(ARGS, "--quiet")

// hexa-brain CLI sub-verb 실행 → stdout/stderr 검사 후 sentinel 매칭.
// PASS_SENTINEL 이 stdout 어디에든 존재해야 PASS (rc==0 보강 조건).
fn _wrap_brain_cli(verb_args: string, pass_sentinel: string, quiet: bool) -> string {
    if !file_exists(HEXA_BRAIN_BIN) { return "SKIP" }
    let cmd = HEXA_BRAIN_BIN + " " + verb_args + " 2>&1"
    let out = to_string(exec(cmd))
    if !quiet { println(out.trim()) }
    if out.index_of(pass_sentinel) >= 0 { return "PASS" }
    return "FAIL"
}

// ─── eeg selftest aggregator (8 backends synthetic) ─────────────────
//   verdict: ALL_BACKENDS_SELFTEST_PASS  ← canonical pass token
let r_eeg = _wrap_brain_cli("eeg selftest", "ALL_BACKENDS_SELFTEST_PASS", QUIET)

// ─── core jsonl-audit selftest (ledger contract verifier) ───────────
//   selftest: OK  ← canonical pass token
let r_audit = _wrap_brain_cli("core jsonl-audit --selftest", "selftest: OK", QUIET)

let mut overall = "PASS"
if r_eeg == "FAIL" || r_audit == "FAIL" { overall = "FAIL" }
println("__NEXUS_CHECK_BRAIN__ " + overall + " eeg_selftest=" + r_eeg + " jsonl_audit=" + r_audit)
if overall == "FAIL" { exit(2) }
