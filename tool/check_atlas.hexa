#!hexa strict
// tool/check_atlas.hexa — nexus check atlas 도메인 백엔드
//
// @tool(slug="check_atlas", desc="atlas.n6 axis-M anchor surface inspection + drift detection")
// @usage(HEXA_ARGV='' hexa run tool/check_atlas.hexa)
// @exit_codes(0=PASS, 1=usage, 2=verify FAIL)
// @sentinel(__NEXUS_CHECK_ATLAS__ <PASS|FAIL> entries=<N> axis_m=<N> shards=<N>)
//
// Read-only atlas.n6 + atlas.append.* inspection. Reports:
//   - total typed-value entries (@P/@C/@L/@F/@R/@?/@X/@S)
//   - axis-M attributed entries (carry unit= + anchor= continuation rows)
//   - shard count
//   - drift detection: anima D4 capacity-ratio "7.7x" vs corrected 1.547x
//
// LLM judge 금지 — deterministic grep/wc only.
// circular-trap-free: target counts come from atlas (single source) — but
// each atlas entry's own anchor= field traces to an external authority,
// so atlas-of-atlas inspection is structurally non-circular.

fn _argv() -> array {
    let raw = to_string(exec("printf '%s' \"${HEXA_ARGV:-}\""))
    let parts = split(raw, " ")
    let mut out = []
    let mut k = 0
    while k < len(parts) { if len(parts[k]) > 0 { out.push(parts[k]) }; k = k + 1 }
    return out
}

fn _has(a: array, f: string) -> bool {
    let mut i = 0
    while i < len(a) { if a[i] == f { return true }; i = i + 1 }
    return false
}

let HOME = env("HOME")
let ATLAS_DIR = HOME + "/core/n6-architecture/atlas"
let ARGS = _argv()
let QUIET = _has(ARGS, "--quiet")

fn _exists(p: string) -> bool { return file_exists(p) }

let total_cmd = "grep -hcE '^@[PCLFRSX?] ' " + ATLAS_DIR + "/atlas.n6 " + ATLAS_DIR + "/atlas.append.*.n6 2>/dev/null | awk -F: '{s+=$1} END{print s+0}'"
let axis_m_cmd = "grep -hcE '^  anchor[ ]*=' " + ATLAS_DIR + "/atlas.append.*.n6 2>/dev/null | awk -F: '{s+=$1} END{print s+0}'"
let shard_cmd = "ls " + ATLAS_DIR + "/atlas.append.*.n6 2>/dev/null | wc -l"

let total_str = to_string(exec(total_cmd)).trim()
let axis_m_str = to_string(exec(axis_m_cmd)).trim()
let shard_str = to_string(exec(shard_cmd)).trim()

let total = to_int(total_str)
let axis_m = to_int(axis_m_str)
let shards = to_int(shard_str)

// Drift detection: known D4 capacity-ratio drift (atlas records both)
let drift_cmd = "grep -l 'd4-evidence-capacity-ratio-corrected' " + ATLAS_DIR + "/atlas.append.*.n6 2>/dev/null | wc -l"
let drift_str = to_string(exec(drift_cmd)).trim()
let drift_recorded = to_int(drift_str)

let mut overall = "PASS"
if total < 100 { overall = "FAIL" }
if axis_m < 30 { overall = "FAIL" }
if shards < 4 { overall = "FAIL" }

if !QUIET {
    println("atlas surface (read-only inspection):")
    println("  ATLAS_DIR:               " + ATLAS_DIR)
    println("  total typed entries:     " + to_string(total))
    println("  axis-M anchor= rows:     " + to_string(axis_m))
    println("  atlas.append.* shards:   " + to_string(shards))
    println("  D4 drift records (corrected): " + to_string(drift_recorded))
}

println("__NEXUS_CHECK_ATLAS__ " + overall + " entries=" + to_string(total) + " axis_m=" + to_string(axis_m) + " shards=" + to_string(shards))
if overall == "FAIL" { exit(2) }
