// session_lock.hexa — H-SESSION-LOCK 하네스 룰
// @no-lock-needed
// @no-sandbox
// 역할: 파일 area 기반 advisory lock. 다중 Claude Code 세션 + 다중 프로젝트가
//       같은 shared/ 를 동시 편집하여 race 발생 — area 단위 lockdir 로 차단.
// SSOT: /tmp/nexus-lock-{area}/ (디렉토리 존재 자체가 lock)
//       /tmp/nexus-lock-{area}/pid  3줄: {pid}\n{ts_unix}\n{session_id}
// 우회: NEXUS_LOCK_OK=1 (acquire 시 bypass + exit 0)
//
// modes:
//   acquire <area> <ttl_sec>  — lockdir 생성. stale(age>ttl) 이면 rm+재시도 1회.
//   release <area>            — 소유 pid 검증 후 rm -rf
//   list                      — 활성 lock JSONL
//   gc                        — stale 일괄 정리
//   derive <path>             — 경로→area 매핑 helper
//
// 성공 조용, BLOCK 시끄럽게 (H1).
// 주의: hexa exit() 은 nested function 에서 상위로 전파되지 않음 —
//       command fn 은 i64 반환, main() 에서 최종 exit() 호출.

let LOCK_PREFIX = "/tmp/nexus-lock-"

// void-safe coercion — "".split() 첫 원소 void 반환 우회
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    return to_int(first)
}

fn now_unix() -> i64 {
    return _to_int0(_str(exec("date +%s")).trim())
}

// hexa 프로세스 pid 는 exec("echo $PPID") 로 안정 조회
// ($$ 는 exec() 마다 다른 서브셸 pid 반환 — 사용 불가)
fn cur_pid() -> string {
    let p = _str(exec("echo $PPID")).trim()
    if p == "" { return "0" }
    return p
}

fn cur_ppid() -> string {
    // session_id 해시 재료용 — cur_pid 와 동일 소스 사용
    return cur_pid()
}

// ─── session_id: ppid|ts_unix 해시 8자 → "s" prefix ───
fn make_session_id() -> string {
    let ppid = cur_ppid()
    let ts = to_string(now_unix())
    let cmd = "printf '%s|%s' '" + ppid + "' '" + ts + "' | (sha256sum 2>/dev/null || shasum -a 256 2>/dev/null) | cut -c1-8"
    let r = _str(exec(cmd)).trim()
    if r == "" {
        return "s" + ts
    }
    return "s" + r
}

// ─── area sanitize: 영숫자+언더스코어+하이픈만 허용 ───
fn sanitize_area(area: string) -> string {
    let mut out = ""
    let mut i = 0
    while i < area.len() {
        let c = area.substring(i, i + 1)
        if c == "a" || c == "b" || c == "c" || c == "d" || c == "e" || c == "f" || c == "g" || c == "h" || c == "i" || c == "j" || c == "k" || c == "l" || c == "m" || c == "n" || c == "o" || c == "p" || c == "q" || c == "r" || c == "s" || c == "t" || c == "u" || c == "v" || c == "w" || c == "x" || c == "y" || c == "z" {
            out = out + c
        } else if c == "A" || c == "B" || c == "C" || c == "D" || c == "E" || c == "F" || c == "G" || c == "H" || c == "I" || c == "J" || c == "K" || c == "L" || c == "M" || c == "N" || c == "O" || c == "P" || c == "Q" || c == "R" || c == "S" || c == "T" || c == "U" || c == "V" || c == "W" || c == "X" || c == "Y" || c == "Z" {
            out = out + c
        } else if c == "0" || c == "1" || c == "2" || c == "3" || c == "4" || c == "5" || c == "6" || c == "7" || c == "8" || c == "9" {
            out = out + c
        } else if c == "_" || c == "-" {
            out = out + c
        }
        i = i + 1
    }
    return out
}

// ─── derive: shared/tool/* → harness, etc ───
fn derive_area(path: string) -> string {
    let p = path.trim()
    if p.contains("shared/tool/") || p.starts_with("shared/harness") {
        return "harness"
    }
    if p.contains("shared/config/") || p.starts_with("shared/config") {
        return "config"
    }
    if p.contains("shared/blowup/") || p.starts_with("shared/blowup") {
        return "blowup"
    }
    if p.contains("shared/n6/") || p.starts_with("shared/n6") {
        return "n6"
    }
    if p.contains("shared/rules/") || p.starts_with("shared/rules") {
        return "rules"
    }
    if p.contains("shared/discovery/") || p.starts_with("shared/discovery") {
        return "discovery"
    }
    return "misc"
}

fn lockdir_of(area: string) -> string {
    return LOCK_PREFIX + area
}

fn pidfile_of(area: string) -> string {
    return LOCK_PREFIX + area + "/pid"
}

// ─── lock 소유자 정보 읽기 [pid, ts, session_id] ───
fn read_owner(area: string) -> [string] {
    let pf = pidfile_of(area)
    if file_exists(pf) == false { return ["", "0", ""] }
    let raw = read_file(pf)
    let lines = raw.split("\n")
    let mut pid = ""
    let mut ts = "0"
    let mut sid = ""
    if lines.len() >= 1 { pid = _str(lines[0]).trim() }
    if lines.len() >= 2 { ts = _str(lines[1]).trim() }
    if lines.len() >= 3 { sid = _str(lines[2]).trim() }
    if ts == "" { ts = "0" }
    return [pid, ts, sid]
}

// ─── lockdir 생성 시도 — 성공 시 0, 실패 시 0 이 아닌 값 ───
fn try_mkdir(area: string) -> i64 {
    let ld = lockdir_of(area)
    let cmd = "mkdir '" + ld + "' 2>/dev/null; echo $?"
    let rc = _to_int0(_str(exec(cmd)).trim())
    return rc
}

fn remove_lockdir(area: string) {
    let ld = lockdir_of(area)
    exec("rm -rf '" + ld + "' 2>/dev/null")
}

fn write_pidfile(area: string, pid: string, ts: i64, sid: string) {
    let pf = pidfile_of(area)
    let content = pid + "\n" + to_string(ts) + "\n" + sid + "\n"
    try { write_file(pf, content) } catch e {}
}

// ─── acquire → exit code ───
fn cmd_acquire(argv: [string]) -> i64 {
    if env("NEXUS_LOCK_OK") == "1" {
        println("bypass")
        return 0
    }
    if argv.len() < 5 {
        eprintln("usage: acquire <area> <ttl_sec>")
        return 2
    }
    let area_raw = argv[3].trim()
    let area = sanitize_area(area_raw)
    if area == "" {
        eprintln("REJECT: area 비어있음 또는 유효하지 않은 문자")
        return 2
    }
    let ttl = _to_int0(argv[4].trim())
    if ttl <= 0 {
        eprintln("REJECT: ttl_sec 은 양수여야 함")
        return 2
    }

    let pid = cur_pid()
    let sid = make_session_id()
    let now = now_unix()

    // 1차 시도
    let rc1 = try_mkdir(area)
    if rc1 == 0 {
        write_pidfile(area, pid, now, sid)
        println(sid)
        return 0
    }

    // 기존 lock 읽어 stale 판정 (TTL 기준, pid 생사는 release 에서만 참고)
    let owner = read_owner(area)
    let owner_pid = owner[0]
    let owner_ts = _to_int0(owner[1])
    let age = now - owner_ts

    if age > ttl {
        // stale — 제거 후 재시도 1회
        remove_lockdir(area)
        let rc2 = try_mkdir(area)
        if rc2 == 0 {
            write_pidfile(area, pid, now, sid)
            println(sid)
            return 0
        }
        eprintln("[H-SESSION-LOCK BLOCK] area='" + area + "' stale 제거 후 재시도 실패 (race) — pid=" + owner_pid + " age=" + to_string(age) + "s")
        return 2
    }

    // active lock → BLOCK
    eprintln("[H-SESSION-LOCK BLOCK] area='" + area + "' 이미 잠김 — pid=" + owner_pid + " age=" + to_string(age) + "s ttl=" + to_string(ttl) + "s")
    return 2
}

// pid 가 여전히 살아있는지 — kill -0 로 best-effort 체크
fn pid_alive(pid: string) -> bool {
    if pid == "" || pid == "0" { return false }
    let esc = pid.replace("'", "")
    let cmd = "kill -0 '" + esc + "' 2>/dev/null; echo $?"
    let rc = _to_int0(_str(exec(cmd)).trim())
    return rc == 0
}

// ─── release → exit code ───
fn cmd_release(argv: [string]) -> i64 {
    if env("NEXUS_LOCK_OK") == "1" { return 0 }
    if argv.len() < 4 {
        eprintln("usage: release <area>")
        return 2
    }
    let area_raw = argv[3].trim()
    let area = sanitize_area(area_raw)
    if area == "" {
        eprintln("REJECT: area 비어있음")
        return 2
    }

    let pf = pidfile_of(area)
    if file_exists(pf) == false {
        // 잠금 없음 — silent (디렉토리만 있으면 제거)
        remove_lockdir(area)
        return 0
    }

    let owner = read_owner(area)
    let owner_pid = owner[0]
    let my_pid = cur_pid()

    // 소유자 체크: 내 pid 거나, owner 가 이미 dead 면 silent 해제.
    // 살아있고 내 것이 아니면 WARN (강제 해제).
    if owner_pid != "" && owner_pid != my_pid && pid_alive(owner_pid) {
        eprintln("[H-SESSION-LOCK WARN] area='" + area + "' 소유자 불일치 — owner_pid=" + owner_pid + " my_pid=" + my_pid + " (강제 해제)")
    }
    remove_lockdir(area)
    return 0
}

// ─── list → exit code ───
fn cmd_list(argv: [string]) -> i64 {
    let cmd = "ls -d /tmp/nexus-lock-*/ 2>/dev/null"
    let raw = _str(exec(cmd)).trim()
    if raw == "" { return 0 }

    let now = now_unix()
    for line in raw.split("\n") {
        let ld = _str(line).trim()
        if ld == "" { continue }
        // ld = /tmp/nexus-lock-{area}/
        let mut area = ld.replace("/tmp/nexus-lock-", "")
        if area.len() > 0 {
            let last = area.substring(area.len() - 1, area.len())
            if last == "/" {
                area = area.substring(0, area.len() - 1)
            }
        }
        let owner = read_owner(area)
        let age = now - _to_int0(owner[1])
        let row = "{\"area\":\"" + area + "\"," +
                  "\"pid\":\"" + owner[0] + "\"," +
                  "\"ts\":" + owner[1] + "," +
                  "\"age_sec\":" + to_string(age) + "," +
                  "\"session_id\":\"" + owner[2] + "\"}"
        println(row)
    }
    return 0
}

// ─── gc → exit code (default TTL 3600s) ───
fn cmd_gc(argv: [string]) -> i64 {
    let default_ttl: i64 = 3600
    let cmd = "ls -d /tmp/nexus-lock-*/ 2>/dev/null"
    let raw = _str(exec(cmd)).trim()
    if raw == "" {
        println("gc: 0 stale")
        return 0
    }

    let now = now_unix()
    let mut count: i64 = 0
    for line in raw.split("\n") {
        let ld = _str(line).trim()
        if ld == "" { continue }
        let mut area = ld.replace("/tmp/nexus-lock-", "")
        if area.len() > 0 {
            let last = area.substring(area.len() - 1, area.len())
            if last == "/" {
                area = area.substring(0, area.len() - 1)
            }
        }
        let owner = read_owner(area)
        let ts = _to_int0(owner[1])
        let age = now - ts
        if ts > 0 && age > default_ttl {
            remove_lockdir(area)
            count = count + 1
        }
    }
    println("gc: " + to_string(count) + " stale")
    return 0
}

// ─── derive → exit code ───
fn cmd_derive(argv: [string]) -> i64 {
    if argv.len() < 4 {
        eprintln("usage: derive <path>")
        return 2
    }
    let path = argv[3].trim()
    println(derive_area(path))
    return 0
}

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    if argv.len() < 3 {
        eprintln("usage: session_lock <acquire|release|list|gc|derive> [args...]")
        exit(2)
    }
    let mode = argv[2].trim()
    let mut rc: i64 = 0
    if mode == "acquire" { rc = cmd_acquire(argv) }
    else if mode == "release" { rc = cmd_release(argv) }
    else if mode == "list" { rc = cmd_list(argv) }
    else if mode == "gc" { rc = cmd_gc(argv) }
    else if mode == "derive" { rc = cmd_derive(argv) }
    else {
        eprintln("REJECT: unknown mode '" + mode + "' — modes: acquire|release|list|gc|derive")
        rc = 2
    }
    exit(rc)
}

main()
