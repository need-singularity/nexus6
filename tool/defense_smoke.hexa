// tool/defense_smoke.hexa — 5-layer defense system smoke test (hexa-native)
//
// raw 9 hexa-only-suffix 정책 준수. self-host avoid 패턴 회피 — 신규 hexa 도구로
// shell 도구들 (atlas_status_all.sh, ledger_verify.sh 등)과 별개로 hexa runtime
// 안에서 직접 defense 상태 확인.
//
// @tool(slug="defense_smoke", desc="5-layer (R1+R2+R3-lite+R4+R5) defense smoke test")
// @usage(hexa run tool/defense_smoke.hexa [--quiet])
//
// 검사 항목:
//   1. falsifiers.jsonl 존재 + 파싱 가능 + entries >= 100 (R1 cmd_sha256 보존)
//   2. state/falsifier_registry.sha256 baseline 존재 + 일치 (R3-lite)
//   3. state/bridge_sha256.tsv 존재 + 16 entries (R1 file_sha256 for bridges)
//   4. state/atlas_sha256.tsv 존재 + 10 entries (R1 file_sha256 for atlas)
//   5. state/falsifier_registry_rotation_log.jsonl chain 무결성 (R5)
//      (없거나 비어 있으면 GENESIS PASS)
//
// sentinel: __DEFENSE_SMOKE__ <PASS|FAIL> r1_falsifier=N r1_bridge=N r1_atlas=N r3_lite=<MATCH|DRIFT|MISSING> r5_chain=<PASS|EMPTY|FAIL>
// exit: 0 PASS / 76 FAIL (any layer broken)
//
// raw 73 admissibility: 5 독립 검증, 자명 아님
// raw 80 sentinel: 한 줄 stdout 끝
// raw 71: report-only, 자동 mutation 없음

let mut QUIET = false
let args = sys_args()
let mut i = 0
while i < len(args) {
    let a = args[i]
    if a == "--quiet" { QUIET = true }
    if a == "--help" || a == "-h" {
        println("usage: hexa run tool/defense_smoke.hexa [--quiet]")
        println("  5-layer defense smoke test (R1 + R2 + R3-lite + R4 + R5)")
        println("  exit 0 if all PASS, 76 if any layer broken")
        return
    }
    i = i + 1
}

let NEXUS = "/Users/ghost/core/nexus"
let mut overall_pass = true

fn _say(msg: string) {
    if !QUIET { println(msg) }
}

fn _file_lines(path: string) -> int {
    if !file_exists(path) { return 0 }
    let content = to_string(read_file(path))
    let lines = split(content, "\n")
    let mut n = 0
    for l in lines { if len(l.trim()) > 0 { n = n + 1 } }
    return n
}

// ── R1 falsifier registry ─────────────────────────────────────
let registry = NEXUS + "/design/hexa_sim/falsifiers.jsonl"
let r1_fals = _file_lines(registry)
let r1_fals_ok = r1_fals >= 100
if r1_fals_ok { _say("R1 falsifier:  PASS (" + to_string(r1_fals) + " entries)") }
else {
    _say("R1 falsifier:  FAIL (" + to_string(r1_fals) + " entries; reason=registry_below_100; fix=audit_registry_path)")
    overall_pass = false
}

// ── R1 bridge registry ────────────────────────────────────────
let bridge_tsv = NEXUS + "/state/bridge_sha256.tsv"
let r1_bridge_lines = _file_lines(bridge_tsv)
let r1_bridge = r1_bridge_lines - 1   // header
let r1_bridge_ok = r1_bridge >= 16
if r1_bridge_ok { _say("R1 bridge:     PASS (" + to_string(r1_bridge) + " entries)") }
else {
    _say("R1 bridge:     FAIL (" + to_string(r1_bridge) + " entries; reason=bridge_tsv_below_16; fix=bash tool/bridge_sha256_rotate.sh)")
    overall_pass = false
}

// ── R1 atlas registry ─────────────────────────────────────────
let atlas_tsv = NEXUS + "/state/atlas_sha256.tsv"
let r1_atlas_lines = _file_lines(atlas_tsv)
let r1_atlas = r1_atlas_lines - 1   // header (- 4 maybe per format; tolerate)
let r1_atlas_ok = r1_atlas >= 10
if r1_atlas_ok { _say("R1 atlas:      PASS (" + to_string(r1_atlas) + " entries)") }
else {
    _say("R1 atlas:      FAIL (" + to_string(r1_atlas) + " entries; reason=atlas_tsv_below_10; fix=bash tool/atlas_sha256_rotate.sh)")
    overall_pass = false
}

// ── R3-lite baseline match ────────────────────────────────────
let baseline_path = NEXUS + "/state/falsifier_registry.sha256"
let mut r3_status = "MISSING"
if file_exists(baseline_path) {
    let baseline = to_string(read_file(baseline_path)).trim()
    let live_cmd = "shasum -a 256 " + registry + " | awk '{print $1}'"
    let live = to_string(exec(live_cmd)).trim()
    if baseline == live {
        r3_status = "MATCH"
        _say("R3-lite:       PASS (baseline=" + baseline.substring(0, 12) + ")")
    } else {
        r3_status = "DRIFT"
        _say("R3-lite:       DRIFT (baseline=" + baseline.substring(0, 12) + " live=" + live.substring(0, 12) + "; reason=baseline_stale; fix=shasum > state/falsifier_registry.sha256)")
        overall_pass = false
    }
} else {
    _say("R3-lite:       MISSING (reason=no_baseline_file; fix=shasum -a 256 falsifiers.jsonl > state/falsifier_registry.sha256)")
    overall_pass = false
}

// ── R5 ledger chain ───────────────────────────────────────────
let ledger_path = NEXUS + "/state/falsifier_registry_rotation_log.jsonl"
let mut r5_status = "EMPTY"
if file_exists(ledger_path) {
    let entries = _file_lines(ledger_path)
    if entries == 0 {
        _say("R5 chain:      EMPTY (genesis state — 0 rotations)")
    } else {
        // delegate chain integrity to ledger_verify.sh (raw 73 — reuse audited tool)
        let verify_cmd = "bash " + NEXUS + "/tool/ledger_verify.sh --ledger falsifier --quiet 2>/dev/null"
        let verify_out = to_string(exec(verify_cmd))
        if verify_out.index_of("PASS") >= 0 {
            r5_status = "PASS"
            _say("R5 chain:      PASS (" + to_string(entries) + " entries chain intact)")
        } else {
            r5_status = "FAIL"
            _say("R5 chain:      FAIL (" + to_string(entries) + " entries; reason=chain_broken; fix=audit ledger_verify output)")
            overall_pass = false
        }
    }
} else {
    _say("R5 chain:      EMPTY (no ledger file — genesis state)")
}

// ── final sentinel ────────────────────────────────────────────
let mut verdict = "PASS"
if !overall_pass { verdict = "FAIL" }
let sentinel = "__DEFENSE_SMOKE__ " + verdict +
               " r1_falsifier=" + to_string(r1_fals) +
               " r1_bridge=" + to_string(r1_bridge) +
               " r1_atlas=" + to_string(r1_atlas) +
               " r3_lite=" + r3_status +
               " r5_chain=" + r5_status
println(sentinel)

if !overall_pass { exit(76) }
