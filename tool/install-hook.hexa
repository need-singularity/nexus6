// install-hook.hexa — 하네스 pre-commit 훅 설치 (git config core.hooksPath)
// @allow-bare-exec
// Usage: hexa shared/tool/install-hook.hexa
// 효과: .githooks/ 경로를 git 훅 디렉토리로 설정. clone 후 1회 실행.

let REPO_ROOT = exec("git rev-parse --show-toplevel 2>/dev/null").trim()  // @allow-bare-exec
if REPO_ROOT == "" {
    println("ERROR: git 리포 안에서 실행")
    exit(1)
}

let HOOKS_DIR = REPO_ROOT + "/.githooks"
let PRE_COMMIT = HOOKS_DIR + "/pre-commit"

if !file_exists(PRE_COMMIT) {
    println("ERROR: " + PRE_COMMIT + " 없음 — git pull 후 재시도")
    exit(1)
}

// 실행권한 보장
exec("chmod +x '" + PRE_COMMIT + "'")  // @allow-bare-exec

// core.hooksPath 설정
let set = exec("git -C '" + REPO_ROOT + "' config core.hooksPath .githooks 2>&1").trim()  // @allow-bare-exec
if set != "" { println(set) }

let check = exec("git -C '" + REPO_ROOT + "' config --get core.hooksPath").trim()  // @allow-bare-exec
println("core.hooksPath = " + check)
println("훅 설치 완료: " + PRE_COMMIT)
exit(0)
