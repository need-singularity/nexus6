// session.hexa — 하네스 session 라우터 (본문 위임)
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
// modes: list | lock [args...] | registry [args...] | worktree [args...] | prompt_gen [args...]
// delegates:
//   session_lock.hexa        H-SESSION-LOCK — advisory lockdir
//   session_registry.hexa    H-SESSION-REGISTRY — 세션 manifest + peers
//   session_worktree.hexa    H-SESSION-WORKTREE — opt-in git worktree 헬퍼
//   session_prompt_gen.hexa  세션 이어받기 프롬프트 자동 생성
// 본문 4개는 그대로 유지 (직접 호출 경로 호환).

let HOME = env("HOME")
let HARNESS = HOME + "/Dev/nexus/harness"
let HEXA = HOME + "/Dev/nexus/bin/hexa"

let SESSION_LOCK = HARNESS + "/session_lock.hexa"
let SESSION_REGISTRY = HARNESS + "/session_registry.hexa"
let SESSION_WORKTREE = HARNESS + "/session_worktree.hexa"
let SESSION_PROMPT_GEN = HARNESS + "/session_prompt_gen.hexa"

fn print_list() {
    println("session modes:")
    println("  lock         — H-SESSION-LOCK advisory lockdir → " + SESSION_LOCK)
    println("  registry     — H-SESSION-REGISTRY 세션 manifest → " + SESSION_REGISTRY)
    println("  worktree     — H-SESSION-WORKTREE git worktree 헬퍼 → " + SESSION_WORKTREE)
    println("  prompt_gen   — 세션 이어받기 프롬프트 생성 → " + SESSION_PROMPT_GEN)
    println("  list         — 이 목록")
    println("usage: hexa run session.hexa <mode> [args...]")
}

fn dispatch_file(path: string, rest: [str]) -> i64 {
    if file_exists(path) == false {
        eprintln("REJECT: delegate not found: " + path)
        return 2
    }
    let mut cmd = HEXA + " run " + path
    for a in rest {
        let safe = a.replace("\"", "\\\"")
        cmd = cmd + " \"" + safe + "\""
    }
    let out = to_string(exec(cmd + " 2>&1"))  // @allow-bare-exec
    if out.trim().len() > 0 { print(out) }
    return 0
}

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    if argv.len() < 3 {
        print_list()
        return
    }
    let mode = argv[2].trim().to_lower()
    let mut rest = []
    let mut i = 3
    while i < argv.len() {
        rest = rest + [argv[i]]
        i = i + 1
    }
    if mode == "list" || mode == "-h" || mode == "--help" || mode == "help" {
        print_list()
        return
    }
    if mode == "lock" {
        let c = dispatch_file(SESSION_LOCK, rest)
        exit(c)
    }
    if mode == "registry" {
        let c = dispatch_file(SESSION_REGISTRY, rest)
        exit(c)
    }
    if mode == "worktree" {
        let c = dispatch_file(SESSION_WORKTREE, rest)
        exit(c)
    }
    if mode == "prompt_gen" || mode == "prompt-gen" || mode == "promptgen" {
        let c = dispatch_file(SESSION_PROMPT_GEN, rest)
        exit(c)
    }
    eprintln("REJECT: unknown mode '" + mode + "' — modes: list|lock|registry|worktree|prompt_gen")
    exit(2)
}

main()
