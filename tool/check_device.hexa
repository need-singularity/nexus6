#!hexa strict
// tool/check_device.hexa — nexus check 디바이스 도메인 백엔드
//
// @tool(slug="check_device", desc="device-level physics verification — wraps hexa-sscb sscb_atlas_check + nexus calc/hsscb_verify")
// @usage(HEXA_ARGV='' hexa run tool/check_device.hexa)
// @exit_codes(0=PASS, 1=usage, 2=verify FAIL)
// @sentinel(__NEXUS_CHECK_DEVICE__ <PASS|FAIL> sscb_atlas=<R> hsscb_verify=<R>)
//
// hexa-sscb mk1 device verification dispatch:
//   1. python3 hexa-sscb/verify/sscb_atlas_check.py — Python stdlib runner
//      (project carve-out per "hexa-sscb 외에는 hexa")
//   2. hexa run nexus/calc/hsscb_verify/run_all.hexa — hexa scaffold
//      (when hexa interp ready)
//
// Both consume nexus/calc/hsscb_verify/manifest.jsonl + atlas anchors
// (hsscb-mk1-vendor-anchors + hsscb-mk1-spec-derived shards).
//
// LLM judge 금지 — deterministic physics formulas (Joule / Lenz / Weibull /
// Nyquist / lumped thermal) per atlas @L EE-* entries.

fn _argv() -> array {
    let raw = to_string(exec("printf '%s' \"${HEXA_ARGV:-}\""))
    let parts = split(raw, " ")
    let mut out = []
    let mut k = 0
    while k < len(parts) { if len(parts[k]) > 0 { out.push(parts[k]) }; k = k + 1 }
    return out
}

fn _has(a: array, f: string) -> bool {
    let mut i = 0
    while i < len(a) { if a[i] == f { return true }; i = i + 1 }
    return false
}

let HOME = env("HOME")
let HSSCB = HOME + "/core/hexa-sscb"
let REPO_ROOT = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
let ARGS = _argv()
let QUIET = _has(ARGS, "--quiet")

fn _wrap_py(path: string, quiet: bool) -> string {
    if !file_exists(path) { return "SKIP" }
    let cmd = "python3 " + path + " 2>&1"
    let out = to_string(exec(cmd))
    if !quiet { println(out.trim()) }
    let lines = split(out, "\n")
    let mut last = ""
    for l in lines {
        let t = l.trim()
        if len(t) > 0 { last = t }
    }
    if last.index_of("PASS") >= 0 { return "PASS" }
    if last.index_of("FAIL") >= 0 { return "FAIL" }
    return "FAIL"
}

fn _wrap_hexa(path: string, quiet: bool) -> string {
    if !file_exists(path) { return "SKIP" }
    let cmd = "HEXA_LOCAL=1 HEXA_ARGV='' hexa run " + path + " 2>&1"
    let out = to_string(exec(cmd))
    if !quiet { println(out.trim()) }
    let lines = split(out, "\n")
    let mut last = ""
    for l in lines {
        let t = l.trim()
        if len(t) > 0 { last = t }
    }
    if last.index_of("PASS") >= 0 { return "PASS" }
    if last.index_of("FAIL") >= 0 { return "FAIL" }
    return "FAIL"
}

let r1 = _wrap_py(HSSCB + "/verify/sscb_atlas_check.py", QUIET)
let r2 = _wrap_hexa(REPO_ROOT + "/calc/hsscb_verify/run_all.hexa", QUIET)

let mut overall = "PASS"
if r1 == "FAIL" { overall = "FAIL" }
// r2 = SKIP allowed (hexa stubs are STUB until full eval lands)
if r2 == "FAIL" { overall = "FAIL" }
println("__NEXUS_CHECK_DEVICE__ " + overall + " sscb_atlas=" + r1 + " hsscb_verify=" + r2)
if overall == "FAIL" { exit(2) }
