// sync_dryrun.hexa — 변경 미리보기 유틸
// 역할: dry-run 모드에서 "would change" 형태로 포맷팅

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let LOG = NEXUS + "/tool/sync_log.jsonl"

fn log_append(task_id: str, result: str, changed: i64, dry: bool) {
    let ts = to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
    let dry_str = if dry { "true" } else { "false" }
    let line = "{\"ts\":\"" + ts + "\",\"task\":\"" + task_id + "\",\"result\":\"" + result + "\",\"changed\":" + to_string(changed) + ",\"dry\":" + dry_str + "}"
    try { exec("bash -c \"echo '" + line + "' >> '" + LOG + "'\"") } catch e {}
}

fn fmt_preview(task_id: str, src: str, dst: str, result: str) -> str {
    let mut line = "[" + task_id + "] "
    // 패딩
    while line.len() < 26 { line = line + " " }
    line = line + result
    if src.len() > 0 || dst.len() > 0 {
        line = line + "  " + src + " → " + dst
    }
    return line
}

fn count_files_different(src: str, dst: str) -> i64 {
    let src_exists = to_string(exec("test -e '" + src + "' && echo y || echo n")).trim()
    let dst_exists = to_string(exec("test -e '" + dst + "' && echo y || echo n")).trim()
    if src_exists != "y" { return 0 }
    if dst_exists != "y" { return 1 }
    let v = to_string(exec("diff -q '" + src + "' '" + dst + "' 2>/dev/null; echo $?")).trim()
    if v == "0" { return 0 }
    return 1
}
