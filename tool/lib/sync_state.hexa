// sync_state.hexa — prev_hash 캐시, drift 감지
// 파일: shared/tool/sync_state.json (하네스 루트)

let HOME = env("HOME")
let NEXUS = HOME + "/core/nexus"
let STATE = NEXUS + "/tool/sync_state.json"

fn md5_of(path: str) -> str {
    let v = to_string(exec("md5 -q '" + path + "' 2>/dev/null || md5sum '" + path + "' 2>/dev/null | cut -d' ' -f1")).trim()
    if v == "" { return "missing" }
    return v
}

// 디렉토리 내 glob pattern md5 (파일 연결)
fn md5_glob(pattern: str) -> str {
    let v = to_string(exec("bash -c \"cat " + pattern + " 2>/dev/null | md5 -q 2>/dev/null || cat " + pattern + " 2>/dev/null | md5sum | cut -d' ' -f1\"")).trim()
    if v == "" { return "empty" }
    return v
}

fn load_hash(task_id: str) -> str {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    // Original: python3 JSON get on sync_state.json[task_id]
    if file_exists(STATE) == false { return "" }
    let _ = task_id
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync_state.hexa:load_hash. Escalate to user for hexa-native replacement.")
    return ""
}

fn save_hash(task_id: str, hash_val: str) {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    // Original: python3 JSON update sync_state.json[task_id]=hash_val
    let _ = task_id
    let _ = hash_val
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync_state.hexa:save_hash. Escalate to user for hexa-native replacement.")
}

// src/dst hash 비교 — drift 감지
fn compare(src: str, dst: str) -> str {
    let sh = if file_exists(src) { md5_of(src) } else { "missing" }
    let dh = if file_exists(dst) { md5_of(dst) } else { "missing" }
    if sh == "missing" && dh == "missing" { return "both_missing" }
    if sh == "missing" { return "src_missing" }
    if dh == "missing" { return "dst_missing" }
    if sh == dh { return "same" }
    return "drift"
}
