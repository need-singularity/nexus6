// sync_project_iter.hexa — registered projects 순회 유틸
// 역할: sync_manifest.json 의 "projects" 블록에서 키별 프로젝트 리스트 추출.
//       hexa 에서 JSON 직접 파싱이 제한적이므로 python3 로 delegate.

let HOME = env("HOME")
let NEXUS = HOME + "/core/nexus"
let MANIFEST = NEXUS + "/tool/sync_manifest.json"

// 해당 키의 프로젝트 배열을 공백 구분 문자열로 반환
fn iter_projects(key: str) -> str {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    // Original: python3 JSON parse of sync_manifest.json["projects"][key]
    let _ = key
    let _ = MANIFEST
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at sync_project_iter.hexa:iter_projects. Escalate to user for hexa-native replacement.")
    return ""
}

// name -> repo 경로 (특수 처리: nexus, TECS-L, sedi 대소문자)
fn repo_path(name: str) -> str {
    if name == "nexus" { return HOME + "/core/nexus" }
    if name == "TECS-L" { return HOME + "/core/nexus/shared" }
    if name == "SEDI" { return HOME + "/Dev/sedi" }
    return HOME + "/Dev/" + name
}

// 심링크 여부
fn is_symlink(path: str) -> bool {
    let v = to_string(exec("test -L '" + path + "' && echo y || echo n")).trim()
    return v == "y"
}

// 디렉토리 존재
fn dir_exists(path: str) -> bool {
    let v = to_string(exec("test -d '" + path + "' && echo y || echo n")).trim()
    return v == "y"
}
