// signal_null_guardian.hexa — E9 대체 하네스
// 인자로 가설 statement 받음 → atlas.signals.n6 [MN] 엔트리와 키워드 매칭
// 매칭 시 경고 출력 + retry_forbidden_until 체크
// 실행: hexa run $NEXUS/tool/signal_null_guardian.hexa "가설 문장"

let HOME = env("HOME")
let NEXUS = HOME + "/core/nexus"
let SIGNALS = NEXUS + "/n6/atlas.signals.n6"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn now_iso() -> string {
    let r = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    return _str(r).trim()
}

fn today_ymd() -> string {
    let r = exec("date -u +%Y-%m-%d")
    return _str(r).trim()
}

// YYYY-MM-DD → 정수 YYYYMMDD (hexa 는 문자열 비교 연산자 미지원)
fn ymd_to_int(s: string) -> i64 {
    if s.len() < 10 { return 0 }
    let clean = s.replace("-", "")
    let mut v: i64 = 0
    try { v = to_int(clean) } catch e { v = 0 }
    return v
}

fn shell_quote(s: string) -> string {
    let escaped = s.replace("'", "'\\''")
    return "'" + escaped + "'"
}

// [MN] 블록들만 추출 — sig_id | statement | retry_forbidden_until
fn load_null_signals() -> [string] {
    let cmd = "awk '" +
      "/^@S .*\\[MN\\]/ { " +
      "  id = $2; line = $0; " +
      "  sub(/^@S [^=]+= /, \"\", line); " +
      "  sub(/ ::.*/, \"\", line); " +
      "  curr_id = id; curr_stmt = line; curr_retry = \"\"; next " +
      "} " +
      "/retry_forbidden_until:/ { " +
      "  if (curr_id != \"\") { " +
      "    match($0, /[0-9]{4}-[0-9]{2}-[0-9]{2}/); " +
      "    curr_retry = substr($0, RSTART, RLENGTH); " +
      "    print curr_id \"|\" curr_stmt \"|\" curr_retry; " +
      "    curr_id = \"\"; " +
      "  } " +
      "} " +
      "/^@S / && !/\\[MN\\]/ { " +
      "  if (curr_id != \"\") { print curr_id \"|\" curr_stmt \"|\"; curr_id = \"\" } " +
      "} " +
      "END { if (curr_id != \"\") print curr_id \"|\" curr_stmt \"|\" }' '" + SIGNALS + "'"
    let r = exec(cmd)
    let text = _str(r)
    let lines = text.split("\n")
    let mut out: [string] = []
    for line in lines {
        let s = _str(line).trim()
        if s != "" { out = out + [s] }
    }
    return out
}

// lowercase 변환 — exec 로 tr 호출 (hexa 에 to_lowercase 미지원)
fn to_lower(s: string) -> string {
    if s == "" { return "" }
    let escaped = s.replace("'", "'\\''")
    let cmd = "printf '%s' '" + escaped + "' | tr '[:upper:]' '[:lower:]'"
    let r = exec(cmd)
    return _str(r)
}

// 단어 단위 overlap — 대소문자 무시 매칭 (양쪽 모두 lower 로 변환)
fn score_overlap(a: string, b: string) -> i64 {
    let al = to_lower(a)
    let bl = to_lower(b)
    let terms = [
        "qrng", "anu", "seed", "urandom", "bell", "correlation",
        "quantum", "64", "tick", "buffer", "bufsize", "stochastic",
        "resonance", "ouroboros", "peak", "null", "ks", "p-value",
        "fisher", "kolmogorov"
    ]
    let mut score: i64 = 0
    let mut i = 0
    while i < terms.len() {
        let t = terms[i]
        if al.contains(t) && bl.contains(t) {
            score = score + 1
        }
        i = i + 1
    }
    return score
}

// ─── 메인 ───
let a = args()
if a.len() < 3 {
    println("사용: hexa run signal_null_guardian.hexa \"가설 문장\"")
    exit(2)
}

// 인자 2부터 이어붙이기 (공백 있는 문장)
let mut hypothesis = ""
let mut i = 2
while i < a.len() {
    if hypothesis != "" { hypothesis = hypothesis + " " }
    hypothesis = hypothesis + a[i]
    i = i + 1
}

println("signal_null_guardian: ts=" + now_iso())
println("  가설: " + hypothesis)

let today = today_ymd()

let nulls = load_null_signals()
println("  [MN] NULL signals 로드: " + to_string(nulls.len()))

if nulls.len() == 0 {
    println("  OK: NULL 공간 비어있음 — 진행 가능")
    exit(0)
}

// 매칭 스캔
let mut warnings: i64 = 0
let mut j = 0
while j < nulls.len() {
    let line = nulls[j]
    let parts = line.split("|")
    if parts.len() >= 2 {
        let sid = _str(parts[0])
        let stmt = _str(parts[1])
        let retry = if parts.len() >= 3 { _str(parts[2]).trim() } else { "" }
        let sc = score_overlap(hypothesis, stmt)
        if sc >= 2 {
            warnings = warnings + 1
            println("")
            println("  [WARN] score=" + to_string(sc) + " match=" + sid)
            println("    NULL statement: " + stmt)
            if retry != "" {
                let r_int = ymd_to_int(retry)
                let t_int = ymd_to_int(today)
                if r_int > t_int {
                    println("    retry_forbidden_until=" + retry + " (현재 " + today + ") — 재시도 금지 중")
                } else {
                    println("    retry_forbidden_until=" + retry + " 만료 — 재시도 가능")
                }
            }
        }
    }
    j = j + 1
}

if warnings == 0 {
    println("  OK: NULL 중복 없음 — 진행 가능")
} else {
    println("")
    println("  경고 " + to_string(warnings) + "건 — NULL 공간과 중복, 신중 검토")
    exit(1)
}
