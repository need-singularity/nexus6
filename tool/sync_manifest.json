      "src": "shared/scripts/shared_work_rules.md",
      "dst_pattern": "$HOME/Dev/{name}/CLAUDE.md",
      "dst_nexus": "shared/CLAUDE.md",
      "mode": "marker",
      "marker_start": "<!-- SHARED:WORK_RULES:START -->",
