      "dst_pattern": "$HOME/Dev/{name}/CLAUDE.md",
      "mode": "copy",
      "git": true,
      "projects_key": "claude_md",
      "handle_symlink": true,
      "commit_msg": "sync: CLAUDE.md from nexus/project-claude/{name}.md",
      "status": "active",
      "original": "shared/scripts/sync_claude_md.hexa"
    },
    {
      "id": "settings",
      "description": ".claude/settings.json 템플릿 (hexa 훅 + 커스텀 보존)",
      "src": "shared/hooks/hook-entry.hexa",
      "dst_pattern": "$HOME/Dev/{name}/.claude/settings.json",
      "mode": "template",
      "git": true,
      "projects_key": "settings",
