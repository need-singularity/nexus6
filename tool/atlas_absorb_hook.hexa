#!hexa strict
// tool/atlas_absorb_hook.hexa — own:atlas-absorb-mandatory triad B.2 (agent-level hook).
//
// @tool(slug="atlas_absorb_hook", desc="agent-level PostToolUse hook entrypoint — invokes omega_cycle_atlas_ingest --witness <path> on any *omega_cycle*.json write. Designed for two paths: (P) Claude Code PostToolUse hook on Write/Edit, (Q) tool-wrapper helper any emitter can call after writing a witness JSON.")
// @usage(hexa run tool/atlas_absorb_hook.hexa --witness <abs_path> [--source <slug>])
// @usage(hexa run tool/atlas_absorb_hook.hexa --selftest)
// @omega-converge(witness="fixpoint-convergence", attempts=1, attempt_log="own:atlas-absorb-mandatory triad B.2: invoked at write-time. Fixpoint = ingest --witness rc==0 + sentinel emitted.")
// @exit_codes(0=PASS or skip, 1=usage/io, 2=ingest failure)
// @sentinel(__ATLAS_ABSORB_HOOK__ <PASS|SKIP|FAIL> witness=<path> source=<slug> [reason=<slug>])
//
// Triad B.2 — second (agent-level) enforcement layer.
// Two invocation paths:
//   (P) Claude Code PostToolUse hook on Write/Edit — fires when any tool
//       writes a file matching *omega_cycle*.json. Hook config goes in
//       <repo>/.claude/settings.json or ~/.claude/settings.json. Repo path
//       requires user install (sandbox EPERM blocks ~/.claude/ writes from
//       Claude Code sessions; see feedback_macos_launchagents_eperm).
//   (Q) Tool-wrapper helper — kick_dispatch already wires _auto_absorb_witness
//       for its writeback paths (F20). Other future emitters that write
//       *omega_cycle*.json should call this hook tool after their write_file.
//
// raw 66 trailers on every error path (reason=<slug> fix=<directive>).
// raw 80 sentinel: __ATLAS_ABSORB_HOOK__ <PASS|SKIP|FAIL> witness=<path>.

fn _core_root() -> string {
    let override = env_var("NEXUS_CORE_ROOT")
    if len(override) > 0 { return override }
    let h = env_var("HOME")
    return h + "/core"
}

fn _ingest_tool_path() -> string {
    return _core_root() + "/nexus/tool/omega_cycle_atlas_ingest.hexa"
}

fn _shell_quote(s: string) -> string {
    let mut r = s.replace("'", "'\\''")
    return "'" + r + "'"
}

fn _is_omega_cycle_witness(path: string) -> bool {
    if path.index_of("omega_cycle") < 0 { return false }
    let n = len(path)
    if n < 5 { return false }
    let tail = path.substring(n - 5, n)
    if tail != ".json" { return false }
    if path.index_of("/design/") < 0 { return false }
    return true
}

fn _selftest() -> void {
    println("[atlas_absorb_hook selftest]")
    if !_is_omega_cycle_witness("/Users/ghost/core/nexus/design/kick/2026-04-26_kick_test_omega_cycle.json") {
        eprintln("selftest FAIL classifier should accept canonical witness")
        eprintln("reason=classifier-false-negative fix=verify _is_omega_cycle_witness predicate")
        exit(1)
    }
    if _is_omega_cycle_witness("/Users/ghost/core/nexus/state/blockers/foo.hexa") {
        eprintln("selftest FAIL classifier should reject non-design path")
        eprintln("reason=classifier-false-positive fix=verify _is_omega_cycle_witness rejects non-design paths")
        exit(1)
    }
    if _is_omega_cycle_witness("/Users/ghost/core/nexus/design/kick/foo.txt") {
        eprintln("selftest FAIL classifier should reject non-json")
        eprintln("reason=classifier-extension-check fix=verify .json extension check")
        exit(1)
    }
    let ingest = _ingest_tool_path()
    let test_i = to_string(exec("test -f '" + ingest + "' && echo y || echo n")).trim()
    if test_i != "y" {
        eprintln("selftest FAIL ingest tool not found at " + ingest)
        eprintln("reason=ingest-tool-missing fix=verify nexus/tool/omega_cycle_atlas_ingest.hexa exists")
        exit(1)
    }
    println("[atlas_absorb_hook selftest] OK")
    exit(0)
}

fn main() -> void {
    let raw_args = args()
    let mut cli = []
    let mut ai = 2
    while ai < len(raw_args) {
        cli.push(raw_args[ai])
        ai = ai + 1
    }
    if len(cli) >= 1 && (cli[0] == "--selftest" || cli[0] == "selftest") {
        _selftest()
    }

    let mut witness = ""
    let mut source = "unknown"
    let mut i = 0
    while i < len(cli) {
        let a = cli[i]
        if a == "--witness" {
            i = i + 1
            if i >= len(cli) {
                eprintln("__ATLAS_ABSORB_HOOK__ FAIL witness= source=" + source + " reason=missing-witness-arg fix=hexa run tool/atlas_absorb_hook.hexa --witness /abs/path/foo_omega_cycle.json")
                exit(1)
            }
            witness = cli[i]
        } else if a == "--source" {
            i = i + 1
            if i >= len(cli) {
                eprintln("__ATLAS_ABSORB_HOOK__ FAIL witness=" + witness + " source= reason=missing-source-arg fix=--source <slug>")
                exit(1)
            }
            source = cli[i]
        } else if a == "--help" || a == "-h" {
            println("usage: hexa run tool/atlas_absorb_hook.hexa --witness <abs_path> [--source <slug>]")
            println("  invokes omega_cycle_atlas_ingest --witness <abs> on the given witness path")
            println("  raw 80 sentinel: __ATLAS_ABSORB_HOOK__ <PASS|SKIP|FAIL> witness=<path> source=<slug> [reason=<slug>]")
            println("  raw 66 err:     reason=<slug> fix=<directive>")
            println("  opt-out:        ATLAS_ABSORB_HOOK_DISABLED=1")
            exit(0)
        } else {
            eprintln("__ATLAS_ABSORB_HOOK__ FAIL witness=" + witness + " source=" + source + " reason=unknown-arg-" + a + " fix=hexa run tool/atlas_absorb_hook.hexa --help")
            exit(1)
        }
        i = i + 1
    }

    if env_var("ATLAS_ABSORB_HOOK_DISABLED") == "1" {
        println("__ATLAS_ABSORB_HOOK__ SKIP witness=" + witness + " source=" + source + " reason=opt_out_env")
        exit(0)
    }

    if len(witness) == 0 {
        eprintln("__ATLAS_ABSORB_HOOK__ FAIL witness= source=" + source + " reason=missing-witness-arg fix=--witness <abs_path>")
        exit(1)
    }

    if !_is_omega_cycle_witness(witness) {
        // not an omega_cycle witness — silent skip (hook may fire on every Write)
        println("__ATLAS_ABSORB_HOOK__ SKIP witness=" + witness + " source=" + source + " reason=not_omega_cycle_witness")
        exit(0)
    }

    let test_w = to_string(exec("test -f '" + witness + "' && echo y || echo n")).trim()
    if test_w != "y" {
        eprintln("__ATLAS_ABSORB_HOOK__ FAIL witness=" + witness + " source=" + source + " reason=witness-missing fix=verify witness JSON landed before hook fired")
        exit(1)
    }

    let ingest = _ingest_tool_path()
    let cmd = "env HEXA_RESOLVER_NO_REROUTE=1 hexa run " + _shell_quote(ingest) + " --witness " + _shell_quote(witness) + " 2>&1; echo __RC=$?"
    let out = to_string(exec(cmd))
    // OUTER rc — explicit `; echo __RC=$?` shell wrapper. Take first line
    // only (avoid bleeding into trailing __HEXA_RC= sentinel).
    let rc_idx = out.last_index_of("__RC=")
    let mut rc_str = "0"
    if rc_idx >= 0 {
        let outer_tail = out.substring(rc_idx + 5, len(out)).trim()
        let nl_o = outer_tail.index_of("\n")
        rc_str = if nl_o >= 0 { outer_tail.substring(0, nl_o).trim() } else { outer_tail }
    }
    // INNER rc — auto-appended by hexa.real exec() runtime as __HEXA_RC=N.
    // Carry-forward from kick_bench.hexa post-fix (commit 2d40c170, ω-cycle
    // live-spawn-smoke). Outer rc=0 + inner rc!=0 must still gate to FAIL,
    // else docker/sub-runtime failures silently absorb-pass.
    let hkey = "__HEXA_RC="
    let hi = out.last_index_of(hkey)
    let mut inner_rc_str = "0"
    if hi >= 0 {
        let h_tail = out.substring(hi + len(hkey), len(out)).trim()
        let mut he: i64 = 0
        while he < len(h_tail) {
            let hc = h_tail.substring(he, he + 1)
            if hc == " " || hc == "\n" || hc == "\t" || hc == "_" { break }
            he = he + 1
        }
        inner_rc_str = h_tail.substring(0, he).trim()
        if len(inner_rc_str) == 0 { inner_rc_str = "0" }
    }

    if rc_str != "0" {
        eprintln("__ATLAS_ABSORB_HOOK__ FAIL witness=" + witness + " source=" + source + " reason=ingest-rc-" + rc_str + " fix=hexa run " + ingest + " --witness " + witness + " 2>&1   # inspect")
        exit(2)
    }
    if inner_rc_str != "0" {
        eprintln("__ATLAS_ABSORB_HOOK__ FAIL witness=" + witness + " source=" + source + " reason=ingest-inner-rc-" + inner_rc_str + " fix=hexa run " + ingest + " --witness " + witness + " 2>&1   # outer rc=0 but hexa.real reported inner failure")
        exit(2)
    }

    if out.index_of("__OMEGA_CYCLE_ATLAS_INGEST__ SKIP") >= 0 {
        println("__ATLAS_ABSORB_HOOK__ SKIP witness=" + witness + " source=" + source + " reason=already_absorbed")
        exit(0)
    }

    println("__ATLAS_ABSORB_HOOK__ PASS witness=" + witness + " source=" + source)
    exit(0)
}
