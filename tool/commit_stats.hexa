// tool/commit_stats.hexa — 본 세션 commit 통계 (hexa-native, META_ROI hexa version)
//
// raw 9 hexa-only-suffix. git log 본 세션 commits + LoC + category 분석.
// META_OMEGA_CYCLE_ROI.md의 핵심 metrics를 hexa runtime 안에서 직접.
//
// @tool(slug="commit_stats", desc="git log session commit + LoC + category stats")
// @usage:
//   hexa run tool/commit_stats.hexa
//   HEXA_ARGV='--quiet' hexa run tool/commit_stats.hexa
//   HEXA_ARGV='--since 2026-04-25' hexa run tool/commit_stats.hexa  # custom since
//
// 분석:
//   1. commits 카운트 (since 2026-04-25)
//   2. category 분류 (feat/fix/docs/chore/refactor)
//   3. files changed + LoC delta (insertions, deletions)
//   4. ω-cycle 빈도 (subject에 'omega-cycle' 포함)
//
// sentinel: __COMMIT_STATS__ since=DATE total=N feat=F fix=X docs=D chore=C omega=O ins=+I del=-D
//
// raw 71 read-only / raw 73 admissibility (5 metrics) / raw 80 sentinel

let mut QUIET = false
let mut SINCE = "2026-04-25"

fn _argv() -> array {
    let raw = to_string(exec("printf '%s' \"${HEXA_ARGV:-}\""))
    let parts = split(raw, " ")
    let mut out = []
    let mut k = 0
    while k < len(parts) {
        if len(parts[k]) > 0 { out.push(parts[k]) }
        k = k + 1
    }
    return out
}

let args = _argv()
let mut i = 0
while i < len(args) {
    let a = args[i]
    if a == "--quiet" { QUIET = true }
    if a == "--since" && i + 1 < len(args) { SINCE = args[i+1]; i = i + 1 }
    if a == "--help" || a == "-h" {
        println("usage: HEXA_ARGV='[--since YYYY-MM-DD] [--quiet]' hexa run tool/commit_stats.hexa")
        println("  본 세션 commit stats (default since=2026-04-25)")
        return
    }
    i = i + 1
}

fn _say(msg: string) { if !QUIET { println(msg) } }

// 1. Total commits since SINCE
let cmd_count = "cd /Users/ghost/core/nexus && git log --since='" + SINCE + " 00:00' --oneline | wc -l | tr -d ' '"
let total = to_string(exec(cmd_count)).trim()

// 2. Category분류 (feat/fix/docs/chore/refactor)
fn _count_subj(prefix: string, since: string) -> string {
    let cmd = "{ cd /Users/ghost/core/nexus && git log --since='" + since + " 00:00' --oneline | grep -cE '^[a-f0-9]+ " + prefix + "' || true; }"
    let raw = to_string(exec(cmd)).trim()
    if raw == "" { return "0" }
    return raw.split("\n")[0]
}

let n_feat = _count_subj("feat", SINCE)
let n_fix = _count_subj("fix", SINCE)
let n_docs = _count_subj("docs", SINCE)
let n_chore = _count_subj("chore", SINCE)
let n_refactor = _count_subj("refactor", SINCE)

// 3. omega-cycle commits
let cmd_omega = "{ cd /Users/ghost/core/nexus && git log --since='" + SINCE + " 00:00' --oneline | grep -c omega-cycle || true; }"
let n_omega_raw = to_string(exec(cmd_omega)).trim()
let n_omega = if n_omega_raw == "" { "0" } else { n_omega_raw.split("\n")[0] }

// 4. Total insertions / deletions
let cmd_ins = "cd /Users/ghost/core/nexus && git log --since='" + SINCE + " 00:00' --shortstat | grep -E 'insertion|deletion' | awk '{s+=$4} END {print s+0}'"
let n_ins = to_string(exec(cmd_ins)).trim()

let cmd_del = "cd /Users/ghost/core/nexus && git log --since='" + SINCE + " 00:00' --shortstat | grep -E 'insertion|deletion' | awk '{s+=$6} END {print s+0}'"
let n_del = to_string(exec(cmd_del)).trim()

// 5. Files changed (unique)
let cmd_files = "cd /Users/ghost/core/nexus && git log --since='" + SINCE + " 00:00' --name-only --format= | sort -u | grep -v '^$' | wc -l | tr -d ' '"
let n_files = to_string(exec(cmd_files)).trim()

// Output
_say("═══ Session commit stats (since " + SINCE + ") ═══")
_say("")
_say("Total commits:       " + total)
_say("Files touched:       " + n_files + " unique")
_say("LoC delta:           +" + n_ins + " / -" + n_del)
_say("")
_say("Category breakdown:")
_say("  feat:              " + n_feat)
_say("  fix:               " + n_fix)
_say("  docs:              " + n_docs)
_say("  chore:             " + n_chore)
_say("  refactor:          " + n_refactor)
_say("")
_say("ω-cycle commits:     " + n_omega)

println("__COMMIT_STATS__ since=" + SINCE + " total=" + total + " feat=" + n_feat + " fix=" + n_fix + " docs=" + n_docs + " chore=" + n_chore + " omega=" + n_omega + " ins=+" + n_ins + " del=-" + n_del + " files=" + n_files)
