// tool/drill_cycle_trigger.hexa — nxs-20260422-082 drill cycle trigger
// @no-lock-needed
// @no-sandbox
// 역할: L0 SSOT (/Users/ghost/core/hexa-lang/.raw) sha256 drift 감지 → drill cycle 발사.
//       drift 없으면 silent exit 0. --check-only 로 side-effect 없이 비교만.
//
// SSOT refs:
//   L0 rulebook:      /Users/ghost/core/hexa-lang/.raw  (chflags uchg locked, 21 rules)
//   sidecar:          state/raw_sha_last_seen.json       (single-record)
//   drill config:     config/drill.json                  (6-stage SSOT)
//   CLI:              cli/drill/                          (problem_preset=scan)
//   history sink:     state/drill_baseline_history.jsonl
//
// cadence: weekly OR raw_sha_drift (daemon host pending nxs infra rebuild)
// atlas recompute targets (follow-up):
//   n6/atlas.n6.{events.jsonl, shard_meta.json, hub_centrality,
//                stats, deg, consciousness, cdo_weekly}
//
// usage:
//   hexa run tool/drill_cycle_trigger.hexa             — detect + trigger
//   hexa run tool/drill_cycle_trigger.hexa --check-only — detect only (no side effect)

let HOME = env("HOME")
let RAW_PATH   = HOME + "/core/hexa-lang/.raw"
// raw 95: 하드 코딩 금지 — host-aware cascade matches sub-L .resource schema.
fn _resolve_nexus_root() -> string {
    let n = env("NEXUS")
    if n.len() > 0 { return n }
    let candidates = [HOME + "/core/nexus", HOME + "/core/nexus", "/root/core/nexus", "/home/nexus"]
    let mut i = 0
    while i < len(candidates) {
        if file_exists(candidates[i] + "/cli/run.hexa") { return candidates[i] }
        i = i + 1
    }
    return HOME + "/core/nexus"
}
let NEXUS_ROOT = _resolve_nexus_root()
let SIDECAR    = NEXUS_ROOT + "/state/raw_sha_last_seen.json"
let HISTORY    = NEXUS_ROOT + "/state/drill_baseline_history.jsonl"
let DRILL_CLI  = NEXUS_ROOT + "/cli/drill"

// ─── void-safe coercion ───
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _now_iso() -> string {
    return _str(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
}

// ─── sha256 of file path via /usr/bin/shasum ───
fn _file_sha256(path: string) -> string {
    let esc = path.replace("'", "")
    let cmd = "/usr/bin/shasum -a 256 '" + esc + "' 2>/dev/null | cut -c1-64"
    let r = _str(exec(cmd)).trim()
    return r
}

// ─── naive extract of "raw_sha256" value from sidecar JSON ───
// 의존성 최소화: jq 없이 string search.
fn _read_last_sha() -> string {
    if file_exists(SIDECAR) == false { return "" }
    let raw = _str(read_file(SIDECAR))
    let key = "\"raw_sha256\":"
    let idx = raw.index_of(key)
    if idx < 0 { return "" }
    let after = raw.substring(idx + key.len(), raw.len())
    let q1 = after.index_of("\"")
    if q1 < 0 { return "" }
    let tail = after.substring(q1 + 1, after.len())
    let q2 = tail.index_of("\"")
    if q2 < 0 { return "" }
    return tail.substring(0, q2)
}

fn _write_sidecar(new_sha: string, ts: string) {
    let body = "{\n"
        + "  \"raw_sha256\": \"" + new_sha + "\",\n"
        + "  \"last_checked_ts\": \"" + ts + "\",\n"
        + "  \"_doc\": \"Used by drill_cycle_trigger to detect .raw drift — see tool/drill_cycle_trigger.hexa\"\n"
        + "}\n"
    try { write_file(SIDECAR, body) } catch e {}
}

fn _append_history(ts: string, old_sha: string, new_sha: string) {
    let line = "{\"ts\":\"" + ts + "\""
        + ",\"trigger\":\"raw_drift\""
        + ",\"old_sha\":\"" + old_sha + "\""
        + ",\"new_sha\":\"" + new_sha + "\"}\n"
    try { append_file(HISTORY, line) } catch e {}
}

fn _invoke_drill_scan() {
    // hexa stdlib shell-out. cli/drill 은 problem_preset=scan 지원 가정.
    //   (실제 CLI 계약은 cli/drill/ README 기준; 여기서는 convention 따름.)
    let cmd = "cd '" + DRILL_CLI + "' && "
        + "hexa run ./drill.hexa --problem-preset scan 2>&1 | tail -40"
    let out = _str(exec(cmd))
    println(out)
}

fn main() -> i64 {
    let av = argv()
    let mut check_only = false
    let mut i = 0
    while i < av.len() {
        if av[i] == "--check-only" { check_only = true }
        i = i + 1
    }

    if file_exists(RAW_PATH) == false {
        println("[RAW-DRIFT-ERR] RAW_PATH missing: " + RAW_PATH)
        return 2
    }

    let cur_sha  = _file_sha256(RAW_PATH)
    let last_sha = _read_last_sha()
    let ts       = _now_iso()

    if cur_sha == "" {
        println("[RAW-DRIFT-ERR] shasum failed")
        return 2
    }

    // no drift → silent exit 0
    if cur_sha == last_sha { return 0 }

    // drift detected
    println("[RAW-DRIFT] old=" + last_sha + " new=" + cur_sha)

    if check_only { return 0 }

    // (b) drill cycle trigger
    _invoke_drill_scan()

    // (c) atlas recompute placeholder — follow-up wiring.
    //     targets: n6/atlas.n6.{events.jsonl, shard_meta.json, hub_centrality,
    //              stats, deg, consciousness, cdo_weekly}
    println("[ATLAS-RECOMPUTE] TODO")

    // (d) history append
    _append_history(ts, last_sha, cur_sha)

    // (e) sidecar update
    _write_sidecar(cur_sha, ts)

    return 0
}

main()
