// signal_weekly_digest.hexa — E6 대체 하네스
// atlas.signals.n6 에서 최근 7일 signal (특히 [M7!], [M10*], [CROSS]) 집계
// 텍스트 리포트 생성 — /Users/ghost/Dev/n6-architecture/reports/digest-YYYYMMDD.md
// 실행: hexa run $NEXUS/tool/signal_weekly_digest.hexa

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let N6 = HOME + "/Dev/n6-architecture"
let SIGNALS = NEXUS + "/n6/atlas.signals.n6"
let REPORT_DIR = N6 + "/reports"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    let mut v: i64 = 0
    try { v = to_int(first) } catch e { v = 0 }
    return v
}

fn now_iso() -> string {
    let r = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    return _str(r).trim()
}

fn today_ymd() -> string {
    let r = exec("date +%Y%m%d")
    return _str(r).trim()
}

fn count_grep(pat: string) -> i64 {
    let cmd = "{ grep -c '" + pat + "' '" + SIGNALS + "' 2>/dev/null || true; }"
    let r = exec(cmd)
    return _to_int0(_str(r).trim().split("\n")[0])
}

fn recent_ids(pat: string, since_date: string, max: i64) -> [string] {
    // atlas.signals.n6 는 각 @S 블록 아래 discovered_at 라인이 있음 — awk 로 blockwise 처리
    // 간단 구현: grep -A 20 로 후속 20줄 포함 → discovered_at 비교 → sig_id 수집
    let cmd = "awk -v since='" + since_date + "' '" +
              "/^@S / { id = $2; blk = $0; want = 0; buf = $0; next } " +
              "/^@S / == 0 && /discovered_at:/ { " +
              "  match($0, /[0-9]{4}-[0-9]{2}-[0-9]{2}/); " +
              "  d = substr($0, RSTART, RLENGTH); " +
              "  if (d >= since) print id " +
              "}' '" + SIGNALS + "' | sort -u | head -" + to_string(max)
    let r = exec(cmd)
    let text = _str(r)
    let lines = text.split("\n")
    let mut out: [string] = []
    for line in lines {
        let s = _str(line).trim()
        if s != "" { out = out + [s] }
    }
    return out
}

fn get_statement(sig_id: string) -> string {
    let cmd = "grep -F '@S " + sig_id + " =' '" + SIGNALS + "' | head -1 | " +
              "awk -F'= |:: signal' '{print $2}' | sed 's/ *$//'"
    let r = exec(cmd)
    let s = _str(r).trim()
    if s == "" { return "(문장 없음)" }
    return s
}

// ─── 메인 ───
let ymd = today_ymd()
let report_path = REPORT_DIR + "/digest-" + ymd + ".md"

println("signal_weekly_digest: ts=" + now_iso() + " report=" + report_path)

// 디렉토리 확인
if file_exists(REPORT_DIR) == false {
    exec("mkdir -p '" + REPORT_DIR + "'")
}

// 지난 7일 시작일 (YYYY-MM-DD)
let since_r = exec("date -u -v-7d +%Y-%m-%d 2>/dev/null || date -u -d '7 days ago' +%Y-%m-%d")
let since = _str(since_r).trim().split("\n")[0]

// 등급별 전역 count
let n_total = count_grep("^@S ")
let n_m10s = count_grep("\\[M10\\*\\]")
let n_m10 = count_grep("\\[M10\\]")
let n_m9 = count_grep("\\[M9\\]")
let n_m7b = count_grep("\\[M7!\\]")
let n_m7 = count_grep("\\[M7\\]")
let n_cross = count_grep("\\[CROSS")
let n_null = count_grep("\\[MN\\]")

// 최근 7일 breakthrough 후보
let recent_m7b = recent_ids("\\[M7!\\]", since, 20)
let recent_m10s = recent_ids("\\[M10\\*\\]", since, 20)
let recent_cross = recent_ids("\\[CROSS", since, 20)

// 리포트 생성
let mut body = "# atlas.signals.n6 주간 다이제스트 — " + ymd + "\n\n"
body = body + "> 생성: " + now_iso() + "\n"
body = body + "> 기간: " + since + " ~ 현재\n"
body = body + "> SSOT: " + SIGNALS + "\n\n"

body = body + "## 1. 전역 통계 (전체 signal)\n\n"
body = body + "| 등급 | 개수 |\n|------|-----:|\n"
body = body + "| 전체 | " + to_string(n_total) + " |\n"
body = body + "| [M10*] | " + to_string(n_m10s) + " |\n"
body = body + "| [M10] | " + to_string(n_m10) + " |\n"
body = body + "| [M9] | " + to_string(n_m9) + " |\n"
body = body + "| [M7!] | " + to_string(n_m7b) + " |\n"
body = body + "| [M7] | " + to_string(n_m7) + " |\n"
body = body + "| [CROSS] | " + to_string(n_cross) + " |\n"
body = body + "| [MN] NULL | " + to_string(n_null) + " |\n\n"

body = body + "## 2. 최근 7일 [M7!] breakthrough 후보 (" +
       to_string(recent_m7b.len()) + ")\n\n"
let mut i = 0
while i < recent_m7b.len() && i < 10 {
    let sid = recent_m7b[i]
    let st = get_statement(sid)
    body = body + "- **" + sid + "** — " + st + "\n"
    i = i + 1
}
if recent_m7b.len() == 0 { body = body + "_(없음)_\n" }

body = body + "\n## 3. 최근 7일 [M10*] conditional exact (" +
       to_string(recent_m10s.len()) + ")\n\n"
let mut j = 0
while j < recent_m10s.len() && j < 10 {
    let sid = recent_m10s[j]
    let st = get_statement(sid)
    body = body + "- **" + sid + "** — " + st + "\n"
    j = j + 1
}
if recent_m10s.len() == 0 { body = body + "_(없음)_\n" }

body = body + "\n## 4. 최근 7일 [CROSS] 3리포 공명 (" +
       to_string(recent_cross.len()) + ")\n\n"
let mut k = 0
while k < recent_cross.len() && k < 10 {
    let sid = recent_cross[k]
    let st = get_statement(sid)
    body = body + "- **" + sid + "** — " + st + "\n"
    k = k + 1
}
if recent_cross.len() == 0 { body = body + "_(없음)_\n" }

body = body + "\n---\n*자동 생성: signal_weekly_digest.hexa*\n"

try {
    write_file(report_path, body)
    println("  PASS: report written " + to_string(body.len()) + " bytes")
} catch e {
    println("  FAIL: write_file error")
    exit(1)
}

println("  total=" + to_string(n_total) + " M7!=" + to_string(n_m7b) +
        " M10*=" + to_string(n_m10s) + " CROSS=" + to_string(n_cross))
println("  report=" + report_path)
