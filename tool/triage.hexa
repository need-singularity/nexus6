// triage.hexa — findings 분류 리포트
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
// gc_log.jsonl + mistakes.jsonl 의 findings 를 kind × rule × 상위 디렉토리별 집계
// 산출: shared/tool/triage_report.json
// Usage: hexa shared/tool/triage.hexa

let REPO_ROOT = exec("git rev-parse --show-toplevel 2>/dev/null").trim()  // @allow-bare-exec
let MISTAKES = REPO_ROOT + "/tool/mistakes.jsonl"
let REPORT = REPO_ROOT + "/tool/triage_report.json"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn now_iso() -> string {
    return exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()  // @allow-bare-exec
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    return r
}

fn extract_field(line: string, key: string) -> string {
    let marker = "\"" + key + "\":\""
    let idx = line.index_of(marker)
    if idx < 0 { return "" }
    let after = line.substring(idx + len(marker), len(line))
    let end = after.index_of("\"")
    if end < 0 { return "" }
    return after.substring(0, end)
}

// 상위 디렉토리 추출: "shared/n6/foo.py" → "shared/n6"
fn top_dir(path: string) -> string {
    let first = path.index_of("/")
    if first < 0 { return path }
    let after = path.substring(first + 1, len(path))
    let second = after.index_of("/")
    if second < 0 { return path }
    return path.substring(0, first + 1 + second)
}

// ─── 집계 ───
if !file_exists(MISTAKES) {
    println("mistakes.jsonl 없음")
    exit(0)
}

let raw = exec("cat '" + MISTAKES + "' 2>/dev/null").trim()  // @allow-bare-exec
if raw == "" {
    println("mistakes.jsonl 비어있음")
    exit(0)
}

let lines = raw.split("\n")
let mut keys: [string] = []        // "kind|rule|topdir"
let mut counts: [i64] = []
let mut examples: [string] = []    // first file seen for that key

for ln in lines {
    let l = _str(ln).trim()
    if l == "" { continue }
    let kind = extract_field(l, "kind")
    let rule = extract_field(l, "rule")
    let file = extract_field(l, "file")
    if kind == "" || rule == "" || file == "" { continue }
    let td = top_dir(file)
    let key = kind + "|" + rule + "|" + td

    let mut found: i64 = -1
    let mut i: i64 = 0
    while i < len(keys) {
        if keys[i] == key { found = i; break }
        i = i + 1
    }
    if found < 0 {
        keys = keys.push(key)
        counts = counts.push(1)
        examples = examples.push(file)
    } else {
        // index 할당 no-op 우회 — counts 만 rebuild
        let mut new_counts: [i64] = []
        let mut j: i64 = 0
        while j < len(counts) {
            if j == found { new_counts = new_counts.push(counts[j] + 1) }
            else { new_counts = new_counts.push(counts[j]) }
            j = j + 1
        }
        counts = new_counts
    }
}

// ─── 리포트 생성 ───
let ts = now_iso()
let mut items: [string] = []
let mut i: i64 = 0
while i < len(keys) {
    let parts = keys[i].split("|")
    if len(parts) >= 3 {
        let kind = _str(parts[0])
        let rule = _str(parts[1])
        let td = _str(parts[2])
        let ex = _str(examples[i])
        let item = "{\"kind\":\"" + kind + "\",\"rule\":\"" + rule + "\",\"top_dir\":\"" + json_escape(td) + "\",\"count\":" + to_string(counts[i]) + ",\"example\":\"" + json_escape(ex) + "\"}"
        items = items.push(item)
    }
    i = i + 1
}

let mut body = "["
let mut k: i64 = 0
while k < len(items) {
    if k > 0 { body = body + "," }
    body = body + items[k]
    k = k + 1
}
body = body + "]"

let report = "{\n  \"ts\": \"" + ts + "\",\n  \"total_buckets\": " + to_string(len(items)) + ",\n  \"groups\": " + body + "\n}\n"
try { write_file(REPORT, report) } catch e {}

println("triage: " + to_string(len(items)) + " unique (kind × rule × top_dir)")
println("report: shared/tool/triage_report.json")

// 상위 5개 표시
let mut display: i64 = 0
let mut shown: i64 = 0
while shown < 5 && display < len(items) {
    println("  " + items[display])
    display = display + 1
    shown = shown + 1
}
exit(0)
