// tool/hexa_tool_inventory.hexa — 본 세션 hexa-only 도구 자동 카탈로그 (메타 도구)
//
// raw 9 hexa-only-suffix. tool/*.hexa 모두 walk → 첫 줄 desc 추출 + @tool annotation
// 검사 + raw compliance hint. 자기-반사적 도구 (자기 자신도 inventory에 포함).
//
// @tool(slug="hexa_tool_inventory", desc="hexa-only tool catalog + meta-stats")
// @usage:
//   hexa run tool/hexa_tool_inventory.hexa
//   HEXA_ARGV='--quiet' hexa run tool/hexa_tool_inventory.hexa
//   HEXA_ARGV='--session' hexa run tool/hexa_tool_inventory.hexa  # 본 세션만 (mtime ≥ 2026-04-25)
//
// sentinel: __HEXA_TOOL_INVENTORY__ total=N session_only=S has_at_tool=A
//
// raw 71 read-only / raw 73 admissibility / raw 80 sentinel

let TOOL_DIR = "/Users/ghost/core/nexus/tool"
let mut QUIET = false
let mut SESSION_ONLY = false

fn _argv() -> array {
    let raw = to_string(exec("printf '%s' \"${HEXA_ARGV:-}\""))
    let parts = split(raw, " ")
    let mut out = []
    let mut k = 0
    while k < len(parts) {
        if len(parts[k]) > 0 { out.push(parts[k]) }
        k = k + 1
    }
    return out
}

let args = _argv()
let mut i = 0
while i < len(args) {
    let a = args[i]
    if a == "--quiet" { QUIET = true }
    if a == "--session" { SESSION_ONLY = true }
    if a == "--help" || a == "-h" {
        println("usage: HEXA_ARGV='[--quiet | --session]' hexa run tool/hexa_tool_inventory.hexa")
        println("  본 세션 hexa-only 도구 자동 카탈로그")
        println("  --session  최신 mtime 기준 본 세션만 (대략 2026-04-25 이후)")
        return
    }
    i = i + 1
}

fn _say(msg: string) { if !QUIET { println(msg) } }

// .hexa file list via shell exec — raw 71 (no FS mutation)
let cmd_list = "ls " + TOOL_DIR + "/*.hexa 2>/dev/null | sort"
let raw_list = to_string(exec(cmd_list))
let entries = split(raw_list, "\n")

let mut total = 0
let mut session_count = 0
let mut has_at_tool = 0

_say("═══ hexa-only tool inventory (" + TOOL_DIR + ") ═══")
_say("")

for path in entries {
    let p = path.trim()
    if len(p) == 0 { continue }
    if !file_exists(p) { continue }
    total = total + 1

    // basename
    let bsi = p.last_index_of("/")
    let mut basename = p
    if bsi >= 0 { basename = p.substring(bsi + 1, len(p)) }

    // mtime via stat — 본 세션 판정 (2026-04-25 이후)
    let mtime_cmd = "stat -f '%Sm' -t '%Y-%m-%d' " + p + " 2>/dev/null || echo unknown"
    let mtime = to_string(exec(mtime_cmd)).trim()
    let mut is_session = false
    if mtime.index_of("2026-04-25") == 0 || mtime.index_of("2026-04-26") == 0 || mtime.index_of("2026-04-27") == 0 {
        is_session = true
        session_count = session_count + 1
    }

    if SESSION_ONLY && !is_session { continue }

    // first line desc 추출 (// tool/name.hexa — desc 형식)
    let head_cmd = "head -1 " + p + " 2>/dev/null"
    let firstline = to_string(exec(head_cmd)).trim()
    let mut desc = firstline
    // strip leading '// tool/...— ' or 'tool/'
    let dash = firstline.index_of("— ")
    if dash >= 0 {
        desc = firstline.substring(dash + 4, len(firstline))
    }

    // @tool annotation check
    let at_cmd = "grep -c '^// @tool' " + p + " 2>/dev/null || echo 0"
    let has_at = to_string(exec(at_cmd)).trim()
    if has_at != "0" { has_at_tool = has_at_tool + 1 }

    let mut tag = " "
    if is_session { tag = "★" }
    let mut atok = " "
    if has_at != "0" { atok = "@" }

    if !QUIET {
        // padding for basename
        let mut pad = ""
        let plen = 36 - len(basename)
        let mut q = 0
        while q < plen { pad = pad + " "; q = q + 1 }
        println("  " + tag + " " + atok + " " + basename + pad + "(" + mtime + ")  " + desc.substring(0, 50))
    }
}

_say("")
_say("legend: ★ = 본 세션 (2026-04-25/26/27)  @ = @tool annotation 있음")
_say("")
_say("aggregate: " + to_string(total) + " total .hexa files | " + to_string(session_count) + " session-tagged | " + to_string(has_at_tool) + " with @tool annotation")

println("__HEXA_TOOL_INVENTORY__ total=" + to_string(total) + " session_only=" + to_string(session_count) + " has_at_tool=" + to_string(has_at_tool))
