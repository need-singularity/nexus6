{
  "schema": "nexus.harness.evolution.v1",
  "updated": "2026-04-13",
  "principle": "As models get smarter, harnesses must get simpler — review deletion before addition",
  "source": "Richard Sutton — The Bitter Lesson",
  "stages": [
    {
      "id": "L1",
      "name": "setup_manual_enforce",
      "status": "done",
      "artifacts": [
        "shared/tool/lint.hexa",
        "shared/tool/gc.hexa",
        "shared/tool/mistakes.jsonl",
        ".git/hooks/pre-commit"
      ],
      "behavior": "manual rule enforcement via pre-commit; gc run on demand",
      "logs": ["lint_log.jsonl", "gc_log.jsonl", "mistakes.jsonl"]
    },
    {
      "id": "L2",
      "name": "autofix_proposal_loop",
      "status": "done",
      "artifacts": ["shared/tool/autofix.hexa"],
      "behavior": "scan mistakes.jsonl recurring (file × rule) patterns; emit proposals with known-fix templates; no auto-edit",
      "input": "shared/tool/mistakes.jsonl",
      "output": "shared/tool/autofix_proposals.jsonl",
      "threshold_default": 3,
      "window_default": 500,
      "not_in_scope": "automatic code rewriting — too risky for nexus deliberate violations"
    },
    {
      "id": "L3",
      "name": "weekly_gc_chain",
      "status": "done_pending_registration",
      "artifacts": ["shared/tool/gc-weekly.hexa"],
      "behavior": "7-day cooldown wrapper around gc.hexa --scan; safe to call from growth-tick or cron unconditionally",
      "cooldown_file": "shared/tool/.gc_weekly_cooldown",
      "pending": "hooks-config.json registration requires user approval — not in this commit"
    },
    {
      "id": "bitter_gate",
      "name": "rule_usage_audit",
      "status": "done",
      "artifacts": ["shared/tool/bitter-gate.hexa"],
      "behavior": "count each rule's hits across lint_log + gc_log within window; mark dormant (0 hits) as deletion candidates",
      "output": "shared/tool/rules_usage.jsonl",
      "principle": "before adding any new rule, run bitter-gate and prune dormant ones first"
    },
    {
      "id": "L4",
      "name": "engine_evolution",
      "ko": "엔진 진화",
      "desc": "engine_forge 가 메타 진화 — discover/spawn/bench/absorb/prune. L1~L3 룰 진화의 메타 레이어",
      "parent": "L3",
      "status": "done",
      "artifacts": [
        "shared/tool/engine_forge.hexa",
        "shared/tool/engine_candidates.jsonl",
        "shared/tool/engines_usage.jsonl",
        "shared/config/engine_registry.json",
        "shared/tool/auto/"
      ],
      "behavior": "discover atlas/cross_feed gaps → spawn sandbox .hexa → 7d bench → score>50 absorb + register → <10 prune dormant",
      "cooldown": "7d bench window; absorb_threshold=50; prune_threshold=10",
      "env_flags": {
        "NEXUS_AUTO_FORGE": "1 enables spawn code-gen (default dry)",
        "NEXUS_FORGE_PRUNE": "1 enables real prune delete (default report-only)"
      },
      "failed_branches": [],
      "principle": "engine 도 L1~L3 룰처럼 lifecycle 을 가진다 — spawn → bench → absorb/prune"
    }
  ],
  "loop_graph": {
    "edges": [
      {"from": "commit", "to": "lint.hexa", "via": ".git/hooks/pre-commit"},
      {"from": "lint.hexa", "to": "mistakes.jsonl", "on": "violation"},
      {"from": "mistakes.jsonl", "to": "autofix.hexa", "via": "manual or cron"},
      {"from": "autofix.hexa", "to": "autofix_proposals.jsonl", "effect": "propose"},
      {"from": "autofix_proposals.jsonl", "to": "rule_update", "effect": "human-in-the-loop"},
      {"from": "cron_or_growth_tick", "to": "gc-weekly.hexa", "via": "weekly chain (pending approval)"},
      {"from": "gc-weekly.hexa", "to": "gc.hexa", "on": "cooldown_expired"},
      {"from": "gc.hexa", "to": "gc_log.jsonl"},
      {"from": "any_rule_add_intent", "to": "bitter-gate.hexa", "via": "mandatory gate"},
      {"from": "bitter-gate.hexa", "to": "rules_usage.jsonl"},
      {"from": "rules_usage.jsonl", "to": "rule_prune", "on": "status == dormant"},
      {"from": "atlas.n6.deg+cross_feed.jsonl", "to": "engine_forge.hexa", "via": "discover"},
      {"from": "engine_forge.hexa", "to": "engine_candidates.jsonl", "effect": "append"},
      {"from": "engine_candidates.jsonl", "to": "auto/<name>.hexa", "via": "spawn (NEXUS_AUTO_FORGE=1)"},
      {"from": "auto/<name>.hexa", "to": "engines_usage.jsonl", "via": "bench"},
      {"from": "engines_usage.jsonl", "to": "shared/tool/<name>.hexa", "on": "7d avg score > 50 (absorb)"},
      {"from": "engines_usage.jsonl", "to": "dormant_flag", "on": "7d no-hit or score < 10 (prune)"},
      {"from": "engine_registry.json", "to": "bitter-gate.hexa --engine-audit", "via": "optional audit"}
    ]
  },
  "entrypoints": [
    {"cmd": "hexa shared/tool/lint.hexa --staged", "when": "every commit (auto)"},
    {"cmd": "hexa shared/tool/gc.hexa --scan", "when": "manual or via gc-weekly"},
    {"cmd": "hexa shared/tool/gc-weekly.hexa", "when": "growth-tick or cron (cooldown-guarded)"},
    {"cmd": "hexa shared/tool/autofix.hexa --analyze", "when": "manual after mistakes accumulate"},
    {"cmd": "hexa shared/tool/autofix.hexa --auto-bitter", "when": "repeated mistakes → bitter-gate rule promotion proposal"},
    {"cmd": "hexa shared/tool/bitter-gate.hexa --audit", "when": "before adding any new rule"},
    {"cmd": "hexa shared/tool/bitter-gate.hexa --engine-audit", "when": "L4 audit — list 7d unused engines"},
    {"cmd": "hexa shared/tool/engine_forge.hexa discover", "when": "atlas/cross_feed gap analysis"},
    {"cmd": "hexa shared/tool/engine_forge.hexa bench <name>", "when": "score recompute (7d)"},
    {"cmd": "hexa shared/tool/engine_forge.hexa absorb <name>", "when": "bench avg>50 → registry promote"},
    {"cmd": "hexa shared/tool/engine_forge.hexa prune", "when": "dormant engines flag (default report-only)"}
  ],
  "next": [
    "real-world verification of L1 (user local; sandbox blocked hexa exec)",
    "register gc-weekly into growth-tick.hexa (user approval on hooks-config.json)",
    "first bitter-gate --audit run after lint_log accumulates real traffic",
    "consider L4: self-simplification — if bitter-gate keeps surfacing the same dormant rules, promote the prune itself to auto"
  ],
  "forbidden": [
    "automatic source-code rewriting by autofix.hexa (violations in nexus are usually deliberate)",
    "adding new rules without first running bitter-gate to prune dormant ones"
  ]
}
