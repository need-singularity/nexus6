// tasks/marker.hexa — mode: marker (마커 내용 주입)
// usage: hexa run tasks/marker.hexa <task_id> <src> <marker_start> <marker_end> <projects_key> <dry> <do_git>

let HOME = env("HOME")
let NEXUS = HOME + "/core/nexus"
let MANIFEST = NEXUS + "/tool/sync_manifest.json"

fn expand_path(p: str) -> str {
    if p.substring(0, 1) == "/" { return p }
    if p.substring(0, 2) == "~/" { return HOME + p.substring(1, p.len()) }
    return HOME + "/core/nexus/" + p
}

fn project_list(key: str) -> str {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = key
    let _ = MANIFEST
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at tasks/marker.hexa:project_list. Escalate to user for hexa-native replacement.")
    return ""
}

fn repo_of(name: str) -> str {
    if name == "nexus" { return HOME + "/core/nexus" }
    if name == "TECS-L" { return HOME + "/core/nexus/shared" }
    if name == "SEDI" { return HOME + "/Dev/sedi" }
    return HOME + "/Dev/" + name
}

// 파일명 결정: {name} 포함된 경로에서 CLAUDE.md / README.md 판단
fn file_for(name: str, dst_basename: str) -> str {
    return repo_of(name) + "/" + dst_basename
}

fn apply_marker(file: str, start: str, end: str, body: str, dry: bool) -> str {
    let exists = to_string(exec("test -f '" + file + "' && echo y || echo n")).trim()
    if exists != "y" { return "skip:missing" }
    let text = read_file(file)
    if text.contains(start) == false { return "skip:no_marker" }
    let before = text.split(start)[0] + start
    let after_parts = text.split(end)
    let mut after = end
    if after_parts.len() >= 2 { after = end + after_parts[1] }
    let updated = before + "\n" + body + "\n" + after
    if updated == text { return "ok:nochange" }
    if dry { return "dry:would_change" }
    try { write_file(file, updated) } catch e { return "fail:write" }
    return "changed"
}

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    if argv.len() < 10 {
        eprintln("usage: marker <task_id> <src> <marker_start> <marker_end> <projects_key> <dst_basename> <dry> <do_git>")
        exit(2)
    }
    let task_id = argv[2]
    let src = expand_path(argv[3])
    let ms = argv[4]
    let me = argv[5]
    let pkey = argv[6]
    let dst_base = argv[7]
    let dry = argv[8] == "1"
    // do_git 는 commit 단계에서 실제 푸시 여부에만 영향 — marker.hexa 단독은 파일 수정만 담당
    // let do_git = argv[9] == "1"

    if file_exists(src) == false {
        println("[" + task_id + "] skip:src_missing " + src)
        return
    }
    let body = read_file(src)
    let names = project_list(pkey)
    if names.len() == 0 {
        println("[" + task_id + "] skip:no_projects projects_key=" + pkey)
        return
    }

    let mut changed = 0
    let mut skipped = 0
    for raw in names.split(" ") {
        let name = raw.trim()
        if name.len() == 0 { continue }
        let file = file_for(name, dst_base)
        let res = apply_marker(file, ms, me, body, dry)
        if res == "changed" || res == "dry:would_change" {
            changed = changed + 1
            println("[" + task_id + ":" + name + "] " + res)
        } else {
            skipped = skipped + 1
        }
    }
    println("[" + task_id + "] summary changed=" + to_string(changed) + " skipped=" + to_string(skipped))
}

main()
