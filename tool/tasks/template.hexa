// tasks/template.hexa — mode: template (.claude/settings.json 템플릿 적용, 커스텀 보존)
// src 원본 sync_settings.hexa 로직을 재현 (호출만 wrap, 본문 hexa 파일은 그대로 남김).
// usage: hexa run tasks/template.hexa <task_id> <dry> <do_git>

let HOME = env("HOME")
let NEXUS = HOME + "/core/nexus"
let HEXA = NEXUS + "/bin/hexa"
let ORIGINAL = NEXUS + "/scripts/sync_settings.hexa"

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    if argv.len() < 5 {
        eprintln("usage: template <task_id> <dry> <do_git>")
        exit(2)
    }
    let task_id = argv[2]
    let dry = argv[3] == "1"
    let do_git = argv[4] == "1"

    if dry {
        println("[" + task_id + "] dry:would_apply_template 7_projects (anima,papers,void,n6-architecture,airgenome,contact,hexa-lang)")
        return
    }

    if file_exists(ORIGINAL) == false {
        println("[" + task_id + "] skip:original_missing")
        return
    }

    // original hexa 는 자체 delta check 포함 — 무조건 호출
    let mut cmd = HEXA + " run " + ORIGINAL
    if do_git == false {
        // v1: do_git=false 시 git 회피를 위해 env flag 전달 (원본은 아직 미지원)
        cmd = "SYNC_NO_GIT=1 " + cmd
    }
    let out = to_string(exec(cmd + " 2>&1")).trim()
    if out.len() > 0 {
        println("[" + task_id + "] " + out.split("\n")[0])
    } else {
        println("[" + task_id + "] ok:silent")
    }
}

main()
