// tasks/multi.hexa — mode: multi (lenses 처럼 다중 타겟 갱신)
// usage: hexa run tasks/multi.hexa <task_id> <dry> <do_git>
// 본 핸들러는 sync-nexus-lenses.hexa 를 직접 호출한다 (복잡 로직 재생산 회피).

let HOME = env("HOME")
let NEXUS = HOME + "/core/nexus"
let HEXA = NEXUS + "/bin/hexa"
let ORIGINAL = NEXUS + "/scripts/sync-nexus-lenses.hexa"

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    if argv.len() < 5 {
        eprintln("usage: multi <task_id> <dry> <do_git>")
        exit(2)
    }
    let task_id = argv[2]
    let dry = argv[3] == "1"
    // do_git 은 원본 스크립트 내부에서 결정 (기본 커밋 only, push 없음)

    if file_exists(ORIGINAL) == false {
        println("[" + task_id + "] skip:original_missing " + ORIGINAL)
        return
    }

    if dry {
        let test_file = HOME + "/core/canon/bridge/tests/telescope_test.rs"
        if file_exists(test_file) == false {
            println("[" + task_id + "] dry:would_skip test_file_missing")
            return
        }
        let n = to_string(exec("grep -oE 'reg\\.len\\(\\),\\s*[0-9]+' '" + test_file + "' | head -1 | grep -oE '[0-9]+$' 2>/dev/null")).trim()
        println("[" + task_id + "] dry:would_update_lens_count=" + n)
        return
    }

    let out = to_string(exec(HEXA + " run " + ORIGINAL + " 2>&1")).trim()
    let summary = if out.len() > 0 { out.split("\n")[out.split("\n").len() - 1] } else { "silent" }
    println("[" + task_id + "] " + summary)
}

main()
