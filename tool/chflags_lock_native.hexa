// tool/chflags_lock_native.hexa — ai-native (raw 66) wrapper for chflags uchg/schg
//                                  with mandatory reason+fix metadata sidecar.
//
// @no-lock-needed
// @no-sandbox
// @resolver-bypass(reason="chflags uchg/nouchg are BSD-only syscalls — must land on bare Mac inode, not container bind-mount")
// @omega-saturation-exempt("static OS-level enforcement primitive — single-shot lock/unlock is idempotent per raw 65")
// @chflags-lock-wrapper — only authorized bare chflags caller (audited by tool/chflags_lock_audit.hexa)
//
// architecture witness (4 Tier-1 promotions, 14 falsifiers):
//   /Users/ghost/core/nexus/design/kick/2026-04-26_chflags-lock-ai-native-error-message-raw-66-reason-fix-guida_omega_cycle.json
//   commit 81f9e268
//
// SUBCOMMANDS
//   lock    --path <p> --reason <r> --fix <f> [--fix <f>...] [--guidance <g>...] [--level L1|L2]
//   unlock  --path <p> [--reason <r>] [--level L1|L2]
//   lookup  --path <p> [--json]
//   explain --path <p>     — EPERM-victim helper (emits raw 66 trailer to stderr)
//   status  --path <p>     — pretty-print state + metadata
//   list                   — list all sidecars (sibling + central)
//   selftest               — F1-F7 falsifier suite
//
// EXIT CODES
//   0 = success (also for lookup-unlocked-null)
//   1 = io / chflags failure
//   2 = required arg missing → ai-native raw 66 hard-fail
//   3 = lock collision (different reason on same path)
//   4 = path missing
//
// SENTINEL (raw 80)  — last stdout line:
//   __CHFLAGS_LOCK_RESULT__ <PASS|FAIL> path=<abs> op=<lock|unlock|lookup|explain|status|list|selftest>
//
// SCHEMA — chflags_lock_native.v1
//   required:  path, reason, fix[], locked_at, locked_by_pid, locked_by_session,
//              locker_actor, schema_version
//   optional:  guidance[], roadmap_ref, parent_lock_ts
//
// SIDECAR LOCATION (axis_metadata_sidecar_location decision)
//   primary:  <abs_path>.lock_meta.json  (sibling — greppable by EPERM victim)
//   fallback: ~/.local/state/chflags_locks/<sha256(abs)>.json  (when parent dir is itself locked)

let SCHEMA_VERSION = "chflags_lock_native.v1"
let SENTINEL_TAG = "__CHFLAGS_LOCK_RESULT__"

// wrapper-deps: paths that auto-inject canonical reason+fix on self-reference (F7)
let WRAPPER_DEPS = [
    "tool/chflags_lock_native.hexa",
    "tool/chflags_lock_audit.hexa"
]

// ─── void-safe coercion + tiny helpers ───────────────────────────────────

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _shq(s: string) -> string {
    let r = s.replace("'", "'\\''")
    return "'" + r + "'"
}

fn sh(cmd: string) -> string {
    return _str(exec(cmd)).trim()
}

fn _utc_iso() -> string {
    return sh("date -u +%Y-%m-%dT%H:%M:%SZ")
}

fn _pid() -> string {
    return sh("echo $$")
}

fn _hostname() -> string {
    return sh("hostname -s 2>/dev/null")
}

fn _actor() -> string {
    let u = env("USER")
    if u != "" { return u }
    return "unknown"
}

fn _session() -> string {
    let s = env("HEXA_SESSION_ID")
    if s != "" { return s }
    let s2 = env("CLAUDE_SESSION_ID")
    if s2 != "" { return s2 }
    let s3 = env("HIVE_SESSION_ID")
    if s3 != "" { return s3 }
    return _hostname() + "-" + _pid()
}

fn _is_darwin() -> bool { return sh("uname -s") == "Darwin" }
fn _is_linux()  -> bool { return sh("uname -s") == "Linux" }

fn _path_exists(p: string) -> bool {
    if p == "" { return false }
    return file_exists(p)
}

fn _abs(p: string) -> string {
    if p == "" { return "" }
    let r = sh("python3 -c 'import os,sys; print(os.path.abspath(os.path.expanduser(sys.argv[1])))' " + _shq(p) + " 2>/dev/null")
    if r != "" { return r }
    let r2 = sh("readlink -f " + _shq(p) + " 2>/dev/null")
    if r2 != "" { return r2 }
    if p.substring(0, 1) == "/" { return p }
    return sh("pwd") + "/" + p
}

fn _path_sha(p: string) -> string {
    return sh("printf '%s' " + _shq(p) + " | shasum -a 256 | awk '{print $1}'")
}

// ─── sidecar location resolution (sibling primary, central fallback) ─────

fn _central_dir() -> string { return env("HOME") + "/.local/state/chflags_locks" }
fn _central_path(abs: string) -> string { return _central_dir() + "/" + _path_sha(abs) + ".json" }
fn _sibling_path(abs: string) -> string { return abs + ".lock_meta.json" }

// resolve which existing sidecar to read (sibling first, central fallback)
fn _existing_sidecar(abs: string) -> string {
    let sib = _sibling_path(abs)
    if _path_exists(sib) { return sib }
    let cen = _central_path(abs)
    if _path_exists(cen) { return cen }
    return ""
}

// resolve where to write a new sidecar — sibling unless parent dir is locked
fn _resolve_write_target(abs: string) -> string {
    let parent = sh("dirname " + _shq(abs))
    if parent == "" { return _sibling_path(abs) }
    let pflags = sh("ls -lOd " + _shq(parent) + " 2>/dev/null | awk '{print $5}'")
    if pflags.contains("uchg") || pflags.contains("schg") {
        let _ = sh("mkdir -p " + _shq(_central_dir()))
        return _central_path(abs)
    }
    return _sibling_path(abs)
}

// ─── lock-state probe (cross-platform) ───────────────────────────────────

fn _darwin_locked(p: string) -> bool {
    let line = sh("ls -lOd " + _shq(p) + " 2>/dev/null")
    if line == "" { return false }
    if line.contains(" uchg ") { return true }
    if line.contains(" uchg,") { return true }
    if line.contains(",uchg ") { return true }
    if line.contains(",uchg,") { return true }
    if line.contains(" schg ") { return true }
    if line.contains(" schg,") { return true }
    if line.contains(",schg ") { return true }
    if line.contains(",schg,") { return true }
    return false
}

fn _linux_locked(p: string) -> bool {
    let line = sh("lsattr -d " + _shq(p) + " 2>/dev/null")
    if line == "" { return false }
    let mut i = 0
    while i < len(line) {
        let c = line.substring(i, i + 1)
        if c == " " || c == "\t" { break }
        if c == "i" { return true }
        i = i + 1
    }
    return false
}

fn _is_locked(p: string) -> bool {
    if !_path_exists(p) { return false }
    if _is_darwin() { return _darwin_locked(p) }
    if _is_linux()  { return _linux_locked(p) }
    return false
}

// ─── chflags primitives — ONLY authorized bare chflags call sites ────────
// @chflags-lock-wrapper-call-site

fn _apply_flag(p: string, level: string) -> i64 {
    if _is_darwin() {
        let cmd = if level == "L2" { "sudo -n chflags schg " + _shq(p) + " 2>&1" } else { "chflags uchg " + _shq(p) + " 2>&1" }
        let r = exec_with_status(cmd)
        return r[1]
    }
    if _is_linux() {
        let r = exec_with_status("chattr +i " + _shq(p) + " 2>/dev/null")
        if r[1] == 0 { return 0 }
        let r2 = exec_with_status("sudo -n chattr +i " + _shq(p) + " 2>&1")
        return r2[1]
    }
    return 0
}

fn _remove_flag(p: string, level: string) -> i64 {
    if _is_darwin() {
        let cmd = if level == "L2" { "sudo -n chflags noschg " + _shq(p) + " 2>&1" } else { "chflags nouchg " + _shq(p) + " 2>&1" }
        let r = exec_with_status(cmd)
        return r[1]
    }
    if _is_linux() {
        let r = exec_with_status("chattr -i " + _shq(p) + " 2>/dev/null")
        if r[1] == 0 { return 0 }
        let r2 = exec_with_status("sudo -n chattr -i " + _shq(p) + " 2>&1")
        return r2[1]
    }
    return 0
}

// ─── JSON ────────────────────────────────────────────────────────────────

fn _json_escape(s: string) -> string {
    let mut out = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if      c == "\"" { out = out + "\\\"" }
        else if c == "\\" { out = out + "\\\\" }
        else if c == "\n" { out = out + "\\n" }
        else if c == "\r" { out = out + "\\r" }
        else if c == "\t" { out = out + "\\t" }
        else { out = out + c }
        i = i + 1
    }
    return out
}

fn _arr_to_json(arr: [string]) -> string {
    let mut s = "["
    let mut i = 0
    while i < len(arr) {
        if i > 0 { s = s + "," }
        s = s + "\"" + _json_escape(arr[i]) + "\""
        i = i + 1
    }
    return s + "]"
}

// single-key string extractor (sidecar bodies are produced by _json_escape, so
// only \" \\ \n \r \t escapes are used).
fn _json_get_str(body: string, key: string) -> string {
    let k = "\"" + key + "\":\""
    let idx = body.index_of(k)
    if idx < 0 { return "" }
    let mut i = idx + len(k)
    let mut out = ""
    while i < len(body) {
        let c = body.substring(i, i + 1)
        if c == "\\" && i + 1 < len(body) {
            let n = body.substring(i + 1, i + 2)
            if      n == "\"" { out = out + "\"" }
            else if n == "\\" { out = out + "\\" }
            else if n == "n"  { out = out + "\n" }
            else if n == "r"  { out = out + "\r" }
            else if n == "t"  { out = out + "\t" }
            else { out = out + n }
            i = i + 2
            continue
        }
        if c == "\"" { break }
        out = out + c
        i = i + 1
    }
    return out
}

fn _json_get_int(body: string, key: string) -> i64 {
    let k = "\"" + key + "\":"
    let idx = body.index_of(k)
    if idx < 0 { return 0 }
    let mut i = idx + len(k)
    while i < len(body) {
        let c = body.substring(i, i + 1)
        if c == " " || c == "\t" { i = i + 1; continue }
        break
    }
    let mut sign: i64 = 1
    if i < len(body) && body.substring(i, i + 1) == "-" {
        sign = -1
        i = i + 1
    }
    let mut n: i64 = 0
    let mut saw = false
    while i < len(body) {
        let c = body.substring(i, i + 1)
        if c >= "0" && c <= "9" {
            n = n * 10 + to_int(c)
            saw = true
            i = i + 1
            continue
        }
        break
    }
    if !saw { return 0 }
    return n * sign
}

// extract array of strings — assumes simple ["a","b"] form (writer always uses _arr_to_json).
fn _json_get_arr(body: string, key: string) -> [string] {
    let k = "\"" + key + "\":["
    let idx = body.index_of(k)
    if idx < 0 { return [] }
    let mut i = idx + len(k)
    let mut out: [string] = []
    let mut buf = ""
    let mut in_s = false
    while i < len(body) {
        let c = body.substring(i, i + 1)
        if in_s {
            if c == "\\" && i + 1 < len(body) {
                let n = body.substring(i + 1, i + 2)
                if      n == "\"" { buf = buf + "\"" }
                else if n == "\\" { buf = buf + "\\" }
                else if n == "n"  { buf = buf + "\n" }
                else if n == "r"  { buf = buf + "\r" }
                else if n == "t"  { buf = buf + "\t" }
                else { buf = buf + n }
                i = i + 2
                continue
            }
            if c == "\"" { in_s = false; out = out + [buf]; buf = ""; i = i + 1; continue }
            buf = buf + c
            i = i + 1
            continue
        }
        if c == "\"" { in_s = true; i = i + 1; continue }
        if c == "]"  { break }
        i = i + 1
    }
    return out
}

// ─── schema validity (F2) ────────────────────────────────────────────────

fn _validate_schema(body: string) -> bool {
    if body.trim() == "" { return false }
    if body.index_of("\"path\":") < 0 { return false }
    if body.index_of("\"reason\":") < 0 { return false }
    if body.index_of("\"fix\":") < 0 { return false }
    if body.index_of("\"locked_at\":") < 0 { return false }
    if body.index_of("\"locked_by_pid\":") < 0 { return false }
    if body.index_of("\"locked_by_session\":") < 0 { return false }
    if body.index_of("\"locker_actor\":") < 0 { return false }
    if body.index_of("\"" + SCHEMA_VERSION + "\"") < 0 { return false }
    return true
}

// ─── self-reference detection (F7) ───────────────────────────────────────

fn _is_wrapper_dep(abs: string) -> bool {
    let mut i = 0
    while i < len(WRAPPER_DEPS) {
        let suf = WRAPPER_DEPS[i]
        let n = len(abs)
        let m = len(suf)
        if n >= m && abs.substring(n - m, n) == suf { return true }
        i = i + 1
    }
    return false
}

fn _self_reason() -> string {
    return "raw-66-wrapper-self-reference: locking the locker (tier2_required infra per raw 1 + raw 0 SSOT)"
}

fn _self_fix() -> [string] {
    return [
        "hexa run tool/chflags_lock_native.hexa unlock --path <self> --reason '<amend reason>'",
        "consult .raw-audit ledger for prior unlock context per raw 85"
    ]
}

fn _self_guidance() -> [string] {
    return [
        "this wrapper enforces the raw 66 ai-native error message contract — modifying it requires the same unlock-edit-relock ladder as raw 1 5-SSOT"
    ]
}

// ─── audit ledger (raw 77/85 .raw-audit append) ──────────────────────────

fn _audit_path() -> string {
    let pwd = env("PWD")
    if pwd == "" {
        return env("HOME") + "/core/nexus/.raw-audit"
    }
    let r = sh("git -C " + _shq(pwd) + " rev-parse --show-toplevel 2>/dev/null")
    if r != "" { return r + "/.raw-audit" }
    return env("HOME") + "/core/nexus/.raw-audit"
}

fn _audit_append(op: string, abs: string, reason: string, sidecar_inline: string) {
    let row = "{\"ts\":\"" + _utc_iso() + "\","
            + "\"op\":\"" + _json_escape(op) + "\","
            + "\"path\":\"" + _json_escape(abs) + "\","
            + "\"reason\":\"" + _json_escape(reason) + "\","
            + "\"actor\":\"" + _json_escape(_actor()) + "\","
            + "\"window_sec\":0,"
            + "\"pid\":" + _pid() + ","
            + "\"host\":\"" + _json_escape(_hostname()) + "\","
            + "\"prev_ts\":\"\","
            + "\"sidecar_metadata_archived\":" + sidecar_inline + "}\n"
    let p = _audit_path()
    try { append_file(p, row) } catch e {
        eprintln("warn: audit append failed path=" + p)
    }
}

// ─── sidecar build / read / delete ───────────────────────────────────────

fn _build_sidecar(abs: string, reason: string, fix: [string], guidance: [string]) -> string {
    let mut s = "{"
    s = s + "\"path\":\"" + _json_escape(abs) + "\","
    s = s + "\"reason\":\"" + _json_escape(reason) + "\","
    s = s + "\"fix\":" + _arr_to_json(fix) + ","
    if len(guidance) > 0 {
        s = s + "\"guidance\":" + _arr_to_json(guidance) + ","
    }
    s = s + "\"locked_at\":\"" + _utc_iso() + "\","
    s = s + "\"locked_by_pid\":" + _pid() + ","
    s = s + "\"locked_by_session\":\"" + _json_escape(_session()) + "\","
    s = s + "\"locker_actor\":\"" + _json_escape(_actor()) + "\","
    s = s + "\"schema_version\":\"" + SCHEMA_VERSION + "\""
    s = s + "}\n"
    return s
}

fn _read_sidecar(abs: string) -> string {
    let p = _existing_sidecar(abs)
    if p == "" { return "" }
    return _str(read_file(p))
}

fn _delete_sidecar(abs: string) -> bool {
    let p = _existing_sidecar(abs)
    if p == "" { return true }
    let r = exec_with_status("rm -f " + _shq(p) + " 2>&1")
    if r[1] != 0 { return false }
    if _path_exists(p) { return false }
    return true
}

// ─── sentinel + raw 66 emitters ──────────────────────────────────────────

fn _sentinel(verdict: string, abs: string, op: string) {
    println("")
    println(SENTINEL_TAG + " " + verdict + " path=" + abs + " op=" + op)
}

fn _raw66(reason_class: string, specifics: string, fix_list: [string]) {
    eprintln("reason: " + reason_class + ": " + specifics)
    let mut s = "fix: "
    let mut i = 0
    while i < len(fix_list) {
        if i > 0 { s = s + "  " }
        s = s + to_string(i + 1) + ") " + fix_list[i]
        i = i + 1
    }
    eprintln(s)
    eprintln("ref: raw:ai-native-error-message (raw#66)")
}

// ─── argv parsing helpers ────────────────────────────────────────────────

fn _argv() -> [string] { return argv() }

// scan all occurrences of --key, returning array of values (repeatable flag)
fn _arg_list(av: [string], key: string) -> [string] {
    let mut out: [string] = []
    let mut i = 2
    while i < len(av) {
        if av[i] == key && i + 1 < len(av) {
            out = out + [_str(av[i + 1])]
        }
        i = i + 1
    }
    return out
}

fn _arg_kv(av: [string], key: string) -> string {
    let arr = _arg_list(av, key)
    if len(arr) > 0 { return arr[0] }
    return ""
}

fn _arg_flag(av: [string], key: string) -> bool {
    let mut i = 2
    while i < len(av) {
        if av[i] == key { return true }
        i = i + 1
    }
    return false
}

// ─── subcommand: lock ────────────────────────────────────────────────────

fn cmd_lock(av: [string]) -> i64 {
    let path = _arg_kv(av, "--path")
    let mut reason = _arg_kv(av, "--reason")
    let mut fixes = _arg_list(av, "--fix")
    let mut guidance = _arg_list(av, "--guidance")
    let mut level = _arg_kv(av, "--level")
    if level == "" { level = "L1" }

    let abs = if path == "" { "" } else { _abs(path) }
    let self_ref = abs != "" && _is_wrapper_dep(abs)

    // F7 — self-reference auto-injection (canonical defaults bypass required-arg)
    if self_ref {
        if reason == "" { reason = _self_reason() }
        if len(fixes) == 0 { fixes = _self_fix() }
        if len(guidance) == 0 { guidance = _self_guidance() }
    }

    // F1 — required args
    if path == "" {
        _raw66("validation-fail", "required-arg-missing-path",
            ["hexa run tool/chflags_lock_native.hexa lock --path <abs> --reason '<r>' --fix '<cmd>' [--fix '<cmd>'] [--guidance '<text>']",
             "cite raw 66 trailer schema for context"])
        _sentinel("FAIL", "", "lock")
        return 2
    }
    if reason == "" {
        _raw66("validation-fail", "required-arg-missing-reason",
            ["hexa run tool/chflags_lock_native.hexa lock --path " + abs + " --reason '<causal-class>: <specifics>' --fix '<cmd>'",
             "raw 66: reason = cause-class + specifics; fix = numbered candidate commands"])
        _sentinel("FAIL", abs, "lock")
        return 2
    }
    if len(fixes) == 0 {
        _raw66("validation-fail", "required-arg-missing-fix",
            ["hexa run tool/chflags_lock_native.hexa lock --path " + abs + " --reason '" + reason + "' --fix '<remediation cmd>'",
             "--fix is repeatable; provide ordered candidate commands the EPERM victim can run"])
        _sentinel("FAIL", abs, "lock")
        return 2
    }

    if !_path_exists(abs) {
        _raw66("validation-fail", "path-not-found",
            ["ls -la " + _shq(abs),
             "create the target before locking",
             "verify path resolution (relative paths resolve against PWD)"])
        _sentinel("FAIL", abs, "lock")
        return 4
    }

    // collision: already locked AND existing sidecar with different reason → exit 3
    let prev_body = _read_sidecar(abs)
    let was_locked = _is_locked(abs)
    if was_locked && prev_body != "" {
        let prev_reason = _json_get_str(prev_body, "reason")
        if prev_reason != "" && prev_reason != reason {
            _raw66("validation-fail", "lock-collision-different-reason",
                ["hexa run tool/chflags_lock_native.hexa lookup --path " + _shq(abs),
                 "hexa run tool/chflags_lock_native.hexa unlock --path " + _shq(abs) + " --reason 'amend before relock'",
                 "re-issue lock with the correct reason"])
            eprintln("  existing reason: " + prev_reason)
            eprintln("  new reason:      " + reason)
            _sentinel("FAIL", abs, "lock")
            return 3
        }
    }

    // resolve sidecar write target (sibling primary, central fallback)
    let target = _resolve_write_target(abs)
    let body = _build_sidecar(abs, reason, fixes, guidance)

    // fail-closed: write sidecar BEFORE applying chflags. If sidecar write fails, do not lock.
    let mut wrote = true
    try { write_file(target, body) } catch e { wrote = false }
    if !wrote {
        _raw66("io-fail", "sidecar-write-failed",
            ["mkdir -p " + sh("dirname " + _shq(target)),
             "ls -la " + sh("dirname " + _shq(target)),
             "df -h " + sh("dirname " + _shq(target))])
        _sentinel("FAIL", abs, "lock")
        return 1
    }

    // apply chflags
    let rc = _apply_flag(abs, level)
    if rc != 0 || !_is_locked(abs) {
        // rollback sidecar — never leave context-less lock OR orphan sidecar
        let _ = _delete_sidecar(abs)
        _raw66("syscall-fail", "chflags-apply-failed-rc-" + to_string(rc),
            ["ls -lOd " + _shq(abs),
             "chflags " + (if level == "L2" { "schg" } else { "uchg" }) + " " + _shq(abs) + "  # try manually",
             "if path is on a volume that does not support BSD flags, chflags will silently no-op"])
        _sentinel("FAIL", abs, "lock")
        return 1
    }

    let op_label = if was_locked { "relock" } else { "lock" }
    _audit_append(op_label, abs, reason, body.trim())

    println("locked path=" + abs + " sidecar=" + target + " level=" + level)
    println("  reason: " + reason)
    let mut fi = 0
    while fi < len(fixes) { println("  fix " + to_string(fi + 1) + ": " + fixes[fi]); fi = fi + 1 }
    if len(guidance) > 0 {
        let mut gi = 0
        while gi < len(guidance) { println("  guidance " + to_string(gi + 1) + ": " + guidance[gi]); gi = gi + 1 }
    }
    _sentinel("PASS", abs, "lock")
    return 0
}

// ─── subcommand: unlock ──────────────────────────────────────────────────

fn cmd_unlock(av: [string]) -> i64 {
    let path = _arg_kv(av, "--path")
    let mut reason = _arg_kv(av, "--reason")
    let mut level = _arg_kv(av, "--level")
    if level == "" { level = "L1" }

    if path == "" {
        _raw66("validation-fail", "required-arg-missing-path",
            ["hexa run tool/chflags_lock_native.hexa unlock --path <abs> --reason '<r>'"])
        _sentinel("FAIL", "", "unlock")
        return 2
    }
    let abs = _abs(path)
    let self_ref = _is_wrapper_dep(abs)
    if self_ref && reason == "" { reason = _self_reason() }
    if reason == "" {
        // raw 85 mandates escalation reason; but for cleanup convenience, allow "unspecified"
        // when sidecar is absent (already-unlocked path, just GC'ing).
        if _existing_sidecar(abs) == "" && !_is_locked(abs) {
            reason = "unspecified-cleanup"
        } else {
            _raw66("validation-fail", "required-arg-missing-reason",
                ["hexa run tool/chflags_lock_native.hexa unlock --path " + abs + " --reason '<r>'",
                 "raw 85 mandates escalation reason at every unlock"])
            _sentinel("FAIL", abs, "unlock")
            return 2
        }
    }

    // capture sidecar BEFORE removal — archived into audit row
    let sc_path = _existing_sidecar(abs)
    let mut sc_body = "null"
    if sc_path != "" {
        let body = _str(read_file(sc_path))
        if body.trim() != "" { sc_body = body.trim() }
    }

    let was_locked = _is_locked(abs)
    if was_locked {
        let rc = _remove_flag(abs, level)
        if rc != 0 {
            _raw66("syscall-fail", "chflags-remove-failed-rc-" + to_string(rc),
                ["ls -lOd " + _shq(abs),
                 (if level == "L2" { "sudo chflags noschg " } else { "chflags nouchg " }) + _shq(abs)])
            _sentinel("FAIL", abs, "unlock")
            return 1
        }
    }

    // F5 — sidecar GC + audit append (always, even if path was already unlocked → orphan sweep)
    let gc_ok = _delete_sidecar(abs)
    if !gc_ok {
        _raw66("io-fail-partial", "sidecar-gc-orphan",
            ["rm -f " + _shq(sc_path),
             "chflags_lock_audit.hexa will flag this orphan; check parent dir flags"])
        _audit_append("unlock+gc-partial", abs, reason, sc_body)
        _sentinel("FAIL", abs, "unlock")
        return 1
    }
    _audit_append("unlock+gc", abs, reason, sc_body)

    let gc_label = if sc_path != "" { "removed" } else { "none" }
    println("unlocked path=" + abs + " sidecar_gc=" + gc_label + " reason=" + reason)
    _sentinel("PASS", abs, "unlock")
    return 0
}

// ─── subcommand: lookup ──────────────────────────────────────────────────
// F3: unlocked path → {locked:false, metadata:null}, never inferred.

fn cmd_lookup(av: [string]) -> i64 {
    let path = _arg_kv(av, "--path")
    let json_out = _arg_flag(av, "--json")
    if path == "" {
        _raw66("validation-fail", "required-arg-missing-path",
            ["hexa run tool/chflags_lock_native.hexa lookup --path <abs> [--json]"])
        _sentinel("FAIL", "", "lookup")
        return 2
    }
    let abs = _abs(path)
    let locked = _is_locked(abs)
    if !locked {
        if json_out {
            println("{\"locked\":false,\"metadata\":null,\"reason\":\"not-locked\"}")
        } else {
            println("locked=false metadata=null reason=not-locked path=" + abs)
        }
        _sentinel("PASS", abs, "lookup")
        return 0
    }
    let sc = _existing_sidecar(abs)
    if sc == "" {
        if json_out {
            println("{\"locked\":true,\"metadata\":null,\"sidecar_invalid\":false,\"reason\":\"locked-no-sidecar\"}")
        } else {
            println("locked=true metadata=null reason=locked-no-sidecar path=" + abs)
        }
        _sentinel("PASS", abs, "lookup")
        return 0
    }
    let body = _str(read_file(sc))
    if !_validate_schema(body) {
        if json_out {
            println("{\"locked\":true,\"metadata\":null,\"sidecar_invalid\":true,\"sidecar_path\":\"" + _json_escape(sc) + "\"}")
        } else {
            println("locked=true metadata=null sidecar_invalid=true sidecar=" + sc + " path=" + abs)
        }
        _sentinel("PASS", abs, "lookup")
        return 0
    }
    if json_out {
        println("{\"locked\":true,\"metadata\":" + body.trim() + ",\"sidecar_path\":\"" + _json_escape(sc) + "\"}")
    } else {
        println("locked=true sidecar=" + sc + " path=" + abs)
        println(body.trim())
    }
    _sentinel("PASS", abs, "lookup")
    return 0
}

// ─── subcommand: explain (EPERM-victim helper, raw 66 trailer to stderr) ─

fn cmd_explain(av: [string]) -> i64 {
    let path = _arg_kv(av, "--path")
    if path == "" {
        _raw66("validation-fail", "required-arg-missing-path",
            ["hexa run tool/chflags_lock_native.hexa explain --path <abs>"])
        _sentinel("FAIL", "", "explain")
        return 2
    }
    let abs = _abs(path)
    let locked = _is_locked(abs)
    if !locked {
        _raw66("eperm-context", "path-not-chflags-locked",
            ["ls -lO " + _shq(abs) + "  # inspect actual flag column",
             "ls -ld " + sh("dirname " + _shq(abs)) + "  # check parent dir",
             "stat -f '%Sp %Su %Sg' " + _shq(abs) + "  # mode + owner"])
        _sentinel("PASS", abs, "explain")
        return 0
    }
    let sc = _existing_sidecar(abs)
    if sc == "" {
        _raw66("chflags-uchg-lock-no-sidecar", "path-locked-but-no-metadata",
            ["chflags nouchg " + _shq(abs) + "  # if you own this lock",
             "check .raw-audit for prior lock-time context",
             "apply tool/chflags_lock_native.hexa lock --path <p> --reason --fix at the locker site to prevent future generic fallback"])
        _sentinel("PASS", abs, "explain")
        return 0
    }
    let body = _str(read_file(sc))
    if !_validate_schema(body) {
        _raw66("chflags-uchg-lock-sidecar-invalid", "schema-mismatch-or-corrupt",
            ["jq . < " + _shq(sc),
             "rm " + _shq(sc) + " && hexa run tool/chflags_lock_native.hexa unlock --path " + _shq(abs) + " --reason 'corrupt sidecar — recover'"])
        _sentinel("PASS", abs, "explain")
        return 0
    }
    let r = _json_get_str(body, "reason")
    let fixes = _json_get_arr(body, "fix")
    let guidance = _json_get_arr(body, "guidance")
    let actor = _json_get_str(body, "locker_actor")
    let locked_at = _json_get_str(body, "locked_at")
    eprintln("EPERM: chflags-uchg-lock at " + abs)
    eprintln("reason: chflags-uchg-lock: " + r)
    let mut s = "fix: "
    let mut i = 0
    while i < len(fixes) {
        if i > 0 { s = s + "  " }
        s = s + to_string(i + 1) + ") " + fixes[i]
        i = i + 1
    }
    eprintln(s)
    if len(guidance) > 0 {
        let mut g = "guidance: "
        let mut j = 0
        while j < len(guidance) {
            if j > 0 { g = g + " | " }
            g = g + guidance[j]
            j = j + 1
        }
        eprintln(g)
    }
    eprintln("ref: raw:ai-native-error-message (raw#66)")
    eprintln("locked_at: " + locked_at)
    if actor != "" { eprintln("locker_actor: " + actor) }
    _sentinel("PASS", abs, "explain")
    return 0
}

// ─── subcommand: status ──────────────────────────────────────────────────

fn cmd_status(av: [string]) -> i64 {
    let path = _arg_kv(av, "--path")
    if path == "" {
        _raw66("validation-fail", "required-arg-missing-path",
            ["hexa run tool/chflags_lock_native.hexa status --path <abs>"])
        _sentinel("FAIL", "", "status")
        return 2
    }
    let abs = _abs(path)
    let locked = _is_locked(abs)
    let sc = _existing_sidecar(abs)
    println("chflags_lock_native status — " + abs)
    println("  exists:        " + to_string(_path_exists(abs)))
    println("  kernel-locked: " + to_string(locked))
    println("  sidecar:       " + (if sc == "" { "(none)" } else { sc }))
    if sc != "" {
        let body = _str(read_file(sc))
        let valid = _validate_schema(body)
        println("  schema-valid:  " + to_string(valid))
        if valid {
            println("  reason:        " + _json_get_str(body, "reason"))
            let fixes = _json_get_arr(body, "fix")
            let mut i = 0
            while i < len(fixes) { println("  fix " + to_string(i + 1) + ":         " + fixes[i]); i = i + 1 }
            let g = _json_get_arr(body, "guidance")
            let mut j = 0
            while j < len(g) { println("  guidance " + to_string(j + 1) + ":    " + g[j]); j = j + 1 }
            println("  locked_at:     " + _json_get_str(body, "locked_at"))
            println("  locked_by_pid: " + to_string(_json_get_int(body, "locked_by_pid")))
            println("  session:       " + _json_get_str(body, "locked_by_session"))
            println("  actor:         " + _json_get_str(body, "locker_actor"))
            println("  schema_ver:    " + _json_get_str(body, "schema_version"))
        }
    }
    _sentinel("PASS", abs, "status")
    return 0
}

// ─── subcommand: list (sibling .lock_meta.json + central) ───────────────

fn cmd_list() -> i64 {
    println("chflags_lock_native sidecars:")
    let cen_dir = _central_dir()
    if _path_exists(cen_dir) {
        let listing = _str(exec("ls -1 " + _shq(cen_dir) + "/*.json 2>/dev/null"))
        let lines = listing.split("\n")
        let mut i = 0
        while i < len(lines) {
            let f = _str(lines[i]).trim()
            if f != "" {
                let body = _str(read_file(f))
                let p = _json_get_str(body, "path")
                let r = _json_get_str(body, "reason")
                let lock_state = if p != "" && _is_locked(p) { "uchg" } else { "STALE" }
                println("  [central " + lock_state + "] " + p + " — " + r)
            }
            i = i + 1
        }
    }
    // sibling .lock_meta.json scan — best-effort using find
    let cwd = sh("pwd")
    let sibs = _str(exec("find " + _shq(cwd) + " -name '*.lock_meta.json' -not -path '*/.git/*' 2>/dev/null"))
    let lines2 = sibs.split("\n")
    let mut j = 0
    while j < len(lines2) {
        let f = _str(lines2[j]).trim()
        if f != "" {
            let body = _str(read_file(f))
            let p = _json_get_str(body, "path")
            let r = _json_get_str(body, "reason")
            let lock_state = if p != "" && _is_locked(p) { "uchg" } else { "STALE" }
            println("  [sibling " + lock_state + "] " + p + " — " + r)
        }
        j = j + 1
    }
    _sentinel("PASS", "", "list")
    return 0
}

// ─── selftest (F1-F7 falsifier suite) ────────────────────────────────────

fn _selftest_pass(name: string) { println("  PASS  " + name) }
fn _selftest_fail(name: string, msg: string) -> i64 {
    eprintln("  FAIL  " + name + " — " + msg)
    return 1
}

fn cmd_selftest() -> i64 {
    println("=== chflags_lock_native selftest (F1-F7) ===")
    let mut fails: i64 = 0
    let pid = _pid()
    let tmp = "/tmp/chflags_lock_native_selftest_" + pid + ".tmp"
    let _ = exec("rm -f " + _shq(tmp) + " " + _shq(tmp + ".lock_meta.json") + " 2>/dev/null")
    let _ = exec("touch " + _shq(tmp))
    let SELF = "/Users/ghost/core/nexus/tool/chflags_lock_native.hexa"

    // F1 — required args missing on lock → exit 2 + raw 66 trailer
    let r1 = exec_with_status("hexa run " + SELF + " lock --path " + _shq(tmp) + " 2>&1")
    let out1 = _str(r1[0])
    if r1[1] == 2 && out1.contains("required-arg-missing") && out1.contains("reason:") && out1.contains("fix:") && out1.contains(SENTINEL_TAG + " FAIL") {
        _selftest_pass("F1 required-args-hard-fail-raw-66")
    } else {
        fails = fails + _selftest_fail("F1", "rc=" + to_string(r1[1]) + " out=" + out1)
    }

    // F3 (run before lock) — lookup unlocked = explicit null
    let r3 = exec_with_status("hexa run " + SELF + " lookup --path " + _shq(tmp) + " --json 2>&1")
    let out3 = _str(r3[0])
    if out3.contains("\"locked\":false") && out3.contains("\"metadata\":null") {
        _selftest_pass("F3 lookup-unlocked-explicit-null")
    } else {
        fails = fails + _selftest_fail("F3", "out=" + out3)
    }

    // Lock OK with --reason + repeatable --fix + --guidance
    let lock_cmd = "hexa run " + SELF + " lock --path " + _shq(tmp)
                 + " --reason 'selftest reason: F2/F5/F6 setup'"
                 + " --fix 'hexa run tool/chflags_lock_native.hexa unlock --path " + tmp + " --reason cleanup'"
                 + " --fix 'chflags nouchg " + tmp + "  # manual fallback'"
                 + " --guidance 'F2 schema validity test sidecar' 2>&1"
    let rL = exec_with_status(lock_cmd)
    if rL[1] != 0 {
        fails = fails + _selftest_fail("setup-lock", "rc=" + to_string(rL[1]) + " out=" + _str(rL[0]))
    }

    // F2 — sidecar schema validity
    let scp = tmp + ".lock_meta.json"
    if !_path_exists(scp) {
        fails = fails + _selftest_fail("F2 sidecar-presence", "sidecar missing at " + scp)
    } else {
        let body = _str(read_file(scp))
        if _validate_schema(body) {
            // and verify required keys
            let mut all = true
            if _json_get_str(body, "path") == "" { all = false }
            if _json_get_str(body, "reason") == "" { all = false }
            if len(_json_get_arr(body, "fix")) == 0 { all = false }
            if _json_get_str(body, "locked_at") == "" { all = false }
            if _json_get_int(body, "locked_by_pid") == 0 { all = false }
            if _json_get_str(body, "locked_by_session") == "" { all = false }
            if _json_get_str(body, "locker_actor") == "" { all = false }
            if _json_get_str(body, "schema_version") != SCHEMA_VERSION { all = false }
            if all { _selftest_pass("F2 metadata-sidecar-jsonschema") }
            else { fails = fails + _selftest_fail("F2", "sidecar present but missing required keys") }
        } else {
            fails = fails + _selftest_fail("F2", "sidecar schema invalid: " + body)
        }
    }

    // F6 — locked-write attempt → EPERM, then `explain` surfaces ai-native error
    let wprobe = exec_with_status("sh -c 'printf x >> " + _shq(tmp) + "' 2>/dev/null")
    if wprobe[1] == 0 {
        fails = fails + _selftest_fail("F6 write-attempt-eperm", "expected EPERM on write to uchg file; rc=0")
    } else {
        let exp = exec_with_status("hexa run " + SELF + " explain --path " + _shq(tmp) + " 2>&1")
        let outE = _str(exp[0])
        if outE.contains("reason: chflags-uchg-lock: selftest reason") && outE.contains("fix: 1) ") {
            _selftest_pass("F6 locked-write-trap-surfaces-ai-native")
        } else {
            fails = fails + _selftest_fail("F6 explain", "out=" + outE)
        }
    }

    // F5 — unlock GC sidecar
    let rU = exec_with_status("hexa run " + SELF + " unlock --path " + _shq(tmp) + " --reason 'selftest cleanup' 2>&1")
    if rU[1] != 0 {
        fails = fails + _selftest_fail("F5 unlock-rc", "rc=" + to_string(rU[1]) + " out=" + _str(rU[0]))
    }
    if _is_locked(tmp) {
        fails = fails + _selftest_fail("F5 unlock-kernel", "uchg flag still set after unlock")
    }
    if _path_exists(scp) {
        fails = fails + _selftest_fail("F5 nouchg-metadata-gc", "sidecar survived after unlock at " + scp)
    } else {
        _selftest_pass("F5 nouchg-metadata-gc")
    }

    // F7 — self-reference auto-injection (lock with empty reason/fix on a path
    //      whose suffix matches WRAPPER_DEPS — should auto-inject canonical defaults).
    let self_dir = "/tmp/chflags_self_selftest_" + pid + "/tool"
    let _ = exec("rm -rf /tmp/chflags_self_selftest_" + pid + " 2>/dev/null")
    let _ = exec("mkdir -p " + _shq(self_dir) + " && touch " + _shq(self_dir + "/chflags_lock_native.hexa"))
    let self_path = self_dir + "/chflags_lock_native.hexa"
    let r7 = exec_with_status("hexa run " + SELF + " lock --path " + _shq(self_path) + " 2>&1")
    if r7[1] == 0 {
        let scs = self_path + ".lock_meta.json"
        if _path_exists(scs) {
            let body = _str(read_file(scs))
            if _validate_schema(body) && _json_get_str(body, "reason").contains("self-reference") {
                _selftest_pass("F7 self-reference-auto-injection")
            } else {
                fails = fails + _selftest_fail("F7 self-ref-canonical", "reason did not auto-inject; body=" + body)
            }
        } else {
            fails = fails + _selftest_fail("F7 self-ref-sidecar", "sidecar missing at " + scs)
        }
        let _ = exec_with_status("hexa run " + SELF + " unlock --path " + _shq(self_path) + " 2>/dev/null")
    } else {
        fails = fails + _selftest_fail("F7 self-ref-lock", "rc=" + to_string(r7[1]) + " out=" + _str(r7[0]))
    }
    let _ = exec("rm -rf /tmp/chflags_self_selftest_" + pid + " " + _shq(tmp))

    // F8 — sentinel emitted (raw 80) — examine lock cmd output
    let probe = _str(rL[0])
    if probe.contains(SENTINEL_TAG + " PASS path=") && probe.contains("op=lock") {
        _selftest_pass("F8 raw-80-sentinel-on-completion")
    } else {
        fails = fails + _selftest_fail("F8 sentinel", "tag missing in lock output")
    }

    println("=== " + to_string(fails) + " selftest fail(s) ===")
    if fails > 0 {
        _sentinel("FAIL", "", "selftest")
        return 1
    }
    _sentinel("PASS", "", "selftest")
    return 0
}

// ─── usage ───────────────────────────────────────────────────────────────

fn _usage() {
    eprintln("usage: hexa run tool/chflags_lock_native.hexa <subcmd> [opts]")
    eprintln("  lock    --path <abs> --reason '<r>' --fix '<cmd>' [--fix '<cmd>'...] [--guidance '<text>'...] [--level L1|L2]")
    eprintln("  unlock  --path <abs> [--reason '<r>'] [--level L1|L2]")
    eprintln("  lookup  --path <abs> [--json]")
    eprintln("  explain --path <abs>      (EPERM-victim helper — raw 66 trailer to stderr)")
    eprintln("  status  --path <abs>")
    eprintln("  list")
    eprintln("  selftest                  (F1-F7 falsifier suite)")
    eprintln("")
    eprintln("required args missing → raw 66 hard-fail (exit 2)")
    eprintln("sidecar:  <abs>.lock_meta.json (sibling primary) | ~/.local/state/chflags_locks/<sha>.json (central fallback)")
    eprintln("sentinel: " + SENTINEL_TAG + " <PASS|FAIL> path=<abs> op=<lock|unlock|lookup|explain|status|list|selftest>")
}

// ─── main ────────────────────────────────────────────────────────────────

fn main() {
    let av = _argv()
    if len(av) < 3 {
        _usage()
        _sentinel("FAIL", "", "usage")
        exit(1)
    }
    let mode = av[2]
    let mut rc: i64 = 0
    if      mode == "lock"     { rc = cmd_lock(av) }
    else if mode == "unlock"   { rc = cmd_unlock(av) }
    else if mode == "lookup"   { rc = cmd_lookup(av) }
    else if mode == "explain"  { rc = cmd_explain(av) }
    else if mode == "status"   { rc = cmd_status(av) }
    else if mode == "list"     { rc = cmd_list() }
    else if mode == "selftest" { rc = cmd_selftest() }
    else if mode == "--help" || mode == "-h" { _usage(); exit(0) }
    else {
        eprintln("unknown subcmd: " + mode)
        _usage()
        _sentinel("FAIL", "", "unknown-subcmd/" + mode)
        exit(1)
    }
    exit(to_int(to_string(rc)))
}

main()
