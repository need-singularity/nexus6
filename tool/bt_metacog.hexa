// bt_metacog.hexa — BT-541..547 사전 메타인지 prefetch (THINK-P7-1)
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
// 역할: BT 공격 시리즈(541..547) 각 대상에 대해 thinking_engine 6-phase reflection 을
//       사전 수행하여, 관련 atlas 허브 / 함정 / 사전법칙 3축을 prefetch context 로 주입.
//       본 엔진은 prefetch 스캐폴드이며 BT 자체 공격이 아님.
// SSOT: shared/bt/metacog_<bt_id>.json  (thinking_depth, touches, laws_refs, pitfalls_refs)
//       shared/tool/bt_metacog_log.jsonl  (append-only prefetch 기록)
//
// subcommands:
//   prefetch <bt_id>         thinking query 1회 + metacog_<bt_id>.json emit
//                            bt_id ∈ {BT-541, BT-542, ..., BT-547}
//   prefetch-all             BT-541..547 전 7개 연속 prefetch
//   list                     내부 BT-541..547 테이블 stdout
//   status                   metacog_*.json 생성된 수 + 평균 depth/touches
//
// 성공 조용 (H1). prefetch 만 최소 stdout.

let HOME = env("HOME")
let NEXUS = HOME + "/core/nexus"
let HARNESS = NEXUS + "/harness"
let BT_DIR = NEXUS + "/bt"
let HEXA_BIN = NEXUS + "/bin/hexa"
let THINK_BIN = HARNESS + "/thinking_engine.hexa"
let LOG = HARNESS + "/bt_metacog_log.jsonl"

// ─── BT-541..547 매핑 테이블 (docs/breakthrough-theorems.md L19737~L19990 근거) ───
// [id, name_ko, domain, laws_ref, pitfalls_ref]
// laws_ref / pitfalls_ref 는 atlas / papers 내 관련 노드 표기 (3축 힌트)
fn bt_table() -> [[string]] {
    return [
        ["BT-541", "Riemann Hypothesis — zeta n=6 quintuple convergence",
         "math:analytic_number_theory",
         "n6-zeta|Euler-Basel|Von-Staudt-Clausen|Bernoulli-B12|Moonshine",
         "critical-line-conjecture|Guth-Maynard-2024-bound|Li-criterion-unresolved"],
        ["BT-542", "P vs NP — complexity hierarchy n=6 skeleton",
         "cs:complexity_theory",
         "3-SAT-phi-to-n-over-phi|Chomsky-tau4|Karp-21|Shannon-bit",
         "relativization-barrier|natural-proofs|algebrization|GCT-Mulmuley"],
        ["BT-543", "Yang-Mills mass gap — QCD gauge n=6 full parametrization",
         "physics:particle_qcd",
         "SU3-color|gluon-sigma-tau-8|beta0-sigma-sopfr-7|Wilson-lattice",
         "confinement-nonperturbative|4D-only-Clay|mass-gap-proof-absent"],
        ["BT-544", "Navier-Stokes — fluid n=6 tensor + triple resonance",
         "physics:fluid_dynamics",
         "Reynolds-stress-6|Kolmogorov-5over3|Onsager-1over3|d3-triple-resonance",
         "blowup-scenario|Tao-2016-averaged|Chen-Hou-Euler-PNAS2025"],
        ["BT-545", "Hodge Conjecture — algebraic geometry cohomology n=6",
         "math:algebraic_geometry",
         "K3-chi-24|CP3-real-dim-6|CalabiYau-3fold|modular-weights-4-6-12",
         "Benoist-Ottem-integral-failure|Moonshine-L5-barrier|Hauptmodul"],
        ["BT-546", "BSD Conjecture — elliptic L-function n=6 modular skeleton",
         "math:number_theory",
         "Sel6-sigma6-12|CRT-Sel-m-times-Sel-n|j-invariant-1728|Mazur-torsion",
         "BKLPR-A3-assumption|Iwasawa-mod-6|Cremona-500k-deferred"],
        ["BT-547", "Poincaré Conjecture — 3-manifolds n/phi=3 topological classification",
         "math:topology",
         "Thurston-8-geometries|Ricci-flow-Perelman|Smale-dim5-plus|dim3-unique",
         "Perelman-retrospective|Morgan-Tian-Kleiner-Lott|n6arch-contribution-zero"]
    ]
}

// ─── void-safe coercion (thinking_engine.hexa 동형) ───
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    return to_int(first)
}

fn now_unix() -> i64 {
    return _to_int0(_str(exec("date +%s")).trim())  // @allow-bare-exec
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", " ")
    r = r.replace("\r", " ")
    r = r.replace("\t", " ")
    return r
}

fn json_field(line: string, key: string) -> string {
    let tag = "\"" + key + "\""
    if line.contains(tag) == false { return "" }
    let after = line.split(tag)[1]
    let parts = after.split(":")
    if parts.len() < 2 { return "" }
    let mut rest = parts[1]
    let mut i = 2
    while i < parts.len() {
        rest = rest + ":" + parts[i]
        i = i + 1
    }
    let s = rest.trim()
    if s.len() == 0 { return "" }
    if s.substring(0, 1) == "\"" {
        let inner = s.substring(1, s.len())
        let ep = inner.split("\"")
        if ep.len() < 1 { return "" }
        return ep[0]
    }
    let mut end = 0
    while end < s.len() {
        let c = s.substring(end, end + 1)
        if c == "," || c == "}" || c == "\n" || c == " " { break }
        end = end + 1
    }
    return s.substring(0, end).trim()
}

fn shell_quote(s: string) -> string {
    let escaped = s.replace("'", "'\\''")
    return "'" + escaped + "'"
}

fn append_line(path: string, line: string) {
    let cmd = "printf '%s\\n' " + shell_quote(line) + " >> '" + path + "' 2>/dev/null"
    let _r = exec(cmd)  // @allow-bare-exec
}

// ─── BT row 조회 ───
fn find_bt(bt_id: string) -> [string] {
    let table = bt_table()
    for row in table {
        if row[0] == bt_id { return row }
    }
    return []
}

// ─── thinking_engine query 실행 (synchronous, 결과 JSON stdout 캡처) ───
fn think_query(prompt: string) -> string {
    let cmd = "'" + HEXA_BIN + "' run '" + THINK_BIN + "' query " +
              shell_quote(prompt) + " 2>/dev/null"
    let out = _str(exec(cmd))  // @allow-bare-exec
    // thinking_engine 은 한 줄 JSON 을 println — 마지막 비어있지 않은 줄 반환
    let lines = out.split("\n")
    let mut i = lines.len() - 1
    while i >= 0 {
        let t = _str(lines[i]).trim()
        if t.len() > 0 { return t }
        i = i - 1
    }
    return ""
}

// ─── laws_ref / pitfalls_ref CSV → JSON array 문자열 ───
fn csv_to_json_array(csv: string) -> string {
    if csv.len() == 0 { return "[]" }
    let parts = csv.split("|")
    let mut out = "["
    let mut i = 0
    while i < parts.len() {
        let p = _str(parts[i]).trim()
        if p.len() > 0 {
            if out.len() > 1 { out = out + "," }
            out = out + "\"" + json_escape(p) + "\""
        }
        i = i + 1
    }
    out = out + "]"
    return out
}

// ─── metacog json emit ───
fn emit_metacog(bt_id: string, row: [string], think_out: string) -> string {
    let ts = now_unix()
    let name = row[1]
    let domain = row[2]
    let laws = row[3]
    let pitfalls = row[4]
    let depth = _to_int0(json_field(think_out, "depth"))
    let touches = _to_int0(json_field(think_out, "atlas_touches"))
    let rejected = json_field(think_out, "rejected")
    let conclusion = json_field(think_out, "conclusion")

    let laws_arr = csv_to_json_array(laws)
    let pitfalls_arr = csv_to_json_array(pitfalls)

    let body = "{\"schema\":1" +
               ",\"bt_id\":\"" + json_escape(bt_id) + "\"" +
               ",\"name\":\"" + json_escape(name) + "\"" +
               ",\"domain\":\"" + json_escape(domain) + "\"" +
               ",\"ts\":" + to_string(ts) +
               ",\"thinking_depth\":" + to_string(depth) +
               ",\"atlas_touches\":" + to_string(touches) +
               ",\"rejected\":" + rejected +
               ",\"conclusion\":\"" + json_escape(conclusion) + "\"" +
               ",\"laws_refs\":" + laws_arr +
               ",\"pitfalls_refs\":" + pitfalls_arr +
               ",\"axes\":[\"laws\",\"hints\",\"pitfalls\"]" +
               ",\"note\":\"THINK-P7-1 prefetch — thinking_engine 6-phase 결과 + atlas hubs / 사전법칙 / 함정 3축. BT 공격 전 context 주입용.\"}\n"

    let path = BT_DIR + "/metacog_" + bt_id + ".json"
    try { write_file(path, body) } catch e {
        eprintln("FAIL: metacog write — " + path)
        exit(1)
    }
    return path
}

// ─── cmd: prefetch ───
fn cmd_prefetch(argv: [string]) {
    if argv.len() < 4 {
        eprintln("usage: bt_metacog prefetch <BT-541..547>")
        exit(2)
    }
    let bt_id = argv[3].trim()
    let row = find_bt(bt_id)
    if row.len() == 0 {
        eprintln("REJECT: unknown bt_id '" + bt_id + "' — BT-541..547 만 허용")
        exit(2)
    }
    let name = row[1]
    let domain = row[2]
    // thinking prompt — 3축 요청 (함정/힌트/사전법칙)
    let prompt = bt_id + " — " + name +
                 ": pitfalls hints prior-laws axes (domain=" + domain + ")"
    let think_out = think_query(prompt)
    let path = emit_metacog(bt_id, row, think_out)

    let ts = now_unix()
    let log_row = "{\"ts\":" + to_string(ts) +
                  ",\"kind\":\"prefetch\"" +
                  ",\"bt_id\":\"" + json_escape(bt_id) + "\"" +
                  ",\"path\":\"" + json_escape(path) + "\"" +
                  ",\"thinking_depth\":" + to_string(_to_int0(json_field(think_out, "depth"))) +
                  ",\"atlas_touches\":" + to_string(_to_int0(json_field(think_out, "atlas_touches"))) + "}"
    append_line(LOG, log_row)
    println("prefetch: " + bt_id + " -> " + path +
            " depth=" + to_string(_to_int0(json_field(think_out, "depth"))) +
            " touches=" + to_string(_to_int0(json_field(think_out, "atlas_touches"))))
}

// ─── cmd: prefetch-all ───
fn cmd_prefetch_all(argv: [string]) {
    let table = bt_table()
    for row in table {
        let bt_id = row[0]
        let name = row[1]
        let domain = row[2]
        let prompt = bt_id + " — " + name +
                     ": pitfalls hints prior-laws axes (domain=" + domain + ")"
        let think_out = think_query(prompt)
        let path = emit_metacog(bt_id, row, think_out)
        let ts = now_unix()
        let log_row = "{\"ts\":" + to_string(ts) +
                      ",\"kind\":\"prefetch\"" +
                      ",\"bt_id\":\"" + json_escape(bt_id) + "\"" +
                      ",\"path\":\"" + json_escape(path) + "\"" +
                      ",\"thinking_depth\":" + to_string(_to_int0(json_field(think_out, "depth"))) +
                      ",\"atlas_touches\":" + to_string(_to_int0(json_field(think_out, "atlas_touches"))) + "}"
        append_line(LOG, log_row)
        println("prefetch: " + bt_id + " -> " + path +
                " depth=" + to_string(_to_int0(json_field(think_out, "depth"))) +
                " touches=" + to_string(_to_int0(json_field(think_out, "atlas_touches"))))
    }
}

// ─── cmd: list ───
fn cmd_list(argv: [string]) {
    let table = bt_table()
    for row in table {
        println(row[0] + "\t" + row[2] + "\t" + row[1])
    }
}

// ─── cmd: status ───
fn cmd_status(argv: [string]) {
    let table = bt_table()
    let mut found: i64 = 0
    let mut sum_depth: i64 = 0
    let mut sum_touch: i64 = 0
    for row in table {
        let bt_id = row[0]
        let path = BT_DIR + "/metacog_" + bt_id + ".json"
        if file_exists(path) {
            found = found + 1
            let raw = _str(read_file(path))
            sum_depth = sum_depth + _to_int0(json_field(raw, "thinking_depth"))
            sum_touch = sum_touch + _to_int0(json_field(raw, "atlas_touches"))
        }
    }
    let mut avg_depth_pct: i64 = 0
    let mut avg_touch_pct: i64 = 0
    if found > 0 {
        avg_depth_pct = (sum_depth * 100) / found
        avg_touch_pct = (sum_touch * 100) / found
    }
    let ad_w = avg_depth_pct / 100
    let ad_f = avg_depth_pct - (ad_w * 100)
    let at_w = avg_touch_pct / 100
    let at_f = avg_touch_pct - (at_w * 100)
    let mut ad_fs = to_string(ad_f)
    if ad_f < 10 { ad_fs = "0" + ad_fs }
    let mut at_fs = to_string(at_f)
    if at_f < 10 { at_fs = "0" + at_fs }
    println("bt_metacog generated=" + to_string(found) + "/7" +
            " avg_depth=" + to_string(ad_w) + "." + ad_fs +
            " avg_touches=" + to_string(at_w) + "." + at_fs)
}

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    if argv.len() < 3 {
        eprintln("usage: bt_metacog <prefetch|prefetch-all|list|status> [args...]")
        exit(2)
    }
    let mode = argv[2].trim()
    if mode == "prefetch" { cmd_prefetch(argv) }
    else if mode == "prefetch-all" { cmd_prefetch_all(argv) }
    else if mode == "list" { cmd_list(argv) }
    else if mode == "status" { cmd_status(argv) }
    else {
        eprintln("REJECT: unknown mode '" + mode + "' — modes: prefetch|prefetch-all|list|status")
        exit(2)
    }
}

main()
