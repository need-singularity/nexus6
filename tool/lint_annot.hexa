// lint_annot.hexa — alias rules 기반 old marker deprecation 검사 (H-ANNOT-LINT, 2026-04-16)
// @allow-bare-exec
// @no-lock-needed
//
// 역할: shared/config/annot_rules.json 의 kind=alias 룰을 소비하여
//       대상 .hexa 파일에서 deprecated from-marker 발견 시 lint_log.jsonl warn append.
//
// usage:
//   hexa run shared/tool/lint_annot.hexa scan <path.hexa|dir>
//   hexa run shared/tool/lint_annot.hexa scan .            # 현재 디렉토리 재귀
//
// 출력: 매치 시 stderr 라인별 warn + lint_log.jsonl 에 {ts,file,line,kind:"alias-deprecated",from,to} append
//       매치 없으면 무출력 (성공 조용)

let HOME = env("HOME")
let NEXUS = HOME + "/core/nexus"
let LINT_LOG = NEXUS + "/tool/lint_log.jsonl"
let HEXA_RULE = NEXUS + "/bin/hexa-rule"
let ANNOT_RULES = NEXUS + "/config/annot_rules.json"

fn now_iso() -> str {
    return to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()  // @allow-bare-exec
}

fn json_escape(s: str) -> str {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "\\r")
    r = r.replace("\t", "\\t")
    return r
}

// hexa-rule --mode migrate 호출 → JSON migrations 배열 파싱 (jq 필수)
// 반환: TSV 라인 (file\tline\tfrom\tto). 매치 없으면 "".
fn _scan_alias_migrations(target: str) -> str {
    let exists = to_string(exec("test -e '" + target + "' && echo y || echo n")).trim()  // @allow-bare-exec
    if exists != "y" { return "" }
    let jq_ok = to_string(exec("command -v jq >/dev/null 2>&1 && echo y || echo n")).trim()  // @allow-bare-exec
    if jq_ok != "y" { return "" }

    // 파일 vs 디렉토리
    let is_dir = to_string(exec("test -d '" + target + "' && echo y || echo n")).trim()  // @allow-bare-exec
    let mut cmd = ""
    if is_dir == "y" {
        cmd = HEXA_RULE + " --rules '" + ANNOT_RULES + "' --mode migrate --dir '" + target + "' 2>/dev/null"
    } else {
        cmd = HEXA_RULE + " --rules '" + ANNOT_RULES + "' --mode migrate '" + target + "' 2>/dev/null"
    }
    let json = to_string(exec(cmd)).trim()  // @allow-bare-exec
    if json.len() == 0 { return "" }

    // jq 로 migrations[] 추출 → TSV
    let tmp = "/tmp/_lint_annot." + to_string(exec("date +%s%N")).trim()  // @allow-bare-exec
    let _ = exec("cat > " + tmp + " <<'__LINT_ANNOT_EOF__'\n" + json + "\n__LINT_ANNOT_EOF__")  // @allow-bare-exec
    let jq_cmd = "jq -r '.migrations[]? | [.file, .line, .from, .to] | @tsv' " + tmp + " 2>/dev/null"
    let tsv = to_string(exec(jq_cmd))  // @allow-bare-exec
    let _ = exec("rm -f " + tmp)  // @allow-bare-exec
    return tsv.trim()
}

// lint_log.jsonl 에 한 줄 append
fn _append_lint_log(ts: str, file: str, line: str, from_marker: str, to_marker: str) {
    let row = "{\"ts\":\"" + ts + "\"," +
              "\"mode\":\"annot\"," +
              "\"kind\":\"alias-deprecated\"," +
              "\"severity\":\"warn\"," +
              "\"file\":\"" + json_escape(file) + "\"," +
              "\"line\":" + line + "," +
              "\"from\":\"" + json_escape(from_marker) + "\"," +
              "\"to\":\"" + json_escape(to_marker) + "\"}"
    let esc = row.replace("'", "'\\''")
    let _ = exec("echo '" + esc + "' >> '" + LINT_LOG + "'")  // @allow-bare-exec
}

fn cmd_scan(target: str) -> i64 {
    let tsv = _scan_alias_migrations(target)
    if tsv.len() == 0 { return 0 }

    let ts = now_iso()
    let lines = tsv.split("\n")
    let mut hits: i64 = 0
    for ln_raw in lines {
        let ln = to_string(ln_raw).trim()
        if ln.len() == 0 { continue }
        let parts = ln.split("\t")
        if parts.len() < 4 { continue }
        let file = to_string(parts[0])
        let line = to_string(parts[1])
        let from_m = to_string(parts[2])
        let to_m = to_string(parts[3])
        _append_lint_log(ts, file, line, from_m, to_m)
        eprintln("[H-ANNOT-LINT WARN] " + file + ":" + line + " alias-deprecated '" + from_m + "' → '" + to_m + "'")
        hits = hits + 1
    }
    return hits
}

fn cmd_help() {
    eprintln("usage: hexa run shared/tool/lint_annot.hexa scan <path>")
    eprintln("       scan .hexa file or directory for alias-deprecated markers")
    eprintln("       consumes: shared/config/annot_rules.json (kind=alias)")
    eprintln("       appends: shared/tool/lint_log.jsonl")
}

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    if argv.len() < 3 {
        cmd_help()
        return
    }
    let sub = argv[2]
    if sub == "scan" {
        if argv.len() < 4 {
            cmd_help()
            return
        }
        let target = argv[3]
        let _ = cmd_scan(target)
        return
    }
    cmd_help()
}

main()
