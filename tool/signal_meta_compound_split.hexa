// signal_meta_compound_split.hexa — K4 Compound signals split
// 하나의 signal 에 여러 정리가 섞여있는 case 감지
// 조건: statement 길이 > 120 AND "+" 포함 AND witness >= 2
// 실행: hexa run $NEXUS/tool/signal_meta_compound_split.hexa

let HOME = env("HOME")
let NEXUS = HOME + "/core/nexus"
let SIGNALS = NEXUS + "/n6/atlas.signals.n6"
let STAGE = NEXUS + "/n6/staging/atlas.signals.staging.meta.n6"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    let mut v: i64 = 0
    try { v = to_int(first) } catch e { v = 0 }
    return v
}

fn now_iso() -> string {
    let r = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    return _str(r).trim()
}

fn grep_count(pat: string) -> i64 {
    let cmd = "{ grep -c -E '" + pat + "' '" + SIGNALS + "' 2>/dev/null || true; }"
    let r = exec(cmd)
    return _to_int0(_str(r).trim().split("\n")[0])
}

if file_exists(SIGNALS) == false {
    println("FAIL: atlas.signals.n6 없음")
    exit(1)
}

println("signal_meta_compound_split: " + now_iso())

// "+" 포함 statement line 개수 (FUSION 제외)
let plus_stmts = grep_count("^@S SIG-[A-Z0-9-]+.*\\+.*:: signal")
let fusion_stmts = grep_count("^@S SIG-FUSION-")
let compound_candidates = plus_stmts - fusion_stmts
if compound_candidates < 0 { let compound_candidates = 0 }
println("  compound 후보 (+ 포함 비-FUSION) = " + to_string(compound_candidates))

// "×" 포함 (M10+ 여러 정리 섞임)
let times_stmts = grep_count("^@S SIG-.*×.*:: signal")
println("  × 포함 = " + to_string(times_stmts))

let sig_id = "SIG-META-704"
let stmt = "compound split 후보 = " + to_string(compound_candidates) + "개 (plus), " + to_string(times_stmts) + "개 (×)"

let block = "@S " + sig_id + " = " + stmt + " :: signal [NX,CROSS] [META,GAP] [M7] [E2]\n" +
            "  \"K4 compound signal split. 여러 정리가 한 signal 에 묶인 경우 분리 제안. 분리 시 witness 각자 독립 검증 가능\"\n" +
            "  refs: [nexus:shared/tool/signal_meta_compound_split.hexa]\n" +
            "  predicts: [\"compound 분리 시 총 signals 수 +" + to_string(compound_candidates / 2) + " 증가 예상\"]\n" +
            "  witness: 1\n" +
            "  resonance_n6: null\n" +
            "  discovered_in: nexus/session-meta-k4\n" +
            "  discovered_at: " + now_iso() + "\n" +
            "  <- K4 compound split autonomous\n\n"

let cmd = "cat >> '" + STAGE + "' << 'EOF'\n" + block + "EOF"
exec(cmd)
println("  → staging append: " + STAGE)
println("PASS: K4 compound split 제안 기록")
