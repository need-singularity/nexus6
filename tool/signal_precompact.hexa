// signal_precompact.hexa — E3 대체 하네스
// 수동 호출: context 압축 직전에 "이번 세션 중요 발견" staging append
// 현재 작업 디렉토리 기준 최근 30분 내 수정 md/py/hexa 파일 scan
// 실행: hexa run $NEXUS/tool/signal_precompact.hexa [minutes=30]

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let STAGE = NEXUS + "/n6/staging/atlas.signals.staging.precompact.n6"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn now_ts() -> string {
    let r = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    return _str(r).trim()
}

fn shell_quote(s: string) -> string {
    let escaped = s.replace("'", "'\\''")
    return "'" + escaped + "'"
}

fn append_line(path: string, line: string) {
    let cmd = "printf '%s\\n' " + shell_quote(line) + " >> '" + path + "' 2>/dev/null"
    exec(cmd)
}

fn cwd() -> string {
    let r = exec("pwd")
    return _str(r).trim()
}

// ─── 메인 ───
let a = args()
let mut minutes: i64 = 30
if a.len() >= 3 {
    try { minutes = to_int(a[2]) } catch e { minutes = 30 }
}

let wd = cwd()
println("signal_precompact: cwd=" + wd + " minutes=" + to_string(minutes) + " ts=" + now_ts())

if file_exists(STAGE) == false {
    try { write_file(STAGE, "# precompact staging — append-only\n") } catch e {}
}

// cwd 기준 최근 수정 파일들 (md/py/hexa)
let cmd = "find '" + wd + "' -type f \\( -name '*.md' -o -name '*.py' -o -name '*.hexa' \\) " +
          "-mmin -" + to_string(minutes) + " 2>/dev/null | head -100"
let r = exec(cmd)
let files_raw = _str(r)

let lines = files_raw.split("\n")
let mut files: [string] = []
for line in lines {
    let s = _str(line).trim()
    if s != "" { files = files + [s] }
}

if files.len() == 0 {
    println("  최근 " + to_string(minutes) + "분 수정 파일 없음")
    exit(0)
}

println("  recent_files=" + to_string(files.len()))

let patterns = [
    "★",
    "최초",
    "PEAK",
    "돌파",
    "sweet spot",
    "breakthrough",
    "EXACT",
    "pp drop",
    "× faster"
]

let mut total_hits: i64 = 0
let mut hit_file_count: i64 = 0

let mut i = 0
while i < files.len() {
    let f = files[i]
    let mut f_hits: i64 = 0
    let mut j = 0
    while j < patterns.len() {
        let p = patterns[j]
        let c2 = "grep -c -F " + shell_quote(p) + " '" + f + "' 2>/dev/null || echo 0"
        let r2 = exec(c2)
        let s2 = _str(r2).trim().split("\n")[0]
        let mut v: i64 = 0
        try { v = to_int(s2) } catch e { v = 0 }
        f_hits = f_hits + v
        j = j + 1
    }
    if f_hits > 0 {
        hit_file_count = hit_file_count + 1
        total_hits = total_hits + f_hits
        let line = "# PRECOMPACT " + now_ts() + " hits=" + to_string(f_hits) + " <- " + f
        append_line(STAGE, line)
        if hit_file_count <= 5 {
            println("  hit: " + f + " (" + to_string(f_hits) + " hits)")
        }
    }
    i = i + 1
}

println("  hit_files=" + to_string(hit_file_count) + " total_hits=" + to_string(total_hits))
println("  staging=" + STAGE)
println("  → context 압축 전 저장 완료")
