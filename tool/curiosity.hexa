// curiosity.hexa — P7 야간 발견: Curiosity (hub↔leaf gap 질문 생성)
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
// 역할: atlas.n6.deg hub(top10) 와 leaf(deg=1 head50) 사이 prefix 공유 관계 감지
//       → "Q: how does {hub} relate to {leaf}?" 질문 생성
//       → thinking_engine 에 백그라운드 위임
// SSOT: shared/tool/curiosity_log.jsonl (append-only)
//
// subcommands:
//   ask                   질문 1개 생성 + log append + thinking_engine 백그라운드 위임
//   status                최근 100 질문 중 thinking_log reflect 비율
//   history [N=10]        curiosity_log.jsonl 마지막 N 줄
//
// 성공 조용 (H1). ask 만 최소 stdout.

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let HARNESS = NEXUS + "/harness"

let LOG = HARNESS + "/curiosity_log.jsonl"
let THINK_LOG = HARNESS + "/thinking_log.jsonl"
let ATLAS_DEG = NEXUS + "/n6/atlas.n6.deg"
let THINK_BIN = HARNESS + "/thinking_engine.hexa"
let HEXA_BIN = NEXUS + "/bin/hexa"

// ─── void-safe coercion ───
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    return to_int(first)
}

fn now_unix() -> i64 {
    return _to_int0(_str(exec("date +%s")).trim())  // @allow-bare-exec
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", " ")
    r = r.replace("\r", " ")
    r = r.replace("\t", " ")
    return r
}

fn json_field(line: string, key: string) -> string {
    let tag = "\"" + key + "\""
    if line.contains(tag) == false { return "" }
    let after = line.split(tag)[1]
    let parts = after.split(":")
    if parts.len() < 2 { return "" }
    let mut rest = parts[1]
    let mut i = 2
    while i < parts.len() {
        rest = rest + ":" + parts[i]
        i = i + 1
    }
    let s = rest.trim()
    if s.len() == 0 { return "" }
    if s.substring(0, 1) == "\"" {
        let inner = s.substring(1, s.len())
        let ep = inner.split("\"")
        if ep.len() < 1 { return "" }
        return ep[0]
    }
    let mut end = 0
    while end < s.len() {
        let c = s.substring(end, end + 1)
        if c == "," || c == "}" || c == "\n" || c == " " { break }
        end = end + 1
    }
    return s.substring(0, end).trim()
}

fn shell_quote(s: string) -> string {
    let escaped = s.replace("'", "'\\''")
    return "'" + escaped + "'"
}

fn append_line(path: string, line: string) {
    let cmd = "printf '%s\\n' " + shell_quote(line) + " >> '" + path + "' 2>/dev/null"
    let _r = exec(cmd)  // @allow-bare-exec
}

fn _ensure_log() {
    if file_exists(LOG) == false {
        try { write_file(LOG, "") } catch e {}
    }
}

// ─── atlas.n6.deg 의 top10 hub (degree 내림차순) ───
fn load_hubs() -> [string] {
    let mut hubs: [string] = []
    if file_exists(ATLAS_DEG) == false { return hubs }
    // sort -k2 -n -r 로 내림차순 + head 10
    let raw = _str(exec("sort -k2 -n -r '" + ATLAS_DEG + "' 2>/dev/null | head -10"))  // @allow-bare-exec
    if raw.trim() == "" { return hubs }
    let lines = raw.split("\n")
    let mut i = 0
    while i < lines.len() {
        let line = _str(lines[i]).trim()
        if line.len() > 0 {
            let parts = line.split("\t")
            if parts.len() >= 1 {
                let node = _str(parts[0]).trim()
                if node.len() > 0 { hubs = hubs.push(node) }
            }
        }
        i = i + 1
    }
    return hubs
}

// ─── atlas.n6.deg 의 degree=1 leaf head 50 ───
fn load_leaves() -> [string] {
    let mut leaves: [string] = []
    if file_exists(ATLAS_DEG) == false { return leaves }
    // awk '$2==1' | head -50
    let raw = _str(exec("awk -F'\\t' '$2==1' '" + ATLAS_DEG + "' 2>/dev/null | head -50"))  // @allow-bare-exec
    if raw.trim() == "" { return leaves }
    let lines = raw.split("\n")
    let mut i = 0
    while i < lines.len() {
        let line = _str(lines[i]).trim()
        if line.len() > 0 {
            let parts = line.split("\t")
            if parts.len() >= 1 {
                let node = _str(parts[0]).trim()
                if node.len() > 0 { leaves = leaves.push(node) }
            }
        }
        i = i + 1
    }
    return leaves
}

// ─── prefix 추출 ('-' 앞 첫 segment) ───
fn prefix_of(s: string) -> string {
    if s.contains("-") == false { return s }
    let p = s.split("-")
    if p.len() < 1 { return s }
    return _str(p[0])
}

// ─── ask ───
fn cmd_ask(argv: [string]) {
    _ensure_log()
    let hubs = load_hubs()
    let leaves = load_leaves()
    if hubs.len() == 0 || leaves.len() == 0 {
        eprintln("REJECT: hubs/leaves 로드 실패 (hubs=" + to_string(hubs.len()) +
                 " leaves=" + to_string(leaves.len()) + ")")
        exit(2)
    }

    let ts = now_unix()
    // deterministic pick — ts mod len
    let h_idx = ts % hubs.len()
    let hub = hubs[h_idx]
    let hub_px = prefix_of(hub)

    // leaf 중 prefix 공유 우선, 없으면 첫 leaf
    let mut leaf = leaves[ts % leaves.len()]
    let mut matched = false
    let mut i = 0
    while i < leaves.len() {
        let cand = leaves[i]
        if prefix_of(cand) == hub_px && cand != hub {
            leaf = cand
            matched = true
            break
        }
        i = i + 1
    }

    let question = "Q: how does " + hub + " relate to " + leaf + "?"
    let shared = ""
    let mut shared_flag = "false"
    if matched { shared_flag = "true" }

    let row = "{\"ts\":" + to_string(ts) +
              ",\"kind\":\"question\"" +
              ",\"hub\":\"" + json_escape(hub) + "\"" +
              ",\"leaf\":\"" + json_escape(leaf) + "\"" +
              ",\"prefix_shared\":" + shared_flag +
              ",\"question\":\"" + json_escape(question) + "\"}"
    append_line(LOG, row)

    // thinking_engine 백그라운드 위임 (nohup 불필요 — & 만)
    let th_cmd = "'" + HEXA_BIN + "' run '" + THINK_BIN + "' query " +
                 shell_quote(question) + " >/dev/null 2>&1 &"
    let _r = exec(th_cmd)  // @allow-bare-exec

    println("ask: " + question + " (prefix_shared=" + shared_flag + ")")
}

// ─── status — 최근 100 질문 reflect 비율 ───
fn cmd_status(argv: [string]) {
    if file_exists(LOG) == false {
        println("curiosity questions_100=0 reflected=0 reflect_ratio=0.0 last_ts=0")
        return
    }
    let raw = _str(read_file(LOG))
    if raw.trim() == "" {
        println("curiosity questions_100=0 reflected=0 reflect_ratio=0.0 last_ts=0")
        return
    }
    let lines = raw.split("\n")
    let mut rows: [string] = []
    let mut i = 0
    while i < lines.len() {
        let line = _str(lines[i]).trim()
        if line.len() > 0 { rows = rows.push(line) }
        i = i + 1
    }
    let total = rows.len()
    let window: i64 = 100
    let mut start: i64 = 0
    if total > window { start = total - window }
    let slice_len = total - start

    // thinking_log 최근 raw 스캔 (답변 매핑: question substring 포함 여부)
    let mut think_raw = ""
    if file_exists(THINK_LOG) {
        think_raw = _str(read_file(THINK_LOG))
    }

    let mut last_ts: i64 = 0
    let mut reflected: i64 = 0
    let mut j: i64 = start
    while j < total {
        let line = rows[j]
        let ts = _to_int0(json_field(line, "ts"))
        if ts > last_ts { last_ts = ts }
        let q = json_field(line, "question")
        // thinking_log 에 question 문자열 직접 매칭 (첫 30자 prefix 로 근사)
        if q.len() > 0 && think_raw.len() > 0 {
            let plen = 30
            let mut probe = q
            if q.len() > plen { probe = q.substring(0, plen) }
            if think_raw.contains(probe) { reflected = reflected + 1 }
        }
        j = j + 1
    }

    // ratio 소수 2자리 (int math — *100)
    let mut ratio_pct: i64 = 0
    if slice_len > 0 { ratio_pct = (reflected * 100) / slice_len }

    println("curiosity questions_100=" + to_string(slice_len) +
            " reflected=" + to_string(reflected) +
            " reflect_pct=" + to_string(ratio_pct) +
            " last_ts=" + to_string(last_ts))
}

fn cmd_history(argv: [string]) {
    let mut n: i64 = 10
    if argv.len() >= 4 {
        let v = _to_int0(argv[3].trim())
        if v > 0 { n = v }
    }
    if file_exists(LOG) == false { return }
    let cmd = "tail -n " + to_string(n) + " '" + LOG + "' 2>/dev/null"
    let out = _str(exec(cmd))  // @allow-bare-exec
    print(out)
}

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    if argv.len() < 3 {
        eprintln("usage: curiosity <ask|status|history> [args...]")
        exit(2)
    }
    let mode = argv[2].trim()
    if mode == "ask" { cmd_ask(argv) }
    else if mode == "status" { cmd_status(argv) }
    else if mode == "history" { cmd_history(argv) }
    else {
        eprintln("REJECT: unknown mode '" + mode + "' — modes: ask|status|history")
        exit(2)
    }
}

main()
