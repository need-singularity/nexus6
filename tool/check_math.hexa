#!hexa strict
// tool/check_math.hexa — nexus check 수학 분야 백엔드 (n6 자산 wrapper)
//
// @tool(slug="check_math", desc="math domain — wraps n6_invariants_drift_check + (placeholder) absolute/hyperarith")
// @usage(HEXA_ARGV='[--quiet] [--no-invariants]' hexa run tool/check_math.hexa)
// @exit_codes(0=PASS, 1=usage, 2=verify FAIL)
// @sentinel(__NEXUS_CHECK_MATH__ <PASS|FAIL> invariants=<R> absolute=<R> hyperarith=<R>)
// @origin(nexus 자산 wrapper — see docs/nexus_check.ai.md migration policy)
//
// v1 scope:
//   - invariants  : tool/n6_invariants_drift_check.sh — exit code 기준 PASS/FAIL
//                   (exit 0=PASS, 1=DRIFT→FAIL, 2=STALE→FAIL, 3=parse-err→FAIL,
//                    upstream missing → script 가 자체적으로 exit 0 [SKIP] 반환)
//   - absolute    : engine/run.hexa cmd_absolute (Mk.VIII Π₀¹) — 인자(--seed) 필요,
//                   v1 에서는 항상 SKIP. v2 에서 wire 예정.
//   - hyperarith  : engine/run.hexa cmd_hyperarithmetic (Mk.IX Π₀²) — 인자(--prop) 필요,
//                   v1 에서는 항상 SKIP. v2 에서 wire 예정.
//
// 라우터 합의: 마지막 stdout 라인이 sentinel 이며 PASS/FAIL 토큰 포함 (check_router.hexa
// last-line index_of("PASS"/"FAIL") 컨벤션).

fn _argv() -> array {
    let raw = to_string(exec("printf '%s' \"${HEXA_ARGV:-}\""))
    let parts = split(raw, " ")
    let mut out = []
    let mut k = 0
    while k < len(parts) { if len(parts[k]) > 0 { out.push(parts[k]) }; k = k + 1 }
    return out
}

fn _has(a: array, f: string) -> bool {
    let mut i = 0
    while i < len(a) { if a[i] == f { return true }; i = i + 1 }
    return false
}

let NEXUS = "/Users/ghost/core/nexus"
let ARGS = _argv()
let QUIET = _has(ARGS, "--quiet")

if _has(ARGS, "--help") || _has(ARGS, "-h") {
    println("usage: HEXA_ARGV='[--quiet] [--no-invariants]' hexa run tool/check_math.hexa")
    println("  invariants : n6_invariants_drift_check.sh (10 atoms drift)")
    println("  absolute   : SKIP in v1 (requires --seed arg; wired in v2)")
    println("  hyperarith : SKIP in v1 (requires --prop arg; wired in v2)")
    println("  exit 0=PASS, 2=FAIL")
    return
}

// invariants — bash script exit code via inline __EXIT__ marker
fn run_invariants(quiet: bool) -> string {
    let path = NEXUS + "/tool/n6_invariants_drift_check.sh"
    if !file_exists(path) { return "SKIP" }
    // exec() 은 stdout 만 반환 — exit code 를 마지막 라인에 echo 로 emit 하여 파싱.
    let cmd = "bash " + path + " 2>&1; echo __EXIT__=$?"
    let out = to_string(exec(cmd))
    let lines = split(out, "\n")
    let mut ec = -1
    let mut display = []
    for l in lines {
        let t = l.trim()
        if len(t) == 0 { continue }
        if t.index_of("__EXIT__=") == 0 {
            let v = t.substring(9, len(t))
            ec = to_int(v)
        } else {
            display.push(l)
        }
    }
    if !quiet {
        let mut j = 0
        while j < len(display) { println(display[j]); j = j + 1 }
    }
    // exit 0 ⇒ PASS (semantic match + fresh, OR upstream-missing fail-open SKIP)
    // exit 1/2/3 ⇒ FAIL (drift / stale / parse error)
    if ec == 0 { return "PASS" }
    return "FAIL"
}

// v1: absolute / hyperarith 는 별도 PR 에서 wire — 항상 SKIP
let mut s_inv = "SKIP"
let mut s_abs = "SKIP"
let mut s_hyp = "SKIP"

if !_has(ARGS, "--no-invariants") {
    s_inv = run_invariants(QUIET)
}

let mut overall = "PASS"
if s_inv == "FAIL" || s_abs == "FAIL" || s_hyp == "FAIL" { overall = "FAIL" }

println("__NEXUS_CHECK_MATH__ " + overall +
        " invariants=" + s_inv +
        " absolute=" + s_abs +
        " hyperarith=" + s_hyp)

if overall == "FAIL" { exit(2) }
