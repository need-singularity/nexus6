#!hexa strict
// tool/check_sim.hexa — nexus check sim 분야 백엔드 (sim_bridge/anu_time wrapper)
//
// @tool(slug="check_sim", desc="sim-universe (sim_bridge/anu_time) 검증 — pipeline/ensemble/propagation selftest wrap")
// @usage(HEXA_ARGV='[--quiet] [--no-pipeline|--no-ensemble|--no-propagation]' hexa run tool/check_sim.hexa)
// @exit_codes(0=PASS, 1=usage, 2=verify FAIL)
// @sentinel(__NEXUS_CHECK_SIM__ <PASS|FAIL> pipeline=<R> ensemble=<R> propagation=<R>)
// @origin(check_physics 가 이미 wrap 한 empirical_anchor/lorentz_metric 은 중복 회피 — 상위 통합 도구만 wrap)
//
// 선정 근거 (check_physics 와 중복 회피):
//   - empirical_anchor.hexa  → check_physics --anchor  (제외)
//   - lorentz_metric.hexa    → check_physics --lorentz (제외)
//   - universe_pipeline      → Stage 1-5 unified independent runner (5 topo × 5 stage)
//   - universe_ensemble      → Stage 7 multi-cycle ensemble (mean/stdev)
//   - universe_propagation   → Stage 6 cross-feed (state propagation)
//
// 라우터 합의: 마지막 stdout 라인이 sentinel 이며 PASS/FAIL 토큰 포함.
// sim 도구는 args() 로 인자 읽음 → HEXA_ARGV 로는 --selftest 전달 안됨 →
// `hexa run <path> --selftest` positional 로 직접 호출.

fn _argv() -> array {
    let raw = to_string(exec("printf '%s' \"${HEXA_ARGV:-}\""))
    let parts = split(raw, " ")
    let mut out = []
    let mut k = 0
    while k < len(parts) {
        if len(parts[k]) > 0 { out.push(parts[k]) }
        k = k + 1
    }
    return out
}

fn _has(a: array, f: string) -> bool {
    let mut i = 0
    while i < len(a) {
        if a[i] == f { return true }
        i = i + 1
    }
    return false
}

let NEXUS = "/Users/ghost/core/nexus"
let ARGS = _argv()
let QUIET = _has(ARGS, "--quiet")

if _has(ARGS, "--help") || _has(ARGS, "-h") {
    println("usage: HEXA_ARGV='[--quiet] [--no-pipeline|--no-ensemble|--no-propagation]' hexa run tool/check_sim.hexa")
    println("  pipeline    : sim_bridge/anu_time/universe_pipeline.hexa --selftest (Stage 1-5 × 5 topo)")
    println("  ensemble    : sim_bridge/anu_time/universe_ensemble.hexa --selftest (Stage 7 multi-cycle)")
    println("  propagation : sim_bridge/anu_time/universe_propagation.hexa --selftest (Stage 6 cross-feed)")
    println("  exit 0=PASS, 2=FAIL")
    return
}

// sim_bridge selftest wrapper — selftest 결과는 own sentinel (__UNIVERSE_*_SELFTEST__) 마지막 라인.
fn _wrap_selftest(path: string, quiet: bool) -> string {
    if !file_exists(path) { return "SKIP" }
    // sim 도구는 args() 사용 → HEXA_ARGV 로 못 보냄. positional 로 전달.
    let cmd = "HEXA_LOCAL=1 hexa run " + path + " --selftest 2>&1"
    let out = to_string(exec(cmd))
    if !quiet { println(out.trim()) }
    let lines = split(out, "\n")
    let mut last = ""
    for l in lines {
        let tl = l.trim()
        if len(tl) > 0 { last = tl }
    }
    if last.index_of("PASS") >= 0 { return "PASS" }
    if last.index_of("FAIL") >= 0 { return "FAIL" }
    return "FAIL"
}

let DO_PIPELINE    = !_has(ARGS, "--no-pipeline")
let DO_ENSEMBLE    = !_has(ARGS, "--no-ensemble")
let DO_PROPAGATION = !_has(ARGS, "--no-propagation")

let mut s_pipe = "SKIP"
let mut s_ens  = "SKIP"
let mut s_prop = "SKIP"
let mut overall_pass = true

if DO_PIPELINE {
    s_pipe = _wrap_selftest(NEXUS + "/sim_bridge/anu_time/universe_pipeline.hexa", QUIET)
    if s_pipe == "FAIL" { overall_pass = false }
}
if DO_ENSEMBLE {
    s_ens = _wrap_selftest(NEXUS + "/sim_bridge/anu_time/universe_ensemble.hexa", QUIET)
    if s_ens == "FAIL" { overall_pass = false }
}
if DO_PROPAGATION {
    s_prop = _wrap_selftest(NEXUS + "/sim_bridge/anu_time/universe_propagation.hexa", QUIET)
    if s_prop == "FAIL" { overall_pass = false }
}

let mut verdict = "PASS"
if !overall_pass { verdict = "FAIL" }
println("__NEXUS_CHECK_SIM__ " + verdict + " pipeline=" + s_pipe + " ensemble=" + s_ens + " propagation=" + s_prop)
if !overall_pass { exit(2) }
