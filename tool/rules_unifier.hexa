// rules_unifier.hexa — GOV-P9-1 unified rules v3 (ai-proposed rules 통합)
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
//
// Reads rule_suggest staging JSONL + mistakes/lint logs, extracts 3+ repeat
// violation patterns, drafts new rules in common.json schema, dedup/conflict
// checks vs existing, dry-run or apply mode.
//
// Usage:
//   hexa shared/tool/rules_unifier.hexa analyze [--threshold N]
//   hexa shared/tool/rules_unifier.hexa draft [--threshold N]
//   hexa shared/tool/rules_unifier.hexa apply [--threshold N]
//   hexa shared/tool/rules_unifier.hexa reindex
//   hexa shared/tool/rules_unifier.hexa status

let REPO = exec("git rev-parse --show-toplevel 2>/dev/null").trim()  // @allow-bare-exec
let SHARED = REPO + "/shared"
let HARNESS = SHARED + "/harness"
let COMMON_PATH = SHARED + "/rules/common.json"
let NEXUS_PATH = SHARED + "/rules/nexus.json"
let STAGING_PATH = HARNESS + "/rule_suggest_staging.jsonl"
let MISTAKES_PATH = HARNESS + "/mistakes.jsonl"
let LINT_LOG_PATH = HARNESS + "/lint_log.jsonl"
let BINARY_INDEX_PATH = HARNESS + "/rule_binary_index.json"
let DEFAULT_THRESHOLD = 3
let SCAN_WINDOW = 500

fn now_iso() -> string { return exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim() }  // @allow-bare-exec

fn json_escape(s: string) -> string {
    return s.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n")
}
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}
fn _to_int0(x) -> i64 {
    let mut v = 0
    try { v = to_int(x) } catch e {}
    return v
}
fn tail_lines(path: string, n: i64) -> [string] {
    let mut raw = ""
    try { raw = exec("tail -n " + to_string(n) + " '" + path + "' 2>/dev/null").trim() } catch e {}  // @allow-bare-exec
    if len(raw) == 0 { return [] }
    return raw.split("\n")
}

fn extract_field(line: string, field: string) -> string {
    let key = "\"" + field + "\":\""
    let idx = line.index_of(key)
    if idx < 0 { return "" }
    let start = idx + len(key)
    let rest = line.substring(start, len(line))
    let end_idx = rest.index_of("\"")
    if end_idx < 0 { return "" }
    return rest.substring(0, end_idx)
}

fn extract_int_field(line: string, field: string) -> i64 {
    let key = "\"" + field + "\":"
    let idx = line.index_of(key)
    if idx < 0 { return 0 }
    let start = idx + len(key)
    let rest = line.substring(start, len(line))
    let mut end_idx = 0
    let rlen = len(rest)
    while end_idx < rlen {
        let ch = rest.substring(end_idx, end_idx + 1)
        if ch == "0" || ch == "1" || ch == "2" || ch == "3" || ch == "4"
            || ch == "5" || ch == "6" || ch == "7" || ch == "8" || ch == "9" {
            end_idx = end_idx + 1
        } else { break }
    }
    if end_idx == 0 { return 0 }
    return _to_int0(rest.substring(0, end_idx))
}

// ─── Load existing rule IDs from common.json + nexus.json ───
fn _load_rules_from(path: string) -> map {
    let mut ids = #{}
    let mut raw = ""
    try { raw = read_file(path) } catch e {}
    if len(raw) == 0 { return ids }
    let lines = raw.split("\n")
    for l in lines {
        let rid = extract_field(l, "id")
        if len(rid) > 0 { ids[rid] = true }
    }
    return ids
}
fn load_existing_rule_ids() -> map {
    let c = _load_rules_from(COMMON_PATH)
    let n = _load_rules_from(NEXUS_PATH)
    let nk = keys(n)
    for k in nk { c[k] = true }
    return c
}
fn load_existing_rule_descriptions() -> map {
    let mut descs = #{}
    let mut raw = ""
    try { raw = read_file(COMMON_PATH) } catch e {}
    if len(raw) == 0 { return descs }
    let lines = raw.split("\n")
    for l in lines {
        let rid = extract_field(l, "id")
        let rule_text = extract_field(l, "rule")
        if len(rid) > 0 && len(rule_text) > 0 { descs[rid] = rule_text }
    }
    return descs
}

// ─── Mine patterns from JSONL logs ───
fn _mine_rules(path: string, window: i64) -> map {
    let lines = tail_lines(path, window)
    let mut counts = #{}
    for line in lines {
        let viol_key = "\"rule\":\""
        let mut search_from = 0
        let line_len = len(line)
        while search_from < line_len {
            let rest = line.substring(search_from, line_len)
            let idx = rest.index_of(viol_key)
            if idx < 0 { break }
            let start = idx + len(viol_key)
            let after = rest.substring(start, len(rest))
            let end_idx = after.index_of("\"")
            if end_idx < 0 { break }
            let rule = after.substring(0, end_idx)
            if len(rule) > 0 {
                let mut cur = 0
                try { cur = counts[rule] } catch e {}
                counts[rule] = cur + 1
            }
            search_from = search_from + idx + start + end_idx + 1
        }
    }
    return counts
}
fn merge_counts(a: map, b: map) -> map {
    let mut m = #{}
    let ak = keys(a)
    for k in ak { m[k] = a[k] }
    let bk = keys(b)
    for k in bk {
        let mut prev = 0
        try { prev = m[k] } catch e {}
        m[k] = prev + b[k]
    }
    return m
}

fn load_staging() -> [map] {
    let mut proposals = []
    if file_exists(STAGING_PATH) == false { return proposals }
    let lines = tail_lines(STAGING_PATH, 1000)
    for line in lines {
        if len(line.trim()) == 0 { continue }
        let id = extract_field(line, "id")
        if len(id) == 0 { continue }
        proposals = proposals.push(#{
            "id": id, "source_pattern": extract_field(line, "source_pattern"),
            "occurrences": extract_int_field(line, "occurrences"),
            "severity": extract_field(line, "severity"), "status": extract_field(line, "status")
        })
    }
    return proposals
}

fn level_from_count(c: i64) -> string {
    if c >= 50 { return "⛔⛔" }
    if c >= 20 { return "⛔" }
    if c >= 10 { return "🔴" }
    return "⚠️"
}
fn enf_from_count(c: i64) -> string {
    if c >= 20 { return "error" }
    if c >= 10 { return "warn" }
    return "info"
}
fn check_conflict(pattern: string, descs: map) -> string {
    let pl = pattern.to_lower()
    if len(pl) <= 3 { return "" }
    let dk = keys(descs)
    for k in dk {
        if _str(descs[k]).to_lower().contains(pl) { return k }
    }
    return ""
}
fn next_r_number(existing: map) -> i64 {
    let mut max_r = 36
    let ek = keys(existing)
    for k in ek {
        let sk = _str(k)
        if sk.starts_with("R") {
            let n = _to_int0(sk.substring(1, len(sk)))
            if n > max_r { max_r = n }
        }
    }
    return max_r + 1
}

// ─── Core analysis ───
fn analyze(threshold: i64) -> map {
    let live = merge_counts(_mine_rules(MISTAKES_PATH, SCAN_WINDOW), _mine_rules(LINT_LOG_PATH, SCAN_WINDOW))
    let existing = load_existing_rule_ids()
    let descs = load_existing_rule_descriptions()
    let staging = load_staging()
    let mut staged_pats = #{}
    for sp in staging {
        let p = _str(sp["source_pattern"])
        if len(p) > 0 { staged_pats[p] = true }
    }
    let mk = keys(live)
    let mut candidates = []
    let mut covered = []
    let mut below = []
    for rn in mk {
        let count = live[rn]
        let mut is_ex = false
        try { is_ex = existing[rn] == true } catch e {}
        if is_ex {
            covered = covered.push(#{"pattern": rn, "count": count})
            continue
        }
        if count < threshold {
            below = below.push(#{"pattern": rn, "count": count})
            continue
        }
        let mut is_staged = false
        try { is_staged = staged_pats[rn] == true } catch e {}
        candidates = candidates.push(#{
            "pattern": rn, "count": count, "already_staged": is_staged,
            "conflict_with": check_conflict(rn, descs),
            "severity": enf_from_count(count), "level": level_from_count(count)
        })
    }
    return #{
        "candidates": candidates, "covered": covered, "below": below,
        "staging": staging, "existing_count": len(keys(existing)),
        "live_patterns": len(mk), "threshold": threshold
    }
}

// ─── Draft new rules ───
fn draft_rules(threshold: i64) -> [map] {
    let a = analyze(threshold)
    let candidates = a["candidates"]
    let existing = load_existing_rule_ids()
    let mut next_r = next_r_number(existing)
    let mut drafts = []
    for c in candidates {
        if c["already_staged"] == true { continue }
        if len(_str(c["conflict_with"])) > 0 { continue }
        let pat = _str(c["pattern"])
        let count = c["count"]
        drafts = drafts.push(#{
            "id": "R" + to_string(next_r),
            "rule": "Auto-detected: " + pat + " (" + to_string(count) + " violations in last " + to_string(SCAN_WINDOW) + " entries)",
            "level": _str(c["level"]),
            "enforcement": enf_from_count(count) + ". auto-proposed by rules_unifier. pattern='" + pat + "' hits=" + to_string(count),
            "applies_to": "all", "source": "rules_unifier",
            "source_pattern": pat, "occurrences": count,
            "added": now_iso(), "see_also": ["H-ERR-PROMOTE"]
        })
        next_r = next_r + 1
    }
    return drafts
}

// ─── Binary index builder ───
fn build_binary_index() -> string {
    let mut rule_ids = []
    let mut bit_map = #{}
    let mut bit_pos = 0
    let mut common_raw = ""
    try { common_raw = read_file(COMMON_PATH) } catch e {}
    let clines = common_raw.split("\n")
    for cl in clines {
        let rid = extract_field(cl, "id")
        if len(rid) == 0 { continue }
        let mut al = false
        try { al = bit_map[rid] != "" } catch e {}
        if al { continue }
        bit_map[rid] = to_string(bit_pos)
        rule_ids = rule_ids.push(rid)
        bit_pos = bit_pos + 1
    }
    let mut nexus_raw = ""
    try { nexus_raw = read_file(NEXUS_PATH) } catch e {}
    let nlines = nexus_raw.split("\n")
    for nl in nlines {
        let rid = extract_field(nl, "id")
        if len(rid) == 0 { continue }
        let mut al = false
        try { al = bit_map[rid] != "" } catch e {}
        if al { continue }
        bit_map[rid] = to_string(bit_pos)
        rule_ids = rule_ids.push(rid)
        bit_pos = bit_pos + 1
    }
    let mut crit = []
    let mut err_g = []
    let mut warn_g = []
    for rid in rule_ids {
        let mut lvl = ""
        for cl in clines {
            if extract_field(cl, "id") == rid {
                lvl = extract_field(cl, "level")
                break
            }
        }
        if lvl.contains("⛔⛔") || lvl.contains("★★") { crit = crit.push("\"" + json_escape(rid) + "\"") }
        else if lvl.contains("⛔") || lvl.contains("🔴") { err_g = err_g.push("\"" + json_escape(rid) + "\"") }
        else { warn_g = warn_g.push("\"" + json_escape(rid) + "\"") }
    }
    let mut j = "{\n  \"_meta\": {\"description\": \"Binary rule index v3\", \"total_rules\": " + to_string(bit_pos) + ", \"generated_by\": \"rules_unifier.hexa\", \"ts\": \"" + now_iso() + "\"},\n"
    j = j + "  \"encoding\": \"bit_position: rule_id\",\n  \"index\": {\n"
    let mut i = 0
    for rid in rule_ids {
        if i > 0 { j = j + ",\n" }
        j = j + "    \"" + json_escape(rid) + "\": " + to_string(i)
        i = i + 1
    }
    j = j + "\n  },\n  \"total_bits\": " + to_string(bit_pos) + ",\n"
    j = j + "  \"hex_words_needed\": " + to_string((bit_pos + 63) / 64) + ",\n"
    j = j + "  \"severity_groups\": {\n    \"critical\": [" + crit.join(", ") + "],\n"
    j = j + "    \"error\": [" + err_g.join(", ") + "],\n"
    j = j + "    \"warn\": [" + warn_g.join(", ") + "]\n  }\n}\n"
    return j
}

// ─── Apply rules to common.json ───
fn apply_rules(drafts: [map]) {
    if len(drafts) == 0 {
        println("[rules_unifier] no new rules to apply")
        return
    }
    let mut common_raw = ""
    try { common_raw = read_file(COMMON_PATH) } catch e {
        print_err("[rules_unifier] ERROR reading common.json: " + to_string(e))
        return
    }
    let marker = "\n  ]\n}"
    let insert_pos = common_raw.index_of(marker)
    if insert_pos < 0 {
        print_err("[rules_unifier] ERROR: rules array end marker not found")
        return
    }
    let mut entries = ""
    for d in drafts {
        entries = entries + ",\n    {\n"
        entries = entries + "      \"id\": \"" + json_escape(_str(d["id"])) + "\",\n"
        entries = entries + "      \"rule\": \"" + json_escape(_str(d["rule"])) + "\",\n"
        entries = entries + "      \"level\": \"" + json_escape(_str(d["level"])) + "\",\n"
        entries = entries + "      \"enforcement\": \"" + json_escape(_str(d["enforcement"])) + "\",\n"
        entries = entries + "      \"applies_to\": \"all\",\n"
        entries = entries + "      \"source\": \"rules_unifier\",\n"
        entries = entries + "      \"source_pattern\": \"" + json_escape(_str(d["source_pattern"])) + "\",\n"
        entries = entries + "      \"added\": \"" + json_escape(_str(d["added"])) + "\",\n"
        entries = entries + "      \"see_also\": [\"H-ERR-PROMOTE\"]\n    }"
    }
    let updated = common_raw.substring(0, insert_pos) + entries + marker
    try { write_file(COMMON_PATH, updated) } catch e {
        print_err("[rules_unifier] ERROR writing common.json: " + to_string(e))
        return
    }
    println("[rules_unifier] applied " + to_string(len(drafts)) + " new rules to common.json")
    // refresh binary index
    try { write_file(BINARY_INDEX_PATH, build_binary_index()) } catch e {
        print_err("[rules_unifier] warn: binary index write failed")
    }
    println("[rules_unifier] binary index refreshed")
    // record applied in staging
    let mut sa = ""
    for d in drafts {
        sa = sa + "{\"id\":\"" + json_escape(_str(d["id"])) + "\",\"source_pattern\":\"" + json_escape(_str(d["source_pattern"])) + "\",\"occurrences\":" + to_string(d["occurrences"]) + ",\"status\":\"applied\",\"ts\":\"" + now_iso() + "\"}\n"
    }
    try { append_file(STAGING_PATH, sa) } catch e {}
}

// ─── Print candidate line ───
fn _print_candidate(c: map) {
    let pat = _str(c["pattern"])
    let count = to_string(c["count"])
    if c["already_staged"] == true {
        println("  [staged] " + pat + "  (" + count + " hits)")
        return
    }
    let conf = _str(c["conflict_with"])
    if len(conf) > 0 {
        println("  [conflict:" + conf + "] " + pat + "  (" + count + " hits)")
        return
    }
    println("  [new] " + pat + "  (" + count + " hits, " + _str(c["severity"]) + ")")
}

// ─── CLI commands ───
fn cmd_status() {
    let a = analyze(DEFAULT_THRESHOLD)
    println("=== Rules Unifier v3 Status (GOV-P9-1) ===")
    println("existing rules:    " + to_string(a["existing_count"]))
    println("live patterns:     " + to_string(a["live_patterns"]))
    println("  covered:         " + to_string(len(a["covered"])))
    println("  candidates:      " + to_string(len(a["candidates"])))
    println("  below threshold: " + to_string(len(a["below"])))
    println("staging:           " + to_string(len(a["staging"])))
    let candidates = a["candidates"]
    if len(candidates) > 0 {
        println("--- candidates ---")
        for c in candidates { _print_candidate(c) }
    }
    let mut idx_s = "missing"
    if file_exists(BINARY_INDEX_PATH) { idx_s = "present" }
    println("binary index:      " + idx_s)
    println("__HARNESS_RULES_UNIFIER__ STATUS_OK")
}

fn cmd_analyze(threshold: i64) {
    println("[rules_unifier] analyzing (threshold=" + to_string(threshold) + ", window=" + to_string(SCAN_WINDOW) + ")")
    let a = analyze(threshold)
    println("--- covered ---")
    let covered = a["covered"]
    for c in covered { println("  " + _str(c["pattern"]) + "  (" + to_string(c["count"]) + ")") }
    println("--- candidates ---")
    let candidates = a["candidates"]
    if len(candidates) == 0 { println("  (none)") }
    for c in candidates { _print_candidate(c) }
    println("--- below threshold ---")
    let below = a["below"]
    for b in below { println("  " + _str(b["pattern"]) + "  (" + to_string(b["count"]) + ")") }
    println("__HARNESS_RULES_UNIFIER__ ANALYZE_OK")
}

fn cmd_draft(threshold: i64) {
    let drafts = draft_rules(threshold)
    if len(drafts) == 0 {
        println("[rules_unifier] no drafts")
        println("__HARNESS_RULES_UNIFIER__ DRAFT_EMPTY")
        return
    }
    println("[rules_unifier] drafted " + to_string(len(drafts)) + " rule(s):")
    for d in drafts {
        println("  " + _str(d["id"]) + "  " + _str(d["source_pattern"]) + "  " + to_string(d["occurrences"]) + "x  " + _str(d["level"]))
    }
    println("__HARNESS_RULES_UNIFIER__ DRAFT_OK")
}

fn cmd_apply(threshold: i64) {
    let drafts = draft_rules(threshold)
    if len(drafts) == 0 {
        println("[rules_unifier] nothing to apply")
        println("__HARNESS_RULES_UNIFIER__ APPLY_EMPTY")
        return
    }
    println("[rules_unifier] applying " + to_string(len(drafts)) + " rule(s)...")
    for d in drafts { println("  " + _str(d["id"]) + "  " + _str(d["source_pattern"])) }
    apply_rules(drafts)
    println("__HARNESS_RULES_UNIFIER__ APPLY_OK")
}

fn cmd_reindex() {
    println("[rules_unifier] regenerating binary index...")
    try { write_file(BINARY_INDEX_PATH, build_binary_index()) } catch e {
        print_err("[rules_unifier] ERROR: " + to_string(e))
        return
    }
    println("[rules_unifier] binary index written: " + BINARY_INDEX_PATH)
    println("__HARNESS_RULES_UNIFIER__ REINDEX_OK")
}

// ─── CLI router ───
let argv = args()
let argc = len(argv)
if argc < 1 {
    println("usage: hexa rules_unifier.hexa <analyze|draft|apply|reindex|status> [--threshold N]")
    exit(1)
}
let mode = _str(argv[0])
let mut threshold = DEFAULT_THRESHOLD
let mut i = 1
while i < argc {
    let arg = _str(argv[i])
    if arg == "--threshold" && (i + 1) < argc {
        try { threshold = to_int(argv[i + 1]) } catch e {}
        i = i + 2
        continue
    }
    i = i + 1
}
if mode == "analyze" { cmd_analyze(threshold) }
else if mode == "draft" { cmd_draft(threshold) }
else if mode == "apply" { cmd_apply(threshold) }
else if mode == "reindex" { cmd_reindex() }
else if mode == "status" { cmd_status() }
else {
    print_err("[rules_unifier] unknown mode: " + mode)
    exit(1)
}
