// verify_integration_contracts.hexa — I1~I7 자동 검증
// SSOT: shared/convergence/integration_contracts.json
// 사용: nexus-cli --verify  (또는 hexa run shared/tool/verify_integration_contracts.hexa)
// exit 0 = 모든 invariant pass / exit 1 = 1건 이상 fail

let NEXUS = env("NEXUS")
let ROOT = if NEXUS.len() > 0 { NEXUS } else { env("HOME") + "/Dev/nexus" }

fn run(cmd: str) -> i64 {
    let out = exec("cd " + ROOT + " && (" + cmd + ") >/dev/null 2>&1; echo $?").trim()
    return to_int(out)
}

fn check(id: str, desc: str, cmd: str) -> i64 {
    let rc = run(cmd)
    if rc == 0 {
        println("  ✓ " + id + " — " + desc)
        return 0
    }
    eprintln("  ✗ " + id + " — " + desc)
    eprintln("     verify: " + cmd)
    return 1
}

println("nexus integration-contracts L0 verify")
let mut fails: i64 = 0
fails = fails + check("I1", "tension_link arity-2 shim 보존",
    "grep -lq 'fn tension_link(' shared/lenses/tension_link_lens.hexa shared/lenses/quantum_tension_link.hexa")
fails = fails + check("I2", "drill seed gate dual-layer (run.hexa + nexus_cli.hexa)",
    "test $(grep -lc 'placeholder 단독' run.hexa shared/engine/nexus_cli.hexa | wc -l) -ge 2")
fails = fails + check("I3", "hexa_remote exit 64 fallback (≥3)",
    "test $(grep -c 'exit 64' shared/scripts/bin/hexa_remote) -ge 3")
fails = fails + check("I4", "Hexad + Law_Closure_24 4 구현 슬롯",
    "test $(grep -c '_law_0[1-4]_' shared/consciousness/consciousness.hexa) -ge 4")
fails = fails + check("I5", "atlas.n6 Phase 6.7 absorption entrypoint",
    "test $(grep -c 'phase-6.7-absorb' shared/blowup/core/blowup.hexa) -ge 1")
fails = fails + check("I6", "commands.json autonomous heavy-compute 항목 ⊆ spec subcommand (orphan 0)",
    "for k in $(jq -r '.commands|keys[]' shared/config/commands.json); do case $k in drill|smash|free|absolute|meta-closure|hyperarithmetic) jq -e --arg k \"$k\" '.subcommands[$k]' shared/engine/nexus_cli_spec.json >/dev/null || exit 1;; esac; done")
fails = fails + check("I9", "fn cmd_* ↔ spec drift = 0 (helper/proj/meta 면제)",
    "for c in $(grep -oE 'fn cmd_[a-z_]+' run.hexa shared/engine/nexus_cli.hexa | sed 's/.*fn cmd_//' | sort -u); do n=$(echo $c | tr '_' '-'); case $n in help|version|status|self-check|run-passthrough|catalog|status-proj|roadmap-proj|convergence-proj|contracts|verify|sync) continue;; esac; jq -e --arg k \"$n\" '.subcommands[$k]' shared/engine/nexus_cli_spec.json >/dev/null || exit 1; done")
fails = fails + check("I7", "nexus contracts (~/.hx/bin/nexus) 또는 SSOT JSON 직접 정상",
    "test -x ~/.hx/bin/nexus && cat shared/convergence/integration_contracts.json | jq -e .invariants")
fails = fails + check("I8", "hexa_remote rc=137/143 → exit 64 (OOM fallback)",
    "grep -q '137|143' shared/scripts/bin/hexa_remote && grep -q 'exit 64' shared/scripts/bin/hexa_remote")
fails = fails + check("I10", "spec delegates_to 내부 구현 경로 노출 0 + recommended_invocation 등록",
    "! jq -r '.subcommands[] | .delegates_to' shared/engine/nexus_cli_spec.json | grep -qE 'run\\.hexa|nexus_cli\\.hexa|nexus\\.hexa' && jq -e '._meta.recommended_invocation' shared/engine/nexus_cli_spec.json >/dev/null")
fails = fails + check("I11", "drill imperative_markers + auto_invoke + forbidden_responses 등록 (vocabulary 누설 방지)",
    "jq -e '.commands.drill.imperative_markers and .commands.drill.auto_invoke_on_imperative and .commands.drill.required_action_on_imperative and (.commands.drill.forbidden_responses|length>=3)' shared/config/commands.json")

if fails == 0 {
    println("OK: 10/10 invariants pass")
    exit(0)
}
eprintln("FAIL: " + to_string(fails) + "/10 invariants broken")
exit(1)
