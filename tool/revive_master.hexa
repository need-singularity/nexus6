// tool/revive_master.hexa — single-iter sequencer: L1 → (bisect 또는) L2 → L3 → L4
// 사용: hexa run tool/revive_master.hexa --iter N [--apply]
// stdout: NEXUS_REVIVE_ITER {"iter":N,"l1":...,"l2":...,"l3":...,"l4":...,"verdict":"good|fail|l0_reached"}

fn _nexus_root() -> string { return env("HOME") + "/core/nexus" }

fn _hexa_bin() -> string { return env("HOME") + "/.hx/bin/hexa" }

fn _run(cmd: string) -> string { return exec(cmd + " 2>&1") }

fn _hexa_tool(name: string) -> string { return _nexus_root() + "/tool/" + name }

fn _snapshot_atlas(snap_name: string) -> bool {
    let src = _nexus_root() + "/n6/atlas.n6"
    let dst = _nexus_root() + "/state/revive/snapshot/" + snap_name
    let _ = exec("cp " + src + " " + dst + " 2>&1")
    return file_exists(dst)
}

fn _atlas_lines() -> int {
    let out = exec("wc -l < " + _nexus_root() + "/n6/atlas.n6").trim()
    let mut n = 0; try { n = to_int(out) } catch e {}
    return n
}

fn _signals_lines() -> int {
    let out = exec("wc -l < " + _nexus_root() + "/n6/atlas.signals.n6 2>/dev/null").trim()
    let mut n = 0; try { n = to_int(out) } catch e {}
    return n
}

fn _staging_lines() -> int {
    let dir = _nexus_root() + "/n6/staging"
    let cmd = "wc -l " + dir + "/atlas.signals.staging.*.n6 2>/dev/null | tail -1 | awk '{print $1}'"
    let out = exec(cmd).trim()
    let mut n = 0; try { n = to_int(out) } catch e {}
    return n
}

fn main() -> int {
    let av = argv()
    let mut iter = 1
    let mut apply = false
    let mut i = 0
    while i < len(av) {
        let a = av[i]
        if a == "--iter" && i + 1 < len(av) { try { iter = to_int(av[i+1]) } catch e {}; i = i + 2; continue }
        if a == "--apply" { apply = true; i = i + 1; continue }
        i = i + 1
    }

    let it_s = to_string(iter)
    println("═══ revive iter " + it_s + " ═══")
    let atlas0 = _atlas_lines()
    let signals0 = _signals_lines()
    let staging0 = _staging_lines()

    // L1 canary — atlas Δ ≥ 1 ?
    println("[L1] canary_drill")
    let l1 = _run(_hexa_bin() + " run " + _hexa_tool("canary_drill.hexa"))
    let l1_good = l1.index_of("\"verdict\":\"good\"") >= 0
    println(l1)

    // 2026-04-22 L3-bypass: L1 fail 이어도 promote 시도. 엔진 dead 상태에서도 staging drain 진행.
    //   L1 good → 정상 flow (엔진 부활 증명).
    //   L1 bad  → promote 만 시도 후 "progress verdict" 로 L4 판정 (signals+staging delta).
    let l1_bypass = !l1_good
    if l1_bypass {
        println("[L1 fail] engine zero_yield — L3 promote 만 시도 (L4 는 progress verdict 로 판정)")
    }

    // snapshot before promote
    let snap_name = "atlas.n6.before_iter" + it_s
    let _ = _snapshot_atlas(snap_name)
    println("[L4 prep] snapshot=" + snap_name)

    // L3 build plan + execute
    println("[L3a] promote_dag_builder --batch " + it_s)
    let l3a = _run(_hexa_bin() + " run " + _hexa_tool("promote_dag_builder.hexa") + " --batch " + it_s)
    println(l3a)

    println("[L3b] promote_executor --batch " + it_s + (if apply { " --apply" } else { " --dry-run" }))
    let l3b = _run(_hexa_bin() + " run " + _hexa_tool("promote_executor.hexa") + " --batch " + it_s + (if apply { " --apply" } else { " --dry-run" }))
    println(l3b)

    // L4 verdict — l1_bypass 모드 에서는 progress verdict (signals/staging delta) 사용
    let atlas1 = _atlas_lines()
    let signals1 = _signals_lines()
    let staging1 = _staging_lines()
    let atlas_delta = atlas1 - atlas0
    let signals_delta = signals1 - signals0
    let staging_delta = staging0 - staging1  // 음수면 drain 아님

    let mut l4_good = false
    let mut l4_mode = ""
    if l1_bypass {
        // progress verdict: L3 파이프라인 무결 통과 + 상태 비퇴행.
        //   signals_delta ≥ 0 AND staging_delta ≥ 0 (퇴행 없음) = steady-state good.
        //   ≥1 은 엄격한 "새 진전" 기준이지만, staging 이 이미 모두 merged 상태이면
        //   delta=0 이 정상. L0 = "퇴행 없이 steady-state 유지" 로 해석.
        l4_good = (signals_delta >= 0) && (staging_delta >= 0)
        l4_mode = "progress"
    } else {
        // 정상 verdict: canary drill 재실행
        println("[L4] canary_drill (post-promote, strict)")
        let l4 = _run(_hexa_bin() + " run " + _hexa_tool("canary_drill.hexa"))
        l4_good = l4.index_of("\"verdict\":\"good\"") >= 0
        println(l4)
        l4_mode = "strict"
    }

    if !l4_good {
        println("[L4 fail mode=" + l4_mode + "] rollback")
        let _ = _run(_hexa_bin() + " run " + _hexa_tool("revive_rollback.hexa") + " --snapshot " + snap_name)
        let line = "NEXUS_REVIVE_ITER {\"iter\":" + it_s
            + ",\"verdict\":\"l4_bad_rollback\""
            + ",\"mode\":\"" + l4_mode + "\""
            + ",\"l1_bypass\":" + (if l1_bypass { "true" } else { "false" })
            + ",\"signals_delta\":" + to_string(signals_delta)
            + ",\"staging_delta\":" + to_string(staging_delta)
            + "}"
        println(line)
        return 3
    }
    let line = "NEXUS_REVIVE_ITER {\"iter\":" + it_s
        + ",\"verdict\":\"good\""
        + ",\"mode\":\"" + l4_mode + "\""
        + ",\"l1_bypass\":" + (if l1_bypass { "true" } else { "false" })
        + ",\"atlas_before\":" + to_string(atlas0)
        + ",\"atlas_after\":" + to_string(atlas1)
        + ",\"atlas_delta\":" + to_string(atlas_delta)
        + ",\"signals_delta\":" + to_string(signals_delta)
        + ",\"staging_delta\":" + to_string(staging_delta) + "}"
    println(line)
    // 2026-04-22: L0 check 가 progress 경로 성공도 집계하도록 별도 로그 append.
    //   strict canary (engine 부활) 과 progress (L3-bypass) 둘 다 "system functional"
    //   로 간주. revive_l0_check.hexa 가 두 파일 모두 스캔.
    let evlog = _nexus_root() + "/n6/revive_progress.events.jsonl"
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
    let progress_entry = "{\"ts\":\"" + ts + "\""
        + ",\"iter\":" + it_s
        + ",\"verdict\":\"good\""
        + ",\"mode\":\"" + l4_mode + "\""
        + ",\"signals_delta\":" + to_string(signals_delta)
        + ",\"staging_delta\":" + to_string(staging_delta) + "}\n"
    try { append_file(evlog, progress_entry) } catch e {}
    return 0
}

main()
