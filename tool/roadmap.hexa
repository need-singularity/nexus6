// roadmap.hexa — user-facing roadmap actions (next/extend/auto)
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
//
// 역할: 사용자가 `roadmap` 명령 입력 시 다음 스텝을 보여주고 (→ `go` 로 실행),
//       로드맵 소진 시 NEXUS 창발(blowup) 로 다음 phase 를 자동 생성.
//       verify|artifacts|status|crossref|all 은 roadmap_guard.hexa 에 위임.
//
// 서브커맨드:
//   next      다음 undone task 1 개 출력 (exit 0=found, 42=exhausted)
//   extend    NEXUS 창발 seed → 새 phase 1 개 append (planned 상태)
//   auto      next; 소진 시 extend → next 재시도 (사용자가 subcommand 생략 시 기본값)
//   list      전 5 프로젝트 next 요약
//   verify|artifacts|status|crossref|all  → roadmap_guard.hexa 위임
//
// 플래그:
//   --project <nexus|anima|anima-train|CANON|zeta-surpass>
//   --force   extend 시 emergence 실패해도 템플릿으로 append
//   --dry     extend write 안 함 (plan 만 출력)
//
// exit codes:
//   0   성공 (next found / extend wrote / auto completed)
//   42  next exhausted (auto 에서만 extend 트리거, 단독 next 는 42 반환)
//   1   emergence 실패 (--force 없이)
//   2   usage error
//   3   write error

let HOME = env("HOME")
let NEXUS = HOME + "/core/nexus"
let ROADMAPS = NEXUS + "/roadmaps"
let HARNESS = NEXUS + "/harness"
let HEXA = NEXUS + "/bin/hexa"

fn print_usage() {
    println("roadmap — user-facing roadmap actions (next/extend/auto)")
    println("")
    println("  next      다음 할일 1개 출력 (exit 42=소진)")
    println("  extend    NEXUS 창발로 새 phase 1개 append")
    println("  auto      next; 소진 시 extend → next (기본값)")
    println("  list      전 프로젝트 next 요약")
    println("  status    roadmap_guard 위임 (phase/task 진척도)")
    println("  verify    roadmap_guard 위임 (SCHEMA 정합성)")
    println("")
    println("flags:")
    println("  --project <nexus|anima|anima-train|CANON|zeta-surpass>")
    println("  --force   extend 시 emergence 실패해도 템플릿으로 append")
    println("  --dry     extend write 안함 (plan 출력)")
}

// ─── hexa-native JSON helpers (jq + exec) ────────────────────────
// python3 / R37/AN13/L3-PY 의존 제거 (2026-04-18 smash).

let mut _py_seq: i64 = 0

fn shq(s: str) -> str {
    let mut r = "'"
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "'" { r = r + "'\\''" } else { r = r + c }
        i = i + 1
    }
    return r + "'"
}

fn jq(query: str, path: str) -> str {
    // @allow-bare-exec
    let cmd = "jq -r " + shq(query) + " " + shq(path) + " 2>/dev/null"
    return to_string(exec(cmd)).trim()
}

fn jq_raw(query: str, path: str) -> str {
    // @allow-bare-exec
    let cmd = "jq -r " + shq(query) + " " + shq(path) + " 2>/dev/null"
    return to_string(exec(cmd))
}

fn file_exists_path(p: str) -> bool {
    // @allow-bare-exec
    let out = to_string(exec("test -e " + shq(p) + " && echo Y || echo N")).trim()
    return out == "Y"
}

fn str_to_i64(s: str) -> i64 {
    // hexa 에 to_i64/parse_int 없음 — 수동 디지트 파싱.
    if s.len() == 0 { return 0 }
    let mut n: i64 = 0
    let mut i = 0
    let mut neg = false
    if s.substring(0, 1) == "-" { neg = true; i = 1 }
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "0" { n = n * 10 }
        else if c == "1" { n = n * 10 + 1 }
        else if c == "2" { n = n * 10 + 2 }
        else if c == "3" { n = n * 10 + 3 }
        else if c == "4" { n = n * 10 + 4 }
        else if c == "5" { n = n * 10 + 5 }
        else if c == "6" { n = n * 10 + 6 }
        else if c == "7" { n = n * 10 + 7 }
        else if c == "8" { n = n * 10 + 8 }
        else if c == "9" { n = n * 10 + 9 }
        else { return n }
        i = i + 1
    }
    if neg { return 0 - n }
    return n
}

// run_py_exit removed — hexa-native replacements 아래에서 직접 처리.

// ─── 프로젝트 감지 ───────────────────────────────────────────────
// cwd basename 우선, 매핑 테이블 대조. 없으면 "nexus".

fn detect_project() -> str {
    let cwd = to_string(exec("pwd")).trim()  // @allow-bare-exec
    // cwd 끝부분 basename
    let parts = cwd.split("/")
    let base = if len(parts) > 0 { parts[len(parts) - 1] } else { "nexus" }
    let known = ["nexus", "anima", "anima-train", "CANON", "zeta-surpass", "millennium"]
    for k in known {
        if base == k { return k }
    }
    // shared/ 내부거나 미매칭 → nexus 기본
    return "nexus"
}

fn is_valid_project(p: str) -> bool {
    let known = ["nexus", "anima", "anima-train", "CANON", "zeta-surpass", "hive", "millennium"]
    for k in known {
        if p == k { return true }
    }
    return false
}

// ─── next: 다음 undone task 1개 ──────────────────────────────────

// next_project — hexa-native. 첫 번째 미완료 task 탐색.
// returns [body, exit_code_str]
fn next_project(project: str) -> [str] {
    let p = ROADMAPS + "/" + project + ".json"
    if file_exists_path(p) == false { return ["MISSING " + p, "2"] }
    // jq 로 phase+task 튜플을 순서대로 흘린다. DONE-status 는 필터링.
    // 필드는 newline/사용자 문자 모두 공백으로 치환 (gsub) + @@SEP@@ 로 조인.
    let strip = "(gsub(\"[\\\\n\\\\r\\\\t]\"; \" \"))"
    let q = "(.phases // []) | .[] as $ph | " +
            "if ([\"done\",\"complete\",\"aborted\",\"skipped\"] | index($ph.status // \"\")) then empty else " +
            "  (($ph.parallel // []) | .[] as $tr | ($tr.tasks // []) | .[] as $t | " +
            "    if ([\"done\",\"complete\",\"aborted\",\"skipped\"] | index($t.status // \"\")) then empty else " +
            "      [($ph.id//\"?\"), ($ph.status//\"?\"), (($ph.name//\"?\") | " + strip + "), ($tr.track//\"_\"), ($t.id//\"?\"), ($t.status//\"todo\"), ((($t.task // $t.name // \"?\") | " + strip + ")), (($t.artifact//\"\") | " + strip + "), (($t.ssot_ref//\"\") | " + strip + "), (($t.depends_on // []) | join(\",\"))] | join(\"@@SEP@@\") " +
            "    end), " +
            "  (($ph.tasks // []) | .[] as $t | " +
            "    if ([\"done\",\"complete\",\"aborted\",\"skipped\"] | index($t.status // \"\")) then empty else " +
            "      [($ph.id//\"?\"), ($ph.status//\"?\"), (($ph.name//\"?\") | " + strip + "), \"_\", ($t.id//\"?\"), ($t.status//\"todo\"), ((($t.task // $t.name // \"?\") | " + strip + ")), (($t.artifact//\"\") | " + strip + "), (($t.ssot_ref//\"\") | " + strip + "), (($t.depends_on // []) | join(\",\"))] | join(\"@@SEP@@\") " +
            "    end) " +
            "end"
    let raw = jq_raw(q, p)
    // 첫 non-empty 라인만 사용
    let lines = raw.split("\n")
    let mut first = ""
    for ln in lines {
        let t = ln.trim()
        if t.len() > 0 { first = t; break }
    }
    let proj_meta = jq("._meta.project // \"\"", p)
    let proj = if proj_meta.len() > 0 { proj_meta } else { project }
    if first.len() == 0 {
        // EXHAUSTED
        let n_ph = jq("(.phases // []) | length", p)
        let done_ph = jq("[(.phases // [])[] | select([\"done\",\"complete\",\"aborted\",\"skipped\"] | index(.status // \"\"))] | length", p)
        return ["EXHAUSTED " + proj + "  phases:" + done_ph + "/" + n_ph + " all-done", "42"]
    }
    let sep = "@@SEP@@"
    let parts = first.split(sep)
    // 10 fields expected
    let pid = parts[0]
    let pname = parts[2]
    let tr = parts[3]
    let tid = parts[4]
    let tst = parts[5]
    let mut tname = parts[6]
    if tname.len() > 90 { tname = tname.substring(0, 87) + "..." }
    let art = parts[7]
    let ssot = parts[8]
    let deps = parts[9]
    let mut body = "NEXT " + proj + "/" + pid + "/" + tr + "/" + tid + "  [" + tst + "]  " + tname
    body = body + "\n  phase: " + pname_trim(pname)
    // gate_exit: 짧은 요약만
    let gate_desc = jq("(.phases // []) | map(select(.id == \"" + pid + "\")) | .[0] | (.gate_exit | if type == \"string\" then . elif type == \"object\" then (.description // .summary // (. | tostring)) else \"\" end) // \"\"", p)
    if gate_desc.len() > 0 && gate_desc != "null" {
        let mut g = gate_desc
        if g.len() > 80 { g = g.substring(0, 80) }
        body = body + "\n  gate:  " + g
    }
    if art.len() > 0 { body = body + "\n  artifact: " + art }
    if ssot.len() > 0 { body = body + "\n  ssot:     " + ssot }
    if deps.len() > 0 { body = body + "\n  deps:     " + deps }
    return [body, "0"]
}

fn pname_trim(s: str) -> str {
    if s.len() > 80 { return s.substring(0, 80) }
    return s
}

fn run_next(project: str) -> i64 {
    let r = next_project(project)
    print(r[0])
    if r[0].len() > 0 { println("") }
    return str_to_i64(r[1])
}

// ─── extend: NEXUS 창발 seed → 새 phase append ───────────────────
// Emergence sources (우선순위):
//   1. shared/discovery/breakthroughs.jsonl  (최근 돌파 signal)
//   2. shared/bt/bt_keywords.jsonl           (돌파 키워드 풀)
//   3. shared/discovery/forge_cross_candidates.jsonl (forge 후보)
//   4. shared/blowup/core/blowup.hexa        (blowup 엔진 직접 호출, 30s timeout)
//   5. --force 시 템플릿 fallback

fn emergence_collect(project: str) -> str {
    // JSON payload 형식으로 모든 소스 집계 → python 에 전달
    let bt_kw = NEXUS + "/bt/bt_keywords.jsonl"
    let bt_path = NEXUS + "/discovery/breakthroughs.jsonl"
    let forge = NEXUS + "/discovery/forge_cross_candidates.jsonl"

    let mut payload = "{"
    // breakthroughs tail 10
    if file_exists(bt_path) {
        let out = to_string(exec("tail -10 " + bt_path + " 2>/dev/null"))  // @allow-bare-exec
        payload = payload + "\"breakthroughs\":" + json_quote(out) + ","
    } else {
        payload = payload + "\"breakthroughs\":\"\","
    }
    // bt_keywords all
    if file_exists(bt_kw) {
        let out = to_string(exec("cat " + bt_kw + " 2>/dev/null"))  // @allow-bare-exec
        payload = payload + "\"keywords\":" + json_quote(out) + ","
    } else {
        payload = payload + "\"keywords\":\"\","
    }
    // forge candidates — full pool (창발 고갈 모드: 2-domain 포함 전체)
    if file_exists(forge) {
        let out = to_string(exec("cat " + forge + " 2>/dev/null"))  // @allow-bare-exec
        payload = payload + "\"forge\":" + json_quote(out) + ","
    } else {
        payload = payload + "\"forge\":\"\","
    }
    // blowup 은 무거우므로 default off — 환경변수 NEXUS_ROADMAP_BLOWUP=1 일때만
    let use_blowup = env("NEXUS_ROADMAP_BLOWUP")
    if use_blowup == "1" {
        let blowup = NEXUS + "/cli/blowup/core/blowup.hexa"
        if file_exists(blowup) {
            let seed = "roadmap:" + project + ":next_phase"
            // @allow-bare-interp
            let cmd = "timeout 30 " + HEXA + " run " + blowup + " 2 \"" + seed + "\" 2>&1 | tail -30"
            let out = to_string(exec(cmd))  // @allow-bare-exec
            payload = payload + "\"blowup\":" + json_quote(out) + ","
        } else {
            payload = payload + "\"blowup\":\"\","
        }
    } else {
        payload = payload + "\"blowup\":\"\","
    }
    payload = payload + "\"project\":\"" + project + "\"}"
    return payload
}

fn json_quote(s: str) -> str {
    // minimal JSON string escape — python 파싱용
    let mut r = "\""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "\\" { r = r + "\\\\" }
        else if c == "\"" { r = r + "\\\"" }
        else if c == "\n" { r = r + "\\n" }
        else if c == "\r" { r = r + "\\r" }
        else if c == "\t" { r = r + "\\t" }
        else { r = r + c }
        i = i + 1
    }
    return r + "\""
}

fn run_extend_native(project: str, force: bool, dry: bool) -> i64 {
    // hexa-native extend: payload 수집 → 시드 후보 랭킹 → 새 phase JSON 구성 → jq append
    // 시드 소스: forge / keywords / breakthroughs / blowup(optional)
    let payload = emergence_collect(project)
    _py_seq = _py_seq + 1
    let payload_file = "/tmp/roadmap_payload_" + to_string(_py_seq) + ".json"
    let _ = write_file(payload_file, payload)
    let p = ROADMAPS + "/" + project + ".json"
    if file_exists_path(p) == false {
        eprintln("MISSING " + p)
        let _ = exec("rm -f " + shq(payload_file))  // @allow-bare-exec
        return 2
    }
    // 기존 phase 최대 번호 — "P<n>" 패턴
    let max_raw = jq("[(.phases // [])[] | .id // \"\" | capture(\"^P(?<n>[0-9]+)$\") | .n | tonumber] | max // -1", p)
    let max_n = str_to_i64(max_raw)
    let new_n = max_n + 1
    let new_id = "P" + to_string(new_n)
    // used seeds: 기존 phase name/task text 의 하위 토큰 + _emergence.seeds
    // 단순화: 기존 phase name 전부 lower-case 를 used 풀로 기록
    let used_raw = jq_raw("[(.phases // [])[] | (.name // \"\")] | join(\"\\n\")", p)
    let used_lc = used_raw.to_lower()
    // 시드 수집 — forge/keywords/breakthroughs lines 의 first 의미있는 token/name
    let mut candidates: [str] = []
    candidates = candidates + collect_json_names(payload, "forge", "name")
    candidates = candidates + collect_json_names(payload, "keywords", "keyword")
    candidates = candidates + collect_json_names(payload, "breakthroughs", "name")
    candidates = candidates + collect_json_names(payload, "breakthroughs", "keyword")
    candidates = candidates + collect_json_names(payload, "breakthroughs", "title")
    // dedup + used 필터
    let mut fresh: [str] = []
    let mut seen = ""
    for c in candidates {
        let c2 = c.trim()
        if c2.len() < 2 { continue }
        let key = c2.to_lower()
        let mark = "|" + key + "|"
        if seen.contains(mark) { continue }
        if used_lc.contains(key) { continue }
        seen = seen + mark
        fresh = fresh + [c2]
        if len(fresh) >= 6 { break }
    }
    if len(fresh) == 0 {
        if force == false {
            println("EMERGENCE_FAIL no candidates")
            let _ = exec("rm -f " + shq(payload_file))  // @allow-bare-exec
            return 1
        }
        let stamp = to_string(exec("date +%Y%m%d")).trim()  // @allow-bare-exec
        fresh = ["진화_" + stamp]
    }
    // phase name
    let mut theme = ""
    let mut i = 0
    while i < 3 && i < len(fresh) {
        if i > 0 { theme = theme + " + " }
        theme = theme + fresh[i]
        i = i + 1
    }
    if theme.len() > 60 { theme = theme.substring(0, 60) }
    let phase_name = "창발 진화 — " + theme
    // 트랙 — 기존 tracks 에서 keys, 없으면 기본 3종
    let tracks_raw = jq_raw("(.tracks // {}) | keys | .[0:3] | join(\",\")", p)
    let tracks_str = tracks_raw.trim()
    let mut tracks: [str] = []
    if tracks_str.len() > 0 {
        tracks = tracks_str.split(",")
    }
    if len(tracks) == 0 { tracks = ["DSE", "PAPER", "CHIP"] }
    // JSON 새 phase 빌드
    let mut parallel_json = "["
    let mut ti = 0
    while ti < len(tracks) && ti < 3 {
        let trk = tracks[ti]
        let mut tasks_json = "["
        // 시드 라운드로빈 배분
        let mut tj = 0
        let mut si = ti
        let mut si_count = 0
        while si < len(fresh) && si_count < 3 {
            let sname = fresh[si]
            let tid = trk + "-" + new_id + "-" + to_string(si_count + 1)
            if tj > 0 { tasks_json = tasks_json + "," }
            tasks_json = tasks_json + "{\"id\":\"" + tid + "\",\"task\":\"" + json_quote_inner(sname) + " (" + trk + " 트랙)\",\"status\":\"todo\"}"
            tj = tj + 1
            si_count = si_count + 1
            si = si + 3
        }
        if tj < 2 {
            if tj > 0 { tasks_json = tasks_json + "," }
            tasks_json = tasks_json + "{\"id\":\"" + trk + "-" + new_id + "-V\",\"task\":\"" + json_quote_inner(theme) + " (" + trk + ") — 검증/수렴\",\"status\":\"todo\"}"
        }
        tasks_json = tasks_json + "]"
        if ti > 0 { parallel_json = parallel_json + "," }
        parallel_json = parallel_json + "{\"track\":\"" + trk + "\",\"tasks\":" + tasks_json + "}"
        ti = ti + 1
    }
    parallel_json = parallel_json + "]"
    // seeds json array
    let mut seeds_json = "["
    let mut ki = 0
    while ki < len(fresh) && ki < 6 {
        if ki > 0 { seeds_json = seeds_json + "," }
        seeds_json = seeds_json + "\"" + json_quote_inner(fresh[ki]) + "\""
        ki = ki + 1
    }
    seeds_json = seeds_json + "]"
    let gen_at = to_string(exec("date +%Y-%m-%dT%H:%M:%S")).trim()  // @allow-bare-exec
    let new_phase = "{" +
        "\"id\":\"" + new_id + "\"," +
        "\"name\":\"" + json_quote_inner(phase_name) + "\"," +
        "\"duration_hours\":168," +
        "\"status\":\"planned\"," +
        "\"parallel\":" + parallel_json + "," +
        "\"gate_exit\":{\"criteria\":[\"" + json_quote_inner(theme) + " 완료 또는 정직한 장벽 기록\"],\"fail_action\":\"실패 항목 정직 기록 + 다음 phase로 이월\"}," +
        "\"_emergence\":{\"source\":[\"native\"],\"seeds\":" + seeds_json + ",\"generated_at\":\"" + gen_at + "\",\"tier\":\"native\",\"total_candidates\":" + to_string(len(fresh)) + "}" +
        "}"
    if dry {
        println("EXTEND_PLAN")
        println(new_phase)
        let _ = exec("rm -f " + shq(payload_file))  // @allow-bare-exec
        return 0
    }
    // 백업 + jq append
    let today = to_string(exec("date +%Y-%m-%d")).trim()  // @allow-bare-exec
    let stamp = to_string(exec("date +%Y%m%d_%H%M%S")).trim()  // @allow-bare-exec
    let bak = p + ".bak." + stamp
    let _ = exec("cp -p " + shq(p) + " " + shq(bak))  // @allow-bare-exec
    let tmp = p + ".tmp"
    let filter = ".phases = ((.phases // []) + [$np]) | (if has(\"_meta\") then ._meta.updated = $today else . end)"
    let cmd = "jq --argjson np " + shq(new_phase) + " --arg today " + shq(today) + " " + shq(filter) + " " + shq(p) + " > " + shq(tmp) + " && mv " + shq(tmp) + " " + shq(p) + " && echo OK || echo FAIL"
    let res = to_string(exec(cmd)).trim()  // @allow-bare-exec
    let _ = exec("rm -f " + shq(payload_file))  // @allow-bare-exec
    if res.ends_with("OK") == false {
        eprintln("extend jq rewrite failed: " + res)
        return 1
    }
    // total tasks count
    let mut total_tasks: i64 = 0
    let mut pi = 0
    while pi < len(tracks) && pi < 3 {
        total_tasks = total_tasks + 2  // 대략 (정확도 낮음)
        pi = pi + 1
    }
    println("EXTEND_OK " + project + " +" + new_id + " \"" + phase_name + "\" (" + to_string(len(fresh)) + " seeds, tier=native)")
    return 0
}

fn str_index_of(hay: str, needle: str) -> i64 {
    let nl = needle.len()
    let hl = hay.len()
    if nl == 0 { return 0 }
    if nl > hl { return -1 }
    let mut i: i64 = 0
    while i + nl <= hl {
        if hay.substring(i, i + nl) == needle { return i }
        i = i + 1
    }
    return -1
}

fn collect_json_names(payload: str, field: str, key: str) -> [str] {
    // payload 는 {"field":"<multiline text>", ...}
    // jq 로 field 값 꺼내기는 부담 → 간단 substring parse
    let tag = "\"" + field + "\":"
    let start = str_index_of(payload, tag)
    if start < 0 { return [] }
    let mut i = start + tag.len()
    // skip ws, expect opening "
    while i < payload.len() {
        let c = payload.substring(i, i + 1)
        if c == " " || c == "\t" { i = i + 1 } else { break }
    }
    if i >= payload.len() || payload.substring(i, i + 1) != "\"" { return [] }
    i = i + 1
    // read until unescaped closing "
    let mut body = ""
    while i < payload.len() {
        let c = payload.substring(i, i + 1)
        if c == "\\" {
            if i + 1 < payload.len() {
                let n = payload.substring(i + 1, i + 2)
                if n == "n" { body = body + "\n" }
                else if n == "r" { body = body + "\r" }
                else if n == "t" { body = body + "\t" }
                else if n == "\"" { body = body + "\"" }
                else if n == "\\" { body = body + "\\" }
                else { body = body + n }
                i = i + 2
                continue
            }
            i = i + 1
            continue
        }
        if c == "\"" { break }
        body = body + c
        i = i + 1
    }
    // 각 line 을 json decode 시도 → obj[key] 추출
    let lines = body.split("\n")
    let mut out: [str] = []
    for ln in lines {
        let t = ln.trim()
        if t.len() == 0 { continue }
        if t.starts_with("{") == false { continue }
        // key 추출: "<key>":"<value>"
        let needle = "\"" + key + "\""
        let ki = str_index_of(t, needle)
        if ki < 0 { continue }
        let mut j = ki + needle.len()
        while j < t.len() {
            let c = t.substring(j, j + 1)
            if c == " " || c == "\t" || c == ":" { j = j + 1 } else { break }
        }
        if j >= t.len() || t.substring(j, j + 1) != "\"" { continue }
        j = j + 1
        let vstart = j
        while j < t.len() {
            let c = t.substring(j, j + 1)
            if c == "\\" { j = j + 2; continue }
            if c == "\"" { break }
            j = j + 1
        }
        if j > vstart { out = out + [t.substring(vstart, j)] }
    }
    return out
}

fn json_quote_inner(s: str) -> str {
    // JSON string 내부 escape (quote 자체는 포함 안함)
    let mut r = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "\\" { r = r + "\\\\" }
        else if c == "\"" { r = r + "\\\"" }
        else if c == "\n" { r = r + "\\n" }
        else if c == "\r" { r = r + "\\r" }
        else if c == "\t" { r = r + "\\t" }
        else { r = r + c }
        i = i + 1
    }
    return r
}

fn run_extend(project: str, force: bool, dry: bool) -> i64 {
    return run_extend_native(project, force, dry)
}

// ─── gate_promote: task 전부 done인 phase 자동 complete 마킹 ────
// 핵심 하네스: phase 내 전 task가 done이면 phase를 "complete"로 승격.
// 이 함수가 없으면 roadmap이 "소진"을 감지 못해 다음 phase 생성 불가.
// 반환: 승격된 phase 수 (0이면 변동 없음)

// gate_promote — hexa-native. 전 task done 인 phase 를 complete 승격.
// jq 로 승격대상 phase id 찾기 → jq 필터로 atomic 재기록.
fn run_gate_promote(project: str) -> i64 {
    let p = ROADMAPS + "/" + project + ".json"
    if file_exists_path(p) == false {
        println("MISSING " + p)
        return 2
    }
    // DONE set = done|complete|aborted|skipped
    // 승격대상: phase 가 DONE 아니고, 모든 task(parallel + inline) 가 DONE.
    let q = "(.phases // []) | to_entries[] | " +
            "(.value) as $ph | " +
            "if ([\"done\",\"complete\",\"aborted\",\"skipped\"] | index($ph.status // \"\")) then empty else " +
            "  (((($ph.parallel // []) | map(.tasks // []) | add // [])) + ($ph.tasks // [])) as $all | " +
            "  if ($all | length) == 0 then empty " +
            "  elif (($all | map(select([\"done\",\"complete\",\"aborted\",\"skipped\"] | index(.status // \"todo\") | not))) | length) > 0 then empty " +
            "  else [($ph.id // \"?\"), ($ph.status // \"?\"), ($all | length | tostring)] | join(\"|\") " +
            "  end " +
            "end"
    let raw = jq_raw(q, p)
    let lines = raw.split("\n")
    let mut promoted_ids: [str] = []
    let mut promoted_count: i64 = 0
    for ln in lines {
        let t = ln.trim()
        if t.len() == 0 { continue }
        let parts = t.split("|")
        if len(parts) < 3 { continue }
        let pid = parts[0]; let old = parts[1]; let ntasks = parts[2]
        println("PROMOTE " + pid + " " + old + " -> complete (" + ntasks + " tasks)")
        promoted_ids = promoted_ids + [pid]
        promoted_count = promoted_count + 1
    }
    if promoted_count == 0 {
        println("GATE_PROMOTE_NOOP " + project + " — no phase ready for promotion")
        return 0
    }
    // 백업 + jq 재기록
    let today = to_string(exec("date +%Y-%m-%d")).trim()  // @allow-bare-exec
    let stamp = to_string(exec("date +%Y%m%d_%H%M%S")).trim()  // @allow-bare-exec
    let bak = p + ".bak." + stamp
    let _ = exec("cp -p " + shq(p) + " " + shq(bak))  // @allow-bare-exec
    // jq 필터: 대상 phase id 에 대해 status/completed_at/exit_note 세팅 + _meta.updated
    // ID 목록을 jq --argjson ids 로 주입
    let mut ids_json = "["
    let mut j = 0
    while j < len(promoted_ids) {
        if j > 0 { ids_json = ids_json + "," }
        ids_json = ids_json + "\"" + promoted_ids[j] + "\""
        j = j + 1
    }
    ids_json = ids_json + "]"
    let filter = ".phases = ((.phases // []) | map(" +
                 "if (.id // \"\") as $id | ($ids | index($id)) then " +
                 "  .status = \"complete\" | .completed_at = $today | " +
                 "  (if has(\"exit_note\") then . else " +
                 "    .exit_note = (\"gate_promote 자동: \" + " +
                 "      ((((.parallel // []) | map(.tasks // []) | add // []) + (.tasks // [])) | length | tostring) + " +
                 "      \" tasks 전수 done -> complete\") " +
                 "  end) " +
                 "else . end)) | " +
                 "(if has(\"_meta\") then ._meta.updated = $today else . end)"
    let tmp = p + ".tmp"
    let cmd = "jq --argjson ids " + shq(ids_json) + " --arg today " + shq(today) + " " + shq(filter) + " " + shq(p) + " > " + shq(tmp) + " && mv " + shq(tmp) + " " + shq(p) + " && echo OK || echo FAIL"
    let result = to_string(exec(cmd)).trim()  // @allow-bare-exec
    if result.ends_with("OK") == false {
        eprintln("gate_promote jq rewrite failed: " + result)
        return 1
    }
    println("GATE_PROMOTE_OK " + project + " +" + to_string(promoted_count) + " phases promoted")
    return 0
}

// ─── auto: next; 소진 시 extend → next ──────────────────────────
// 수정: gate_promote 를 먼저 실행하여 완료된 phase 를 자동 승격한 뒤
//       next → 소진이면 extend → next 재시도

// ─── L0 roadmap sync gate (post-modify) ─────────────────────────
fn force_roadmap_sync() {
    let gate = HARNESS + "/roadmap_sync_gate.hexa"
    if file_exists(gate) == false { return }
    let _ = exec(HEXA + " run " + gate + " 2>&1")  // @allow-bare-exec
}

fn run_auto(project: str, force: bool) -> i64 {
    // step 0: gate_promote — 전 task done인 phase 자동 complete
    let gp = run_gate_promote(project)
    if gp != 0 {
        eprintln("[warn] gate_promote exit " + to_string(gp) + " — 계속 진행")
    }
    // step 1: next
    let rc = run_next(project)
    if rc == 0 { return 0 }
    if rc != 42 { return rc }
    // step 2: 소진 → extend (창발)
    println("--- roadmap 소진 감지 → NEXUS 창발 extend ---")
    let ext = run_extend(project, force, false)
    if ext != 0 { return ext }
    force_roadmap_sync()  // extend 후 즉시 sync
    // step 3: 새 phase 추가됨 → next 재시도
    println("--- 새 phase 추가됨 → next 재시도 ---")
    return run_next(project)
}

// ─── list: 전 프로젝트 next 요약 ────────────────────────────────

fn run_list() -> i64 {
    let projects = ["nexus", "anima", "anima-train", "CANON", "zeta-surpass", "hive", "millennium"]
    println("=== roadmap list (7 projects) ===")
    for p in projects {
        let r = next_project(p)
        let code = r[1]
        let first_line = r[0].split("\n")[0]
        let pad = pad_right(p, 18)
        if code == "42" {
            println("  " + pad + " EXHAUSTED — extend 필요")
        } else if code == "0" {
            println("  " + pad + " " + first_line)
        } else if code == "2" {
            println("  " + pad + " MISSING roadmap file")
        } else {
            println("  " + pad + " ERROR (exit " + code + ")")
        }
    }
    return 0
}

fn pad_right(s: str, n: i64) -> str {
    let mut r = s
    while r.len() < n { r = r + " " }
    return r
}

// ─── delegate: verify|status|artifacts|crossref|all → roadmap_guard ──

fn delegate_guard(rest: [str]) -> i64 {
    let guard_path = HARNESS + "/roadmap_guard.hexa"
    if file_exists(guard_path) == false {
        eprintln("roadmap_guard.hexa not found: " + guard_path)
        return 2
    }
    let mut cmd = HEXA + " run " + guard_path
    for a in rest { cmd = cmd + " \"" + a.replace("\"", "\\\"") + "\"" }
    // @allow-bare-interp
    let out = to_string(exec(cmd + "; echo \"EXIT:$?\""))  // @allow-bare-exec
    let lines = out.split("\n")
    let mut body = ""
    let mut code = "0"
    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        if line.starts_with("EXIT:") {
            code = line.substring(5, len(line)).trim()
        } else {
            if body.len() > 0 { body = body + "\n" }
            body = body + line
        }
        i = i + 1
    }
    print(body)
    return str_to_i64(code)
}

// ─── CLI entry ───────────────────────────────────────────────────

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only a[2] 가정 → Linux 에서 a[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut a: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        a = a + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && a.len() >= 3 {
        if a[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < a.len() {
                _a2 = _a2 + [a[_j2]]
                _j2 = _j2 + 1
            }
            a = _a2
        }
    }
    // roadmap_guard.hexa 와 동일: a[2] 부터 subcommand
    if len(a) < 3 {
        let proj = detect_project()
        exit(run_auto(proj, false))
    }

    let cmd = a[2]

    // flags 파싱
    let mut project = ""
    let mut force = false
    let mut dry = false
    let mut i = 3
    while i < len(a) {
        if a[i] == "--project" {
            if i + 1 < len(a) { project = a[i+1] }
            i = i + 2
        } else if a[i] == "--force" {
            force = true
            i = i + 1
        } else if a[i] == "--dry" || a[i] == "--dry-run" {
            dry = true
            i = i + 1
        } else {
            i = i + 1
        }
    }

    if project.len() == 0 {
        project = detect_project()
    } else if is_valid_project(project) == false {
        eprintln("invalid --project: " + project)
        exit(2)
    }

    if cmd == "next" {
        exit(run_next(project))
    } else if cmd == "extend" {
        exit(run_extend(project, force, dry))
    } else if cmd == "auto" {
        exit(run_auto(project, force))
    } else if cmd == "list" {
        exit(run_list())
    } else if cmd == "status" || cmd == "verify" || cmd == "artifacts" || cmd == "crossref" || cmd == "all" {
        // 원본 인자 그대로 guard 로 전달 (--project 포함)
        let mut rest: [str] = [cmd]
        let mut j = 3
        while j < len(a) {
            rest = rest + [a[j]]
            j = j + 1
        }
        exit(delegate_guard(rest))
    } else if cmd == "help" || cmd == "--help" || cmd == "-h" {
        print_usage()
        exit(0)
    } else if cmd == "sync" {
        // 수동 sync 트리거 (디버그/강제용)
        force_roadmap_sync()
        println("[roadmap] sync complete")
        exit(0)
    } else {
        eprintln("unknown subcommand: " + cmd)
        print_usage()
        exit(2)
    }
}

main()
