#!hexa strict
// tool/atlas_shard_scope_lint.hexa — RCA §4.3 implementation
//
// @tool(slug="atlas_shard_scope_lint", desc="Per-shard header lint — every atlas.append.*.n6 shard should declare which corpus roots it scanned. Verdicts: PASS (>=3 known roots OR `lint-exempt:` opt-out) / WARN (no scope OR 1-2 roots) / FAIL (claims n6-arch origin AND lists 0 known roots) / WARN_EXPERIMENTS_BLINDSPOT (recent + claims n6-arch but no experiments/ root).")
// @usage(hexa run tool/atlas_shard_scope_lint.hexa [--strict] [--summary-only] [--self-test])
// @exit_codes(0=PASS, 1=usage/io, 2=self-test failure, 3=--strict and at least one FAIL)
// @sentinel(__ATLAS_SHARD_SCOPE_LINT__ PASS scanned=N pass=A warn=B fail=C blindspot=D)
// @origin(state/absorption_miss_rca_2026-04-27.md §4.3)
// @paradigm(structural — header lint over append shards, encourages explicit scope declaration)
// @allow-bare-exec

// ─── helpers ───────────────────────────────────────────────────

fn dir_exists(p: string) -> bool {
    let out = to_string(exec("test -d '" + p + "' && echo y || echo n")).trim()
    if out == "y" { return true }
    return false
}

fn file_exists_safe(p: string) -> bool {
    let out = to_string(exec("test -f '" + p + "' && echo y || echo n")).trim()
    if out == "y" { return true }
    return false
}

fn _core_root() -> string {
    let override = env_var("NEXUS_CORE_ROOT")
    if len(override) > 0 && dir_exists(override) { return override }
    return env_var("HOME") + "/core"
}

fn _n6arch_root() -> string {
    let r = _core_root()
    if dir_exists(r + "/canon") { return r + "/canon" }
    if dir_exists(r + "/n6-architecture") { return r + "/n6-architecture" }  // legacy
    if dir_exists(r + "/n6-arch") { return r + "/n6-arch" }
    return r + "/canon"
}

fn _shard_dir() -> string {
    return _core_root() + "/nexus/n6"
}

fn _known_roots() -> array {
    return [
        "papers/",
        "reports/",
        "domains/",
        "design/",
        "docs/",
        "experiments/",
        "tool/",
        "bridge/",
        "n6shared/",
        "atlas/"
    ]
}

// list shards
fn _list_shards() -> array {
    let cmd = "ls -1 '" + _shard_dir() + "'/atlas.append.*.n6 2>/dev/null | sort"
    let out = to_string(exec(cmd)).trim()
    if len(out) == 0 { return [] }
    return out.split("\n")
}

// read first N lines (returns string)
fn _read_head(path: string, n: int) -> string {
    let cmd = "head -n " + to_string(n) + " '" + path + "' 2>/dev/null"
    return to_string(exec(cmd))
}

// scan shard header for known-root mentions (substring search)
fn _detected_roots(header: string) -> array {
    let known = _known_roots()
    let mut hits = []
    let mut i = 0
    while i < len(known) {
        if header.index_of(known[i]) >= 0 { hits.push(known[i]) }
        i = i + 1
    }
    return hits
}

// detect lint-exempt: opt-out
fn _is_exempt(header: string) -> bool {
    if header.index_of("lint-exempt:") >= 0 { return true }
    if header.index_of("scope-lint-exempt") >= 0 { return true }
    return false
}

// detect "claims n6-arch origin"
fn _claims_n6arch(header: string) -> bool {
    if header.index_of("n6-architecture") >= 0 { return true }
    if header.index_of("n6-arch") >= 0 { return true }
    if header.index_of("/core/n6-architecture") >= 0 { return true }
    return false
}

// detect "scope" keyword presence
fn _mentions_scope(header: string) -> bool {
    if header.index_of("Scope") >= 0 { return true }
    if header.index_of("scope:") >= 0 { return true }
    if header.index_of("Sources:") >= 0 { return true }
    if header.index_of("sources:") >= 0 { return true }
    if header.index_of("Source:") >= 0 { return true }
    return false
}

// pull yyyy-mm-dd date out of shard filename (basename atlas.append.*-yyyy-mm-dd.n6)
// or from the header content itself.
fn _shard_date(path: string, header: string) -> string {
    // try filename first: look for "-2026-04-27" style suffix
    let cmd = "basename '" + path + "' | grep -oE '20[0-9]{2}-[0-9]{2}-[0-9]{2}' | tail -1"
    let out = to_string(exec(cmd)).trim()
    if len(out) >= 10 { return out.substring(0, 10) }
    // fallback to header
    let cmd2 = "printf '%s' " + _shell_quote(header) + " | grep -oE '20[0-9]{2}-[0-9]{2}-[0-9]{2}' | head -1"
    let out2 = to_string(exec(cmd2)).trim()
    if len(out2) >= 10 { return out2.substring(0, 10) }
    return ""
}

fn _shell_quote(s: string) -> string {
    let r = s.replace("'", "'\\''")
    return "'" + r + "'"
}

// detect recent n6-arch experiments/ activity (mtime within ±7d of date)
// Implementation: see if any file under experiments/ has mtime within 7 days of date.
// Cheap version: check if experiments/ has been touched within 7 days of TODAY when shard date is within 7d of today.
fn _experiments_recently_active(shard_date: string) -> bool {
    if len(shard_date) < 10 { return false }
    let repo = _n6arch_root()
    let exp = repo + "/experiments"
    if !dir_exists(exp) { return false }
    // Compare shard_date to each file's mtime in experiments/. We approximate by:
    // any file under experiments/ with mtime difference (in days) ≤ 7.
    // shard_date is yyyy-mm-dd; we compute its epoch via `date -j -f`
    // and then `find ... -newermt ... -not -newermt ...` for ±7d window.
    let lo = to_string(exec("date -u -j -v-7d -f '%Y-%m-%d' '" + shard_date + "' +'%Y-%m-%d' 2>/dev/null")).trim()
    let hi = to_string(exec("date -u -j -v+7d -f '%Y-%m-%d' '" + shard_date + "' +'%Y-%m-%d' 2>/dev/null")).trim()
    if len(lo) == 0 || len(hi) == 0 { return false }
    let cmd = "find '" + exp + "' -type f -newermt '" + lo + "' ! -newermt '" + hi + "' 2>/dev/null | head -1"
    let out = to_string(exec(cmd)).trim()
    if len(out) > 0 { return true }
    return false
}

// ─── verdict ──────────────────────────────────────────────────

fn _verdict(header: string, has_experiments: bool, claims_n6arch: bool, recent_exp: bool, n_roots: int, exempt: bool, has_scope: bool) -> string {
    if exempt { return "PASS" }
    if claims_n6arch && n_roots == 0 { return "FAIL" }
    if !has_scope && n_roots == 0 { return "WARN" }
    if n_roots >= 3 {
        // PASS but check experiments blindspot
        if claims_n6arch && recent_exp && !has_experiments { return "WARN_EXPERIMENTS_BLINDSPOT" }
        return "PASS"
    }
    // 1-2 roots
    if claims_n6arch && recent_exp && !has_experiments { return "WARN_EXPERIMENTS_BLINDSPOT" }
    return "WARN"
}

// ─── self-test ────────────────────────────────────────────────

fn _run_self_test() {
    let tdir = "/tmp/atlas_shard_scope_test"
    exec("rm -rf '" + tdir + "'")
    exec("mkdir -p '" + tdir + "'")
    // fixture 1: noscope
    let f1 = tdir + "/atlas.append.fixture-noscope.n6"
    write_file(f1, "// ═══════════════════════════════════════════════════════════════\n// atlas.append.fixture-noscope.n6\n//   Random absorption shard with no Scope/Sources block.\n//\n// @F foo = bar :: x [7]\n")
    // fixture 2: zeroroots — claims n6-arch, lists no known roots
    let f2 = tdir + "/atlas.append.fixture-zeroroots-2026-04-27.n6"
    write_file(f2, "// atlas.append.fixture-zeroroots.n6\n//   Sources: ~/core/n6-architecture (read-only, this session)\n//     <no enumerated roots>\n//\n// Date: 2026-04-27\n")
    // fixture 3: good — Scope + 3 roots
    let f3 = tdir + "/atlas.append.fixture-good-2026-04-27.n6"
    write_file(f3, "// atlas.append.fixture-good.n6\n//   Sources (n6-architecture):\n//     papers/foo.md\n//     experiments/anu_mc_verification/\n//     reports/sessions/bar.md\n//     docs/baz.md\n//\n// Date: 2026-04-27\n")
    // fixture 4: exempt — explicit lint-exempt:
    let f4 = tdir + "/atlas.append.fixture-exempt.n6"
    write_file(f4, "// atlas.append.fixture-exempt.n6\n// lint-exempt: bridge-only patch, no corpus scope\n//\n// @F bar = baz :: x [7]\n")

    let fixtures = [
        [f1, "WARN", "noscope"],
        [f2, "FAIL", "zeroroots"],
        [f3, "PASS", "good"],
        [f4, "PASS", "exempt"]
    ]

    let mut pass_total = 0
    let mut i = 0
    while i < len(fixtures) {
        let row = fixtures[i]
        let path = row[0]
        let expected = row[1]
        let label = row[2]
        let header = _read_head(path, 100)
        let roots = _detected_roots(header)
        let has_exp = _has_experiments_root(roots)
        let claims = _claims_n6arch(header)
        let exempt = _is_exempt(header)
        let has_scope = _mentions_scope(header)
        // for self-test we don't probe real n6-arch experiments dir mtimes; force false
        let v = _verdict(header, has_exp, claims, false, len(roots), exempt, has_scope)
        let ok = if v == expected { "OK" } else { "FAIL(got=" + v + ")" }
        println("  fixture " + label + " : expected=" + expected + " got=" + v + " " + ok)
        if v == expected { pass_total = pass_total + 1 }
        i = i + 1
    }

    exec("rm -rf '" + tdir + "'")

    println("=== atlas_shard_scope_lint --self-test ===")
    println("  fixtures passed  : " + to_string(pass_total) + "/" + to_string(len(fixtures)))
    if pass_total == len(fixtures) {
        println("__ATLAS_SHARD_SCOPE_LINT_SELFTEST__ PASS")
        exit(0)
    }
    println("__ATLAS_SHARD_SCOPE_LINT_SELFTEST__ FAIL")
    exit(2)
}

fn _has_experiments_root(roots: array) -> bool {
    let mut i = 0
    while i < len(roots) {
        if roots[i] == "experiments/" { return true }
        i = i + 1
    }
    return false
}

// ─── main ─────────────────────────────────────────────────────

fn _print_help() {
    println("usage: hexa run tool/atlas_shard_scope_lint.hexa [--strict] [--summary-only] [--self-test]")
    println("modes:")
    println("  (default)        per-shard report (verdict + roots)")
    println("  --strict         exit 3 if any FAIL")
    println("  --summary-only   just the totals + sentinel line")
    println("  --self-test      synthesize 4 fixtures, verify verdict semantics")
    println("origin: state/absorption_miss_rca_2026-04-27.md §4.3")
    println("verdicts: PASS / WARN / FAIL / WARN_EXPERIMENTS_BLINDSPOT")
    println("sentinel: __ATLAS_SHARD_SCOPE_LINT__ PASS scanned=N pass=A warn=B fail=C blindspot=D")
}

fn main() -> void {
    let raw_args = args()
    let mut cli = []
    let mut ai = 2
    while ai < len(raw_args) {
        cli.push(raw_args[ai])
        ai = ai + 1
    }
    let mut strict = false
    let mut summary_only = false
    let mut self_test = false
    let mut i = 0
    while i < len(cli) {
        let a = cli[i]
        if a == "--self-test" || a == "--selftest" { self_test = true }
        else if a == "--strict" { strict = true }
        else if a == "--summary-only" { summary_only = true }
        else if a == "--help" || a == "-h" { _print_help(); exit(0) }
        else {
            eprintln("atlas_shard_scope_lint: unknown arg `" + a + "`")
            exit(1)
        }
        i = i + 1
    }

    if self_test { _run_self_test() }

    let shards = _list_shards()
    if len(shards) == 0 {
        eprintln("__ATLAS_SHARD_SCOPE_LINT__ FAIL no shards under " + _shard_dir())
        exit(1)
    }

    let mut n_pass = 0
    let mut n_warn = 0
    let mut n_fail = 0
    let mut n_blind = 0
    let mut details = []
    let mut s = 0
    while s < len(shards) {
        let path = shards[s]
        let header = _read_head(path, 100)
        let roots = _detected_roots(header)
        let has_exp = _has_experiments_root(roots)
        let claims = _claims_n6arch(header)
        let exempt = _is_exempt(header)
        let has_scope = _mentions_scope(header)
        let date = _shard_date(path, header)
        let recent = if claims && len(date) > 0 { _experiments_recently_active(date) } else { false }
        let v = _verdict(header, has_exp, claims, recent, len(roots), exempt, has_scope)
        if v == "PASS" { n_pass = n_pass + 1 }
        else if v == "WARN" { n_warn = n_warn + 1 }
        else if v == "FAIL" { n_fail = n_fail + 1 }
        else if v == "WARN_EXPERIMENTS_BLINDSPOT" { n_blind = n_blind + 1 }
        details.push([path, v, to_string(len(roots)), date])
        s = s + 1
    }

    println("=== atlas_shard_scope_lint ===")
    println("  shard dir        : " + _shard_dir())
    println("  scanned          : " + to_string(len(shards)))
    println("  PASS             : " + to_string(n_pass))
    println("  WARN             : " + to_string(n_warn))
    println("  FAIL             : " + to_string(n_fail))
    println("  BLINDSPOT        : " + to_string(n_blind))
    println("")

    if !summary_only {
        let mut k = 0
        while k < len(details) {
            let row = details[k]
            // basename of path for display
            let bn = to_string(exec("basename '" + row[0] + "'")).trim()
            println("  " + row[1] + "  roots=" + row[2] + "  date=" + row[3] + "  " + bn)
            k = k + 1
        }
        println("")
    }

    println("__ATLAS_SHARD_SCOPE_LINT__ PASS scanned=" + to_string(len(shards)) + " pass=" + to_string(n_pass) + " warn=" + to_string(n_warn) + " fail=" + to_string(n_fail) + " blindspot=" + to_string(n_blind))

    if strict && n_fail > 0 { exit(3) }
    exit(0)
}
