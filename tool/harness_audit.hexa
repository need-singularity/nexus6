// @enforce-sandbox  — H-ENFORCE-SANDBOX: 하네스 전체 audit scan (7 카테고리)
// @no-lock-needed
// @allow-bare-exec
// harness_audit.hexa — 하네스 스코어카드 (7 카테고리 × 0-10, max total=70)
// 역할: 하네스 건강도 정량 평가. 매 실행 시 JSONL append + 요약 stdout.
// SSOT: shared/tool/harness_score.jsonl (append-only)
//
// usage:
//   hexa run shared/tool/harness_audit.hexa                — 전체 실행 + JSONL append + 요약
//   hexa run shared/tool/harness_audit.hexa json           — JSON 한 줄 stdout
//   hexa run shared/tool/harness_audit.hexa summary        — 총점 한 줄
//
// 7 카테고리:
//   tool_coverage  entry.hexa mode 수 ÷ 16 × 10
//   context_eff    CLAUDE.md 라인 수 밴드
//   quality_gate   lint_log.jsonl tail 200 fail 비율
//   memory         handoff-latest.md mtime 밴드
//   eval           mistakes.jsonl 200 vs rules_usage total 비율
//   security       permissions_ssot.json deny 배열 길이
//   cost           work_registry.jsonl tail 500 평균 수명
//
// 성공 조용 X — 이 모듈은 본래 스코어 출력이 목적이므로 항상 출력.

import "safe_hexa_enforce.hexa"

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let HARNESS = NEXUS + "/harness"
let SCORE = HARNESS + "/harness_score.jsonl"

let ENTRY = HARNESS + "/entry.hexa"
let ROOT_CLAUDE = NEXUS + "/CLAUDE.md"
let LINT_LOG = HARNESS + "/lint_log.jsonl"
let HANDOFF = HOME + "/.claude-claude1/projects/-Users-ghost-Dev-nexus/memory/handoff-latest.md"
let MISTAKES = HARNESS + "/mistakes.jsonl"
let RULES_USAGE = HARNESS + "/rules_usage.jsonl"
let PERM_SSOT = NEXUS + "/config/permissions_ssot.json"
let WORK_REG = HARNESS + "/work_registry.jsonl"

// ─── void-safe helpers (hexa stage1 pitfalls 방어) ───
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    return to_int(first)
}

fn now_unix() -> i64 {
    return _to_int0(_str(exec("date +%s")).trim())  // @allow-bare-exec
}

fn iso_now() -> string {
    return _str(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()  // @allow-bare-exec
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", " ")
    r = r.replace("\r", " ")
    r = r.replace("\t", " ")
    return r
}

// ─── 카테고리 1: tool_coverage ───
// entry.hexa 의 `else if mode ==` + 첫 `if mode ==` 카운트
fn score_tool_coverage() -> i64 {
    if file_exists(ENTRY) == false { return 0 }
    let n = _to_int0(_str(exec("grep -cE 'mode == \"[a-z_]+\"' '" + ENTRY + "' 2>/dev/null")).trim())  // @allow-bare-exec
    // 16 모드 기준 정규화 → 0~10 (초과 cap)
    let mut s: i64 = (n * 10) / 16
    if s > 10 { s = 10 }
    if s < 0 { s = 0 }
    return s
}

// ─── 카테고리 2: context_eff ───
// root CLAUDE.md 라인 수 밴드
fn score_context_eff() -> i64 {
    if file_exists(ROOT_CLAUDE) == false { return 0 }
    let lines = _to_int0(_str(exec("wc -l < '" + ROOT_CLAUDE + "' 2>/dev/null")).trim())  // @allow-bare-exec
    if lines <= 100 { return 10 }
    if lines <= 200 { return 8 }
    if lines <= 300 { return 6 }
    if lines <= 400 { return 4 }
    return 2
}

// ─── 카테고리 3: quality_gate ───
// lint_log.jsonl tail 200 중 "status":"fail" OR "ok":false 비율
fn score_quality_gate() -> i64 {
    if file_exists(LINT_LOG) == false { return 5 }
    let total = _to_int0(_str(exec("tail -200 '" + LINT_LOG + "' 2>/dev/null | wc -l")).trim())  // @allow-bare-exec
    if total == 0 { return 10 }
    let fails = _to_int0(_str(exec("tail -200 '" + LINT_LOG + "' 2>/dev/null | grep -cE '\"status\":\"fail\"|\"ok\":false|\"pass\":false' 2>/dev/null")).trim())  // @allow-bare-exec
    let pct = (fails * 100) / total
    if pct <= 5 { return 10 }
    if pct <= 10 { return 8 }
    if pct <= 20 { return 6 }
    if pct <= 40 { return 4 }
    return 2
}

// ─── 카테고리 4: memory ───
// handoff-latest.md mtime 밴드 (세컨드 단위)
fn score_memory() -> i64 {
    if file_exists(HANDOFF) == false { return 0 }
    let mt = _to_int0(_str(exec("stat -f %m '" + HANDOFF + "' 2>/dev/null || stat -c %Y '" + HANDOFF + "' 2>/dev/null")).trim())  // @allow-bare-exec
    if mt == 0 { return 0 }
    let age = now_unix() - mt
    if age <= 86400 { return 10 }           // 24h
    if age <= 259200 { return 8 }           // 72h
    if age <= 604800 { return 6 }           // 7d
    if age <= 2592000 { return 4 }          // 30d
    return 2
}

// ─── 카테고리 5: eval ───
// mistakes.jsonl tail 200 vs rules_usage total hits
fn score_eval() -> i64 {
    let mistakes_n = _to_int0(_str(exec("tail -200 '" + MISTAKES + "' 2>/dev/null | wc -l")).trim())  // @allow-bare-exec
    if mistakes_n == 0 { return 10 }
    // rules_usage total = sum of "total" fields (간단화: 라인 수 * avg, 여기서는 라인 수 기준)
    let rules_n = _to_int0(_str(exec("wc -l < '" + RULES_USAGE + "' 2>/dev/null")).trim())  // @allow-bare-exec
    if rules_n == 0 {
        // 분모 없으면 중립
        return 5
    }
    let pct = (mistakes_n * 100) / (mistakes_n + rules_n)
    if pct <= 5 { return 10 }
    if pct <= 10 { return 8 }
    if pct <= 20 { return 6 }
    if pct <= 40 { return 4 }
    return 2
}

// ─── 카테고리 6: security ───
// permissions_ssot.json deny 배열 길이 (build_deny_array)
fn score_security() -> i64 {
    if file_exists(PERM_SSOT) == false { return 0 }
    // jq 선호, fallback grep
    let mut n = _to_int0(_str(exec("jq '.build_deny_array | length' '" + PERM_SSOT + "' 2>/dev/null")).trim())  // @allow-bare-exec
    if n == 0 {
        // fallback: build_deny_array 블록 내 따옴표로 시작하는 라인 카운트
        n = _to_int0(_str(exec("awk '/\"build_deny_array\"/,/^  \\]/' '" + PERM_SSOT + "' 2>/dev/null | grep -cE '^    \"' 2>/dev/null")).trim())  // @allow-bare-exec
    }
    if n >= 28 { return 10 }
    if n >= 20 { return 8 }
    if n >= 10 { return 6 }
    if n >= 5 { return 4 }
    return 2
}

// ─── 카테고리 7: cost ───
// work_registry.jsonl tail 500 중 완료된 agent 평균 (ts_end - ts_start)
fn score_cost() -> i64 {
    if file_exists(WORK_REG) == false { return 5 }
    // awk 로 status=done 이고 ts_end not null 인 라인만, avg 계산
    let awk_cmd = "tail -500 '" + WORK_REG + "' 2>/dev/null | " +
                  "awk '/\"status\":\"done\"/ {" +
                  " if (match($0,/\"ts_start\":[0-9]+/)){ s=substr($0,RSTART+12,RLENGTH-12) } else { next }" +
                  " if (match($0,/\"ts_end\":[0-9]+/)){ e=substr($0,RSTART+10,RLENGTH-10) } else { next }" +
                  " d=e-s; if(d>=0){ sum+=d; n++ } }" +
                  " END { if(n>0) printf \"%d\\n\", sum/n; else print \"-1\" }'"
    let avg_str = _str(exec(awk_cmd)).trim()  // @allow-bare-exec
    let avg = _to_int0(avg_str)
    // 완료 없음 → 중립 5 (활성만 있는 경우)
    if avg_str == "-1" || avg_str == "" { return 5 }
    if avg <= 10 { return 10 }
    if avg <= 60 { return 8 }
    if avg <= 300 { return 6 }
    if avg <= 1800 { return 4 }
    return 2
}

// ─── 실행 + 집계 ───
fn compute_all() -> [i64] {
    let s_tool = score_tool_coverage()
    let s_ctx  = score_context_eff()
    let s_qg   = score_quality_gate()
    let s_mem  = score_memory()
    let s_eval = score_eval()
    let s_sec  = score_security()
    let s_cost = score_cost()
    return [s_tool, s_ctx, s_qg, s_mem, s_eval, s_sec, s_cost]
}

fn sum_scores(sc: [i64]) -> i64 {
    let mut t: i64 = 0
    for v in sc { t = t + v }
    return t
}

fn flags_below_6(sc: [i64]) -> [string] {
    let names = ["tool_coverage", "context_eff", "quality_gate", "memory", "eval", "security", "cost"]
    let mut flags = []
    let mut i = 0
    while i < sc.len() {
        if sc[i] < 6 {
            // R0 pass-by-value 우회 — xs = xs + [v]
            flags = flags + [names[i] + "<6"]
        }
        i = i + 1
    }
    return flags
}

fn to_json(sc: [i64], total: i64, flags: [string]) -> string {
    let ts = iso_now()
    let mut flags_str = "["
    let mut first = true
    for f in flags {
        if first == false { flags_str = flags_str + "," }
        flags_str = flags_str + "\"" + json_escape(f) + "\""
        first = false
    }
    flags_str = flags_str + "]"
    let json = "{\"ts\":\"" + ts + "\"," +
               "\"scores\":{" +
               "\"tool_coverage\":" + to_string(sc[0]) + "," +
               "\"context_eff\":" + to_string(sc[1]) + "," +
               "\"quality_gate\":" + to_string(sc[2]) + "," +
               "\"memory\":" + to_string(sc[3]) + "," +
               "\"eval\":" + to_string(sc[4]) + "," +
               "\"security\":" + to_string(sc[5]) + "," +
               "\"cost\":" + to_string(sc[6]) + "}," +
               "\"total\":" + to_string(total) + "," +
               "\"flags\":" + flags_str + "}"
    return json
}

fn format_summary(sc: [i64], total: i64, flags: [string]) -> string {
    let mut line = "harness_audit: "
    line = line + "tool=" + to_string(sc[0]) + " "
    line = line + "ctx=" + to_string(sc[1]) + " "
    line = line + "qg=" + to_string(sc[2]) + " "
    line = line + "mem=" + to_string(sc[3]) + " "
    line = line + "eval=" + to_string(sc[4]) + " "
    line = line + "sec=" + to_string(sc[5]) + " "
    line = line + "cost=" + to_string(sc[6])
    line = line + "  total=" + to_string(total) + "/70"
    if flags.len() > 0 {
        let mut f_str = ""
        let mut first = true
        for f in flags {
            if first == false { f_str = f_str + ", " }
            f_str = f_str + f
            first = false
        }
        line = line + "\nflags: " + f_str
    }
    return line
}

// ─── 모드 분기 ───
fn cmd_full() {
    let sc = compute_all()
    let total = sum_scores(sc)
    let flags = flags_below_6(sc)
    let json = to_json(sc, total, flags)
    try { append_file(SCORE, json + "\n") } catch e {
        eprintln("FAIL: append_file 실패 — " + SCORE)
    }
    println(format_summary(sc, total, flags))
}

fn cmd_json() {
    let sc = compute_all()
    let total = sum_scores(sc)
    let flags = flags_below_6(sc)
    println(to_json(sc, total, flags))
}

fn cmd_summary() {
    let sc = compute_all()
    let total = sum_scores(sc)
    let flags = flags_below_6(sc)
    println(format_summary(sc, total, flags))
}

fn main() {
    ensure_launchd_sandbox()
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    let mut mode = "full"
    if argv.len() >= 3 {
        mode = argv[2].trim()
        if mode == "" { mode = "full" }
    }
    if mode == "full" { cmd_full() }
    else if mode == "json" { cmd_json() }
    else if mode == "summary" { cmd_summary() }
    else {
        eprintln("usage: harness_audit.hexa [full|json|summary]")
    }
}

main()
