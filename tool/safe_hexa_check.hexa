// safe_hexa_check.hexa — CLI wrapper for safe_hexa_enforce 라이브러리
// @no-lock-needed
//
// 사용:
//   hexa run safe_hexa_check.hexa check         # exit 0:sandbox OK, 1:raw (무방비)
//   hexa run safe_hexa_check.hexa ensure        # SAFE_HEXA_MODE 에 따라 warn 또는 exit 9
//   hexa run safe_hexa_check.hexa breaches [N]  # 최근 N (default 10) breach jsonl 조회
//   hexa run safe_hexa_check.hexa stats         # 전체 breach 카운트 + mode/script 집계

import "safe_hexa_enforce.hexa"

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    let mut action = "check"
    if argv.len() > 2 { action = argv[2] }

    if action == "check" {
        if _in_launchd_sandbox() {
            println("OK: inside launchd sandbox")
            exit(0)
        }
        println("WARN: outside launchd sandbox (raw hexa — jetsam=180)")
        exit(1)
    }

    if action == "ensure" {
        ensure_launchd_sandbox()
        println("OK")
        exit(0)
    }

    let log = env("HOME") + "/Dev/nexus/tool/sandbox_breaches.jsonl"

    if action == "breaches" {
        let mut n = "10"
        if argv.len() > 3 { n = argv[3] }
        let exists = exec("test -f " + _shq(log) + " && echo y || echo n").trim()
        if exists != "y" { println("no breaches logged"); exit(0) }
        let out = exec("tail -n " + n + " " + _shq(log))
        print(out)
        exit(0)
    }

    if action == "stats" {
        let exists = exec("test -f " + _shq(log) + " && echo y || echo n").trim()
        if exists != "y" { println("total=0 (no breaches logged)"); exit(0) }
        let total = exec("wc -l < " + _shq(log)).trim()
        let warn_n = exec("grep -c '\"mode\":\"warn\"' " + _shq(log) + " 2>/dev/null").trim()
        let strict_n = exec("grep -c '\"mode\":\"strict\"' " + _shq(log) + " 2>/dev/null").trim()
        println("total=" + total + " warn=" + warn_n + " strict=" + strict_n)
        println("top scripts:")
        print(exec("awk -F'\"script\":\"' '{print $2}' " + _shq(log) + " | awk -F'\"' '{print $1}' | sort | uniq -c | sort -rn | head -5"))
        exit(0)
    }

    eprintln("usage: safe_hexa_check <check|ensure|breaches [N]|stats>")
    exit(2)
}

main()
