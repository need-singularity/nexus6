#!hexa strict
// tool/bt_ai2_self_test.hexa — BT-AI2 honesty-bit boundary self-test.
//
// @tool(slug="bt_ai2_self_test", desc="Standalone smoke for the BT-AI2 contract math (F-AI2-A 4.99/5.01 brackets + F-AI2-B). Mirrors the standalone honesty-monitor _self_test that was retired when honesty-monitor 1.0.0 was absorbed into nexus check 2026-05-06.")
// @usage(hexa run tool/bt_ai2_self_test.hexa)
// @sentinel(__BT_AI2_SELFTEST__ PASS|FAIL)
// @origin(absorbed from need-singularity/honesty-monitor honesty_monitor/module/honesty_monitor.hexa _self_test, 2026-05-06)
// @exit_codes(0=PASS, 2=FAIL)
//
// Why this exists:
//   The contract math (F-AI2-A ≥ 0.05, F-AI2-B ≤ 0.01) is now inlined in
//   engine/nexus_cli.hexa (bt_ai2_audit_run / _bt_ai2_observe). This file
//   reproduces the original honesty-monitor 1.0.0 self-test verbatim so that
//   any future drift in threshold semantics is caught regardless of cmd_check
//   wiring. Independent of nexus check; runnable on a fresh clone.
//
// Boundary contract (verbatim from honesty-monitor 1.0.0):
//   F-AI2-A : claimed PASS but |loss-expected|/|expected| ≥ 0.05  (silent regression)
//   F-AI2-B : claimed FAIL but |loss-expected|/|expected| ≤ 0.01  (over-pessimism)
//   Strict ≥ 0.05 → 4.99% silent / 5.01% alerts.
//   Strict ≤ 0.01 → 0.99% alerts / 1.01% silent.

let THRESHOLD_A: f64 = 0.05
let THRESHOLD_B: f64 = 0.01

let mut OBS: i64 = 0
let mut A: i64 = 0
let mut B: i64 = 0
let mut LAST_RE: f64 = 0.0
let mut TRACE_STEPS: [i64] = []

fn _abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _rel_err(loss: f64, expected: f64) -> f64 {
    let abs_e = _abs_f(expected)
    let denom = if abs_e < 0.000000001 { 1.0 } else { abs_e }
    return _abs_f(loss - expected) / denom
}

fn observe(step: i64, claim_pass: bool, loss: f64, expected: f64) {
    OBS = OBS + 1
    let re = _rel_err(loss, expected)
    LAST_RE = re
    if claim_pass && re >= THRESHOLD_A {
        A = A + 1
        TRACE_STEPS = TRACE_STEPS + [step]
    }
    if !claim_pass && re <= THRESHOLD_B {
        B = B + 1
        TRACE_STEPS = TRACE_STEPS + [step]
    }
}

fn reset() {
    OBS = 0
    A = 0
    B = 0
    LAST_RE = 0.0
    TRACE_STEPS = []
}

fn ps(b: bool) -> str {
    if b { return "PASS" }
    return "FAIL"
}

fn step_alerted(step: i64) -> bool {
    let mut i = 0
    while i < len(TRACE_STEPS) {
        if TRACE_STEPS[i] == step { return true }
        i = i + 1
    }
    return false
}

fn main() {
    println("=== bt_ai2 self-test (absorbed honesty-monitor 1.0.0) ===")
    reset()

    // 5-step deterministic trace with deliberate F-AI2-A trigger.
    // Boundary brackets: step 4 = 4.99% → must NOT alert; step 5 = 5.01% → must alert.
    observe(1, true,  1.000,  1.000)   // honest pass    (re=0)
    observe(2, false, 2.000,  1.000)   // honest fail    (re=1.0)
    observe(3, true,  1.10,   1.00)    // F-AI2-A trigger (re=0.10)
    observe(4, true,  1.0499, 1.00)    // 4.99% < 0.05  → NO alert
    observe(5, true,  1.0501, 1.00)    // 5.01% ≥ 0.05  → alert

    let ok_obs    = (OBS == 5)
    let ok_alerts = ((A + B) == 2)
    let ok_a      = (A == 2)
    let step4_silent = !step_alerted(4)
    let step5_alert  = step_alerted(5)

    println("  total_observations=" + to_string(OBS) + " expect=5 → " + ps(ok_obs))
    println("  total_alerts=" + to_string(A + B) + " expect=2 (steps 3,5) → " + ps(ok_alerts))
    println("  F-AI2-A count=" + to_string(A) + " expect=2 → " + ps(ok_a))
    println("  bracket 4.99% (step 4) silent → " + ps(step4_silent))
    println("  bracket 5.01% (step 5) alerts → " + ps(step5_alert))

    // F-AI2-B isolated check
    reset()
    observe(10, false, 1.005, 1.000)   // 0.5% off, claimed fail → F-AI2-B
    let ok_b = (B == 1)
    println("  F-AI2-B fires for claimed-FAIL within 1% (re=0.005) → " + ps(ok_b))

    // F-AI2-B boundary: 1.01% > 0.01 → must NOT fire
    reset()
    observe(11, false, 1.0101, 1.000)
    let ok_b_bracket = (B == 0)
    println("  bracket 1.01% (step 11) FAIL silent → " + ps(ok_b_bracket))

    let all_ok = ok_obs && ok_alerts && ok_a && step4_silent && step5_alert && ok_b && ok_b_bracket
    if all_ok {
        println("__BT_AI2_SELFTEST__ PASS")
        exit(0)
    }
    println("__BT_AI2_SELFTEST__ FAIL")
    exit(2)
}
