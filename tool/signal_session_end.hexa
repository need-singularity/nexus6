// signal_session_end.hexa — E2 대체 하네스
// ~/.claude/projects/*/*.jsonl 최근 세션 1개의 마지막 N 메시지에서
// signal 마커 감지 → staging append
// 실행: hexa run $NEXUS/tool/signal_session_end.hexa [tail=200]

let HOME = env("HOME")
let NEXUS = HOME + "/core/nexus"
let STAGE = NEXUS + "/n6/staging/atlas.signals.staging.session.n6"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn now_ts() -> string {
    let r = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    return _str(r).trim()
}

fn shell_quote(s: string) -> string {
    let escaped = s.replace("'", "'\\''")
    return "'" + escaped + "'"
}

fn append_line(path: string, line: string) {
    let cmd = "printf '%s\\n' " + shell_quote(line) + " >> '" + path + "' 2>/dev/null"
    exec(cmd)
}

// 가장 최근 mtime jsonl 파일 1개 찾기
fn find_latest_jsonl() -> string {
    // BSD find -> ls -t 로 mtime 내림차순
    let cmd = "find '" + HOME + "/.claude/projects' -type f -name '*.jsonl' " +
              "-exec stat -f '%m %N' {} \\; 2>/dev/null | sort -rn | head -1 | awk '{print $2}'"
    let r = exec(cmd)
    return _str(r).trim().split("\n")[0]
}

// ─── 메인 ───
let a = args()
let mut tail_n: i64 = 200
if a.len() >= 3 {
    try { tail_n = to_int(a[2]) } catch e { tail_n = 200 }
}

println("signal_session_end: tail=" + to_string(tail_n) + " ts=" + now_ts())

let latest = find_latest_jsonl()
if latest == "" {
    println("  WARN: ~/.claude/projects 에 jsonl 없음")
    exit(0)
}

println("  latest=" + latest)

if file_exists(STAGE) == false {
    try { write_file(STAGE, "# session_end staging — append-only\n") } catch e {}
}

// 마지막 N 줄 읽어서 마커 검색
// grep -c 를 count 용으로만 쓰고, 실제 매칭된 sample 은 grep -m 로 1줄씩
let patterns = [
    "★",
    "최초",
    "NULL",
    "PEAK",
    "sweet spot",
    "breakthrough",
    "돌파",
    "pp drop",
    "× faster",
    "진짜 발견"
]

let mut total_hits: i64 = 0
let mut j = 0

while j < patterns.len() {
    let pat = patterns[j]
    let cmd = "{ tail -n " + to_string(tail_n) + " '" + latest +
              "' 2>/dev/null | grep -c -F " + shell_quote(pat) + " || true; }"
    let r = exec(cmd)
    let s = _str(r).trim().split("\n")[0]
    let mut v: i64 = 0
    try { v = to_int(s) } catch e { v = 0 }
    if v > 0 {
        total_hits = total_hits + v
        println("    pattern=" + pat + " count=" + to_string(v))
    }
    j = j + 1
}

if total_hits > 0 {
    let line = "# CANDIDATE " + now_ts() + " session_jsonl_hits=" + to_string(total_hits) + " <- " + latest
    append_line(STAGE, line)
    println("  staged hits=" + to_string(total_hits))
} else {
    println("  no signal markers in last " + to_string(tail_n) + " lines")
}

println("  staging=" + STAGE)
