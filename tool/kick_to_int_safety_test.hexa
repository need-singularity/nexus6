// tool/kick_to_int_safety_test.hexa — regression test for kick_dispatch _safe_to_int_line.
//
// @tool(slug="kick_to_int_safety_test", desc="exercise kick_dispatch _safe_to_int_line with multi-line + garbage probe outputs (incl. the original `0\\n0` failure case from the chflags-lock kick orchestrator prep phase) and assert graceful degrade")
// @usage(hexa /Users/ghost/core/nexus/tool/kick_to_int_safety_test.hexa)
// @exit_codes(0=PASS, 1=any-case-failed)
//
// raw 80 sentinel: __KICK_TO_INT_SAFETY__ <PASS|FAIL> cases=<N> failed=<N>
// raw 66 err:     reason=<slug> fix=<directive>
//
// The helper is duplicated verbatim from tool/kick_dispatch.hexa (no module
// export in hexa-lang). If you change the helper there, mirror the change here
// and re-run this test. Falsifier: any divergence in behaviour between the two
// copies is a fail-loud signal.

fn _safe_to_int_line(raw: str, default: i64, label: str) -> i64 {
    let trimmed = raw.trim()
    if trimmed.len() == 0 { return default }
    let nl = trimmed.index_of("\n")
    let first = if nl >= 0 { trimmed.substring(0, nl).trim() } else { trimmed }
    if first.len() == 0 { return default }
    let mut v: i64 = default
    try { v = to_int(first) } catch e {
        let mut repr = raw.replace("\n", "\\n").replace("\r", "\\r")
        if repr.len() > 80 { repr = repr.substring(0, 80) + "…" }
        eprintln("# kick_to_int_safety_test: reason=to_int-probe-parse-fail-" + label + " fix=audit probe stdout (multiline / non-int) raw=\"" + repr + "\" default=" + to_string(default))
        v = default
    }
    return v
}

fn _check(label: str, raw: str, default: i64, want: i64, mut failed: i64) -> i64 {
    let got = _safe_to_int_line(raw, default, label)
    if got == want {
        println("PASS " + label + " raw=\"" + raw.replace("\n", "\\n") + "\" got=" + to_string(got))
        return failed
    }
    println("FAIL " + label + " raw=\"" + raw.replace("\n", "\\n") + "\" want=" + to_string(want) + " got=" + to_string(got))
    return failed + 1
}

fn main() -> void {
    let mut failed: i64 = 0
    let mut cases: i64 = 0

    // Case 1 — the original failure mode: probe returned "0\n0".
    // Bare to_int("0\n0") would throw "trailing garbage in 0\n0".
    // Helper must take first line "0" → return 0 (NOT default), no throw.
    failed = _check("multiline-zero-zero", "0\n0", -1, 0, failed); cases = cases + 1

    // Case 2 — multi-line with non-zero first value.
    failed = _check("multiline-first-line-wins", "42\n99\nextra", -1, 42, failed); cases = cases + 1

    // Case 3 — garbage on first line returns default.
    failed = _check("first-line-garbage", "abc\n5", -1, -1, failed); cases = cases + 1

    // Case 4 — empty input returns default.
    failed = _check("empty-input", "", 7, 7, failed); cases = cases + 1

    // Case 5 — whitespace-only input returns default.
    failed = _check("whitespace-only", "   \n  \n", 9, 9, failed); cases = cases + 1

    // Case 6 — clean single integer (the happy path).
    failed = _check("clean-int", "12345", -1, 12345, failed); cases = cases + 1

    // Case 7 — leading/trailing spaces on first line.
    failed = _check("padded-int", "   77   \n", -1, 77, failed); cases = cases + 1

    // Case 8 — negative integer.
    failed = _check("negative-int", "-13\n", 0, -13, failed); cases = cases + 1

    // Case 9 — trailing CRLF on first line (Windows-flavoured probes).
    failed = _check("crlf-first-line", "256\r\n0\r\n", -1, 256, failed); cases = cases + 1

    // Case 10 — pure newline input returns default.
    failed = _check("only-newline", "\n", 5, 5, failed); cases = cases + 1

    // Case 11 — `wc -l < missing-file` typically returns "" via 2>/dev/null;
    // ensure we don't throw and we return the default.
    failed = _check("wc-empty-stdout", "", 0, 0, failed); cases = cases + 1

    // Case 12 — ANU-style probe with extra trailing JSON noise (real obs_2 path
    // already extracts num_s; this guards a defence-in-depth misuse).
    failed = _check("anu-byte-with-noise", "237 noise\n{}", -1, -1, failed); cases = cases + 1

    if failed > 0 {
        println("__KICK_TO_INT_SAFETY__ FAIL cases=" + to_string(cases) + " failed=" + to_string(failed))
        eprintln("reason=safe-to-int-regression-failed fix=tail tool/kick_dispatch.hexa _safe_to_int_line; ensure helper splits on first \\n + try/catch + raw 66 trailer")
        exit(1)
    }
    println("__KICK_TO_INT_SAFETY__ PASS cases=" + to_string(cases) + " failed=0")
    exit(0)
}
