#!hexa strict
// tool/handlers/outside_noise_clm_handler.hexa — Phase 4 Option B impl (fallback to standalone)
//
// @tool(slug="outside_noise_clm_handler", desc="kick (omega-cycle) per-cycle anima CLM outside-noise generator -> validation -> absorb. Dual entry: CLI direct (--cycle N) + bind axis subscriber (--bind-fire from nexus/core/bind/router.hexa). dispatch_framework_v1 conformant.")
// @sentinel(__OUTSIDE_NOISE_CLM__ <PASS|FAIL|REJECT> cycle=<N> primitive_id=<id> validated=<bool>)
// @usage(hexa run nexus/tool/handlers/outside_noise_clm_handler.hexa --cycle <N> [--mock] [--hf-fallback] [--bind-fire] [--selftest])
// @resolver-bypass(reason="cross-repo CLM invocation + atlas absorb")
// @exit_codes(0=PASS+ABSORBED, 1=PASS+REJECTED_VALIDATION, 2=CLM_INFERENCE_FAIL, 3=ABSORB_FAIL)
//
// raw#10 honest:
//   - bind framework absent in nexus -> Plan B fallback (standalone)
//   - mac CLM via anima/tool/anima_serve_smoke.hexa is contract-stub only
//     (no real LoRA inference); real path requires HF gated or full local server
//   - 4411 base node count = design doc estimate; actual atlas baseline is
//     atlas_phase4*+phase6 jsonl ~2913 lines (audit-corrected)
//   - cosine_similarity is text-based jaccard fallback (no real embedding stage0)
//   - validation is necessary but NOT sufficient for novelty (LLM hallucination
//     can self-report honest_c3_pass=true)
//
// Pipeline:
//   1. load reality_map cycle_<N-1>.jsonl (or cycle_0.jsonl baseline)
//   2. compose CLM prompt (reality stats + last-5 absorbed)
//   3. invoke anima CLM (mock | local stub | hf gated)
//   4. parse candidate primitive { name, description, evidence_link, falsifier, honest_c3_pass }
//   5. validate: dup_check + verifier + honest_c3
//   6. absorb -> reality_map cycle_<N>.jsonl + omega_cycle witness JSON + atlas_absorb_hook
//   7. emit .roadmap.atlas_n6 entry append
//   8. emit sentinel + marker

fn _home() -> string {
    let h = env_var("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _nexus_root() -> string {
    let override = env_var("NEXUS_CORE_ROOT")
    if len(override) > 0 { return override + "/nexus" }
    return _home() + "/core/nexus"
}

fn _anima_root() -> string {
    return _home() + "/core/anima"
}

fn now_utc() -> string {
    return to_string(exec("date -u +%FT%TZ")).trim()
}

fn _shell_quote(s: string) -> string {
    let mut r = s.replace("'", "'\\''")
    return "'" + r + "'"
}

fn json_escape(s: string) -> string {
    let mut out = s.replace("\\", "\\\\")
    out = out.replace("\"", "\\\"")
    out = out.replace("\n", "\\n")
    out = out.replace("\t", "\\t")
    return out
}

fn _file_exists(p: string) -> bool {
    return to_string(exec("test -f '" + p + "' && echo y || echo n")).trim() == "y"
}

// ─── reality_map I/O ───────────────────────────────────────────────────

fn _reality_map_path(cycle_n: i64) -> string {
    return _nexus_root() + "/state/reality_map/cycle_" + to_string(cycle_n) + ".jsonl"
}

fn _load_reality_map(cycle_n: i64) -> array {
    // returns array of node-line strings (jsonl); empty if file missing
    let path = _reality_map_path(cycle_n)
    if !_file_exists(path) { return [] }
    let raw = to_string(exec("cat '" + path + "' 2>/dev/null"))
    let mut nodes = []
    let mut start = 0
    let mut i = 0
    let n = len(raw)
    while i < n {
        let c = raw.substring(i, i + 1)
        if c == "\n" {
            let line = raw.substring(start, i).trim()
            if len(line) > 0 { nodes.push(line) }
            start = i + 1
        }
        i = i + 1
    }
    if start < n {
        let last = raw.substring(start, n).trim()
        if len(last) > 0 { nodes.push(last) }
    }
    return nodes
}

fn _save_reality_map(cycle_n: i64, nodes: array) -> bool {
    let path = _reality_map_path(cycle_n)
    let mut buf = ""
    let mut i = 0
    while i < len(nodes) {
        buf = buf + nodes[i] + "\n"
        i = i + 1
    }
    let tmp = path + ".tmp"
    let _ = exec("cat > '" + tmp + "' <<'__EOF_RM__'\n" + buf + "__EOF_RM__")
    let _ = exec("mv '" + tmp + "' '" + path + "'")
    return _file_exists(path)
}

fn _last_n_summaries(nodes: array, n: i64) -> string {
    let total = len(nodes)
    let start = if total > n { total - n } else { 0 }
    let mut out = ""
    let mut i = start
    while i < total {
        // crude name extraction: look for "name":"<...>"
        let line = nodes[i]
        let key = "\"name\":\""
        let kp = line.index_of(key)
        if kp >= 0 {
            let after = line.substring(kp + len(key), len(line))
            let qp = after.index_of("\"")
            if qp >= 0 {
                if len(out) > 0 { out = out + "; " }
                out = out + after.substring(0, qp)
            }
        }
        i = i + 1
    }
    if len(out) == 0 { return "(none)" }
    return out
}

// ─── CLM inference (mock | local stub | hf gated) ─────────────────────

fn _compose_prompt(node_count: i64, last_summary: string, cycle_n: i64) -> string {
    let mut p = "Current reality map: " + to_string(node_count) + " nodes (cycle " + to_string(cycle_n) + ").\n"
    p = p + "Last absorbed primitives: " + last_summary + "\n"
    p = p + "Propose ONE NEW primitive (concept|law|pattern) that:\n"
    p = p + "  - is not yet in the map\n"
    p = p + "  - is empirically groundable (measurable claim)\n"
    p = p + "  - extends the reality wall outward\n"
    p = p + "Output strict JSON one-line: {\"name\":\"...\",\"description\":\"...\",\"primitive_type\":\"concept|law|pattern\",\"evidence_link\":\"...\",\"falsifier\":\"...\",\"honest_c3_pass\":true}\n"
    return p
}

fn _mock_clm_inference(cycle_n: i64) -> string {
    // deterministic mock: cycle-seed for reproducible selftest
    let seed = (cycle_n * 7919 + 13) % 4
    let mut name = "mock_primitive_cycle_" + to_string(cycle_n)
    let mut ptype = "concept"
    let mut desc = "deterministic mock candidate for selftest"
    let mut ev = "selftest:mock"
    let mut fals = "if removed, no test impact"
    if seed == 0 {
        ptype = "law"
        desc = "mock measurable threshold law observable in selftest"
    } else if seed == 1 {
        ptype = "pattern"
        desc = "mock recurring pattern measurable across cycles"
    } else if seed == 2 {
        // produce a duplicate-like candidate (forces dup-fail test)
        name = "DUPLICATE_BASE_NODE_42"
        desc = "mock duplicate-trigger to test falsifier"
    } else {
        // honest_c3 fail trigger
        return "{\"name\":\"mock_dishonest_" + to_string(cycle_n) + "\",\"description\":\"hallucinated\",\"primitive_type\":\"concept\",\"evidence_link\":\"none\",\"falsifier\":\"none\",\"honest_c3_pass\":false}"
    }
    return "{\"name\":\"" + name + "\",\"description\":\"" + desc + "\",\"primitive_type\":\"" + ptype + "\",\"evidence_link\":\"" + ev + "\",\"falsifier\":\"" + fals + "\",\"honest_c3_pass\":true}"
}

fn _local_clm_inference(prompt: string) -> string {
    // stage0: anima_serve_smoke is contract-stub only. We invoke and return
    // a templated response. Real LoRA path = TODO (raw#10 caveat).
    let smoke = _anima_root() + "/tool/anima_serve_smoke.hexa"
    if !_file_exists(smoke) {
        return ""
    }
    // do not actually shell out (would error in selftest); emit deterministic template
    return "{\"name\":\"local_stub_primitive\",\"description\":\"anima_serve_smoke contract stub response — real LoRA pending\",\"primitive_type\":\"concept\",\"evidence_link\":\"local_stub:smoke\",\"falsifier\":\"contract schema mismatch\",\"honest_c3_pass\":true}"
}

fn _hf_clm_inference(prompt: string) -> string {
    // requires HUGGINGFACE_API_TOKEN — pre-flight only stage0
    let tok = env_var("HUGGINGFACE_API_TOKEN")
    if len(tok) == 0 { return "" }
    // real call deferred; emit honest pending
    return "{\"name\":\"hf_pending_primitive\",\"description\":\"HF gated path pre-flight pass — real call deferred to live cycle\",\"primitive_type\":\"concept\",\"evidence_link\":\"hf:pending\",\"falsifier\":\"no token / network fail\",\"honest_c3_pass\":true}"
}

fn _invoke_anima_clm(prompt: string, mode: string, cycle_n: i64) -> string {
    // Phase 2: real-inference wire. Delegate to anima/tool/anima_clm_invoke.hexa
    // via subprocess (cross-repo). On wrapper absence OR exit!=0 -> graceful
    // degrade to in-handler mock/local/hf stubs (preserves predecessor 5/5
    // selftest behavior). raw#10: wrapper exit 2 = SKIP (dependency absent),
    // exit 0 = PASS, anything else = FAIL.
    let wrapper = _anima_root() + "/tool/anima_clm_invoke.hexa"
    if mode == "mock" {
        // mock path: prefer wrapper (single SSOT for mock seed semantics);
        // fall back to legacy in-handler mock if wrapper missing.
        if !_file_exists(wrapper) { return _mock_clm_inference(cycle_n) }
    }
    if !_file_exists(wrapper) {
        // wrapper not deployed yet — preserve original behavior path
        if mode == "hf" { return _hf_clm_inference(prompt) }
        return _local_clm_inference(prompt)
    }
    // build cli: --prompt <p> --mode <m> --cycle <N> --temp 0.7 --max-tokens 256
    // (single-line concat — hexa-lang backslash line-continuation unreliable)
    let qprompt = _shell_quote(prompt)
    let cmd = "env HEXA_RESOLVER_NO_REROUTE=1 hexa run " + _shell_quote(wrapper) + " --prompt " + qprompt + " --mode " + mode + " --cycle " + to_string(cycle_n) + " --temp 0.7 --max-tokens 256 2>/dev/null; echo __RC=$?"
    let raw = to_string(exec(cmd))
    let rc_idx = raw.last_index_of("__RC=")
    if rc_idx < 0 {
        // unexpected — fall back to in-handler stubs
        if mode == "mock" { return _mock_clm_inference(cycle_n) }
        if mode == "hf" { return _hf_clm_inference(prompt) }
        return _local_clm_inference(prompt)
    }
    let body = raw.substring(0, rc_idx).trim()
    let tail = raw.substring(rc_idx + 5, len(raw)).trim()
    let nl = tail.index_of("\n")
    let rc_str = if nl >= 0 { tail.substring(0, nl).trim() } else { tail }
    if rc_str == "0" && len(body) > 0 {
        // wrapper produced JSON on stdout — return last non-empty line as candidate
        let lines = body.split("\n")
        let mut idx = len(lines) - 1
        while idx >= 0 {
            let line = lines[idx].trim()
            if len(line) > 0 && line.substring(0, 1) == "{" {
                return line
            }
            idx = idx - 1
        }
    }
    // wrapper SKIP (rc=2) or empty body or rc!=0 -> graceful degrade to legacy
    // in-handler stubs. Preserves the original 5/5 selftest behavior end-to-end.
    if mode == "mock" { return _mock_clm_inference(cycle_n) }
    if mode == "hf" { return _hf_clm_inference(prompt) }
    return _local_clm_inference(prompt)
}

// ─── parse + validation ─────────────────────────────────────────────────

fn _extract_json_string(json: string, key: string) -> string {
    let needle = "\"" + key + "\":\""
    let kp = json.index_of(needle)
    if kp < 0 { return "" }
    let after = json.substring(kp + len(needle), len(json))
    let qp = after.index_of("\"")
    if qp < 0 { return "" }
    return after.substring(0, qp)
}

fn _extract_json_bool(json: string, key: string) -> bool {
    let needle = "\"" + key + "\":"
    let kp = json.index_of(needle)
    if kp < 0 { return false }
    let after = json.substring(kp + len(needle), len(json))
    let trimmed = after.trim()
    if len(trimmed) >= 4 && trimmed.substring(0, 4) == "true" { return true }
    return false
}

fn _jaccard_similarity(a: string, b: string) -> float {
    // crude token-set jaccard — stage0 fallback for embedding cosine
    let toks_a = a.split(" ")
    let toks_b = b.split(" ")
    let mut intersect: i64 = 0
    let mut i = 0
    while i < len(toks_a) {
        let ta = toks_a[i].trim()
        if len(ta) > 0 {
            let mut j = 0
            while j < len(toks_b) {
                if toks_b[j].trim() == ta {
                    intersect = intersect + 1
                    break
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    let union_est = len(toks_a) + len(toks_b) - intersect
    if union_est <= 0 { return 0.0 }
    return float(intersect) / float(union_est)
}

fn _falsifier_dup_check(candidate_name: string, candidate_desc: string, nodes: array, threshold: float) -> bool {
    // returns true = NOVEL (no dup), false = DUPLICATE found
    let mut i = 0
    while i < len(nodes) {
        let line = nodes[i]
        let existing_name = _extract_json_string(line, "name")
        if len(existing_name) > 0 {
            if existing_name == candidate_name { return false }
            let sim = _jaccard_similarity(candidate_desc, _extract_json_string(line, "description"))
            if sim >= threshold { return false }
        }
        i = i + 1
    }
    return true
}

fn _verifier_empirical(candidate_desc: string) -> bool {
    // regex-style match: presence of measure|experiment|observe|test|measurable|threshold|recurring
    let lower = candidate_desc.to_lower()
    if lower.index_of("measur") >= 0 { return true }
    if lower.index_of("experiment") >= 0 { return true }
    if lower.index_of("observ") >= 0 { return true }
    if lower.index_of("test") >= 0 { return true }
    if lower.index_of("threshold") >= 0 { return true }
    if lower.index_of("recurring") >= 0 { return true }
    return false
}

fn _raw91_honest_c3(candidate_raw: string) -> bool {
    return _extract_json_bool(candidate_raw, "honest_c3_pass")
}

// ─── absorb ─────────────────────────────────────────────────────────────

fn _emit_omega_cycle_witness(cycle_n: i64, candidate_raw: string, primitive_id: string) -> string {
    let path = _nexus_root() + "/design/kick/" + to_string(cycle_n) + "_outside_noise_clm_omega_cycle.json"
    let _ = exec("mkdir -p '" + _nexus_root() + "/design/kick'")
    let ts = now_utc()
    let body = "{\"schema\":\"nexus/design/kick/omega_cycle/v1\",\"cycle\":" + to_string(cycle_n) + ",\"primitive_id\":\"" + primitive_id + "\",\"absorbed_at\":\"" + ts + "\",\"source\":\"outside_noise_clm_handler\",\"candidate_raw\":\"" + json_escape(candidate_raw) + "\"}\n"
    let tmp = path + ".tmp"
    let _ = exec("cat > '" + tmp + "' <<'__EOF_OCW__'\n" + body + "__EOF_OCW__")
    let _ = exec("mv '" + tmp + "' '" + path + "'")
    return path
}

fn _invoke_atlas_absorb_hook(witness_path: string) -> i64 {
    let hook = _nexus_root() + "/tool/atlas_absorb_hook.hexa"
    if !_file_exists(hook) { return 99 }
    let cmd = "env HEXA_RESOLVER_NO_REROUTE=1 ATLAS_ABSORB_HOOK_DISABLED=1 hexa run " + _shell_quote(hook) + " --witness " + _shell_quote(witness_path) + " --source outside_noise_clm 2>&1; echo __RC=$?"
    let out = to_string(exec(cmd))
    let rc_idx = out.last_index_of("__RC=")
    if rc_idx < 0 { return 0 }
    let tail = out.substring(rc_idx + 5, len(out)).trim()
    let nl = tail.index_of("\n")
    let rc = if nl >= 0 { tail.substring(0, nl).trim() } else { tail }
    if rc == "0" { return 0 }
    return 1
}

fn _emit_roadmap_entry(primitive_id: string, primitive_name: string, cycle_n: i64) -> bool {
    let rmap = _nexus_root() + "/.roadmap.atlas_n6"
    if !_file_exists(rmap) { return false }
    let entry = "{\"type\":\"entry\",\"id\":\"atlas_n6." + primitive_id + "\",\"kind\":\"entry\",\"title\":\"" + json_escape(primitive_name) + "\",\"status\":\"absorbed\",\"substrates\":[\"clm\",\"atlas_n6\"],\"source\":\"kick_clm_outside_noise_cycle_" + to_string(cycle_n) + "\",\"contributes_to\":[\"atlas_n6.cond.1\"]}\n"
    let _ = exec("printf '%s' " + _shell_quote(entry) + " >> '" + rmap + "'")
    return true
}

fn _emit_marker(slug: string, status: string, cycle_n: i64) -> string {
    let dir = _nexus_root() + "/state/markers"
    let _ = exec("mkdir -p '" + dir + "'")
    let ts = to_string(exec("date +%s")).trim()
    let path = dir + "/" + slug + "_" + status + "_" + to_string(cycle_n) + "_" + ts + ".marker"
    let body = "{\"slug\":\"" + slug + "\",\"status\":\"" + status + "\",\"cycle\":" + to_string(cycle_n) + ",\"ts\":\"" + now_utc() + "\"}\n"
    let _ = exec("printf '%s' " + _shell_quote(body) + " > '" + path + "'")
    return path
}

// ─── selftest ───────────────────────────────────────────────────────────

fn _selftest() -> void {
    println("[outside_noise_clm_handler selftest]")
    // Case 1: mock cycle 0 (seed 13 % 4 = 1 = pattern + valid)
    let raw0 = _invoke_anima_clm("", "mock", 0)
    let h0 = _raw91_honest_c3(raw0)
    let v0 = _verifier_empirical(_extract_json_string(raw0, "description"))
    if !h0 {
        eprintln("selftest FAIL case1 honest_c3 should be true for cycle=0")
        eprintln("reason=mock-honest-c3-mismatch fix=verify _mock_clm_inference seed branches")
        exit(1)
    }
    if !v0 {
        eprintln("selftest FAIL case1 verifier should match 'measurable|recurring|...' for cycle=0")
        eprintln("reason=mock-verifier-mismatch fix=verify mock branch description contains measurable|recurring|...")
        exit(1)
    }
    println("  case1 PASS valid candidate cycle=0 honest=true verifier=true")
    // Case 2: dup detection — cycle 3 -> seed (3*7919+13)%4 = 23770%4 = 2 = DUPLICATE_BASE_NODE_42
    let raw2 = _invoke_anima_clm("", "mock", 3)
    let nodes_with_dup = ["{\"id\":42,\"name\":\"DUPLICATE_BASE_NODE_42\",\"description\":\"existing\"}"]
    let dup_novel = _falsifier_dup_check(_extract_json_string(raw2, "name"), _extract_json_string(raw2, "description"), nodes_with_dup, 0.85)
    if dup_novel {
        eprintln("selftest FAIL case2 falsifier should detect duplicate name DUPLICATE_BASE_NODE_42 (cycle=3 -> seed 2)")
        eprintln("reason=falsifier-dup-miss fix=verify _falsifier_dup_check name equality short-circuit")
        exit(1)
    }
    println("  case2 PASS duplicate detected for cycle=3 (seed=2)")
    // Case 3: honest_c3 fail — cycle 2 -> seed (2*7919+13)%4 = 15851%4 = 3 = honest_c3 false
    let raw3 = _invoke_anima_clm("", "mock", 2)
    let h3 = _raw91_honest_c3(raw3)
    if h3 {
        eprintln("selftest FAIL case3 honest_c3 should be false for cycle=2 (seed=3)")
        eprintln("reason=mock-honest-c3-not-falsifying fix=verify cycle=2 -> seed=3 mock returns honest_c3_pass=false")
        exit(1)
    }
    println("  case3 PASS honest_c3 falsified for cycle=2 (seed=3)")
    // Case 4: verifier reject (description with no measurable keyword)
    let bare = "trivial restatement no keywords"
    if _verifier_empirical(bare) {
        eprintln("selftest FAIL case4 verifier should reject 'trivial restatement no keywords'")
        eprintln("reason=verifier-false-positive fix=verify _verifier_empirical keyword set")
        exit(1)
    }
    println("  case4 PASS verifier rejected non-measurable")
    // Case 5: roadmap atlas_n6 file present
    let rmap = _nexus_root() + "/.roadmap.atlas_n6"
    if !_file_exists(rmap) {
        eprintln("selftest WARN .roadmap.atlas_n6 missing — entry emit will skip")
        eprintln("reason=roadmap-missing fix=ensure .roadmap.atlas_n6 exists before live cycle")
    } else {
        println("  case5 PASS .roadmap.atlas_n6 present")
    }
    // Case 6: real anima_clm_invoke wrapper round-trip (skip if wrapper absent
    // OR if env ANIMA_CLM_MODE=mock-only forces handler-internal mock). Probes
    // that wrapper exists, returns valid JSON for mock mode, and the JSON
    // contains the wrapper's "_mode":"mock" tag (proves wrapper produced it,
    // not the legacy in-handler stub).
    let wrapper = _anima_root() + "/tool/anima_clm_invoke.hexa"
    if !_file_exists(wrapper) {
        println("  case6 SKIP anima_clm_invoke wrapper not deployed (real-inference wire pending)")
    } else {
        // cycle=1 -> seed=(7919+13)%4=1 (pattern + valid in both wrapper+legacy mock paths)
        let raw6 = _invoke_anima_clm("selftest_prompt_case6", "mock", 1)
        if len(raw6) == 0 {
            eprintln("selftest FAIL case6 wrapper round-trip empty output")
            eprintln("reason=wrapper-empty fix=verify anima_clm_invoke.hexa --selftest passes 5/5")
            exit(1)
        }
        if raw6.index_of("\"_mode\":\"mock\"") < 0 {
            eprintln("selftest FAIL case6 wrapper output missing _mode tag (legacy fallback fired unexpectedly)")
            eprintln("output=" + raw6)
            eprintln("reason=wrapper-not-invoked fix=verify hexa binary on PATH and wrapper executable")
            exit(1)
        }
        println("  case6 PASS anima_clm_invoke wrapper round-trip (mock mode, _mode tag verified)")
    }
    // Case 7: fallback graceful degrade path. Force the wrapper-absent code
    // path by invoking the legacy mock directly (proves the fallback branch
    // remains intact and produces valid candidate). This is the safety net
    // when wrapper deploy fails or path resolution diverges.
    let raw7 = _mock_clm_inference(0)
    if len(raw7) == 0 || raw7.index_of("\"name\":\"") < 0 {
        eprintln("selftest FAIL case7 legacy fallback mock empty/malformed")
        eprintln("reason=legacy-mock-broken fix=verify _mock_clm_inference cycle=0 branch")
        exit(1)
    }
    println("  case7 PASS legacy fallback mock intact (graceful-degrade safety net)")
    // Case 8: bind axis fire path — verifies on_outside_noise_axis_fire entry
    // and dispatch_framework_v1 BindResult shape (success + verdict + exit_code).
    // Uses cycle 1 (seed 1, valid pattern) for deterministic mock branch.
    let bf_payload_event = "outside_noise"
    let bf_payload_cycle = "c1"
    // Direct invoke of contract function
    let bf_result_verdict = _bind_fire_self_probe(1)
    if bf_result_verdict != "PASS" && bf_result_verdict != "REJECT" && bf_result_verdict != "DRY-RUN" {
        eprintln("selftest FAIL case8 bind axis fire verdict unexpected: " + bf_result_verdict)
        eprintln("reason=bind-fire-verdict-not-recognized fix=verify on_outside_noise_axis_fire returns PASS|REJECT|DRY-RUN for mock cycle=1")
        exit(1)
    }
    println("  case8 PASS bind axis fire path verdict=" + bf_result_verdict + " event=" + bf_payload_event + " cycle=" + bf_payload_cycle)
    // Case 9: byte-identical CLI vs bind path (mock cycle 1, deterministic seed).
    // Generates twice + diffs the candidate JSON to verify same handler stage
    // produces identical output regardless of dispatch path. Stage0 cannot
    // verify cross-process byte-identity inside selftest (no fork+capture
    // primitive); we verify the candidate generation function is path-agnostic
    // by direct double invoke.
    let raw9a = _invoke_anima_clm("", "mock", 1)
    let raw9b = _invoke_anima_clm("", "mock", 1)
    if raw9a != raw9b {
        eprintln("selftest FAIL case9 byte-identical 2-run mismatch")
        eprintln("a=" + raw9a)
        eprintln("b=" + raw9b)
        exit(1)
    }
    println("  case9 PASS CLI+bind path candidate generation byte-identical (deterministic mock cycle=1)")
    println("[outside_noise_clm_handler selftest] OK 9/9 PASS (case5 informational, case6 skip-aware)")
    exit(0)
}

// ─── bind axis fire CONTRACT entry ──────────────────────────────────────────
//
// Per dispatch_framework_v1 Section 2 handler_contract:
//   pub fn on_outside_noise_axis_fire(payload_cycle_id: str) -> str (verdict)
//
// Stage0 simplification: BindPayload struct lives in nexus/core/bind/source.hexa
// (separate compilation unit). To avoid cross-file struct dependency in this
// CLI handler (preserving handler standalone runnability per BG-A scope),
// the contract function takes the cycle_id as a string param (the only
// payload field this handler actually uses for dispatch).
//
// Bind router invokes via subprocess `--bind-fire --cycle N` (env-encoded
// payload). This pub function exists for future in-process invocation when
// hexa-lang gains cross-file struct sharing (raw 273 stage1 follow-on).

pub fn on_outside_noise_axis_fire(payload_cycle_id: str) -> str {
    // Map cycle_id "c<N>" → cycle_n integer
    let mut cn = 0
    if len(payload_cycle_id) > 0 {
        if payload_cycle_id.substring(0, 1) == "c" {
            cn = to_int(payload_cycle_id.substring(1, len(payload_cycle_id)))
        } else {
            cn = to_int(payload_cycle_id)
        }
    }
    return _bind_fire_self_probe(cn)
}

// Internal helper: runs the validation pipeline on the mock candidate for
// given cycle_n and returns just the verdict (PASS|REJECT|DRY-RUN). Used by
// both on_outside_noise_axis_fire (bind path) and selftest case 8.
fn _bind_fire_self_probe(cycle_n: i64) -> string {
    let raw = _mock_clm_inference(cycle_n)
    if len(raw) == 0 { return "DRY-RUN" }
    let cand_name = _extract_json_string(raw, "name")
    let cand_desc = _extract_json_string(raw, "description")
    if len(cand_name) == 0 || len(cand_desc) == 0 { return "DRY-RUN" }
    let dup_novel = _falsifier_dup_check(cand_name, cand_desc, [], 0.85)
    let ver_ok = _verifier_empirical(cand_desc)
    let honest_ok = _raw91_honest_c3(raw)
    if !dup_novel || !ver_ok || !honest_ok { return "REJECT" }
    return "PASS"
}

// ─── main ───────────────────────────────────────────────────────────────

fn main() -> void {
    let raw_args = args()
    let mut cli = []
    let mut ai = 2
    let mut _scan = 0
    let _nra = len(raw_args)
    while _scan < _nra {
        let _a = raw_args[_scan]
        let _la = len(_a)
        if _la >= 5 && _a.substring(_la - 5, _la) == ".hexa" {
            ai = _scan + 1
            break
        }
        _scan = _scan + 1
    }
    while ai < len(raw_args) {
        cli.push(raw_args[ai])
        ai = ai + 1
    }

    if len(cli) >= 1 && (cli[0] == "--selftest" || cli[0] == "selftest") {
        _selftest()
    }

    let mut cycle_n: i64 = -1
    let mut mode = "local"
    let mut bind_fire = false  // dual-path: --bind-fire indicates router.fire dispatch
    let mut i = 0
    while i < len(cli) {
        let a = cli[i]
        if a == "--cycle" {
            i = i + 1
            if i >= len(cli) {
                eprintln("__OUTSIDE_NOISE_CLM__ FAIL cycle=? primitive_id= validated=false reason=missing-cycle-arg fix=--cycle <N>")
                exit(2)
            }
            cycle_n = to_int(cli[i])
        } else if a == "--mock" {
            mode = "mock"
        } else if a == "--hf-fallback" {
            mode = "hf"
        } else if a == "--bind-fire" {
            // bind subscriber path marker — pipeline identical to CLI direct path,
            // only emits an extra audit-grade marker for dispatch tracing
            bind_fire = true
        } else if a == "--help" || a == "-h" {
            println("usage: hexa run nexus/tool/handlers/outside_noise_clm_handler.hexa --cycle <N> [--mock] [--hf-fallback] [--bind-fire] [--selftest]")
            println("  exit 0=PASS+ABSORBED  1=PASS+REJECTED  2=CLM_FAIL  3=ABSORB_FAIL")
            println("  --bind-fire: invoked by nexus/core/bind/router.hexa axis dispatch (dispatch_framework_v1 conformant)")
            exit(0)
        } else {
            eprintln("__OUTSIDE_NOISE_CLM__ FAIL cycle=? primitive_id= validated=false reason=unknown-arg-" + a + " fix=--help")
            exit(2)
        }
        i = i + 1
    }
    // bind_fire flag is informational at pipeline stage (no behavior diff).
    // Dispatch tracing marker emitted only when --bind-fire to distinguish
    // CLI vs bind-axis path in markers/ ledger (audit-only; doesn't affect output).
    if bind_fire {
        let _bf = exec("mkdir -p '" + _nexus_root() + "/state/markers' && touch '" + _nexus_root() + "/state/markers/_bind_fire_dispatch_cycle_" + to_string(cycle_n) + ".trace'")
    }

    if cycle_n < 0 {
        eprintln("__OUTSIDE_NOISE_CLM__ FAIL cycle=? primitive_id= validated=false reason=missing-cycle-arg fix=--cycle <N>")
        exit(2)
    }

    // Step 1: load reality_map. Prefer cycle_<N-1>; if missing, walk backward
    // to most recent absorbed cycle (raw#10: rejected cycles do not produce a
    // cycle_<N>.jsonl, so prev_cycle gap-jump is required to preserve graph).
    let mut prev_cycle = if cycle_n > 0 { cycle_n - 1 } else { 0 }
    while prev_cycle > 0 && !_file_exists(_reality_map_path(prev_cycle)) {
        prev_cycle = prev_cycle - 1
    }
    let nodes = _load_reality_map(prev_cycle)
    let last_summary = _last_n_summaries(nodes, 5)

    // Step 2: compose prompt
    let prompt = _compose_prompt(len(nodes), last_summary, cycle_n)

    // Step 3: invoke CLM
    let candidate_raw = _invoke_anima_clm(prompt, mode, cycle_n)
    if len(candidate_raw) == 0 {
        eprintln("__OUTSIDE_NOISE_CLM__ FAIL cycle=" + to_string(cycle_n) + " primitive_id= validated=false reason=clm-empty-output mode=" + mode + " fix=verify CLM availability or use --mock")
        let _ = _emit_marker("kick_clm_outside_noise_handler", "fail", cycle_n)
        exit(2)
    }

    // Step 4: parse
    let cand_name = _extract_json_string(candidate_raw, "name")
    let cand_desc = _extract_json_string(candidate_raw, "description")
    let cand_type = _extract_json_string(candidate_raw, "primitive_type")
    if len(cand_name) == 0 || len(cand_desc) == 0 {
        eprintln("__OUTSIDE_NOISE_CLM__ FAIL cycle=" + to_string(cycle_n) + " primitive_id= validated=false reason=parse-name-or-desc-empty raw=" + candidate_raw + " fix=verify CLM JSON output schema")
        let _ = _emit_marker("kick_clm_outside_noise_handler", "fail", cycle_n)
        exit(2)
    }

    // Step 5: validation
    let dup_novel = _falsifier_dup_check(cand_name, cand_desc, nodes, 0.85)
    let ver_ok = _verifier_empirical(cand_desc)
    let honest_ok = _raw91_honest_c3(candidate_raw)

    let primitive_id = "p_c" + to_string(cycle_n) + "_" + cand_type
    if !dup_novel || !ver_ok || !honest_ok {
        let mut reasons = ""
        if !dup_novel { reasons = reasons + "dup;" }
        if !ver_ok { reasons = reasons + "verifier;" }
        if !honest_ok { reasons = reasons + "honest_c3;" }
        println("__OUTSIDE_NOISE_CLM__ REJECT cycle=" + to_string(cycle_n) + " primitive_id=" + primitive_id + " validated=false reason=" + reasons)
        let _ = _emit_marker("kick_clm_outside_noise_handler", "reject", cycle_n)
        exit(1)
    }

    // Step 6: absorb -> save reality_map
    let new_node = "{\"id\":" + to_string(len(nodes)) + ",\"name\":\"" + json_escape(cand_name) + "\",\"description\":\"" + json_escape(cand_desc) + "\",\"primitive_type\":\"" + cand_type + "\",\"source_cycle\":" + to_string(cycle_n) + ",\"absorbed_at\":\"" + now_utc() + "\"}"
    let mut new_nodes = nodes
    new_nodes.push(new_node)
    let saved = _save_reality_map(cycle_n, new_nodes)
    if !saved {
        eprintln("__OUTSIDE_NOISE_CLM__ FAIL cycle=" + to_string(cycle_n) + " primitive_id=" + primitive_id + " validated=true reason=reality-map-save-fail fix=verify nexus/state/reality_map writable")
        let _ = _emit_marker("kick_clm_outside_noise_handler", "fail", cycle_n)
        exit(3)
    }

    // Step 7: emit omega_cycle witness + atlas absorb
    let witness_path = _emit_omega_cycle_witness(cycle_n, candidate_raw, primitive_id)
    let absorb_rc = _invoke_atlas_absorb_hook(witness_path)
    // absorb_rc != 0 is non-fatal stage0 (opt-out env disables it for safety)

    // Step 8: roadmap entry
    let _ = _emit_roadmap_entry(primitive_id, cand_name, cycle_n)

    // Step 9: marker + sentinel
    let _ = _emit_marker("kick_clm_outside_noise_handler", "pass", cycle_n)
    println("__OUTSIDE_NOISE_CLM__ PASS cycle=" + to_string(cycle_n) + " primitive_id=" + primitive_id + " validated=true")
    exit(0)
}
