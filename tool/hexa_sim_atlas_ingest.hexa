    // nist_atomic (live)
    f.push(["C", "rydberg_constant", "10973731.568 m^-1", "physics_atomic", "10*", "nist_atomic_bridge", "NIST CODATA Rydberg constant", ""])
    f.push(["C", "bohr_radius", "5.29177210903e-11 m", "physics_atomic", "10*", "nist_atomic_bridge", "NIST CODATA Bohr radius", ""])
    f.push(["C", "hartree_energy_eV", "27.211386245988", "physics_atomic", "10*", "nist_atomic_bridge", "NIST CODATA Hartree energy", ""])
    f.push(["F", "carbon_atomic_number", "Z(C) = 6", "chemistry_atomic", "10*", "nist_atomic_bridge", "n=6 L1 anchor — Carbon = 6th element", "carbon_dual_scale"])

    // wikipedia (live)
    f.push(["F", "perfect_number_definition", "n equal to sum of proper divisors; 6 = 1+2+3", "encyclopedic", "10*", "wikipedia_summary_bridge", "Wikipedia Perfect_number canonical definition", "perfect_number_anchor"])

    // openalex (live)
    f.push(["C", "openalex_perfect_number_works", "1889760", "scholarly_metadata", "10*", "openalex_bridge", "papers mentioning 'perfect number' (broad query)", ""])

    // gaia (live + fallback)
    f.push(["F", "gaia_astrometric_dof", "RA + DEC + parallax + pm_RA + pm_DEC + RV = 6", "astrometry", "11*", "gaia_bridge", "n=6 EXACT anchor — Gaia per-star 6D state", ""])

