// ─── existing atlas dedup keys (delta-only) ───
// keys present in atlas.n6 main file — skip if attempt to re-emit

fn _atlas_main_path() -> string {
    let h = env_var("HOME")
    return h + "/core/nexus/n6/atlas.n6"
}

fn _check_dup_in_atlas(id: string) -> bool {
    let path = _atlas_main_path()
    if !file_exists(path) { return false }
    // grep -q exits 0 on match, 1 on no-match; use && / || to emit binary token
    let cmd = "grep -qE '^@[PCFLRSX] " + id + " =' '" + path + "' && echo DUP || echo OK"
    let out = to_string(exec(cmd)).trim()
    if out == "DUP" { return true }
    return false
}

// ─── d5 dup-detection-granular (Tier-1, 2026-04-26 dedup_strategy_evolution ω-cycle) ──
// Returns one of: NOT_PRESENT / EXACT_DUP / ID_ONLY_DUP / VALUE_CONFLICT
// Per-call helper uses grep -nA20 (bounded output ≤21 lines per id) — avoids awk over 21850-line atlas.
// Comparison fields: id (header match), expr (between '= ' and ' :: '), grade (between '[' and ']'),
// edges_csv (canonical "=>{applies};|>{source}" form derived from the new fact).

fn _extract_atlas_entry_block(id: string) -> string {
    let path = _atlas_main_path()
    if !file_exists(path) { return "" }
    // grep -A 20 limits output to 21 lines per id; sed/awk strips at first non-indented line.
    // Use grep then a small awk to truncate at first non-indented line after the header.
    let cmd = "grep -m1 -A 20 -E '^@[PCFLRSX] " + id + " =' '" + path + "' 2>/dev/null | awk 'NR==1{print;next} /^[ \\t]/{print;next} {exit}'"
    return to_string(exec(cmd))
}

fn _parse_header_expr(header: string) -> string {
    // header like: "@C alpha_inv_codata = 137.035999177 :: physics_atomic [10*]"
    let eq_idx = header.index_of(" = ")
    if eq_idx < 0 { return "" }
    let after_eq = header.substring(eq_idx + 3, len(header))
    let domain_idx = after_eq.index_of(" :: ")
    if domain_idx < 0 { return after_eq.trim() }
    return after_eq.substring(0, domain_idx).trim()
}

fn _parse_header_grade(header: string) -> string {
    let lb = header.index_of("[")
    if lb < 0 { return "" }
    let after = header.substring(lb + 1, len(header))
    let rb = after.index_of("]")
    if rb < 0 { return "" }
    return after.substring(0, rb).trim()
}

fn _extract_edges_csv_from_block(block: string) -> string {
    // Walk trailer lines (start with whitespace) — collect "->" "<-" "=>" "==" "~>" "|>" "!!" prefixed.
    if len(block) == 0 { return "" }
    let lines = block.split("\n")
    let mut edges = []
    let mut i = 0
    let nl = len(lines)
    while i < nl {
        let raw = lines[i]
        let line = raw.trim()
        if len(line) == 0 { i = i + 1; continue }
        // skip header line (i==0)
        if i == 0 { i = i + 1; continue }
        if len(line) < 2 { i = i + 1; continue }
        let p2 = line.substring(0, 2)
        if p2 == "->" || p2 == "<-" || p2 == "=>" || p2 == "==" || p2 == "~>" || p2 == "|>" || p2 == "!!" {
            edges.push(line)
        }
        i = i + 1
    }
    return edges.join(";")
}

fn _new_edges_csv_for_fact(applies: string, source: string) -> string {
    // canonical form matching _emit_shard_text trailer pattern
    return "=> " + applies + ";|> " + source + " (live or hardcoded fallback)"
}

fn _check_entry_full_match(id: string, expr: string, grade: string, edges_csv: string) -> string {
    let block = _extract_atlas_entry_block(id)
    if len(block.trim()) == 0 { return "NOT_PRESENT" }
    let lines = block.split("\n")
    if len(lines) == 0 { return "NOT_PRESENT" }
    let header = lines[0]
    let old_expr = _parse_header_expr(header)
    let old_grade = _parse_header_grade(header)
    let old_edges = _extract_edges_csv_from_block(block)
    if old_expr != expr || old_grade != grade { return "VALUE_CONFLICT" }
    if old_edges == edges_csv { return "EXACT_DUP" }
    return "ID_ONLY_DUP"
}

// ─── d2 diff-witness-ledger (Tier-1, 2026-04-26) ─────────────────
fn _diff_history_path() -> string {
    let h = env_var("HOME")
    return h + "/core/nexus/state/atlas_ingest_dup_diff_history.jsonl"
}

fn _last_diff_history_hash() -> string {
    let p = _diff_history_path()
    if !file_exists(p) { return "GENESIS" }
    let cmd = "tail -1 '" + p + "' 2>/dev/null | grep -oE '\"current_hash\":\"[^\"]+\"' | cut -d'\"' -f4"
    let out = to_string(exec(cmd)).trim()
    if len(out) == 0 { return "GENESIS" }
    return out
}

fn _json_escape(s: string) -> string {
    return s.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", " ").replace("\r", " ").replace("\t", " ")
}

fn _append_diff_history(tool: string, id: string, match_type: string, old_value: string, new_value: string, decision: string) {
    let p = _diff_history_path()
    let ts = to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
    let prev = _last_diff_history_hash()
    let payload = "ts=" + ts + "|tool=" + tool + "|id=" + id + "|mt=" + match_type + "|ov=" + old_value + "|nv=" + new_value + "|dec=" + decision + "|prev=" + prev
    let escaped_payload = payload.replace("'", "")
    let cur = to_string(exec("printf %s '" + escaped_payload + "' | (sha256sum 2>/dev/null || shasum -a 256) | cut -c1-16")).trim()
    let line = "{\"ts\":\"" + ts + "\",\"tool\":\"" + tool + "\",\"id\":\"" + _json_escape(id) + "\",\"match_type\":\"" + match_type + "\",\"old_value\":\"" + _json_escape(old_value) + "\",\"new_value\":\"" + _json_escape(new_value) + "\",\"decision\":\"" + decision + "\",\"prev_hash\":\"" + prev + "\",\"current_hash\":\"" + cur + "\"}\n"
    let escaped = line.replace("'", "")
    exec("printf %s '" + escaped + "' >> '" + p + "'")
}

// ─── d1 trailer-only-append (Tier-1, 2026-04-26) ─────────────────
fn _emit_delta_edges_text(fact: array, new_edges: array, ts_date: string) -> string {
    let t = fact[0]
    let id = fact[1]
    let source = fact[5]
    let mut s = "\n# ── delta from " + source + " " + ts_date + " (trailer-only) ──\n"
    s = s + "@" + t + " " + id + " (existing, edges only):\n"
    let mut i = 0
    let n = len(new_edges)
    while i < n {
        s = s + "  " + new_edges[i] + "\n"
        i = i + 1
    }
    return s
}

fn _diff_edges_old_vs_new(old_edges_csv: string, new_edges_csv: string) -> array {
    // Return new edges that are not in old edges_csv; preserve order from new.
    let new_parts = new_edges_csv.split(";")
    let old_parts = old_edges_csv.split(";")
    let mut delta = []
    let mut i = 0
    let n = len(new_parts)
    while i < n {
        let ne = new_parts[i].trim()
        if len(ne) == 0 { i = i + 1; continue }
        let mut found = false
        let mut j = 0
        let m = len(old_parts)
        while j < m {
            if old_parts[j].trim() == ne { found = true; break }
            j = j + 1
        }
        if !found { delta.push(ne) }
        i = i + 1
    }
    return delta
}

// ─── schema-guard (raw 23) — atlas DSL mini-lint ───

fn _valid_type(t: string) -> bool {
    if t == "P" || t == "C" || t == "L" || t == "F" || t == "R" || t == "S" || t == "X" { return true }
    return false
}

fn _valid_grade(g: string) -> bool {
    // grade ∈ {0..11} optionally followed by * (verified), ! (breakthrough), ? (hypothesis)
    if len(g) == 0 { return false }
    let mut i = 0
    let n = len(g)
    let mut digit_seen = false
    while i < n {
        let c = g.substring(i, i + 1)
        if c >= "0" && c <= "9" { digit_seen = true; i = i + 1; continue }
        if c == "*" || c == "!" || c == "?" || c == "." { i = i + 1; continue }
        return false
    }
    return digit_seen
}

fn _validate_fact(fact: array) -> array {
    let t = fact[0]
    let id = fact[1]
    let expr = fact[2]
    let domain = fact[3]
    let grade = fact[4]
    if !_valid_type(t) { return ["FAIL", "invalid type `" + t + "`"] }
    if len(id) == 0 { return ["FAIL", "empty id"] }
    if len(expr) == 0 { return ["FAIL", "empty expr"] }
    if len(domain) == 0 { return ["FAIL", "empty domain"] }
    if !_valid_grade(grade) { return ["FAIL", "invalid grade `" + grade + "`"] }
    return ["OK", ""]
}

// ─── cross-link generation (a11) — multi-source clusters → @X ───

fn _crosslinks() -> array {
    // [crossing_id, expr, domain, grade, members_csv, applies]
    return [
        ["X_n6_perfect_number_3source", "{NIST CODATA + OEIS A000396 + Wikipedia Perfect_number} all corroborate n=6 = smallest perfect number", "foundation_n6", "11*", "alpha_int_n6,perfect_number_first,perfect_number_definition", "3-source corroboration of n=6 anchor"],
        ["X_n6_carbon_dual_scale", "{nist_atomic Z(C)=6} <-> {pubchem benzene/glucose/hexane/graphene C6 ring}", "chemistry_n6", "11*", "carbon_atomic_number,carbon_ring_motif_n6", "carbon = THE n6 element across atomic + molecular scales"],
        ["X_n6_neutrino_dual_anchor", "{6 flavors} <-> {6 PMNS params} (icecube_bridge)", "particle_physics_n6", "11*", "neutrino_flavors,neutrino_pmns_params", "n=6 EXACT in neutrino sector via two independent counts"],
        ["X_n6_SM_fermion_dual_axis", "{6 quarks} <-> {6 leptons} (lhc_bridge)", "particle_physics_n6", "11*", "sm_quark_count,sm_lepton_count", "n=6 anchor in SM via dual generation axes (12 fermions = 2 x n)"],
        ["X_fractional_gap_resonance", "alpha_fractional_gap_pct ~ ns_fractional_gap_pct (3.6% ~ 3.5%)", "framework_anomaly", "10*", "alpha_fractional_gap_pct,ns_fractional_gap_pct", "two independent framework fractional residuals coincide (F10 falsifier)"]
    ]
}

// ─── shard emit ───

fn _shard_path() -> string {
    let h = env_var("HOME")
    return h + "/core/nexus/n6/atlas.append.hexa-sim-bridges.n6"
}

fn _history_path() -> string {
    let h = env_var("HOME")
    return h + "/core/nexus/state/atlas_ingest_history.jsonl"
}

fn _now_iso() -> string {
    return to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
}

fn _hash16(content: string) -> string {
    let escaped = content.replace("'", "")
    let cmd = "printf %s '" + escaped + "' | (sha256sum 2>/dev/null || shasum -a 256) | cut -c1-16"
    return to_string(exec(cmd)).trim()
}

fn _last_history_hash() -> string {
    let p = _history_path()
    if !file_exists(p) { return "GENESIS" }
    let cmd = "tail -1 '" + p + "' 2>/dev/null | grep -oE '\"current_hash\":\"[^\"]+\"' | cut -d'\"' -f4"
    let out = to_string(exec(cmd)).trim()
    if len(out) == 0 { return "GENESIS" }
    return out
}

fn _append_history(added: i64, skipped: i64, total: i64, crosslinks: i64, shard_sha16: string) {
    let p = _history_path()
    let ts = _now_iso()
    let prev = _last_history_hash()
    let payload = "ts=" + ts + "|added=" + to_string(added) + "|skipped=" + to_string(skipped) + "|total=" + to_string(total) + "|cx=" + to_string(crosslinks) + "|shard=" + shard_sha16 + "|prev=" + prev
    let cur = _hash16(payload)
    let line = "{\"ts\":\"" + ts + "\",\"tool\":\"hexa_sim_atlas_ingest\",\"added\":" + to_string(added) + ",\"skipped_dup\":" + to_string(skipped) + ",\"total_known\":" + to_string(total) + ",\"crosslinks\":" + to_string(crosslinks) + ",\"shard_sha16\":\"" + shard_sha16 + "\",\"prev_hash\":\"" + prev + "\",\"current_hash\":\"" + cur + "\"}\n"
    let escaped = line.replace("'", "")
    exec("printf %s '" + escaped + "' >> '" + p + "'")
}

fn _shard_sha16() -> string {
    let p = _shard_path()
    if !file_exists(p) { return "absent" }
    let cmd = "shasum -a 256 '" + p + "' | cut -c1-16"
    return to_string(exec(cmd)).trim()
}

// ─── absorption (axis_a16 NEW — ω-cycle 연동) ───
// shard 의 entries 를 main atlas.n6 에 직접 append.
// guard: 모든 entry id 가 main 에 미존재 확인 후에만 진행 (delta-only).
// 충돌 발견 시 exit 3 (no-op, audit 만 emit).

fn _absorb_check_conflicts(facts: array, crosslinks: array) -> array {
    let mut conflicts = []
    for fact in facts {
        let id = fact[1]
        if _check_dup_in_atlas(id) { conflicts.push("@" + fact[0] + " " + id) }
    }
    for cl in crosslinks {
        let cid = cl[0]
        if _check_dup_in_atlas(cid) { conflicts.push("@X " + cid) }
    }
    return conflicts
}

fn _absorb_to_main_atlas() -> array {
    // returns [status, lines_appended, sha16_after]
    let shard = _shard_path()
    let main = _atlas_main_path()
    if !file_exists(shard) { return ["FAIL_SHARD_MISSING", "0", ""] }
    if !file_exists(main) { return ["FAIL_MAIN_MISSING", "0", ""] }
    // separator + shard body (skip header 11 lines)
    let ts = _now_iso()
    let sep = "\n# ── HEXA-SIM bridges absorption (" + ts + ", shard atlas.append.hexa-sim-bridges.n6) ──\n"
    let cmd_sep = "printf %s '" + sep.replace("'", "") + "' >> '" + main + "'"
    exec(cmd_sep)
    let cmd_body = "tail -n +12 '" + shard + "' >> '" + main + "'"
    exec(cmd_body)
    let cmd_sha = "shasum -a 256 '" + main + "' | cut -c1-16"
    let sha = to_string(exec(cmd_sha)).trim()
    let cmd_lines = "wc -l < '" + shard + "'"
    let lines = to_string(exec(cmd_lines)).trim()
    return ["OK", lines, sha]
}

fn _emit_shard_text(facts_to_add: array, crosslinks_to_add: array) -> string {
    let mut s = "// ═══════════════════════════════════════════════════════════════\n"
    s = s + "// atlas.append.hexa-sim-bridges.n6 — HEXA-SIM 16 bridge tools n=6 facts append\n"
    s = s + "// 작성: 2026-04-26, tool/hexa_sim_atlas_ingest.hexa (deterministic emit)\n"
    s = s + "// 본체 충돌 방지: atlas.n6 직접 편집 대신 본 append 파일에만 기록\n"
    s = s + "// 병합 주체: main context (다음 atlas 통합 phase 에서)\n"
    s = s + "// 전체 건수: " + to_string(len(facts_to_add)) + " 신규 fact + " + to_string(len(crosslinks_to_add)) + " crossing\n"
    s = s + "// 소스 SSOT: design/hexa_sim/README.md + design/hexa_sim/2026-04-26_atlas_ingest_omega_cycle.json\n"
    s = s + "// 등급 정책: hardcoded=[7] EMPIRICAL / live API verified=[10*] / 3-source corroborated=[11*]\n"
    s = s + "// idempotence: same input set → byte-eq output (raw 68)\n"
    s = s + "// schema-guard: raw 23 (atlas DSL grammar mini-lint, exit 2 on violation)\n"
    s = s + "// ═══════════════════════════════════════════════════════════════\n\n"
    s = s + "// ── facts (delta-only — main atlas.n6 에 미존재한 것만) ──\n\n"
    for fact in facts_to_add {
        let t = fact[0]
        let id = fact[1]
        let expr = fact[2]
        let domain = fact[3]
        let grade = fact[4]
        let source = fact[5]
        let applies = fact[6]
        s = s + "@" + t + " " + id + " = " + expr + " :: " + domain + " [" + grade + "]\n"
        s = s + "  => " + applies + "\n"
        s = s + "  |> " + source + " (live or hardcoded fallback)\n\n"
    }
    s = s + "// ── crossings (multi-source → @X, grade elevated) ──\n\n"
    for cx in crosslinks_to_add {
        let cid = cx[0]
        let expr = cx[1]
        let domain = cx[2]
        let grade = cx[3]
        let members = cx[4]
        let applies = cx[5]
        s = s + "@X " + cid + " = " + expr + " :: " + domain + " [" + grade + "]\n"
        s = s + "  <- " + members + "\n"
        s = s + "  => " + applies + "\n\n"
    }
    s = s + "// EOF — total " + to_string(len(facts_to_add)) + " facts + " + to_string(len(crosslinks_to_add)) + " crossings\n"
    return s
}

// ─── runner ───

fn _selftest() {
    // axis_5: schema-guard — every fact valid
    let facts = _facts()
    let mut bad = []
    for fact in facts {
        let v = _validate_fact(fact)
        if v[0] != "OK" { bad.push(fact[1] + ":" + v[1]) }
    }
    if len(bad) > 0 {
        eprintln("[hexa_sim_atlas_ingest selftest] FAIL schema-guard: " + bad.join("; "))
        exit(2)
    }
    // axis_4: idempotence — emit shard text twice, byte-eq
    let cx = _crosslinks()
    let s1 = _emit_shard_text(facts, cx)
    let s2 = _emit_shard_text(facts, cx)
    if s1 != s2 {
        eprintln("[hexa_sim_atlas_ingest selftest] FAIL idempotence: two emit_shard calls produced different output")
        exit(2)
    }
    // axis_a11: cross-link members must reference existing fact ids
    let mut all_ids = []
    for fact in facts { all_ids.push(fact[1]) }
    let mut missing = []
    for cl in cx {
        let members = cl[4]
        let parts = split(members, ",")
        for m in parts {
            let mt = m.trim()
            let mut found = false
            for aid in all_ids { if aid == mt { found = true } }
            if !found { missing.push(cl[0] + " -> " + mt) }
        }
    }
    if len(missing) > 0 {
        eprintln("[hexa_sim_atlas_ingest selftest] FAIL crosslink-orphan: " + missing.join("; "))
        exit(2)
    }
    // ── d5 dup-detection-granular selftest (4-case header parse + edges canonical) ──
    let h_ok = "@C alpha_inv_codata = 137.035999177 :: physics_atomic [10*]"
    let expr_ok = _parse_header_expr(h_ok)
    let grade_ok = _parse_header_grade(h_ok)
    if expr_ok != "137.035999177" || grade_ok != "10*" {
        eprintln("[hexa_sim_atlas_ingest selftest] FAIL header-parse: expr=`" + expr_ok + "` grade=`" + grade_ok + "`")
        exit(2)
    }
    let ec1 = _new_edges_csv_for_fact("apply X", "src_b")
    let ec2 = _new_edges_csv_for_fact("apply X", "src_b")
    if ec1 != ec2 {
        eprintln("[hexa_sim_atlas_ingest selftest] FAIL edges_csv determinism")
        exit(2)
    }
    // delta computation: new edges vs old
    let delta = _diff_edges_old_vs_new("=> a;|> s1", "=> a;|> s1;~> z")
    if len(delta) != 1 || delta[0] != "~> z" {
        eprintln("[hexa_sim_atlas_ingest selftest] FAIL delta-edges computation")
        exit(2)
    }
    let delta_empty = _diff_edges_old_vs_new("=> a;|> s1", "=> a;|> s1")
    if len(delta_empty) != 0 {
        eprintln("[hexa_sim_atlas_ingest selftest] FAIL delta-edges empty case")
        exit(2)
    }
    // d1 trailer-only-append text idempotence
    let dummy_fact = ["F", "test_id", "expr", "domain", "10*", "src", "applies", ""]
    let trailer_a = _emit_delta_edges_text(dummy_fact, ["~> z", "|> new_src"], "2026-04-26")
    let trailer_b = _emit_delta_edges_text(dummy_fact, ["~> z", "|> new_src"], "2026-04-26")
    if trailer_a != trailer_b {
        eprintln("[hexa_sim_atlas_ingest selftest] FAIL trailer-emit byte-eq")
        exit(2)
    }
    // d2 diff-history JSON-escape
    let je = _json_escape("a\"b\\c")
    if je != "a\\\"b\\\\c" {
        eprintln("[hexa_sim_atlas_ingest selftest] FAIL json-escape: got `" + je + "`")
        exit(2)
    }
    // 4-case classification synthesized — block parsing
    let synth_block = "@C testid = 137.0 :: dom [10*]\n  => apply x\n  |> src y (live or hardcoded fallback)\n"
    let lines = synth_block.split("\n")
    if _parse_header_expr(lines[0]) != "137.0" {
        eprintln("[hexa_sim_atlas_ingest selftest] FAIL synth-block expr parse")
        exit(2)
    }
    let synth_edges = _extract_edges_csv_from_block(synth_block)
    if synth_edges != "=> apply x;|> src y (live or hardcoded fallback)" {
        eprintln("[hexa_sim_atlas_ingest selftest] FAIL synth-block edges: got `" + synth_edges + "`")
        exit(2)
    }
    println("[hexa_sim_atlas_ingest selftest] OK — " + to_string(len(facts)) + " facts schema-validated + " + to_string(len(cx)) + " crosslinks members-resolved + idempotent emit byte-eq + d5 4-case (header/edges/synth) + d1 trailer byte-eq + d2 escape")
    exit(0)
}

fn main() -> void {
    let raw_args = args()
    let mut cli = []
    let mut ai = 2
    while ai < len(raw_args) {
        cli.push(raw_args[ai])
        ai = ai + 1
    }
    let mut dry_run = false
    let mut json_summary = false
    let mut absorb = false
    let mut diff_mode = false
    let mut i = 0
    while i < len(cli) {
        let a = cli[i]
        if a == "--selftest" || a == "selftest" { _selftest() }
        else if a == "--dry-run" { dry_run = true }
        else if a == "--absorb" { absorb = true }
        else if a == "--diff" { diff_mode = true }
        else if a == "--json-summary" { json_summary = true }
        else if a == "--help" || a == "-h" {
            println("usage: hexa run tool/hexa_sim_atlas_ingest.hexa [--dry-run] [--absorb] [--diff] [--json-summary] [--selftest]")
            println("modes:")
            println("  --dry-run       emit shard to stdout only (no file write)")
            println("  --absorb        emit shard + merge to main atlas.n6 (ω-cycle 연동, axis_a16)")
            println("  --diff          show 'WOULD add vs already present' (axis_a15)")
            println("  --json-summary  JSON output mode")
            println("  --selftest      schema + idempotence + crosslink check")
            println("audit: state/atlas_ingest_history.jsonl (raw 77 chain hash, axis_a8)")
            println("origin: design/hexa_sim/2026-04-26_atlas_ingest_omega_cycle.json")
            exit(0)
        }
        else {
            eprintln("hexa_sim_atlas_ingest: unknown arg `" + a + "`")
            exit(1)
        }
        i = i + 1
    }

    let all_facts = _facts()
    let all_crosslinks = _crosslinks()

    // axis_3 + d5 — delta-only with 4-category granular detection
    let mut to_add = []
    let mut to_append_edges = []  // [fact, delta_edges_list]
    let mut conflict_pending = []  // [fact, old_expr, old_grade]
    let mut skipped = 0
    let mut grade_dist = ["7=0", "10=0", "11=0"]
    let mut g7 = 0
    let mut g10 = 0
    let mut g11 = 0
    for fact in all_facts {
        let id = fact[1]
        let expr = fact[2]
        let grade = fact[4]
        let new_edges_csv = _new_edges_csv_for_fact(fact[6], fact[5])
        let mt = _check_entry_full_match(id, expr, grade, new_edges_csv)
        if mt == "EXACT_DUP" {
            skipped = skipped + 1
            _append_diff_history("hexa_sim_atlas_ingest", id, "EXACT_DUP", expr, expr, "auto_skip")
            continue
        }
        if mt == "ID_ONLY_DUP" {
            let block = _extract_atlas_entry_block(id)
            let old_edges_csv = _extract_edges_csv_from_block(block)
            let delta = _diff_edges_old_vs_new(old_edges_csv, new_edges_csv)
            if len(delta) > 0 {
                to_append_edges.push([fact, delta])
                _append_diff_history("hexa_sim_atlas_ingest", id, "ID_ONLY_DUP", old_edges_csv, new_edges_csv, "delta_appended")
            } else {
                skipped = skipped + 1
                _append_diff_history("hexa_sim_atlas_ingest", id, "ID_ONLY_DUP", old_edges_csv, new_edges_csv, "auto_skip")
            }
            continue
        }
        if mt == "VALUE_CONFLICT" {
            let block = _extract_atlas_entry_block(id)
            let lines = block.split("\n")
            let old_expr = if len(lines) > 0 { _parse_header_expr(lines[0]) } else { "" }
            let old_grade = if len(lines) > 0 { _parse_header_grade(lines[0]) } else { "" }
            conflict_pending.push([fact, old_expr, old_grade])
            _append_diff_history("hexa_sim_atlas_ingest", id, "VALUE_CONFLICT", old_expr, expr, "manual_pending")
            skipped = skipped + 1
            continue
        }
        // NOT_PRESENT → schema-guard then add
        let v = _validate_fact(fact)
        if v[0] != "OK" {
            eprintln("__ATLAS_INGEST__ FAIL schema-guard violation on `" + id + "`: " + v[1])
            exit(2)
        }
        to_add.push(fact)
        if grade == "7" { g7 = g7 + 1 }
        else if grade.substring(0, 2) == "10" { g10 = g10 + 1 }
        else if grade.substring(0, 2) == "11" { g11 = g11 + 1 }
    }

    let mut shard_text = _emit_shard_text(to_add, all_crosslinks)
    // d1 trailer-only-append: append delta-edges blocks for ID_ONLY_DUP entries
    if len(to_append_edges) > 0 {
        let ts_date = to_string(exec("date -u +%Y-%m-%d")).trim()
        shard_text = shard_text + "\n// ── d1 trailer-only-append (ID_ONLY_DUP entries — header preserved) ──\n"
        let mut ti = 0
        while ti < len(to_append_edges) {
            let pair = to_append_edges[ti]
            shard_text = shard_text + _emit_delta_edges_text(pair[0], pair[1], ts_date)
            ti = ti + 1
        }
    }

    // axis_a15 / d15 — 4-category diff mode (NOT_PRESENT / EXACT_DUP / ID_ONLY_DUP / VALUE_CONFLICT)
    if diff_mode {
        println("=== DIFF MODE (4 categories, d5+d15 dedup_strategy_evolution ω-cycle) ===")
        println("WOULD ADD (NOT_PRESENT, " + to_string(len(to_add)) + "):")
        let mut si = 0
        while si < len(to_add) && si < 3 {
            let f = to_add[si]
            println("  + @" + f[0] + " " + f[1] + " :: " + f[3] + " [" + f[4] + "]")
            si = si + 1
        }
        if len(to_add) > 3 { println("  ... (" + to_string(len(to_add) - 3) + " more)") }
        println("WOULD APPEND EDGES (ID_ONLY_DUP, " + to_string(len(to_append_edges)) + "):")
        si = 0
        while si < len(to_append_edges) && si < 3 {
            let pair = to_append_edges[si]
            let f = pair[0]
            println("  ~ @" + f[0] + " " + f[1] + " (header match, " + to_string(len(pair[1])) + " new edges)")
            si = si + 1
        }
        if len(to_append_edges) > 3 { println("  ... (" + to_string(len(to_append_edges) - 3) + " more)") }
        println("WOULD SKIP (EXACT_DUP, " + to_string(skipped - len(conflict_pending)) + "):")
        // (sample omitted — skipped includes EXACT_DUP + ID_ONLY_DUP-no-delta; explicit category below)
        println("WOULD CONFLICT (VALUE_CONFLICT, " + to_string(len(conflict_pending)) + ") — manual_pending:")
        si = 0
        while si < len(conflict_pending) && si < 3 {
            let row = conflict_pending[si]
            let f = row[0]
            println("  ! @" + f[0] + " " + f[1] + " :: old_expr=`" + row[1] + "` new_expr=`" + f[2] + "`")
            si = si + 1
        }
        if len(conflict_pending) > 3 { println("  ... (" + to_string(len(conflict_pending) - 3) + " more)") }
        println("CROSSLINKS WOULD ADD (" + to_string(len(all_crosslinks)) + "):")
        for cl in all_crosslinks {
            let exists = _check_dup_in_atlas(cl[0])
            let mark = if exists { "= " } else { "+ " }
            println("  " + mark + "@X " + cl[0])
        }
        println("=== / DIFF ===")
        exit(0)
    }

    if dry_run {
        if json_summary {
            println("{")
            println("  \"tool\": \"hexa_sim_atlas_ingest\",")
            println("  \"mode\": \"dry-run\",")
            println("  \"total_known\": " + to_string(len(all_facts)) + ",")
            println("  \"to_add\": " + to_string(len(to_add)) + ",")
            println("  \"skipped_dup\": " + to_string(skipped) + ",")
            println("  \"crosslinks\": " + to_string(len(all_crosslinks)) + ",")
            println("  \"grade_dist\": {\"7\": " + to_string(g7) + ", \"10*\": " + to_string(g10) + ", \"11*\": " + to_string(g11) + "}")
            println("}")
        } else {
            println("=== DRY-RUN — would emit shard ===")
            println(shard_text)
            println("=== / DRY-RUN ===")
        }
        println("__ATLAS_INGEST__ PASS added=" + to_string(len(to_add)) + " skipped_dup=" + to_string(skipped) + " total_known=" + to_string(len(all_facts)) + " crosslinks=" + to_string(len(all_crosslinks)) + " grade_dist=7:" + to_string(g7) + ",10*:" + to_string(g10) + ",11*:" + to_string(g11) + " mode=dry-run")
        exit(0)
    }

    // emit shard file
    let shard = _shard_path()
    write_file(shard, shard_text)

    // axis_a16 — absorb to main atlas.n6 (ω-cycle 연동)
    let mut absorb_status = "shard-only"
    let mut absorb_lines = "0"
    let mut atlas_sha_after = ""
    if absorb {
        let conflicts = _absorb_check_conflicts(to_add, all_crosslinks)
        if len(conflicts) > 0 {
            eprintln("__ATLAS_INGEST__ FAIL absorb conflict (" + to_string(len(conflicts)) + " entries already in main atlas.n6):")
            for c in conflicts { eprintln("  conflict: " + c) }
            eprintln("  reason: shard contains entries already in main — delta-only invariant violated")
            eprintln("  fix: investigate dup ids; either remove from shard OR rename in registry; rerun without --absorb to re-emit shard only")
            exit(3)
        }
        let r = _absorb_to_main_atlas()
        absorb_status = r[0]
        absorb_lines = r[1]
        atlas_sha_after = r[2]
    }

    // axis_a8 — audit-ledger append (every run, ω-cycle 연동)
    let shard_sha = _shard_sha16()
    _append_history(len(to_add), skipped, len(all_facts), len(all_crosslinks), shard_sha)

    if json_summary {
        println("{")
        println("  \"tool\": \"hexa_sim_atlas_ingest\",")
        println("  \"shard\": \"" + shard + "\",")
        println("  \"shard_sha16\": \"" + shard_sha + "\",")
        println("  \"total_known\": " + to_string(len(all_facts)) + ",")
        println("  \"added\": " + to_string(len(to_add)) + ",")
        println("  \"skipped_dup\": " + to_string(skipped) + ",")
        println("  \"crosslinks\": " + to_string(len(all_crosslinks)) + ",")
        println("  \"grade_dist\": {\"7\": " + to_string(g7) + ", \"10*\": " + to_string(g10) + ", \"11*\": " + to_string(g11) + "},")
        println("  \"absorb_status\": \"" + absorb_status + "\",")
        println("  \"atlas_sha_after\": \"" + atlas_sha_after + "\",")
        println("  \"history_path\": \"" + _history_path() + "\"")
        println("}")
    } else {
        println("HEXA-SIM bridge facts → atlas auto-ingest")
        println("---")
        println("  total bridges     : 16 (5 Tier-1 + 11 Tier-2)")
        println("  total facts known : " + to_string(len(all_facts)))
        println("  added to shard    : " + to_string(len(to_add)))
        println("  skipped (dup)     : " + to_string(skipped))
        println("  crosslinks (@X)   : " + to_string(len(all_crosslinks)))
        println("  grade dist        : [7]=" + to_string(g7) + " [10*]=" + to_string(g10) + " [11*]=" + to_string(g11))
        println("  shard path        : " + shard)
        println("  shard sha16       : " + shard_sha)
        println("  absorb status     : " + absorb_status + " (lines_appended=" + absorb_lines + ", main_sha=" + atlas_sha_after + ")")
        println("  history (a8)      : " + _history_path())
    }
    println("__ATLAS_INGEST__ PASS added=" + to_string(len(to_add)) + " skipped_dup=" + to_string(skipped) + " total_known=" + to_string(len(all_facts)) + " crosslinks=" + to_string(len(all_crosslinks)) + " grade_dist=7:" + to_string(g7) + ",10*:" + to_string(g10) + ",11*:" + to_string(g11) + " absorb=" + absorb_status)
    exit(0)
}
