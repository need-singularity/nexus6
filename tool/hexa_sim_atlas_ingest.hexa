#!hexa strict
// tool/hexa_sim_atlas_ingest.hexa — bridge facts → atlas.n6 auto-ingest (Tier-1 7 axes)
//
// @tool(slug="hexa_sim_atlas_ingest", desc="13 bridge tools 의 n=6 anchor facts → atlas.append.hexa-sim-bridges.n6 shard 자동 emit. delta-only + idempotent + schema-validated + graded + cross-linked.")
// @usage(hexa run tool/hexa_sim_atlas_ingest.hexa [--dry-run] [--absorb] [--diff] [--json-summary] [--selftest])
// @exit_codes(0=PASS shard emit/skip, 1=usage/io, 2=schema-guard violation, 3=absorb conflict (existing entry))
// @sentinel(__ATLAS_INGEST__ PASS|FAIL added=N skipped_dup=M total_known=K crosslinks=X grade_dist=...)
// @tier2_axes_added(a8 audit-ledger via state/atlas_ingest_history.jsonl + a15 --diff mode)
// @origin(design/hexa_sim/2026-04-26_atlas_ingest_omega_cycle.json Tier-1 axes a1+a3+a4+a5+a6+a11+a14)
// @abstraction(raw 23 schema-guard + raw 68 byte-eq + raw 70 multi-axis-verify + atlas DSL convention)
// @paradigm(structural — static fact registry, no runtime bridge invocation, deterministic output → byte-eq idempotence)
// @allow-bare-exec
//
// atlas DSL grammar (atlas.n6 v1):
//   @<TYPE> <id> = <expr> :: <domain> [<grade>]
//     <- depends_on / -> derives / => application / == equiv / ~> converges / |> verified / !! breakthrough
//   types: P primitive, C constant, L law, F formula, R relation, S symmetry, X crossing
//   grade: 0-10 + d.r alien index; * verified, ! breakthrough, ? hypothesis

// ─── static fact registry (16 bridges → key n=6 facts) ───
