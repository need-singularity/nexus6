    // icecube (live)
    f.push(["F", "neutrino_flavors", "3 active + 3 antiparticle = 6", "particle_physics", "11*", "icecube_neutrino_bridge", "n=6 EXACT anchor — neutrino sector", "neutrino_dual_anchor"])
