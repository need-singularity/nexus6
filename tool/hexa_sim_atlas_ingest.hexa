    f.push(["C", "alpha_fractional_gap_pct", "0.0262", "physics_atomic", "10*", "codata_bridge", "% deviation alpha_codata vs alpha_int_n6 (~17 sigma structural offset)", ""])

    // oeis_live (live)
    f.push(["F", "perfect_number_first", "OEIS A000396[1] = 6", "number_theory", "11*", "oeis_live_bridge", "smallest perfect number — n=6 anchor 외부 검증", "perfect_number_anchor"])
    f.push(["F", "sigma_a000203_n6", "OEIS A000203[6] = 12 = sigma(6)", "number_theory", "11*", "oeis_live_bridge", "divisor sum at n=6 cross-check", ""])

    // gw_observatory (live)
    f.push(["C", "gw_events_total_2026", "263", "astrophysics_gw", "10*", "gw_observatory_bridge", "GWOSC GWTC catalog cumulative event count", ""])
    f.push(["C", "gw_first_event_GW150914", "binary BH merger m1=35.6 m2=30.6 d_L=440Mpc", "astrophysics_gw", "10*", "gw_observatory_bridge", "first GW direct detection 2015-09-14", ""])

    // horizons (live)
    f.push(["F", "tp8_mars_2g_4d_falsified", "Mars max sep 2.67 AU < required 3.92 AU at 2g for 4d", "framework_falsifier", "10*", "horizons_bridge", "TP-8 prediction empirically broken (F9 falsifier)", ""])

    // cmb_planck (live)
    f.push(["C", "h0_planck_2018", "67.36 km/s/Mpc", "cosmology", "10*", "cmb_planck_bridge", "Planck 2018 base-LCDM Hubble constant", ""])
    f.push(["C", "ns_planck_2018", "0.965", "cosmology", "10*", "cmb_planck_bridge", "scalar spectral index", ""])
    f.push(["C", "ns_fractional_gap_pct", "3.50", "cosmology", "10*", "cmb_planck_bridge", "% deviation from Harrison-Zel'dovich n_s=1", "fractional_gap_resonance"])

