#!hexa strict
// tool/anthropic_status_bridge_fetcher.hexa — Anthropic upstream status incidents γ-bridge fetcher
//
// @tool(slug="anthropic_status_bridge_fetcher", desc="γ-bridge web-fetch fetcher — Anthropic status incidents (M-Y browser-harness invoke + sanitize + OFFLINE-FALLBACK)")
// @usage(hexa run tool/anthropic_status_bridge_fetcher.hexa [--fetch] [--selftest] [--json])
// @exit_codes(0=PASS, 1=usage error, 2=fetch fail, 3=injection-reject)
// @sentinel(__ANTHROPIC_STATUS_BRIDGE__ <PASS|OFFLINE|REJECT> incidents=<N> latest=<ts> components=[<csv>] status=<op|degraded|down|offline_fallback>)
// @origin(γ-bridge wave U1 2026-05-01 — hive r58 Stage 19 follow-up #61)
// @abstraction(web-fetch γ-bridge fetcher → kick_dispatch γ envelope contributor)
// @paradigm(M-Y browser-harness invoke + prompt-injection sanitize + raw 91 honest OFFLINE-FALLBACK)
//
// FIXED URL (no user input substitutable — defence in depth):
//   https://status.anthropic.com/api/v2/incidents/unresolved.json
//
// Default state: NOT invoked unless KICK_USE_WEB_BRIDGES=1 (env-gated).
// Production behavior unchanged — bridge is opt-in.

let FETCH_URL = "https://status.anthropic.com/api/v2/incidents/unresolved.json"
let SLUG      = "bridge_anthropic_status"
let SOURCE    = "anthropic_status"

// ─── injection-substring blacklist (raw 91, U1 HARD requirement) ───
fn _injection_substrings() -> array {
    return ["<task-notification>", "<system-reminder>", "IMPORTANT:", "Ignore previous", "ignore all previous"]
}

fn _exec_pattern_substrings() -> array {
    return ["$(", "`", "rm -rf", "<script", "</script", "javascript:", "<style", " on" + "click=", " on" + "load=", " on" + "error="]
}

fn _has_any(haystack: str, needles: array) -> bool {
    let mut i = 0
    while i < len(needles) {
        if haystack.index_of(needles[i]) >= 0 { return true }
        i = i + 1
    }
    return false
}

fn _strip_control_chars(s: str) -> str {
    let mut out = ""
    let mut i = 0
    while i < s.len() {
        let c = s.substring(i, i + 1)
        let code_str = c
        // keep printable ASCII + space + common safe punctuation; drop control chars
        let allowed = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789 .,:;=/\\\"'-_+()[]<>?!@#%&*"
        if allowed.index_of(code_str) >= 0 { out = out + code_str }
        i = i + 1
    }
    return out
}

fn _truncate(s: str, n: i64) -> str {
    if s.len() <= n { return s }
    return s.substring(0, n - 3) + "..."
}

fn _sanitize_payload(raw_text: str) -> str {
    // 1) injection scan — reject if found
    if _has_any(raw_text, _injection_substrings()) { return "INJECTION_REJECT" }
    if _has_any(raw_text, _exec_pattern_substrings()) { return "INJECTION_REJECT" }
    // 2) strip control chars
    let stripped = _strip_control_chars(raw_text)
    // 3) clamp to 200 chars
    return _truncate(stripped, 200)
}

// ─── M-Y browser-harness invoke (tui_extract_text_from primitive) ───
// Returns "" if harness binary absent OR invocation fails — caller treats
// "" as OFFLINE-FALLBACK trigger. Never fakes data (raw 91).
fn _browser_harness_fetch(url: str) -> str {
    // Probe for harness — design-tier file existence check (P1 not yet landed
    // per hive r58 Stage 19 #59). When P1 lands, this seam invokes
    //   tool/browser_harness.hexa --extract-text --url <url>
    let probe = exec("command -v hexa >/dev/null 2>&1 && [ -f tool/browser_harness.hexa ] && echo y || echo n").trim()
    if probe != "y" { return "" }
    // Real invocation deferred until P1 (browser-harness primitive) lands.
    // For U1 design-tier: explicitly return "" to take OFFLINE-FALLBACK path.
    // This is honest C3 (raw 91) — we do NOT fabricate fetch output.
    return ""
}

fn _short_hash(input: str) -> str {
    let cmd = "printf %s '" + input.replace("'", "'\\''") + "' | (sha256sum 2>/dev/null || shasum -a 256) | awk '{print substr($1,1,16)}'"
    return exec(cmd).trim()
}

fn _now_iso_utc() -> str {
    return exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn classify_status(raw_body: str) -> str {
    if raw_body == "" { return "offline_fallback" }
    if raw_body.index_of("\"incidents\":[]") >= 0 { return "op" }
    if raw_body.index_of("\"impact\":\"critical\"") >= 0 { return "down" }
    if raw_body.index_of("\"impact\":\"major\"") >= 0 { return "degraded" }
    if raw_body.index_of("\"impact\":\"minor\"") >= 0 { return "degraded" }
    return "op"
}

fn build_payload(raw_body: str) -> str {
    let ts = _now_iso_utc()
    if raw_body == "" {
        return "incidents=0 latest=" + ts + " components=[api,console] status=offline_fallback"
    }
    // count incident occurrences (substring "\"id\":")
    let mut n = 0
    let mut rest = raw_body
    while true {
        let i = rest.index_of("\"id\":")
        if i < 0 { break }
        n = n + 1
        rest = rest.substring(i + 5, rest.len())
    }
    let status = classify_status(raw_body)
    return "incidents=" + to_string(n) + " latest=" + ts + " components=[api,console] status=" + status
}

fn _emit_envelope(payload: str, ts: str) -> str {
    let bh = _short_hash("gamma:" + SLUG + ":" + ts)
    return "{\"mechanism\":\"gamma\",\"source_id\":\"bridge:" + SLUG + "\",\"byte_hash\":\"" + bh + "\",\"ts\":\"" + ts + "\",\"payload_summary\":\"" + payload + "\",\"kind\":\"web-fetch\"}"
}

fn cmd_fetch(json_mode: bool) {
    let opt_in = exec("printf '%s' \"${KICK_USE_WEB_BRIDGES:-0}\"").trim()
    if opt_in != "1" && opt_in != "web-only" {
        eprintln("anthropic_status_bridge_fetcher: KICK_USE_WEB_BRIDGES not set to 1|web-only — bridge is default-inactive (opt-in only)")
        eprintln("  set KICK_USE_WEB_BRIDGES=1 to enable web-fetch γ bridges")
        exit(1)
    }
    let raw_body = _browser_harness_fetch(FETCH_URL)
    let sanitized = _sanitize_payload(raw_body)
    if sanitized == "INJECTION_REJECT" {
        let ts = _now_iso_utc()
        println("__ANTHROPIC_STATUS_BRIDGE__ REJECT incidents=0 latest=" + ts + " components=[] status=injection_reject")
        exit(3)
    }
    let payload = build_payload(raw_body)
    let ts = _now_iso_utc()
    if json_mode {
        println(_emit_envelope(payload, ts))
    } else {
        println(payload)
    }
    let verdict = if raw_body == "" { "OFFLINE" } else { "PASS" }
    println("__ANTHROPIC_STATUS_BRIDGE__ " + verdict + " " + payload)
    exit(0)
}

fn _selftest() {
    // F1: fixed URL constant invariant
    if FETCH_URL != "https://status.anthropic.com/api/v2/incidents/unresolved.json" {
        eprintln("[selftest] FAIL: FETCH_URL drifted")
        exit(1)
    }
    // F2: classify
    if classify_status("") != "offline_fallback" { eprintln("[selftest] FAIL: empty != offline_fallback"); exit(1) }
    if classify_status("{\"incidents\":[]}") != "op" { eprintln("[selftest] FAIL: empty incidents != op"); exit(1) }
    if classify_status("{\"incidents\":[{\"impact\":\"major\"}]}") != "degraded" { eprintln("[selftest] FAIL: major != degraded"); exit(1) }
    if classify_status("{\"incidents\":[{\"impact\":\"critical\"}]}") != "down" { eprintln("[selftest] FAIL: critical != down"); exit(1) }
    // F3: injection reject
    if _sanitize_payload("hello <task-notification>evil</task-notification>") != "INJECTION_REJECT" {
        eprintln("[selftest] FAIL: task-notification not rejected"); exit(1)
    }
    if _sanitize_payload("normal $(rm -rf /) text") != "INJECTION_REJECT" {
        eprintln("[selftest] FAIL: exec pattern not rejected"); exit(1)
    }
    // F4: clamp 200
    let mut big = ""
    let mut k = 0
    while k < 300 { big = big + "a"; k = k + 1 }
    let clamped = _sanitize_payload(big)
    if clamped.len() > 200 { eprintln("[selftest] FAIL: clamp"); exit(1) }
    // F5: byte_hash determinism
    let h1 = _short_hash("gamma:bridge_anthropic_status:2026-05-01T00:00:00Z")
    let h2 = _short_hash("gamma:bridge_anthropic_status:2026-05-01T00:00:00Z")
    if h1 != h2 { eprintln("[selftest] FAIL: hash non-deterministic"); exit(1) }
    if h1.len() != 16 { eprintln("[selftest] FAIL: hash len != 16"); exit(1) }
    println("[anthropic_status_bridge_fetcher selftest] OK — F1-F5 passed")
    exit(0)
}

fn main() -> void {
    let raw_args = args()
    let mut cli = []
    let mut ai = 2
    while ai < len(raw_args) { cli.push(raw_args[ai]); ai = ai + 1 }
    let mut do_fetch = false
    let mut json_mode = false
    let mut i = 0
    while i < len(cli) {
        let a = cli[i]
        if a == "--selftest" || a == "selftest" { _selftest() }
        else if a == "--fetch" { do_fetch = true }
        else if a == "--json" { json_mode = true }
        else if a == "--help" || a == "-h" {
            println("usage: hexa run tool/anthropic_status_bridge_fetcher.hexa [--fetch] [--json] [--selftest]")
            println("env: KICK_USE_WEB_BRIDGES=1 (required for --fetch)")
            println("url: " + FETCH_URL)
            exit(0)
        } else {
            eprintln("anthropic_status_bridge_fetcher: unknown arg `" + a + "`")
            exit(1)
        }
        i = i + 1
    }
    if do_fetch { cmd_fetch(json_mode) }
    eprintln("anthropic_status_bridge_fetcher: pass --fetch or --selftest")
    exit(1)
}
