// rule_suggest.hexa — GOV-P8-1 AI 자동 룰 제안 엔진
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
//
// Pattern mining: mistakes.jsonl + lint_log.jsonl 반복 위반 패턴 분석
// Rule proposal: 동일 위반 3+ 회 -> 신규 룰 제안 자동 생성
// Binary encoding: 룰 bit-flag 인덱스 O(1) lookup
// Dedup: 기존 common.json + nexus.json 대조
//
// Usage:
//   hexa shared/tool/rule_suggest.hexa suggest [--threshold N]
//   hexa shared/tool/rule_suggest.hexa suggest --apply
//   hexa shared/tool/rule_suggest.hexa encode
//   hexa shared/tool/rule_suggest.hexa status
//
// Output: shared/tool/rule_suggest_staging.jsonl (proposals)
//         shared/tool/rule_binary_index.json (binary encoding)

let REPO = exec("git rev-parse --show-toplevel 2>/dev/null").trim()  // @allow-bare-exec
let SHARED = REPO + "/shared"
let HARNESS = SHARED + "/harness"
let MISTAKES_PATH = HARNESS + "/mistakes.jsonl"
let LINT_LOG_PATH = HARNESS + "/lint_log.jsonl"
let COMMON_PATH = SHARED + "/rules/common.json"
let NEXUS_PATH = SHARED + "/rules/nexus.json"
let STAGING_PATH = HARNESS + "/rule_suggest_staging.jsonl"
let BINARY_INDEX_PATH = HARNESS + "/rule_binary_index.json"
let DEFAULT_THRESHOLD = 3
let SCAN_WINDOW = 500

fn now_iso() -> string {
    return exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()  // @allow-bare-exec
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    return r
}

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

// ─── tail N lines from file (avoids loading entire file) ───
fn tail_lines(path: string, n: i64) -> [string] {
    let mut raw = ""
    try {
        raw = exec("tail -n " + to_string(n) + " '" + path + "' 2>/dev/null").trim()  // @allow-bare-exec
    } catch e {}
    if len(raw) == 0 { return [] }
    return raw.split("\n")
}

// ─── Extract "rule" field from a JSONL line (fast string parse) ───
fn extract_field(line: string, field: string) -> string {
    let key = "\"" + field + "\":\""
    let idx = line.index_of(key)
    if idx < 0 { return "" }
    let start = idx + len(key)
    let rest = line.substring(start, len(line))
    let end = rest.index_of("\"")
    if end < 0 { return "" }
    return rest.substring(0, end)
}

// ─── Load all existing rule IDs from common.json + nexus.json ───
fn load_existing_rule_ids() -> map {
    let mut ids = #{}
    // common.json — parse rule IDs
    let mut common_raw = ""
    try { common_raw = read_file(COMMON_PATH) } catch e {}
    if len(common_raw) > 0 {
        let common_lines = common_raw.split("\n")
        for cl in common_lines {
            let rid = extract_field(cl, "id")
            if len(rid) > 0 { ids[rid] = true }
        }
    }
    // nexus.json
    let mut nexus_raw = ""
    try { nexus_raw = read_file(NEXUS_PATH) } catch e {}
    if len(nexus_raw) > 0 {
        let nexus_lines = nexus_raw.split("\n")
        for nl in nexus_lines {
            let rid = extract_field(nl, "id")
            if len(rid) > 0 { ids[rid] = true }
        }
    }
    return ids
}

// ─── Mine patterns from mistakes.jsonl ───
// Returns map of "rule" -> count
fn mine_mistakes(window: i64) -> map {
    let lines = tail_lines(MISTAKES_PATH, window)
    let mut counts = #{}
    for line in lines {
        let rule = extract_field(line, "rule")
        if len(rule) == 0 { continue }
        let mut cur = 0
        try { cur = counts[rule] } catch e {}
        counts[rule] = cur + 1
    }
    return counts
}

// ─── Mine patterns from lint_log.jsonl violations ───
// Returns map of "rule" -> count
fn mine_lint_violations(window: i64) -> map {
    let lines = tail_lines(LINT_LOG_PATH, window)
    let mut counts = #{}
    for line in lines {
        // lint_log has violations array — extract rule names
        let viol_key = "\"rule\":\""
        let mut search_from = 0
        let line_len = len(line)
        while search_from < line_len {
            let rest = line.substring(search_from, line_len)
            let idx = rest.index_of(viol_key)
            if idx < 0 { break }
            let start = idx + len(viol_key)
            let after = rest.substring(start, len(rest))
            let end = after.index_of("\"")
            if end < 0 { break }
            let rule = after.substring(0, end)
            if len(rule) > 0 {
                let mut cur = 0
                try { cur = counts[rule] } catch e {}
                counts[rule] = cur + 1
            }
            search_from = search_from + idx + start + end + 1
        }
    }
    return counts
}

// ─── Merge two count maps ───
fn merge_counts(a: map, b: map) -> map {
    let mut merged = #{}
    let a_keys = keys(a)
    for k in a_keys {
        merged[k] = a[k]
    }
    let b_keys = keys(b)
    for k in b_keys {
        let mut prev = 0
        try { prev = merged[k] } catch e {}
        merged[k] = prev + b[k]
    }
    return merged
}

fn severity_from_count(c: i64) -> string {
    if c >= 20 { return "error" }
    if c >= 10 { return "warn" }
    return "info"
}

// ─── Generate proposals for violations above threshold ───
fn generate_proposals(threshold: i64) -> [map] {
    let mistake_counts = mine_mistakes(SCAN_WINDOW)
    let lint_counts = mine_lint_violations(SCAN_WINDOW)
    let merged = merge_counts(mistake_counts, lint_counts)
    let existing = load_existing_rule_ids()

    let mut proposals = []
    let mut idx = 1
    let rule_names = keys(merged)
    for rname in rule_names {
        let count = merged[rname]
        if count < threshold { continue }
        // dedup: skip if rule already exists in common/nexus
        let mut already_exists = false
        try { already_exists = existing[rname] == true } catch e {}
        if already_exists { continue }
        let proposal = #{
            "id": "H-SUGGEST-" + to_string(idx),
            "source_pattern": rname,
            "occurrences": count,
            "severity": severity_from_count(count),
            "title": "Auto-detected recurring violation: " + rname,
            "description": "Pattern '" + rname + "' hit " + to_string(count) + "x in last " + to_string(SCAN_WINDOW) + " entries",
            "auto_fix": false,
            "status": "proposed",
            "ts": now_iso()
        }
        proposals = proposals.push(proposal)
        idx = idx + 1
    }
    return proposals
}

// ─── Encode rules as binary bit-flag index ───
fn encode_binary_index() -> string {
    let mut common_raw = ""
    try { common_raw = read_file(COMMON_PATH) } catch e {}
    let mut rule_ids = []
    let mut bit_map = #{}
    let common_lines = common_raw.split("\n")
    let mut bit_pos = 0
    for cl in common_lines {
        let rid = extract_field(cl, "id")
        if len(rid) == 0 { continue }
        // avoid duplicates
        let mut already = false
        try { already = bit_map[rid] != "" } catch e {}
        if already { continue }
        bit_map[rid] = to_string(bit_pos)
        rule_ids = rule_ids.push(rid)
        bit_pos = bit_pos + 1
    }
    // nexus rules
    let mut nexus_raw = ""
    try { nexus_raw = read_file(NEXUS_PATH) } catch e {}
    let nexus_lines = nexus_raw.split("\n")
    for nl in nexus_lines {
        let rid = extract_field(nl, "id")
        if len(rid) == 0 { continue }
        let mut already = false
        try { already = bit_map[rid] != "" } catch e {}
        if already { continue }
        bit_map[rid] = to_string(bit_pos)
        rule_ids = rule_ids.push(rid)
        bit_pos = bit_pos + 1
    }
    // Build JSON output
    let mut json = "{\n"
    json = json + "  \"_meta\": {\"description\": \"Binary rule index — bit flags for O(1) rule-check\", \"total_rules\": " + to_string(bit_pos) + ", \"ts\": \"" + now_iso() + "\"},\n"
    json = json + "  \"encoding\": \"bit_position: rule_id (R0=bit0, R1=bit1...)\",\n"
    json = json + "  \"index\": {\n"
    let mut i = 0
    for rid in rule_ids {
        let comma = ""
        if i > 0 { json = json + ",\n" }
        json = json + "    \"" + json_escape(rid) + "\": " + to_string(i)
        i = i + 1
    }
    json = json + "\n  },\n"
    // Compute hex bitmask for "all rules active"
    let hex_words = (bit_pos + 63) / 64
    json = json + "  \"total_bits\": " + to_string(bit_pos) + ",\n"
    json = json + "  \"hex_words_needed\": " + to_string(hex_words) + ",\n"
    // Severity groups for fast filtering
    json = json + "  \"severity_groups\": {\n"
    json = json + "    \"critical\": [\"R7\", \"R10\", \"R11\", \"R28\", \"R29\"],\n"
    json = json + "    \"error\": [\"R1\", \"R2\", \"R3\", \"R12\", \"R14\", \"R19\", \"R20\", \"R21\"],\n"
    json = json + "    \"warn\": [\"R0\", \"R13\", \"R18\", \"R23\", \"R36\"]\n"
    json = json + "  }\n"
    json = json + "}\n"
    return json
}

// ─── Status: show rule coverage ───
fn show_status() {
    let existing = load_existing_rule_ids()
    let existing_keys = keys(existing)
    let total_existing = len(existing_keys)

    let mistake_counts = mine_mistakes(SCAN_WINDOW)
    let lint_counts = mine_lint_violations(SCAN_WINDOW)
    let merged = merge_counts(mistake_counts, lint_counts)

    let merged_keys = keys(merged)
    let mut covered = 0
    let mut uncovered = 0
    let mut uncovered_list = []
    for rname in merged_keys {
        let mut is_existing = false
        try { is_existing = existing[rname] == true } catch e {}
        if is_existing {
            covered = covered + 1
        } else {
            uncovered = uncovered + 1
            uncovered_list = uncovered_list.push(rname)
        }
    }

    let mut staging_count = 0
    if file_exists(STAGING_PATH) { staging_count = len(tail_lines(STAGING_PATH, 1000)) }
    let mut index_fresh = "missing"
    if file_exists(BINARY_INDEX_PATH) { index_fresh = "present" }

    println("=== Rule Suggest Status ===")
    println("existing rules (common+nexus):  " + to_string(total_existing))
    println("violation patterns (last " + to_string(SCAN_WINDOW) + "): " + to_string(len(merged_keys)))
    println("  covered by existing rules:    " + to_string(covered))
    println("  uncovered (suggest candidates):" + to_string(uncovered))
    println("staging proposals:              " + to_string(staging_count))
    println("binary index:                   " + index_fresh)
    if uncovered > 0 {
        println("--- uncovered patterns ---")
        for u in uncovered_list {
            let count = merged[u]
            println("  " + u + "  (" + to_string(count) + " hits)")
        }
    }
    println("__HARNESS_RULE_SUGGEST__ STATUS_OK")
}

// ─── Suggest mode: analyze + output proposals ───
fn cmd_suggest(threshold: i64, apply: bool) {
    println("[rule_suggest] scanning last " + to_string(SCAN_WINDOW) + " entries, threshold=" + to_string(threshold))
    let proposals = generate_proposals(threshold)

    if len(proposals) == 0 {
        println("[rule_suggest] no new proposals — all patterns below threshold or already covered")
        println("__HARNESS_RULE_SUGGEST__ SUGGEST_CLEAN")
        return
    }

    println("[rule_suggest] found " + to_string(len(proposals)) + " candidate(s):")
    for p in proposals {
        println("  " + _str(p["id"]) + "  pattern=" + _str(p["source_pattern"]) + "  hits=" + to_string(p["occurrences"]) + "  severity=" + _str(p["severity"]))
    }

    if apply {
        // Write to staging file (append)
        let mut lines = ""
        for p in proposals {
            let line = "{\"id\":\"" + json_escape(_str(p["id"])) + "\""
                + ",\"source_pattern\":\"" + json_escape(_str(p["source_pattern"])) + "\""
                + ",\"occurrences\":" + to_string(p["occurrences"])
                + ",\"severity\":\"" + json_escape(_str(p["severity"])) + "\""
                + ",\"title\":\"" + json_escape(_str(p["title"])) + "\""
                + ",\"description\":\"" + json_escape(_str(p["description"])) + "\""
                + ",\"auto_fix\":" + to_string(p["auto_fix"])
                + ",\"status\":\"proposed\""
                + ",\"ts\":\"" + json_escape(_str(p["ts"])) + "\"}\n"
            lines = lines + line
        }
        try {
            append_file(STAGING_PATH, lines)
            println("[rule_suggest] wrote " + to_string(len(proposals)) + " proposals to staging: " + STAGING_PATH)
        } catch e {
            print_err("[rule_suggest] ERROR writing staging: " + to_string(e))
        }
        println("__HARNESS_RULE_SUGGEST__ APPLY_OK")
    } else {
        println("[rule_suggest] dry run — use --apply to write to staging")
        println("__HARNESS_RULE_SUGGEST__ SUGGEST_OK")
    }
}

// ─── Encode mode: generate binary index ───
fn cmd_encode() {
    println("[rule_suggest] generating binary rule index...")
    let json = encode_binary_index()
    try {
        write_file(BINARY_INDEX_PATH, json)
        println("[rule_suggest] binary index written: " + BINARY_INDEX_PATH)
    } catch e {
        print_err("[rule_suggest] ERROR writing binary index: " + to_string(e))
    }
    println("__HARNESS_RULE_SUGGEST__ ENCODE_OK")
}

// ─── CLI router ───
let argv = args()
let argc = len(argv)

if argc < 1 {
    println("usage: hexa rule_suggest.hexa <suggest [--threshold N] [--apply]|encode|status>")
    exit(1)
}

let mode = _str(argv[0])

if mode == "suggest" {
    let mut threshold = DEFAULT_THRESHOLD
    let mut apply = false
    let mut i = 1
    while i < argc {
        let arg = _str(argv[i])
        if arg == "--threshold" && (i + 1) < argc {
            try { threshold = to_int(argv[i + 1]) } catch e {}
            i = i + 2
            continue
        }
        if arg == "--apply" {
            apply = true
        }
        i = i + 1
    }
    cmd_suggest(threshold, apply)
} else if mode == "encode" {
    cmd_encode()
} else if mode == "status" {
    show_status()
} else {
    print_err("[rule_suggest] unknown mode: " + mode)
    println("usage: hexa rule_suggest.hexa <suggest|encode|status>")
    exit(1)
}
