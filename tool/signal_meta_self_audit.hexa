// signal_meta_self_audit.hexa — K1 Self-audit
// atlas.signals.n6 생성 패턴 자체를 signal화 (G1 signal-of-signals)
// prefix 버스트 Top 3 + 일일 생성률 peak → staging append
// 실행: hexa run $NEXUS/tool/signal_meta_self_audit.hexa

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let SIGNALS = NEXUS + "/n6/atlas.signals.n6"
let STAGE = NEXUS + "/n6/staging/atlas.signals.staging.meta.n6"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    let mut v: i64 = 0
    try { v = to_int(first) } catch e { v = 0 }
    return v
}

fn now_iso() -> string {
    let r = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    return _str(r).trim()
}

fn grep_count(pat: string) -> i64 {
    let cmd = "{ grep -c -E '" + pat + "' '" + SIGNALS + "' 2>/dev/null || true; }"
    let r = exec(cmd)
    return _to_int0(_str(r).trim().split("\n")[0])
}

fn grep_count_date(date: string) -> i64 {
    let cmd = "{ grep -c 'discovered_at: " + date + "' '" + SIGNALS + "' 2>/dev/null || true; }"
    let r = exec(cmd)
    return _to_int0(_str(r).trim().split("\n")[0])
}

// ─── 메인 ───
if file_exists(SIGNALS) == false {
    println("FAIL: atlas.signals.n6 없음")
    exit(1)
}

println("signal_meta_self_audit: " + now_iso())

let total = grep_count("^@S SIG-")
println("  총 signals = " + to_string(total))

// 오늘 날짜
let today_cmd = "date -u +%Y-%m-%d"
let today = _str(exec(today_cmd)).trim().split("\n")[0]

// 어제
let yest_cmd = "date -u -v-1d +%Y-%m-%d 2>/dev/null || date -u -d '1 day ago' +%Y-%m-%d"
let yest = _str(exec(yest_cmd)).trim().split("\n")[0]

let today_count = grep_count_date(today)
let yest_count = grep_count_date(yest)

println("  오늘(" + today + ") = " + to_string(today_count))
println("  어제(" + yest + ") = " + to_string(yest_count))

// 메타 signal: 일일 생성 가속도
let accel = today_count - yest_count
let label = if accel > 5 { "burst" } else if accel > 0 { "steady" } else { "decay" }
println("  가속도 = " + to_string(accel) + " → " + label)

// staging append 생성
let sig_id = "SIG-META-700"
let stmt = "signal 생성률 " + today + "=" + to_string(today_count) + " vs " + yest + "=" + to_string(yest_count) + " → " + label
let grade = if accel > 5 { "M7!" } else { "M7" }

let block = "@S " + sig_id + " = " + stmt + " :: signal [NX,CROSS] [META,GAP] [" + grade + "] [E2]\n" +
            "  \"K1 self-audit 메타 signal. signal 생성 패턴 자체 signal화. accel=" + to_string(accel) + " today=" + to_string(today_count) + " yest=" + to_string(yest_count) + "\"\n" +
            "  refs: [nexus:shared/tool/signal_meta_self_audit.hexa]\n" +
            "  predicts: [\"생성률 ≥5 이면 2 세션 내 M10 승격 signal 최소 1건\"]\n" +
            "  witness: 1\n" +
            "  resonance_n6: null\n" +
            "  discovered_in: nexus/session-meta-k1\n" +
            "  discovered_at: " + now_iso() + "\n" +
            "  <- K1 self-audit autonomous\n\n"

// append to staging
let cmd = "cat >> '" + STAGE + "' << 'EOF'\n" + block + "EOF"
exec(cmd)
println("  → staging append: " + STAGE)
println("PASS: K1 self-audit 완료")
