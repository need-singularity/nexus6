// py_ban_guard.hexa — R37/AN13/L3-PY staged .py 차단
// (2026-04-18 BG 에이전트 pod2 위반 사고 재발 방지)
// @allow-bare-exec
//
// Usage:
//   hexa $NEXUS/tool/py_ban_guard.hexa check-staged
//     → staged 에 .py 있으면 exit 1 + 사유 출력
//   hexa $NEXUS/tool/py_ban_guard.hexa check-cmd '<bash cmd>'
//     → 명령어에 python/.py 실행·전송·원격실행 패턴 있으면 exit 1
//
// 연동:
//   .git/hooks/pre-commit — check-staged 호출
//   .claude/settings.json PreToolUse Bash — check-cmd 백업 (인라인 grep 이 1차)
//   shared/agent_templates/no_py_guardrail.md — 에이전트 프롬프트 연결

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    // argv[0]=hexa, argv[1]=script-path, argv[2]=mode, argv[3]=arg
    if argv.len() < 3 {
        eprintln("usage: py_ban_guard.hexa <check-staged|check-cmd> [arg]")
        exit(2)
    }

    let mode = argv[2]

    if mode == "check-staged" {
        check_staged()
    } else if mode == "check-cmd" {
        if argv.len() < 4 {
            eprintln("check-cmd needs command string")
            exit(2)
        }
        check_cmd(argv[3])
    } else {
        eprintln("unknown mode: " + mode)
        exit(2)
    }
}

// git diff --cached --name-only 에서 .py 탐지
fn check_staged() {
    let raw = to_string(exec("git diff --cached --name-only --diff-filter=ACM 2>/dev/null")).trim()  // @allow-bare-exec
    let mut violations: [string] = []
    if raw != "" {
        for ln in raw.split("\n") {
            let s = to_string(ln).trim()
            if s.len() > 0 {
                if s.ends_with(".py") {
                    violations = violations.push(s)
                }
            }
        }
    }
    if violations.len() > 0 {
        eprintln("[py_ban_guard] BLOCK — R37/AN13/L3-PY: staged .py 발견")
        for v in violations {
            eprintln("    " + v)
        }
        eprintln("")
        eprintln("  fix: git reset HEAD <file> 로 unstage + .hexa 재작성")
        eprintln("  refs: CLAUDE.md / common.json#R37 / anima.json#AN13 / lockdown.json#L3-PY")
        exit(1)
    }
    exit(0)
}

// 명령어 패턴 검사 — 훅 백업 로직 (hexa fallback)
fn check_cmd(cmd: string) {
    let trimmed = cmd.trim()

    // 단순 조회는 허용 (prefix 매치)
    let allow_prefix = ["which ", "type ", "command -v ", "ls ", "grep ", "rg ", "find ", "wc ", "stat ", "file ", "head ", "tail ", "cat "]
    for p in allow_prefix {
        if trimmed.starts_with(p) {
            exit(0)
        }
    }

    // python 실행 (토큰 경계 매치)
    if contains_token(cmd, "python3") || contains_token(cmd, "python") || contains_token(cmd, "pypy") {
        deny(cmd, "python 실행 금지")
    }
    // .py 직접
    if cmd.contains(".py ") || cmd.ends_with(".py") {
        deny(cmd, ".py 실행/전송 금지")
    }
    // scp/rsync/runpodctl
    if cmd.contains("scp ") && cmd.contains(".py") {
        deny(cmd, "scp .py 전송 금지")
    }
    if cmd.contains("rsync ") && cmd.contains(".py") {
        deny(cmd, "rsync .py 전송 금지")
    }
    if cmd.contains("runpodctl") && (cmd.contains(".py") || cmd.contains("python")) {
        deny(cmd, "runpodctl .py/python 금지")
    }
    // ssh 원격 python
    if trimmed.starts_with("ssh ") && (cmd.contains("python") || cmd.contains(".py")) {
        deny(cmd, "ssh 원격 python 금지")
    }
    // git add .py
    if cmd.contains("git add") && cmd.contains(".py") {
        deny(cmd, ".py git add 금지")
    }
    exit(0)
}

fn contains_token(haystack: string, token: string) -> bool {
    // 간단 토큰 매치 — 앞뒤 공백/파이프/세미콜론 경계
    let padded = " " + haystack + " "
    let candidates = [" " + token + " ", " " + token + "\n", ";" + token + " ", "|" + token + " ", "&" + token + " "]
    for c in candidates {
        if padded.contains(c) {
            return true
        }
    }
    return false
}

fn deny(cmd: string, reason: string) {
    eprintln("[py_ban_guard] BLOCK — R37/AN13/L3-PY: " + reason)
    eprintln("    cmd: " + cmd)
    eprintln("    refs: .claude/settings.json PreToolUse Bash + common.json#R37 + anima.json#AN13")
    exit(1)
}
