// E4_dfs_autonomous_engine.hexa — DFS 자율 엔진 (gap 검출 → dispatch 권장)
//
// 자가성장 카테고리 E4. 본 엔진은 자율적으로:
//   1. atlas.signals.n6 의 최근 라운드 (R26+) 의 axis 분포를 측정
//   2. 부족한 axis 식별 (gap)
//   3. 권장 dispatch 큐를 출력 (실행은 사람 승인)
//
// 사용:
//   hexa run shared/tool/E4_dfs_autonomous_engine.hexa
//   hexa run shared/tool/E4_dfs_autonomous_engine.hexa --json
//
// 산출:
//   shared/n6/signals/E4_dispatch_recommendation.jsonl  (--json 모드)
// 정직: dispatch 권장 만 — 자동 실행 금지 (R0).
// 7난제 해결 0/7 유지.

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let SIGNALS = NEXUS + "/n6/atlas.signals.n6"
let OUT = NEXUS + "/n6/signals/E4_dispatch_recommendation.jsonl"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn now_ts() -> string {
    let r = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    return _str(r).trim()
}

// 7난제 axis tags 카운트 — atlas.signals.n6 전체
fn count_axis(tag: string) -> i64 {
    if file_exists(SIGNALS) == false { return 0 }
    let cmd = "grep -c '" + tag + "' '" + SIGNALS + "' 2>/dev/null || echo 0"
    let r = exec(cmd)
    let mut v: i64 = 0
    try { v = to_int(_str(r).trim()) } catch e { v = 0 }
    return v
}

// 메가시그니처 카운트 (signal 본문에 키워드 출현)
fn count_keyword(kw: string) -> i64 {
    if file_exists(SIGNALS) == false { return 0 }
    let cmd = "grep -c '" + kw + "' '" + SIGNALS + "' 2>/dev/null || echo 0"
    let r = exec(cmd)
    let mut v: i64 = 0
    try { v = to_int(_str(r).trim()) } catch e { v = 0 }
    return v
}

// gap 점수: 평균 - 본 axis 카운트 (양수 = 부족)
fn gap_score(c: i64, mean: i64) -> i64 {
    return mean - c
}

// ─── 메인 ───
let a = args()
let mut json_mode: i64 = 0
let mut idx: i64 = 0
while idx < a.len() {
    if a[idx] == "--json" { json_mode = 1 }
    idx = idx + 1
}

println("E4_dfs_autonomous_engine: ts=" + now_ts() + " json=" + to_string(json_mode))

if file_exists(SIGNALS) == false {
    println("  FAIL: signals 파일 없음 — " + SIGNALS)
    exit(1)
}

let axes = ["7R", "7N", "7H", "7P", "7B", "7Y", "7Po"]
let names = ["RH", "Navier-Stokes", "Hodge", "P-vs-NP", "BSD", "Yang-Mills", "Poincare"]

let mut counts = []
let mut total: i64 = 0
let mut i: i64 = 0
while i < axes.len() {
    let c = count_axis(axes[i])
    counts = counts + [c]
    total = total + c
    i = i + 1
}

let mean = total / axes.len()
println("  total axis tag matches: " + to_string(total) + ", mean per axis: " + to_string(mean))

// gap 분석
let mut recommendations = []
i = 0
while i < axes.len() {
    let c = counts[i]
    let g = gap_score(c, mean)
    let urgency = if g >= mean / 3 { "HIGH" } else if g > 0 { "MID" } else { "LOW" }
    let line = "  axis=" + axes[i] + " (" + names[i] + ") count=" + to_string(c) + " gap=" + to_string(g) + " urgency=" + urgency
    println(line)
    if g > 0 {
        let rec = "{\"ts\":\"" + now_ts() + "\",\"axis\":\"" + axes[i] + "\",\"name\":\"" + names[i] +
                  "\",\"count\":" + to_string(c) + ",\"gap\":" + to_string(g) +
                  ",\"urgency\":\"" + urgency + "\",\"action\":\"권장: DFS 다음 라운드에서 본 axis 우선 후보 생성\"}"
        recommendations = recommendations + [rec]
    }
    i = i + 1
}

// 메가시그니처 분포
let megs = ["σ·φ", "σ-sopfr", "J_2", "K(2)", "Out(S_6)"]
let mut mi: i64 = 0
println("  -- 메가시그니처 분포 --")
while mi < megs.len() {
    let kc = count_keyword(megs[mi])
    println("    " + megs[mi] + ": " + to_string(kc))
    mi = mi + 1
}

println("  ─── 권장 dispatch ───")
let mut ri: i64 = 0
while ri < recommendations.len() {
    println("  rec[" + to_string(ri) + "]: " + recommendations[ri])
    ri = ri + 1
}

if json_mode == 1 {
    let mut buf: string = ""
    let mut k: i64 = 0
    while k < recommendations.len() {
        buf = buf + recommendations[k] + "\n"
        k = k + 1
    }
    write_file(OUT, buf)
    println("  recommendations written: " + OUT)
}

println("PASS: E4 자율 엔진 — " + to_string(recommendations.len()) + " dispatch 권장 (0~7 axis), 자동 실행 금지 (R0). 7난제 0/7 유지.")
