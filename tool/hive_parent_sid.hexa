// tool/hive_parent_sid.hexa — opaque parent-SID minter for unattended kick contexts.
//
// @tool(slug="hive_parent_sid", desc="emit a usable HIVE_PARENT_SID for kick_dispatch.hexa / subagent_dispatch.hexa when running outside an interactive hive session. The SID is an opaque relay-namespace identifier (used to form /tmp/subagent-relay-<parent>-<child>.fifo paths and state entry blocks); hive's subagent_dispatch.hexa does not validate it against any registry — it is a positional argument string. Resolves carry-forward (b) from 2026-04-26 fanout #6 (bench-orchestrator-smoke).")
// @usage(hexa /Users/ghost/core/nexus/tool/hive_parent_sid.hexa [--persist] [--prefix <slug>])
// @usage(  HIVE_PARENT_SID=$(hexa run /Users/ghost/core/nexus/tool/hive_parent_sid.hexa) hexa run /Users/ghost/core/nexus/tool/kick_bench.hexa "<topic>")
// @exit_codes(0=ok, 1=usage/io)
// @sentinel(stdout: <sid> on success; stderr: reason=<slug> fix=<directive> on failure)
// @origin(design/kick/2026-04-27_bench-orchestrator-smoke-claude-codex_omega_cycle.json step_3 path_A)
// @raw_8_compliance(hexa-only — no .py/.sh/.rs/.toml; new file is .hexa)
//
// Scope (intentionally narrow):
//   - mints an opaque SID; that's it.
//   - does NOT validate hive infrastructure (port pool, slot pool, claude_code availability).
//   - does NOT register with any control plane (hive's subagent_dispatch.hexa
//     uses parent_sid as an opaque relay namespace key, not a registry lookup —
//     verified by Read of hive/tool/subagent_dispatch.hexa lines 305-314, 583, 627).
//   - does NOT bypass the gate semantically: the SID it emits is honest
//     (kick-self prefix advertises that the bench orchestrator is its own parent;
//     not a fabricated SID claiming to be something else).
//
// Honesty:
//   - resolves the env-gate at kick_dispatch.hexa:878-880 only.
//   - downstream success (actual subagent spawn, slot allocation, child completion)
//     remains a separate question and depends on hive infra availability.

fn _now_unix_s() -> i64 {
    let s = exec("date +%s").trim()
    let mut v: i64 = 0
    try { v = to_int(s) } catch e { v = 0 }
    return v
}

fn _hex8() -> str {
    // 8 hex chars from /dev/urandom; portable (no python).
    let h = exec("od -vN 4 -An -tx1 /dev/urandom 2>/dev/null | tr -d ' \\n'").trim()
    if h.len() == 0 { return "00000000" }
    return h
}

fn _file_exists(path: str) -> bool {
    return exec("test -f '" + path + "' && echo y || echo n").trim() == "y"
}

fn _ensure_dir(path: str) { let _ = exec("mkdir -p '" + path + "'") }

fn _nexus_root() -> str {
    let n = env("NEXUS")
    if n.len() > 0 { return n }
    let home = env("HOME")
    let candidates = [home + "/core/nexus", "/root/core/nexus", "/home/nexus"]
    let mut i: i64 = 0
    while i < len(candidates) {
        if _file_exists(candidates[i] + "/cli/run.hexa") { return candidates[i] }
        i = i + 1
    }
    return home + "/core/nexus"
}

fn _persist_path() -> str {
    return _nexus_root() + "/state/kick/parent_sid.txt"
}

fn _mint(prefix: str) -> str {
    let pfx = if prefix.len() > 0 { prefix } else { "kick-self" }
    return pfx + "-" + to_string(_now_unix_s()) + "-" + _hex8()
}

fn main() {
    let argv = args()
    let mut persist = false
    let mut prefix = ""
    let mut i: i64 = 0
    while i < argv.len() {
        let a = argv[i]
        if a == "--persist" { persist = true; i = i + 1; continue }
        if a == "--prefix" { if i + 1 < argv.len() { prefix = argv[i + 1] }; i = i + 2; continue }
        if a == "--help" || a == "-h" {
            println("usage: hexa run tool/hive_parent_sid.hexa [--persist] [--prefix <slug>]")
            println("  --persist    also write SID to state/kick/parent_sid.txt for sentinel-file fallback")
            println("  --prefix S   override default 'kick-self' prefix (e.g. --prefix bench-self)")
            println("  default: emit SID to stdout only; no side effects")
            exit(0)
        }
        i = i + 1
    }

    let sid = _mint(prefix)
    if sid.len() == 0 {
        eprintln("reason=mint-empty fix=check date and /dev/urandom availability")
        exit(1)
    }

    if persist {
        let p = _persist_path()
        let dir_end = p.last_index_of("/")
        if dir_end > 0 { _ensure_dir(p.substring(0, dir_end)) }
        write_file(p, sid + "\n")
    }

    println(sid)
    exit(0)
}
