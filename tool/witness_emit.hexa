#!hexa strict
// tool/witness_emit.hexa — canonical helper: write ω-cycle witness JSON + auto-absorb.
//
// @tool(slug="witness_emit", desc="canonical write+absorb helper for *omega_cycle*.json witnesses. ALL ω-cycle emitters under <core>/{nexus,CANON,anima} should call emit_witness(path, body) instead of writing the JSON directly. Atomically writes the file then invokes omega_cycle_atlas_ingest --witness <abs> so atlas.n6 absorbs in the same process. Triad layer 2 (agent-level) of own:atlas-absorb-mandatory — NOT a hook, just a single canonical entry point.")
// @usage(hexa run tool/witness_emit.hexa --selftest)
// @usage(hexa run tool/witness_emit.hexa --emit <abs_path> --body-file <abs_path> [--source <slug>])
// @usage(hexa run tool/witness_emit.hexa --validate <witness.json>)
// @omega-converge(witness="fixpoint-convergence", attempts=1, attempt_log="own:atlas-absorb-mandatory triad layer 2: write + absorb in one call. Fixpoint = file_exists(path) AND ingest rc==0.")
// @exit_codes(0=PASS, 1=usage/io, 2=ingest failure)
// @sentinel(__WITNESS_EMIT__ <PASS|FAIL> path=<...> shard=<...> absorbed=<true|false>)
//
// claude-dependency: NONE — this tool runs without Claude Code session active.
// hooks: NONE — no claude hooks, no git hooks, no fswatch. Caller invokes the
//   exported emit_witness fn (or the CLI --emit form) explicitly. Bypass is
//   detected by tool/atlas_absorb_lint.hexa (triad layer 3).
//
// raw 66 trailers on every error path (reason=<slug> fix=<directive>).
// raw 80 sentinel: __WITNESS_EMIT__ <PASS|FAIL> path=<path> shard=<path> absorbed=<bool>.

fn _core_root() -> string {
    let override = env_var("NEXUS_CORE_ROOT")
    if len(override) > 0 { return override }
    let h = env_var("HOME")
    return h + "/core"
}

fn _ingest_tool_path() -> string {
    return _core_root() + "/nexus/tool/omega_cycle_atlas_ingest.hexa"
}

fn _atlas_main_path() -> string {
    return _core_root() + "/nexus/n6/atlas.n6"
}

fn _shell_quote(s: string) -> string {
    let mut r = s.replace("'", "'\\''")
    return "'" + r + "'"
}

fn _basename_no_ext(path: string) -> string {
    let cmd = "basename '" + path + "' .json"
    return to_string(exec(cmd)).trim()
}

// Mirror omega_cycle_atlas_ingest._slugify_cycle (raw 65 idempotence).
fn _slugify_cycle(witness_path: string) -> string {
    let base = _basename_no_ext(witness_path)
    let mut s = base
    if len(s) > 11 {
        let dash1 = s.substring(4, 5)
        let dash2 = s.substring(7, 8)
        let under = s.substring(10, 11)
        if dash1 == "-" && dash2 == "-" && under == "_" {
            s = s.substring(11, len(s))
        }
    }
    let suffix = "_omega_cycle"
    if len(s) > len(suffix) {
        let tail = s.substring(len(s) - len(suffix), len(s))
        if tail == suffix { s = s.substring(0, len(s) - len(suffix)) }
    }
    let mut out = ""
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "_" { out = out + "-" } else { out = out + c }
        i = i + 1
    }
    return out
}

fn _shard_path_for(cycle_slug: string) -> string {
    return _core_root() + "/nexus/n6/atlas.append." + cycle_slug + ".n6"
}

fn _is_omega_cycle_witness(path: string) -> bool {
    if path.index_of("omega_cycle") < 0 { return false }
    let n = len(path)
    if n < 5 { return false }
    let tail = path.substring(n - 5, n)
    if tail != ".json" { return false }
    return true
}

fn _sha256_file(path: string) -> string {
    let cmd = "(sha256sum " + _shell_quote(path) + " 2>/dev/null || shasum -a 256 " + _shell_quote(path) + " 2>/dev/null) | cut -c1-64"
    return to_string(exec(cmd)).trim()
}

// ─── canonical emit_witness ──────────────────────────────────────
//
// Returns array: [verdict, path, sha256, shard_path, absorbed_bool_str, errors_csv]
//   verdict ∈ {"PASS", "FAIL"}
//   absorbed ∈ {"true", "false"}
//
// Atomic semantics: write file → call ingest --witness → return verdict.
// If ingest fails, emit_witness returns FAIL with absorbed=false; caller
// decides whether to surface as error or continue. No partial-write rollback
// (raw 77 append-only — emitted witness JSON is itself the audit record).
//
// PUBLIC ENTRY POINT — all ω-cycle emitters MUST go through this fn.

pub fn emit_witness(path: string, body: string) -> array {
    return emit_witness_with_source(path, body, "unknown")
}

pub fn emit_witness_with_source(path: string, body: string, source: string) -> array {
    let mut errors = []

    if !_is_omega_cycle_witness(path) {
        errors.push("not_omega_cycle_witness_path")
        return ["FAIL", path, "", "", "false", errors.join(",")]
    }

    // ensure parent dir exists
    let dir_end = path.last_index_of("/")
    if dir_end > 0 {
        let dir = path.substring(0, dir_end)
        let _ = exec("mkdir -p " + _shell_quote(dir))
    }

    // write the witness JSON
    write_file(path, body)

    let test_w = to_string(exec("test -f '" + path + "' && echo y || echo n")).trim()
    if test_w != "y" {
        errors.push("write_failed")
        return ["FAIL", path, "", "", "false", errors.join(",")]
    }

    let sha = _sha256_file(path)
    let cycle_slug = _slugify_cycle(path)
    let shard = _shard_path_for(cycle_slug)

    // invoke ingest tool (single-witness scope, idempotent)
    let ingest = _ingest_tool_path()
    let test_i = to_string(exec("test -f '" + ingest + "' && echo y || echo n")).trim()
    if test_i != "y" {
        errors.push("ingest-tool-missing")
        return ["FAIL", path, sha, shard, "false", errors.join(",")]
    }
    let cmd = "env HEXA_RESOLVER_NO_REROUTE=1 hexa run " + _shell_quote(ingest) + " --witness " + _shell_quote(path) + " 2>&1; echo __RC=$?"
    let out = to_string(exec(cmd))
    // OUTER rc — first line after __RC= (avoid trailing __HEXA_RC= bleed-in).
    let rc_idx = out.last_index_of("__RC=")
    let mut rc_str = "0"
    if rc_idx >= 0 {
        let outer_tail = out.substring(rc_idx + 5, len(out)).trim()
        let nl_o = outer_tail.index_of("\n")
        rc_str = if nl_o >= 0 { outer_tail.substring(0, nl_o).trim() } else { outer_tail }
    }
    // INNER rc — hexa.real-appended __HEXA_RC=N. Carry-forward from
    // kick_bench.hexa post-fix (2d40c170). Outer rc=0 + inner rc!=0 must
    // still gate to FAIL or sub-runtime failures silently absorb-pass.
    let hkey = "__HEXA_RC="
    let hi = out.last_index_of(hkey)
    let mut inner_rc_str = "0"
    if hi >= 0 {
        let h_tail = out.substring(hi + len(hkey), len(out)).trim()
        let mut he: i64 = 0
        while he < len(h_tail) {
            let hc = h_tail.substring(he, he + 1)
            if hc == " " || hc == "\n" || hc == "\t" || hc == "_" { break }
            he = he + 1
        }
        inner_rc_str = h_tail.substring(0, he).trim()
        if len(inner_rc_str) == 0 { inner_rc_str = "0" }
    }
    if rc_str != "0" {
        errors.push("ingest-rc-" + rc_str)
        return ["FAIL", path, sha, shard, "false", errors.join(",")]
    }
    if inner_rc_str != "0" {
        errors.push("ingest-inner-rc-" + inner_rc_str)
        return ["FAIL", path, sha, shard, "false", errors.join(",")]
    }

    // detect already-absorbed (idempotent re-emit) vs newly-absorbed
    let absorbed_str = if out.index_of("__OMEGA_CYCLE_ATLAS_INGEST__ SKIP") >= 0 { "true" } else { "true" }
    // Both SKIP (already-absorbed) and PASS (newly-absorbed) qualify as
    // absorbed=true from the rule's perspective. Distinction is observable
    // via the ingest tool's own sentinel in its stdout.

    let _suppress_unused_source = source
    return ["PASS", path, sha, shard, absorbed_str, ""]
}

// ─── validate ────────────────────────────────────────────────────
//
// Schema: omega_cycle.witness_v1 — closes the LLM-side enforcement gap
// where __KICK_RESULT__ PASS was emitted with schema-violating witnesses
// (raw 71 falsifier-retire-rule + raw 48 multi-axis-orthogonal-witness).
//
// Required non-empty fields (7 total):
//   1. core_5_op_kernel.intake.alpha_absorbed   (non-empty str | non-null map)
//   2. core_5_op_kernel.intake.beta_qrng        (non-empty)
//   3. core_5_op_kernel.intake.gamma_bridge     (non-empty)
//   4. core_5_op_kernel.falsifiers_preregistered  (array len >= 5)
//   5. core_5_op_kernel.fan_out.axis_a          (non-empty)
//   6. core_5_op_kernel.fan_out.axis_b          (non-empty)
//   7. core_5_op_kernel.fan_out.correlation_lt_0_7  (bool true)
//
// Returns array: [verdict, field_pass, field_total, first_fail_field, fail_slug]
//   verdict ∈ {"PASS", "FAIL"}

fn _is_nonempty_value(v: any) -> bool {
    let t = type_of(v)
    if t == "void" || t == "null" { return false }
    if t == "string" { return len(to_string(v)) > 0 }
    if t == "map" {
        let ks = dict_keys(v)
        return len(ks) > 0
    }
    if t == "array" { return len(v) > 0 }
    if t == "int" || t == "float" || t == "bool" { return true }
    return false
}

fn _get_path(obj: any, path: string) -> any {
    if type_of(obj) != "map" { return void }
    let segs = path.split(".")
    let mut cur = obj
    let mut i = 0
    while i < len(segs) {
        let s = segs[i]
        if s == "" { i = i + 1; continue }
        if type_of(cur) != "map" { return void }
        if !has_key(cur, s) { return void }
        cur = cur[s]
        i = i + 1
    }
    return cur
}

// Returns array: [verdict, field_pass(int), field_total(int), fail_field, fail_slug]
fn _validate_witness(path: string) -> array {
    let total = 7
    let test_p = to_string(exec("test -f '" + path + "' && echo y || echo n")).trim()
    if test_p != "y" {
        return ["FAIL", 0, total, "<file>", "witness-file-missing"]
    }
    let raw = to_string(read_file(path))
    if len(raw) == 0 {
        return ["FAIL", 0, total, "<file>", "witness-file-empty"]
    }
    let parsed = json_parse(raw)
    if type_of(parsed) != "map" {
        return ["FAIL", 0, total, "<root>", "witness-not-json-object"]
    }

    let mut pass_ct = 0

    // 1. intake.alpha_absorbed
    let v_alpha = _get_path(parsed, "core_5_op_kernel.intake.alpha_absorbed")
    if !_is_nonempty_value(v_alpha) {
        return ["FAIL", pass_ct, total, "core_5_op_kernel.intake.alpha_absorbed", "alpha-absorbed-empty-or-missing"]
    }
    pass_ct = pass_ct + 1

    // 2. intake.beta_qrng
    let v_beta = _get_path(parsed, "core_5_op_kernel.intake.beta_qrng")
    if !_is_nonempty_value(v_beta) {
        return ["FAIL", pass_ct, total, "core_5_op_kernel.intake.beta_qrng", "beta-qrng-empty-or-missing"]
    }
    pass_ct = pass_ct + 1

    // 3. intake.gamma_bridge
    let v_gamma = _get_path(parsed, "core_5_op_kernel.intake.gamma_bridge")
    if !_is_nonempty_value(v_gamma) {
        return ["FAIL", pass_ct, total, "core_5_op_kernel.intake.gamma_bridge", "gamma-bridge-empty-or-missing"]
    }
    pass_ct = pass_ct + 1

    // 4. falsifiers_preregistered (array len >= 5)
    let v_fals = _get_path(parsed, "core_5_op_kernel.falsifiers_preregistered")
    if type_of(v_fals) != "array" {
        return ["FAIL", pass_ct, total, "core_5_op_kernel.falsifiers_preregistered", "falsifiers-preregistered-empty-or-missing"]
    }
    if len(v_fals) < 5 {
        return ["FAIL", pass_ct, total, "core_5_op_kernel.falsifiers_preregistered", "falsifiers-preregistered-empty-or-missing"]
    }
    pass_ct = pass_ct + 1

    // 5. fan_out.axis_a
    let v_axa = _get_path(parsed, "core_5_op_kernel.fan_out.axis_a")
    if !_is_nonempty_value(v_axa) {
        return ["FAIL", pass_ct, total, "core_5_op_kernel.fan_out.axis_a", "axis-a-empty-or-missing"]
    }
    pass_ct = pass_ct + 1

    // 6. fan_out.axis_b
    let v_axb = _get_path(parsed, "core_5_op_kernel.fan_out.axis_b")
    if !_is_nonempty_value(v_axb) {
        return ["FAIL", pass_ct, total, "core_5_op_kernel.fan_out.axis_b", "axis-b-empty-or-missing"]
    }
    pass_ct = pass_ct + 1

    // 7. fan_out.correlation_lt_0_7 == true (bool)
    let v_corr = _get_path(parsed, "core_5_op_kernel.fan_out.correlation_lt_0_7")
    if type_of(v_corr) != "bool" {
        return ["FAIL", pass_ct, total, "core_5_op_kernel.fan_out.correlation_lt_0_7", "correlation-lt-0-7-empty-or-missing"]
    }
    if v_corr != true {
        return ["FAIL", pass_ct, total, "core_5_op_kernel.fan_out.correlation_lt_0_7", "correlation-lt-0-7-empty-or-missing"]
    }
    pass_ct = pass_ct + 1

    return ["PASS", pass_ct, total, "", ""]
}

fn _fix_directive_for(slug: string) -> string {
    if slug == "alpha-absorbed-empty-or-missing" {
        return "set core_5_op_kernel.intake.alpha_absorbed to a non-empty seed/source id (e.g. 'absorbed:<witness_slug>')"
    }
    if slug == "beta-qrng-empty-or-missing" {
        return "set core_5_op_kernel.intake.beta_qrng to qrng_byte_hash or 'urandom-fallback:<hash>'"
    }
    if slug == "gamma-bridge-empty-or-missing" {
        return "set core_5_op_kernel.intake.gamma_bridge to bridge slug (e.g. 'bridge:bridge_uniprot')"
    }
    if slug == "falsifiers-preregistered-empty-or-missing" {
        return "pre-register >=5 falsifier entries under core_5_op_kernel.falsifiers_preregistered (raw 71)"
    }
    if slug == "axis-a-empty-or-missing" {
        return "set core_5_op_kernel.fan_out.axis_a to non-empty axis slug (raw 48 multi-axis)"
    }
    if slug == "axis-b-empty-or-missing" {
        return "set core_5_op_kernel.fan_out.axis_b to non-empty axis slug orthogonal to axis_a (raw 48)"
    }
    if slug == "correlation-lt-0-7-empty-or-missing" {
        return "compute axis-A vs axis-B correlation; set core_5_op_kernel.fan_out.correlation_lt_0_7=true only if |r|<0.7"
    }
    if slug == "witness-file-missing" {
        return "verify --validate <abs_path>; file does not exist"
    }
    if slug == "witness-file-empty" {
        return "witness JSON file is empty; re-emit via tool/witness_emit.hexa --emit"
    }
    if slug == "witness-not-json-object" {
        return "witness file is not a JSON object; rewrite as omega_cycle.witness_v1 schema"
    }
    return "inspect witness against omega_cycle.witness_v1 schema"
}

fn _emit_validate_sentinel(verdict: string, path: string, pass_ct: i64, total: i64) -> void {
    println("__WITNESS_VALIDATE__ " + verdict + " path=" + path + " field_pass=" + to_string(pass_ct) + " field_total=" + to_string(total))
}

// CLI entry: --validate <witness.json> path. Exits non-zero on FAIL.
fn _run_validate(witness_path: string) -> void {
    let r = _validate_witness(witness_path)
    let verdict = to_string(r[0])
    let pass_ct = to_int(r[1])
    let total = to_int(r[2])
    let fail_field = to_string(r[3])
    let fail_slug = to_string(r[4])
    if verdict == "PASS" {
        _emit_validate_sentinel("PASS", witness_path, pass_ct, total)
        exit(0)
    }
    // raw 66 trailer to stderr
    eprintln("reason=" + fail_slug + ": " + fail_field + "-empty-or-missing")
    eprintln("fix=" + _fix_directive_for(fail_slug))
    _emit_validate_sentinel("FAIL", witness_path, pass_ct, total)
    exit(3)
}

// ─── selftest ────────────────────────────────────────────────────

fn _selftest_validate() -> void {
    println("[witness_emit selftest --validate]")

    // PASS fixture: minimal compliant witness_v1
    let pass_path = "/tmp/witness_pass_fixture.json"
    let pass_body = "{\"schema\":\"omega_cycle.witness_v1\",\"core_5_op_kernel\":{\"intake\":{\"alpha_absorbed\":\"seed:test\",\"beta_qrng\":\"hash:abc\",\"gamma_bridge\":\"bridge:test\"},\"falsifiers_preregistered\":[{\"id\":\"F1\"},{\"id\":\"F2\"},{\"id\":\"F3\"},{\"id\":\"F4\"},{\"id\":\"F5\"}],\"fan_out\":{\"axis_a\":\"A\",\"axis_b\":\"B\",\"correlation_lt_0_7\":true}}}"
    write_file(pass_path, pass_body)
    let pr = _validate_witness(pass_path)
    let pass_verdict = to_string(pr[0])
    let pass_field_pass = to_int(pr[1])

    // FAIL fixture: known schema-violating witness from yesterday's kicks
    let fail_path = _core_root() + "/nexus/design/kick/2026-04-27_cp2-closure_omega_cycle.json"
    let test_f = to_string(exec("test -f '" + fail_path + "' && echo y || echo n")).trim()
    if test_f != "y" {
        eprintln("reason=fail-fixture-missing: " + fail_path + "-empty-or-missing")
        eprintln("fix=verify cp2-closure witness exists at " + fail_path)
        println("__WITNESS_VALIDATE_SELFTEST__ FAIL correct=0/2")
        exit(2)
    }
    let fr = _validate_witness(fail_path)
    let fail_verdict = to_string(fr[0])
    let fail_slug = to_string(fr[4])

    let mut correct = 0
    if pass_verdict == "PASS" && pass_field_pass == 7 { correct = correct + 1 }
    if fail_verdict == "FAIL" { correct = correct + 1 }

    println("[witness_emit selftest --validate] PASS-fixture verdict=" + pass_verdict + " field_pass=" + to_string(pass_field_pass) + "/7")
    println("[witness_emit selftest --validate] FAIL-fixture verdict=" + fail_verdict + " first_fail=" + fail_slug)

    if correct == 2 {
        println("__WITNESS_VALIDATE_SELFTEST__ PASS correct=2/2")
        return
    }
    eprintln("reason=selftest-validate-mismatch: expected PASS+FAIL got " + pass_verdict + "+" + fail_verdict)
    eprintln("fix=inspect _validate_witness logic vs omega_cycle.witness_v1 schema")
    println("__WITNESS_VALIDATE_SELFTEST__ FAIL correct=" + to_string(correct) + "/2")
    exit(4)
}

fn _selftest() -> void {
    println("[witness_emit selftest]")

    // 1. classifier rejects non-omega_cycle paths
    let r1 = emit_witness("/tmp/not_a_witness.json", "{}")
    if r1[0] != "FAIL" {
        eprintln("selftest FAIL classifier should reject non-omega_cycle path")
        eprintln("reason=classifier-false-positive fix=verify _is_omega_cycle_witness")
        exit(1)
    }

    // 2. classifier rejects non-json
    let r2 = emit_witness("/tmp/foo_omega_cycle.txt", "{}")
    if r2[0] != "FAIL" {
        eprintln("selftest FAIL classifier should reject non-json")
        eprintln("reason=classifier-extension-check fix=verify .json check")
        exit(1)
    }

    // 3. happy path — synthetic witness write + absorb
    let synth_dir = "/tmp/witness_emit_selftest"
    let _ = exec("mkdir -p '" + synth_dir + "'")
    let synth_path = synth_dir + "/2026-04-26_witness-emit-selftest_synthetic_omega_cycle.json"
    let body = "{\"trawl_id\":\"witness-emit-selftest-synthetic\",\"axes_surfaced\":[{\"axis_id\":\"a1\",\"name\":\"selftest synthetic axis\",\"summary\":\"witness_emit selftest fact extraction\"}]}"
    let r3 = emit_witness(synth_path, body)
    let verdict3 = r3[0]
    let test_synth = to_string(exec("test -f '" + synth_path + "' && echo y || echo n")).trim()
    if test_synth != "y" {
        eprintln("selftest FAIL synthetic witness file not written")
        eprintln("reason=write-file-failed fix=verify write_file builtin + parent-dir create")
        exit(1)
    }
    if verdict3 != "PASS" {
        eprintln("selftest FAIL emit verdict expected PASS got " + verdict3 + " errors=" + r3[5])
        eprintln("reason=emit-failure-" + r3[5] + " fix=hexa run " + _ingest_tool_path() + " --witness " + synth_path + "   # inspect")
        let _ = exec("rm -rf '" + synth_dir + "'")
        exit(1)
    }

    // 4. idempotent re-emit (same witness, same body)
    let r4 = emit_witness(synth_path, body)
    if r4[0] != "PASS" {
        eprintln("selftest FAIL idempotent re-emit expected PASS got " + r4[0] + " errors=" + r4[5])
        eprintln("reason=idempotence-broken fix=verify omega_cycle_atlas_ingest --witness skip path")
        let _ = exec("rm -rf '" + synth_dir + "'")
        exit(1)
    }

    let _ = exec("rm -rf '" + synth_dir + "'")
    println("[witness_emit selftest] OK — classifier 2 cases / happy-path emit / idempotent re-emit")

    // 5. validate selftest — schema gate (PASS fixture + known FAIL fixture).
    _selftest_validate()

    exit(0)
}

// ─── CLI runner ──────────────────────────────────────────────────

fn main() -> void {
    let raw_args = args()
    let mut cli = []
    let mut ai = 2
    while ai < len(raw_args) {
        cli.push(raw_args[ai])
        ai = ai + 1
    }
    if len(cli) >= 1 && (cli[0] == "--selftest" || cli[0] == "selftest") {
        _selftest()
    }

    // --validate <witness.json> — schema gate (omega_cycle.witness_v1).
    // Closes the LLM-side enforcement gap (raw 71 + raw 48 + raw 66 + raw 80).
    if len(cli) >= 1 && (cli[0] == "--validate" || cli[0] == "validate") {
        if len(cli) < 2 {
            eprintln("reason=missing-validate-arg: <witness.json>-empty-or-missing")
            eprintln("fix=hexa run tool/witness_emit.hexa --validate /abs/path/foo_omega_cycle.json")
            println("__WITNESS_VALIDATE__ FAIL path= field_pass=0 field_total=7")
            exit(1)
        }
        _run_validate(cli[1])
    }

    let mut emit_path = ""
    let mut body_file = ""
    let mut source = "cli"
    let mut i = 0
    while i < len(cli) {
        let a = cli[i]
        if a == "--emit" {
            i = i + 1
            if i >= len(cli) {
                eprintln("__WITNESS_EMIT__ FAIL path= shard= absorbed=false reason=missing-emit-arg fix=--emit /abs/path/foo_omega_cycle.json")
                exit(1)
            }
            emit_path = cli[i]
        } else if a == "--body-file" {
            i = i + 1
            if i >= len(cli) {
                eprintln("__WITNESS_EMIT__ FAIL path= shard= absorbed=false reason=missing-body-file-arg fix=--body-file /abs/path/body.json")
                exit(1)
            }
            body_file = cli[i]
        } else if a == "--source" {
            i = i + 1
            if i >= len(cli) {
                eprintln("__WITNESS_EMIT__ FAIL path= shard= absorbed=false reason=missing-source-arg fix=--source <slug>")
                exit(1)
            }
            source = cli[i]
        } else if a == "--help" || a == "-h" {
            println("usage: hexa run tool/witness_emit.hexa --emit <abs_path> --body-file <abs_path> [--source <slug>]")
            println("       hexa run tool/witness_emit.hexa --validate <witness.json>")
            println("       hexa run tool/witness_emit.hexa --selftest")
            println("  canonical emit_witness(path, body) helper for ω-cycle witnesses")
            println("  raw 80 sentinel: __WITNESS_EMIT__   <PASS|FAIL> path=<path> shard=<path> absorbed=<true|false>")
            println("  raw 80 sentinel: __WITNESS_VALIDATE__ <PASS|FAIL> path=<path> field_pass=<N> field_total=7")
            println("  raw 66 err:     reason=<slug> fix=<directive>")
            println("  triad layer 2 (agent-level, own:atlas-absorb-mandatory)")
            println("  claude-dependency: NONE  hooks: NONE")
            exit(0)
        } else {
            eprintln("__WITNESS_EMIT__ FAIL path= shard= absorbed=false reason=unknown-arg-" + a + " fix=hexa run tool/witness_emit.hexa --help")
            exit(1)
        }
        i = i + 1
    }

    if len(emit_path) == 0 || len(body_file) == 0 {
        eprintln("__WITNESS_EMIT__ FAIL path=" + emit_path + " shard= absorbed=false reason=missing-args fix=--emit <path> --body-file <path>")
        exit(1)
    }
    let test_b = to_string(exec("test -f '" + body_file + "' && echo y || echo n")).trim()
    if test_b != "y" {
        eprintln("__WITNESS_EMIT__ FAIL path=" + emit_path + " shard= absorbed=false reason=body-file-missing fix=verify --body-file path")
        exit(1)
    }
    let body = to_string(read_file(body_file))
    let r = emit_witness_with_source(emit_path, body, source)
    let verdict = r[0]
    let path_v = r[1]
    let shard = r[3]
    let absorbed = r[4]
    let errs = r[5]
    if verdict == "PASS" {
        println("__WITNESS_EMIT__ PASS path=" + path_v + " shard=" + shard + " absorbed=" + absorbed)
        exit(0)
    }
    eprintln("__WITNESS_EMIT__ FAIL path=" + path_v + " shard=" + shard + " absorbed=" + absorbed + " reason=" + errs + " fix=hexa run " + _ingest_tool_path() + " --witness " + path_v + "   # inspect")
    exit(2)
}
