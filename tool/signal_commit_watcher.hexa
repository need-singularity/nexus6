// signal_commit_watcher.hexa — E5 대체 하네스
// git log --since="24 hours ago" --name-only 로 변경된 BT 파일 추출
// 각 파일에서 signal 마커 검색 → staging append
// 실행: hexa run $NEXUS/tool/signal_commit_watcher.hexa [hours=24] [repo=n6|nexus|anima|all]

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let N6 = HOME + "/Dev/n6-architecture"
let ANIMA = HOME + "/Dev/anima"
let STAGE = NEXUS + "/n6/staging/atlas.signals.staging.commit.n6"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn now_ts() -> string {
    let r = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    return _str(r).trim()
}

fn shell_quote(s: string) -> string {
    let escaped = s.replace("'", "'\\''")
    return "'" + escaped + "'"
}

fn append_line(path: string, line: string) {
    let cmd = "printf '%s\\n' " + shell_quote(line) + " >> '" + path + "' 2>/dev/null"
    exec(cmd)
}

fn scan_repo(repo_root: string, hours: i64) -> i64 {
    if file_exists(repo_root + "/.git") == false { return 0 }

    let since = "'" + to_string(hours) + " hours ago'"
    // 최근 커밋에서 변경된 파일 목록 (md/hexa)
    let cmd = "cd '" + repo_root + "' 2>/dev/null && " +
              "git log --since=" + since + " --name-only --pretty=format: 2>/dev/null | " +
              "grep -E '\\.(md|hexa)$' | sort -u | head -200"
    let r = exec(cmd)
    let text = _str(r)
    if text.trim() == "" { return 0 }

    let lines = text.split("\n")
    let patterns = [
        "★",
        "최초",
        "PEAK",
        "sweet spot",
        "돌파",
        "breakthrough",
        "NULL",
        "pp drop",
        "× faster",
        "진짜 발견"
    ]

    let mut hit_file_count: i64 = 0
    let mut total_hits: i64 = 0

    let mut i = 0
    while i < lines.len() {
        let rel = _str(lines[i]).trim()
        if rel == "" { i = i + 1; continue }
        let abs_path = repo_root + "/" + rel
        if file_exists(abs_path) == false { i = i + 1; continue }

        let mut file_hits: i64 = 0
        let mut j = 0
        while j < patterns.len() {
            let p = patterns[j]
            let c2 = "{ grep -c -F " + shell_quote(p) + " '" + abs_path + "' 2>/dev/null || true; }"
            let r2 = exec(c2)
            let s2 = _str(r2).trim().split("\n")[0]
            let mut v: i64 = 0
            try { v = to_int(s2) } catch e { v = 0 }
            file_hits = file_hits + v
            j = j + 1
        }

        if file_hits > 0 {
            hit_file_count = hit_file_count + 1
            total_hits = total_hits + file_hits
            let ln = "# COMMIT " + now_ts() + " hits=" + to_string(file_hits) + " <- " + abs_path
            append_line(STAGE, ln)
        }
        i = i + 1
    }

    println("  [" + repo_root + "] hit_files=" + to_string(hit_file_count) +
            " total_hits=" + to_string(total_hits))
    return total_hits
}

// ─── 메인 ───
let a = args()
let mut hours: i64 = 24
let mut which = "all"
if a.len() >= 3 {
    try { hours = to_int(a[2]) } catch e { hours = 24 }
}
if a.len() >= 4 { which = a[3] }

println("signal_commit_watcher: hours=" + to_string(hours) + " repo=" + which + " ts=" + now_ts())

if file_exists(STAGE) == false {
    try { write_file(STAGE, "# commit_watcher staging — append-only\n") } catch e {}
}

let mut grand_total: i64 = 0
if which == "n6" || which == "all" { grand_total = grand_total + scan_repo(N6, hours) }
if which == "nexus" || which == "all" { grand_total = grand_total + scan_repo(NEXUS, hours) }
if which == "anima" || which == "all" { grand_total = grand_total + scan_repo(ANIMA, hours) }

println("  grand_total_hits=" + to_string(grand_total))
println("  staging=" + STAGE)
