// tool/claude_slot_pick.hexa — claude code multi-slot pool helper
//
// @tool(slug="claude_slot_pick", desc="discover ~/.claude-claude<N> slots; track cooldown via .kick_limit_until + last_used via .kick_last_used; pick LRU-available slot or emit slots-list JSON; phantom-guarded against blank-N expansion")
// @usage:
//   hexa tool/claude_slot_pick.hexa --list [--json] [--include-phantom] [--refresh]
//   hexa tool/claude_slot_pick.hexa --pick [--policy lru|rr] [--exclude <csv>]
//   hexa tool/claude_slot_pick.hexa --mark-cooldown <slot> --kind <session|weekly> --until-epoch <unix> [--source stream_json_signal|live_probe|cache]
//   hexa tool/claude_slot_pick.hexa --touch <slot>
// @exit_codes(0=ok, 1=usage/io, 76=all-slots-exhausted-hard-fail)
//
// raw 11 + raw 66 + raw 80; closes feedback_hive_phantom_slot_pitfall.
//
// ── PHANTOM GUARD (decision 1) ────────────────────────────────────────
// claude CLI auto-mkdirs the directory pointed to by CLAUDE_CONFIG_DIR.
// If a caller sets CLAUDE_CONFIG_DIR=$HOME/.claude-claude$n with $n
// expanded to whitespace ("1 2 3 4"), the CLI silently creates
// "~/.claude-claude1 2 3 4" → phantom slot. This helper:
//   1. Discovers via literal glob `ls -1d ~/.claude-claude*` — dirs MUST
//      already exist on disk; no shell-side $n expansion.
//   2. Validates the suffix is digits-only; suffix containing whitespace
//      or non-digits → status=phantom, default-hidden from --list.
//   3. NEVER constructs CLAUDE_CONFIG_DIR with an unset variable. The
//      --pick output is the literal config_dir of an existing slot, or
//      hard-fail (exit 76) if the pool is empty/all-cooled.
//
// ── COOLDOWN CACHE (decision 2) ────────────────────────────────────────
// Per-slot cooldown is co-located with the slot itself:
//   ~/.claude-claude<N>/.kick_limit_until   — JSON
//     {
//       "session": {"limit_until":"<iso>"|null, "captured_at":"<iso>"|null},
//       "weekly":  {"limit_until":"<iso>"|null, "captured_at":"<iso>"|null},
//       "probe_source": "stream_json_signal"|"live_probe"|"cache"|null,
//       "last_probe": "<iso>"|null
//     }
//   ~/.claude-claude<N>/.kick_last_used     — single ISO line
//
// Co-locating with the slot avoids polluting the nexus repo and
// naturally garbage-collects with the slot dir.
//
// ── PICK POLICY (decision 3) ──────────────────────────────────────────
// Default = LRU.  Reasoning: the operator may add/remove slots over
// time; round-robin needs a per-pool cursor (one more state file to
// keep coherent). LRU reads `.kick_last_used` per slot — if the file
// is missing the slot is treated as "never used" → highest priority.
// Filter ordering on --pick:
//   1. drop phantom slots (status=phantom)
//   2. drop slots with session.limit_until in the future
//   3. drop slots with weekly.limit_until in the future
//   4. drop slots in --exclude csv
//   5. sort by last_used asc (missing/empty first), tie-break by slot id asc
// `--policy rr` is accepted but currently routes to lru (no cursor file
// in MVP); the flag is reserved for a future explicit cursor.
//
// ── PROBE SOURCE (decision 4) ──────────────────────────────────────────
// The JSON `probe_source` field tells the consumer how each slot's
// session/weekly fields were obtained:
//   "cache"             — read directly from .kick_limit_until
//   "stream_json_signal"— a prior kick_dispatch run captured a
//                         rate_limit_event from claude's stream-json
//                         and wrote the cooldown via --mark-cooldown
//   "live_probe"        — reserved (future helper extension; this MVP
//                         does NOT spawn claude itself)
//   null                — no probe data; ALL session/weekly subfields
//                         remain null. NEVER infer remaining-pct from
//                         absence (raw 73 honesty triad).
//
// Sentinel format (raw 80):
//   __SLOT_PICK_RESULT__ <PASS|FAIL> slot=<N|none> reason=<slug>
// Err trailer (raw 66):
//   reason=<slug> fix=<directive>

struct Slot {
    slot: str,
    config_dir: str,
    is_phantom: bool,
    session_until: str,
    session_captured_at: str,
    weekly_until: str,
    weekly_captured_at: str,
    probe_source: str,
    last_probe: str,
    last_used: str,
}

fn _now_iso_utc() -> str {
    return exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn _now_unix() -> i64 {
    let s = exec("date +%s").trim()
    let mut v: i64 = 0
    try { v = to_int(s) } catch e { v = 0 }
    return v
}

fn _epoch_to_iso(epoch: i64) -> str {
    if epoch <= 0 { return "" }
    return exec("date -u -r " + to_string(epoch) + " +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn _iso_to_epoch(iso: str) -> i64 {
    if iso.len() == 0 { return 0 }
    // BSD date (macOS) — accept "YYYY-MM-DDTHH:MM:SSZ"
    let cmd = "TZ=UTC date -j -u -f '%Y-%m-%dT%H:%M:%SZ' " + _shell_quote(iso) + " +%s 2>/dev/null"
    let r = exec(cmd).trim()
    let mut v: i64 = 0
    try { v = to_int(r) } catch e { v = 0 }
    return v
}

fn _file_exists(path: str) -> bool {
    let r = exec("test -f '" + path + "' && echo y || echo n").trim()
    return r == "y"
}

fn _dir_exists(path: str) -> bool {
    let r = exec("test -d '" + path + "' && echo y || echo n").trim()
    return r == "y"
}

fn _shell_quote(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _is_digits(s: str) -> bool {
    if s.len() == 0 { return false }
    let mut i: i64 = 0
    while i < s.len() {
        let c = s.substring(i, i + 1)
        if c < "0" || c > "9" { return false }
        i = i + 1
    }
    return true
}

fn _json_str(s: str) -> str {
    let mut out = "\""
    let mut i: i64 = 0
    while i < s.len() {
        let c = s.substring(i, i + 1)
        if c == "\"" { out = out + "\\\"" }
        else if c == "\\" { out = out + "\\\\" }
        else if c == "\n" { out = out + "\\n" }
        else if c == "\r" { out = out + "\\r" }
        else if c == "\t" { out = out + "\\t" }
        else { out = out + c }
        i = i + 1
    }
    return out + "\""
}

fn _json_str_or_null(s: str) -> str {
    if s.len() == 0 { return "null" }
    return _json_str(s)
}

fn _read_text(path: str) -> str {
    if !_file_exists(path) { return "" }
    return read_file(path)
}

// Best-effort JSON field extractor for flat string values written by
// THIS helper. Format is tightly controlled (no nested arrays / escapes
// beyond the standard set), so a substring scan is sufficient.
fn _flat_json_field(text: str, key: str) -> str {
    let needle = "\"" + key + "\":"
    let i = text.index_of(needle)
    if i < 0 { return "" }
    let mut j = i + needle.len()
    while j < text.len() {
        let c = text.substring(j, j + 1)
        if c == " " || c == "\t" || c == "\n" || c == "\r" { j = j + 1 } else { break }
    }
    if j >= text.len() { return "" }
    let first = text.substring(j, j + 1)
    if first == "n" {
        // null
        if j + 4 <= text.len() && text.substring(j, j + 4) == "null" { return "" }
    }
    if first != "\"" {
        // primitive — not used for our schema, return empty
        return ""
    }
    let mut k = j + 1
    let mut esc = false
    while k < text.len() {
        let c = text.substring(k, k + 1)
        if esc { esc = false; k = k + 1; continue }
        if c == "\\" { esc = true; k = k + 1; continue }
        if c == "\"" { break }
        k = k + 1
    }
    return text.substring(j + 1, k)
}

// Slice a top-level object value: `"key": { ... }` returns the inner
// `{ ... }` substring, depth-aware.
fn _flat_json_object(text: str, key: str) -> str {
    let needle = "\"" + key + "\":"
    let i = text.index_of(needle)
    if i < 0 { return "" }
    let mut j = i + needle.len()
    while j < text.len() {
        let c = text.substring(j, j + 1)
        if c == " " || c == "\t" || c == "\n" || c == "\r" { j = j + 1 } else { break }
    }
    if j >= text.len() { return "" }
    if text.substring(j, j + 1) != "{" { return "" }
    let mut depth: i64 = 0
    let mut k = j
    let mut in_str = false
    let mut esc = false
    while k < text.len() {
        let c = text.substring(k, k + 1)
        if esc { esc = false; k = k + 1; continue }
        if c == "\\" { esc = true; k = k + 1; continue }
        if c == "\"" { in_str = !in_str; k = k + 1; continue }
        if !in_str {
            if c == "{" { depth = depth + 1 }
            else if c == "}" {
                depth = depth - 1
                if depth == 0 { return text.substring(j, k + 1) }
            }
        }
        k = k + 1
    }
    return ""
}

// ─── Slot discovery ────────────────────────────────────────────────────
fn _slot_prefix() -> str {
    // CLAUDE_SLOT_TEST_HOME — opt-in test override. When set, slots are
    // discovered under <override>/.claude-claude<N> instead of $HOME/...
    // Production callers never set this; falsifier harness uses it to test
    // with a clean tempdir without breaking hexa-lang's own $HOME usage.
    let test_home = env("CLAUDE_SLOT_TEST_HOME")
    if test_home.len() > 0 { return test_home + "/.claude-claude" }
    return env("HOME") + "/.claude-claude"
}

fn _discover_slots() -> [Slot] {
    let prefix = _slot_prefix()
    // Literal glob — dirs must exist already (phantom guard 1).
    let raw = exec("ls -1d " + prefix + "* 2>/dev/null").trim()
    let mut out: [Slot] = []
    if raw.len() == 0 { return out }
    let parts = raw.split("\n")
    let mut i: i64 = 0
    while i < len(parts) {
        let dir = parts[i].trim()
        if dir.len() == 0 { i = i + 1; continue }
        if !dir.starts_with(prefix) { i = i + 1; continue }
        if !_dir_exists(dir) { i = i + 1; continue }
        let suffix = dir.substring(prefix.len(), dir.len())
        let phantom = !_is_digits(suffix)
        // Read sidecar metadata (if any).
        let limit_path = dir + "/.kick_limit_until"
        let used_path = dir + "/.kick_last_used"
        let mut sess_until = ""
        let mut sess_at = ""
        let mut wk_until = ""
        let mut wk_at = ""
        let mut probe_src = ""
        let mut last_probe = ""
        if _file_exists(limit_path) {
            let body = _read_text(limit_path)
            let sess_obj = _flat_json_object(body, "session")
            if sess_obj.len() > 0 {
                sess_until = _flat_json_field(sess_obj, "limit_until")
                sess_at = _flat_json_field(sess_obj, "captured_at")
            }
            let wk_obj = _flat_json_object(body, "weekly")
            if wk_obj.len() > 0 {
                wk_until = _flat_json_field(wk_obj, "limit_until")
                wk_at = _flat_json_field(wk_obj, "captured_at")
            }
            probe_src = _flat_json_field(body, "probe_source")
            last_probe = _flat_json_field(body, "last_probe")
        }
        let mut last_used = ""
        if _file_exists(used_path) {
            last_used = _read_text(used_path).trim()
        }
        out = out + [Slot {
            slot: suffix,
            config_dir: dir,
            is_phantom: phantom,
            session_until: sess_until,
            session_captured_at: sess_at,
            weekly_until: wk_until,
            weekly_captured_at: wk_at,
            probe_source: probe_src,
            last_probe: last_probe,
            last_used: last_used,
        }]
        i = i + 1
    }
    return out
}

fn _slot_status(s: Slot) -> str {
    if s.is_phantom { return "phantom" }
    let now_e = _now_unix()
    if s.session_until.len() > 0 {
        let e = _iso_to_epoch(s.session_until)
        if e > now_e { return "session_limit" }
    }
    if s.weekly_until.len() > 0 {
        let e = _iso_to_epoch(s.weekly_until)
        if e > now_e { return "weekly_limit" }
    }
    if s.probe_source.len() == 0 && s.last_used.len() == 0 { return "unknown" }
    return "available"
}

// ─── --list / --json ───────────────────────────────────────────────────
fn _emit_slots_json(slots: [Slot], include_phantom: bool) -> str {
    let mut buf = "{\n"
    buf = buf + "  \"schema_version\": \"1\",\n"
    buf = buf + "  \"generated_at\": " + _json_str(_now_iso_utc()) + ",\n"
    buf = buf + "  \"slots\": [\n"
    let mut total: i64 = 0
    let mut n_avail: i64 = 0
    let mut n_sess: i64 = 0
    let mut n_wk: i64 = 0
    let mut n_unk: i64 = 0
    let mut n_phan: i64 = 0
    let mut first = true
    let mut i: i64 = 0
    while i < len(slots) {
        let s = slots[i]
        let status = _slot_status(s)
        if status == "phantom" { n_phan = n_phan + 1 }
        else if status == "session_limit" { n_sess = n_sess + 1 }
        else if status == "weekly_limit" { n_wk = n_wk + 1 }
        else if status == "unknown" { n_unk = n_unk + 1 }
        else { n_avail = n_avail + 1 }
        if status == "phantom" && !include_phantom { i = i + 1; continue }
        total = total + 1
        if !first { buf = buf + ",\n" }
        first = false
        buf = buf + "    {\n"
        buf = buf + "      \"slot\": " + _json_str(s.slot) + ",\n"
        buf = buf + "      \"config_dir\": " + _json_str(s.config_dir) + ",\n"
        buf = buf + "      \"status\": " + _json_str(status) + ",\n"
        // session block — null subfields when no probe data
        buf = buf + "      \"session\": {\n"
        buf = buf + "        \"limit_until\": " + _json_str_or_null(s.session_until) + ",\n"
        buf = buf + "        \"remaining_5h_window_pct\": null\n"
        buf = buf + "      },\n"
        buf = buf + "      \"weekly\": {\n"
        buf = buf + "        \"limit_until\": " + _json_str_or_null(s.weekly_until) + ",\n"
        buf = buf + "        \"remaining_pct\": null,\n"
        buf = buf + "        \"renews_in_days\": null\n"
        buf = buf + "      },\n"
        buf = buf + "      \"last_used\": " + _json_str_or_null(s.last_used) + ",\n"
        buf = buf + "      \"last_probe\": " + _json_str_or_null(s.last_probe) + ",\n"
        buf = buf + "      \"probe_source\": " + _json_str_or_null(s.probe_source) + "\n"
        buf = buf + "    }"
        i = i + 1
    }
    buf = buf + "\n  ],\n"
    buf = buf + "  \"summary\": {\n"
    buf = buf + "    \"total\": " + to_string(total) + ",\n"
    buf = buf + "    \"available\": " + to_string(n_avail) + ",\n"
    buf = buf + "    \"session_limit\": " + to_string(n_sess) + ",\n"
    buf = buf + "    \"weekly_limit\": " + to_string(n_wk) + ",\n"
    buf = buf + "    \"unknown\": " + to_string(n_unk) + ",\n"
    buf = buf + "    \"phantom\": " + to_string(n_phan) + "\n"
    buf = buf + "  }\n"
    buf = buf + "}\n"
    return buf
}

fn _emit_slots_table(slots: [Slot], include_phantom: bool) -> str {
    let mut buf = ""
    buf = buf + "slot config_dir status session_until weekly_until last_used probe_source\n"
    let mut i: i64 = 0
    while i < len(slots) {
        let s = slots[i]
        let status = _slot_status(s)
        if status == "phantom" && !include_phantom { i = i + 1; continue }
        let su = if s.session_until.len() > 0 { s.session_until } else { "-" }
        let wu = if s.weekly_until.len() > 0 { s.weekly_until } else { "-" }
        let lu = if s.last_used.len() > 0 { s.last_used } else { "-" }
        let ps = if s.probe_source.len() > 0 { s.probe_source } else { "-" }
        buf = buf + s.slot + " " + s.config_dir + " " + status + " " + su + " " + wu + " " + lu + " " + ps + "\n"
        i = i + 1
    }
    return buf
}

// ─── --pick (LRU among available) ─────────────────────────────────────
fn _csv_contains(csv: str, key: str) -> bool {
    if csv.len() == 0 { return false }
    let parts = csv.split(",")
    let mut i: i64 = 0
    while i < len(parts) {
        if parts[i].trim() == key { return true }
        i = i + 1
    }
    return false
}

fn _pick_lru(slots: [Slot], exclude_csv: str) -> i64 {
    // Returns index of picked slot in `slots`, or -1 if none available.
    let mut best: i64 = -1
    let mut best_key = ""
    let mut i: i64 = 0
    while i < len(slots) {
        let s = slots[i]
        let status = _slot_status(s)
        if status != "available" && status != "unknown" { i = i + 1; continue }
        if _csv_contains(exclude_csv, s.slot) { i = i + 1; continue }
        // Sort key: empty last_used → "" sorts before any ISO; tie-break by slot id (zero-padded).
        let lu = s.last_used
        // Pad slot id to 6 digits for stable compare.
        let mut padded = s.slot
        while padded.len() < 6 { padded = "0" + padded }
        let key = lu + "|" + padded
        if best < 0 || key < best_key {
            best = i
            best_key = key
        }
        i = i + 1
    }
    return best
}

// ─── --mark-cooldown / --touch (writers) ──────────────────────────────
fn _write_cooldown(slot_id: str, kind: str, until_iso: str, source: str) -> bool {
    let dir = _slot_prefix() + slot_id
    if !_dir_exists(dir) {
        eprintln("reason=slot-dir-missing fix=ls -1d " + _slot_prefix() + "*   # available slots")
        return false
    }
    let path = dir + "/.kick_limit_until"
    let now = _now_iso_utc()
    let body = _read_text(path)
    let mut sess_until = ""
    let mut sess_at = ""
    let mut wk_until = ""
    let mut wk_at = ""
    if body.len() > 0 {
        let so = _flat_json_object(body, "session")
        if so.len() > 0 {
            sess_until = _flat_json_field(so, "limit_until")
            sess_at = _flat_json_field(so, "captured_at")
        }
        let wo = _flat_json_object(body, "weekly")
        if wo.len() > 0 {
            wk_until = _flat_json_field(wo, "limit_until")
            wk_at = _flat_json_field(wo, "captured_at")
        }
    }
    if kind == "session" {
        sess_until = until_iso
        sess_at = now
    } else {
        if kind == "weekly" {
            wk_until = until_iso
            wk_at = now
        } else {
            eprintln("reason=invalid-kind-" + kind + " fix=use --kind session|weekly")
            return false
        }
    }
    let mut buf = "{\n"
    buf = buf + "  \"session\": {\n"
    buf = buf + "    \"limit_until\": " + _json_str_or_null(sess_until) + ",\n"
    buf = buf + "    \"captured_at\": " + _json_str_or_null(sess_at) + "\n"
    buf = buf + "  },\n"
    buf = buf + "  \"weekly\": {\n"
    buf = buf + "    \"limit_until\": " + _json_str_or_null(wk_until) + ",\n"
    buf = buf + "    \"captured_at\": " + _json_str_or_null(wk_at) + "\n"
    buf = buf + "  },\n"
    buf = buf + "  \"probe_source\": " + _json_str(source) + ",\n"
    buf = buf + "  \"last_probe\": " + _json_str(now) + "\n"
    buf = buf + "}\n"
    write_file(path, buf)
    return true
}

fn _touch_slot(slot_id: str) -> bool {
    let dir = _slot_prefix() + slot_id
    if !_dir_exists(dir) {
        eprintln("reason=slot-dir-missing fix=ls -1d " + _slot_prefix() + "*")
        return false
    }
    let path = dir + "/.kick_last_used"
    write_file(path, _now_iso_utc() + "\n")
    return true
}

fn _usage() -> void {
    eprintln("usage:")
    eprintln("  hexa tool/claude_slot_pick.hexa --list [--json] [--include-phantom] [--refresh]")
    eprintln("  hexa tool/claude_slot_pick.hexa --pick [--policy lru|rr] [--exclude <csv>]")
    eprintln("  hexa tool/claude_slot_pick.hexa --mark-cooldown <slot> --kind <session|weekly> --until-epoch <unix> [--source stream_json_signal|live_probe|cache]")
    eprintln("  hexa tool/claude_slot_pick.hexa --touch <slot>")
    eprintln("sentinel (raw 80): __SLOT_PICK_RESULT__ <PASS|FAIL> slot=<N|none> reason=<slug>")
    eprintln("err     (raw 66): reason=<slug> fix=<directive>")
}

fn main() -> void {
    let raw = args()
    let mut start = 2
    if raw.len() >= 3 && raw[1] == "run" { start = 3 }
    let mut mode = ""
    let mut json_out = false
    let mut include_phantom = false
    let mut refresh = false
    let mut policy = "lru"
    let mut exclude_csv = ""
    let mut mark_slot = ""
    let mut mark_kind = ""
    let mut mark_until_epoch: i64 = 0
    let mut mark_source = "stream_json_signal"
    let mut touch_slot = ""
    let mut i = start
    while i < raw.len() {
        let a = raw[i]
        if a == "--list" { mode = "list"; i = i + 1; continue }
        if a == "--pick" { mode = "pick"; i = i + 1; continue }
        if a == "--mark-cooldown" {
            mode = "mark"
            if i + 1 < raw.len() { mark_slot = raw[i + 1] }
            i = i + 2
            continue
        }
        if a == "--touch" {
            mode = "touch"
            if i + 1 < raw.len() { touch_slot = raw[i + 1] }
            i = i + 2
            continue
        }
        if a == "--json" { json_out = true; i = i + 1; continue }
        if a == "--include-phantom" { include_phantom = true; i = i + 1; continue }
        if a == "--refresh" { refresh = true; i = i + 1; continue }
        if a == "--policy" { if i + 1 < raw.len() { policy = raw[i + 1] }; i = i + 2; continue }
        if a == "--exclude" { if i + 1 < raw.len() { exclude_csv = raw[i + 1] }; i = i + 2; continue }
        if a == "--kind" { if i + 1 < raw.len() { mark_kind = raw[i + 1] }; i = i + 2; continue }
        if a == "--until-epoch" {
            if i + 1 < raw.len() {
                try { mark_until_epoch = to_int(raw[i + 1]) } catch e { mark_until_epoch = 0 }
            }
            i = i + 2
            continue
        }
        if a == "--source" { if i + 1 < raw.len() { mark_source = raw[i + 1] }; i = i + 2; continue }
        if a == "--help" || a == "-h" { _usage(); exit(0) }
        i = i + 1
    }

    if mode == "" {
        _usage()
        eprintln("__SLOT_PICK_RESULT__ FAIL slot=none reason=missing-mode")
        eprintln("reason=missing-mode fix=pass --list | --pick | --mark-cooldown | --touch")
        exit(1)
    }

    if mode == "list" {
        let _ = refresh  // reserved (see header)
        let slots = _discover_slots()
        if json_out {
            // --json is stdout-only; logs go to stderr.
            print(_emit_slots_json(slots, include_phantom))
            exit(0)
        }
        print(_emit_slots_table(slots, include_phantom))
        exit(0)
    }

    if mode == "pick" {
        let _ = policy  // lru is the only implemented policy in this MVP
        let slots = _discover_slots()
        if len(slots) == 0 {
            eprintln("__SLOT_PICK_RESULT__ FAIL slot=none reason=empty-pool")
            eprintln("reason=empty-pool fix=ls -1d $HOME/.claude-claude*   # no slot dirs found; run /login in claude CLI to create one")
            exit(76)
        }
        let idx = _pick_lru(slots, exclude_csv)
        if idx < 0 {
            eprintln("__SLOT_PICK_RESULT__ FAIL slot=none reason=all-slots-exhausted")
            eprintln("reason=all-slots-exhausted fix=hexa " + env("HOME") + "/core/nexus/tool/claude_slot_pick.hexa --list   # inspect cooldown windows; or rm ~/.claude-claude*/.kick_limit_until if you believe limits have reset")
            exit(76)
        }
        let picked = slots[idx]
        // stdout: just the config_dir, single line — caller pipes into env=
        println(picked.config_dir)
        eprintln("__SLOT_PICK_RESULT__ PASS slot=" + picked.slot + " reason=lru-available")
        exit(0)
    }

    if mode == "mark" {
        if mark_slot.len() == 0 {
            eprintln("__SLOT_PICK_RESULT__ FAIL slot=none reason=missing-slot")
            eprintln("reason=missing-slot fix=hexa tool/claude_slot_pick.hexa --mark-cooldown <slot> --kind <session|weekly> --until-epoch <unix>")
            exit(1)
        }
        if mark_until_epoch <= 0 {
            eprintln("__SLOT_PICK_RESULT__ FAIL slot=" + mark_slot + " reason=missing-until-epoch")
            eprintln("reason=missing-until-epoch fix=pass --until-epoch <unix-seconds>")
            exit(1)
        }
        let until_iso = _epoch_to_iso(mark_until_epoch)
        let ok = _write_cooldown(mark_slot, mark_kind, until_iso, mark_source)
        if !ok {
            eprintln("__SLOT_PICK_RESULT__ FAIL slot=" + mark_slot + " reason=cooldown-write-failed")
            exit(1)
        }
        eprintln("__SLOT_PICK_RESULT__ PASS slot=" + mark_slot + " reason=cooldown-marked-" + mark_kind)
        exit(0)
    }

    if mode == "touch" {
        if touch_slot.len() == 0 {
            eprintln("__SLOT_PICK_RESULT__ FAIL slot=none reason=missing-slot")
            eprintln("reason=missing-slot fix=hexa tool/claude_slot_pick.hexa --touch <slot>")
            exit(1)
        }
        let ok = _touch_slot(touch_slot)
        if !ok {
            eprintln("__SLOT_PICK_RESULT__ FAIL slot=" + touch_slot + " reason=touch-failed")
            exit(1)
        }
        eprintln("__SLOT_PICK_RESULT__ PASS slot=" + touch_slot + " reason=last-used-touched")
        exit(0)
    }

    _usage()
    exit(1)
}
