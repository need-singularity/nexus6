>>>>>>> Stashed changes
    let mut a: [string] = []
    let mut ai: i64 = 2
    while ai < argv.len() {
        a = a.push(_str(argv[ai]))
        ai = ai + 1
    }
    if a.len() == 0 {
        eprintln("usage: roadmap_edges.hexa <audit|apply|dry-run|--selftest> [args]")
        eprintln("  audit   <roadmap-path> [--json] [--min-score=0.10] [--max-score=0.50]")
        eprintln("  apply   <roadmap-path> [--min-score=0.10] [--max-score=0.50]")
        eprintln("  dry-run <roadmap-path> [--min-score=0.10] [--max-score=0.50]")
        eprintln("  --selftest")
        exit(2)
    }
    let cmd = _str(a[0])
    if cmd == "--selftest" || cmd == "selftest" {
        let r = selftest()
        exit(r)
    }
    if cmd == "audit" || cmd == "apply" || cmd == "dry-run" {
        if a.len() < 2 {
            eprintln("usage: roadmap_edges.hexa " + cmd + " <roadmap-path> [flags]")
            exit(2)
        }
        let path = _str(a[1])
        let mut as_json = false
        let mut min_s: f64 = 0.10
        let mut max_s: f64 = 0.50
        let mut k: i64 = 2
        while k < a.len() {
            let arg = _str(a[k])
            if arg == "--json" { as_json = true }
            else if arg.starts_with("--min-score=") { min_s = _parse_score_flag(arg, "--min-score=", min_s) }
            else if arg.starts_with("--max-score=") { max_s = _parse_score_flag(arg, "--max-score=", max_s) }
            else if arg.starts_with("--") { eprintln("WARN: unknown flag: " + arg) }
            k = k + 1
        }
        let r = if cmd == "audit" {
            cmd_audit(path, as_json, min_s, max_s)
        } else {
            if cmd == "apply" {
                cmd_apply(path, min_s, max_s)
            } else {
                cmd_dry_run(path, min_s, max_s)
            }
        }
        exit(r)
    }
    eprintln("REJECT: unknown command: " + cmd)
    exit(2)
}

main()
