// context_gauge.hexa — 컨텍스트 게이지 (tool-call 누적 카운터)
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
// 역할: Claude 세션에서 호출된 tool 수를 누적 추적 → 임계 도달 시 /compact 권고.
// SSOT: shared/tool/gauge_state.json
//       { "sessions": { "<sid>": { "tool_calls": N, "next_warn": N, "interval": N,
//                                   "last_compact_suggest": "ISO|null", "started": "ISO" } } }
//
// usage:
//   hexa run shared/tool/context_gauge.hexa tick    — +1 증가, 임계 시 stderr WARN
//   hexa run shared/tool/context_gauge.hexa status  — 현재 세션 한 줄 출력
//   hexa run shared/tool/context_gauge.hexa reset   — 현재 세션 카운터 0 리셋
//
// 성공 조용 (H1), 실패 시끄럽게 + stdout sentinel __HARNESS_GAUGE_RESULT__ FAIL.
// Track A 가 post_bash/post_edit 에서 `hexa run context_gauge.hexa tick 2>/dev/null` 호출.
// 이 파일이 없어도 2>/dev/null 로 무시되므로 순서 의존 X.

let HOME = env("HOME")
let HARNESS = HOME + "/Dev/nexus/harness"
let STATE = HARNESS + "/gauge_state.json"
let FIRST_WARN: i64 = 50   // 첫 경고 임계
let INTERVAL: i64 = 25      // 재경고 간격

// ─── void-safe coercion (agent_ledger.hexa 패턴 차용) ───
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    return to_int(first)
}

fn now_unix() -> i64 {
    return _to_int0(_str(exec("date +%s")).trim())  // @allow-bare-exec
}

fn now_iso() -> string {
    return _str(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()  // @allow-bare-exec
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", " ")
    r = r.replace("\r", " ")
    r = r.replace("\t", " ")
    return r
}

// ─── session_id: TERM_SESSION_ID 있으면 sha1-8, 없으면 pid ───
fn make_session_id() -> string {
    let term = _str(env("TERM_SESSION_ID")).trim()
    if term.len() > 0 {
        let esc = term.replace("'", "")
        let cmd = "printf '%s' '" + esc + "' | (sha256sum 2>/dev/null || shasum -a 256 2>/dev/null) | cut -c1-8"
        let r = _str(exec(cmd)).trim()  // @allow-bare-exec
        if r.len() > 0 { return r }
    }
    let pid = _str(exec("echo $$")).trim()  // @allow-bare-exec
    if pid.len() > 0 { return "p" + pid }
    return "unknown"
}

// ─── 간이 JSON 파서: sessions."<sid>" 블록 필드 추출 ───
// gauge_state.json 은 단순 1-depth sessions 구조만 다룸. 외부 jq 의존 X.
// 구현: split_top_entries 로 쪼갠 후 sid prefix 매칭.
fn extract_session_block(raw: string, sid: string) -> string {
    let body = extract_sessions_body(raw)
    if body.len() == 0 { return "" }
    let entries = split_top_entries(body)
    let prefix = "\"" + sid + "\""
    for e in entries {
        let t = _str(e).trim()
        if t.len() == 0 { continue }
        if t.substring(0, prefix.len()) == prefix {
            // t = "<sid>":{...}
            // 내부 {...} 추출
            let after_key = t.substring(prefix.len(), t.len())
            // ':' 및 '{' 스킵
            let mut i = 0
            while i < after_key.len() {
                if after_key.substring(i, i + 1) == "{" { break }
                i = i + 1
            }
            if i >= after_key.len() { return "" }
            let inner_start = i + 1
            // 매칭 '}' 찾기
            let mut depth = 1
            let mut j = inner_start
            let mut in_str = false
            let mut escape = false
            while j < after_key.len() {
                let c = after_key.substring(j, j + 1)
                if escape { escape = false; j = j + 1; continue }
                if in_str {
                    if c == "\\" { escape = true }
                    else if c == "\"" { in_str = false }
                } else {
                    if c == "\"" { in_str = true }
                    else if c == "{" { depth = depth + 1 }
                    else if c == "}" {
                        depth = depth - 1
                        if depth == 0 { break }
                    }
                }
                j = j + 1
            }
            if j > inner_start {
                return after_key.substring(inner_start, j)
            }
            return ""
        }
    }
    return ""
}

fn field_int(block: string, key: string, fallback: i64) -> i64 {
    let tag = "\"" + key + "\""
    if block.contains(tag) == false { return fallback }
    let after = block.split(tag)[1]
    // 첫 ':' 까지 스킵
    let mut i = 0
    while i < after.len() {
        if after.substring(i, i + 1) == ":" { break }
        i = i + 1
    }
    if i >= after.len() { return fallback }
    let s = after.substring(i + 1, after.len()).trim_start()
    let mut end = 0
    while end < s.len() {
        let c = s.substring(end, end + 1)
        if c == "," || c == "}" || c == "\n" || c == " " { break }
        end = end + 1
    }
    let v = s.substring(0, end).trim()
    if v == "" { return fallback }
    return _to_int0(v)
}

fn field_str(block: string, key: string) -> string {
    let tag = "\"" + key + "\""
    if block.contains(tag) == false { return "" }
    let after = block.split(tag)[1]
    // 첫 ':' 위치까지 스킵 (ISO 타임스탬프 내부 ':' 보호)
    let mut i = 0
    while i < after.len() {
        if after.substring(i, i + 1) == ":" { break }
        i = i + 1
    }
    if i >= after.len() { return "" }
    // ':' 다음부터 값
    let s = after.substring(i + 1, after.len()).trim_start()
    if s.len() == 0 { return "" }
    if s.substring(0, 1) == "\"" {
        // 따옴표 문자열: 닫는 따옴표까지 (단순 — 이스케이프 미포함)
        let rest = s.substring(1, s.len())
        let mut j = 0
        while j < rest.len() {
            if rest.substring(j, j + 1) == "\"" { break }
            j = j + 1
        }
        return rest.substring(0, j)
    }
    // null / 숫자 등 비문자열
    let mut end = 0
    while end < s.len() {
        let c = s.substring(end, end + 1)
        if c == "," || c == "}" || c == "\n" || c == " " { break }
        end = end + 1
    }
    return s.substring(0, end).trim()
}

// ─── read: 현재 세션 블록 필드 (없으면 기본값) ───
fn read_session(sid: string) -> [string] {
    // returns [tool_calls, next_warn, interval, last_suggest, started]
    if file_exists(STATE) == false {
        return ["0", to_string(FIRST_WARN), to_string(INTERVAL), "null", ""]
    }
    let raw = read_file(STATE)
    let block = extract_session_block(raw, sid)
    if block.len() == 0 {
        return ["0", to_string(FIRST_WARN), to_string(INTERVAL), "null", ""]
    }
    let tc = field_int(block, "tool_calls", 0)
    let nw = field_int(block, "next_warn", FIRST_WARN)
    let iv = field_int(block, "interval", INTERVAL)
    let ls = field_str(block, "last_compact_suggest")
    let st = field_str(block, "started")
    return [to_string(tc), to_string(nw), to_string(iv), ls, st]
}

// ─── write: sessions 객체 전체 재구성 (현재 sid 는 교체/추가) ───
// 기존 다른 sid 블록은 문자열 그대로 보존.
fn rebuild_state(sid: string, tc: i64, nw: i64, iv: i64, last_suggest: string, started: string) -> string {
    let mut others = ""
    if file_exists(STATE) {
        let raw = read_file(STATE)
        // 전체 sessions 객체 내부 추출 후, 현재 sid 블록 제거
        // 포맷: {"sessions":{"<sid1>":{...},"<sid2>":{...}}}
        // 간이 방식: 줄 단위 재구성 대신, 모든 "<sid>":{...} 토큰을 regex 없이 수작업 스캔
        others = extract_other_sessions(raw, sid)
    }

    // last_suggest 직렬화: "null" 그대로 통과, 아니면 따옴표
    let mut ls_json = "null"
    if last_suggest != "" && last_suggest != "null" {
        ls_json = "\"" + json_escape(last_suggest) + "\""
    }

    let mut st_json = "\"\""
    if started != "" {
        st_json = "\"" + json_escape(started) + "\""
    }

    let cur_block = "\"" + sid + "\":{" +
        "\"tool_calls\":" + to_string(tc) + "," +
        "\"next_warn\":" + to_string(nw) + "," +
        "\"interval\":" + to_string(iv) + "," +
        "\"last_compact_suggest\":" + ls_json + "," +
        "\"started\":" + st_json +
        "}"

    let mut inner = cur_block
    if others.len() > 0 {
        inner = others + "," + cur_block
    }
    return "{\"sessions\":{" + inner + "}}"
}

// 다른 session 블록들을 원본 보존해서 "k1:{...},k2:{...}" 형태로 반환
// 없으면 "" 반환. 현재 sid 블록은 제외.
// 구현: 문자 단위 스캔으로 최상위 key:{...} 쌍을 쪼갠다 (단일 depth 전제).
fn extract_other_sessions(raw: string, cur_sid: string) -> string {
    let body = extract_sessions_body(raw)
    if body.len() == 0 { return "" }
    // body = `"k1":{...},"k2":{...},...`
    // 최상위 쉼표 기준 쪼개기 (내부 '{...}' depth 1 내부의 쉼표는 제외)
    let entries = split_top_entries(body)
    let mut kept = []
    let cur_prefix = "\"" + cur_sid + "\""
    for e in entries {
        let t = _str(e).trim()
        if t.len() == 0 { continue }
        // cur_sid 로 시작하는 엔트리는 스킵
        if t.substring(0, cur_prefix.len()) == cur_prefix { continue }
        kept = kept.push(t)
    }
    if kept.len() == 0 { return "" }
    let mut out = ""
    for k in kept {
        if out.len() > 0 { out = out + "," }
        out = out + k
    }
    return out
}

// {"sessions":{ body }} 에서 body 부분만 반환
fn extract_sessions_body(raw: string) -> string {
    let tag = "\"sessions\""
    if raw.contains(tag) == false { return "" }
    let after = raw.split(tag)[1]
    // ':' 까지 스킵
    let mut i = 0
    while i < after.len() {
        if after.substring(i, i + 1) == ":" { break }
        i = i + 1
    }
    if i >= after.len() { return "" }
    // 첫 '{' 까지 스킵
    while i < after.len() {
        if after.substring(i, i + 1) == "{" { break }
        i = i + 1
    }
    if i >= after.len() { return "" }
    let inner_start = i + 1
    // 매칭 '}' 스캔 (문자열 내부 따옴표 처리)
    let mut depth = 1
    let mut j = inner_start
    let mut in_str = false
    let mut escape = false
    while j < after.len() {
        let c = after.substring(j, j + 1)
        if escape { escape = false; j = j + 1; continue }
        if in_str {
            if c == "\\" { escape = true }
            else if c == "\"" { in_str = false }
        } else {
            if c == "\"" { in_str = true }
            else if c == "{" { depth = depth + 1 }
            else if c == "}" {
                depth = depth - 1
                if depth == 0 { break }
            }
        }
        j = j + 1
    }
    if j > inner_start {
        return after.substring(inner_start, j).trim()
    }
    return ""
}

// body 를 최상위 쉼표로 쪼갠 엔트리 배열 반환.
// 각 엔트리는 `"key":{...}` 형태.
fn split_top_entries(body: string) -> [string] {
    let mut out = []
    let mut buf = ""
    let mut depth = 0
    let mut in_str = false
    let mut escape = false
    let mut k = 0
    while k < body.len() {
        let c = body.substring(k, k + 1)
        if escape { buf = buf + c; escape = false; k = k + 1; continue }
        if in_str {
            if c == "\\" { escape = true; buf = buf + c }
            else if c == "\"" { in_str = false; buf = buf + c }
            else { buf = buf + c }
        } else {
            if c == "\"" { in_str = true; buf = buf + c }
            else if c == "{" { depth = depth + 1; buf = buf + c }
            else if c == "}" { depth = depth - 1; buf = buf + c }
            else if c == "," && depth == 0 {
                if buf.trim().len() > 0 { out = out.push(buf.trim()) }
                buf = ""
            } else {
                buf = buf + c
            }
        }
        k = k + 1
    }
    if buf.trim().len() > 0 { out = out.push(buf.trim()) }
    return out
}

fn trim_trailing_comma(s: string) -> string {
    let t = s.trim()
    if t.len() == 0 { return "" }
    if t.substring(t.len() - 1, t.len()) == "," {
        return t.substring(0, t.len() - 1).trim()
    }
    return t
}

// ─── atomic write ───
fn write_state(content: string) {
    let tmp = STATE + ".tmp"
    try { write_file(tmp, content + "\n") } catch e {
        eprintln("FAIL: write_file " + tmp)
        println("__HARNESS_GAUGE_RESULT__ FAIL")
        return
    }
    exec("mv '" + tmp + "' '" + STATE + "'")  // @allow-bare-exec
}

// ─── cmd: tick ───
fn cmd_tick() {
    let sid = make_session_id()
    let cur = read_session(sid)
    let tc_old = _to_int0(cur[0])
    let nw = _to_int0(cur[1])
    let iv = _to_int0(cur[2])
    let mut last_suggest = cur[3]
    let mut started = cur[4]

    let tc_new = tc_old + 1
    if started == "" { started = now_iso() }

    // 임계 도달 판정
    let mut nw_new = nw
    if tc_new == nw {
        let iso = now_iso()
        eprintln("[context_gauge] session " + sid + ": " + to_string(tc_new) +
                 " tool calls reached. Consider /compact or hexa run shared/tool/session_prompt_gen.hexa to hand off.")
        last_suggest = iso
        nw_new = nw + iv
    }

    let content = rebuild_state(sid, tc_new, nw_new, iv, last_suggest, started)
    write_state(content)
    // stdout 무출력 (성공 조용)
}

// ─── cmd: status ───
fn cmd_status() {
    let sid = make_session_id()
    let cur = read_session(sid)
    let tc = cur[0]
    let nw = cur[1]
    let iv = cur[2]
    let mut ls = cur[3]
    if ls == "" || ls == "null" { ls = "never" }
    println("gauge " + sid + ": " + tc + " calls (next warn at " + nw +
            ", interval " + iv + ", last suggest: " + ls + ")")
}

// ─── cmd: reset ───
fn cmd_reset() {
    let sid = make_session_id()
    let iso = now_iso()
    let content = rebuild_state(sid, 0, FIRST_WARN, INTERVAL, "null", iso)
    write_state(content)
}

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    if argv.len() < 3 {
        eprintln("usage: context_gauge.hexa <tick|status|reset>")
        return
    }
    let mode = argv[2].trim()
    if mode == "tick" { cmd_tick() }
    else if mode == "status" { cmd_status() }
    else if mode == "reset" { cmd_reset() }
    else {
        eprintln("REJECT: unknown mode '" + mode + "' — modes: tick|status|reset")
        println("__HARNESS_GAUGE_RESULT__ FAIL")
    }
}

main()
