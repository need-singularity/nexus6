// tool/grep_c_fallback_safety_test.hexa — omega-cycle to_int sweep regression suite.
//
// @tool(slug="grep_c_fallback_safety_test", desc="exercise the post-sweep `{ grep -c X 2>/dev/null || true; }` callsite shape — simulate raw subprocess outputs (multiline 0\\n0, empty, garbage, clean int, padding, negative, CRLF) against the canonical caller-side parse path used in signal_*, commit_stats, consensus_bt_gate, bt_atlas_pipe, hexa_tool_inventory, E4_dfs_autonomous_engine, lib/pre_tool_bash and cli/run after the omega-cycle 31-hit fix")
// @usage(hexa /Users/ghost/core/nexus/tool/grep_c_fallback_safety_test.hexa)
// @exit_codes(0=PASS, 1=any-case-failed)
//
// raw 80 sentinel: __GREPC_FALLBACK_SAFETY__ <PASS|FAIL> cases=<N> failed=<N>
// raw 66 err:     reason=<slug> fix=<directive>
//
// Two parse helpers are exercised — both shapes appear across the swept
// callsites:
//
//   (a) _parse_count_int      — empty→default, first-line, try/catch
//                              (signal_*, E4_dfs_*, run.hexa, bt_engine_forge)
//   (b) _parse_count_str      — empty→"0", first-line                       (commit_stats,
//                              hexa_tool_inventory, lib/pre_tool_bash)
//
// Falsifier: any divergence between a probe simulation and the expected
// post-fix value is a fail-loud signal that the sweep regressed.

fn _parse_count_int(raw: string, default: i64) -> i64 {
    let trimmed = raw.trim()
    if trimmed.len() == 0 { return default }
    let nl = trimmed.index_of("\n")
    let first = if nl >= 0 { trimmed.substring(0, nl).trim() } else { trimmed }
    if first.len() == 0 { return default }
    let mut v: i64 = default
    try { v = to_int(first) } catch e { v = default }
    return v
}

fn _parse_count_str(raw: string) -> string {
    let trimmed = raw.trim()
    if trimmed.len() == 0 { return "0" }
    let nl = trimmed.index_of("\n")
    let first = if nl >= 0 { trimmed.substring(0, nl).trim() } else { trimmed }
    if first.len() == 0 { return "0" }
    return first
}

fn _check_int(label: string, raw: string, default: i64, want: i64, mut failed: i64) -> i64 {
    let got = _parse_count_int(raw, default)
    if got == want {
        println("PASS int " + label + " raw=\"" + raw.replace("\n", "\\n") + "\" got=" + to_string(got))
        return failed
    }
    println("FAIL int " + label + " raw=\"" + raw.replace("\n", "\\n") + "\" want=" + to_string(want) + " got=" + to_string(got))
    return failed + 1
}

fn _check_str(label: string, raw: string, want: string, mut failed: i64) -> i64 {
    let got = _parse_count_str(raw)
    if got == want {
        println("PASS str " + label + " raw=\"" + raw.replace("\n", "\\n") + "\" got=\"" + got + "\"")
        return failed
    }
    println("FAIL str " + label + " raw=\"" + raw.replace("\n", "\\n") + "\" want=\"" + want + "\" got=\"" + got + "\"")
    return failed + 1
}

fn main() -> void {
    let mut failed: i64 = 0
    let mut cases: i64 = 0

    // ─── int-parse path (signal_*, E4_dfs_*, run.hexa, bt_engine_forge) ───

    // Case 1 — post-sweep clean zero ({...||true;} when grep matches 0 lines):
    //   r = "0\n", trim = "0", first = "0", to_int = 0.  No more "0\n0".
    failed = _check_int("post-sweep-zero", "0\n", -1, 0, failed); cases = cases + 1

    // Case 2 — pre-sweep regression input ("0\n0" from `|| echo 0`):
    //   helper takes first line "0" → 0 (NOT default), no throw.
    //   This is the original failure mode the sweep eliminates.
    failed = _check_int("pre-sweep-regression-0n0", "0\n0", -1, 0, failed); cases = cases + 1

    // Case 3 — clean non-zero count.
    failed = _check_int("clean-nonzero", "42\n", -1, 42, failed); cases = cases + 1

    // Case 4 — empty (file missing — `2>/dev/null` swallowed grep stderr,
    //   `|| true` swallowed exit 2, output is "").  Default returned.
    failed = _check_int("empty-file-missing", "", -1, -1, failed); cases = cases + 1

    // Case 5 — multiline garbage on first line returns default.
    failed = _check_int("multiline-garbage", "abc\n5\n", 0, 0, failed); cases = cases + 1

    // Case 6 — clean multi-digit count.
    failed = _check_int("multi-digit", "12345", -1, 12345, failed); cases = cases + 1

    // Case 7 — leading/trailing whitespace on first line (BSD/GNU grep variants).
    failed = _check_int("padded-int", "   77   \n0\n", -1, 77, failed); cases = cases + 1

    // Case 8 — negative integer (defensive — grep -c never emits, but the
    //   parser must not throw if some other probe sneaks in).
    failed = _check_int("negative-int", "-13\n", 0, -13, failed); cases = cases + 1

    // Case 9 — trailing CRLF (Windows-flavoured probes / pasted input).
    failed = _check_int("crlf-first-line", "256\r\n0\r\n", -1, 256, failed); cases = cases + 1

    // Case 10 — pure newline returns default.
    failed = _check_int("only-newline", "\n", 5, 5, failed); cases = cases + 1

    // ─── str-parse path (commit_stats, hexa_tool_inventory, pre_tool_bash) ───

    // Case 11 — empty raw → "0" (commit_stats omega-cycle absent).
    failed = _check_str("str-empty-to-zero", "", "0", failed); cases = cases + 1

    // Case 12 — pre-sweep "0\n0" → "0" (no longer the literal raw output).
    failed = _check_str("str-multiline-first-wins", "0\n0", "0", failed); cases = cases + 1

    // Case 13 — clean non-zero string.
    failed = _check_str("str-clean", "37", "37", failed); cases = cases + 1

    // Case 14 — string compare guard for hexa_tool_inventory `has_at != "0"`:
    //   prior bug → empty raw treated as non-zero (true positive).  After fix,
    //   parse_str collapses "" → "0", so the compare is correct.
    failed = _check_str("str-empty-not-misread", "", "0", failed); cases = cases + 1

    // Case 15 — trailing-newline only on first line.
    failed = _check_str("str-trailing-newline", "9\n", "9", failed); cases = cases + 1

    if failed > 0 {
        println("__GREPC_FALLBACK_SAFETY__ FAIL cases=" + to_string(cases) + " failed=" + to_string(failed))
        eprintln("reason=grep-c-fallback-regression-failed fix=audit affected callsite — ensure cmd uses '{ grep -c ... 2>/dev/null || true; }' (no echo) AND caller normalizes empty→default with first-line guard")
        exit(1)
    }
    println("__GREPC_FALLBACK_SAFETY__ PASS cases=" + to_string(cases) + " failed=0")
    exit(0)
}
