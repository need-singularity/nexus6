// tool/hexa_daemon_design.hexa — printable design summary for the hexa-daemon (ω-runner-13d)
//
// Purpose: this is a DESIGN-CYCLE artifact, not an implementation. ω-runner-13d
// produced a frozen specification for a future cross-invocation hexa-daemon (the
// thing 13c said was "non-trivial and out of scope for one cycle"). The full
// spec lives in anima at:
//   /Users/ghost/core/anima/state/omega_runner_13d_daemon_design_spec.json
//
// This .hexa is a 100% report-only summary printer for humans browsing tool/.
// Run it to get the 5-bullet final design + the honest verdict on whether to
// actually implement it now.
//
// raw 9 hexa-only-suffix (sweeper-safe .hexa). raw 71 report-only (no writes).
// raw 80 sentinel preserved: __HEXA_DAEMON_DESIGN__ section=<NAME>
//
// @tool(slug="hexa_daemon_design", desc="prints frozen design spec for hexa-daemon (ω-runner-13d)")
// @usage:
//   hexa run tool/hexa_daemon_design.hexa
//   hexa run tool/hexa_daemon_design.hexa --verdict-only

fn main() {
    let argv = env_var("HEXA_ARGV")
    let verdict_only = argv.contains("--verdict-only")

    if !verdict_only {
        println("__HEXA_DAEMON_DESIGN__ section=header")
        println("ω-runner-13d — hexa-daemon design specification (FROZEN, not implemented)")
        println("predecessor chain: 13_phase_a → 13b (FIFO POC, 25-50× speedup proven) → 13c (audit-only, daemonization deferred)")
        println("")

        println("__HEXA_DAEMON_DESIGN__ section=lifecycle")
        println("  trigger:        lazy-spawn on first client request (NOT launchd-always-on by default)")
        println("  stop:           idle timeout HEXA_DAEMON_IDLE_SECS=600; explicit __SHUTDOWN__; SIGTERM")
        println("  filesystem:     pid=$HOME/.hx/run/hexa_daemon.pid sock=$HOME/.hx/run/hexa_daemon.sock lock=$HOME/.hx/run/hexa_daemon.lock")
        println("  race control:   flock LOCK_EX|LOCK_NB on lock_file at spawn; loser retries connect 3×200ms")
        println("")

        println("__HEXA_DAEMON_DESIGN__ section=ipc")
        println("  transport:      Unix domain socket SOCK_STREAM (kernel-scoped, file-perm auth)")
        println("  framing:        4-byte big-endian length prefix + UTF-8 JSON v1 frame; 16 MiB cap")
        println("  ops:            RUN | PING | STATUS | SHUTDOWN")
        println("  request:        {v, op, cmd, cwd, env, stdin_b64, timeout_ms, id}")
        println("  response:       {v, id, exit_code, stdout_b64, stderr_b64, wall_ms, spawn_ms, error}")
        println("  pattern:        connection-per-request (one frame in, one frame out, close)")
        println("")

        println("__HEXA_DAEMON_DESIGN__ section=auth")
        println("  primary:        socket mode 0600, dir $HOME/.hx/run/ mode 0700")
        println("  defense:        accept-time getpeereid() (macOS) / SO_PEERCRED (Linux); reject peer_uid != getuid()")
        println("  trust domain:   single-uid same-host (matches existing hexa_remote model)")
        println("  out of scope:   shared-secret, multi-tenant — defer to v2 if/when needed")
        println("")

        println("__HEXA_DAEMON_DESIGN__ section=state_isolation")
        println("  decision:       daemon is REQUEST ORCHESTRATOR; fork-exec fresh hexa-interp child per RUN")
        println("  rationale:      eliminates state-leak risk that 13c flagged; in-process eval-with-reset is rejected")
        println("  savings come from:    persistent docker-exec coproc inside daemon (per remote target, 13b pattern)")
        println("  savings DO NOT come from:  host-side hexa-interp startup (~35ms still paid per fork)")
        println("")

        println("__HEXA_DAEMON_DESIGN__ section=integration")
        println("  client toggle:        env HEXA_DAEMON_SOCK=<path>     (opt in)")
        println("  client opt-out:       env HEXA_DAEMON_SOCK=NONE       (forces fresh-exec)")
        println("  auto-discovery:       socket exists + PING < 200ms    (opportunistic)")
        println("  patch surface:        scripts/bin/hexa_remote near L1228 (~30-50 LoC, deferred until file leaves parallel-session lock)")
        println("")

        println("__HEXA_DAEMON_DESIGN__ section=recovery")
        println("  stale pid:      kill(pid,0) ESRCH → cleanup pid+sock+lock → respawn")
        println("  stale sock:     connect ECONNREFUSED → cleanup → respawn")
        println("  hang:           per-request timeout_ms; client falls back to fresh-exec; 3 timeouts in 60s → force respawn")
        println("  child hang:     daemon-side timer SIGKILLs child, returns {exit_code:-1, error:'timeout'}")
        println("")

        println("__HEXA_DAEMON_DESIGN__ section=phasing")
        println("  E1: minimal daemon (sock+spawn+RUN, single-client, no recovery)               ~250-350 LoC")
        println("  E2: lock+pid+stale-detection+timeout+PING/STATUS/SHUTDOWN                     +150-250 LoC")
        println("  E3: launchd LaunchAgent generator (opt-in via `hexa daemon install`)          +80-120 LoC")
        println("  E4: hexa_remote wiring at L1228 (BLOCKED until parallel-session lock lifts)   +30-50 LoC")
        println("")
    }

    println("__HEXA_DAEMON_DESIGN__ section=verdict")
    println("  recommendation:       DO NOT IMPLEMENT NOW")
    println("  reason:               no current workload uses HEXA_REMOTE_DOCKER=1 in batch.")
    println("                        bridge_health.sh runs hexa locally → fork-per-request still pays")
    println("                        the ~35ms host startup; daemon adds 3-5ms net regression.")
    println("                        13b's 25-50× speedup is locked behind docker-exec floor.")
    println("  trigger to revisit:   (a) bridge_health.sh rerouted through HEXA_REMOTE_DOCKER=1, OR")
    println("                        (b) ≥50-call docker-mode batch workload appears in CI")
    println("  shelf value:          design is frozen — next cycle skips ~1.5 cycles of design work,")
    println("                        goes straight to E1 once a triggering workload exists.")
    println("")
    println("  full spec: /Users/ghost/core/anima/state/omega_runner_13d_daemon_design_spec.json")
    println("__HEXA_DAEMON_DESIGN__ done")
}
