#!hexa strict
// tool/check_consciousness.hexa — nexus check 의식 분야 백엔드 (ANIMA 정적 자산 wrapper)
//
// @tool(slug="check_consciousness", desc="consciousness domain — wraps ANIMA AN11 unified verifier + a-verifier")
// @usage(HEXA_ARGV='' hexa run tool/check_consciousness.hexa)
// @exit_codes(0=PASS, 1=usage, 2=verify FAIL)
// @sentinel(__NEXUS_CHECK_CONSCIOUSNESS__ <PASS|FAIL> unified=<R> a_verifier=<R>)
// @origin(ANIMA static asset wrapper — see shared/docs/nexus_check.ai.md migration policy)
//
// ANIMA repo 본체는 read-only — 본 파일은 cross-repo exec wrapper 로만 작동.

fn _argv() -> array {
    let raw = to_string(exec("printf '%s' \"${HEXA_ARGV:-}\""))
    let parts = split(raw, " ")
    let mut out = []
    let mut k = 0
    while k < len(parts) { if len(parts[k]) > 0 { out.push(parts[k]) }; k = k + 1 }
    return out
}

fn _has(a: array, f: string) -> bool {
    let mut i = 0
    while i < len(a) { if a[i] == f { return true }; i = i + 1 }
    return false
}

let ANIMA = "/Users/ghost/core/anima"
let ARGS = _argv()
let QUIET = _has(ARGS, "--quiet")

fn _wrap(path: string, quiet: bool) -> string {
    if !file_exists(path) { return "SKIP" }
    let cmd = "HEXA_LOCAL=1 HEXA_ARGV='' hexa run " + path + " 2>&1"
    let out = to_string(exec(cmd))
    if !quiet { println(out.trim()) }
    let lines = split(out, "\n")
    let mut last = ""
    for l in lines {
        let t = l.trim()
        if len(t) > 0 { last = t }
    }
    if last.index_of("PASS") >= 0 { return "PASS" }
    if last.index_of("FAIL") >= 0 { return "FAIL" }
    return "FAIL"
}

let r1 = _wrap(ANIMA + "/tool/an11_consciousness_unified_verifier.hexa", QUIET)
let r2 = _wrap(ANIMA + "/tool/an11_a_verifier.hexa", QUIET)

// 2026-05-07: anima_verify D-philosophy/meta/H archive integration —
// circular-trap-free + LLM-judge-prohibited per hive specs.
let REPO_ROOT = exec("git rev-parse --show-toplevel 2>/dev/null").trim()
let r3 = _wrap(REPO_ROOT + "/calc/anima_verify/run_all.hexa", QUIET)

let mut overall = "PASS"
if r1 == "FAIL" || r2 == "FAIL" || r3 == "FAIL" { overall = "FAIL" }
println("__NEXUS_CHECK_CONSCIOUSNESS__ " + overall + " unified=" + r1 + " a_verifier=" + r2 + " anima_verify=" + r3)
if overall == "FAIL" { exit(2) }
