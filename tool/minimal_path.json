{
  "_meta": {
    "name": "최소 경로 공식 SSOT",
    "description": "옵션 N개 → 단계최소+차단0+복잡도최소 자동 픽. R34(roadmap)/R35(go) 공유 참조",
    "updated": "2026-04-14",
    "consumers": ["R34", "R35"],
    "rationale": "옵션 1/2/3 제시 → 사용자 재확인 → 실행 패턴은 NEXUS-6 자율 진행 원칙과 충돌. 코드 레이어 강제로 패턴 차단."
  },

  "principle": "옵션 제시 시 추가 확인 없이 decision_order 자동 적용 + 즉시 실행",

  "decision_order": [
    "1. blocker(=0): 차단(권한/의존/destructive) 없는 옵션만 후보",
    "2. steps(↑min): 실행 단계/툴콜 수 최소",
    "3. loc/time(↑min): 추정 작업량 최소",
    "4. tie: 첫번째 옵션"
  ],

  "destructive_exception": [
    "rm -rf",
    "git push --force",
    "git reset --hard",
    "git branch -D",
    "db drop",
    "credentials/.env",
    "외부 발송 (gh issue/PR/email/webhook — H-SEND-GUARD)"
  ],

  "no_blocking": {
    "_for": "H-NOBLOCK",
    "principle": "세션 채팅 블로킹 금지 — 사용자 입력 채널을 막지 말 것",
    "ban": [
      "read -p / read -rp / read -sp (TTY 입력 대기)",
      "wait $PID / wait %N (백그라운드 합류 동기 대기)",
      "fg (foreground 복귀)",
      "sleep N (N>=10, 장시간 대기)",
      "while/until + sleep ... done (폴링 루프)",
      "foreground Agent 호출 (run_in_background 누락)"
    ],
    "alternatives": [
      "ScheduleWakeup(delaySeconds, prompt) — 시간 기반 재진입",
      "Monitor(task_id) — 백그라운드 stdout 스트림",
      "Bash(run_in_background=true) + Monitor — 비동기 실행",
      "Agent(run_in_background=true) — 병렬 위임"
    ],
    "bypass": "`@allow-block` 토큰 또는 `NEXUS_BLOCK_OK=1` prefix (정당 사유 명시 시)"
  },

  "roadmap_syntax": {
    "_for": "R34",
    "root": "배열(순차) 또는 {plan: 배열, _meta?: {...}}",
    "elements": "string | array(병렬+barrier) | {par_bg: array}",
    "string_subseq": "'cmd>cmd2>cmd3' 서브순차",
    "max_depth": 2,
    "banned_keys": [
      "depends_on", "deps", "priority", "weight", "roi", "est", "val",
      "phases", "tracks", "gate_exit", "acceleration_options",
      "cost_projection", "decision_points", "critical_path"
    ],
    "examples_ok": [
      "[\"build\", [\"lint>fix\", \"test>report\", \"typecheck\"], \"commit\"]",
      "[\"edit\", [\"a\", \"b\"], \"commit\", {\"par_bg\": [\"metrics\", \"notify\"]}]"
    ],
    "examples_fail": [
      "{\"phases\":[{\"id\":\"P0\",\"parallel\":[{\"track\":\"ML\",\"tasks\":[...]}]}]}",
      "[{\"id\":\"A\",\"depends_on\":[\"B\"],\"priority\":\"high\"}]"
    ],
    "bypass": "`\"_legacy\": true` 또는 `@allow-roadmap-ext` 토큰"
  },

  "go_command": {
    "_for": "R35",
    "trigger_keywords": ["go", "가자", "ㄱ", "진행", "gogo", "고", "ㄱㄱ"],
    "behavior": "직전 응답 옵션 N개 중 decision_order 자동 픽 + 즉시 실행. 추가 확인/재질문 금지.",
    "exception": "옵션이 destructive_exception 매칭 시 명시 확인 필요 (단 한 번)",
    "anti_pattern": [
      "옵션 1/2/3 제시 → '어디까지 할까요?' 재질문",
      "각 옵션 trade-off 표 → 사용자 선택 대기",
      "'어떻게 진행할까요?' 식 묻고 끝내기"
    ],
    "lint_message": "[H-MINPATH] 최소 경로 SSOT 적용 — 직전 옵션 중 단계최소+차단0 즉시 실행"
  }
}
