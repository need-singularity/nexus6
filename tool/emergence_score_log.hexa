// emergence_score_log.hexa — A3
// emergence_lens.hexa 를 호출해서 total_score 를 뽑아내고
// growth_tick.jsonl 에 기록 (emergence 점수 trend 추적)
// 실행: hexa run $NEXUS/tool/emergence_score_log.hexa

let HOME = env("HOME")
let NEXUS = HOME + "/core/nexus"
let LENS = NEXUS + "/lenses/emergence_lens.hexa"
let HEXA_BIN = NEXUS + "/bin/hexa"
let TICK_LOG = NEXUS + "/tool/growth_tick_log.jsonl"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    let mut v: i64 = 0
    try { v = to_int(first) } catch e { v = 0 }
    return v
}

fn now_unix() -> i64 {
    let r = exec("date +%s")
    return _to_int0(_str(r).trim())
}

fn now_iso() -> string {
    let r = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    return _str(r).trim()
}

fn shell_quote(s: string) -> string {
    let escaped = s.replace("'", "'\\''")
    return "'" + escaped + "'"
}

fn append_line(path: string, line: string) {
    let cmd = "printf '%s\\n' " + shell_quote(line) + " >> '" + path + "' 2>/dev/null"
    exec(cmd)
}

// emergence_lens 출력에서 특정 필드 추출 (예: "total_score=1.23")
fn parse_field(text: string, field: string) -> string {
    let key = field + "="
    if text.contains(key) == false { return "" }
    let after = text.split(key)[1]
    let s = _str(after)
    // 공백 또는 개행까지
    let mut end: i64 = 0
    while end < s.len() {
        let c = s.substring(end, end + 1)
        if c == " " || c == "\n" || c == "\r" { break }
        end = end + 1
    }
    return s.substring(0, end).trim()
}

// ─── 메인 ───
println("emergence_score_log: ts=" + now_iso())

if file_exists(LENS) == false {
    println("  FAIL: emergence_lens 없음 — " + LENS)
    exit(1)
}

// emergence_lens 호출 (stdout 캡처)
let cmd = "'" + HEXA_BIN + "' run '" + LENS + "' 2>&1"
let r = exec(cmd)
let out = _str(r)

if out.trim() == "" {
    println("  FAIL: emergence_lens 출력 없음")
    exit(1)
}

let core = parse_field(out, "core_score")
let boost = parse_field(out, "signal_boost")
let total = parse_field(out, "total_score")
let sig_total = parse_field(out, "signals_total")

println("  core_score=" + core + "  signal_boost=" + boost +
        "  total_score=" + total + "  signals_total=" + sig_total)

if total == "" {
    println("  WARN: total_score 파싱 실패")
    exit(1)
}

// growth_tick_log.jsonl 에 한 줄 append
let ts = now_unix()
let row = "{\"ts\":" + to_string(ts) +
          ",\"iso\":\"" + now_iso() + "\"" +
          ",\"kind\":\"emergence_score\"" +
          ",\"core_score\":" + (if core == "" { "0" } else { core }) +
          ",\"signal_boost\":" + (if boost == "" { "0" } else { boost }) +
          ",\"total_score\":" + total +
          ",\"signals_total\":" + (if sig_total == "" { "0" } else { sig_total }) +
          "}"

append_line(TICK_LOG, row)
println("  logged to " + TICK_LOG)
println("  PASS")
