// A7_fusion_expanded.hexa — signals_nightly_fusion 확장판
//
// 차이:
//   - 시간 게이트 제거 (수동 호출 가정)
//   - 모드 다양화: cross / m7bang / random / bern (Bernoulli 후보 우선)
//   - 결과 통계를 fusion_stats_A7.json 으로 직렬화
//
// 사용:
//   hexa run shared/tool/A7_fusion_expanded.hexa [rounds=10] [mode=mixed]
//   modes: mixed (기본 균형), bern (Bernoulli 우선), cross, m7bang, random
//
// 정직: fusion lens 가 새 신호를 생성한다는 뜻이 아님 — 기존 신호 cross-match 만.
//        본 하네스는 단순 batch 호출. 7대 난제 0/7 유지.

let HOME = env("HOME")
let NEXUS = HOME + "/core/nexus"
let FUSION_LENS = NEXUS + "/lenses/signals_fusion_lens.hexa"
let FUSION_LOG = NEXUS + "/n6/signals/fusion_log.jsonl"
let STATS = NEXUS + "/n6/signals/fusion_stats_A7.json"
let HEXA_BIN = NEXUS + "/bin/hexa"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let mut v: i64 = 0
    try { v = to_int(s) } catch e { v = 0 }
    return v
}

fn now_ts() -> string {
    let r = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    return _str(r).trim()
}

fn log_line_count() -> i64 {
    if file_exists(FUSION_LOG) == false { return 0 }
    let r = exec("wc -l < '" + FUSION_LOG + "' 2>/dev/null || echo 0")
    return _to_int0(_str(r).trim())
}

// 모드별 호출 시퀀스 빌더
fn build_mode_seq(mode: string, n: i64) -> array {
    let mut out = []
    let mut i: i64 = 0
    if mode == "bern" {
        // Bernoulli 우선 — cross 6 + m7bang 4
        let pat = ["cross", "cross", "cross", "cross", "cross", "cross",
                   "m7bang", "m7bang", "m7bang", "m7bang"]
        while i < n {
            out = out + [pat[i % pat.len()]]
            i = i + 1
        }
    } else if mode == "cross" {
        while i < n { out = out + ["cross"]; i = i + 1 }
    } else if mode == "m7bang" {
        while i < n { out = out + ["m7bang"]; i = i + 1 }
    } else if mode == "random" {
        while i < n { out = out + ["random"]; i = i + 1 }
    } else {
        // mixed (default) — cross 5 + m7bang 3 + random 1 + bern 1
        let pat = ["cross", "cross", "cross", "cross", "cross",
                   "m7bang", "m7bang", "m7bang", "random", "cross"]
        while i < n {
            out = out + [pat[i % pat.len()]]
            i = i + 1
        }
    }
    return out
}

// ─── 메인 ───
let a = args()
let mut rounds: i64 = 10
let mut mode: string = "mixed"
if a.len() >= 3 {
    try { rounds = to_int(a[2]) } catch e { rounds = 10 }
}
if a.len() >= 4 {
    mode = _str(a[3])
}

println("A7_fusion_expanded: ts=" + now_ts() + " rounds=" + to_string(rounds) + " mode=" + mode)
println("  lens: " + FUSION_LENS)
println("  log:  " + FUSION_LOG)

if file_exists(FUSION_LENS) == false {
    println("  FAIL: fusion lens 없음")
    exit(1)
}

let pre_count = log_line_count()
println("  pre  fusion_log lines: " + to_string(pre_count))

let seq = build_mode_seq(mode, rounds)
let mut success: i64 = 0
let mut i: i64 = 0
while i < rounds {
    let m = seq[i]
    let cmd = "'" + HEXA_BIN + "' run '" + FUSION_LENS + "' 3 " + m + " >/dev/null 2>&1"
    let r = exec(cmd)
    success = success + 1
    i = i + 1
}

let post_count = log_line_count()
let delta = post_count - pre_count

println("  post fusion_log lines: " + to_string(post_count) + " (delta=" + to_string(delta) + ")")

let stats = "{\"ts\":\"" + now_ts() + "\",\"rounds\":" + to_string(rounds) +
            ",\"mode\":\"" + mode + "\"" +
            ",\"pre\":" + to_string(pre_count) +
            ",\"post\":" + to_string(post_count) +
            ",\"delta\":" + to_string(delta) +
            ",\"success_invocations\":" + to_string(success) +
            "}"
write_file(STATS, stats + "\n")
println("  stats: " + STATS)

if delta >= rounds * 2 {
    println("PASS: fusion entries recorded (delta=" + to_string(delta) + " >= " + to_string(rounds * 2) + ")")
} else if delta > 0 {
    println("PARTIAL: some fusions wrote (delta=" + to_string(delta) + ")")
} else {
    println("WARN: delta=0 — lens 미실행 or 새 결과 없음")
}
