// tool/kick_bench_freshness_smoke.hexa — synthetic verifier for kick_bench.hexa freshness guard.
//
// @tool(slug="kick_bench_freshness_smoke", desc="exercise the 3-condition freshness guard at tool/kick_bench.hexa:485-496 with controlled witness files (fresh/stale/absent) and verify the boolean fresh + status reassignment match expected values without requiring live hive subagent spawn. Synthetic alternative to the live S1/S2/S3 path when hive infra is broken (interp interpreter not found, dispatch hang).")
// @usage(hexa run /Users/ghost/core/nexus/tool/kick_bench_freshness_smoke.hexa)
// @raw_8_compliance(hexa-only — no .py/.sh; this is a verification harness)
// @origin(design/kick/2026-04-27_kick-bench-witness-counter-live-verify_omega_cycle.json — OBSTRUCTION_DOCUMENTED minimal-alternative path)
// @sentinel(__KICK_BENCH_FRESHNESS_SMOKE__ <PASS|FAIL> cases=<N> passes=<N>)
//
// Cases (mirror the kick_bench logic at lines 485-496 verbatim):
//   C1 fresh-rc0      — rc=0, witness present, mtime >= t0/1000  → counter++, status=fire
//   C2 stale-rc0      — rc=0, witness present, mtime <  t0/1000  → counter unchanged, status=fail-stale-witness
//   C3 absent-rc0     — rc=0, witness path empty                  → counter unchanged, status=fire (no witness to count)
//   C4 fresh-rcfail   — rc=2, witness present, fresh              → counter unchanged, status=fail
//   C5 stale-rcfail   — rc=2, witness present, stale              → counter unchanged, status=fail (no reassignment when not fire)

fn _file_exists(path: str) -> bool { return exec("test -f '" + path + "' && echo y || echo n").trim() == "y" }
fn _file_mtime_s(path: str) -> i64 {
    if !_file_exists(path) { return 0 }
    let raw = exec("stat -f %m '" + path + "' 2>/dev/null || stat -c %Y '" + path + "' 2>/dev/null").trim()
    let mut v: i64 = 0
    try { v = to_int(raw) } catch e { v = 0 }
    return v
}

fn _now_unix_ms() -> i64 {
    // macOS-correct: BSD date +%s%3N emits literal "...N" (no ms support); to_int
    // throws → fall through to python3. This mirrors the bug in kick_bench's own
    // _now_unix_ms (filed as carry-forward).
    let s = exec("date +%s%3N 2>/dev/null").trim()
    let mut v: i64 = 0
    try { v = to_int(s) } catch e { v = 0 }
    if v <= 0 {
        let s2 = exec("python3 -c 'import time;print(int(time.time()*1000))'").trim()
        try { v = to_int(s2) } catch e2 { v = 0 }
    }
    if v <= 0 {
        let s3 = exec("date +%s").trim()
        try { let sec = to_int(s3); v = sec * 1000 } catch e3 { v = 0 }
    }
    return v
}

// Mirror the exact guard logic from kick_bench.hexa:488-496.
// Returns "fire" | "fail" | "fail-stale-witness" + delta to counter.
fn _apply_guard(rc: i64, witness_path: str, t0_ms: i64) -> [str] {
    let mut status = if rc == 0 { "fire" } else { "fail" }
    let t0_s = t0_ms / 1000
    let mtime_s = if witness_path.len() > 0 { _file_mtime_s(witness_path) } else { 0 }
    let fresh = witness_path.len() > 0 && mtime_s >= t0_s
    let mut delta = "0"
    if status == "fire" && fresh {
        delta = "1"
    } else if status == "fire" && witness_path.len() > 0 && !fresh {
        status = "fail-stale-witness"
    }
    return [status, delta]
}

fn _expect(case_id: str, got_status: str, got_delta: str, want_status: str, want_delta: str) -> bool {
    let ok = (got_status == want_status) && (got_delta == want_delta)
    let mark = if ok { "PASS" } else { "FAIL" }
    println("  " + mark + " " + case_id + " status=" + got_status + " delta=" + got_delta + " (want status=" + want_status + " delta=" + want_delta + ")")
    return ok
}

fn main() {
    let tmp = "/tmp/kick_bench_freshness_smoke_" + to_string(_now_unix_ms())
    let _ = exec("mkdir -p '" + tmp + "'")
    let fresh_path = tmp + "/fresh.json"
    let stale_path = tmp + "/stale.json"
    write_file(fresh_path, "{\"fresh\":true}")
    write_file(stale_path, "{\"stale\":true}")
    let _ = exec("touch -t 200001010000 '" + stale_path + "'")
    // Sleep ~1.1s so the t0 we capture below is strictly AFTER fresh_path's mtime
    // wait — we want fresh_path's mtime >= t0_s. So set t0 BEFORE we wrote fresh.
    // Actually: write_file already happened, so fresh_path's mtime = ~now.
    // We want fresh_path mtime >= t0_s → t0 must be <= fresh_path's mtime.
    // Capture t0 right before the test loop, set it to (now - 5000ms) to ensure fresh wins.
    let t0_ms = _now_unix_ms() - 5000

    println("# kick_bench freshness guard smoke (synthetic)")
    println("# tmp=" + tmp)
    println("# t0_ms=" + to_string(t0_ms) + " t0_s=" + to_string(t0_ms / 1000))
    println("# fresh_path mtime_s=" + to_string(_file_mtime_s(fresh_path)))
    println("# stale_path mtime_s=" + to_string(_file_mtime_s(stale_path)))

    let mut total: i64 = 0
    let mut passed: i64 = 0

    // C1 fresh + rc=0 → fire, +1
    let r1 = _apply_guard(0, fresh_path, t0_ms)
    total = total + 1; if _expect("C1-fresh-rc0", r1[0], r1[1], "fire", "1") { passed = passed + 1 }

    // C2 stale + rc=0 → fail-stale-witness, +0  (THE CRITICAL GUARD CASE)
    let r2 = _apply_guard(0, stale_path, t0_ms)
    total = total + 1; if _expect("C2-stale-rc0", r2[0], r2[1], "fail-stale-witness", "0") { passed = passed + 1 }

    // C3 empty path + rc=0 → fire, +0  (no witness to count, counter unchanged)
    let r3 = _apply_guard(0, "", t0_ms)
    total = total + 1; if _expect("C3-absent-rc0", r3[0], r3[1], "fire", "0") { passed = passed + 1 }

    // C4 fresh + rc=2 → fail, +0  (rc!=0 short-circuits)
    let r4 = _apply_guard(2, fresh_path, t0_ms)
    total = total + 1; if _expect("C4-fresh-rcfail", r4[0], r4[1], "fail", "0") { passed = passed + 1 }

    // C5 stale + rc=2 → fail, +0  (no reassignment when not fire)
    let r5 = _apply_guard(2, stale_path, t0_ms)
    total = total + 1; if _expect("C5-stale-rcfail", r5[0], r5[1], "fail", "0") { passed = passed + 1 }

    let _ = exec("rm -rf '" + tmp + "'")

    let verdict = if passed == total { "PASS" } else { "FAIL" }
    println("__KICK_BENCH_FRESHNESS_SMOKE__ " + verdict + " cases=" + to_string(total) + " passes=" + to_string(passed))
    if passed == total { exit(0) } else {
        eprintln("reason=guard-mechanics-mismatch fix=re-read tool/kick_bench.hexa:488-496 and align _apply_guard with the live code")
        exit(2)
    }
}
