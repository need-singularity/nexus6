// _probe_map_api.hexa — verify top-level `#{}` + `.keys()` behavior.
// expected: all 3 stages print.
// observed (2026-04-22 76bf08b7 regression): silent exit if ANY fn uses this pattern.

println("stage-1: entering top-level")

fn _test_map_fn() -> [string] {
    let mut m = #{}
    m["a"] = 1
    m["b"] = 2
    return m.keys()
}

println("stage-2: fn defined")

let result = _test_map_fn()
println("stage-3: result.len=" + to_string(len(result)))
println("DONE")
