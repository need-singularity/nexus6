// @enforce-sandbox  — H-ENFORCE-SANDBOX: 대형 jsonl scan/score 파이프라인 (495줄)
// @no-lock-needed
// @allow-bare-exec
// instinct.hexa — 인스팅트 파이프라인 (S2 scan + S3 score/promote/prune)
// 역할: mistakes.jsonl + rules_usage.jsonl + observations.jsonl 를 스캔해
//        frequent trigger→action 쌍을 candidate 로 제안, 확신도 기반 promote/prune.
// SSOT:
//   shared/tool/instincts/projects/<project_hash>/candidates.jsonl  (append)
//   shared/tool/instincts/global/promoted.jsonl                    (append)
//
// modes:
//   scan                        관찰 소스 → candidates.jsonl append (+ 기존 id merge)
//   score --confirm <id>        n_confirm +1, confidence +0.05
//   score --contradict <id>     n_contradict +1, confidence -0.10
//   score --decay                week decay -0.02 (all pending)
//   promote                     2+ 프로젝트 × avg ≥ 0.8 → global/promoted.jsonl + status=promoted
//   prune                       status=pending AND last_seen > 30d → status=pruned
//   status                      통계 요약
//   project_hash                현재 repo project_hash 출력
//
// 성공 조용, 실패 시끄럽게 (H1). exit() 미전파 우회:
//   stdout 마지막 라인 __HARNESS_INSTINCT_RESULT__ PASS|FAIL

import "safe_hexa_enforce.hexa"

let HOME = env("HOME")
let HARNESS = HOME + "/Dev/nexus/harness"
let INST_ROOT = HARNESS + "/instincts"
let PROJ_ROOT = INST_ROOT + "/projects"
let GLOBAL_ROOT = INST_ROOT + "/global"
let PROMOTED = GLOBAL_ROOT + "/promoted.jsonl"

let OBS_LOG = HARNESS + "/observations.jsonl"
let MISTAKES = HARNESS + "/mistakes.jsonl"
let USAGE = HARNESS + "/rules_usage.jsonl"

let SEC_DAY: i64 = 86400
let SEC_WEEK: i64 = 604800
let SEC_30D: i64 = 2592000

// ─── void-safe coercion (첫 split 원소 void 우회) ───
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    return to_int(first)
}

fn now_unix() -> i64 {
    return _to_int0(_str(exec("date +%s")).trim())  // @allow-bare-exec
}

fn now_iso() -> string {
    return _str(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()  // @allow-bare-exec
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", " ")
    r = r.replace("\r", " ")
    r = r.replace("\t", " ")
    return r
}

fn sentinel_pass() {
    println("__HARNESS_INSTINCT_RESULT__ PASS")
}

fn sentinel_fail() {
    println("__HARNESS_INSTINCT_RESULT__ FAIL")
}

// ─── project_hash: git remote origin sha1-12, 없으면 noremote ───
fn project_hash() -> string {
    let url = _str(exec("git remote get-url origin 2>/dev/null")).trim()  // @allow-bare-exec
    if url == "" { return "noremote" }
    let esc = url.replace("'", "")
    let cmd = "printf '%s' '" + esc + "' | /usr/bin/shasum -a 1 2>/dev/null | cut -c1-12"
    let r = _str(exec(cmd)).trim()  // @allow-bare-exec
    if r == "" { return "noremote" }
    return r
}

fn ensure_dir(path: string) {
    exec("mkdir -p '" + path.replace("'", "") + "' 2>/dev/null")  // @allow-bare-exec
}

fn ensure_file(path: string) {
    if file_exists(path) == false {
        try { write_file(path, "") } catch e {}
    }
}

fn proj_dir(ph: string) -> string {
    return PROJ_ROOT + "/" + ph
}

fn candidates_path(ph: string) -> string {
    return proj_dir(ph) + "/candidates.jsonl"
}

// ─── kebab-case id 생성 (trigger+action 해시 8자) ───
fn make_id(trigger: string, action: string) -> string {
    let raw = trigger + "|" + action
    let esc = raw.replace("'", "")
    let cmd = "printf '%s' '" + esc + "' | /usr/bin/shasum -a 256 2>/dev/null | cut -c1-8"
    let r = _str(exec(cmd)).trim()  // @allow-bare-exec
    if r == "" { return "inst-" + to_string(now_unix()) }
    return "inst-" + r
}

// ─── initial confidence 규칙 ───
fn initial_confidence(n: i64) -> string {
    if n >= 11 { return "0.85" }
    if n >= 6 { return "0.70" }
    if n >= 3 { return "0.50" }
    return "0.30"
}

// ─── observations.jsonl 에서 pattern_key 별 count 집계 ───
// 반환: "pattern_key\tcount" 다중 라인
fn aggregate_observations() -> string {
    if file_exists(OBS_LOG) == false { return "" }
    // 최근 2000줄만 (대용량 대비)
    let cmd = "tail -2000 '" + OBS_LOG + "' 2>/dev/null | " +
              "/usr/bin/jq -r '.pattern_key // empty' 2>/dev/null | " +
              "grep -v '^$' | sort | uniq -c | awk '{count=$1; $1=\"\"; sub(/^ /,\"\"); print $0\"\\t\"count}'"
    return _str(exec(cmd)).trim()  // @allow-bare-exec
}

// ─── mistakes.jsonl 에서 rule 별 count ───
fn aggregate_mistakes() -> string {
    if file_exists(MISTAKES) == false { return "" }
    let cmd = "tail -2000 '" + MISTAKES + "' 2>/dev/null | " +
              "/usr/bin/jq -r '.rule // .kind // empty' 2>/dev/null | " +
              "grep -v '^$' | sort | uniq -c | awk '$1 >= 3 {count=$1; $1=\"\"; sub(/^ /,\"\"); print $0\"\\t\"count}'"
    return _str(exec(cmd)).trim()  // @allow-bare-exec
}

// ─── 기존 candidates 에서 id 존재 확인 ───
fn candidate_exists(path: string, id: string) -> bool {
    if file_exists(path) == false { return false }
    let cmd = "grep -c '\"id\":\"" + id + "\"' '" + path + "' 2>/dev/null"
    let n = _to_int0(_str(exec(cmd)).trim())  // @allow-bare-exec
    return n > 0
}

// ─── last_seen 만 업데이트 (기존 id 재관측) ───
fn update_last_seen(path: string, id: string, ts: string) {
    let cmd = "/usr/bin/sed -i.bak -E 's/(\"id\":\"" + id + "\"[^\\n]*\"last_seen\":\")[^\"]+(\")/\\1" +
              ts + "\\2/' '" + path + "' && rm -f '" + path + ".bak'"
    exec(cmd)  // @allow-bare-exec
}

// ─── 신규 candidate row append ───
fn append_candidate(path: string, id: string, trigger: string, action: string,
                    conf: string, domain: string, scope_s: string, ph: string) {
    let ts = now_iso()
    let row = "{\"id\":\"" + id + "\"," +
              "\"trigger\":\"" + json_escape(trigger) + "\"," +
              "\"action\":\"" + json_escape(action) + "\"," +
              "\"confidence\":" + conf + "," +
              "\"domain\":\"" + json_escape(domain) + "\"," +
              "\"scope\":\"" + scope_s + "\"," +
              "\"project_hash\":\"" + ph + "\"," +
              "\"first_seen\":\"" + ts + "\"," +
              "\"last_seen\":\"" + ts + "\"," +
              "\"n_confirm\":0," +
              "\"n_contradict\":0," +
              "\"status\":\"pending\"}"
    try { append_file(path, row + "\n") } catch e {
        eprintln("FAIL: append_file " + path)
    }
}

// ─── SCAN ───
fn cmd_scan() {
    let ph = project_hash()
    ensure_dir(proj_dir(ph))
    let path = candidates_path(ph)
    ensure_file(path)

    let mut added: i64 = 0
    let mut updated: i64 = 0
    let ts = now_iso()

    // observations 소스
    let obs_raw = aggregate_observations()
    if obs_raw.len() > 0 {
        for line in obs_raw.split("\n") {
            let lt = _str(line).trim()
            if lt.len() == 0 { continue }
            let parts = lt.split("\t")
            if parts.len() < 2 { continue }
            let pattern = _str(parts[0]).trim()
            let cnt_s = _str(parts[1]).trim()
            let cnt = _to_int0(cnt_s)
            if cnt < 3 { continue }  // 최소 3 obs
            let trigger = "observe:" + pattern
            let action = "review_" + pattern
            let id = make_id(trigger, action)
            if candidate_exists(path, id) {
                update_last_seen(path, id, ts)
                updated = updated + 1
            } else {
                let conf = initial_confidence(cnt)
                append_candidate(path, id, trigger, action, conf, "observation", "project", ph)
                added = added + 1
            }
        }
    }

    // mistakes 소스
    let mis_raw = aggregate_mistakes()
    if mis_raw.len() > 0 {
        for line in mis_raw.split("\n") {
            let lt = _str(line).trim()
            if lt.len() == 0 { continue }
            let parts = lt.split("\t")
            if parts.len() < 2 { continue }
            let rule = _str(parts[0]).trim()
            let cnt_s = _str(parts[1]).trim()
            let cnt = _to_int0(cnt_s)
            if cnt < 3 { continue }
            let trigger = "mistake:" + rule
            let action = "prevent_" + rule
            let id = make_id(trigger, action)
            if candidate_exists(path, id) {
                update_last_seen(path, id, ts)
                updated = updated + 1
            } else {
                let conf = initial_confidence(cnt)
                append_candidate(path, id, trigger, action, conf, "mistake", "project", ph)
                added = added + 1
            }
        }
    }

    // rules_usage active 소스
    if file_exists(USAGE) {
        let cmd = "tail -500 '" + USAGE + "' 2>/dev/null | /usr/bin/jq -r 'select(.status==\"active\") | .rule' 2>/dev/null | sort -u"
        let raw = _str(exec(cmd)).trim()  // @allow-bare-exec
        for line in raw.split("\n") {
            let rule = _str(line).trim()
            if rule.len() == 0 { continue }
            let trigger = "usage:" + rule
            let action = "reinforce_" + rule
            let id = make_id(trigger, action)
            if candidate_exists(path, id) {
                update_last_seen(path, id, ts)
                updated = updated + 1
            } else {
                append_candidate(path, id, trigger, action, "0.30", "usage", "project", ph)
                added = added + 1
            }
        }
    }

    if added > 0 || updated > 0 {
        println("scan: added=" + to_string(added) + " updated=" + to_string(updated) + " path=" + path)
    }
    sentinel_pass()
}

// ─── id 기반 candidate JSON 라인 추출 (projects/*/*candidates.jsonl 전체) ───
fn find_candidate_line(id: string) -> string {
    let cmd = "grep -h '\"id\":\"" + id + "\"' " + PROJ_ROOT + "/*/candidates.jsonl 2>/dev/null | head -1"
    return _str(exec(cmd)).trim()  // @allow-bare-exec
}

fn find_candidate_path(id: string) -> string {
    let cmd = "grep -l '\"id\":\"" + id + "\"' " + PROJ_ROOT + "/*/candidates.jsonl 2>/dev/null | head -1"
    return _str(exec(cmd)).trim()  // @allow-bare-exec
}

// ─── jq 로 필드 치환 (bsd/gnu sed race 회피 — rewrite 방식) ───
fn rewrite_candidate(path: string, id: string, jq_filter: string) {
    if file_exists(path) == false { return }
    let tmp = path + ".tmp"
    let cmd = "/usr/bin/jq -c --arg id '" + id + "' 'if .id == $id then " + jq_filter +
              " else . end' '" + path + "' > '" + tmp + "' && mv '" + tmp + "' '" + path + "'"
    exec(cmd)  // @allow-bare-exec
}

// ─── SCORE ───
fn cmd_score(argv: [string]) {
    if argv.len() < 4 {
        eprintln("usage: score --confirm <id> | --contradict <id> | --decay")
        sentinel_fail()
        return
    }
    let sub = _str(argv[3]).trim()
    let ts = now_iso()

    if sub == "--decay" {
        // 모든 pending candidate confidence -0.02 (week decay — 호출자가 주기 제어)
        let cmd = "for f in " + PROJ_ROOT + "/*/candidates.jsonl; do " +
                  "[ -f \"$f\" ] || continue; " +
                  "/usr/bin/jq -c 'if .status==\"pending\" then .confidence = ((.confidence - 0.02) | if . < 0 then 0 else . end) else . end' \"$f\" > \"$f.tmp\" && mv \"$f.tmp\" \"$f\"; " +
                  "done"
        exec(cmd)  // @allow-bare-exec
        println("score --decay: applied -0.02 to all pending")
        sentinel_pass()
        return
    }

    if argv.len() < 5 {
        eprintln("usage: score --confirm <id> | --contradict <id>")
        sentinel_fail()
        return
    }
    let id = _str(argv[4]).trim()
    if id.len() == 0 {
        eprintln("REJECT: id empty")
        sentinel_fail()
        return
    }
    let path = find_candidate_path(id)
    if path == "" {
        eprintln("FAIL: id not found: " + id)
        sentinel_fail()
        return
    }

    if sub == "--confirm" {
        let jqf = ".n_confirm = (.n_confirm + 1) | .confidence = ((.confidence + 0.05) | if . > 1 then 1 else . end) | .last_seen = \"" + ts + "\""
        rewrite_candidate(path, id, jqf)
        println("confirm: " + id)
        sentinel_pass()
        return
    }
    if sub == "--contradict" {
        let jqf = ".n_contradict = (.n_contradict + 1) | .confidence = ((.confidence - 0.10) | if . < 0 then 0 else . end) | .last_seen = \"" + ts + "\""
        rewrite_candidate(path, id, jqf)
        println("contradict: " + id)
        sentinel_pass()
        return
    }
    eprintln("unknown subcommand: " + sub)
    sentinel_fail()
}

// ─── PROMOTE: N+ 프로젝트 × avg ≥ 0.8 → global/promoted.jsonl ───
// env: INSTINCT_MIN_PROJECTS (default 1, 단일리포 친화. 다중리포 운영 시 2+)
fn cmd_promote() {
    ensure_dir(GLOBAL_ROOT)
    ensure_file(PROMOTED)

    let mut min_proj_s = _str(env("INSTINCT_MIN_PROJECTS")).trim()
    if min_proj_s == "" { min_proj_s = "1" }
    let min_proj = _to_int0(min_proj_s)
    if min_proj < 1 { min_proj_s = "1" }

    // id 별 프로젝트 수 + 평균 confidence 집계
    let cmd = "cat " + PROJ_ROOT + "/*/candidates.jsonl 2>/dev/null | " +
              "/usr/bin/jq -r 'select(.status==\"pending\") | [.id, .project_hash, .confidence] | @tsv' 2>/dev/null | " +
              "awk -F'\\t' -v MINP=" + min_proj_s + " '{ " +
              "  sum[$1]+=$3; cnt[$1]++; " +
              "  if (!($1 SUBSEP $2 in seen)) { seen[$1 SUBSEP $2]=1; proj[$1]++ } " +
              "} END { " +
              "  for (id in cnt) { " +
              "    avg = sum[id]/cnt[id]; " +
              "    if (proj[id] >= MINP && avg >= 0.8) printf \"%s\\t%.4f\\t%d\\n\", id, avg, proj[id] " +
              "  } " +
              "}'"
    let raw = _str(exec(cmd)).trim()  // @allow-bare-exec
    if raw == "" {
        println("promote: 0 candidates eligible")
        sentinel_pass()
        return
    }

    let ts = now_iso()
    let mut promoted_count: i64 = 0
    for line in raw.split("\n") {
        let lt = _str(line).trim()
        if lt.len() == 0 { continue }
        let parts = lt.split("\t")
        if parts.len() < 3 { continue }
        let id = _str(parts[0]).trim()
        let avg = _str(parts[1]).trim()
        let proj_n = _str(parts[2]).trim()

        // 원본 라인 하나 복제
        let src_line = find_candidate_line(id)
        if src_line == "" { continue }
        // promoted row
        let prow = "{\"id\":\"" + id + "\"," +
                   "\"promoted_at\":\"" + ts + "\"," +
                   "\"avg_confidence\":" + avg + "," +
                   "\"n_projects\":" + proj_n + "," +
                   "\"origin\":" + src_line + "}"
        try { append_file(PROMOTED, prow + "\n") } catch e {}
        // 원본 status=pending → promoted 로 전 프로젝트 rewrite
        let find_cmd = "grep -l '\"id\":\"" + id + "\"' " + PROJ_ROOT + "/*/candidates.jsonl 2>/dev/null"
        let paths = _str(exec(find_cmd)).trim()  // @allow-bare-exec
        for p in paths.split("\n") {
            let pt = _str(p).trim()
            if pt.len() == 0 { continue }
            let jqf = ".status = \"promoted\""
            rewrite_candidate(pt, id, jqf)
        }
        promoted_count = promoted_count + 1
    }
    println("promote: " + to_string(promoted_count) + " candidates → " + PROMOTED)
    sentinel_pass()
}

// ─── PRUNE: pending AND (now - last_seen_unix) > 30d → pruned ───
fn cmd_prune() {
    let now = now_unix()
    let cutoff = now - SEC_30D
    // jq 로 last_seen ISO → epoch 변환 후 판정 (date -d 안 쓰고 문자열 비교)
    // ISO 문자열 비교로 대체: (now - 30d) 의 ISO 생성
    let cutoff_iso = _str(exec("date -u -r " + to_string(cutoff) + " +%Y-%m-%dT%H:%M:%SZ 2>/dev/null")).trim()  // @allow-bare-exec
    if cutoff_iso == "" {
        // linux fallback
        let alt = _str(exec("date -u -d '@" + to_string(cutoff) + "' +%Y-%m-%dT%H:%M:%SZ 2>/dev/null")).trim()  // @allow-bare-exec
        if alt == "" {
            eprintln("FAIL: cutoff iso 생성 불가")
            sentinel_fail()
            return
        }
    }
    let cutoff_final = if cutoff_iso.len() > 0 { cutoff_iso } else { _str(exec("date -u -d '@" + to_string(cutoff) + "' +%Y-%m-%dT%H:%M:%SZ 2>/dev/null")).trim() }  // @allow-bare-exec

    let cmd = "for f in " + PROJ_ROOT + "/*/candidates.jsonl; do " +
              "[ -f \"$f\" ] || continue; " +
              "/usr/bin/jq -c --arg c '" + cutoff_final + "' " +
              "'if (.status==\"pending\" and .last_seen < $c) then .status = \"pruned\" else . end' " +
              "\"$f\" > \"$f.tmp\" && mv \"$f.tmp\" \"$f\"; " +
              "done"
    exec(cmd)  // @allow-bare-exec
    // 통계
    let count_cmd = "cat " + PROJ_ROOT + "/*/candidates.jsonl 2>/dev/null | grep -c '\"status\":\"pruned\"'"
    let n = _to_int0(_str(exec(count_cmd)).trim())  // @allow-bare-exec
    println("prune: total pruned=" + to_string(n) + " (cutoff=" + cutoff_final + ")")
    sentinel_pass()
}

// ─── STATUS ───
fn cmd_status() {
    let ph = project_hash()
    let path = candidates_path(ph)
    println("project_hash: " + ph)
    println("candidates: " + path)
    if file_exists(path) {
        let total = _to_int0(_str(exec("wc -l < '" + path + "' 2>/dev/null")).trim())  // @allow-bare-exec
        let pending = _to_int0(_str(exec("grep -c '\"status\":\"pending\"' '" + path + "' 2>/dev/null")).trim())  // @allow-bare-exec
        let promoted = _to_int0(_str(exec("grep -c '\"status\":\"promoted\"' '" + path + "' 2>/dev/null")).trim())  // @allow-bare-exec
        let pruned = _to_int0(_str(exec("grep -c '\"status\":\"pruned\"' '" + path + "' 2>/dev/null")).trim())  // @allow-bare-exec
        println("  total=" + to_string(total) + " pending=" + to_string(pending) + " promoted=" + to_string(promoted) + " pruned=" + to_string(pruned))
    } else {
        println("  (no candidates yet — run 'scan')")
    }
    if file_exists(PROMOTED) {
        let gp = _to_int0(_str(exec("wc -l < '" + PROMOTED + "' 2>/dev/null")).trim())  // @allow-bare-exec
        println("global promoted: " + to_string(gp) + " entries @ " + PROMOTED)
    }
    sentinel_pass()
}

fn cmd_project_hash() {
    println(project_hash())
    sentinel_pass()
}

fn main() {
    ensure_launchd_sandbox()
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    if argv.len() < 3 {
        eprintln("usage: instinct.hexa <scan|score|promote|prune|status|project_hash> [args]")
        sentinel_fail()
        return
    }
    ensure_dir(INST_ROOT)
    ensure_dir(PROJ_ROOT)
    ensure_dir(GLOBAL_ROOT)

    let mode = _str(argv[2]).trim()
    if mode == "scan" { cmd_scan() }
    else if mode == "score" { cmd_score(argv) }
    else if mode == "promote" { cmd_promote() }
    else if mode == "prune" { cmd_prune() }
    else if mode == "status" { cmd_status() }
    else if mode == "project_hash" { cmd_project_hash() }
    else {
        eprintln("REJECT: unknown mode '" + mode + "' — modes: scan|score|promote|prune|status|project_hash")
        sentinel_fail()
    }
}

main()
