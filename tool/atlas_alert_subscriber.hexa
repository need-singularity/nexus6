// tool/atlas_alert_subscriber.hexa — JSONL stream subscriber for bridge_anomaly verdicts (ω-bridge-17)
//
// raw 9 hexa-only-suffix (sweeper-safe .hexa). ω-bridge-16 promoted the
// __BRIDGE_ANOMALY__ sentinel into a structured sibling row in
// state/atlas_health_timeline.jsonl scoped 'bridge_anomaly'. With persistence
// in place we can now reason over verdict *trends* across sweeps rather than
// reacting to a single sentinel in isolation.
//
// This tool is a one-shot poller (NOT continuous tail -F — kept simple for
// stage1): it reads the timeline up to current EOF, filters scope==bridge_anomaly,
// keeps the last N matching rows, and evaluates configurable alert rules.
//
// Read-only on the timeline (raw 71 / raw 77). Parallel-session may be
// appending while we read; we tolerate this — read_file is a single fs syscall
// snapshot and any mid-read append is just truncated past EOF, not a problem
// for "last N" tail semantics.
//
// @tool(slug="atlas_alert_subscriber", desc="bridge_anomaly JSONL trend alerter")
// @usage:
//   hexa run tool/atlas_alert_subscriber.hexa                                        # default
//   HEXA_ARGV='--last 20' hexa run tool/atlas_alert_subscriber.hexa
//   HEXA_ARGV='--warn-threshold 0.3' hexa run tool/atlas_alert_subscriber.hexa
//   HEXA_ARGV='--insufficient-threshold 0.7' hexa run tool/atlas_alert_subscriber.hexa
//   HEXA_ARGV='--timeline /tmp/fixture.jsonl' hexa run tool/atlas_alert_subscriber.hexa
//   HEXA_ARGV='--no-history' hexa run tool/atlas_alert_subscriber.hexa            (ω-bridge-21)
//   ATLAS_ALERT_HISTORY_TSV=/tmp/foo.tsv hexa run tool/atlas_alert_subscriber.hexa (ω-bridge-21)
//   ATLAS_ALERT_HISTORY_JSONL=/tmp/foo.jsonl hexa run tool/atlas_alert_subscriber.hexa (ω-bridge-23)
//   HEXA_ARGV='--cooldown-minutes 10' hexa run tool/atlas_alert_subscriber.hexa  (ω-bridge-24)
//   ATLAS_ALERT_COOLDOWN=10 hexa run tool/atlas_alert_subscriber.hexa             (ω-bridge-24)
//   HEXA_ARGV='--quiet' hexa run tool/atlas_alert_subscriber.hexa
//   HEXA_ARGV='--help' hexa run tool/atlas_alert_subscriber.hexa
//
// sentinels (raw 80):
//   __ATLAS_ALERT__ SKIP reason=timeline_missing path=...
//   __ATLAS_ALERT__ SKIP reason=no_matching_rows scope=bridge_anomaly
//   __ATLAS_ALERT__ FIRED rule=warn_ratio        ratio=R threshold=T last_n=N sampled=S
//   __ATLAS_ALERT__ FIRED rule=insufficient_ratio ratio=R threshold=T last_n=N sampled=S
//   __ATLAS_ALERT__ FIRED rule=consecutive_warn  streak=K observed=K last_n=N sampled=S       (ω-bridge-19)
//   __ATLAS_ALERT__ FIRED rule=recent_warn_ratio ratio=R threshold=T window_minutes=M sampled=S (ω-bridge-19)
//   __ATLAS_ALERT__ SUPPRESSED rule=R reason=cooldown last_fired_ago_min=X cooldown_minutes=M (ω-bridge-24)
//   __ATLAS_ALERT__ PASS sampled=S rules_evaluated=R
//   __ATLAS_ALERT__ HISTORY_WRITE_FAIL path=PATH reason=...                            (ω-bridge-21)
//   __ATLAS_ALERT__ HISTORY_WRITE_FAIL path=PATH reason=jsonl_append_failed             (ω-bridge-23)
//
// rules (configurable via HEXA_ARGV):
//   --last N                          inspect last N matching rows                     (default 10)
//   --warn-threshold R                fire if WARN ratio of last N >= R                (default 0.4)
//   --insufficient-threshold R        fire if INSUFFICIENT_DATA ratio >= R             (default 0.6)
//   --streak-threshold K              fire if last K matching rows are ALL WARN        (default 0 = disabled, ω-bridge-19)
//   --window-minutes M                fire if WARN-ratio over last M minutes (by ts)
//                                     >= --warn-threshold                              (default 0 = disabled, ω-bridge-19)
//   --cooldown-minutes M              suppress same-rule re-firings within M minutes   (default 0 = disabled, ω-bridge-24)
//   --timeline PATH                   override timeline path (testing fixtures)
//   --no-history                      do NOT append firing events to atlas_alert_history.tsv (ω-bridge-21)
//   --quiet                           sentinel-only output
//
// raw compliance: 71 read-only-on-timeline / 73 admissibility / 77 append-only /
//                 80 sentinel
//
// Origin: design/hexa_sim/cross_repo_dashboard.md ω-bridge-17 entry
//         /Users/ghost/core/anima/state/omega_bridge_17_*.json
//         /Users/ghost/core/anima/state/omega_bridge_19_*.json (time-shape rules)
//         /Users/ghost/core/anima/state/omega_bridge_21_*.json (history persistence)
//         /Users/ghost/core/anima/state/omega_bridge_23_24_*.json (JSONL sibling + cooldown dedup)

let NEXUS = "/Users/ghost/core/nexus"
let DEFAULT_TIMELINE = NEXUS + "/state/atlas_health_timeline.jsonl"
let DEFAULT_HISTORY_TSV = NEXUS + "/state/atlas_alert_history.tsv"   // ω-bridge-21
let DEFAULT_HISTORY_JSONL = NEXUS + "/state/atlas_alert_history.jsonl"  // ω-bridge-23
let HISTORY_HEADER = "# atlas_alert_history.tsv — alert firing event log (raw 77 append-only)\n# ts\trule\tratio\tthreshold\tlast_n\tsampled\textra\n"  // ω-bridge-21
let DEFAULT_LAST = "10"
let DEFAULT_WARN_THR = "0.4"
let DEFAULT_INSUF_THR = "0.6"
let DEFAULT_STREAK = "0"        // ω-bridge-19 — 0 = disabled (existing-behaviour preserved)
let DEFAULT_WINDOW_MIN = "0"    // ω-bridge-19 — 0 = disabled
let DEFAULT_COOLDOWN_MIN = "0"  // ω-bridge-24 — 0 = disabled (full backward compat)
let DEDUP_TAIL_K = "20"         // ω-bridge-24 — perf bound on TSV tail-scan for dedup
let TARGET_SCOPE = "bridge_anomaly"
let ALERT_SCOPE = "atlas_alert"  // ω-bridge-23 — discriminator for our own JSONL rows

let mut QUIET = false

fn _argv() -> array {
    let raw = to_string(exec("printf '%s' \"${HEXA_ARGV:-}\""))
    let parts = split(raw, " ")
    let mut out = []
    let mut k = 0
    while k < len(parts) {
        if len(parts[k]) > 0 { out.push(parts[k]) }
        k = k + 1
    }
    return out
}

fn _say(msg: string) { if !QUIET { println(msg) } }

let args = _argv()
let mut timeline_path = DEFAULT_TIMELINE
let mut last_str = DEFAULT_LAST
let mut warn_thr_str = DEFAULT_WARN_THR
let mut insuf_thr_str = DEFAULT_INSUF_THR
let mut streak_str = DEFAULT_STREAK            // ω-bridge-19
let mut window_min_str = DEFAULT_WINDOW_MIN    // ω-bridge-19
let mut write_history = true                   // ω-bridge-21 — default ON
let mut cooldown_str = DEFAULT_COOLDOWN_MIN    // ω-bridge-24
let mut i = 0
while i < len(args) {
    let a = args[i]
    if a == "--quiet" { QUIET = true }
    if a == "--no-history" { write_history = false }   // ω-bridge-21
    if a == "--timeline" && i + 1 < len(args) { timeline_path = args[i+1]; i = i + 1 }
    if a == "--last" && i + 1 < len(args) { last_str = args[i+1]; i = i + 1 }
    if a == "--warn-threshold" && i + 1 < len(args) { warn_thr_str = args[i+1]; i = i + 1 }
    if a == "--insufficient-threshold" && i + 1 < len(args) { insuf_thr_str = args[i+1]; i = i + 1 }
    if a == "--streak-threshold" && i + 1 < len(args) { streak_str = args[i+1]; i = i + 1 }
    if a == "--window-minutes" && i + 1 < len(args) { window_min_str = args[i+1]; i = i + 1 }
    if a == "--cooldown-minutes" && i + 1 < len(args) { cooldown_str = args[i+1]; i = i + 1 }  // ω-bridge-24
    if a == "--help" || a == "-h" {
        println("usage: HEXA_ARGV='[--timeline PATH] [--last N] [--warn-threshold R] [--insufficient-threshold R] [--streak-threshold K] [--window-minutes M] [--cooldown-minutes M] [--no-history] [--quiet]' hexa run tool/atlas_alert_subscriber.hexa")
        println("  default: scan state/atlas_health_timeline.jsonl, last 10 bridge_anomaly rows")
        println("  --last N                       inspect last N matching rows  (default 10)")
        println("  --warn-threshold R             fire if WARN/N >= R           (default 0.4)")
        println("  --insufficient-threshold R     fire if INSUFFICIENT_DATA/N >= R (default 0.6)")
        println("  --streak-threshold K           fire consecutive_warn if last K matching rows are ALL WARN (default 0 = off)")
        println("  --window-minutes M             fire recent_warn_ratio if WARN-ratio over last M minutes (by ts) >= --warn-threshold (default 0 = off)")
        println("  --cooldown-minutes M           suppress same-rule re-firings within M minutes (default 0 = off, ω-bridge-24)")
        println("  --timeline PATH                override timeline path (fixtures)")
        println("  --no-history                   skip appending firing events to atlas_alert_history.tsv (default: write)")
        println("  --quiet                        emit __ATLAS_ALERT__ sentinel only")
        println("env: ATLAS_ALERT_HISTORY_TSV=PATH    override history TSV path (default: state/atlas_alert_history.tsv)")
        println("env: ATLAS_ALERT_HISTORY_JSONL=PATH  override history JSONL path (default: state/atlas_alert_history.jsonl, ω-bridge-23)")
        println("env: ATLAS_ALERT_COOLDOWN=M          cooldown minutes (overrides --cooldown-minutes, ω-bridge-24)")
        return
    }
    i = i + 1
}

// ω-bridge-21 — resolve history TSV path (env override > default)
let env_history = to_string(exec("printf '%s' \"${ATLAS_ALERT_HISTORY_TSV:-}\"")).trim()
let mut history_path = DEFAULT_HISTORY_TSV
if len(env_history) > 0 { history_path = env_history }

// ω-bridge-23 — resolve history JSONL sibling path (env override > default)
let env_history_jsonl = to_string(exec("printf '%s' \"${ATLAS_ALERT_HISTORY_JSONL:-}\"")).trim()
let mut history_jsonl_path = DEFAULT_HISTORY_JSONL
if len(env_history_jsonl) > 0 { history_jsonl_path = env_history_jsonl }

// ω-bridge-24 — resolve cooldown minutes (env override > flag > default 0).
// Negative values clamped to 0; non-numeric strings collapse to 0 via awk's
// implicit numeric coercion. cooldown_min is the canonical value used below.
let env_cooldown = to_string(exec("printf '%s' \"${ATLAS_ALERT_COOLDOWN:-}\"")).trim()
if len(env_cooldown) > 0 { cooldown_str = env_cooldown }
let cooldown_min = to_string(exec("awk 'BEGIN { v = (\"" + cooldown_str + "\"+0); if (v < 0) v = 0; print v }' </dev/null")).trim()

// ─── pre-flight ──────────────────────────────────────────────────────────────
if !file_exists(timeline_path) {
    println("__ATLAS_ALERT__ SKIP reason=timeline_missing path=" + timeline_path)
    return
}

// ─── load + filter ───────────────────────────────────────────────────────────
// JSONL parse via shell tooling is overkill here — we only need:
//   1. presence of "scope":"bridge_anomaly"
//   2. extracted verdict in {PASS, WARN, INSUFFICIENT_DATA}
// A naive substring scan suffices for the controlled schema (raw 73): the
// timeline writer is bridge_health.sh (ω-bridge-16), single producer, fixed
// field order, no escaping concerns inside the fields we read.

let raw_content = to_string(read_file(timeline_path))
let lines = split(raw_content, "\n")

let scope_marker = "\"scope\":\"" + TARGET_SCOPE + "\""

let mut matched = []
for line in lines {
    let t = line.trim()
    if len(t) == 0 { continue }
    if !t.contains(scope_marker) { continue }
    matched.push(t)
}

let total_matched = len(matched)
if total_matched == 0 {
    println("__ATLAS_ALERT__ SKIP reason=no_matching_rows scope=" + TARGET_SCOPE + " path=" + timeline_path)
    return
}

// Tail to last N rows. last_str is a small int; use shell tail so we don't
// re-implement integer parse + slice in hexa.
let last_int = to_string(exec("printf '%d' " + last_str)).trim()
let mut joined = ""
let mut s = 0
while s < len(matched) {
    joined = joined + matched[s] + "\n"
    s = s + 1
}
let tail_cmd = "printf '%s' '" + joined + "' | tail -" + last_int
let tail_out = to_string(exec(tail_cmd)).trim()
let tail_lines = split(tail_out, "\n")
let sampled = len(tail_lines)

// ─── verdict tally ───────────────────────────────────────────────────────────
let mut warn_n = 0
let mut insuf_n = 0
let mut pass_n = 0
let mut other_n = 0

let warn_marker  = "\"verdict\":\"WARN\""
let insuf_marker = "\"verdict\":\"INSUFFICIENT_DATA\""
let pass_marker  = "\"verdict\":\"PASS\""

let mut li = 0
while li < len(tail_lines) {
    let row = tail_lines[li]
    if row.contains(warn_marker) {
        warn_n = warn_n + 1
    } else if row.contains(insuf_marker) {
        insuf_n = insuf_n + 1
    } else if row.contains(pass_marker) {
        pass_n = pass_n + 1
    } else {
        other_n = other_n + 1
    }
    li = li + 1
}

// ─── ratio compute (single awk call — avoids hexa float parse) ───────────────
// Output: "<warn_ratio> <insuf_ratio>" formatted to 4 decimals.
let ratio_prog = "BEGIN { " +
    "  s=" + to_string(sampled) + "+0; " +
    "  if (s==0) { printf \"0.0000 0.0000\\n\"; exit } " +
    "  wr=(" + to_string(warn_n) + "+0)/s; " +
    "  ir=(" + to_string(insuf_n) + "+0)/s; " +
    "  printf \"%.4f %.4f\\n\", wr, ir; " +
    "}"
let ratios_out = to_string(exec("awk '" + ratio_prog + "' </dev/null")).trim()
let rparts = split(ratios_out, " ")
let mut warn_ratio_s = "0.0000"
let mut insuf_ratio_s = "0.0000"
if len(rparts) >= 2 {
    warn_ratio_s = rparts[0]
    insuf_ratio_s = rparts[1]
}

// ─── rule evaluation (awk for >= compare on floats) ──────────────────────────
let mut rules_evaluated = 2

let warn_cmp = to_string(exec("awk 'BEGIN { print ((" + warn_ratio_s + "+0) >= (" + warn_thr_str + "+0)) ? 1 : 0 }' </dev/null")).trim()
let insuf_cmp = to_string(exec("awk 'BEGIN { print ((" + insuf_ratio_s + "+0) >= (" + insuf_thr_str + "+0)) ? 1 : 0 }' </dev/null")).trim()

let mut fired = []
// ω-bridge-21 — parallel event records for history TSV. Each fired sentinel
// pushes one TSV row (TAB-separated) into `event_rows` in lockstep. Schema:
//   ts<TAB>rule<TAB>ratio<TAB>threshold<TAB>last_n<TAB>sampled<TAB>extra
// The ts is filled in at write time (system clock at emit, not row ts).
let mut event_rows = []
// ω-bridge-23 — parallel JSONL row fragments (sans ts; ts is injected at write
// time alongside the TSV ts so they line up exactly). Each entry is the inner
// body of the JSON object, ready to be wrapped as
//   {"ts":"...","scope":"atlas_alert",<body>}
let mut event_jsonl_bodies = []
// ω-bridge-24 — parallel rule-name list for cooldown dedup. Indices stay in
// lockstep with `fired` / `event_rows` / `event_jsonl_bodies` so post-hoc
// suppression can drop matched indices uniformly across all four arrays.
let mut fired_rules = []
if warn_cmp == "1" {
    fired.push("__ATLAS_ALERT__ FIRED rule=warn_ratio ratio=" + warn_ratio_s + " threshold=" + warn_thr_str + " last_n=" + last_str + " sampled=" + to_string(sampled))
    event_rows.push("warn_ratio\t" + warn_ratio_s + "\t" + warn_thr_str + "\t" + last_str + "\t" + to_string(sampled) + "\t")
    event_jsonl_bodies.push("\"rule\":\"warn_ratio\",\"ratio\":" + warn_ratio_s + ",\"threshold\":" + warn_thr_str + ",\"last_n\":" + last_str + ",\"sampled\":" + to_string(sampled) + ",\"extra\":\"\"")
    fired_rules.push("warn_ratio")
}
if insuf_cmp == "1" {
    fired.push("__ATLAS_ALERT__ FIRED rule=insufficient_ratio ratio=" + insuf_ratio_s + " threshold=" + insuf_thr_str + " last_n=" + last_str + " sampled=" + to_string(sampled))
    event_rows.push("insufficient_ratio\t" + insuf_ratio_s + "\t" + insuf_thr_str + "\t" + last_str + "\t" + to_string(sampled) + "\t")
    event_jsonl_bodies.push("\"rule\":\"insufficient_ratio\",\"ratio\":" + insuf_ratio_s + ",\"threshold\":" + insuf_thr_str + ",\"last_n\":" + last_str + ",\"sampled\":" + to_string(sampled) + ",\"extra\":\"\"")
    fired_rules.push("insufficient_ratio")
}

// ─── ω-bridge-19: consecutive WARN streak (time-shape rule, hot-anomaly) ─────
// Walks tail_lines from end; counts how many consecutive trailing rows are WARN.
// All entries in tail_lines are already filtered to scope=bridge_anomaly (matched
// above) — so the "skip non-matching to compute streak only on matching rows"
// edge case is satisfied automatically.
let streak_int = to_string(exec("printf '%d' " + streak_str + " 2>/dev/null || printf 0")).trim()
let streak_k = to_string(exec("awk 'BEGIN { print (" + streak_int + "+0) }' </dev/null")).trim()
if streak_k != "0" {
    rules_evaluated = rules_evaluated + 1
    // Count trailing consecutive WARN — break on first non-WARN.
    let mut observed = 0
    let mut walk = len(tail_lines) - 1
    while walk >= 0 {
        let row = tail_lines[walk]
        if row.contains(warn_marker) {
            observed = observed + 1
        } else {
            walk = -1  // break
        }
        walk = walk - 1
    }
    let cmp = to_string(exec("awk 'BEGIN { print ((" + to_string(observed) + "+0) >= (" + streak_k + "+0)) ? 1 : 0 }' </dev/null")).trim()
    if cmp == "1" {
        fired.push("__ATLAS_ALERT__ FIRED rule=consecutive_warn streak=" + streak_k + " observed=" + to_string(observed) + " last_n=" + last_str + " sampled=" + to_string(sampled))
        // ω-bridge-21 — streak rule has no ratio/threshold; encode 0 / extra=streak=K
        event_rows.push("consecutive_warn\t0.0000\t0\t" + last_str + "\t" + to_string(sampled) + "\tstreak=" + streak_k)
        // ω-bridge-23 — JSONL body. Streak rule: ratio=0.0, threshold=0, extra="streak=K"
        event_jsonl_bodies.push("\"rule\":\"consecutive_warn\",\"ratio\":0.0,\"threshold\":0,\"last_n\":" + last_str + ",\"sampled\":" + to_string(sampled) + ",\"extra\":\"streak=" + streak_k + "\"")
        fired_rules.push("consecutive_warn")
    }
}

// ─── ω-bridge-19: time-decay window (recent WARN-ratio over last M minutes) ──
// Filters `matched` (NOT tail_lines — window is time-bounded, not count-bounded)
// to rows whose ts is within [now - M*60, now]. Future-dated rows excluded
// defensively. Parse failures skipped silently (raw 71). Ratio computed via
// python3 (single shell-out) to avoid duplicating ISO-8601 parsing per-row.
let window_min_int = to_string(exec("printf '%d' " + window_min_str + " 2>/dev/null || printf 0")).trim()
let window_m = to_string(exec("awk 'BEGIN { print (" + window_min_int + "+0) }' </dev/null")).trim()
if window_m != "0" {
    rules_evaluated = rules_evaluated + 1
    // Build joined matched rows for python3. Reuse `joined` from the earlier
    // tail compute — it already contains every matched row, newline-terminated.
    // Write to a temp file to avoid quoting hell with embedded JSON.
    let tmpf = "/tmp/atlas_alert_window_" + to_string(timestamp()) + "_" + to_string(len(matched)) + ".jsonl"
    write_file(tmpf, joined)
    let py = "import sys, json, datetime, re\n" +
             "now = datetime.datetime.now(datetime.timezone.utc)\n" +
             "cutoff = now - datetime.timedelta(minutes=" + window_m + ")\n" +
             "warn = 0; total = 0\n" +
             "with open('" + tmpf + "') as f:\n" +
             "    for ln in f:\n" +
             "        ln = ln.strip()\n" +
             "        if not ln: continue\n" +
             "        try:\n" +
             "            obj = json.loads(ln)\n" +
             "            ts = obj.get('ts','')\n" +
             "            t = datetime.datetime.strptime(ts, '%Y-%m-%dT%H:%M:%SZ').replace(tzinfo=datetime.timezone.utc)\n" +
             "        except Exception:\n" +
             "            continue\n" +
             "        if t > now: continue   # future-dated, defensive\n" +
             "        if t < cutoff: continue\n" +
             "        total += 1\n" +
             "        if obj.get('verdict','') == 'WARN': warn += 1\n" +
             "ratio = (warn/total) if total > 0 else 0.0\n" +
             "print('%d %d %.4f' % (warn, total, ratio))\n"
    let cmd = "/usr/bin/env python3 -c \"" + py.replace("\"", "\\\"") + "\" 2>/dev/null"
    let out = to_string(exec(cmd)).trim()
    let parts = split(out, " ")
    let mut win_warn_n = 0
    let mut win_total = 0
    let mut win_ratio_s = "0.0000"
    if len(parts) >= 3 {
        win_warn_n = to_int(parts[0])
        win_total = to_int(parts[1])
        win_ratio_s = parts[2]
    }
    // Best-effort cleanup of the fixture-tmp file (raw 71: tmp dir, no state).
    exec("rm -f '" + tmpf + "' 2>/dev/null")
    if win_total > 0 {
        let cmp = to_string(exec("awk 'BEGIN { print ((" + win_ratio_s + "+0) >= (" + warn_thr_str + "+0)) ? 1 : 0 }' </dev/null")).trim()
        if cmp == "1" {
            fired.push("__ATLAS_ALERT__ FIRED rule=recent_warn_ratio ratio=" + win_ratio_s + " threshold=" + warn_thr_str + " window_minutes=" + window_m + " sampled=" + to_string(win_total))
            // ω-bridge-21 — window rule has no last_n; encode 0 / extra=window_minutes=M
            event_rows.push("recent_warn_ratio\t" + win_ratio_s + "\t" + warn_thr_str + "\t0\t" + to_string(win_total) + "\twindow_minutes=" + window_m)
            // ω-bridge-23 — JSONL body. Window rule: last_n=0, extra="window_minutes=M"
            event_jsonl_bodies.push("\"rule\":\"recent_warn_ratio\",\"ratio\":" + win_ratio_s + ",\"threshold\":" + warn_thr_str + ",\"last_n\":0,\"sampled\":" + to_string(win_total) + ",\"extra\":\"window_minutes=" + window_m + "\"")
            fired_rules.push("recent_warn_ratio")
        }
    }
}

// ─── ω-bridge-24: cooldown dedup ─────────────────────────────────────────────
// For each candidate firing, check the LAST K=20 rows of history_path for a
// row with the same rule. If found within cooldown_min minutes of NOW, drop
// the candidate from `fired` / `event_rows` / `event_jsonl_bodies` and emit a
// SUPPRESSED sentinel instead. cooldown_min=0 → fully disabled (skip pass).
// Missing OR header-only TSV → skip dedup (treat as "no prior firing").
// One python3 shell-out per candidate (small N — at most 4 rules); the parse
// is cheap. We avoid one big shell-out batched across all rules to keep the
// SUPPRESSED sentinel emission ordering trivial and per-rule diagnostics clean.
let mut suppressed_sentinels = []
if cooldown_min != "0" && len(fired) > 0 && file_exists(history_path) {
    // Tail K rows for perf bound. -K does NOT include header lines (`#`-prefixed)
    // — we strip those in awk for safety since `tail -K` counts raw lines.
    let tail_cmd2 = "tail -" + DEDUP_TAIL_K + " '" + history_path + "' 2>/dev/null | awk -F '\\t' '!/^#/ && NF >= 2 { print $0 }'"
    let dedup_tail = to_string(exec(tail_cmd2))
    let dedup_lines = split(dedup_tail, "\n")
    let now_epoch = to_string(exec("date -u +%s")).trim()
    let mut new_fired = []
    let mut new_event_rows = []
    let mut new_event_jsonl_bodies = []
    let mut new_fired_rules = []
    let mut fi2 = 0
    while fi2 < len(fired_rules) {
        let rule_name = fired_rules[fi2]
        // Walk dedup_lines from end → start; first row matching this rule wins.
        let mut last_ts = ""
        let mut dl = len(dedup_lines) - 1
        while dl >= 0 {
            let dline = dedup_lines[dl].trim()
            if len(dline) == 0 { dl = dl - 1; continue }
            let dparts = split(dline, "\t")
            if len(dparts) >= 2 {
                if dparts[1] == rule_name {
                    last_ts = dparts[0]
                    dl = -1  // break
                }
            }
            dl = dl - 1
        }
        let mut suppress = false
        let mut ago_min_s = "0"
        if len(last_ts) > 0 {
            // Compute (NOW - last_ts) in minutes via date(1). On macOS BSD `date`
            // we use `-j -f` to parse, falling back to GNU `date -d`. The
            // fallback chain is awk-driven from python3 to dodge platform skew.
            let py_diff = "import sys, datetime\n" +
                          "try:\n" +
                          "    t = datetime.datetime.strptime('" + last_ts + "', '%Y-%m-%dT%H:%M:%SZ').replace(tzinfo=datetime.timezone.utc)\n" +
                          "    now = datetime.datetime.now(datetime.timezone.utc)\n" +
                          "    delta_s = (now - t).total_seconds()\n" +
                          "    if delta_s < 0: delta_s = 0\n" +
                          "    print('%.4f' % (delta_s / 60.0))\n" +
                          "except Exception:\n" +
                          "    print('-1')\n"
            let cmd_diff = "/usr/bin/env python3 -c \"" + py_diff.replace("\"", "\\\"") + "\" 2>/dev/null"
            ago_min_s = to_string(exec(cmd_diff)).trim()
            // suppress if 0 <= ago < cooldown_min  (parse error → ago=-1 → don't suppress)
            let cmp_sup = to_string(exec("awk 'BEGIN { a = (\"" + ago_min_s + "\"+0); c = (\"" + cooldown_min + "\"+0); print (a >= 0 && a < c) ? 1 : 0 }' </dev/null")).trim()
            if cmp_sup == "1" { suppress = true }
        }
        if suppress {
            // Render ago_min as a clean number (4dp from python).
            suppressed_sentinels.push("__ATLAS_ALERT__ SUPPRESSED rule=" + rule_name + " reason=cooldown last_fired_ago_min=" + ago_min_s + " cooldown_minutes=" + cooldown_min)
        } else {
            new_fired.push(fired[fi2])
            new_event_rows.push(event_rows[fi2])
            new_event_jsonl_bodies.push(event_jsonl_bodies[fi2])
            new_fired_rules.push(rule_name)
        }
        fi2 = fi2 + 1
    }
    fired = new_fired
    event_rows = new_event_rows
    event_jsonl_bodies = new_event_jsonl_bodies
    fired_rules = new_fired_rules
}

// ─── human-readable summary (suppressed when --quiet) ────────────────────────
if !QUIET {
    println("═══ ATLAS ALERT SUBSCRIBER — timeline=" + timeline_path)
    println("  scope=" + TARGET_SCOPE + "  total_matched=" + to_string(total_matched) + "  last_n_requested=" + last_str + "  sampled=" + to_string(sampled))
    println("  tally: PASS=" + to_string(pass_n) + " WARN=" + to_string(warn_n) + " INSUFFICIENT_DATA=" + to_string(insuf_n) + " other=" + to_string(other_n))
    println("  ratios: warn=" + warn_ratio_s + " (thr=" + warn_thr_str + ")  insufficient=" + insuf_ratio_s + " (thr=" + insuf_thr_str + ")")
    if len(fired) > 0 {
        println("  ALERT(S) FIRED:")
        let mut fi = 0
        while fi < len(fired) {
            println("    " + fired[fi])
            fi = fi + 1
        }
        println("  fix:    investigate analyzer output / bridge_health_history.tsv freshness / upstream API outage")
    } else {
        println("  no rules fired")
    }
    if len(suppressed_sentinels) > 0 {
        println("  ALERT(S) SUPPRESSED (cooldown):")
        let mut si = 0
        while si < len(suppressed_sentinels) {
            println("    " + suppressed_sentinels[si])
            si = si + 1
        }
    }
}

// ─── ω-bridge-21 + ω-bridge-23: history persistence (FIRED outcomes only) ────
// Append-only TSV + sibling JSONL row per fired rule. PASS/SKIP outcomes
// deliberately not recorded — the file is an event log of *firings*
// (raw 77 / append-only). SUPPRESSED outcomes are also NOT persisted (raw 71:
// suppression is fully ephemeral by design).
// Pre-flight: if the TSV is missing, seed it with the canonical header before
// the first append. JSONL has no header (one object per line). Failures are
// report-only (raw 71): emit a sentinel and continue (we still want stdout
// sentinels of the firings to surface, and the JSONL failure must not block
// the TSV append or vice versa).
if write_history && len(event_rows) > 0 {
    let now_iso = to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
    if !file_exists(history_path) {
        try { write_file(history_path, HISTORY_HEADER) } catch e {
            println("__ATLAS_ALERT__ HISTORY_WRITE_FAIL path=" + history_path + " reason=header_init_failed")
            write_history = false
        }
    }
    if write_history {
        let mut ei = 0
        while ei < len(event_rows) {
            let row = now_iso + "\t" + event_rows[ei] + "\n"
            try { append_file(history_path, row) } catch e {
                println("__ATLAS_ALERT__ HISTORY_WRITE_FAIL path=" + history_path + " reason=append_failed")
                ei = len(event_rows)  // break — don't retry remaining rows
            }
            ei = ei + 1
        }
    }
    // ω-bridge-23 — JSONL sibling append. Independent failure handling so a
    // JSONL write fault does not invalidate the TSV that just succeeded
    // (or vice versa). Each line is one self-describing JSON object with
    // scope="atlas_alert" to discriminate from other JSONL rows downstream.
    let mut ji = 0
    let mut jsonl_ok = true
    while ji < len(event_jsonl_bodies) && jsonl_ok {
        let jline = "{\"ts\":\"" + now_iso + "\",\"scope\":\"" + ALERT_SCOPE + "\"," + event_jsonl_bodies[ji] + "}\n"
        try { append_file(history_jsonl_path, jline) } catch e {
            println("__ATLAS_ALERT__ HISTORY_WRITE_FAIL path=" + history_jsonl_path + " reason=jsonl_append_failed")
            jsonl_ok = false  // skip remaining (raw 71 report-only — never abort)
        }
        ji = ji + 1
    }
}

// ─── sentinel emission (always) ──────────────────────────────────────────────
// Order:  FIRED (per surviving candidate) → SUPPRESSED (per dedup'd candidate)
//         → PASS (only if no fired AND no suppressed — the "truly nothing"
//         signal). Operators tooling on stdout can distinguish the three
//         verdict classes without parsing structured fields.
if len(fired) > 0 {
    let mut fi = 0
    while fi < len(fired) {
        println(fired[fi])
        fi = fi + 1
    }
}
// ω-bridge-24 — emit suppressed sentinels (always, even when other rules fired)
if len(suppressed_sentinels) > 0 {
    let mut si = 0
    while si < len(suppressed_sentinels) {
        println(suppressed_sentinels[si])
        si = si + 1
    }
}
if len(fired) == 0 && len(suppressed_sentinels) == 0 {
    println("__ATLAS_ALERT__ PASS sampled=" + to_string(sampled) + " rules_evaluated=" + to_string(rules_evaluated))
}
