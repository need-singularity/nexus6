// tool/session_overview.hexa — hexa-native sentinel 종합 패널 (defense+registry+pending)
//
// raw 9 hexa-only-suffix. 본 세션의 3 hexa 도구 sentinel을 한 번에 호출 + parse하여
// 통합 status panel emit. cron-friendly: 1 stdout sentinel + (default) detail.
//
// @tool(slug="session_overview", desc="hexa-native 3-tool sentinel aggregator panel")
// @usage:
//   hexa run tool/session_overview.hexa            # detail + sentinel
//   HEXA_ARGV='--quiet' hexa run tool/session_overview.hexa  # sentinel only
//
// 호출 도구:
//   1. tool/defense_smoke.hexa     → __DEFENSE_SMOKE__
//   2. tool/falsifier_quick.hexa   → __FALSIFIER_QUICK__
//   3. tool/pending_actions.hexa   → __PENDING_ACTIONS__
//
// sentinel: __SESSION_OVERVIEW__ <PASS|WARN|FAIL> defense=<P/F> falsifiers=<N> pending_ready=<N>/<N>
//
// raw 71 read-only / raw 73 admissibility (3 독립 도구) / raw 80 sentinel

let NEXUS = "/Users/ghost/core/nexus"
let mut QUIET = false

fn _argv() -> array {
    let raw = to_string(exec("printf '%s' \"${HEXA_ARGV:-}\""))
    let parts = split(raw, " ")
    let mut out = []
    let mut k = 0
    while k < len(parts) {
        if len(parts[k]) > 0 { out.push(parts[k]) }
        k = k + 1
    }
    return out
}

let args = _argv()
let mut i = 0
while i < len(args) {
    let a = args[i]
    if a == "--quiet" { QUIET = true }
    if a == "--help" || a == "-h" {
        println("usage: HEXA_ARGV='--quiet' hexa run tool/session_overview.hexa")
        println("  3 hexa-native tool sentinel 종합 패널")
        return
    }
    i = i + 1
}

fn _say(msg: string) { if !QUIET { println(msg) } }

// Helper: extract value after key= in sentinel string
fn _sentinel_get(sentinel: string, key: string) -> string {
    let needle = key + "="
    let i = sentinel.index_of(needle)
    if i < 0 { return "" }
    let start = i + len(needle)
    let rest = sentinel.substring(start, len(sentinel))
    let endi = rest.index_of(" ")
    if endi < 0 { return rest }
    return rest.substring(0, endi)
}

// Helper: extract sentinel line (last line starting with __NAME__)
fn _last_sentinel(out: string, name: string) -> string {
    let needle = "__" + name + "__"
    let lines = split(out, "\n")
    let mut found = ""
    for l in lines {
        if l.index_of(needle) >= 0 { found = l }
    }
    return found
}

// 1. defense_smoke
_say("═══ session overview (3 hexa-native sentinels) ═══")
_say("")
_say("▶ 1. defense_smoke (5-layer R1+R2+R3-lite+R4+R5)")
let cmd_def = "HEXA_ARGV='--quiet' /Users/ghost/core/hexa-lang/hexa run " + NEXUS + "/tool/defense_smoke.hexa 2>&1"
let out_def = to_string(exec(cmd_def))
let sent_def = _last_sentinel(out_def, "DEFENSE_SMOKE")
let def_verdict = ""
if sent_def.index_of("PASS") >= 0 { def_verdict = "PASS" }
if sent_def.index_of("FAIL") >= 0 { def_verdict = "FAIL" }
let def_falsifier = _sentinel_get(sent_def, "r1_falsifier")
let def_bridge = _sentinel_get(sent_def, "r1_bridge")
let def_atlas = _sentinel_get(sent_def, "r1_atlas")
let def_r3 = _sentinel_get(sent_def, "r3_lite")
let def_r5 = _sentinel_get(sent_def, "r5_chain")
_say("  verdict: " + def_verdict + " | r1=fals:" + def_falsifier + "/bridge:" + def_bridge + "/atlas:" + def_atlas + " | r3_lite=" + def_r3 + " | r5_chain=" + def_r5)

// 2. falsifier_quick
_say("")
_say("▶ 2. falsifier_quick (registry distribution)")
let cmd_fq = "HEXA_ARGV='--quiet' /Users/ghost/core/hexa-lang/hexa run " + NEXUS + "/tool/falsifier_quick.hexa 2>&1"
let out_fq = to_string(exec(cmd_fq))
let sent_fq = _last_sentinel(out_fq, "FALSIFIER_QUICK")
let fq_total = _sentinel_get(sent_fq, "total")
let fq_matched = _sentinel_get(sent_fq, "matched")
_say("  verdict: total=" + fq_total + " entries (matched=" + fq_matched + ")")

// 3. pending_actions
_say("")
_say("▶ 3. pending_actions (5 user-go items)")
let cmd_pa = "HEXA_ARGV='--quiet' /Users/ghost/core/hexa-lang/hexa run " + NEXUS + "/tool/pending_actions.hexa 2>&1"
let out_pa = to_string(exec(cmd_pa))
let sent_pa = _last_sentinel(out_pa, "PENDING_ACTIONS")
let pa_count = _sentinel_get(sent_pa, "count")
let pa_ready = _sentinel_get(sent_pa, "ready")
let pa_blocked = _sentinel_get(sent_pa, "blocked")
let pa_done = _sentinel_get(sent_pa, "done")
_say("  verdict: " + pa_ready + " ready / " + pa_blocked + " blocked / " + pa_done + " done (of " + pa_count + ")")

// Aggregate verdict
_say("")
_say("═══ aggregate ═══")
let mut overall = "PASS"
if def_verdict == "FAIL" { overall = "FAIL" }
if def_verdict == "" { overall = "WARN" }

if !QUIET {
    println("  defense:   " + def_verdict)
    println("  falsifier: " + fq_total + " entries")
    println("  pending:   " + pa_ready + "/" + pa_count + " ready")
    println("")
}

println("__SESSION_OVERVIEW__ " + overall + " defense=" + def_verdict + " falsifiers=" + fq_total + " pending_ready=" + pa_ready + "/" + pa_count)
