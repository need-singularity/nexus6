// tool/session_overview.hexa — hexa-native sentinel 종합 패널 (10 tools)
//
// raw 9 hexa-only-suffix. 본 세션의 10 hexa 도구 sentinel을 한 번에 호출 + parse하여
// 통합 status panel emit. cron-friendly: 1 stdout sentinel + (default) detail.
//
// @tool(slug="session_overview", desc="hexa-native 10-tool sentinel aggregator panel")
// @usage:
//   hexa run tool/session_overview.hexa            # detail + sentinel
//   HEXA_ARGV='--quiet' hexa run tool/session_overview.hexa  # sentinel only
//
// 호출 도구 (자기 자신 제외 10개):
//   1. tool/defense_smoke.hexa     → __DEFENSE_SMOKE__
//   2. tool/falsifier_quick.hexa   → __FALSIFIER_QUICK__
//   3. tool/pending_actions.hexa   → __PENDING_ACTIONS__
//   4. tool/falsifier_id_gaps.hexa → __FALSIFIER_ID_GAPS__
//   5. tool/bridge_quick.hexa      → __BRIDGE_QUICK__
//   6. tool/atlas_quick.hexa       → __ATLAS_QUICK__
//   7. tool/honesty_quick.hexa     → __HONESTY_QUICK__
//   8. tool/commit_stats.hexa      → __COMMIT_STATS__
//   9. tool/hexa_tool_inventory.hexa → __HEXA_TOOL_INVENTORY__
//   10. tool/omega_cycle_count.hexa → __OMEGA_CYCLE_COUNT__
//
// sentinel: __SESSION_OVERVIEW__ <PASS|WARN|FAIL> defense=<P/F> falsifiers=<N> bridges=<N>/<T> atlas=<N>/<T> honesty=<5_5>/<6_6> pending_ready=<R>/<C> next_f=<N> commits=<N> hexa_tools=<N> omegas=<N>
//
// raw 71 read-only / raw 73 admissibility (7 독립 도구) / raw 80 sentinel

let NEXUS = "/Users/ghost/core/nexus"
let HEXA = "/Users/ghost/core/hexa-lang/hexa"
let mut QUIET = false

fn _argv() -> array {
    let raw = to_string(exec("printf '%s' \"${HEXA_ARGV:-}\""))
    let parts = split(raw, " ")
    let mut out = []
    let mut k = 0
    while k < len(parts) {
        if len(parts[k]) > 0 { out.push(parts[k]) }
        k = k + 1
    }
    return out
}

let args = _argv()
let mut i = 0
while i < len(args) {
    let a = args[i]
    if a == "--quiet" { QUIET = true }
    if a == "--help" || a == "-h" {
        println("usage: HEXA_ARGV='--quiet' hexa run tool/session_overview.hexa")
        println("  7 hexa-native tool sentinel 종합 패널")
        return
    }
    i = i + 1
}

fn _say(msg: string) { if !QUIET { println(msg) } }

fn _sentinel_get(sentinel: string, key: string) -> string {
    let needle = key + "="
    let i = sentinel.index_of(needle)
    if i < 0 { return "" }
    let start = i + len(needle)
    let rest = sentinel.substring(start, len(sentinel))
    let endi = rest.index_of(" ")
    if endi < 0 { return rest }
    return rest.substring(0, endi)
}

fn _last_sentinel(out: string, name: string) -> string {
    let needle = "__" + name + "__"
    let lines = split(out, "\n")
    let mut found = ""
    for l in lines {
        if l.index_of(needle) >= 0 { found = l }
    }
    return found
}

fn _run(tool: string) -> string {
    let cmd = "HEXA_ARGV='--quiet' " + HEXA + " run " + NEXUS + "/tool/" + tool + " 2>&1"
    return to_string(exec(cmd))
}

_say("═══ session overview (10 hexa-native sentinels) ═══")
_say("")

// 1. defense_smoke
_say("▶ 1. defense_smoke")
let s_def = _last_sentinel(_run("defense_smoke.hexa"), "DEFENSE_SMOKE")
let def_v = ""
if s_def.index_of("PASS") >= 0 { def_v = "PASS" }
if s_def.index_of("FAIL") >= 0 { def_v = "FAIL" }
let def_r3 = _sentinel_get(s_def, "r3_lite")
let def_r5 = _sentinel_get(s_def, "r5_chain")
_say("  " + def_v + " | r3_lite=" + def_r3 + " r5_chain=" + def_r5)

// 2. falsifier_quick
_say("")
_say("▶ 2. falsifier_quick")
let s_fq = _last_sentinel(_run("falsifier_quick.hexa"), "FALSIFIER_QUICK")
let fq_total = _sentinel_get(s_fq, "total")
_say("  " + fq_total + " entries")

// 3. pending_actions
_say("")
_say("▶ 3. pending_actions")
let s_pa = _last_sentinel(_run("pending_actions.hexa"), "PENDING_ACTIONS")
let pa_count = _sentinel_get(s_pa, "count")
let pa_ready = _sentinel_get(s_pa, "ready")
_say("  " + pa_ready + "/" + pa_count + " ready")

// 4. falsifier_id_gaps
_say("")
_say("▶ 4. falsifier_id_gaps")
let s_ig = _last_sentinel(_run("falsifier_id_gaps.hexa"), "FALSIFIER_ID_GAPS")
let ig_max = _sentinel_get(s_ig, "max")
let ig_gaps = _sentinel_get(s_ig, "gaps")
let ig_next = _sentinel_get(s_ig, "next")
_say("  max=F" + ig_max + " gaps=" + ig_gaps + " next=F" + ig_next)

// 5. bridge_quick
_say("")
_say("▶ 5. bridge_quick")
let s_bq = _last_sentinel(_run("bridge_quick.hexa"), "BRIDGE_QUICK")
let bq_total = _sentinel_get(s_bq, "total")
let bq_tampered = _sentinel_get(s_bq, "tampered")
_say("  " + bq_total + " bridges (tampered=" + bq_tampered + ")")

// 6. atlas_quick
_say("")
_say("▶ 6. atlas_quick")
let s_aq = _last_sentinel(_run("atlas_quick.hexa"), "ATLAS_QUICK")
let aq_total = _sentinel_get(s_aq, "total")
let aq_tampered = _sentinel_get(s_aq, "tampered")
_say("  " + aq_total + " shards (tampered=" + aq_tampered + ")")

// 7. honesty_quick
_say("")
_say("▶ 7. honesty_quick")
let s_hq = _last_sentinel(_run("honesty_quick.hexa"), "HONESTY_QUICK")
let hq_5_5 = _sentinel_get(s_hq, "honesty_5_5")
let hq_6_6 = _sentinel_get(s_hq, "honesty_6_6")
_say("  mode-6: 5/5=" + hq_5_5 + " | 6/6=" + hq_6_6)

// 8. commit_stats
_say("")
_say("▶ 8. commit_stats")
let s_cs = _last_sentinel(_run("commit_stats.hexa"), "COMMIT_STATS")
let cs_total = _sentinel_get(s_cs, "total")
let cs_omega = _sentinel_get(s_cs, "omega")
_say("  " + cs_total + " commits (omega=" + cs_omega + ")")

// 9. hexa_tool_inventory
_say("")
_say("▶ 9. hexa_tool_inventory")
let s_hti = _last_sentinel(_run("hexa_tool_inventory.hexa"), "HEXA_TOOL_INVENTORY")
let hti_total = _sentinel_get(s_hti, "total")
let hti_session = _sentinel_get(s_hti, "session_only")
_say("  " + hti_total + " hexa tools (session-tagged " + hti_session + ")")

// 10. omega_cycle_count
_say("")
_say("▶ 10. omega_cycle_count")
let s_occ = _last_sentinel(_run("omega_cycle_count.hexa"), "OMEGA_CYCLE_COUNT")
let occ_total = _sentinel_get(s_occ, "total")
let occ_hexa_sim = _sentinel_get(s_occ, "hexa_sim")
_say("  " + occ_total + " witnesses (hexa_sim=" + occ_hexa_sim + ")")

// Aggregate
_say("")
_say("═══ aggregate ═══")

let mut overall = "PASS"
if def_v == "FAIL" { overall = "FAIL" }
if def_v == "" { overall = "WARN" }
if bq_tampered != "" && bq_tampered != "0" { overall = "FAIL" }
if aq_tampered != "" && aq_tampered != "0" { overall = "FAIL" }

if !QUIET {
    println("  defense:    " + def_v)
    println("  falsifier:  " + fq_total + " entries (next F" + ig_next + ")")
    println("  bridge:     " + bq_total + " (tampered=" + bq_tampered + ")")
    println("  atlas:      " + aq_total + " (tampered=" + aq_tampered + ")")
    println("  honesty:    mode-6 5_5=" + hq_5_5 + " 6_6=" + hq_6_6)
    println("  pending:    " + pa_ready + "/" + pa_count + " ready")
    println("  commits:    " + cs_total + " (omega=" + cs_omega + ")")
    println("  hexa_tools: " + hti_total + " (session " + hti_session + ")")
    println("  omegas:     " + occ_total + " witnesses")
    println("")
}

println("__SESSION_OVERVIEW__ " + overall + " defense=" + def_v + " falsifiers=" + fq_total + " bridges=" + bq_total + "/" + bq_tampered + "_tampered atlas=" + aq_total + "/" + aq_tampered + "_tampered honesty=" + hq_5_5 + "/" + hq_6_6 + " pending_ready=" + pa_ready + "/" + pa_count + " next_f=F" + ig_next + " commits=" + cs_total + " hexa_tools=" + hti_total + " omegas=" + occ_total)
