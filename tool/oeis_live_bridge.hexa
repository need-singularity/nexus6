#!hexa strict
// tool/oeis_live_bridge.hexa — OEIS HTTP b-file live fetch + axis_oeis static-table consistency check.
//
// @tool(slug="oeis_live_bridge", desc="Fetch OEIS b-files via HTTP + cross-check vs hexa_sim_verify_grid axis_oeis static n=1..6 table; n=6 perfect-number anchor verification")
// @usage(hexa run tool/oeis_live_bridge.hexa [--selftest] [--seq <ID>] [--json])
// @exit_codes(0=PASS, 1=usage/io error, 2=value mismatch (anchor or cross-check fail))
// @sentinel(__OEIS_LIVE_BRIDGE__ PASS|FAIL A000396_first=N sigma6=N tau6=N phi6=N axis_oeis_consistent=true|false)
// @origin(n6-architecture/domains/physics/simulation-theory/simulation-theory.md §7 VERIFY axis OEIS)
// @abstraction(hive raw 70 design-multi-axis-verify-grid + external-source-corroboration)
// @paradigm(structural-admissibility — deterministic checks against external authoritative source)
// @companion(tool/hexa_sim_verify_grid.hexa axis_oeis static table at lines 209-211)
//
// Mirror sequences (b-file = "index value" plain text, one pair per line):
//   A000396 — perfect numbers       https://oeis.org/A000396/b000396.txt
//   A000203 — sigma (sum-of-divisors) https://oeis.org/A000203/b000203.txt
//   A000005 — tau (number-of-divisors) https://oeis.org/A000005/b000005.txt
//   A000010 — euler phi (totient)    https://oeis.org/A000010/b000010.txt
//
// CRITICAL CHECK: A000396 first term MUST be 6 (smallest perfect number) — if it is not,
// the n=6 anchor framework loses its OEIS-side external corroboration.

// ─── void-safe string coercion ───
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _esc_json(s: string) -> string {
    let mut r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    return r
}

// ─── b-file parser ───
// b-file lines are "<index> <value>"; comments start with '#', blank lines ignored.
// returns list of value strings (i64 would overflow on A000396 term 8 = 2305843008139952128, so keep as strings;
// for axis_oeis cross-check the n=1..6 values fit in i64).
fn parse_b_file(text: string) -> array {
    let mut out = []
    let lines = text.split("\n")
    let mut i = 0
    while i < len(lines) {
        let raw = _str(lines[i]).trim()
        if raw == "" {
            i = i + 1
            continue
        }
        if raw.substring(0, 1) == "#" {
            i = i + 1
            continue
        }
        // split on first whitespace; tolerate multi-space.
        let sp = raw.index_of(" ")
        if sp < 0 {
            i = i + 1
            continue
        }
        let val = raw.substring(sp + 1, len(raw)).trim()
        if val == "" {
            i = i + 1
            continue
        }
        out.push(val)
        i = i + 1
    }
    return out
}

// ─── HTTP fetch ───
// payload trim (OPT-A, 2026-04-26 oom_resolution ω-cycle):
//   sigma/tau/phi b-files run 800KB-1.2MB (1 line ~10-20B × 100k+ lines). interp
//   text.substring(j, j+1) byte-walk + per-line .split alloc blow past the 4GB
//   container cap (project_mac_hard_landing_policy). selftest only needs first 6
//   terms per sequence for the n=6 anchor cross-check, so we cap the fetched
//   stream at the first 100 lines via shell-side `head` BEFORE the bytes ever
//   reach interp.  This preserves the live-fetch semantics (real OEIS server,
//   real bytes) while killing the O(n) tail.
//   reason: 4GB cgroup OOM kill (oom_kill=4 in cgroup memory.events).
//   fix: head -n 100 in shell pipeline; raises floor on safe fetch ceiling.
fn fetch_b_file(seq_id: string) -> string {
    // OEIS b-file URL pattern: lowercase 'b' + numeric tail + '.txt'
    // seq_id is "A000396" → "b000396.txt"
    let tail = seq_id.substring(1, len(seq_id))
    let url = "https://oeis.org/" + seq_id + "/b" + tail + ".txt"
    // shell trim: pipe through head -n 100 (caps at ~2KB regardless of upstream size).
    // for --seq mode we still want full data so callers go through fetch_b_file_full.
    // ω-bridge-3 (2026-04-26): route through bridge_helper.sh for cache + retry +
    // polite-API rate-limit. ttl=86400s (OEIS b-files immutable per sequence ID).
    let nexus_root = to_string(exec("printf '%s' \"${NEXUS_ROOT:-$HOME/core/nexus}\"")).trim()  // @allow-bare-exec
    let helper = nexus_root + "/tool/bridge_helper.sh"
    // ω-bridge-13 (2026-04-26): TTL/min_interval sourced from state/bridge_config.tsv (oeis: 86400 / 1).
    let cmd = "bash '" + helper + "' fetch oeis '" + url + "' 2>/dev/null | head -n 100"
    return _str(exec(cmd))  // @allow-bare-exec
}

fn fetch_sequence(seq_id: string) -> array {
    // selftest path — uses head-capped fetch (first 100 lines only).
    let text = fetch_b_file(seq_id)
    return parse_b_file(text)
}

fn fetch_sequence_full(seq_id: string) -> array {
    // --seq mode — caller wants more than 6 terms; uses uncapped fetch.
    // still safer than original because we head -c cap to 200KB to dodge worst-case
    // OOM (200KB ÷ ~15B/line = ~13K terms, plenty for any practical use).
    let tail = seq_id.substring(1, len(seq_id))
    let url = "https://oeis.org/" + seq_id + "/b" + tail + ".txt"
    // ω-bridge-3 (2026-04-26): route through bridge_helper.sh (cache + retry).
    let nexus_root = to_string(exec("printf '%s' \"${NEXUS_ROOT:-$HOME/core/nexus}\"")).trim()  // @allow-bare-exec
    let helper = nexus_root + "/tool/bridge_helper.sh"
    // ω-bridge-13 (2026-04-26): TTL/min_interval sourced from state/bridge_config.tsv (oeis: 86400 / 1).
    let cmd = "bash '" + helper + "' fetch oeis '" + url + "' 2>/dev/null | head -c 200000"
    let text = _str(exec(cmd))  // @allow-bare-exec
    return parse_b_file(text)
}

// ─── core verification helpers ───
fn _first_n(terms: array, n: i64) -> array {
    let mut out = []
    let mut i = 0
    while i < n && i < len(terms) {
        out.push(terms[i])
        i = i + 1
    }
    return out
}

fn _val_at(terms: array, idx: i64) -> string {
    if idx < 0 || idx >= len(terms) { return "" }
    return _str(terms[idx])
}

// axis_oeis static table from hexa_sim_verify_grid.hexa lines 209-211 (n=1..6).
fn _static_a000203() -> array { return ["1", "3", "4", "7", "6", "12"] }
fn _static_a000005() -> array { return ["1", "2", "2", "3", "2", "4"] }
fn _static_a000010() -> array { return ["1", "1", "2", "2", "4", "2"] }

// returns [seq_id, first_term, n6_value_or_member, ok_flag, fails_csv]
fn verify_sequence(seq_id: string) -> array {
    let terms = fetch_sequence(seq_id)
    if len(terms) == 0 {
        return [seq_id, "", "", "false", "fetch_empty_or_parse_failed"]
    }
    let first = _val_at(terms, 0)
    let mut fails = []

    if seq_id == "A000396" {
        // critical n=6 anchor: first perfect number = 6
        if first != "6" {
            fails.push("A000396 first term expected '6' got '" + first + "'")
        }
        let ok = if len(fails) == 0 { "true" } else { "false" }
        return [seq_id, first, first, ok, fails.join("; ")]
    }

    // for sigma/tau/phi: cross-check first 6 against static table.
    let mut static_tbl = []
    if seq_id == "A000203" { static_tbl = _static_a000203() }
    else if seq_id == "A000005" { static_tbl = _static_a000005() }
    else if seq_id == "A000010" { static_tbl = _static_a000010() }

    if len(static_tbl) == 6 {
        let mut k = 0
        while k < 6 {
            let live = _val_at(terms, k)
            let stat = _str(static_tbl[k])
            if live != stat {
                fails.push(seq_id + "[" + to_string(k + 1) + "] live='" + live + "' static='" + stat + "'")
            }
            k = k + 1
        }
    }

    let n6 = _val_at(terms, 5)  // index 5 = n=6 (b-file is 1-indexed by line, but parse_b_file drops index)
    let ok = if len(fails) == 0 { "true" } else { "false" }
    return [seq_id, first, n6, ok, fails.join("; ")]
}

// ─── emitters ───
fn _emit_text(results: array) {
    for r in results {
        let line = r[0] + " first=" + r[1] + " n6_val=" + r[2] + " ok=" + r[3]
        if r[4] != "" { println(line + " fails=" + r[4]) }
        else { println(line) }
    }
    println("---")
}

fn _emit_json(results: array, axis_consistent: bool) {
    println("{")
    println("  \"tool\": \"oeis_live_bridge\",")
    println("  \"origin\": \"hive raw 70 design-multi-axis-verify-grid + external OEIS corroboration\",")
    println("  \"companion\": \"tool/hexa_sim_verify_grid.hexa axis_oeis\",")
    println("  \"sequences\": [")
    let mut k = 0
    while k < len(results) {
        let r = results[k]
        let trail = if k + 1 < len(results) { "," } else { "" }
        let n6_field = if r[0] == "A000396" { "\"n6_index_if_member\": \"smallest=6 (line 1)\"" } else { "\"n6_value\": \"" + _esc_json(r[2]) + "\"" }
        println("    {\"id\": \"" + r[0] + "\", \"first_term\": \"" + _esc_json(r[1]) + "\", " + n6_field + ", \"ok\": " + r[3] + ", \"fails\": \"" + _esc_json(r[4]) + "\"}" + trail)
        k = k + 1
    }
    println("  ],")
    let cons = if axis_consistent { "true" } else { "false" }
    println("  \"axis_oeis_consistency\": " + cons)
    println("}")
}

// ─── runners ───
fn run_selftest(json_mode: bool) {
    let ids = ["A000396", "A000203", "A000005", "A000010"]
    let mut results = []
    let mut axis_consistent = true
    let mut a396_first = ""
    let mut a203_n6 = ""
    let mut a005_n6 = ""
    let mut a010_n6 = ""
    for sid in ids {
        let r = verify_sequence(sid)
        results.push(r)
        if r[3] != "true" { axis_consistent = false }
        if r[0] == "A000396" { a396_first = r[1] }
        else if r[0] == "A000203" { a203_n6 = r[2] }
        else if r[0] == "A000005" { a005_n6 = r[2] }
        else if r[0] == "A000010" { a010_n6 = r[2] }
    }

    if json_mode { _emit_json(results, axis_consistent) }
    else { _emit_text(results) }

    let cons_str = if axis_consistent { "true" } else { "false" }
    let verdict = if axis_consistent && a396_first == "6" { "PASS" } else { "FAIL" }
    println("__OEIS_LIVE_BRIDGE__ " + verdict + " A000396_first=" + a396_first + " sigma6=" + a203_n6 + " tau6=" + a005_n6 + " phi6=" + a010_n6 + " axis_oeis_consistent=" + cons_str)
    if verdict == "PASS" { exit(0) }
    exit(2)
}

fn run_single(seq_id: string, json_mode: bool) {
    let terms = fetch_sequence_full(seq_id)
    if len(terms) == 0 {
        eprintln("oeis_live_bridge: fetch failed or empty for " + seq_id)
        println("__OEIS_LIVE_BRIDGE__ FAIL seq=" + seq_id + " reason=fetch_empty")
        exit(1)
    }
    let head5 = _first_n(terms, 5)
    if json_mode {
        println("{")
        println("  \"tool\": \"oeis_live_bridge\",")
        println("  \"sequences\": [")
        print("    {\"id\": \"" + seq_id + "\", \"first_n_terms\": [")
        let mut k = 0
        while k < len(head5) {
            let trail = if k + 1 < len(head5) { ", " } else { "" }
            print("\"" + _esc_json(_str(head5[k])) + "\"" + trail)
            k = k + 1
        }
        println("], \"total_terms_fetched\": " + to_string(len(terms)) + "}")
        println("  ]")
        println("}")
    } else {
        println(seq_id + " first5=[" + head5.join(", ") + "] total_terms=" + to_string(len(terms)))
    }
    println("__OEIS_LIVE_BRIDGE__ PASS seq=" + seq_id + " first=" + _str(head5[0]) + " count=" + to_string(len(terms)))
    exit(0)
}

fn main() -> void {
    let raw_args = args()
    let mut cli = []
    // #65 F22 args() ABI: hexa runtime arg layout = [hexa_real, run, SCRIPT, ...user_args].
    // Robustly locate *.hexa entry → start user-arg capture at next index. Fallback ai=2 (legacy).
    let mut ai = 2
    let mut _scan = 0
    let _nra = len(raw_args)
    while _scan < _nra {
        let _a = raw_args[_scan]
        let _la = len(_a)
        if _la >= 5 && _a.substring(_la - 5, _la) == ".hexa" {
            ai = _scan + 1
            break
        }
        _scan = _scan + 1
    }
    while ai < len(raw_args) {
        cli.push(raw_args[ai])
        ai = ai + 1
    }

    let mut mode = "selftest"
    let mut seq = ""
    let mut json_mode = false
    let mut i = 0
    while i < len(cli) {
        let a = cli[i]
        if a == "--selftest" || a == "selftest" { mode = "selftest" }
        else if a == "--seq" {
            if i + 1 < len(cli) {
                i = i + 1
                seq = cli[i]
                mode = "single"
            } else {
                eprintln("oeis_live_bridge: --seq requires <ID>")
                exit(1)
            }
        }
        else if a == "--json" { json_mode = true }
        else if a == "--help" || a == "-h" {
            println("usage: hexa run tool/oeis_live_bridge.hexa [--selftest] [--seq <ID>] [--json]")
            println("default: --selftest (4 sequences cross-check + n=6 anchor)")
            println("origin: hive raw 70 + n6-architecture simulation-theory.md §7 axis OEIS")
            exit(0)
        }
        else {
            eprintln("oeis_live_bridge: unknown arg `" + a + "`")
            exit(1)
        }
        i = i + 1
    }

    if mode == "single" { run_single(seq, json_mode) }
    else { run_selftest(json_mode) }
}
