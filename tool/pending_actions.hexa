// tool/pending_actions.hexa — 5 user-go pending items quick status (hexa-native)
//
// raw 9 hexa-only-suffix. 본 세션 마지막 핸드오프 (NEXT_SESSION_HANDOFF_v3.md)
// 의 5 pending items 자동 status 체크 — 사용자가 어느 것 승인 가능한지 한눈에.
//
// @tool(slug="pending_actions", desc="user-go pending items status (5 items)")
// @usage:
//   hexa run tool/pending_actions.hexa
//   HEXA_ARGV='--quiet' hexa run tool/pending_actions.hexa  # sentinel only
//
// 점검 항목:
//   1. F78-F80 atlas merge 대기 (multi-decomp @X 23/168/1728)
//   2. F126-F132 cross-engine merge 대기 (m3/m5/r4/r10)
//   3. xpoll cleanup 대기 (atlas.n6의 19 sigma + 11 tau xpoll-* 규약 위반)
//   4. n6-arch precondition (f) populate 대기 (cross-repo defense doc)
//   5. R5 SSH key activation 대기 (~/.ssh/id_ed25519 reuse, ~5 min)
//
// sentinel: __PENDING_ACTIONS__ count=5 ready=R blocked=B
//   ready = 자율 안전 (user 1-cmd 실행 가능)
//   blocked = cross-repo write OR 사용자 검토 필요 (1+분)
//
// raw 71 read-only / raw 73 admissibility / raw 80 sentinel

let NEXUS = "/Users/ghost/core/nexus"
let mut QUIET = false

fn _argv() -> array {
    let raw = to_string(exec("printf '%s' \"${HEXA_ARGV:-}\""))
    let parts = split(raw, " ")
    let mut out = []
    let mut k = 0
    while k < len(parts) {
        if len(parts[k]) > 0 { out.push(parts[k]) }
        k = k + 1
    }
    return out
}

let args = _argv()
let mut i = 0
while i < len(args) {
    let a = args[i]
    if a == "--quiet" { QUIET = true }
    if a == "--help" || a == "-h" {
        println("usage: HEXA_ARGV='--quiet' hexa run tool/pending_actions.hexa")
        println("  5 user-go pending items status (READY|BLOCKED)")
        return
    }
    i = i + 1
}

fn _say(msg: string) { if !QUIET { println(msg) } }

// 1. F78-F80 atlas merge proposal — registry에 F78 존재 시 ALREADY_DONE
let p1_witness = NEXUS + "/design/hexa_sim/2026-04-26_synthesis_multi_decomp_formalization_omega_cycle.json"
let p1_check = to_string(exec("grep -c '\"id\":\"F78\"\\|\"id\": \"F78\"' /Users/ghost/core/nexus/design/hexa_sim/falsifiers.jsonl 2>/dev/null")).trim()
let mut p1 = "BLOCKED"
if file_exists(p1_witness) {
    if p1_check != "0" && len(p1_check) > 0 { p1 = "ALREADY_DONE" }
    else { p1 = "READY" }
}
_say("1. F78-F80 atlas merge       : " + p1 + " (multi-decomp @X 23/168/1728; ~5min user execute)")

// 2. F126-F132 cross-engine merge — registry에 F126 존재 시 ALREADY_DONE
let p2_audit = NEXUS + "/design/hexa_sim/2026-04-26_cross_engine_integration_audit.md"
let p2_witness = NEXUS + "/design/hexa_sim/2026-04-26_cross_engine_integration_omega_cycle.json"
let p2_check = to_string(exec("grep -c '\"id\":\"F126\"\\|\"id\": \"F126\"' /Users/ghost/core/nexus/design/hexa_sim/falsifiers.jsonl 2>/dev/null")).trim()
let mut p2 = "BLOCKED"
if file_exists(p2_audit) && file_exists(p2_witness) {
    if p2_check != "0" && len(p2_check) > 0 { p2 = "ALREADY_DONE" }
    else { p2 = "READY" }
}
_say("2. F126-F132 cross-engine    : " + p2 + " (m3/m5/r4/r10 anchors; ~10min)")

// 3. xpoll cleanup — atlas.n6에 'sigma(12) = 12' 패턴 있으면 READY, 없으면 ALREADY_DONE
let p3_convention = NEXUS + "/design/atlas_function_call_convention.md"
let p3_violations = to_string(exec("grep -cE '= sigma\\(12\\) = 12|= tau\\(4\\) = 4' /Users/ghost/core/nexus/n6/atlas.n6 2>/dev/null")).trim()
let mut p3 = "BLOCKED"
if file_exists(p3_convention) {
    if p3_violations == "0" || len(p3_violations) == 0 { p3 = "ALREADY_DONE" }
    else { p3 = "READY" }
}
_say("3. xpoll cleanup             : " + p3 + " (21 atlas lines; ~10min mechanical rewrite)")

// 4. canon (f) populate — cross-repo write
let p4_n6arch = "/Users/ghost/core/canon"
let mut p4 = "BLOCKED"
if file_exists(p4_n6arch) {
    // canon에 SECURITY 류 doc 있는지 직접 확인
    let check_cmd = "ls /Users/ghost/core/canon/SECURITY* /Users/ghost/core/canon/doc/security/* 2>/dev/null | wc -l | tr -d ' '"
    let n = to_string(exec(check_cmd)).trim()
    if n != "0" { p4 = "ALREADY_DONE" }
    else { p4 = "BLOCKED" }
}
_say("4. n6-arch precondition (f)  : " + p4 + " (cross-repo write; user-only ~15min)")

// 5. R5 SSH key activation
let p5_runbook = NEXUS + "/design/hexa_sim/R5_SSH_ACTIVATION_RUNBOOK.md"
let p5_signing_check = "git config --get user.signingkey 2>/dev/null"
let signing = to_string(exec(p5_signing_check)).trim()
let mut p5 = "BLOCKED"
if file_exists(p5_runbook) {
    if len(signing) > 0 { p5 = "ALREADY_DONE" }
    else { p5 = "READY" }
}
_say("5. R5 SSH key activation     : " + p5 + " (Path A reuse ~/.ssh/id_ed25519; ~5min)")

// Tally
let mut ready = 0
let mut blocked = 0
let mut done = 0
for s in [p1, p2, p3, p4, p5] {
    if s == "READY" { ready = ready + 1 }
    if s == "BLOCKED" { blocked = blocked + 1 }
    if s == "ALREADY_DONE" { done = done + 1 }
}

if !QUIET {
    println("")
    println("Summary: " + to_string(ready) + " READY (자율 user 1-cmd) / " + to_string(blocked) + " BLOCKED (cross-repo or 미준비) / " + to_string(done) + " ALREADY_DONE")
}

println("__PENDING_ACTIONS__ count=5 ready=" + to_string(ready) + " blocked=" + to_string(blocked) + " done=" + to_string(done))
