// roadmap_sync.hexa — 로드맵 JSON 자동 commit+push
// @allow-bare-exec
// @no-sandbox
//
// 목적: 로드맵 변경이 GitHub Pages(need-singularity.github.io/nexus/roadmap)에
//       즉시 반영되도록 OS 레벨에서 강제 동기화. Claude Code 훅 사용 금지.
//
// 2-layer 강제 체계 (OS 레벨, hook/skill 금지):
//   L1 launchd WatchPaths: fsevents 로 roadmap 디렉터리 변경 즉시 감지
//      → shared/launchd/com.nexus.roadmap-sync.plist
//   L2 launchd StartInterval: 5분 주기 안전망 (WatchPaths 누락 대비)
//   ※ Claude Code hook / git hook / skill 일절 사용 금지
//
// 대상 repo:
//   - nexus              → shared/roadmaps/
//   - n6-architecture    → shared/roadmaps/ (있으면)
//   - anima              → shared/roadmaps/ (nexus 심링크, 중복 no-op)
//
// 멱등: clean tree → 즉시 return. 충돌/ahead → 로그 후 skip.
// 로그: shared/tool/roadmap_sync.jsonl (ts, rule, repo, result, detail)
// SSOT: shared/rules/common.json R-ROADMAP-SYNC

let HOME = env("HOME")
let LOG_PATH = HOME + "/Dev/nexus/tool/roadmap_sync.jsonl"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn run(cmd: string) -> string {
    return _str(exec(cmd))  // @allow-bare-exec
}

fn now_iso() -> string {
    return run("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", " ")
    r = r.replace("\r", " ")
    r = r.replace("\t", " ")
    return r
}

fn log_event(repo: string, result: string, detail: string) {
    let j = "{\"ts\":\"" + now_iso() + "\""
          + ",\"rule\":\"R-ROADMAP-SYNC\""
          + ",\"repo\":\"" + repo + "\""
          + ",\"result\":\"" + result + "\""
          + ",\"detail\":\"" + json_escape(detail) + "\"}"
    try { append_file(LOG_PATH, j + "\n") } catch e {}
}

fn basename_str(path: string) -> string {
    return run("basename " + path).trim()
}

fn repo_exists(path: string) -> bool {
    let r = run("test -d " + path + "/.git && echo 1").trim()
    return r == "1"
}

fn paths_exist(repo: string, paths: string) -> bool {
    // Return true if at least one listed path exists in repo.
    let mut i = 0
    let parts = paths.split(" ")
    while i < len(parts) {
        let p = _str(parts[i]).trim()
        if p != "" {
            let r = run("test -e " + repo + "/" + p + " && echo 1").trim()
            if r == "1" { return true }
        }
        i = i + 1
    }
    return false
}

fn dirty_paths(repo: string, paths: string) -> string {
    // `git status --porcelain -- <paths>` — empty output = clean.
    let cmd = "cd " + repo + " && git status --porcelain -- " + paths + " 2>/dev/null"
    return run(cmd).trim()
}

fn current_branch(repo: string) -> string {
    return run("cd " + repo + " && git rev-parse --abbrev-ref HEAD 2>/dev/null").trim()
}

fn sync_repo(repo: string, paths: string) {
    let label = basename_str(repo)
    if !repo_exists(repo) {
        log_event(label, "skip", "not a git repo")
        return
    }
    if !paths_exist(repo, paths) {
        log_event(label, "skip", "roadmap path absent")
        return
    }
    let dirty = dirty_paths(repo, paths)
    if dirty == "" {
        // clean — idempotent no-op
        return
    }

    let branch = current_branch(repo)
    if branch != "main" && branch != "master" {
        log_event(label, "skip", "branch=" + branch + " (not main/master)")
        return
    }

    // Stage
    let add_out = run("cd " + repo + " && git add " + paths + " 2>&1")
    // Guard: nothing staged → bail (rare race)
    let staged = run("cd " + repo + " && git diff --cached --name-only -- " + paths + " 2>/dev/null").trim()
    if staged == "" {
        log_event(label, "skip", "nothing staged after add")
        return
    }

    // Commit via message file to avoid shell-escape issues with newlines.
    // NEXUS_COMMIT_OK=1 bypasses the heavy harness chain (roadmap-only changes
    // don't need lint/balance/broadcast gating that targets code commits).
    let msg_path = "/tmp/roadmap_sync_msg_" + run("echo $$").trim() + ".txt"
    let body = "chore(roadmap): auto-sync [" + now_iso() + "]\n\n"
             + "Auto-committed by shared/tool/roadmap_sync.hexa to keep\n"
             + "GitHub Pages roadmap view in real-time.\n\n"
             + "Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>\n"
    let _ = write_file(msg_path, body)
    // -- <path> 로 스코프 제한: roadmap 외 staged 파일 건드리지 않음
    let commit_cmd = "cd " + repo + " && NEXUS_COMMIT_OK=1 git commit -F " + msg_path + " -- " + paths + " 2>&1"
    let commit_out = run(commit_cmd)
    let _ = run("rm -f " + msg_path)
    let committed = run("cd " + repo + " && git log -1 --format=%H 2>/dev/null").trim()
    if committed == "" {
        log_event(label, "fail_commit", commit_out)
        return
    }

    // Push
    let push_out = run("cd " + repo + " && git push origin " + branch + " 2>&1")
    // Detect common failures
    let push_ok_check = run("cd " + repo + " && git status -sb 2>/dev/null | head -1").trim()
    // A successful push leaves the first line without "ahead" marker.
    let ahead_check = run("cd " + repo + " && git rev-list --count @{u}..HEAD 2>/dev/null").trim()
    if ahead_check != "0" && ahead_check != "" {
        log_event(label, "fail_push", push_out)
        return
    }
    log_event(label, "ok", "committed+pushed on " + branch)
    println("[roadmap_sync] " + label + " synced (branch=" + branch + ")")
}

fn main() {
    sync_repo(HOME + "/Dev/nexus",           "shared/roadmaps/")
    sync_repo(HOME + "/Dev/n6-architecture", "shared/roadmaps/")
    sync_repo(HOME + "/Dev/anima",           "shared/roadmaps/")
}

main()
