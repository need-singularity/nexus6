// tool/psi_calibration_install_help.hexa — ω-network-6b install instructions printer
//
// raw 9 hexa-only-suffix. Self-discoverable install help for the
// com.nexus.psi_calibration_refresh launchd agent
// (config/launchd/com.nexus.psi_calibration_refresh.plist).
// The plist itself is committed to the repo; install is operator-initiated, manual.
// This tool prints the launchctl ritual + log/status paths.
//
// @tool(slug="psi_calibration_install_help", desc="print launchd install ritual for com.nexus.psi_calibration_refresh")
// @usage:
//   hexa run tool/psi_calibration_install_help.hexa
//
// raw 71 read-only / raw 80 sentinel-free (pure stdout doc tool)

let LABEL = "com.nexus.psi_calibration_refresh"
let PLIST_REPO = "/Users/ghost/core/nexus/config/launchd/com.nexus.psi_calibration_refresh.plist"
let PLIST_USER = "~/Library/LaunchAgents/com.nexus.psi_calibration_refresh.plist"
let LOG_OUT = "~/.hx/log/psi_calibration_refresh.log"
let LOG_ERR = "~/.hx/log/psi_calibration_refresh.err"
let CACHE_TSV = "/Users/ghost/core/nexus/state/psi_calibration_active.tsv"

println("== ω-network-6b install help: " + LABEL + " ==")
println("")
println("Schedule:  daily at 04:20 (StartCalendarInterval Hour=4 Minute=20)")
println("Action:    hexa run tool/psi_calibration_cache.hexa --refresh-force")
println("           -> regenerates state/psi_calibration_active.tsv")
println("           -> 24h TTL stays satisfied without operator shell sourcing")
println("")
println("-- Install (operator-initiated, ω-network-6b does NOT load) --")
println("  cp " + PLIST_REPO + " \\")
println("     " + PLIST_USER)
println("  mkdir -p ~/.hx/log")
println("  launchctl bootstrap gui/$UID " + PLIST_USER)
println("  launchctl enable     gui/$UID/" + LABEL)
println("  # force first run (otherwise wait for next 04:20):")
println("  launchctl kickstart -k gui/$UID/" + LABEL)
println("")
println("-- Status / logs --")
println("  launchctl print gui/$UID/" + LABEL)
println("  tail -F " + LOG_OUT + " " + LOG_ERR)
println("  tail -n 5 " + CACHE_TSV)
println("")
println("-- Uninstall --")
println("  launchctl bootout gui/$UID/" + LABEL)
println("  rm " + PLIST_USER)
println("")
println("-- Verify plist --")
println("  plutil -lint " + PLIST_REPO)
println("")
println("Repo plist: " + PLIST_REPO)
exit(0)
