// tool/honesty_quick.hexa — 4-repo Honesty triad mode-6 quick check (hexa-native)
//
// raw 9 hexa-only-suffix. atlas_cross_repo_dashboard.sh 핵심 로직의 hexa-native
// 가벼운 빠른 체크. 6 preconditions × 4 repos 매트릭스. mode-6 (precondition (f)
// defense surface 포함).
//
// @tool(slug="honesty_quick", desc="4-repo Honesty mode-6 quick check")
// @usage:
//   hexa run tool/honesty_quick.hexa
//   HEXA_ARGV='--quiet' hexa run tool/honesty_quick.hexa
//
// preconditions:
//   a) git-tracked SSOT     (.git/HEAD exists)
//   b) design corpus        (design/ OR docs/ OR papers/ OR reports/ non-empty)
//   c) tool ecosystem       (tool/ OR scripts/ OR bin/ non-empty)
//   d) atlas SSOT           (n6/atlas.n6 OR atlas.n6 OR atlas/ exists)
//   e) LLM agents indicator (CLAUDE.md OR .claude/ OR agents/)
//   f) defense surface      (SECURITY* OR doc/security/ OR design/SECURITY_AUDIT.md OR ...)
//
// sentinel: __HONESTY_QUICK__ mode=6 honesty_5_5=N honesty_6_6=M repos=4
//
// raw 71 read-only / raw 73 admissibility (4 repos × 6 preconditions = 24 검사) /
// raw 80 sentinel
//
// verified align with atlas_cross_repo_dashboard.sh as of commit 77adae0c
// (mode-6 sentinel honesty_5_5=3 honesty_6_6=3 — fix: file_exists 는 정규파일만
//  탐지하므로 dir 검사는 _dir_exists shell test -d 위임. 이전 버전은 0/0 오탐).

let mut QUIET = false

fn _argv() -> array {
    let raw = to_string(exec("printf '%s' \"${HEXA_ARGV:-}\""))
    let parts = split(raw, " ")
    let mut out = []
    let mut k = 0
    while k < len(parts) {
        if len(parts[k]) > 0 { out.push(parts[k]) }
        k = k + 1
    }
    return out
}

let args = _argv()
let mut i = 0
while i < len(args) {
    let a = args[i]
    if a == "--quiet" { QUIET = true }
    if a == "--help" || a == "-h" {
        println("usage: HEXA_ARGV='--quiet' hexa run tool/honesty_quick.hexa")
        println("  4-repo Honesty triad mode-6 quick check")
        return
    }
    i = i + 1
}

fn _say(msg: string) { if !QUIET { println(msg) } }

// builtin file_exists 는 정규파일만 탐지 — dir 은 shell test -d 로 위임 (raw 9).
fn _dir_exists(path: string) -> bool {
    let r = to_string(exec("test -d '" + path + "' && printf 1 || printf 0")).trim()
    return r == "1"
}

// Each precondition: 'cmd-style' check via shell exec — 1 = present
fn _check_a(repo: string) -> int {
    if file_exists(repo + "/.git/HEAD") { return 1 }
    return 0
}

fn _check_b(repo: string) -> int {
    if _dir_exists(repo + "/design") { return 1 }
    if _dir_exists(repo + "/docs") { return 1 }
    if _dir_exists(repo + "/papers") { return 1 }
    if _dir_exists(repo + "/reports") { return 1 }
    return 0
}

fn _check_c(repo: string) -> int {
    if _dir_exists(repo + "/tool") { return 1 }
    if _dir_exists(repo + "/scripts") { return 1 }
    if _dir_exists(repo + "/bin") { return 1 }
    return 0
}

fn _check_d(repo: string) -> int {
    if file_exists(repo + "/n6/atlas.n6") { return 1 }
    if file_exists(repo + "/atlas.n6") { return 1 }
    if file_exists(repo + "/atlas/atlas.n6") { return 1 }
    if _dir_exists(repo + "/atlas") { return 1 }
    return 0
}

fn _check_e(repo: string) -> int {
    if file_exists(repo + "/CLAUDE.md") { return 1 }
    if _dir_exists(repo + "/.claude") { return 1 }
    if _dir_exists(repo + "/agents") { return 1 }
    return 0
}

fn _check_f(repo: string) -> int {
    // 8 canonical paths per cross_repo_dashboard.sh
    let cmd = "ls " + repo + "/SECURITY* " + repo + "/doc/security/* " + repo + "/docs/security/* " + repo + "/design/security/* " + repo + "/design/SECURITY_AUDIT.md " + repo + "/design/hexa_sim/SECURITY_AUDIT.md " + repo + "/state/security_*.json " + repo + "/tool/security_* 2>/dev/null | wc -l | tr -d ' '"
    let n = to_string(exec(cmd)).trim()
    if n != "0" && len(n) > 0 { return 1 }
    return 0
}

let HOME = "/Users/ghost/core"
let repos = ["nexus", "canon", "anima", "hexa-lang"]

let mut h_5_5 = 0   // count repos passing all 5 (a-e)
let mut h_6_6 = 0   // count repos passing all 6 (a-f)

_say("4-repo Honesty (mode-6, 6 preconditions):")
_say("")
_say("repo                    a b c d e f  total")

for name in repos {
    let path = HOME + "/" + name
    let a = _check_a(path)
    let b = _check_b(path)
    let c = _check_c(path)
    let d = _check_d(path)
    let e = _check_e(path)
    let f = _check_f(path)
    let total_5 = a + b + c + d + e
    let total_6 = total_5 + f
    if total_5 >= 5 { h_5_5 = h_5_5 + 1 }
    if total_6 >= 6 { h_6_6 = h_6_6 + 1 }
    // padding
    let mut pad = ""
    let plen = 24 - len(name)
    let mut q = 0
    while q < plen { pad = pad + " "; q = q + 1 }
    _say(name + pad + to_string(a) + " " + to_string(b) + " " + to_string(c) + " " + to_string(d) + " " + to_string(e) + " " + to_string(f) + "  " + to_string(total_6) + "/6")
}

_say("")
_say("aggregate: " + to_string(h_5_5) + " repos at 5/5 (legacy mode-5) | " + to_string(h_6_6) + " repos at 6/6 (mode-6)")

println("__HONESTY_QUICK__ mode=6 honesty_5_5=" + to_string(h_5_5) + " honesty_6_6=" + to_string(h_6_6) + " repos=4")
