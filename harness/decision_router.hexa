// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
// decision_router.hexa — anima user-fixed 결정 강제 inject 라우터
//
// 역할:
//   - shared/config/decisions.json 읽어 사용자 명시 결정 로드
//   - "go" 5-track dispatch 시 각 agent prompt 에 DECISION ENFORCEMENT 블록 prepend
//   - validate 모드: 필수 필드 + 값 범위 체크 (CI 친화)
//
// 사용:
//   hexa shared/harness/decision_router.hexa            — 결정 prefix stdout 출력
//   hexa shared/harness/decision_router.hexa emit       — 동일
//   hexa shared/harness/decision_router.hexa validate   — 결정 SSOT 정합성 (exit 0/1)
//   hexa shared/harness/decision_router.hexa for <track> — 트랙별 must_check 만 출력
//
// 호출 위치 (강제):
//   - shared/harness/loop.hexa 의 "go" 분기에서 dispatch 직전 호출
//   - shared/config/commands.json go.tracks_anima.dispatch_rule 에 명시
//   - 모든 agent prompt 의 첫 블록으로 inject
//
// SSOT: shared/config/decisions.json
// 변경 정책: 사용자 명시 변경만. 변경 시 decisions.json 의 _meta.updated + 해당 decision rationale 갱신.

let DECISIONS_PATH = "/Users/ghost/Dev/anima/shared/config/decisions.json"

fn jq_get(file: string, query: string) -> string {
    let cmd = "jq -r '" + query + "' '" + file + "' 2>/dev/null"
    let out = exec(cmd).trim()
    return out
}

fn read_decision(key: string) -> string {
    return jq_get(DECISIONS_PATH, ".decisions." + key + ".value")
}

fn read_rationale(key: string) -> string {
    return jq_get(DECISIONS_PATH, ".decisions." + key + ".rationale")
}

fn emit_prefix() {
    let model_size = read_decision("model_size")
    let persona_inclusion = read_decision("persona_inclusion")
    let corpus_strategy = read_decision("corpus_strategy")
    let h100_idle_cap = read_decision("h100_idle_cap_seconds")
    let ckpt_label = read_decision("ckpt_label_default")
    let p3_p4_path = read_decision("p3_p4_path_choice")
    let platform_target = read_decision("platform_release_target")
    let track_pri = jq_get(DECISIONS_PATH, ".decisions.track_priority.value | join(\",\")")

    println("## DECISION ENFORCEMENT (user-fixed, agent 자체 판단 변경 금지)")
    println("source: shared/config/decisions.json (decision_router.hexa)")
    println("")
    println("- model_size: " + model_size + " (Qwen2.5 시리즈; 32B 도전은 P3 gate 미달 시에만)")
    println("- persona_inclusion: " + persona_inclusion + " (직원 P4 path 직행, 페르소나 P2/P3 별도 트랙)")
    println("- corpus_strategy: " + corpus_strategy + " (claude_synthesis 1-2일 / $30-50 권장)")
    println("- track_priority: " + track_pri + " (자원 부족 시 단일 발사 순서)")
    println("- h100_idle_cap_seconds: " + h100_idle_cap + " — 작업 종료 즉시 pod 삭제 (h100_idle_guard 정합)")
    println("- ckpt_label_default: " + ckpt_label + " — production 명시만 R2 백업, 그 외 pod 삭제 시 폐기")
    println("- p3_p4_path_choice: " + p3_p4_path)
    println("- platform_release_target: " + platform_target)
    println("")
    println("primary_doc: shared/papers/v2_v3_full_throttle_path_20260416.md")
    println("override: 사용자 명시 시에만 decisions.json 갱신 후 commit. agent 자체 판단 변경 금지.")
    println("")
}

fn emit_for_track(track: string) {
    let must_check = jq_get(DECISIONS_PATH, ".track_dispatch_rules." + track + ".must_check | join(\",\")")
    if len(must_check) == 0 {
        println("# NO DECISION CONSTRAINTS for track=" + track)
        return
    }
    println("## DECISION ENFORCEMENT for track=" + track)
    println("source: shared/config/decisions.json (decision_router.hexa)")
    println("")
    let parts = must_check.split(",")
    let mut i = 0
    while i < len(parts) {
        let key = parts[i].trim()
        let val = read_decision(key)
        println("- " + key + ": " + val)
        i = i + 1
    }
    println("")
    let enforce = jq_get(DECISIONS_PATH, ".track_dispatch_rules." + track + ".enforcement")
    if len(enforce) > 0 && enforce != "null" {
        println("ENFORCEMENT: " + enforce)
        println("")
    }
}

fn validate() -> bool {
    let required = ["model_size", "persona_inclusion", "corpus_strategy",
                    "h100_idle_cap_seconds", "ckpt_label_default",
                    "p3_p4_path_choice", "platform_release_target"]
    let mut ok = true
    let mut i = 0
    while i < len(required) {
        let key = required[i]
        let v = read_decision(key)
        if len(v) == 0 || v == "null" {
            println("FAIL: missing decision = " + key)
            ok = false
        }
        i = i + 1
    }
    let h100_cap = read_decision("h100_idle_cap_seconds")
    if h100_cap != "0" && h100_cap.parse_int() < 0 {
        println("FAIL: h100_idle_cap_seconds must be >= 0 (got " + h100_cap + ")")
        ok = false
    }
    let model = read_decision("model_size")
    if model != "14b" && model != "32b" && model != "70b" {
        println("FAIL: model_size invalid (got " + model + ")")
        ok = false
    }
    if ok {
        println("decisions.json: VALID")
    }
    return ok
}

fn main() {
    let argv = sys_args()
    let mode = if len(argv) >= 2 { argv[1] } else { "emit" }

    if mode == "emit" {
        emit_prefix()
        return
    }
    if mode == "validate" {
        if !validate() { exit(1) }
        return
    }
    if mode == "for" {
        if len(argv) < 3 {
            println("usage: decision_router.hexa for <track_id>")
            exit(1)
        }
        emit_for_track(argv[2])
        return
    }
    println("usage: decision_router.hexa [emit | validate | for <track>]")
    exit(1)
}

fn sys_args() -> array {
    // Minimal hexa arg accessor — use exec workaround if process_argv unavailable
    // Default: no args (emit mode) — overridden by env if set
    let raw = exec("printf '%s' \"${HEXA_ARGV:-emit}\"")
    let parts = raw.split(" ")
    let mut out = ["decision_router"]
    let mut i = 0
    while i < len(parts) {
        if len(parts[i]) > 0 { out = out.push(parts[i]) }
        i = i + 1
    }
    return out
}
