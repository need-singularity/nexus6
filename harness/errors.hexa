// errors.hexa — H-ERR-ROUTE / DRAIN / PROMOTE CLI wrapper
// @allow-bare-exec
// @no-sandbox
// SSOT: shared/harness/errors.jsonl (큐)
//        shared/harness/severity_map.json (block|defer|warn 분류)
//
// 소비자 (post_bash/post_edit/prompt_scan) 는 exec() 로 이 wrapper 호출.  // @allow-bare-exec
// 고수준 API 는 lib/errors.hexa.inc 에 있음 (copy-paste 소스, 향후 확장).
//
// usage:
//   hexa run errors.hexa route <src> <file> <line> <code> [msg]
//     — severity_map 분류 → block/defer 는 큐 append, warn 은 보고만
//     — block 이면 stdout 에 [H-ERR BLOCK] 메시지 (Claude 즉시 fix 모드)
//   hexa run errors.hexa count_open
//   hexa run errors.hexa drain_check [threshold=10]
//     — open >= threshold 면 [H-ERR-DRAIN] 메시지 stdout
//   hexa run errors.hexa promote [min_recurrence=3]
//   hexa run errors.hexa mark_fixed <key>
//
// 규약: 성공 조용, 실패 stderr. block/drain 은 stdout (액션 유도).

let HOME = env("HOME")
let QUEUE = HOME + "/Dev/nexus/shared/harness/errors.jsonl"
let SMAP = HOME + "/Dev/nexus/shared/harness/severity_map.json"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    return to_int(first)
}

fn _ensure_queue() {
    if !file_exists(QUEUE) {
        try { write_file(QUEUE, "") } catch e {}
    }
}

fn classify(source: string, code: string) -> string {
    let esc_src = source.replace("'", "")
    let esc_code = code.replace("'", "")
    let q = "/usr/bin/jq -r --arg c '" + esc_code + "' --arg s '" + esc_src +
            "' '.rules.lint_rule[$c] // .rules.gc_kind[$c] // .rules.exit_signal[$c] // .rules.source_default[$s] // .fallback' '" +
            SMAP + "' 2>/dev/null"
    let r = _str(exec(q)).trim()  // @allow-bare-exec
    if r == "" || r == "null" { return "defer" }
    return r
}

fn hash_key(file: string, code: string, line: i64) -> string {
    let raw = file + "|" + code + "|" + to_string(line)
    let esc = raw.replace("'", "")
    let cmd = "printf '%s' '" + esc + "' | /usr/bin/shasum -a 256 2>/dev/null | cut -c1-8"
    let r = _str(exec(cmd)).trim()  // @allow-bare-exec
    if r == "" {
        // fallback — 길이 기반 hex (충돌 위험 증가하나 최소 동작 보장)
        let h = len(raw) * 2654435761 + line
        let n = h % 4294967296
        return to_string(n)
    }
    return r
}

fn append_row(sev: string, src: string, file: string, line: i64, code: string, msg: string, key: string) {
    _ensure_queue()
    // dedup: 같은 key + open 있으면 skip (promote 는 라인 수로 판단)
    let grep = "grep -c '\"key\":\"" + key + "\",.*\"status\":\"open\"\\|\"status\":\"open\",.*\"key\":\"" + key + "\"' '" + QUEUE + "' 2>/dev/null"
    let n = _to_int0(_str(exec(grep)))  // @allow-bare-exec
    if n > 0 { return }

    let ts = _str(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()  // @allow-bare-exec
    let proj = _str(exec("basename \"$(pwd)\" 2>/dev/null")).trim()  // @allow-bare-exec
    let esc_msg = msg.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", " ").replace("\r", " ").replace("\t", " ")
    let json = "{\"ts\":\"" + ts + "\"," +
               "\"project\":\"" + proj + "\"," +
               "\"severity\":\"" + sev + "\"," +
               "\"source\":\"" + src + "\"," +
               "\"file\":\"" + file + "\"," +
               "\"line\":" + to_string(line) + "," +
               "\"code\":\"" + code + "\"," +
               "\"msg\":\"" + esc_msg + "\"," +
               "\"attempts\":0," +
               "\"status\":\"open\"," +
               "\"key\":\"" + key + "\"}"
    try { append_file(QUEUE, json + "\n") } catch e {}
}

fn count_open() -> i64 {
    _ensure_queue()
    let out = _str(exec("grep -c '\"status\":\"open\"' '" + QUEUE + "' 2>/dev/null")).trim()  // @allow-bare-exec
    return _to_int0(out)
}

fn cmd_route(argv: [string]) {
    if argv.len() < 7 {
        eprintln("usage: route <src> <file> <line> <code> [msg]")
        return
    }
    let src = argv[3]
    let file = argv[4]
    let line = _to_int0(argv[5])
    let code = argv[6]
    let mut msg = ""
    if argv.len() > 7 { msg = argv[7] }

    let sev = classify(src, code)
    if sev == "warn" {
        println("[H-ERR WARN] " + code + " " + file + ":" + to_string(line))
        return
    }
    let key = hash_key(file, code, line)
    append_row(sev, src, file, line, code, msg, key)
    if sev == "block" {
        println("[H-ERR BLOCK] " + code + " " + file + ":" + to_string(line) + " — " + msg + " (queued, key=" + key + ")")
    }
    // defer: silent
}

fn cmd_count_open() {
    println(to_string(count_open()))
}

fn cmd_drain_check(argv: [string]) {
    let mut threshold: i64 = 10
    if argv.len() > 3 { threshold = _to_int0(argv[3]) }
    let n = count_open()
    if n >= threshold {
        println("[H-ERR-DRAIN] open=" + to_string(n) + " >= " + to_string(threshold) +
                " — drain 필요 (우회: NEXUS_DRAIN_OK=1)")
    }
}

fn cmd_promote(argv: [string]) {
    _ensure_queue()
    let mut min_rec: i64 = 3
    if argv.len() > 3 { min_rec = _to_int0(argv[3]) }
    let script = "grep '\"status\":\"open\"' '" + QUEUE +
                 "' 2>/dev/null | /usr/bin/jq -r '[.file, .code] | @tsv' 2>/dev/null | " +
                 "sort | uniq -c | awk -v m=" + to_string(min_rec) +
                 " '$1 >= m {printf \"%s|%s x%d\\n\", $2, $3, $1}'"
    let out = _str(exec(script)).trim()  // @allow-bare-exec
    if out.len() > 0 { println(out) }
}

fn cmd_mark_fixed(argv: [string]) {
    if argv.len() < 4 {
        eprintln("usage: mark_fixed <key>")
        return
    }
    let key = argv[3]
    _ensure_queue()
    // key 포함 라인의 "status":"open" → "status":"fixed" (BSD/GNU sed 호환)
    let cmd_s = "/usr/bin/sed -i.bak '/\"key\":\"" + key + "\"/ s/\"status\":\"open\"/\"status\":\"fixed\"/' '" +
                QUEUE + "' && rm -f '" + QUEUE + ".bak'"
    exec(cmd_s)  // @allow-bare-exec
    println("marked fixed: " + key)
}

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    if argv.len() < 3 {
        eprintln("usage: errors.hexa <route|count_open|drain_check|promote|mark_fixed> [args]")
        return
    }
    let cmd = argv[2]
    if cmd == "route" { cmd_route(argv) }
    else if cmd == "count_open" { cmd_count_open() }
    else if cmd == "drain_check" { cmd_drain_check(argv) }
    else if cmd == "promote" { cmd_promote(argv) }
    else if cmd == "mark_fixed" { cmd_mark_fixed(argv) }
    else { eprintln("unknown cmd: " + cmd) }
}

main()
