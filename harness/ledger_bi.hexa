// @no-sandbox       — 읽기 집계 + JSON/HTML writer, launchd sandbox 불필요
// @no-lock-needed   — 단발 실행 (build_stats → write_outputs), 동시 호출 안전
// ledger_bi.hexa — AGL-P7-1 BI 대시보드
// 역할: work_registry.jsonl + session_registry.jsonl 통계 집계 → JSON SSOT + HTML.
// PROJECTS 하드코딩은 shared/config/projects.json `root` 필드 7개 미러 (동기 필요 시 자동화 여지)
// SSOT out:
//   shared/reports/ledger_bi_<YYYYMMDD>.json  (통계 스냅샷)
//   shared/reports/ledger_bi_latest.json      (심링크 역할 — 항상 최신 복사본)
//   docs/ledger_bi.html                       (static + fetch JSON, meta-refresh 60s)
//
// panels (4):
//   P1 volume_7d      daily_agents / avg_duration / success_rate
//   P2 projects       area → project 매핑 후 프로젝트별 agent 건수 + 평균 수명
//   P3 cost_30d       model × tokens_est 합계 + 30일 추세
//   P4 failures       최빈 stale/active>stale 영역 top5
//
// usage:
//   hexa run shared/harness/ledger_bi.hexa           — 전체 집계 + JSON/HTML 갱신
//   hexa run shared/harness/ledger_bi.hexa smoke     — 1회 실행 + 결과 경로 stdout
//   hexa run shared/harness/ledger_bi.hexa json      — stdout JSON 만 (HTML skip)
//
// 성공 조용: 에러만 stderr, 정상 시 산출 파일 경로 1줄.

let HOME = env("HOME")
let NEXUS_ENV = env("NEXUS")
let NEXUS = if NEXUS_ENV == "" { HOME + "/Dev/nexus" } else { NEXUS_ENV }
let HARNESS = NEXUS + "/shared/harness"
let REPORTS = NEXUS + "/shared/reports"
let DOCS = NEXUS + "/docs"

let WORK_REG = HARNESS + "/work_registry.jsonl"
let SESSION_REG = HARNESS + "/session_registry.jsonl"

let JSON_LATEST = REPORTS + "/ledger_bi_latest.json"
let HTML_OUT = DOCS + "/ledger_bi.html"

// 7 canonical projects (shared/config/projects.json root)
let PROJECTS = ["nexus", "anima", "n6-architecture", "papers", "hexa-lang", "void", "airgenome"]

// ─── void-safe helpers ───
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    return to_int(first)
}

fn now_unix() -> i64 {
    return _to_int0(_str(exec("date +%s")).trim())
}

fn iso_now() -> string {
    return _str(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
}

fn ymd_today() -> string {
    return _str(exec("date +%Y%m%d")).trim()
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", " ")
    r = r.replace("\r", " ")
    r = r.replace("\t", " ")
    return r
}

fn ensure_reports() {
    let _ = exec("mkdir -p '" + REPORTS + "' 2>/dev/null")
    let _ = exec("mkdir -p '" + DOCS + "' 2>/dev/null")
}

// ─── JSON 단순 필드 추출 ("key":value | "key":"value") ───
fn json_field(line: string, key: string) -> string {
    let tag = "\"" + key + "\""
    if line.contains(tag) == false { return "" }
    let after = line.split(tag)[1]
    let parts = after.split(":")
    if parts.len() < 2 { return "" }
    let mut rest = parts[1]
    let mut i = 2
    while i < parts.len() {
        rest = rest + ":" + parts[i]
        i = i + 1
    }
    let s = rest.trim()
    if s.len() == 0 { return "" }
    if s.substring(0, 1) == "\"" {
        let inner = s.substring(1, s.len())
        let end = inner.index_of("\"")
        if end < 0 { return "" }
        return inner.substring(0, end)
    }
    // numeric or null — 콤마/} 전까지
    let mut v = ""
    let mut j = 0
    while j < s.len() {
        let ch = s.substring(j, j + 1)
        if ch == "," || ch == "}" || ch == " " { break }
        v = v + ch
        j = j + 1
    }
    return v
}

// ─── area → project 매핑 ───
// 규칙:
//   1) area 가 프로젝트명 prefix 로 시작  → 해당 프로젝트
//   2) "nexus-", "harness", "atlas", "lens", "disc" 포함  → nexus
//   3) "anima" 포함 → anima
//   4) 기타 → nexus (default — 이 ledger 자체가 nexus harness)
fn area_to_project(area: string) -> string {
    let a = area.trim()
    if a == "" { return "nexus" }
    for p in PROJECTS {
        if a == p { return p }
        if a.substring(0, 0) == "" && a.len() >= p.len() {
            if a.substring(0, p.len()) == p { return p }
        }
    }
    if a.contains("anima") { return "anima" }
    if a.contains("n6-") || a.contains("n6_") { return "n6-architecture" }
    if a.contains("paper") { return "papers" }
    if a.contains("hexa-lang") || a.contains("hexa_lang") { return "hexa-lang" }
    if a.contains("void") { return "void" }
    if a.contains("airgenome") || a.contains("airgnm") { return "airgenome" }
    // harness/atlas/lens/disc 등은 nexus
    return "nexus"
}

// ─── 집계 구조체 — parallel arrays (hexa hashmap iterate 제한 회피) ───
// project_* : PROJECTS 와 같은 인덱스
// area_* : 동적 (stale top-k 용)

fn build_stats() -> string {
    let now = now_unix()
    let cutoff_7d = now - 7 * 86400
    let cutoff_30d = now - 30 * 86400

    // accumulators
    let mut total: i64 = 0
    let mut done: i64 = 0
    let mut active: i64 = 0
    let mut stale: i64 = 0

    let mut dur_sum: i64 = 0
    let mut dur_n: i64 = 0

    let mut tokens_sum: i64 = 0

    // daily 7 buckets (index = day offset 0~6 from today)
    let mut daily_count = [0, 0, 0, 0, 0, 0, 0]
    let mut daily_dur_sum = [0, 0, 0, 0, 0, 0, 0]
    let mut daily_dur_n = [0, 0, 0, 0, 0, 0, 0]

    // project buckets (7 projects)
    let mut proj_count = [0, 0, 0, 0, 0, 0, 0]
    let mut proj_done = [0, 0, 0, 0, 0, 0, 0]
    let mut proj_dur_sum = [0, 0, 0, 0, 0, 0, 0]
    let mut proj_tokens = [0, 0, 0, 0, 0, 0, 0]

    // 30-day bucket (주별 4개 + today=index4)
    let mut cost_buckets = [0, 0, 0, 0, 0]  // [w1..w4, today]
    let mut model_names = []
    let mut model_tokens = []

    // failure tracking (stale area → count)
    let mut fail_area_names = []
    let mut fail_area_counts = []

    // read registry
    let mut raw = ""
    try { raw = _str(read_file(WORK_REG)) } catch e {}
    if raw.len() == 0 {
        // 빈 ledger도 정상 — 모두 0
        return stats_to_json(total, done, active, stale,
            dur_sum, dur_n, tokens_sum,
            daily_count, daily_dur_sum, daily_dur_n,
            proj_count, proj_done, proj_dur_sum, proj_tokens,
            cost_buckets, model_names, model_tokens,
            fail_area_names, fail_area_counts, 0)
    }

    let lines = raw.split("\n")
    let mut sessions_active = count_active_sessions()

    for line in lines {
        let s = _str(line).trim()
        if s.len() < 10 { continue }
        if s.substring(0, 1) != "{" { continue }

        total = total + 1
        let status = json_field(s, "status")
        let area = json_field(s, "area")
        let model = json_field(s, "model")
        let ts_start_s = json_field(s, "ts_start")
        let ts_end_s = json_field(s, "ts_end")
        let tokens_s = json_field(s, "tokens_est")

        let ts_start = _to_int0(ts_start_s)
        let mut ts_end: i64 = 0
        if ts_end_s != "" && ts_end_s != "null" {
            ts_end = _to_int0(ts_end_s)
        }
        let tokens = _to_int0(tokens_s)

        if status == "done" { done = done + 1 }
        else if status == "active" { active = active + 1 }
        else if status == "stale" { stale = stale + 1 }

        // duration (done + valid ts_end)
        if status == "done" && ts_end > 0 && ts_start > 0 && ts_end >= ts_start {
            let d = ts_end - ts_start
            dur_sum = dur_sum + d
            dur_n = dur_n + 1
        }
        tokens_sum = tokens_sum + tokens

        // 7d daily bucket
        if ts_start >= cutoff_7d {
            let age_days = (now - ts_start) / 86400
            if age_days >= 0 && age_days < 7 {
                let idx: i64 = 6 - age_days  // 0=6d ago, 6=today
                daily_count[idx] = daily_count[idx] + 1
                if status == "done" && ts_end > 0 && ts_start > 0 && ts_end >= ts_start {
                    daily_dur_sum[idx] = daily_dur_sum[idx] + (ts_end - ts_start)
                    daily_dur_n[idx] = daily_dur_n[idx] + 1
                }
            }
        }

        // project mapping
        let proj = area_to_project(area)
        let mut p_idx: i64 = -1
        let mut pi = 0
        while pi < PROJECTS.len() {
            if PROJECTS[pi] == proj { p_idx = pi; break }
            pi = pi + 1
        }
        if p_idx >= 0 {
            proj_count[p_idx] = proj_count[p_idx] + 1
            if status == "done" { proj_done[p_idx] = proj_done[p_idx] + 1 }
            if status == "done" && ts_end > 0 && ts_start > 0 && ts_end >= ts_start {
                proj_dur_sum[p_idx] = proj_dur_sum[p_idx] + (ts_end - ts_start)
            }
            proj_tokens[p_idx] = proj_tokens[p_idx] + tokens
        }

        // 30d cost bucket (tokens proxy)
        if ts_start >= cutoff_30d {
            let age_sec = now - ts_start
            let mut cb_idx: i64 = 4  // today default
            if age_sec >= 86400 && age_sec < 7 * 86400 { cb_idx = 3 }
            else if age_sec >= 7 * 86400 && age_sec < 14 * 86400 { cb_idx = 2 }
            else if age_sec >= 14 * 86400 && age_sec < 21 * 86400 { cb_idx = 1 }
            else if age_sec >= 21 * 86400 { cb_idx = 0 }
            cost_buckets[cb_idx] = cost_buckets[cb_idx] + tokens
        }

        // model histogram (tokens by model)
        if model.len() > 0 {
            let mut mi = 0
            let mut found = false
            while mi < model_names.len() {
                if model_names[mi] == model {
                    model_tokens[mi] = model_tokens[mi] + tokens
                    found = true
                    break
                }
                mi = mi + 1
            }
            if found == false {
                model_names = model_names + [model]
                model_tokens = model_tokens + [tokens]
            }
        }

        // failure tracking — stale + active-too-long (>3600s, 실제 stale 후보)
        let is_fail = status == "stale"
        let is_stuck = status == "active" && ts_start > 0 && (now - ts_start) > 3600
        if is_fail || is_stuck {
            let mut ai = 0
            let mut found_a = false
            while ai < fail_area_names.len() {
                if fail_area_names[ai] == area {
                    fail_area_counts[ai] = fail_area_counts[ai] + 1
                    found_a = true
                    break
                }
                ai = ai + 1
            }
            if found_a == false {
                fail_area_names = fail_area_names + [area]
                fail_area_counts = fail_area_counts + [1]
            }
        }
    }

    return stats_to_json(total, done, active, stale,
        dur_sum, dur_n, tokens_sum,
        daily_count, daily_dur_sum, daily_dur_n,
        proj_count, proj_done, proj_dur_sum, proj_tokens,
        cost_buckets, model_names, model_tokens,
        fail_area_names, fail_area_counts, sessions_active)
}

fn count_active_sessions() -> i64 {
    let mut raw = ""
    try { raw = _str(read_file(SESSION_REG)) } catch e {}
    if raw.len() == 0 { return 0 }
    let mut n: i64 = 0
    for line in raw.split("\n") {
        let s = _str(line).trim()
        if s.len() < 10 { continue }
        if s.contains("\"status\":\"active\"") { n = n + 1 }
    }
    return n
}

// ─── AGL-P8-1 race wins 패널 집계 ───
// shared/logs/agent_race.jsonl 에서 finished row 만 집계.
// 반환 JSON: {"finished":N,"planned":P,"started":S,"avg_time_to_first_sec":T,
//             "wins_7d":W, "latest":[{race_id,winner,time_to_first,ts_unix},...x5]}
fn build_race_json() -> string {
    let race_log = NEXUS + "/shared/logs/agent_race.jsonl"
    let mut raw = ""
    try { raw = _str(read_file(race_log)) } catch e {}
    if raw.len() == 0 {
        return "{\"finished\":0,\"planned\":0,\"started\":0," +
               "\"avg_time_to_first_sec\":0,\"wins_7d\":0,\"latest\":[]}"
    }

    let now = now_unix()
    let cutoff_7d = now - 7 * 86400

    let mut fin: i64 = 0
    let mut plan: i64 = 0
    let mut start: i64 = 0
    let mut dur_sum: i64 = 0
    let mut dur_n: i64 = 0
    let mut wins_7d: i64 = 0

    // latest 5 finished (insertion order, 끝에서 5개 유지)
    let mut latest_ids: [string] = []
    let mut latest_winners: [string] = []
    let mut latest_times: [i64] = []
    let mut latest_ts: [i64] = []

    for line in raw.split("\n") {
        let s = _str(line).trim()
        if s.len() < 10 { continue }
        if s.substring(0, 1) != "{" { continue }
        let status = json_field(s, "status")
        let ts = _to_int0(json_field(s, "ts_unix"))
        if status == "planned" { plan = plan + 1 }
        else if status == "started" { start = start + 1 }
        else if status == "finished" {
            fin = fin + 1
            let t = _to_int0(json_field(s, "time_to_first_sec"))
            if t > 0 {
                dur_sum = dur_sum + t
                dur_n = dur_n + 1
            }
            if ts >= cutoff_7d { wins_7d = wins_7d + 1 }
            // append latest (keep last 5)
            let rid = json_field(s, "race_id")
            let win = json_field(s, "winner_agent_id")
            latest_ids = latest_ids + [rid]
            latest_winners = latest_winners + [win]
            latest_times = latest_times + [t]
            latest_ts = latest_ts + [ts]
        }
    }

    let avg_t = if dur_n > 0 { dur_sum / dur_n } else { 0 }

    // latest 5 -- tail
    let total_latest = latest_ids.len()
    let start_idx = if total_latest > 5 { total_latest - 5 } else { 0 }
    let mut latest_json = "["
    let mut i = start_idx
    let mut first = true
    while i < total_latest {
        if first == false { latest_json = latest_json + "," }
        latest_json = latest_json +
            "{\"race_id\":\"" + json_escape(latest_ids[i]) + "\"," +
            "\"winner\":\"" + json_escape(latest_winners[i]) + "\"," +
            "\"time_to_first_sec\":" + to_string(latest_times[i]) + "," +
            "\"ts_unix\":" + to_string(latest_ts[i]) + "}"
        first = false
        i = i + 1
    }
    latest_json = latest_json + "]"

    return "{\"finished\":" + to_string(fin) + "," +
           "\"planned\":" + to_string(plan) + "," +
           "\"started\":" + to_string(start) + "," +
           "\"avg_time_to_first_sec\":" + to_string(avg_t) + "," +
           "\"wins_7d\":" + to_string(wins_7d) + "," +
           "\"latest\":" + latest_json + "}"
}

// ─── top-k by count (failures panel) ───
fn top_k_fails(names: [string], counts: [i64], k: i64) -> string {
    // bubble sort desc by counts (small list, O(n^2) ok)
    let mut nm = names
    let mut cn = counts
    let n = nm.len()
    let mut i = 0
    while i < n {
        let mut j = 0
        while j < n - i - 1 {
            if cn[j] < cn[j + 1] {
                let tc = cn[j]; cn[j] = cn[j + 1]; cn[j + 1] = tc
                let tn = nm[j]; nm[j] = nm[j + 1]; nm[j + 1] = tn
            }
            j = j + 1
        }
        i = i + 1
    }
    let limit = if n < k { n } else { k }
    let mut out = "["
    let mut idx = 0
    while idx < limit {
        if idx > 0 { out = out + "," }
        out = out + "{\"area\":\"" + json_escape(nm[idx]) + "\",\"count\":" + to_string(cn[idx]) + "}"
        idx = idx + 1
    }
    out = out + "]"
    return out
}

// ─── JSON 직렬화 ───
fn arr_i64_json(xs: [i64]) -> string {
    let mut out = "["
    let mut i = 0
    while i < xs.len() {
        if i > 0 { out = out + "," }
        out = out + to_string(xs[i])
        i = i + 1
    }
    return out + "]"
}

fn stats_to_json(total: i64, done: i64, active: i64, stale: i64,
    dur_sum: i64, dur_n: i64, tokens_sum: i64,
    daily_count: [i64], daily_dur_sum: [i64], daily_dur_n: [i64],
    proj_count: [i64], proj_done: [i64], proj_dur_sum: [i64], proj_tokens: [i64],
    cost_buckets: [i64], model_names: [string], model_tokens: [i64],
    fail_names: [string], fail_counts: [i64], sessions_active: i64) -> string {

    let avg_dur = if dur_n > 0 { dur_sum / dur_n } else { 0 }
    let success_rate_pct = if total > 0 { (done * 100) / total } else { 0 }

    // projects array
    let mut proj_json = "["
    let mut i = 0
    while i < PROJECTS.len() {
        if i > 0 { proj_json = proj_json + "," }
        let avg_p = if proj_done[i] > 0 { proj_dur_sum[i] / proj_done[i] } else { 0 }
        proj_json = proj_json +
            "{\"name\":\"" + PROJECTS[i] + "\"," +
            "\"agents\":" + to_string(proj_count[i]) + "," +
            "\"done\":" + to_string(proj_done[i]) + "," +
            "\"avg_duration_sec\":" + to_string(avg_p) + "," +
            "\"tokens_est\":" + to_string(proj_tokens[i]) + "}"
        i = i + 1
    }
    proj_json = proj_json + "]"

    // daily 7d array (today 기준 과거 → 현재 순)
    let mut daily_json = "["
    let mut di = 0
    while di < 7 {
        if di > 0 { daily_json = daily_json + "," }
        let avg_d = if daily_dur_n[di] > 0 { daily_dur_sum[di] / daily_dur_n[di] } else { 0 }
        let day_label = "d-" + to_string(6 - di)
        daily_json = daily_json +
            "{\"day\":\"" + day_label + "\"," +
            "\"agents\":" + to_string(daily_count[di]) + "," +
            "\"avg_duration_sec\":" + to_string(avg_d) + "}"
        di = di + 1
    }
    daily_json = daily_json + "]"

    // cost_30d buckets
    let cost_json = "{\"w_minus_3\":" + to_string(cost_buckets[0]) + "," +
                    "\"w_minus_2\":" + to_string(cost_buckets[1]) + "," +
                    "\"w_minus_1\":" + to_string(cost_buckets[2]) + "," +
                    "\"last_7d\":" + to_string(cost_buckets[3]) + "," +
                    "\"today\":" + to_string(cost_buckets[4]) + "}"

    // model hist
    let mut model_json = "["
    let mut mi = 0
    while mi < model_names.len() {
        if mi > 0 { model_json = model_json + "," }
        model_json = model_json +
            "{\"model\":\"" + json_escape(model_names[mi]) + "\"," +
            "\"tokens_est\":" + to_string(model_tokens[mi]) + "}"
        mi = mi + 1
    }
    model_json = model_json + "]"

    let fails_json = top_k_fails(fail_names, fail_counts, 5)

    let ts = iso_now()
    let ts_unix = now_unix()

    let race_json = build_race_json()

    let out = "{\"schema\":\"ledger_bi/v1\"," +
              "\"generated_at\":\"" + ts + "\"," +
              "\"generated_unix\":" + to_string(ts_unix) + "," +
              "\"source\":\"" + WORK_REG + "\"," +
              "\"volume\":{" +
                "\"total\":" + to_string(total) + "," +
                "\"done\":" + to_string(done) + "," +
                "\"active\":" + to_string(active) + "," +
                "\"stale\":" + to_string(stale) + "," +
                "\"avg_duration_sec\":" + to_string(avg_dur) + "," +
                "\"success_rate_pct\":" + to_string(success_rate_pct) + "," +
                "\"sessions_active\":" + to_string(sessions_active) + "," +
                "\"daily_7d\":" + daily_json + "}," +
              "\"projects\":" + proj_json + "," +
              "\"cost\":{" +
                "\"tokens_est_total\":" + to_string(tokens_sum) + "," +
                "\"buckets_30d\":" + cost_json + "," +
                "\"by_model\":" + model_json + "}," +
              "\"failures\":{\"top5\":" + fails_json + "}," +
              "\"race\":" + race_json + "}"
    return out
}

// ─── HTML 렌더 (정적 + fetch JSON) ───
// 기존 shared/dashboard.html 스타일 차용: dark bg, grid panels, meta-refresh 60s.
fn render_html() -> string {
    let ts = iso_now()
    let h = "<!doctype html><html lang=\"ko\"><head><meta charset=\"utf-8\">\n" +
        "<title>nexus ledger BI</title>\n" +
        "<meta http-equiv=\"refresh\" content=\"60\">\n" +
        "<style>\n" +
        "*{margin:0;padding:0;box-sizing:border-box;}\n" +
        "body{font:12px 'SF Mono','Menlo',monospace;background:#0a0a0a;color:#c8d0c0;padding:16px;max-width:1200px;margin:0 auto;line-height:1.5;}\n" +
        "h1{color:#8ef;font-size:18px;margin:0 0 2px;}\n" +
        ".meta{color:#555;font-size:10px;margin-bottom:14px;}\n" +
        ".grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;}\n" +
        ".panel{background:#0d0d0d;border:1px solid #2a3a2a;border-radius:4px;overflow:hidden;}\n" +
        ".panel.volume{border-color:#4a9;}\n" +
        ".panel.projects{border-color:#8ef;}\n" +
        ".panel.cost{border-color:#f80;}\n" +
        ".panel.failures{border-color:#f48;}\n" +
        ".panel.race{border-color:#cc4;}\n" +
        ".panel-title{background:#111;color:#8ef;padding:8px 12px;border-bottom:1px solid #2a3a2a;font-size:11px;font-weight:600;letter-spacing:1px;text-transform:uppercase;}\n" +
        ".panel.volume .panel-title{color:#4a9;}\n" +
        ".panel.cost .panel-title{color:#f80;}\n" +
        ".panel.failures .panel-title{color:#f48;}\n" +
        ".panel.race .panel-title{color:#cc4;}\n" +
        ".panel-section{padding:10px 12px;border-bottom:1px solid #1a1a1a;}\n" +
        ".panel-section:last-child{border-bottom:none;}\n" +
        ".row{display:flex;justify-content:space-between;align-items:baseline;padding:2px 0;font-size:11px;}\n" +
        ".row .k{color:#888;}\n" +
        ".row .v{color:#c8d0c0;font-weight:500;}\n" +
        ".row .v.hi{color:#8ef;}\n" +
        ".bar-row{display:flex;align-items:center;margin:3px 0;font-size:10px;}\n" +
        ".bar-row .name{width:130px;color:#888;text-align:right;padding-right:8px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}\n" +
        ".bar-row .bar{height:12px;background:#4a9;border-radius:2px;min-width:2px;}\n" +
        ".bar-row .count{color:#888;padding-left:6px;font-size:10px;}\n" +
        ".stale{color:#f48;}\n" +
        ".active{color:#f80;}\n" +
        ".done{color:#4a9;}\n" +
        "#status{color:#555;font-size:10px;margin-top:16px;}\n" +
        "</style></head><body>\n" +
        "<h1>nexus ledger BI</h1>\n" +
        "<div class=\"meta\">AGL-P7-1 + AGL-P8-1 · work_registry + agent_race · 5 panels · auto-refresh 60s · generated " + ts + "</div>\n" +
        "<div id=\"status\">Loading ledger_bi_latest.json...</div>\n" +
        "<div class=\"grid2\">\n" +
        "  <div class=\"panel volume\"><div class=\"panel-title\">P1 volume (7d)</div><div id=\"p-volume\" class=\"panel-section\">loading...</div></div>\n" +
        "  <div class=\"panel projects\"><div class=\"panel-title\">P2 by project</div><div id=\"p-projects\" class=\"panel-section\">loading...</div></div>\n" +
        "  <div class=\"panel cost\"><div class=\"panel-title\">P3 cost / tokens (30d)</div><div id=\"p-cost\" class=\"panel-section\">loading...</div></div>\n" +
        "  <div class=\"panel failures\"><div class=\"panel-title\">P4 failures (top 5)</div><div id=\"p-failures\" class=\"panel-section\">loading...</div></div>\n" +
        "  <div class=\"panel race\"><div class=\"panel-title\">P5 race wins (distributed)</div><div id=\"p-race\" class=\"panel-section\">loading...</div></div>\n" +
        "</div>\n" +
        "<script>\n" +
        "async function load(){\n" +
        "  try{\n" +
        "    const r = await fetch('../shared/reports/ledger_bi_latest.json?t='+Date.now());\n" +
        "    if(!r.ok) throw new Error('HTTP '+r.status);\n" +
        "    const d = await r.json();\n" +
        "    document.getElementById('status').textContent = 'Loaded: '+d.generated_at+' · '+d.volume.total+' ledger rows · '+d.volume.sessions_active+' active sessions';\n" +
        "    renderVolume(d.volume);\n" +
        "    renderProjects(d.projects);\n" +
        "    renderCost(d.cost);\n" +
        "    renderFailures(d.failures);\n" +
        "    renderRace(d.race || {finished:0,planned:0,started:0,avg_time_to_first_sec:0,wins_7d:0,latest:[]});\n" +
        "  }catch(e){\n" +
        "    document.getElementById('status').textContent = 'Fetch failed ('+e.message+') — run: hexa $NEXUS/shared/harness/ledger_bi.hexa';\n" +
        "  }\n" +
        "}\n" +
        "function row(k,v,cls){return '<div class=\"row\"><span class=\"k\">'+k+'</span><span class=\"v '+(cls||'')+'\">'+v+'</span></div>';}\n" +
        "function renderVolume(v){\n" +
        "  let html = row('total', v.total, 'hi') + row('done', v.done, 'done') + row('active', v.active, 'active') + row('stale', v.stale, 'stale');\n" +
        "  html += row('success %', v.success_rate_pct+'%');\n" +
        "  html += row('avg duration', v.avg_duration_sec+'s');\n" +
        "  html += '<div style=\"margin-top:8px;color:#888;font-size:10px;\">daily 7d:</div>';\n" +
        "  const maxD = Math.max(1, ...v.daily_7d.map(x=>x.agents));\n" +
        "  v.daily_7d.forEach(d => {\n" +
        "    const w = Math.max(2, d.agents/maxD*100);\n" +
        "    html += '<div class=\"bar-row\"><span class=\"name\">'+d.day+'</span><span class=\"bar\" style=\"width:'+w+'%\"></span><span class=\"count\">'+d.agents+'</span></div>';\n" +
        "  });\n" +
        "  document.getElementById('p-volume').innerHTML = html;\n" +
        "}\n" +
        "function renderProjects(projs){\n" +
        "  const max = Math.max(1, ...projs.map(p=>p.agents));\n" +
        "  let html = '';\n" +
        "  projs.forEach(p => {\n" +
        "    const w = Math.max(2, p.agents/max*100);\n" +
        "    html += '<div class=\"bar-row\"><span class=\"name\">'+p.name+'</span><span class=\"bar\" style=\"width:'+w+'%\"></span><span class=\"count\">'+p.agents+' ('+p.avg_duration_sec+'s)</span></div>';\n" +
        "  });\n" +
        "  document.getElementById('p-projects').innerHTML = html || '<div style=\"color:#555\">(no data)</div>';\n" +
        "}\n" +
        "function renderCost(c){\n" +
        "  let html = row('tokens total', c.tokens_est_total, 'hi');\n" +
        "  html += '<div style=\"margin-top:8px;color:#888;font-size:10px;\">30d buckets (tokens):</div>';\n" +
        "  const b = c.buckets_30d;\n" +
        "  const labels = [['w-3',b.w_minus_3],['w-2',b.w_minus_2],['w-1',b.w_minus_1],['7d',b.last_7d],['today',b.today]];\n" +
        "  const max = Math.max(1, ...labels.map(x=>x[1]));\n" +
        "  labels.forEach(([l,n]) => {\n" +
        "    const w = Math.max(2, n/max*100);\n" +
        "    html += '<div class=\"bar-row\"><span class=\"name\">'+l+'</span><span class=\"bar\" style=\"width:'+w+'%;background:#f80\"></span><span class=\"count\">'+n+'</span></div>';\n" +
        "  });\n" +
        "  if(c.by_model && c.by_model.length){\n" +
        "    html += '<div style=\"margin-top:8px;color:#888;font-size:10px;\">by model:</div>';\n" +
        "    c.by_model.forEach(m => { html += row(m.model || '(none)', m.tokens_est+' tok'); });\n" +
        "  }\n" +
        "  document.getElementById('p-cost').innerHTML = html;\n" +
        "}\n" +
        "function renderFailures(f){\n" +
        "  if(!f.top5 || !f.top5.length){ document.getElementById('p-failures').innerHTML = '<div style=\"color:#4a9\">no failures — all agents done/active within SLA</div>'; return; }\n" +
        "  const max = Math.max(1, ...f.top5.map(x=>x.count));\n" +
        "  let html = '';\n" +
        "  f.top5.forEach(x => {\n" +
        "    const w = Math.max(2, x.count/max*100);\n" +
        "    html += '<div class=\"bar-row\"><span class=\"name\">'+x.area+'</span><span class=\"bar\" style=\"width:'+w+'%;background:#f48\"></span><span class=\"count\">'+x.count+'</span></div>';\n" +
        "  });\n" +
        "  document.getElementById('p-failures').innerHTML = html;\n" +
        "}\n" +
        "function renderRace(r){\n" +
        "  let html = row('finished', r.finished, 'hi') + row('planned', r.planned) + row('started', r.started);\n" +
        "  html += row('wins 7d', r.wins_7d, 'done');\n" +
        "  html += row('avg time-to-first', r.avg_time_to_first_sec+'s');\n" +
        "  if(r.latest && r.latest.length){\n" +
        "    html += '<div style=\"margin-top:8px;color:#888;font-size:10px;\">latest wins:</div>';\n" +
        "    r.latest.forEach(x => {\n" +
        "      html += '<div class=\"bar-row\"><span class=\"name\">'+x.race_id+'</span><span class=\"bar\" style=\"width:'+Math.max(2, Math.min(100, x.time_to_first_sec*5))+'%;background:#cc4\"></span><span class=\"count\">'+x.time_to_first_sec+'s · '+x.winner+'</span></div>';\n" +
        "    });\n" +
        "  } else {\n" +
        "    html += '<div style=\"color:#555;margin-top:6px;\">(no race wins yet — run: hexa $NEXUS/shared/harness/agent_race.hexa simulate 3 3)</div>';\n" +
        "  }\n" +
        "  document.getElementById('p-race').innerHTML = html;\n" +
        "}\n" +
        "load();\n" +
        "</script>\n" +
        "</body></html>\n"
    return h
}

fn write_outputs(json: string, emit_html: bool) -> string {
    ensure_reports()
    let dated = REPORTS + "/ledger_bi_" + ymd_today() + ".json"

    try { write_file(dated, json) } catch e {
        eprintln("FAIL: write_file " + dated + " — " + to_string(e))
        return ""
    }
    try { write_file(JSON_LATEST, json) } catch e {
        eprintln("FAIL: write_file " + JSON_LATEST + " — " + to_string(e))
    }

    if emit_html {
        let html = render_html()
        try { write_file(HTML_OUT, html) } catch e {
            eprintln("FAIL: write_file " + HTML_OUT + " — " + to_string(e))
        }
    }
    return dated
}

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    let mut mode = "full"
    if argv.len() >= 3 { mode = argv[2].trim() }

    let json = build_stats()

    if mode == "json" {
        println(json)
        return
    }

    let dated = write_outputs(json, true)
    if dated == "" {
        exit(1)
    }
    // 성공: 산출 경로만 1줄 stdout
    println("json: " + dated)
    println("latest: " + JSON_LATEST)
    println("html: " + HTML_OUT)

    if mode == "smoke" {
        // 추가 요약
        eprintln("smoke ok — ledger_bi_latest.json + docs/ledger_bi.html generated")
    }
}

main()
