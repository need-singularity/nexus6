// signal_writer_watcher.hexa — E1 대체 하네스
// 최근 수정된 .md (find -mtime -N) 에서 signal 마커 grep 후 staging append
// 실행: hexa run $NEXUS/shared/harness/signal_writer_watcher.hexa [hours=24]
//
// 감지 패턴: ★ / 진짜 (특별|발견) / 최초 / NULL / PEAK / sweet spot / pp drop / × faster

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let N6 = HOME + "/Dev/n6-architecture"
let ANIMA = HOME + "/Dev/anima"
let STAGE = NEXUS + "/shared/n6/staging/atlas.signals.staging.writer.n6"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn now_ts() -> string {
    let r = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    return _str(r).trim()
}

fn shell_quote(s: string) -> string {
    let escaped = s.replace("'", "'\\''")
    return "'" + escaped + "'"
}

fn grep_count_in_file(file: string, pat: string) -> i64 {
    let cmd = "grep -c -E " + shell_quote(pat) + " '" + file + "' 2>/dev/null || echo 0"
    let r = exec(cmd)
    let s = _str(r).trim().split("\n")[0]
    let mut v: i64 = 0
    try { v = to_int(s) } catch e { v = 0 }
    return v
}

fn find_recent_md(root: string, hours: i64) -> [string] {
    let mins = hours * 60
    let cmd = "find '" + root + "' -type f -name '*.md' -mmin -" +
              to_string(mins) + " 2>/dev/null | head -200"
    let r = exec(cmd)
    let text = _str(r)
    let lines = text.split("\n")
    let mut out: [string] = []
    for line in lines {
        let s = _str(line).trim()
        if s != "" { out = out + [s] }
    }
    return out
}

fn append_line(path: string, line: string) {
    let cmd = "printf '%s\\n' " + shell_quote(line) + " >> '" + path + "' 2>/dev/null"
    exec(cmd)
}

// ─── 메인 ───
let a = args()
let mut hours: i64 = 24
if a.len() >= 3 {
    try { hours = to_int(a[2]) } catch e { hours = 24 }
}

println("signal_writer_watcher: hours=" + to_string(hours) + " ts=" + now_ts())

// staging 초기화 (없으면 생성)
if file_exists(STAGE) == false {
    try { write_file(STAGE, "# writer_watcher staging — append-only\n") } catch e {}
}

// 3리포 최근 md 스캔
let roots = [NEXUS, N6, ANIMA]
let mut total_scanned: i64 = 0
let mut total_hits: i64 = 0
let mut hit_files: [string] = []

// 주요 signal 마커 (extended regex — grep -E)
let patterns = [
    "★",
    "(진짜 특별|진짜 발견)",
    "최초",
    "NULL",
    "PEAK",
    "sweet spot",
    "pp drop",
    "× faster",
    "배 더"
]

for root in roots {
    if file_exists(root) == false { continue }
    let files = find_recent_md(root, hours)
    let mut i = 0
    while i < files.len() {
        let f = files[i]
        total_scanned = total_scanned + 1
        let mut hits: i64 = 0
        let mut j = 0
        while j < patterns.len() {
            let p = patterns[j]
            hits = hits + grep_count_in_file(f, p)
            j = j + 1
        }
        if hits > 0 {
            total_hits = total_hits + hits
            hit_files = hit_files + [f]
            // staging append (후보 형식)
            let line = "# CANDIDATE " + now_ts() + " hits=" + to_string(hits) + " <- " + f
            append_line(STAGE, line)
        }
        i = i + 1
    }
}

println("  scanned_md=" + to_string(total_scanned))
println("  files_with_signals=" + to_string(hit_files.len()))
println("  total_hits=" + to_string(total_hits))
println("  staging=" + STAGE)

// 상위 5개 샘플 출력
let mut k = 0
let show_max: i64 = 5
while k < hit_files.len() && k < show_max {
    println("  hit: " + hit_files[k])
    k = k + 1
}
