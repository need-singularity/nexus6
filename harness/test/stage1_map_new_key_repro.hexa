// stage1_map_new_key_repro.hexa
// 2026-04-14  NEXUS-6 DISC-P1-1 NDJSON 파서 blocker
// 목적: hexa stage1 인터프리터 `map["new_key"] = v` 삽입 동작 재현 + 공식 우회 검증.
//
// 기대:
//   PART A — 네이티브 `#{}` 맵 + `m[k]=v`: 현재 stage0 바이너리는 silent no-op.
//            (fix 는 self/hexa_full.hexa ef7ccc1 에 있으나 bin 재빌드 필요)
//   PART B — parallel-list 우회(`shared/blowup/lib/map_stage1_compat.hexa.inc`):
//            모든 assertion 통과.
//
// 사용:
//   HEXA_BIN=/path/to/hexa  shared/bin/hexa run shared/harness/test/stage1_map_new_key_repro.hexa
// ═══════════════════════════════════════════════════════════

// ─── parallel-list helpers (shared/blowup/lib/map_stage1_compat.hexa.inc 동본) ───
fn map_idx(ks: list, k: string) -> i64 {
    let n = len(ks)
    let mut i = 0
    while i < n {
        if to_string(ks[i]) == k { return i }
        i = i + 1
    }
    return -1
}
fn map_has(ks: list, k: string) -> bool { return map_idx(ks, k) >= 0 }
fn map_get_or(ks: list, vs: list, k: string, default_v) {
    let i = map_idx(ks, k)
    if i < 0 { return default_v }
    return vs[i]
}
fn map_set_list(ks: list, vs: list, k: string, v) -> list {
    let i = map_idx(ks, k)
    if i < 0 { return [ks + [k], vs + [v]] }
    let start = i + 1
    let end = len(vs)
    let head = vs[0..i]
    let tail = vs[start..end]
    let new_vs = head + [v] + tail
    return [ks, new_vs]
}
fn map_bump(ks: list, vs: list, k: string) -> list {
    let cur = to_int(map_get_or(ks, vs, k, 0))
    return map_set_list(ks, vs, k, cur + 1)
}

// ─── PART A: 네이티브 맵 버그 재현 ───
fn part_a() -> i64 {
    println("=== PART A: 네이티브 `#{}` + m[k]=v ===")
    // Case 1: 빈 맵 신규 키 삽입
    let mut m1 = #{}
    m1["alpha"] = 1
    let ks1 = m1.keys()
    println("case1 len(keys)=" + to_string(len(ks1)) + " (expected 1)")
    let a_case1 = 0
    if len(ks1) == 1 { let a_case1 = 1 }

    // Case 2: seeded 맵에 두 번째 키 삽입
    let mut m2 = #{"seed": 0}
    m2["beta"] = 2
    let ks2 = m2.keys()
    println("case2 len(keys)=" + to_string(len(ks2)) + " (expected 2)")

    // Case 3: 기존 키 값 update (동작할 수도 있음)
    let mut m3 = #{"k": 10}
    m3["k"] = 20
    let mut v3 = 0
    try { v3 = m3["k"] } catch e {}
    println("case3 v3=" + to_string(v3) + " (expected 20)")

    let mut bug_count = 0
    if len(ks1) != 1 { bug_count = bug_count + 1 }
    if len(ks2) != 2 { bug_count = bug_count + 1 }
    if v3 != 20 { bug_count = bug_count + 1 }
    println("PART A bug_count=" + to_string(bug_count) + "/3")
    if bug_count > 0 {
        println("PART A: BUG_REPRODUCED (fix 전)")
    } else {
        println("PART A: NATIVE_OK (fix 반영됨)")
    }
    return bug_count
}

// ─── PART B: parallel-list 우회 검증 ───
fn part_b() -> i64 {
    println("")
    println("=== PART B: parallel-list 우회 검증 ===")
    let mut ks = []
    let mut vs = []
    let domains = ["math", "phys", "math", "bio", "phys", "math", "geom", "geom", "bio"]
    let mut i = 0
    while i < len(domains) {
        let pair = map_bump(ks, vs, domains[i])
        ks = pair[0]
        vs = pair[1]
        i = i + 1
    }
    let m = to_int(map_get_or(ks, vs, "math", 0))
    let p = to_int(map_get_or(ks, vs, "phys", 0))
    let b = to_int(map_get_or(ks, vs, "bio", 0))
    let g = to_int(map_get_or(ks, vs, "geom", 0))
    let unknown = to_int(map_get_or(ks, vs, "xyz", -1))
    println("math=" + to_string(m) + " phys=" + to_string(p) + " bio=" + to_string(b) + " geom=" + to_string(g) + " unknown=" + to_string(unknown))
    let mut fail_count = 0
    if m != 3 { fail_count = fail_count + 1 }
    if p != 2 { fail_count = fail_count + 1 }
    if b != 2 { fail_count = fail_count + 1 }
    if g != 2 { fail_count = fail_count + 1 }
    if unknown != -1 { fail_count = fail_count + 1 }
    if len(ks) != 4 { fail_count = fail_count + 1 }
    println("PART B fail_count=" + to_string(fail_count) + "/6")
    if fail_count == 0 { println("PART B: ALL_PASS (우회 OK)") }
    else { println("PART B: FAIL") }
    return fail_count
}

fn main() {
    let a_bugs = part_a()
    let b_fails = part_b()
    println("")
    println("=== SUMMARY ===")
    println("{\"bug_reproduced\": " + to_string(a_bugs > 0) + ", \"bypass_works\": " + to_string(b_fails == 0) + ", \"native_bug_count\": " + to_string(a_bugs) + ", \"bypass_fail_count\": " + to_string(b_fails) + "}")
}

main()
