// ═══════════════════════════════════════════════════════════
// @allow-bare-exec — lock primitive 자기참조 (perl_timeout wrap 불가)
// lib/lock_gate.hexa — mkdir-atomic advisory lock (hexa port of lock_gate.sh)
// H-NOZOMBIE 좀비 5층 방어 Layer 2 — lock_gate.sh 대체.
//
// usage (hexa run):
//   hexa run lib/lock_gate.hexa acquire <name> [wait_s=0]
//   hexa run lib/lock_gate.hexa release <name>
//   hexa run lib/lock_gate.hexa status [<name>]
//   hexa run lib/lock_gate.hexa gc
//
// exit code 전달: stdout 마지막 라인 __LOCK_GATE_RC__ N (f-hexa-exit-sentinel).
//   .sh 엔트리 shim (lock_gate.sh) 이 파싱하여 실제 shell $? 반영.
// 정책 (sh 과 동일):
//   acquire — 성공 0 / busy 75 / usage 2
//   release — 0
//   status  — 0 (HELD/FREE/list 출력)
//   gc      — 0 (purged 출력)
// stale: age>600s (절대) OR age>5s + pid dead. age<=5s 구간은 race 보호.
// env:
//   NEXUS_LOCK_ROOT  default /tmp/nexus_locks
//   NEXUS_LOCK_STRICT=1  release 시 PID strict 검증 (same-shell 패턴만)
// hexa-only logic + exec() 시스템콜 wrapper (mkdir/rm/kill/cat/stat) — f-hexa-only-logic.
// ═══════════════════════════════════════════════════════════

let LOCK_ROOT = if env("NEXUS_LOCK_ROOT") != "" { env("NEXUS_LOCK_ROOT") } else { "/tmp/nexus_locks" }

// ─── void-safe string coercion ───
fn _lg_str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _lg_trim_str(x) -> string { return _lg_str(x).trim() }

// ─── integer parse with default ───
fn _lg_to_int0(s: string) -> i64 {
    let t = s.trim()
    if len(t) == 0 { return 0 }
    let mut v: i64 = 0
    try { v = to_int(t) } catch e { v = 0 }
    return v
}

// ─── 출력 sentinel ───
fn emit_rc(rc: i64) {
    println("__LOCK_GATE_RC__ " + to_string(rc))
}

// ─── shell single-quote escape ───
fn shq(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

// ─── 현재 unix ts ───
fn now_ts() -> i64 {
    return _lg_to_int0(_lg_trim_str(exec("date +%s")))
}

// ─── LOCK_ROOT 보장 ───
//   `mkdir -p` 는 단일 토큰만 사용 → shell metachar 0개. dir_exists() 빌트인 후행 검증 생략 (idempotent).
fn ensure_root() {
    exec("mkdir -p " + shq(LOCK_ROOT) + " 2>/dev/null")
}

// ─── lock 경로 ───
fn lock_path(name: string) -> string { return LOCK_ROOT + "/" + name + ".lock" }

// ─── mkdir-atomic 시도 (성공=획득) ───
//   metachar-free 패턴 (2026-04-19 fix):
//     1. dir_exists() 빠른 경합 감지 — 이미 존재하면 즉시 false (실패)
//     2. `mkdir 'X' 2>/dev/null` — OS-atomic, 동시 호출 시 한 명만 성공
//     3. dir_exists() 재확인 — false 면 mkdir 자체가 실패 (권한 등)
//     4. unique 토큰을 lock/.attempt 에 write/read-back — TOCTOU race 결정
//        (동시 winner 가 둘 이상이면 마지막 writer 만 토큰 일치)
//   POSIX write(2) 4KB 까지 atomic — 작은 토큰은 race-safe.
fn mkdir_atomic(lock: string) -> bool {
    if dir_exists(lock) > 0 { return false }
    exec("mkdir " + shq(lock) + " 2>/dev/null")
    if dir_exists(lock) <= 0 { return false }
    // 고유 토큰 = ts(ns) + ppid (충돌 가능성 무시)
    let ts_ns = _lg_trim_str(exec("date +%s%N"))
    let ppid = _lg_trim_str(exec("echo $PPID"))
    let token = ts_ns + "_" + ppid
    let attempt = lock + "/.attempt"
    exec("printf %s " + shq(token) + " > " + shq(attempt) + " 2>/dev/null")
    let read_back = _lg_trim_str(exec("cat " + shq(attempt) + " 2>/dev/null"))
    return read_back == token
}

// ─── lock 디렉토리 존재 확인 ───
//   dir_exists() 빌트인 — i64 반환 (1=exists, 0=absent). metachar 0.
fn lock_dir_exists(lock: string) -> bool {
    return dir_exists(lock) > 0
}

// ─── lock 파일 존재 확인 ───
//   file_exists() 빌트인 — bool 반환. metachar 0.
fn lock_file_exists(lock: string, name: string) -> bool {
    return file_exists(lock + "/" + name)
}

// ─── read small file ───
fn read_small(path: string) -> string {
    return _lg_trim_str(exec("cat " + shq(path) + " 2>/dev/null"))
}

// ─── PID 살아있나 ───
//   `ps -p PID -o pid=` — 살아있으면 PID stdout, 죽었으면 빈 출력. metachar 0
//   (기존 `kill -0 X && echo Y || echo N` 의 metachar 패턴 제거).
fn pid_alive(pid: string) -> bool {
    if len(pid) == 0 { return false }
    let out = _lg_trim_str(exec("ps -p " + shq(pid) + " -o pid= 2>/dev/null"))
    return len(out) > 0
}

// ─── lock 삭제 ───
fn lock_rm(lock: string) {
    exec("rm -rf " + shq(lock) + " 2>/dev/null")
}

// ─── pid/ts 기록 ───
fn lock_write_meta(lock: string) {
    // 부모 쉘 PID — hexa exec 는 매번 새 subshell 이라 $$ 대신 ppid 사용
    // 단, .sh 엔트리 쉘이 부모 → $$ 가 stable 하지 않음. 대신 `ps -p $$ -o ppid=` 로 상위 PID.
    // 더 단순하게: hexa process 의 부모 PID (PPID) 를 사용.
    let pid = _lg_trim_str(exec("echo $PPID"))
    let ts = _lg_trim_str(exec("date +%s"))
    exec("echo " + shq(pid) + " > " + shq(lock + "/pid") + " 2>/dev/null")
    exec("echo " + shq(ts) + " > " + shq(lock + "/ts") + " 2>/dev/null")
}

// ─── 절대값 ───
fn abs_i(x: i64) -> i64 { if x < 0 { return 0 - x } return x }

// ─── acquire: 성공 0 / busy 75 / usage 2 ───
fn do_acquire(name: string, wait_s: i64) -> i64 {
    if len(name) == 0 {
        eprintln("usage: lock_gate acquire <name> [wait_s]")
        return 2
    }
    ensure_root()
    let lock = lock_path(name)
    let start = now_ts()
    let deadline = start + wait_s
    // bounded loop — 최대 (wait_s + 5) 초 동안 polling. 절대 상한: 600s (safety)
    let max_iter: i64 = if wait_s > 0 { (wait_s * 2) + 20 } else { 4 }
    let mut iter: i64 = 0
    while iter < max_iter {
        iter = iter + 1
        if mkdir_atomic(lock) {
            lock_write_meta(lock)
            return 0
        }
        // stale check
        if lock_file_exists(lock, "pid") {
            let oldpid = read_small(lock + "/pid")
            let oldts_s = read_small(lock + "/ts")
            // cat-cat split race — release 가 사이 rm -rf 한 경우 빈값
            if len(oldpid) == 0 || len(oldts_s) == 0 {
                exec("sleep 0.1")
                continue
            }
            let oldts = _lg_to_int0(oldts_s)
            let age = now_ts() - oldts
            let mut stale: i64 = 0
            if age > 600 { stale = 1 }
            else if age > 5 && !pid_alive(oldpid) { stale = 1 }
            if stale == 1 {
                lock_rm(lock)
                continue
            }
        }
        if now_ts() >= deadline { return 75 }
        exec("sleep 0.5")
    }
    // safety — bounded loop 한계 도달 (never expected)
    return 75
}

// ─── release: 항상 0 ───
fn do_release(name: string) -> i64 {
    if len(name) == 0 {
        eprintln("usage: lock_gate release <name>")
        return 2
    }
    let lock = lock_path(name)
    if env("NEXUS_LOCK_STRICT") == "1" {
        // metachar-free strict release (2026-04-19):
        //   1. dir_exists() / file_exists() 로 사전 검증
        //   2. 저장된 pid 와 현재 ppid 일치 확인 — 일치 시만 rm
        //   `kill -0` 의 `&&|;|$(` 메타 패턴 제거.
        if dir_exists(lock) <= 0 { return 0 }
        if !file_exists(lock + "/pid") {
            // pid 파일 부재 — 메타 미작성 lock. 안전상 보존.
            return 0
        }
        let stored_pid = _lg_trim_str(exec("cat " + shq(lock + "/pid") + " 2>/dev/null"))
        let cur_ppid = _lg_trim_str(exec("echo $PPID"))
        if stored_pid == cur_ppid { lock_rm(lock) }
    } else {
        lock_rm(lock)
    }
    return 0
}

// ─── status ───
fn do_status(name: string) -> i64 {
    if len(name) > 0 {
        let lock = lock_path(name)
        if lock_dir_exists(lock) {
            let pid = read_small(lock + "/pid")
            let ts = read_small(lock + "/ts")
            println("HELD pid=" + pid + " ts=" + ts)
        } else {
            println("FREE")
        }
    } else {
        // metachar-free listing (2026-04-19): list_dir() 빌트인 + .lock suffix 제거 hexa-side.
        let entries = list_dir(LOCK_ROOT)
        let mut lines = ""
        let mut li: i64 = 0
        let nE = len(entries)
        while li < nE {
            let it = _lg_trim_str(entries[li])
            li = li + 1
            if len(it) == 0 { continue }
            let trimmed = if it.ends_with(".lock") { it.substring(0, len(it) - 5) } else { it }
            if len(lines) == 0 { lines = trimmed } else { lines = lines + "\n" + trimmed }
        }
        if len(lines) > 0 { println(lines) }
    }
    return 0
}

// ─── gc: stale 청소 (600s+ OR dead pid) ───
//   list_dir() 빌트인 사용 — exec ls 제거 (metachar 0이지만 일관성).
fn do_gc() -> i64 {
    ensure_root()
    let items = list_dir(LOCK_ROOT)
    let n = len(items)
    let mut i: i64 = 0
    while i < n {
        let item = _lg_trim_str(items[i])
        i = i + 1
        if len(item) == 0 { continue }
        if !item.ends_with(".lock") { continue }
        let lock = LOCK_ROOT + "/" + item
        if !lock_dir_exists(lock) { continue }
        let oldpid = read_small(lock + "/pid")
        let oldts_s = read_small(lock + "/ts")
        let oldts = _lg_to_int0(oldts_s)
        let age = now_ts() - oldts
        if age > 600 || !pid_alive(oldpid) {
            lock_rm(lock)
            println("purged: " + lock)
        }
    }
    return 0
}

// ─── main ───
// argv 정규화: Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
// .hexa 앵커 스캔 → [hexa, script, user...] 로 재구성 (argv.hexa.inc 패턴, cc2ec688)
let _raw_argv = args()
let mut _script_idx: i64 = -1
let mut _scan_i: i64 = 0
while _scan_i < _raw_argv.len() {
    if to_string(_raw_argv[_scan_i]).ends_with(".hexa") { _script_idx = _scan_i; break }
    _scan_i = _scan_i + 1
}
let _user_start = if _script_idx >= 0 { _script_idx + 1 } else {
    if _raw_argv.len() >= 3 && (to_string(_raw_argv[1]) == "run" || to_string(_raw_argv[1]) == "eval") { 3 } else { 2 }
}
let _script_token = if _script_idx >= 0 { _raw_argv[_script_idx] } else { "" }
let mut argv = [_raw_argv[0], _script_token]
let mut _ua_i = _user_start
while _ua_i < _raw_argv.len() {
    argv = argv + [_raw_argv[_ua_i]]
    _ua_i = _ua_i + 1
}
let nargs = len(argv)
// argv[0]=hexa argv[1]=script argv[2]=cmd argv[3]=name argv[4]=wait_s
if nargs < 3 {
    eprintln("usage: lock_gate.hexa {acquire|release|status|gc} [name] [wait_s]")
    emit_rc(2)
    exit(2)
}

let cmd = _lg_str(argv[2])
let name = if nargs > 3 { _lg_str(argv[3]) } else { "" }
let wait_s = if nargs > 4 { _lg_to_int0(_lg_str(argv[4])) } else { 0 }

let mut rc: i64 = 2
if cmd == "acquire" {
    rc = do_acquire(name, wait_s)
} else if cmd == "release" {
    rc = do_release(name)
} else if cmd == "status" {
    rc = do_status(name)
} else if cmd == "gc" {
    rc = do_gc()
} else {
    eprintln("usage: lock_gate.hexa {acquire|release|status|gc} [name] [wait_s]")
    rc = 2
}

emit_rc(rc)
exit(rc)
