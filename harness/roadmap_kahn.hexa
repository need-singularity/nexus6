    let mut path: string = ""
    let mut p_arg: i64 = DEFAULT_PARALLELISM
    let mut json_flag: bool = false
    let mut k: i64 = 1
    while k < a.len() {
        let arg = _str(a[k])
        if arg.starts_with("--p=") {
            let s = arg.substring(4, arg.len())
            let v = _to_int0(s)
            if v > 0 { p_arg = v }
        } else if arg == "--json" {
            json_flag = true
        } else if arg.starts_with("--") {
            eprintln("WARN: unknown flag: " + arg)
        } else {
            if path == "" { path = arg }
        }
        k = k + 1
    }

    if path == "" { path = ROADMAPS_DIR + "/example.json" }

    if first == "verify" {
        let rc = cmd_verify(path, p_arg)
        exit(rc)
    } else if first == "suggest" {
        let rc = cmd_suggest(path, p_arg, json_flag)
        exit(rc)
    } else if first == "levels" {
        let rc = cmd_levels(path)
        exit(rc)
    } else {
        eprintln("REJECT: unknown subcommand: " + first)
        usage()
    }
}

main()
