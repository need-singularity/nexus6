// sync_cli_spec.hexa — run.hexa cmd_* ↔ nexus_cli_spec.json drift 검출
// 사용:
//   nexus sync          drift 보고만 (read-only)
//   nexus sync --apply  spec 에 누락된 cmd_* 자동 추가 (stub 엔트리)
// 목적: run.hexa 새 cmd_* 추가 시 매번 spec 수동 갱신 불필요. 자기진화.

let NEXUS = env("NEXUS")
let ROOT = if NEXUS.len() > 0 { NEXUS } else { env("HOME") + "/Dev/nexus" }
let APPLY = exec("echo \"$1\"").trim() == "--apply"

fn run(cmd: str) -> str {
    return exec("cd " + ROOT + " && " + cmd).trim()
}

// run.hexa + nexus_cli.hexa 둘 다 스캔 (양쪽 모두 cmd_* 등록 가능)
let run_cmds_raw = run("(grep -oE 'fn cmd_[a-z_]+' run.hexa shared/engine/nexus_cli.hexa | sed 's/.*fn cmd_//') | sort -u")
let spec_cmds_raw = run("jq -r '.subcommands|keys[]' shared/engine/nexus_cli_spec.json | sort")

fn _norm(s: str) -> str { return s.replace("_", "-") }

fn _to_set(blob: str) -> [str] {
    let lines = blob.split("\n")
    let mut out: [str] = []
    let mut i = 0
    while i < len(lines) {
        let s = lines[i].trim()
        if s.len() > 0 { out = out + [s] }
        i = i + 1
    }
    return out
}

fn _has(arr: [str], target: str) -> bool {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == target { return true }
        i = i + 1
    }
    return false
}

let run_set = _to_set(run_cmds_raw)
let spec_set = _to_set(spec_cmds_raw)

// META subcommands (run.hexa 내부 dispatcher 전용 — spec 등록 면제)
let META = ["help", "version", "status", "self-check", "self_check"]

println("nexus-cli spec drift report")
println("  run.hexa cmd_*  : " + to_string(len(run_set)))
println("  spec subcommands: " + to_string(len(spec_set)))
println("")

let mut missing_in_spec: [str] = []
let mut i = 0
while i < len(run_set) {
    let cmd = _norm(run_set[i])
    if !_has(META, cmd) && !_has(META, run_set[i]) && !_has(spec_set, cmd) {
        missing_in_spec = missing_in_spec + [cmd]
    }
    i = i + 1
}

let mut missing_in_runhexa: [str] = []
let mut j = 0
while j < len(spec_set) {
    let cmd = spec_set[j]
    let cmd_alt = cmd.replace("-", "_")
    if !_has(run_set, cmd) && !_has(run_set, cmd_alt) {
        missing_in_runhexa = missing_in_runhexa + [cmd]
    }
    j = j + 1
}

println("missing in spec (run.hexa 에는 있음): " + to_string(len(missing_in_spec)))
let mut k = 0
while k < len(missing_in_spec) { println("  + " + missing_in_spec[k]); k = k + 1 }

println("missing in run.hexa (spec 에만 있음, delegated 가능): " + to_string(len(missing_in_runhexa)))
let mut m = 0
while m < len(missing_in_runhexa) { println("  - " + missing_in_runhexa[m]); m = m + 1 }

if APPLY && len(missing_in_spec) > 0 {
    println("")
    println("--apply: spec 에 stub 추가 중...")
    let mut n = 0
    while n < len(missing_in_spec) {
        let cmd = missing_in_spec[n]
        let stub = "{\"desc\":\"auto-stub from run.hexa cmd_" + cmd.replace("-", "_") + "\",\"usage\":\"nexus-cli " + cmd + " ...\",\"delegates_to\":\"run.hexa cmd_" + cmd.replace("-", "_") + "\",\"gate\":\"cmd_gate.hexa\",\"output_json\":{}}"
        let cmd_jq = "jq --arg k '" + cmd + "' --argjson v '" + stub + "' '.subcommands[$k] = $v' shared/engine/nexus_cli_spec.json > /tmp/_spec_new.json && mv /tmp/_spec_new.json shared/engine/nexus_cli_spec.json"
        let r = run(cmd_jq)
        println("  + added: " + cmd)
        n = n + 1
    }
}

if len(missing_in_spec) == 0 && len(missing_in_runhexa) == 0 {
    println("")
    println("OK: drift = 0")
    exit(0)
}
exit(0)
