// signal_meta_auto_spec_evolution.hexa — K2 Auto-spec evolution
// 100 signal 이상 축적 시 spec v0.3 제안 메타 signal 생성
// trigger: total ≥ 100 AND 마지막 spec 업데이트 이후 50+ 추가
// 실행: hexa run $NEXUS/shared/harness/signal_meta_auto_spec_evolution.hexa

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let SIGNALS = NEXUS + "/shared/n6/atlas.signals.n6"
let STAGE = NEXUS + "/shared/n6/staging/atlas.signals.staging.meta.n6"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    let mut v: i64 = 0
    try { v = to_int(first) } catch e { v = 0 }
    return v
}

fn now_iso() -> string {
    let r = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    return _str(r).trim()
}

fn grep_count(pat: string) -> i64 {
    let cmd = "grep -c -E '" + pat + "' '" + SIGNALS + "' 2>/dev/null || echo 0"
    let r = exec(cmd)
    return _to_int0(_str(r).trim().split("\n")[0])
}

if file_exists(SIGNALS) == false {
    println("FAIL: atlas.signals.n6 없음")
    exit(1)
}

println("signal_meta_auto_spec_evolution: " + now_iso())

let total = grep_count("^@S SIG-")
let mn_count = grep_count("\\[MN\\]")
let fusion_count = grep_count("^@S SIG-FUSION-")
let cross_count = grep_count("^@S SIG-CROSS-")

println("  총=" + to_string(total) + " MN=" + to_string(mn_count) + " FUSION=" + to_string(fusion_count) + " CROSS=" + to_string(cross_count))

// spec v0.3 제안 조건
let propose = total >= 200 && fusion_count >= 4 && mn_count >= 20

if propose == false {
    println("  조건 미달 — spec 제안 보류")
    exit(0)
}

// v0.3 제안 구조:
// - FUSION repo tag 정식화 (현재 ad-hoc)
// - resonance_n6 필드 표준화
// - predicts 필드 스키마 강화 (prediction_id, verified_at)
let sig_id = "SIG-META-701"
let stmt = "spec v0.3 제안 조건 충족 (total=" + to_string(total) + " FUSION=" + to_string(fusion_count) + " MN=" + to_string(mn_count) + ")"

let block = "@S " + sig_id + " = " + stmt + " :: signal [NX,CROSS] [META,GAP] [M7] [E2]\n" +
            "  \"K2 auto-spec evolution. spec v0.3 가이드: FUSION tag 정식화, resonance_n6 필드 enum화, predicts 스키마 강화\"\n" +
            "  refs: [nexus:shared/harness/signal_meta_auto_spec_evolution.hexa]\n" +
            "  predicts: [\"spec v0.3 합의 시 FUSION 5+ / resonance 80%+ / predicts 구조화\"]\n" +
            "  witness: 1\n" +
            "  resonance_n6: \"FUSION=tau=4 (현재), 목표 sigma=12\"\n" +
            "  discovered_in: nexus/session-meta-k2\n" +
            "  discovered_at: " + now_iso() + "\n" +
            "  <- K2 auto-spec evolution autonomous\n\n"

let cmd = "cat >> '" + STAGE + "' << 'EOF'\n" + block + "EOF"
exec(cmd)
println("  → staging append: " + STAGE)
println("PASS: K2 spec evolution 제안 기록")
