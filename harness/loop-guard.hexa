// loop-guard.hexa — 범용 불일치 탐지/수정 엔진 v3
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
// 모든 NEXUS-6 프로젝트에서 동작. 프로젝트별 loop-rules.json 로 확장.
//
// 용법: hexa loop-guard.hexa [--fix] [--commit] [--push] [--all]
//   --fix    : 불일치 자동 수정
//   --commit : 수정 후 git commit
//   --push   : commit 후 git push
//   --all    : 전 프로젝트 순회 (whitelisted_projects 기준)
//
// 점검 계층:
//   L1. CLAUDE.md 헤더 카운트 (종/편/개/건 패턴)
//   L2. _registry.json _total vs 배열, 고아/유령
//   L3. README.md 통계 블록 + 제품 테이블
//   L4. JSON _meta.total_* vs 실제 배열 길이
//   L5. loop-rules.json 프로젝트별 규칙 (파일수/LOC/인라인숫자)
//   L6. 수렴 JSON

let ARGS = args()
let DO_FIX = ARGS.contains("--fix") || ARGS.contains("--commit") || ARGS.contains("--push")
let DO_COMMIT = ARGS.contains("--commit") || ARGS.contains("--push")
let DO_PUSH = ARGS.contains("--push")
let DO_ALL = ARGS.contains("--all")

let HOME = env("HOME")
let miss_count = 0
let fix_count = 0

fn log_miss(msg: string) { println("[MISS] " + msg); miss_count = miss_count + 1 }
fn log_ok(msg: string)    { println("[OK]    " + msg) }
fn log_fix(msg: string)   { println("[FIX]   " + msg); fix_count = fix_count + 1 }
fn log_info(msg: string)  { println("[INFO]  " + msg) }

fn sh(cmd: string) -> string { return to_string(exec(cmd + "")).trim() }  // @allow-bare-exec
fn sh_int(cmd: string) -> int {
    let r = sh(cmd)
    if len(r) == 0 { return 0 }
    return to_int(r)
}

// ---- L1. CLAUDE.md 헤더 카운트 ----

fn check_claude_headers(root: string) {
    println("=== L1. CLAUDE.md 헤더 카운트 ===")
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = root
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at loop-guard.hexa:check_claude_headers. Escalate to user for hexa-native replacement.")
    let result = ""
    if len(result) == 0 { return }
    let lines = result.split("\n")
    for line in lines {
        if len(line) == 0 { continue }
        let p = line.split("|")
        if p[0] == "DRIFT" {
            log_miss(p[1] + "/CLAUDE.md " + p[2] + " != ." + p[4] + "=" + p[3])
            if DO_FIX {
                exec("sed -i '' '1s/" + p[2] + "/" + p[3] + "/' '" + p[5] + "'")  // @allow-bare-exec
                log_fix(p[1] + "/CLAUDE.md -> " + p[3])
            }
        } else if p[0] == "OK" { log_ok(p[1] + "/CLAUDE.md=" + p[2]) }
    }
}

// ---- L2. _registry.json 고아/유령 + _total ----

fn check_registries(root: string) {
    println("")
    println("=== L2. _registry.json 정합 ===")
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = root
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at loop-guard.hexa:check_registries. Escalate to user for hexa-native replacement.")
    let result = ""
    if len(result) == 0 { log_ok("레지스트리 없음"); return }
    let lines = result.split("\n")
    for line in lines {
        if len(line) == 0 { continue }
        let p = line.split("|")
        if p[0] == "ORPHAN" { log_miss(p[1] + " 고아: " + p[2]) }
        else if p[0] == "GHOST" { log_miss(p[1] + " 유령: " + p[2]) }
        else if p[0] == "TOTAL" { log_miss(p[1] + " _total=" + p[2] + " != 실제=" + p[3]) }
        else if p[0] == "OK" { log_ok(p[1] + "=" + p[2]) }
        else if p[0] == "META" { log_info(p[1] + " " + p[2]) }
    }
}

// ---- L3. README 통계/제품 테이블 ----

fn check_readme(root: string) {
    let readme = root + "/README.md"
    if file_exists(readme) == false { return }
    println("")
    println("=== L3. README.md 통계 ===")
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = root
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at loop-guard.hexa:check_readme. Escalate to user for hexa-native replacement.")
    let result = ""
    if result == "OK" { log_ok("README 통계 정합") }
    else {
        let lines = result.split("\n")
        for line in lines {
            if len(line) == 0 { continue }
            let p = line.split("|")
            if len(p) >= 5 {
                log_miss("README " + p[4] + ": " + p[2] + "->" + p[3])
                if DO_FIX { log_fix("README " + p[4] + " -> " + p[3]) }
            }
        }
    }
}

// ---- L4. JSON _meta vs 배열 길이 범용 ----

fn check_json_meta(root: string) {
    println("")
    println("=== L4. JSON _meta 정합 ===")
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = root
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at loop-guard.hexa:check_json_meta. Escalate to user for hexa-native replacement.")
    let result = ""
    if len(result) == 0 { log_ok("JSON meta 대상 없음"); return }
    let lines = result.split("\n")
    for line in lines {
        if len(line) == 0 { continue }
        let p = line.split("|")
        if p[0] == "DRIFT" {
            log_miss(p[1] + " " + p[2] + " != " + p[3])
            if DO_FIX {
                // _meta.total_X를 실제 배열 길이로 수정
                let file_path = root + "/" + p[1]
                let meta_info = p[2]  // e.g. "total_laws=2516"
                let actual_info = p[3]  // e.g. "실제 laws[]=2507"
                // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
                let _ = file_path
                eprintln("R37/AN13/L3-PY: python3 invocation blocked at loop-guard.hexa:check_json_meta (fix). Escalate to user for hexa-native replacement.")
                log_fix(p[1] + " " + meta_info + " -> " + actual_info)
            }
        } else if p[0] == "OK" { log_ok(p[1] + " " + p[2]) }
    }
}

// ---- L5. loop-rules.json 프로젝트별 규칙 ----
// 형식: { "rules": [ {"type":"file_count","doc":"README.md","pattern":"\\d+ lenses","dir":"shared/lenses","glob":"*.toml"}, ... ] }

fn check_project_rules(root: string) {
    let rules_path = root + "/loop-rules.json"
    if file_exists(rules_path) == false { return }
    println("")
    println("=== L5. 프로젝트별 규칙 (loop-rules.json) ===")
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = root
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at loop-guard.hexa:check_project_rules. Escalate to user for hexa-native replacement.")
    let result = ""
    if len(result) == 0 { return }
    let lines = result.split("\n")
    for line in lines {
        if len(line) == 0 { continue }
        let p = line.split("|")
        if p[0] == "DRIFT" {
            log_miss(p[5] + ": " + p[3] + " -> " + p[4])
        } else if p[0] == "OK" {
            log_ok(p[1] + "=" + p[2])
        } else if p[0] == "ERR" {
            log_info("규칙 오류: " + p[1] + " " + p[2])
        }
    }
}

// ---- L6. 수렴 JSON ----

fn check_convergence(root: string, project: string) {
    let conv = root + "/shared/convergence/" + project + ".json"
    if file_exists(conv) == false { return }
    println("")
    println("=== L6. 수렴 JSON ===")
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = conv
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at loop-guard.hexa:check_convergence. Escalate to user for hexa-native replacement.")
    let info = ""
    log_ok("수렴: " + info)
}

// ---- 단일 프로젝트 실행 ----

fn run_project(root: string) {
    let project = sh("basename '" + root + "'")
    println("========================================")
    println("loop-guard v3 -- " + project)
    println("========================================")
    println("")

    check_claude_headers(root)
    check_registries(root)
    check_readme(root)
    check_json_meta(root)
    check_project_rules(root)
    check_convergence(root, project)

    println("")
    println("--- " + project + " 결과: 불일치=" + to_string(miss_count) + " 수정=" + to_string(fix_count) + " ---")
    println("")
}

// ---- 메인 ----
// stage0 early-return bug workaround: positive-gate branch instead of
// `if X { println; return }` pattern to avoid HexaVal pointer leak +
// non-terminating return on subsequent println() calls.
//
// 2026-04-13: atomic mkdir lockdir 추가 — 동시 실행 방지 (Load Avg 폭주 차단).

let LG_LOCKDIR = "/tmp/nexus-hook-loop-guard.lockdir"
let LG_STALE_SEC = 600

// atomic mkdir 잠금 — shell 측 결정, hexa if 최소화.
// 반환 "ok" = 단독 소유, 그 외 = 중복, 즉시 종료.
fn lg_acquire() -> string {
    let mut got = "no"
    let r1 = to_string(exec("mkdir '" + LG_LOCKDIR + "' 2>/dev/null && echo ok || echo no")).trim()  // @allow-bare-exec
    if r1 == "ok" {
        exec("echo $PPID > '" + LG_LOCKDIR + "/pid'")  // @allow-bare-exec
        got = "ok"
    }
    if r1 == "no" {
        let cmd = "PID=$(cat '" + LG_LOCKDIR + "/pid' 2>/dev/null); MTIME=$(stat -c %Y '" + LG_LOCKDIR + "' 2>/dev/null || stat -f %m '" + LG_LOCKDIR + "' 2>/dev/null || echo 0); AGE=$(( $(date +%s) - MTIME )); STALE=" + to_string(LG_STALE_SEC) + "; if [ -z \"$PID\" ] && [ $AGE -lt 5 ]; then echo skip; elif [ -n \"$PID\" ] && kill -0 $PID 2>/dev/null && [ $AGE -lt $STALE ]; then echo skip; else rm -rf '" + LG_LOCKDIR + "' && mkdir '" + LG_LOCKDIR + "' 2>/dev/null && echo $PPID > '" + LG_LOCKDIR + "/pid' && echo ok || echo skip; fi"
        let r2 = to_string(exec(cmd)).trim()  // @allow-bare-exec
        if r2 == "ok" { got = "ok" }
    }
    return got
}

fn run_guard() {
    if DO_ALL {
        // 전 프로젝트 순회
        // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
        eprintln("R37/AN13/L3-PY: python3 invocation blocked at loop-guard.hexa:run_guard[--all]. Escalate to user for hexa-native replacement.")
        let projects_str = ""
        let have_projects = len(projects_str) > 0
        if have_projects == false {
            println("프로젝트 목록 없음")
        }
        if have_projects {
            let projects = projects_str.split("\n")
            for proj_path in projects {
                if len(proj_path) == 0 { continue }
                run_project(proj_path)
            }
        }
    } else {
        let root = sh("git rev-parse --show-toplevel || pwd")
        run_project(root)
    }

    // ---- L7. 로드맵 phase 자동 승격 ----
    println("=== L7. 로드맵 phase gate_promote ===")
    let roadmap_harness = HOME + "/Dev/nexus/shared/harness/roadmap.hexa"
    let hexa_bin = HOME + "/Dev/nexus/shared/bin/hexa"
    if file_exists(roadmap_harness) {
        // gate_promote: task 전수 done인 phase를 complete로 승격
        // @allow-bare-interp
        let gp_out = sh(hexa_bin + " run " + roadmap_harness + " auto --project " + sh("basename $(git rev-parse --show-toplevel || echo nexus)") + " --force 2>&1 || true")
        if gp_out.contains("PROMOTE") {
            log_fix("roadmap phase 자동 승격: " + gp_out.split("\n")[0])
        } else if gp_out.contains("EXTEND_OK") {
            log_fix("roadmap 창발 extend: " + gp_out.split("\n")[0])
        } else if gp_out.contains("EXHAUSTED") {
            log_miss("roadmap 소진 — extend 실패")
        } else {
            log_ok("roadmap 정상")
        }
    }

    println("")
    println("════════════════════════════════════════")
    println("전체 합계: 불일치=" + to_string(miss_count) + " 수정=" + to_string(fix_count))

    if miss_count == 0 {
        println("결과: 전체 정합")
    } else if DO_FIX && fix_count > 0 {
        println("결과: " + to_string(fix_count) + "건 자동 수정")
        if DO_COMMIT {
            let root = sh("git rev-parse --show-toplevel || pwd")
            exec("cd '" + root + "' && git add -A && git commit -m 'fix(loop-guard): v3 정합 자동 수정\n\nCo-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>'")  // @allow-bare-exec
            println("[COMMIT] 완료")
            if DO_PUSH { exec("cd '" + root + "' && git push"); println("[PUSH] 완료") }  // @allow-bare-exec
        }
    } else {
        println("결과: " + to_string(miss_count) + "건 미수정 (--fix)")
    }
}

// ---- Seed-freeze bail (2026-04-19) ----------------------------
// feedback_seed_freeze.md — full guard disabled while bootstrap
// binaries (build/hexa_stage0, self/native/hexa_v2, self/native/hexa_cc.c)
// are under freeze. loop-guard's auto-fix + git add -A path can sweep
// unrelated post-fix edits on these bootstrap files back into the tree
// during concurrent agent work. Gate:
//   (a) env SEED_FREEZE=1, OR
//   (b) marker file <repo>/.seed_freeze present
// Either disables all L1-L7 checks (report-only would still be OK, but
// --fix + --commit are the risky paths; cleanest is full bail).
// Override: set ALLOW_LOOP_GUARD=1 to force a one-shot run despite freeze.
fn seed_freeze_active() -> bool {
    if env("ALLOW_LOOP_GUARD") == "1" { return false }
    if env("SEED_FREEZE") == "1" { return true }
    let root = sh("git rev-parse --show-toplevel 2>/dev/null || pwd")
    if file_exists(root + "/.seed_freeze") { return true }
    return false
}

fn main() {
    if seed_freeze_active() {
        println("[loop-guard] seed-freeze active — skipping (set ALLOW_LOOP_GUARD=1 to override)")
        return
    }
    let got = lg_acquire()
    if got == "ok" {
        run_guard()
    }
}

main()
