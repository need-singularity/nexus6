fn plan_pod_count() -> int {
    return plan_get_int(PLAN, "['pods'].__len__()")
}

fn plan_pod_field(idx: int, field: string) -> string {
    return plan_get_str(PLAN, "['pods'][" + to_string(idx) + "]['" + field + "']")
}

fn plan_pod_int(idx: int, field: string) -> int {
    return plan_get_int(PLAN, "['pods'][" + to_string(idx) + "]['" + field + "']")
}

// ── RunPod GraphQL query ────────────────────────────────────────────────────
@convergence(state="ossified", id="RUNPOD_GRAPHQL_RUNTIME_PORTS", value="pod.ports=String('22/tcp'), runtime.ports=[{ip,publicPort,privatePort}]. SSH info from runtime{ports{...}} only", ossified_at="2026-04-16")
@convergence(state="ossified", id="RUNPOD_POD_FLEET_VARIANCE", value="Same stack, 31% step/min variance across H100 SXM pods. Tag measurements with pod_id. Same-pod A/B preferred", ossified_at="2026-04-16")
@convergence(state="ossified", id="RUNPOD_POD_LIST_FRESHNESS_GATE", value="Any 'running'/'active' claim must cite runpodctl pod list output ≤5min old. Incident 2026-04-16: anima_train.json had ALM P4-4 in_progress for pod tubq10zkct0t8f absent from pod list ≥12h. Every health tick MUST query live GraphQL (this fn) before trusting state files", ossified_at="2026-04-16")
fn query_pods(api_key: string) -> string {
    if len(api_key) == 0 { return "" }
    let q = "{\\\"query\\\":\\\"query { myself { pods { id name desiredStatus costPerHr machine { gpuDisplayName } runtime { uptimeInSeconds gpus { gpuUtilPerc } ports { ip publicPort privatePort } } } } }\\\"}"
    let cmd = "curl -s -H 'Authorization: Bearer " + api_key + "' -H 'Content-Type: application/json' -X POST -d \"" + q + "\" https://api.runpod.io/graphql"
    return sh(cmd)
}

let TMP_RESP = "/tmp/h100_guard_resp.json"
let TMP_IDLE = "/tmp/h100_idle_consecutive.json"

fn stash_resp(resp: string) {
    write_file(TMP_RESP, resp)
}

fn count_running_pods(resp: string) -> int {
    if len(resp) == 0 { return 0 }
    stash_resp(resp)
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at h100_idle_guard.hexa:count_running_pods. Escalate to user for hexa-native replacement.")
    return 0
}

fn total_cost_per_hr(resp: string) -> string {
    if len(resp) == 0 { return "0.00" }
    stash_resp(resp)
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at h100_idle_guard.hexa:total_cost_per_hr. Escalate to user for hexa-native replacement.")
