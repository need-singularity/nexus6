// @enforce-sandbox  — H-ENFORCE-SANDBOX: long-running guard, GraphQL + periodic polling
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
// h100_idle_guard.hexa — ANIMA + HEXA-LANG H100 유휴 가드 (4-pod enforcement)
//
// ═══════════════════════════════════════════════════════════════════════════
// PURPOSE
//   모든 가동 중인 H100 pod을 감시해 유휴 상태를 방지한다.
//   - RunPod GraphQL로 가동 pod 목록 + 상태 조회
//   - GPU util 실시간 체크: runpodctl + nvidia-smi SSH (< 5% = idle)
//   - 각 slot의 heartbeat 파일 age 검사 (shared/state/h100_heartbeat/<slot>.json)
//   - idle_policy.action_sequence 단계적 실행 (강화):
//       3분  → warn (alert jsonl 기록)
//       5분  → dispatch_fallback (큐 다음 작업 지시)
//       8분  → HARD KILL (runpodctl pod stop — 실제 실행, alert 아님)
//   - GPU util < 5% 감지 시 즉시 경고, 2회 연속 시 HARD KILL
//   - 예산 모니터링 (일일/월간 cap)
//   - 사람이 읽는 상태표 출력
//
// ENFORCED BY
//   - shared/config/loop/anima.json every_cycle[] → h100_idle_check
//   - ScheduleWakeup (session-bound, 1200초 간격)
//   - pre-commit hook (선택 — 과다 pod 기동 방지)
//
// SSOT
//   shared/config/h100_plan.json                 ← 플랜 + 정책
//   shared/state/h100_heartbeat/<slot>.json      ← pod이 주기 기록
//   shared/harness/h100_alerts.jsonl             ← 가드 이벤트 로그
//   ~/.runpod/config.toml                        ← API key
//
// USAGE
//   hexa shared/harness/h100_idle_guard.hexa                # 기본 check
//   hexa shared/harness/h100_idle_guard.hexa --dry          # 종료 없이 시뮬
//   hexa shared/harness/h100_idle_guard.hexa --status       # 상태표만
//   hexa shared/harness/h100_idle_guard.hexa --plan         # 3-pod 플랜표
// ═══════════════════════════════════════════════════════════════════════════

import "safe_hexa_enforce.hexa"

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let PLAN = NEXUS + "/shared/config/h100_plan.json"
let HB_DIR = NEXUS + "/shared/state/h100_heartbeat"
let ALERTS = NEXUS + "/shared/harness/h100_alerts.jsonl"
let STATE = NEXUS + "/shared/harness/h100_state.json"
let RUNPOD_CFG = HOME + "/.runpod/config.toml"

fn sh(cmd: string) -> string {
    return to_string(exec(cmd + " 2>/dev/null")).trim()  // @allow-bare-exec
}

fn sh_stderr(cmd: string) -> string {
    return to_string(exec(cmd + " 2>&1")).trim()  // @allow-bare-exec
}

fn read_api_key() -> string {
    if file_exists(RUNPOD_CFG) == false { return "" }
    let raw = sh("grep -E '^apikey' '" + RUNPOD_CFG + "' | head -1 | sed \"s/.*'\\(.*\\)'.*/\\1/\"")
    return raw
}

fn file_mtime(path: string) -> int {
    let s = sh("stat -f '%m' '" + path + "' 2>/dev/null || stat -c '%Y' '" + path + "' 2>/dev/null")
    return to_int(s)
}

fn now_epoch() -> int {
    return to_int(sh("date +%s"))
}

fn iso_now() -> string {
    return sh("date -u +%Y-%m-%dT%H:%M:%SZ")
}

fn jsonl_append(line: string) {
    let esc = line.replace("'", "'\\''")
    let _ = exec("printf '%s\\n' '" + esc + "' >> '" + ALERTS + "' 2>/dev/null")  // @allow-bare-exec
}

// ── Plan loader — R37/AN13/L3-PY: python3 stubs returning sentinels ─────────
fn plan_get_int(path: string, key: string) -> int {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = path
    let _ = key
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at h100_idle_guard.hexa:plan_get_int. Escalate to user for hexa-native replacement.")
    return 0
}

fn plan_get_str(path: string, key: string) -> string {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    let _ = path
    let _ = key
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at h100_idle_guard.hexa:plan_get_str. Escalate to user for hexa-native replacement.")
