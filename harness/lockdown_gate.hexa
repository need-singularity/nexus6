// SUPERSEDES: harness/l0_guard.hexa (구: lockdown/l0_guard.hexa — 2026-04-14 harness 이동)
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
// lockdown_gate.hexa — L0/L1/L2 통합 게이트 (harness 편입)
//
// SSOT: shared/lockdown/lockdown.json → projects.{name}.{L0|L1|L2}
// Sidecar: shared/harness/lockdown_log.jsonl  (위반/복원 기록)
// 역할: 기존 l0_guard(488L) 를 L0/L1/L2 3-tier 라우터로 재편 + harness 6대 슬롯 편입.
//
// Usage (git 리포 안에서):
//   hexa .../lockdown_gate.hexa verify [--scope L0|L1|L2|all]   파일 + CODEOWNERS + gh branch protection
//   hexa .../lockdown_gate.hexa status [--json]                 6항목 PASS/FAIL, --json 이면 machine-readable
//   hexa .../lockdown_gate.hexa watch <path>                    path → tier 분류 → BLOCK|WARN|ALLOW
//   hexa .../lockdown_gate.hexa repair [--dry-run]              drift 복원 — CODEOWNERS + enforce_admins on
//   hexa .../lockdown_gate.hexa safe-merge <PR#>                admins off → gh merge → admins on (defer 복원)
//   hexa .../lockdown_gate.hexa log [--tail N]                  lockdown_log.jsonl tail (default N=20)
//
// 제외: parse error 검증(기존 §4) → lint.hexa V-PARSE 로 이관. lock/promote → sync.hexa 라우터 위임.

// ─── 상단 고정 영역: 상수 + gh/python/sed 헬퍼 ───────────────────────────

let HOME = env("HOME")
let LOCKDOWN = HOME + "/Dev/nexus/shared/lockdown/lockdown.json"
let SYNC_CODEOWNERS = HOME + "/Dev/nexus/shared/scripts/sync_codeowners.hexa"
let LOG = HOME + "/Dev/nexus/shared/harness/lockdown_log.jsonl"
let BRANCH = "main"
let CODEOWNERS = ".github/CODEOWNERS"
// PY3 constant removed 2026-04-18 (R37/AN13/L3-PY) — python3 invocation blocked

// R33 guard — grep -c + "|| echo 0" 이중 출력 방어. 첫 줄만 파싱.
fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = s.split("\n")[0].trim()
    if first == "" { return 0 }
    return to_int(first)
}

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _bstr(b: bool) -> string {
    if b { return "true" }
    return "false"
}

// sh exec wrapper — trim + string 강제 (void split 회피).
fn sh(cmd: string) -> string {
    return _str(exec(cmd)).trim()  // @allow-bare-exec
}

// ISO8601 UTC.
fn iso_now() -> string {
    return sh("date -u +%Y-%m-%dT%H:%M:%SZ")
}

// ─── git/project 자동 감지 ────────────────────────────────────────────────

fn detect_root() -> string { return sh("git rev-parse --show-toplevel 2>/dev/null") }
fn detect_project() -> string {
    let r = detect_root()
    if r == "" { return "" }
    return sh("basename '" + r + "'")
}
fn detect_repo() -> string {
    let url = sh("git remote get-url origin 2>/dev/null")
    if url == "" { return "" }
    return sh("echo '" + url + "' | sed -E 's|.*github\\.com[:/]||; s|\\.git$||'")
}

// ─── lockdown.json 조회 — R37/AN13/L3-PY: python3 stubs ──────────────────
// tier: "L0" | "L1" | "L2"  — path 만 개행 구분 출력.
fn paths_of(project: string, tier: string) -> string {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    // Original: python3 reads LOCKDOWN json and emits projects[project][tier] paths
    let _ = project
    let _ = tier
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at lockdown_gate.hexa:paths_of. Escalate to user for hexa-native replacement.")
    return ""
}

// path → tier (BLOCK=L0, WARN=L1, ALLOW=L2/미등록). repo-relative 매칭.
fn classify_path(project: string, rel: string) -> string {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    // Original: python3 tier-matching against LOCKDOWN json
    let _ = project
    let _ = rel
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at lockdown_gate.hexa:classify_path. Escalate to user for hexa-native replacement.")
    return "NONE"
}

// ─── gh CLI 헬퍼 ─────────────────────────────────────────────────────────

fn gh_field(repo: string, field_expr: string) -> string {
    // R37/AN13/L3-PY violation — python3 wrapper-fallback removed 2026-04-18
    // Original: gh api branches/protection | python3 -c "<field_expr>"
    let _ = repo
    let _ = field_expr
    eprintln("R37/AN13/L3-PY: python3 invocation blocked at lockdown_gate.hexa:gh_field. Escalate to user for hexa-native replacement.")
    return ""
}

fn gh_bool(repo: string, field_expr: string) -> bool {
    let r = gh_field(repo, field_expr)
    if r == "True" { return true }
    if r == "true" { return true }
    return false
}

fn gh_enforce_admins(repo: string) -> bool {
    return gh_bool(repo, "print(d.get('enforce_admins',{}).get('enabled',False))")
}
fn gh_require_pr(repo: string) -> bool {
    return gh_bool(repo, "print(d.get('required_pull_request_reviews') is not None)")
}
fn gh_codeowner_reviews(repo: string) -> bool {
    return gh_bool(repo, "print(d.get('required_pull_request_reviews',{}).get('require_code_owner_reviews',False))")
}
fn gh_force_push_blocked(repo: string) -> bool {
    return gh_bool(repo, "print(not d.get('allow_force_pushes',{}).get('enabled',True))")
}
fn gh_deletions_blocked(repo: string) -> bool {
    return gh_bool(repo, "print(not d.get('allow_deletions',{}).get('enabled',True))")
}
fn gh_admins_on(repo: string) { exec("gh api repos/" + repo + "/branches/" + BRANCH + "/protection/enforce_admins -X POST 2>/dev/null") }  // @allow-bare-exec
fn gh_admins_off(repo: string) { exec("gh api repos/" + repo + "/branches/" + BRANCH + "/protection/enforce_admins -X DELETE 2>/dev/null") }  // @allow-bare-exec

// ─── 로그 append (JSONL) ─────────────────────────────────────────────────
// 스키마: {"ts","tier","path","action","restored"}
fn log_event(tier: string, path: string, action: string, restored: bool) {
    let rstr = "false"
    if restored { rstr = "true" }
    let line = "{\"ts\":\"" + iso_now() + "\",\"tier\":\"" + tier + "\",\"path\":\"" + path + "\",\"action\":\"" + action + "\",\"restored\":" + rstr + "}"
    exec("printf '%s\\n' '" + line.replace("'", "'\\''") + "' >> '" + LOG + "'")  // @allow-bare-exec
}

// ─── Modes ───────────────────────────────────────────────────────────────

// verify: 파일 존재 + CODEOWNERS + gh protection 검증.
fn cmd_verify(project: string, repo: string, scope_arg: string) {
    println("=== lockdown_gate verify — " + project + " (" + repo + ") scope=" + scope_arg + " ===")
    let mut pass = 0
    let mut fail = 0
    let root = detect_root()

    // 1. 파일 존재 (scope 별)
    let tiers = ["L0", "L1", "L2"]
    let mut ti = 0
    while ti < len(tiers) {
        let t = tiers[ti]
        let active = scope_arg == "all" || scope_arg == t
        if active {
            let ps = paths_of(project, t)
            if ps != "" {
                let lines = ps.split("\n")
                let mut i = 0
                while i < len(lines) {
                    let p = lines[i].trim()
                    if p != "" {
                        let abs = root + "/" + p
                        let exists = sh("test -e '" + abs + "' && echo Y || echo N")
                        if exists == "Y" {
                            pass = pass + 1
                        } else {
                            println("  FAIL  [" + t + "] " + p + " — 없음")
                            log_event(t, p, "block", false)
                            fail = fail + 1
                        }
                    }
                    i = i + 1
                }
            }
        }
        ti = ti + 1
    }

    // 2. CODEOWNERS 동기화 (L0 전체 포함 검증)
    let co_exists = sh("test -e '" + CODEOWNERS + "' && echo Y || echo N")
    if co_exists != "Y" {
        println("  FAIL  CODEOWNERS 없음")
        fail = fail + 1
    } else {
        let l0_ps = paths_of(project, "L0")
        let co_body = _str(read_file(CODEOWNERS))
        let lines = l0_ps.split("\n")
        let mut j = 0
        let mut miss = 0
        while j < len(lines) {
            let p = lines[j].trim()
            if p != "" {
                if co_body.contains(p) == false {
                    miss = miss + 1
                }
            }
            j = j + 1
        }
        if miss == 0 { pass = pass + 1 } else {
            println("  FAIL  CODEOWNERS 누락 " + to_string(miss) + "건")
            fail = fail + 1
        }
    }

    // 3. gh branch protection (5항목)
    let checks = [
        ["enforce_admins", gh_enforce_admins(repo)],
        ["require_pull_request", gh_require_pr(repo)],
        ["require_code_owner_reviews", gh_codeowner_reviews(repo)],
        ["force_push_blocked", gh_force_push_blocked(repo)],
        ["branch_delete_blocked", gh_deletions_blocked(repo)]
    ]
    let mut k = 0
    while k < len(checks) {
        let c = checks[k]
        if c[1] { pass = pass + 1 } else {
            println("  FAIL  " + _str(c[0]))
            fail = fail + 1
        }
        k = k + 1
    }

    println("=== " + to_string(pass) + " PASS / " + to_string(fail) + " FAIL ===")
    if fail > 0 { println("drift 있음 — repair 로 복원") }
}

// status: 6항목 PASS/FAIL. --json 이면 machine-readable.
fn cmd_status(project: string, repo: string, as_json: bool) {
    let e = gh_enforce_admins(repo)
    let pr = gh_require_pr(repo)
    let co = gh_codeowner_reviews(repo)
    let fp = gh_force_push_blocked(repo)
    let dl = gh_deletions_blocked(repo)
    let cf = sh("test -e '" + CODEOWNERS + "' && echo Y || echo N") == "Y"

    if as_json {
        let out = "{\"project\":\"" + project + "\",\"repo\":\"" + repo + "\"," +
            "\"enforce_admins\":" + _bstr(e) + "," +
            "\"require_pull_request\":" + _bstr(pr) + "," +
            "\"require_code_owner_reviews\":" + _bstr(co) + "," +
            "\"force_push_blocked\":" + _bstr(fp) + "," +
            "\"branch_delete_blocked\":" + _bstr(dl) + "," +
            "\"codeowners_present\":" + _bstr(cf) + "}"
        println(out)
        return
    }

    println("=== lockdown status — " + project + " (" + repo + ") ===")
    let rows = [
        ["enforce_admins", e],
        ["require_pull_request", pr],
        ["require_code_owner_reviews", co],
        ["force_push_blocked", fp],
        ["branch_delete_blocked", dl],
        ["codeowners_present", cf]
    ]
    let mut i = 0
    let mut allok = true
    while i < len(rows) {
        let r = rows[i]
        if r[1] { println("  PASS  " + _str(r[0])) } else { println("  FAIL  " + _str(r[0])); allok = false }
        i = i + 1
    }
    if allok { println("L0/L1/L2 protection: intact") } else { println("drift present — repair") }
}

// watch: path → tier 분류 + BLOCK|WARN|ALLOW 출력. pre_tool_guard 가 호출.
fn cmd_watch(project: string, rel: string) {
    if rel == "" {
        eprintln("usage: lockdown_gate watch <path>")
        return
    }
    let tier = classify_path(project, rel)
    if tier == "L0" {
        println("BLOCK: [L0] " + rel + " — lockdown.json 보호. 수정 시 사용자 명시 승인 필요")
        log_event("L0", rel, "block", false)
    } else if tier == "L1" {
        println("WARN: [L1] " + rel + " — 리뷰 필요. 변경 이유 기록 필수")
        log_event("L1", rel, "warn", false)
    } else {
        println("ALLOW: [L2/NONE] " + rel)
    }
}

// repair: drift 자동 복원. --dry-run 기본.
fn cmd_repair(project: string, repo: string, dry: bool) {
    let mode = "DRY-RUN"
    if dry == false { mode = "APPLY" }
    println("=== lockdown repair — " + project + " (" + mode + ") ===")

    // 1. CODEOWNERS 재생성 (sync_codeowners.hexa 위임)
    let co_missing = sh("test -e '" + CODEOWNERS + "' && echo N || echo Y") == "Y"
    if co_missing {
        println("  CODEOWNERS 누락 → sync_codeowners 호출")
        if dry == false {
            let hexa_bin = HOME + "/Dev/nexus/shared/bin/hexa"
            let out = sh(hexa_bin + " " + SYNC_CODEOWNERS + " 2>&1")
            println("  " + out)
            log_event("L0", CODEOWNERS, "repair", true)
        }
    } else {
        println("  CODEOWNERS 존재 — skip")
    }

    // 2. enforce_admins 복원
    if gh_enforce_admins(repo) == false {
        println("  enforce_admins OFF → ON")
        if dry == false {
            gh_admins_on(repo)
            let ok = gh_enforce_admins(repo)
            if ok {
                println("  DONE enforce_admins=true")
                log_event("L0", "branch_protection", "repair", true)
            } else {
                println("  FAIL 복원 실패")
                log_event("L0", "branch_protection", "repair", false)
            }
        }
    } else {
        println("  enforce_admins ON — skip")
    }

    if dry { println("(dry-run — 변경 없음. --dry-run 제거 시 실제 복원)") }
}

// safe-merge: admins off → gh merge → admins on. 실패해도 admins on 복원 보장.
fn cmd_safe_merge(repo: string, pr: string) {
    if pr == "" {
        eprintln("usage: lockdown_gate safe-merge <PR#>")
        return
    }
    println("=== lockdown safe-merge PR #" + pr + " (" + repo + ") ===")

    // 방어 패턴: admins off → merge 시도 → finally admins on.
    println("  [1/4] enforce_admins OFF")
    gh_admins_off(repo)

    println("  [2/4] gh pr merge " + pr + " --merge --admin")
    let out = sh("gh pr merge " + pr + " --merge --admin 2>&1")
    println("  " + out)

    // 3. 무조건 admins on 복원 (defer 패턴)
    println("  [3/4] enforce_admins ON (복원 보장)")
    gh_admins_on(repo)
    let restored = gh_enforce_admins(repo)

    let state = sh("gh pr view " + pr + " --json state -q '.state' 2>/dev/null")
    println("  [4/4] PR state=" + state)
    if state == "MERGED" {
        println("  DONE merged + admins restored=" + to_string(restored))
        log_event("L0", "PR#" + pr, "merge", restored)
        let pull = sh("git checkout " + BRANCH + " && git pull origin " + BRANCH + " 2>&1")
        println("  " + pull)
    } else {
        println("  FAIL merge 실패 — admins restored=" + to_string(restored))
        log_event("L0", "PR#" + pr, "merge", restored)
    }
}

// log: lockdown_log.jsonl tail N.
fn cmd_log(tail_n: string) {
    let n = tail_n
    if n == "" { n = "20" }
    let exists = sh("test -e '" + LOG + "' && echo Y || echo N")
    if exists != "Y" {
        println("(empty) " + LOG)
        return
    }
    let out = sh("tail -n " + n + " '" + LOG + "' 2>/dev/null")
    if out == "" { println("(empty)") } else { println(out) }
}

// ─── Entry ───────────────────────────────────────────────────────────────

fn print_usage() {
    println("Usage: hexa .../harness/lockdown_gate.hexa <mode> [args]")
    println("  verify [--scope L0|L1|L2|all]    파일+CODEOWNERS+gh protection")
    println("  status [--json]                  6항목 PASS/FAIL")
    println("  watch <path>                     path → BLOCK|WARN|ALLOW")
    println("  repair [--dry-run]               drift 복원 (CODEOWNERS + enforce_admins)")
    println("  safe-merge <PR#>                 admins off → merge → admins on")
    println("  log [--tail N]                   lockdown_log.jsonl tail (default 20)")
}

fn parse_scope(argv) -> string {
    let mut i = 3
    while i < argv.len() {
        if argv[i] == "--scope" && i + 1 < argv.len() {
            return argv[i + 1]
        }
        i = i + 1
    }
    return "all"
}

fn has_flag(argv, flag: string) -> bool {
    let mut i = 3
    while i < argv.len() {
        if argv[i] == flag { return true }
        i = i + 1
    }
    return false
}

fn parse_kv(argv, key: string) -> string {
    let mut i = 3
    while i < argv.len() {
        if argv[i] == key && i + 1 < argv.len() {
            return argv[i + 1]
        }
        i = i + 1
    }
    return ""
}

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    if argv.len() < 3 {
        print_usage()
        return
    }
    let mode = argv[2]

    if mode == "log" {
        cmd_log(parse_kv(argv, "--tail"))
        return
    }

    let project = detect_project()
    let repo = detect_repo()
    if project == "" {
        eprintln("FAIL: git 리포 안에서 실행 필요")
        return
    }

    if mode == "verify" {
        cmd_verify(project, repo, parse_scope(argv))
    } else if mode == "status" {
        cmd_status(project, repo, has_flag(argv, "--json"))
    } else if mode == "watch" {
        let rel = ""
        if argv.len() >= 4 { cmd_watch(project, argv[3]) } else { cmd_watch(project, rel) }
    } else if mode == "repair" {
        // 기본 dry-run. --dry-run 명시 또는 flag 없음 → dry=true. `repair apply` / no-dry 는 명시 해제.
        let apply = has_flag(argv, "--apply")
        cmd_repair(project, repo, apply == false)
    } else if mode == "safe-merge" {
        let pr = ""
        if argv.len() >= 4 { cmd_safe_merge(repo, argv[3]) } else { cmd_safe_merge(repo, pr) }
    } else {
        eprintln("unknown mode: " + mode)
        print_usage()
    }
}

main()
