// test_roadmap_engine.hexa — 로드맵 엔진 v1 회귀 테스트 (자체기능)
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
//
// 검증 항목 (hard-coded assertions, plugin 구조 아님):
//   1. example.json 로드 → nodes=9
//   2. schedule → T*=46.1 (progress 반영)
//   3. dispatch → bottleneck=rollup (build, 22.75)
//   4. eta 음수 (progress 편차 → replan 필요 신호)
//   5. ready 목록 in_progress 제외 (todo/planned 만)
//   6. soft_drop_candidates = [lint_pass]
//   7. 이벤트 출력 ≥ 5 라인 (Plan, NodeStart, NodeComplete, BottleneckShift, Replan)
//
// exit: 0 all pass / 1+ fail count

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let ENGINE = NEXUS + "/shared/harness/roadmap_engine.hexa"
let SCHED = NEXUS + "/shared/harness/roadmap_schedule.hexa"
let VIEW = NEXUS + "/shared/harness/roadmap_view.hexa"
let EVENT = NEXUS + "/shared/harness/roadmap_event.hexa"
let EXAMPLE = NEXUS + "/shared/roadmaps/example.json"
let HEXA = NEXUS + "/shared/bin/hexa"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

let mut _fail: i64 = 0
let mut _pass: i64 = 0

fn assert_contains(haystack: string, needle: string, label: string) {
    if haystack.contains(needle) {
        println("  PASS  " + label)
        _pass = _pass + 1
    } else {
        println("  FAIL  " + label + "  (needle='" + needle + "' not found)")
        println("         haystack head: " + haystack.substring(0, if haystack.len() > 120 { 120 } else { haystack.len() }))
        _fail = _fail + 1
    }
}

fn assert_not_contains(haystack: string, needle: string, label: string) {
    if haystack.contains(needle) == false {
        println("  PASS  " + label)
        _pass = _pass + 1
    } else {
        println("  FAIL  " + label + "  (unexpected needle='" + needle + "')")
        _fail = _fail + 1
    }
}

fn test_example_exists() {
    println("[test] example.json exists")
    if file_exists(EXAMPLE) {
        println("  PASS  " + EXAMPLE)
        _pass = _pass + 1
    } else {
        println("  FAIL  " + EXAMPLE + " missing")
        _fail = _fail + 1
    }
}

fn test_schedule_dispatch() {
    println("[test] schedule --dispatch output")
    let cmd = "HEXA_LOCAL=1 " + HEXA + " run " + ENGINE + " " + EXAMPLE + " --dispatch 2>&1"
    let out = _str(exec(cmd)).trim()  // @allow-bare-exec
    assert_contains(out, "\"roadmap\":\"example\"", "roadmap id")
    assert_contains(out, "\"goal\":\"G\"", "goal")
    assert_contains(out, "\"T_star\":46.11", "T*=46.11")
    assert_contains(out, "\"node\":\"rollup\"", "bottleneck=rollup")
    assert_contains(out, "\"category\":\"build\"", "bottleneck category=build")
    assert_contains(out, "\"replan_needed\":true", "replan=true (eta ≤ 0)")
    assert_contains(out, "\"ready\":[]", "ready=[] (in_progress 제외)")
    assert_contains(out, "\"in_progress\":[\"P7\",\"rollup\"]", "in_progress=[P7,rollup]")
}

fn test_view_flowchart() {
    println("[test] view flowchart")
    let cmd = "HEXA_LOCAL=1 " + HEXA + " run " + VIEW + " " + EXAMPLE + " 2>&1"
    let out = _str(exec(cmd))  // @allow-bare-exec
    assert_contains(out, "▼Roadmap  example", "flowchart header")
    assert_contains(out, "T*=46.1m", "T* 표기")
    assert_contains(out, "attack parallel", "parallel block")
    assert_contains(out, "★ goal", "goal glyph")
    assert_contains(out, "REPLAN hint", "replan hint")
    assert_contains(out, "lint_pass", "soft drop candidate shown")
    // parallel group 중복 출력 금지 (hexa continue quirk 회귀 방지):
    //   원 버그 — continue 전후 block 양쪽에서 render_parallel_group 호출되어 4번 찍힘.
    let count = count_occurrences(out, "┌──attack parallel")
    if count == 2 {
        println("  PASS  parallel group 2회만 (diagnose+rollup)")
        _pass = _pass + 1
    } else {
        println("  FAIL  parallel group 출현 " + to_string(count) + "회 (기대=2)")
        _fail = _fail + 1
    }
}

fn count_occurrences(hay: string, needle: string) -> i64 {
    let mut cnt: i64 = 0
    let mut pos: i64 = 0
    let nl = needle.len()
    while pos < hay.len() {
        let idx = hay.substring(pos, hay.len()).index_of(needle)
        if idx < 0 { return cnt }
        cnt = cnt + 1
        pos = pos + idx + nl
    }
    return cnt
}

fn test_event_emit() {
    println("[test] event JSONL emission")
    let tmp = "/tmp/roadmap_test_events_" + _str(exec("date +%s%N")).trim() + ".jsonl"  // @allow-bare-exec
    let _ = exec("rm -f " + tmp)  // @allow-bare-exec
    let cmd = "HEXA_LOCAL=1 " + HEXA + " run " + EVENT + " " + EXAMPLE + " " + tmp + " 2>&1"
    let _ = exec(cmd)  // @allow-bare-exec
    let body = _str(exec("cat " + tmp + " 2>/dev/null"))  // @allow-bare-exec
    assert_contains(body, "\"kind\":\"Plan\"", "Plan event")
    assert_contains(body, "\"kind\":\"NodeStart\"", "NodeStart event")
    assert_contains(body, "\"kind\":\"NodeComplete\"", "NodeComplete event")
    assert_contains(body, "\"kind\":\"BottleneckShift\"", "BottleneckShift event")
    assert_contains(body, "\"kind\":\"Replan\"", "Replan event")
    // ≥ 5 lines
    let cnt = _str(exec("wc -l < " + tmp + " 2>/dev/null")).trim()  // @allow-bare-exec
    if cnt.len() > 0 && to_int(cnt) >= 5 {
        println("  PASS  event count=" + cnt + " (≥5)")
        _pass = _pass + 1
    } else {
        println("  FAIL  event count=" + cnt + " (기대≥5)")
        _fail = _fail + 1
    }
    let _ = exec("rm -f " + tmp)  // @allow-bare-exec
}

fn test_no_plugin_leak() {
    println("[test] no plugin/register/adapter terminology (native-only)")
    // roadmap_{engine,schedule,view,event,parse}.hexa 안에 plugin/adapter/register 금지
    let files = [ENGINE, SCHED, VIEW, EVENT, NEXUS + "/shared/harness/roadmap_parse.hexa"]
    let banned = ["Plugin", "plugin.register", "plugins: [", "plugin_registry", "PluginInterface"]
    let mut hit = false
    for f in files {
        if file_exists(f) == false { continue }
        let body = _str(read_file(f))
        for b in banned {
            if body.contains(b) {
                println("  FAIL  " + f + " contains banned token: " + b)
                _fail = _fail + 1
                hit = true
            }
        }
    }
    if hit == false {
        println("  PASS  plugin 추상화 없음 (자체기능 구조)")
        _pass = _pass + 1
    }
}

fn test_soft_drop_candidates() {
    println("[test] soft_deps dropping semantics")
    let cmd = "HEXA_LOCAL=1 " + HEXA + " run " + ENGINE + " " + EXAMPLE + " --dispatch 2>&1"
    let out = _str(exec(cmd)).trim()  // @allow-bare-exec
    // dispatch JSON 에는 soft_drop 직접 미출력. 이벤트 출력에 포함됨.
    // view 에는 "soft_deps drop 후보: lint_pass" 행 존재 확인
    let view_cmd = "HEXA_LOCAL=1 " + HEXA + " run " + VIEW + " " + EXAMPLE + " 2>&1"
    let view_out = _str(exec(view_cmd))  // @allow-bare-exec
    assert_contains(view_out, "lint_pass", "soft_deps target lint_pass 노출")
    assert_contains(view_out, "soft_deps drop", "drop hint 표기")
}

fn main() {
    println("═══ roadmap engine v1 regression tests ═══")
    println("")
    test_example_exists()
    test_schedule_dispatch()
    test_view_flowchart()
    test_event_emit()
    test_soft_drop_candidates()
    test_no_plugin_leak()
    println("")
    println("═══ summary: " + to_string(_pass) + " pass, " + to_string(_fail) + " fail ═══")
    if _fail > 0 { exit(1) }
    exit(0)
}

main()
