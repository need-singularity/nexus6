// signal_cross_match.hexa — E8 대체 하네스
// atlas.signals.n6 전체 로드 → 수치 + 키워드 기반 cross-repo 매칭
// 새 CROSS 후보 리포트 출력 (merge_signals.py 의 find_cross_matches 간이 포팅)
// 실행: hexa run $NEXUS/shared/harness/signal_cross_match.hexa [min_score=3]

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let SIGNALS = NEXUS + "/shared/n6/atlas.signals.n6"
let REPORT = NEXUS + "/shared/n6/signals/cross_match_report.md"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    let mut v: i64 = 0
    try { v = to_int(first) } catch e { v = 0 }
    return v
}

fn now_iso() -> string {
    let r = exec("date -u +%Y-%m-%dT%H:%M:%SZ")
    return _str(r).trim()
}

fn shell_quote(s: string) -> string {
    let escaped = s.replace("'", "'\\''")
    return "'" + escaped + "'"
}

// awk 로 @S 라인 리스트 뽑기: "sig_id|repo_tags|statement" 형식
fn load_signals() -> [string] {
    let cmd = "awk '/^@S / { " +
              "  id = $2; " +
              "  line = $0; " +
              "  match(line, /\\[[A-Z,]+\\]/); repo = substr(line, RSTART, RLENGTH); " +
              "  sub(/^@S [^=]+= /, \"\", line); " +
              "  sub(/ ::.*/, \"\", line); " +
              "  print id \"|\" repo \"|\" line " +
              "}' '" + SIGNALS + "'"
    let r = exec(cmd)
    let text = _str(r)
    let lines = text.split("\n")
    let mut out: [string] = []
    for line in lines {
        let s = _str(line).trim()
        if s != "" { out = out + [s] }
    }
    return out
}

// 문자열에서 숫자 패턴 토큰 추출 (간이): "%" "pp" "×" "σ=0." 패턴
fn has_token(text: string, tok: string) -> bool {
    return text.contains(tok)
}

// 키워드 목록
let KEYWORDS = [
    "stochastic resonance",
    "resonance",
    "universal",
    "bernoulli",
    "completeness",
    "완전수",
    "millennium",
    "ouroboros",
    "sweet spot",
    "peak",
    "PEAK",
    "threshold",
    "bell",
    "hebbian",
    "ratchet",
    "kuramoto",
    "primitive",
    "hub",
    "cross-domain",
    "golden"
]

// 두 statement 간 스코어 계산
fn score_pair(a: string, b: string) -> i64 {
    let mut score: i64 = 0
    // 수치 오버랩: "σ=0.1" / "pp" / "×" 등
    let tokens = ["σ=0.", "pp", "×", "0.1", "0.25", "0.5", "PEAK", "NULL", "peak"]
    let mut i = 0
    while i < tokens.len() {
        if has_token(a, tokens[i]) && has_token(b, tokens[i]) {
            score = score + 2
        }
        i = i + 1
    }
    // 키워드 오버랩
    let mut j = 0
    while j < KEYWORDS.len() {
        let k = KEYWORDS[j]
        if has_token(a, k) && has_token(b, k) {
            score = score + 1
        }
        j = j + 1
    }
    return score
}

// 리포 태그 추출
fn repo_set(repo_str: string) -> string {
    // "[NX,N6]" → "NX,N6"
    let mut s = repo_str
    s = s.replace("[", "")
    s = s.replace("]", "")
    return s.trim()
}

// 두 리포 세트가 서로 다른 리포를 포함하는지 (CROSS 후보 조건)
fn different_repos(ra: string, rb: string) -> bool {
    // CROSS 태그는 무시, NX/N6/AN 기준
    let na = ra.contains("NX")
    let nb = rb.contains("NX")
    let n6a = ra.contains("N6")
    let n6b = rb.contains("N6")
    let ana = ra.contains("AN")
    let anb = rb.contains("AN")
    // 서로 다른 리포 세트 (최소 1 리포 서로 다름)
    if (na && !nb) || (!na && nb) { return true }
    if (n6a && !n6b) || (!n6a && n6b) { return true }
    if (ana && !anb) || (!ana && anb) { return true }
    return false
}

// ─── 메인 ───
let a = args()
let mut min_score: i64 = 2
if a.len() >= 3 {
    try { min_score = to_int(a[2]) } catch e { min_score = 2 }
}

println("signal_cross_match: min_score=" + to_string(min_score) + " ts=" + now_iso())

let sigs = load_signals()
println("  loaded signals=" + to_string(sigs.len()))

if sigs.len() < 2 {
    println("  FAIL: 2개 미만")
    exit(1)
}

// O(N^2) 비교 — N=260+ 이면 ~34K 쌍 → hexa 는 느리므로 N=150 제한
let max_n = if sigs.len() > 150 { 150 } else { sigs.len() }
println("  비교 윈도우=" + to_string(max_n) + " (전체 " + to_string(sigs.len()) + " 중)")

// 각 sig 를 id/repo/stmt 로 parse
let mut ids: [string] = []
let mut repos: [string] = []
let mut stmts: [string] = []
let mut p = 0
while p < max_n {
    let line = sigs[p]
    let parts = line.split("|")
    if parts.len() >= 3 {
        ids = ids + [_str(parts[0])]
        repos = repos + [repo_set(_str(parts[1]))]
        stmts = stmts + [_str(parts[2])]
    }
    p = p + 1
}

let n = ids.len()
let mut candidate_pairs: [string] = []
let mut candidate_scores: [i64] = []

let mut x = 0
while x < n {
    let mut y = x + 1
    while y < n {
        if different_repos(repos[x], repos[y]) {
            let sc = score_pair(stmts[x], stmts[y])
            if sc >= min_score {
                let pair = ids[x] + " ↔ " + ids[y] +
                           " [" + repos[x] + "↔" + repos[y] + "]"
                candidate_pairs = candidate_pairs + [pair]
                candidate_scores = candidate_scores + [sc]
            }
        }
        y = y + 1
    }
    x = x + 1
}

println("  cross_candidates=" + to_string(candidate_pairs.len()))

// 리포트 작성
let mut body = "# atlas.signals.n6 Cross-Match 리포트\n\n"
body = body + "> 생성: " + now_iso() + "\n"
body = body + "> 비교 윈도우: " + to_string(n) + " signals (전체 " + to_string(sigs.len()) + ")\n"
body = body + "> 최소 스코어: " + to_string(min_score) + "\n\n"
body = body + "## Cross-repo 후보 쌍 (" + to_string(candidate_pairs.len()) + ")\n\n"

let mut i2 = 0
while i2 < candidate_pairs.len() {
    body = body + "- score=" + to_string(candidate_scores[i2]) + "  " + candidate_pairs[i2] + "\n"
    i2 = i2 + 1
}

if candidate_pairs.len() == 0 {
    body = body + "_(후보 없음)_\n"
}

body = body + "\n---\n*signal_cross_match.hexa*\n"

try {
    write_file(REPORT, body)
    println("  report=" + REPORT)
} catch e {
    println("  FAIL: write error")
}

// 상위 5개 출력
let mut show = 0
let show_max: i64 = 5
while show < candidate_pairs.len() && show < show_max {
    println("    [" + to_string(candidate_scores[show]) + "] " + candidate_pairs[show])
    show = show + 1
}
