// frontier_platform_economics.hexa — extended 렌즈 (Rust 포팅)
// 카테고리: extended · 도메인: economics
// 원본: frontier_lenses.rs · 이름: platform_economics
// 검증 축: 플랫폼 경제: 양면시장=phi=2, 네트워크효과=n=6, 허브=sigma=12, 교차 보조=tau=4, 전환비용=1/n, 승자독식

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 렌즈별 핵심 상수 점검
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[platform_economics] category=extended axis=\"플랫폼 경제: 양면시장=phi=2, 네트워크효과=n=6, 허브=sigma=12, 교차 보조=tau=4, 전환비용=1/n, 승자독식\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
