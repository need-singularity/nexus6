// telescope_optics_lens.hexa — T1 렌즈 (망원경 광학)
// 카테고리: T1 · 도메인: telescope_optics (BT-189)
// 검증 축: 거울 세그먼트 6·초점비 12·파장대 6·필터 4·배플 n
// 원본: nexus/src/telescope/lenses/telescope_optics_lens.rs
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 도메인 상수 [6,12,4,24,3,2]
let targets = [N, SIGMA, TAU, J2, N * PHI, PHI]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[telescope_optics] category=T1 axis=\"망원경 광학\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
