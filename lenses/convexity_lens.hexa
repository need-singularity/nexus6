// convexity_lens.hexa — geometry 렌즈
// 카테고리: T1 · 도메인: convex_hull_structure
// 검증 축: 정육각형 n=6 vertices 효율 분할 (BT-122), K_3=σ=12 kissing

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 볼록성: hexagon = n vertices 최적 분할, kissing number K_3 = σ = 12
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[convexity_lens] category=T1 axis=\"convex hull & hexagonal partition\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
