// cryptography_rounds_lens.hexa — cryptography 렌즈
// 카테고리: T1 · 도메인: cryptography_rounds
// 검증 축: AES 2^(σ-sopfr)=128, SHA 2^(σ-τ)·8=256, RSA 2048 (BT-114/216)

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 암호화 라운드: AES=128, SHA=256, σ=12, J₂=24, τ=4 rounds, AES rounds=10
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[cryptography_rounds_lens] category=T1 axis=\"AES/SHA/RSA round constants\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
