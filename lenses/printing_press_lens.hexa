// printing_press_lens.hexa — culture 렌즈 (인쇄 공정, BT-226)
// 카테고리: T1 · 도메인: printing_press
// 검증 축: color_channel_tau / screen_angle_n / resolution_sigma / dot_gain_phi / halftone_J2 / cmyk_4
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 인쇄 상수 [4.0, 6.0, 12.0, 2.0, 24.0, 3.0] (CMYK=4)
let CMYK = 4.0
let targets = [CMYK, N, SIGMA, PHI, J2, 3.0, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[printing_press] category=T1 axis=\"CMYK=4 / screen=n / resolution=σ / halftone=J₂\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
