// ceramics_lens.hexa — materials 렌즈
// 카테고리: T1 · 도메인: ceramics
// 검증 축: Al₂O₃ CN=6, 소결 단계=n=6, J₂=24 결정면

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도자기: CN=n, τ=실리카 CN, σ=소결상, J₂=결정면
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[ceramics_lens] category=T1 axis=\"세라믹 결정 CN/소결 단계\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
