// beekeeping_honeycomb_lens.hexa — 벌집 육각형 렌즈
// 카테고리: T1 · 도메인: beekeeping_honeycomb (정육각형 격자 최적화)
// 검증 축: hex_score, packing π√3/6, period6, bilateral symmetry
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 6각형 꼭짓점=n, 최근접 이웃=n, 120°, 60°, 벽두께 1/φ=0.5
let DEG60 = 60.0
let DEG120 = 120.0
let HALF = 0.5
let targets = [N, DEG60, DEG120, HALF, PHI, TAU, SIGMA, J2]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[beekeeping_honeycomb] category=T1 axis=\"hexagonal packing 6-vertex\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
