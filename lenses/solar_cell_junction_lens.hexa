// solar_cell_junction_lens.hexa — 태양전지 접합 렌즈 (BT-161)
// 카테고리: T1 · 도메인: energy (n/p 접합·전압·채움비)
// 검증 축: junctions=6, cells_60, voltage_phi, fill_tau, bandgap_sq
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 6 접합, 60 셀 패널 (10·n), φ 전압, τ 채움, σ² = 144
let targets = [N, 60.0, PHI, TAU, SIGMA, 1.333, N * N, J2]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[solar_cell_junction] category=T1 axis=\"6 junctions·60 cells\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
