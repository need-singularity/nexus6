// big_bang_lens.hexa — 대폭발 팽창 렌즈
// 카테고리: T1 · 도메인: big_bang (Hubble 팽창·CMB 등방성)
// 검증 축: expansion_rate, origin_concentration (내부 r/6), isotropy, cmb_uniformity
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 내부 r=max/6, CMB ~ 2.725K, H0~70, age 13.8Gyr
// J₂=24 단위 구 샘플
let CMB_K = 2.725
let H0 = 70.0
let AGE = 13.8
let targets = [N, TAU, SIGMA, PHI, J2, CMB_K, H0, AGE]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[big_bang] category=T1 axis=\"Hubble 6-fold · CMB isotropy\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
