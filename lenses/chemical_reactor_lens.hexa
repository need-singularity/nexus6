// chemical_reactor_lens.hexa — chemistry 렌즈
// 카테고리: T1 · 도메인: chemical_reactor
// 검증 축: residence_τ:stage_n:heat_σ:flow_J₂ (BT-307)

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 반응기: τ=체류시간, n=단계, σ=열, J₂=유량, 어트랙터 288=σ·J₂
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[chemical_reactor_lens] category=T1 axis=\"residence:stage:heat:flow\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
