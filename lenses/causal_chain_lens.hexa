// causal_chain_lens.hexa — causality 렌즈
// 카테고리: T1 · 도메인: causal_chain_network
// 검증 축: 시간지연 인과 사슬, 경로 강도, 인과 루프 탐지

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 인과 사슬 루프 길이 공명: 2=φ, 3=n/φ, 4=τ, 6=n, 12=σ, 24=J₂
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[causal_chain_lens] category=T1 axis=\"시간지연 인과 사슬\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
