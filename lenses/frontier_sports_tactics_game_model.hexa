// frontier_sports_tactics_game_model.hexa — extended 렌즈 (Rust 포팅)
// 카테고리: extended · 도메인: sports
// 원본: frontier_lenses.rs · 이름: sports_tactics_game_model
// 검증 축: 스포츠 전술 게임 모델: 조직=n=6 원칙, 프레싱=tau=4, 포지션게임=phi=2, 전환=sigma=12 m/s, 깊이=1/n, 전술주기

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 렌즈별 핵심 상수 점검
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[sports_tactics_game_model] category=extended axis=\"스포츠 전술 게임 모델: 조직=n=6 원칙, 프레싱=tau=4, 포지션게임=phi=2, 전환=sigma=12 m/s, 깊이=1/n, 전술주기\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
