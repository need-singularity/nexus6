// cross_feed_signals.hexa — D3 확장 (cross_feed.hexa + atlas.signals.n6 input)
// 카테고리: extension · 도메인: cross-repo
// 역할: cross_feed.jsonl 의 direction 별 count 에 signal 태그 분포 덧붙이기
//
// 사용: hexa run $NEXUS/shared/lenses/cross_feed_signals.hexa

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let CROSS_FEED_JSONL = NEXUS + "/shared/harness/cross_feed.jsonl"
let SIGNALS = NEXUS + "/shared/n6/atlas.signals.n6"

fn count_cmd(cmd: string) -> i64 {
    let r = exec(cmd)
    let s_raw = if type_of(r) == "str" || type_of(r) == "string" { r } else { "0" }
    let s = s_raw.trim().split("\n")[0]
    let mut v: i64 = 0
    try { v = to_int(s) } catch e { v = 0 }
    return v
}

let n_feed = count_cmd("wc -l < '" + CROSS_FEED_JSONL + "' 2>/dev/null || echo 0")
let n_sig_nx = count_cmd("grep -c '\\[NX' '" + SIGNALS + "' 2>/dev/null || echo 0")
let n_sig_n6 = count_cmd("grep -c '\\[N6' '" + SIGNALS + "' 2>/dev/null || echo 0")
let n_sig_an = count_cmd("grep -c '\\[AN' '" + SIGNALS + "' 2>/dev/null || echo 0")
let n_sig_cross = count_cmd("grep -c '\\[CROSS' '" + SIGNALS + "' 2>/dev/null || echo 0")

println("lens[cross_feed_signals] category=extension axis=\"cross_feed queue + signal repo distribution\"")
println("  cross_feed.jsonl lines=" + to_string(n_feed))
println("  signal repo tags: [NX]=" + to_string(n_sig_nx) + " [N6]=" + to_string(n_sig_n6) + " [AN]=" + to_string(n_sig_an) + " [CROSS]=" + to_string(n_sig_cross))
