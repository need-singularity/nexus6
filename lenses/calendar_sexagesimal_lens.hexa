// calendar_sexagesimal_lens.hexa — calendar 렌즈
// 카테고리: T1 · 도메인: babylonian_sexagesimal
// 검증 축: 60진법 시간 체계, 360°, 24시간 = φ·σ

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 60진법: 60 = 10·n, 360° = 60·n, 24h = φ·σ = J₂
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[calendar_sexagesimal_lens] category=T1 axis=\"60진법 시간 체계\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
