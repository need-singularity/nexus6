// self_heal_lens.hexa — 자기 치유 렌즈
// 카테고리: T0 · 도메인: meta (오류 탐지·자동 복구)
// 검증 축: NaN/Inf, 차원붕괴, 이상치, 스케일 불균형, 중복, 액션 코드
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 6 액션 코드 (0 CLEAN ~ 5 CRITICAL), 모든 스캔 전 전처리
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, 3.0, 1.0]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[self_heal] category=T0 axis=\"6 healing actions\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
