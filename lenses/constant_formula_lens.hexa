// constant_formula_lens.hexa — constants 렌즈
// 카테고리: T1 · 도메인: formula_with_constants
// 검증 축: 공식 계수가 알려진 상수인 경우 탐지 (n=6 / math)

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 공식: n6(6,12,4,24,2,5,10,8,144,288,ln(4/3),4/3) + math(π,e,φ,√2,ln2) 계수
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[constant_formula_lens] category=T1 axis=\"constant-coefficient formula\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
