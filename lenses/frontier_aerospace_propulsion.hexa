// frontier_aerospace_propulsion.hexa — extended 렌즈 (Rust 포팅)
// 카테고리: extended · 도메인: engineering
// 원본: frontier_lenses.rs · 이름: aerospace_propulsion
// 검증 축: 항공우주 추진: Brayton=n=6 파라미터, 비추력=sigma=12 s, 노즐=tau=4, 압축비=phi=2, 팬압=1/n, Tsiolkov

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 렌즈별 핵심 상수 점검
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[aerospace_propulsion] category=extended axis=\"항공우주 추진: Brayton=n=6 파라미터, 비추력=sigma=12 s, 노즐=tau=4, 압축비=phi=2, 팬압=1/n, Tsiolkov\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
