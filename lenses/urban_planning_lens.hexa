// urban_planning_lens.hexa — T1 렌즈 (도시계획)
// 카테고리: T1 · 도메인: urban_planning (BT-267)
// 검증 축: 크리스탈러 육각 n=6·존 n=6·블록 σ=12·J₂=24 district
// 원본: nexus/src/telescope/lenses/urban_planning_lens.rs
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 육각 존·블록 σ·J₂ district·중심 n·φ·링 τ
let targets = [N, SIGMA, J2, N * PHI, TAU, PHI]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[urban_planning] category=T1 axis=\"도시계획 육각\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
