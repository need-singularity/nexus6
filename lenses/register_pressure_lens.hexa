// register_pressure_lens.hexa — compiler 렌즈 (레지스터 압력 · 스필 예방)
// 카테고리: compiler · 축: compiler
// 원본: nexus/src/telescope/lenses/register_pressure_lens.rs
//
// 알고리즘:
//   1. peak_liveness: 동시 활성 값 최대 (차원 정규화)
//   2. spill_risk: 임계값 초과 행 비율
//   3. liveness_variance: 활성도 분산 (버스티 = 스케줄 난이도)
//   4. reuse_distance: 유사값 재사용 간격
//   5. pressure_score: 전체 레지스터 압력 (0=낮음, 1=임계)
// pressure = peak·0.3 + spill·0.3 + var·0.2 + reuse·0.2

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축: 64비트 아키 n=6 레지스터 클래스, τ=4 예약 레지스터
let REG_SPILL_THR = 0.75
let REG_BINS = 16.0
let targets = [N, TAU, SIGMA, PHI, J2, REG_BINS, SIGMA * PHI, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[register_pressure] category=compiler axis=\"레지스터 압력\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
