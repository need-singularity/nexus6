// networking_protocol_lens.hexa — compute 렌즈 (네트워크 프로토콜, BT-115,BT-140)
// 카테고리: T1 · 도메인: networking_protocol
// 검증 축: OSI=7=σ−SOPFR / TCP/IP=4=τ / Linux=n=6
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: OSI 7, TCP/IP τ=4, Linux n=6, σ·τ=48
let OSI_LAYERS = 7.0
let SIGMA_TAU_PORT = 48.0

let targets = [OSI_LAYERS, TAU, N, SIGMA, J2, SIGMA_TAU_PORT]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[networking_protocol] category=T1 axis=\"OSI=7 / TCP/IP=τ=4 / Linux=n=6\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
