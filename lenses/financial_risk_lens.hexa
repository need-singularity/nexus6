// financial_risk_lens.hexa — T1 렌즈 (금융 리스크)
// 카테고리: T1 · 도메인: finance (BT-147, BT-338)
// 검증 축: 변동성 1/(σ-φ)=0.1, 바젤 τ 레벨, 분기 n
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 원본: FinancialRiskLens — 금융 리스크 파라미터

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[financial_risk_lens] category=T1 axis=\"변동성 1/(σ-φ)=0.1·바젤 τ·분기 n\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
