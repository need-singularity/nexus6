// acoustic_lens.hexa — 음향 렌즈
// 카테고리: T1 · 도메인: acoustics (음파 주기·고조파·공명)
// 검증 축: 자기상관 라그 → 6 배음 정렬, 배진 2·3·6 = 완전수 약수
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 음향 렌즈 고조파 배열 = 6의 약수 구조 {1,2,3,6}
// 12 반음 = σ, 옥타브 2배 = φ, 기본 주기 n=6
let targets = [N, PHI, TAU, SIGMA, SOPFR, J2, 1.0, 3.0]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[acoustic] category=T1 axis=\"6-harmonic series\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
