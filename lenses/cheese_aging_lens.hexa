// cheese_aging_lens.hexa — food_science 렌즈
// 카테고리: T1 · 도메인: cheese_aging
// 검증 축: 숙성 단계, pH=n, 온도 n²+1, 수분/단백질=φ

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 치즈: pH=6=n, 37°C=n²+1, 숙성 σ개월 최소, 파르미지아노 σ~σ·τ-τ 개월
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[cheese_aging_lens] category=T1 axis=\"치즈 발효/숙성 n=6 파라미터\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
