// frontier_digital_modulation.hexa — extended 렌즈 (Rust 포팅)
// 카테고리: extended · 도메인: communications
// 원본: frontier_lenses.rs · 이름: digital_modulation
// 검증 축: 디지털 변조 M-QAM: 성상도=n^phi=36 (6-QAM), 최소 거리=1/n, BER=phi/sigma, 스펙트럼 효율=log₂(n)

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 렌즈별 핵심 상수 점검
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[digital_modulation] category=extended axis=\"디지털 변조 M-QAM: 성상도=n^phi=36 (6-QAM), 최소 거리=1/n, BER=phi/sigma, 스펙트럼 효율=log₂(n)\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
