// dead_code_lens.hexa — compiler 렌즈 (데드코드 감지)
// 카테고리: compiler · 도메인: compiler
// 검증 축: 제로-임팩트 차원, 미도달 영역, 죽은 할당
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 원본: DeadCodeLens — dead dimension fraction, unreachable fraction,
// dead allocation score, zero-impact score, branch liveness, effective dim

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 렌즈별 핵심 상수 점검
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[dead_code_lens] category=compiler axis=\"제로-임팩트 차원/미도달/죽은할당\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
