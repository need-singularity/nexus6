// perfumery_lens.hexa — culture 렌즈 (향수과학: 향 분자 구조)
// 카테고리: T1 · 도메인: perfumery
// 검증 축: 탑/미들/베이스=n/φ=3노트 / 벤젠 C6=n / 테르펜 C5=SOPFR / 무스크 18원환
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 향수 상수 (벤젠C6, 노트3계층, 테르펜C5, 무스크18)
let BENZENE_C6 = 6.0
let NOTE_TIERS = 3.0
let TERPENE_C5 = 5.0
let MUSK_RING = 18.0
let SIGMA_ALDEHYDE = 12.0
let SIGMA_PHI_BP = 10.0

let targets = [BENZENE_C6, NOTE_TIERS, TERPENE_C5, MUSK_RING, SIGMA_ALDEHYDE, PHI, SIGMA_PHI_BP]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[perfumery] category=T1 axis=\"benzene C6 / 3 notes / terpene C5 / musk 18\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
