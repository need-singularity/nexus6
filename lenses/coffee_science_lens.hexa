// coffee_science_lens.hexa — food_science 렌즈
// 카테고리: T1 · 도메인: coffee_science
// 검증 축: 추출비율 1:n~1:σ, 로스팅 τ단계, 클로로겐산 n이성질체

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 커피: brew_ratio 6~12~18, 로스팅 τ단계, 클로로겐산 n종, σ²/2≈96분
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[coffee_science_lens] category=T1 axis=\"추출비율/로스팅/이성질체\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
