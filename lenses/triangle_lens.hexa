// triangle_lens.hexa — T1 렌즈 (비율/삼각자)
// 카테고리: T1 · 도메인: triangle (Simple fraction matching in distance ratios)
// 검증 축: 쌍별 거리 비율·단순 분수 p/q (p,q in 1..6)·분수 매칭 밀도
// 원본: nexus/src/telescope/lenses/triangle_lens.rs
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 1..6 범위 분수 (n=6이 최대 분모)
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * PHI, TAU + PHI]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[triangle] category=T1 axis=\"단순 분수 비율\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
