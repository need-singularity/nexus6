// food_web_lens.hexa — T1 렌즈 (먹이그물)
// 카테고리: T1 · 도메인: ecology (BT-178, BT-201, BT-233)
// 검증 축: 영양 단계 6, 포식-피식 σ/τ=3, 생물량 피라미드 6층
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 원본: FoodWebLens — 영양 계층 구조

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[food_web_lens] category=T1 axis=\"영양 단계 6·σ/τ=3·생물량 6층\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
