// rail_transport_lens.hexa — T1 렌즈 (철도 수송 BT-278)
// 카테고리: T1 · 축: transport
// 원본: nexus/src/telescope/lenses/rail_transport_lens.rs
// n=6 연결: SIL τ=4 안전레벨, n=6 궤도회로, σ=12 차축, 250→500→750 배증
//
// 알고리즘:
//   1. 도메인 상수 매칭: 평균 ≈ {4,6,12,1.5,25,50} 허용오차 8%
//   2. n6_rail_matches / d = 점수
// score = 매칭 비율

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 상수: SIL=τ, track=n, axle=σ, phi_doubling=2
let TRACK_GAUGE = 1.5
let FREQ_50 = 50.0
let KV_25 = 25.0

let targets = [TAU, N, SIGMA, TRACK_GAUGE, KV_25, FREQ_50, J2, PHI]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[rail_transport] category=T1 axis=\"철도 수송\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
