// behavioral_economics_lens.hexa — 행동경제학 렌즈
// 카테고리: T1 · 도메인: behavioral_economics (BT-143/189/212)
// 검증 축: 6 인지 편향 클러스터, 손실회피 계수 φ=2, 선택 과부하 임계 n=6
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 원본 bias_consts = [6, 2, 4, 3, 12, 24]
let targets = [N, PHI, TAU, 3.0, SIGMA, J2]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[behavioral_economics] category=T1 axis=\"loss aversion φ=2 · choice 6\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
