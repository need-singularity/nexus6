// recursion_lens.hexa — T0 렌즈 (재귀 · 자기유사성 탐지)
// 카테고리: T0 · 축: recursion
// 원본: nexus/src/telescope/lenses/recursion_lens.rs
//
// 알고리즘:
//   1. 전체 데이터셋 거리 분포 히스토그램 계산
//   2. 1/2, 1/3, 1/4 스케일 하위샘플 거리 분포 계산
//   3. 자기유사성 = KL 발산(하위샘플 vs 전체)
//   4. 낮은 발산 = 프랙탈/자기유사 구조
// self_similarity = 1 / (1 + mean_kl)

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축: 1/φ=0.5, 1/3, 1/τ=0.25 자기유사 스케일 비율
let targets = [N, TAU, SIGMA, PHI, J2, N / PHI, N / TAU, SIGMA / N]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[recursion] category=T0 axis=\"자기유사성\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
