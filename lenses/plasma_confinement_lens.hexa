// plasma_confinement_lens.hexa — energy 렌즈 (플라즈마 가둠, BT-317,BT-243)
// 카테고리: T1 · 도메인: plasma_confinement
// 검증 축: TF 코일=3n=18 / PF=n=6 / q=τ/φ=2 / 가열=τ=4
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 토카막/스텔라레이터 자기장 코일
let PF_COILS = N
let TF_COILS = 18.0
let Q_HEATING = TAU
let Q_SAFETY = PHI

let targets = [PF_COILS, TF_COILS, Q_HEATING, Q_SAFETY, SIGMA, J2]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[plasma_confinement] category=T1 axis=\"PF=n / TF=18 / q=τ/φ / heating=τ\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
