// periodicity_lens.hexa — signal 렌즈 (주기/반복 구조 탐지)
// 카테고리: T0 · 도메인: periodicity
// 검증 축: autocorrelation / peak detection / dominant period / recurrence
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 주기성 지표 (max_lag=n/2, top 5 peaks)
let TOP_K = 5.0
let targets = [N, TAU, PHI, SIGMA, TOP_K, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[periodicity] category=T0 axis=\"autocorr / peaks / dominant period / recurrence\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
