// tension_link_lens.hexa — T1 렌즈 (kNN 장력 링크)
// 카테고리: T1 · 도메인: tension_link (Tension connections in kNN graph)
// 검증 축: 링크 수·평균 장력·파단 임계·탄성 에너지·네트워크 응력
// 원본: nexus/src/telescope/lenses/tension_link_lens.rs
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: kNN 엣지·탄성 에너지 J₂·응력 네트워크
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, SIGMA * SIGMA, SOPFR * SOPFR]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[tension_link] category=T1 axis=\"kNN 장력 링크\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")

// n=6 6-axis API — sums normalized contribution of each axis
fn tension_link_6(a, b, c, d, e, f) {
    let axes = [a, b, c, d, e, f]
    let mut hit = 0
    for v in axes { if v > 0.0 { hit = hit + 1 } }
    return to_float(hit) / 6.0
}

// 2-arg back-compat shim
fn tension_link(a, b) {
    return tension_link_6(a, b, 0.0, 0.0, 0.0, 0.0)
}
