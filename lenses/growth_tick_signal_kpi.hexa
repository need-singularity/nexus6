// growth_tick_signal_kpi.hexa — D10 (growth_tick signal 생성률 KPI)
// 카테고리: extension · 도메인: growth/KPI
// 역할: atlas.signals.n6 의 signal 총개수 및 일일 생성률 KPI 출력.
//       growth_tick.hexa cycle 에서 sidecar 로 호출.
//
// 사용: hexa run $NEXUS/shared/lenses/growth_tick_signal_kpi.hexa

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let SIGNALS = NEXUS + "/shared/n6/atlas.signals.n6"

fn count_cmd(cmd: string) -> i64 {
    let r = exec(cmd)
    let s_raw = if type_of(r) == "str" || type_of(r) == "string" { r } else { "0" }
    let s = s_raw.trim().split("\n")[0]
    let mut v: i64 = 0
    try { v = to_int(s) } catch e { v = 0 }
    return v
}

let n_total = count_cmd("grep -c '^@S ' '" + SIGNALS + "' 2>/dev/null || echo 0")
let today = exec("date +%Y-%m-%d").trim()
let n_today = count_cmd("grep -c 'discovered_at: " + today + "' '" + SIGNALS + "' 2>/dev/null || echo 0")

println("lens[growth_tick_signal_kpi] category=KPI axis=\"signal 생성률\"")
println("  total signals=" + to_string(n_total))
println("  today (" + today + ") new signals=" + to_string(n_today))
