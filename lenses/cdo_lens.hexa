// cdo_lens.hexa — operations 렌즈
// 카테고리: T0 · 도메인: convergence_driven_ops
// 검증 축: 재발 탐지, 수렴 속도, 규칙 승격 시그널 (φ=2회 위반→승격)

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// CDO: 1회=기록, 2회=φ 승격, 3회=n/φ 재설계
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[cdo_lens] category=T0 axis=\"수렴 기반 운영\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
