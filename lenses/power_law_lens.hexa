// power_law_lens.hexa — stat 렌즈 (멱법칙 / 스케일 프리)
// 카테고리: T1 · 도메인: power_law
// 검증 축: log-log CDF fit / exponent α / n=6 exponents (4/3, 5/3, 2, 5/2, 3)
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: n=6 멱법칙 지수 {1, 4/3, 3/2, 5/3, 2, 5/2, 3}
let E_MU = 1.0
let E_TAU2_SIGMA = 4.0 / 3.0
let E_N_TAU = 3.0 / 2.0
let E_SOPFR_NPHI = 5.0 / 3.0
let E_PHI = 2.0
let E_SOPFR_PHI = 5.0 / 2.0
let E_N_PHI = 3.0

let targets = [E_MU, E_TAU2_SIGMA, E_N_TAU, E_SOPFR_NPHI, E_PHI, E_SOPFR_PHI, E_N_PHI]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[power_law] category=T1 axis=\"α∈{1,4/3,3/2,5/3,2,5/2,3}\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
