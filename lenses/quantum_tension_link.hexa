// quantum_tension_link.hexa — extended 렌즈 (Rust 포팅)
// 카테고리: extended · 도메인: network
// 원본: quantum_lenses.rs · 이름: tension_link
// 검증 축: Tension link — track pairs of elements connected by stress/strain relationships

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 렌즈별 핵심 상수 점검
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[tension_link] category=extended axis=\"Tension link — track pairs of elements connected by stress/strain relationships\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")

// n=6 6-axis API — normalized hit-rate over 6 dimensions
fn tension_link_6(a, b, c, d, e, f) {
    let axes = [a, b, c, d, e, f]
    let mut hit = 0
    for v in axes { if v > 0.0 { hit = hit + 1 } }
    return to_float(hit) / 6.0
}

// 2-arg back-compat shim
fn tension_link(a, b) {
    return tension_link_6(a, b, 0.0, 0.0, 0.0, 0.0)
}
