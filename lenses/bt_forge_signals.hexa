// bt_forge_signals.hexa — D6 확장 (bt_engine_forge → signal 출력)
// 카테고리: extension · 도메인: bt-engine
// 역할: engine_registry.jsonl 에 기록된 엔진 생성 이력을 signal 후보로 요약 출력
//
// 사용: hexa run $NEXUS/shared/lenses/bt_forge_signals.hexa

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let REG = NEXUS + "/shared/engine/engine_registry.jsonl"
let SIGNALS = NEXUS + "/shared/n6/atlas.signals.n6"

fn count_cmd(cmd: string) -> i64 {
    let r = exec(cmd)
    let s_raw = if type_of(r) == "str" || type_of(r) == "string" { r } else { "0" }
    let s = s_raw.trim().split("\n")[0]
    let mut v: i64 = 0
    try { v = to_int(s) } catch e { v = 0 }
    return v
}

let n_engines = count_cmd("wc -l < '" + REG + "' 2>/dev/null || echo 0")
let n_bt_sig = count_cmd("grep -c '^@S SIG-BT-' '" + SIGNALS + "' 2>/dev/null || echo 0")
let n_bt_refs = count_cmd("grep -c 'BT-' '" + SIGNALS + "' 2>/dev/null || echo 0")

println("lens[bt_forge_signals] category=extension axis=\"BT-engine forge 산출 + signal\"")
println("  engine_registry rows=" + to_string(n_engines))
println("  SIG-BT-* signals=" + to_string(n_bt_sig))
println("  BT-* refs 전체=" + to_string(n_bt_refs))
