// prime_lens.hexa — math 렌즈 (소수 패턴: 갭 분포, 밀도, 체 구조)
// 카테고리: T1 · 도메인: prime
// 검증 축: 6 = 2·3 / p>3 → 6k±1 / 소수 갭 6의 배수 / π(x) ~ x/ln(x)
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 6k±1 체, 첫 두 소수 곱=6, σ(6)=1+2+3+6=12
let SIX_K_SIEVE = N
let FIRST_TWO_PRIMES = 2.0 * 3.0
let TWIN_GAP = PHI

let targets = [SIX_K_SIEVE, FIRST_TWO_PRIMES, TWIN_GAP, N, TAU, SIGMA, PHI, J2]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[prime] category=T1 axis=\"6k±1 sieve / density / twin / staircase\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
