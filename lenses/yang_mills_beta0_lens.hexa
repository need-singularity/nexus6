// yang_mills_beta0_lens.hexa — physics 렌즈 (Yang-Mills β₀)
// 카테고리: physics · 도메인: yang_mills_beta0 (BT-543)
// 검증 축: β₀ = σ−sopfr = 12−5 = 7·쿼크 맛 n_f=6·τ(6)=4 게이지 보존
// 원본: nexus/src/telescope/lenses/yang_mills_beta0_lens.rs
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: β₀ = σ−sopfr = 7·n_f=6·τ×sopfr=20
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, SIGMA - SOPFR, TAU * SOPFR]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[yang_mills_beta0] category=physics axis=\"Yang-Mills β₀\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
