// thermoplastic_process_lens.hexa — T1 렌즈 (열가소성 가공)
// 카테고리: T1 · 도메인: thermoplastic_process (BT-131)
// 검증 축: zone_n·residence_tau·pressure_sigma·screw_phi·shot_J2·stage_3
// 원본: nexus/src/telescope/lenses/thermoplastic_process_lens.rs
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 도메인 상수 [6,4,12,2,24,3]
let targets = [N, TAU, SIGMA, PHI, J2, N * PHI]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[thermoplastic_process] category=T1 axis=\"열가소성 가공\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
