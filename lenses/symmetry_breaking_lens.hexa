// symmetry_breaking_lens.hexa — 대칭성 파괴 렌즈
// 카테고리: T1 · 도메인: symmetry (skewness·좌우불균형)
// 검증 축: per-feature skewness, mean-based asymmetry, pair asymmetry
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: n 비대칭 축 → 6 숨겨진 구조 노출
let targets = [N, PHI, TAU, SIGMA, SOPFR, J2, 3.0, 1.0]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[symmetry_breaking] category=T1 axis=\"skewness asymmetry\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
