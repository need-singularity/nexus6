// nuclear_reactor_lens.hexa — energy 렌즈 (핵반응로, BT-98,BT-291)
// 카테고리: T1 · 도메인: nuclear_reactor
// 검증 축: fuel_rods_6 / enrichment_4 / coolant_loop_6 / cycle_18 / output_sigma
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 반응로 상수 [6.0, 4.0, 18.0, 12.0, 24.0, 3.0]
let CYCLE_18 = 18.0
let targets = [N, TAU, CYCLE_18, SIGMA, J2, 3.0]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[nuclear_reactor] category=T1 axis=\"fuel_rods=n / enrichment=τ / cycle=18 / output=σ\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
