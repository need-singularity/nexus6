// refraction_lens.hexa — T1 렌즈 (굴절 · 계면 굴절률)
// 카테고리: T1 · 축: optics
// 원본: nexus/src/telescope/lenses/refraction_lens.rs
//
// 알고리즘:
//   1. 신호를 두 매질로 분할 (상/하)
//   2. 각 매질 "속도" = 평균 |1차 미분|
//   3. 굴절률 = v1/v2
//   4. 스넬 법칙 점수: atan(미분) 각도 비교
//   5. 임계각 = asin(1/n)
//   6. 분산: 평활화 속도비 vs 원본 속도비 차이

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축: 굴절률 2=φ (가시광-유리), n=6 차원 광학 공간
let N_WATER = 4.0 / 3.0
let N_GLASS = PHI
let targets = [N, TAU, SIGMA, PHI, J2, N_WATER, N_GLASS, TAU * PHI]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[refraction] category=T1 axis=\"굴절\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
