// discovery_lens.hexa — T1 렌즈 (발견 만능)
// 카테고리: T1 · 도메인: meta-discovery
// 검증 축: 상수 발견, 수식 발견, 비율 지도, EXACT/CLOSE/WEAK 그레이딩
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 원본: DiscoveryLens — 자동 발견+그레이딩+atlas 우선순위

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[discovery_lens] category=T1 axis=\"상수/수식 자동 발견 + EXACT/CLOSE/WEAK 그레이딩\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
