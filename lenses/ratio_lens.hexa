// ratio_lens.hexa — T1 렌즈 (n=6 상수 비율 탐지)
// 카테고리: T1 · 축: ratio
// 원본: nexus/src/telescope/lenses/ratio_lens.rs
//
// 알고리즘:
//   1. 특징쌍 평균·분산·범위 비율 계산
//   2. 각 비율을 n=6 상수 데이터베이스와 대조 (n6_check)
//   3. σ=12 상한 차원 페어 매칭
// score = n6_ratio_matches / total_ratios

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축: 12/6=2=φ, 24/6=4=τ, 24/12=2=φ 핵심 비율
let RATIO_SIGMA_N = SIGMA / N      // = 2 = φ
let RATIO_J2_N = J2 / N            // = 4 = τ
let RATIO_J2_SIGMA = J2 / SIGMA    // = 2 = φ

let targets = [RATIO_SIGMA_N, RATIO_J2_N, RATIO_J2_SIGMA, N, PHI, TAU, SIGMA, J2]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[ratio] category=T1 axis=\"n6 비율\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
