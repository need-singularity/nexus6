// satellite_orbit_lens.hexa — 위성 궤도 렌즈
// 카테고리: T1 · 도메인: space (케플러 궤도 6요소)
// 검증 축: orbital_elements=6, GPS planes=6, LEO≈τ·100km, 원형속도≈7.9 km/s
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 케플러 6요소 (a,e,i,Ω,ω,ν)=n, GPS 6궤도면=n, LEO τ·100km, 원형속도 7.9
let targets = [N, TAU, SIGMA, PHI, SOPFR, 7.9, J2, N * N]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[satellite_orbit] category=T1 axis=\"Kepler 6 elements\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
