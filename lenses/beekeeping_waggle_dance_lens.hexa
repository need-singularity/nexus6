// beekeeping_waggle_dance_lens.hexa — 꿀벌 8자 춤 렌즈
// 카테고리: T1 · 도메인: beekeeping_waggle_dance (정보 전달)
// 검증 축: 1초 waggle = n km, 정족수 6, 방향 15°/45°
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: waggle 1~6초, 방향 15°·45°, 정족수 6, 8자 주기 2
let DEG15 = 15.0
let DEG45 = 45.0
let targets = [1.0, PHI, 3.0, TAU, SOPFR, N, DEG15, DEG45, SIGMA]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[beekeeping_waggle_dance] category=T1 axis=\"waggle 1s/km · quorum 6\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
