// dentistry_lens.hexa — T1 렌즈 (치의학)
// 카테고리: T1 · 도메인: dentistry (BT-286)
// 검증 축: 4분면(τ), 치아(J₂), 치근(n), 근관(φ), 교합(σ), 임플란트(3)
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 원본: DentistryLens — n=6: quadrant_tau:tooth_J2:root_n:canal_phi:occlusal_sigma:implant_3

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[dentistry_lens] category=T1 axis=\"4분면·치아·치근·근관·교합·임플란트\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
