// brain_map_lens.hexa — 뇌지도/의식지도 렌즈
// 카테고리: T1 · 도메인: brain_map (기능 연결성 네트워크)
// 검증 축: n=6 기능 영역, σ=12 연결 매트릭스, J₂=24 최대 노드, 좌우 대칭=φ
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: n=6 영역, σ=12, J₂=24 노드 cap, threshold=0.3
// small-world CC, avg path, hub_ratio, bilateral=φ
let CONN_THR = 0.3
let targets = [N, PHI, TAU, SIGMA, J2, CONN_THR, SOPFR, 3.0]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[brain_map] category=T1 axis=\"6-region · σ-connectivity · J₂-cap\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
