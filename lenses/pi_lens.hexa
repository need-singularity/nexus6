// pi_lens.hexa — math 렌즈 (π 관련 패턴: 원형성, 각균일, 비율)
// 카테고리: T1 · 도메인: pi
// 검증 축: circularity / pi ratio / angular uniformity / Buffon 2/π
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: π·6 = 육각형/원 n=6 grid
// σ(6)·φ(6) = 6·τ(6), 육각형 면적 = 3√3/2·r² ≈ πr²
let PI_APPROX = 3.141592653589793
let TWO_OVER_PI = 2.0 / PI_APPROX
let HEX_GRID = N

let targets = [PI_APPROX, TWO_OVER_PI, HEX_GRID, N, TAU, SIGMA, PHI, J2]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[pi] category=T1 axis=\"circularity / π ratio / angular / Buffon 2/π\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
