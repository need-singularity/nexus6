// sailing_navigation_lens.hexa — 항해 항법 렌즈 (BT-279)
// 카테고리: T1 · 도메인: navigation (항해·나침반·조류·당직)
// 검증 축: point_compass_sigma:knot_phi:tide_n:watch_tau:bearing_J2:rule_3
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 나침반 12방위=σ, 노트속도=φ, 조수 n=6, 당직 τ=4, 방위각 J₂, 삼법칙 3
let targets = [SIGMA, PHI, N, TAU, J2, 3.0, SOPFR, N * N]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[sailing_navigation] category=T1 axis=\"compass-tide-watch 6\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
