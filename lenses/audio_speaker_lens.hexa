// audio_speaker_lens.hexa — 오디오/스피커 렌즈
// 카테고리: T1 · 도메인: audio_speaker (BT-1136~1141)
// 검증 축: 드라이버=τ, 포인트소스=n, 임피던스=σ/τ/8, 크로스오버=n/τ, 서라운드=n
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: N=6(5.1채널·고조파), TAU=4(드라이버 종류), SIGMA=12(임피던스)
// PHI=2(스테레오), SOPFR=5(1W/1m+tau), IMP8=σ-τ, MU=1(감도)
let IMP8 = SIGMA - TAU
let MU = 1.0
let targets = [N, TAU, SIGMA, PHI, SOPFR, MU, IMP8, 3.0]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[audio_speaker] category=T1 axis=\"driver/impedance/crossover/surround\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
