// compass_lens.hexa — geometry 렌즈
// 카테고리: T0 · 도메인: menger_curvature
// 검증 축: 삼중점 Menger 곡률, 평균/분산

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 곡률/컴퍼스: 삼중점 Menger 곡률 = 4·면적/(d01·d02·d12)
let targets = [N, TAU, SIGMA, PHI, SOPFR, J2, N * N, TAU * TAU]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[compass_lens] category=T0 axis=\"Menger curvature triples\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
