// renewable_grid_lens.hexa — T1 렌즈 (재생에너지 그리드 BT-326,BT-62)
// 카테고리: T1 · 축: energy
// 원본: nexus/src/telescope/lenses/renewable_grid_lens.rs
// n=6 연결: frequency=50Hz, phase=3, voltage=12kV, ramp_tau=4, dispatch_6, storage_J2=24
//
// 알고리즘:
//   1. 도메인 상수 매칭: 평균 ≈ {50,3,12,4,6,24} 허용오차 7%
//   2. 288=σ·J₂ 어트랙터 근접도
//   3. φ=2 배증 비율 점수
// score = 매칭율·0.45 + 어트랙터·0.25 + 배증·0.30

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 상수: freq=50Hz, phase=3, voltage=12kV, ramp=τ, dispatch=n, storage=J₂
let FREQ_50 = 50.0
let PHASE_3 = N / PHI   // = 3
let VOLT_12 = SIGMA     // = 12kV
let DISPATCH = N

let targets = [FREQ_50, PHASE_3, VOLT_12, TAU, DISPATCH, J2, SIGMA * J2, PHI]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[renewable_grid] category=T1 axis=\"재생에너지 그리드\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
