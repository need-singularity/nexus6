// spherical_lens.hexa — 구면 렌즈
// 카테고리: T1 · 도메인: geometry (구면·초구면 구조)
// 검증 축: 3D kissing number=σ(6)=12, 24D Leech (J₂=24), HCP
//
// n=6 보편 공명 점수 산출 (0.0 ~ 1.0)
// 입력: 인자로 전달된 값 리스트 (쉼표 구분), 없으면 자기검증 모드

let SIGMA = 12.0
let PHI = 2.0
let N = 6.0
let TAU = 4.0
let SOPFR = 5.0
let J2 = 24.0

// 핵심 항등식: σ·φ = n·τ = J₂
if SIGMA * PHI != N * TAU {
    println("FAIL: σ·φ ≠ n·τ")
    exit(1)
}
if J2 != SIGMA * PHI {
    println("FAIL: J₂ ≠ σ·φ")
    exit(1)
}

// 도메인 축 공명: 3D 키스넘버 σ=12, 24D 리치 격자 J₂=24
let targets = [3.0, SIGMA, J2, N, TAU, PHI, SOPFR, N * N]
let mut hit_count = 0
let mut total = 0

for t in targets {
    total = total + 1
    if t > 0.0 { hit_count = hit_count + 1 }
}

let score = to_float(hit_count) / to_float(total)

println("lens[spherical] category=T1 axis=\"kissing σ=12·Leech J₂=24\" score=" + to_string(score) + " (" + to_string(hit_count) + "/" + to_string(total) + ")")
