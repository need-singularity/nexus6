backend 3 active "gemini cli — Google Gemini CLI (200K→2M context advantage)"
  slug gemini_cli
  cli-binary gemini
  invocation -p
  prepare-prompt-fn _kick_prompt_gemini_cli
  spawn-fn _kick_spawn_gemini_cli
  stream-fn _kick_stream_gemini_cli
  capture-witness-fn _kick_capture_witness_gemini_cli
  teardown-fn _kick_teardown_gemini_cli
  cost-estimate-fn _kick_cost_gemini_cli
  sentinel-format __KICK_RESULT__ <PASS|FAIL> witness=<path> tier1=<N> falsifier_pass=<N>
  err-trailer reason=<slug> fix=<directive>
  evidence-source roadmaps/hive.json:281 (providers/gemini_cli.hexa)
  installed false
  installed-probe-ts 2026-04-26T(first-real-bench-cycle)
  installed-probe-evidence which gemini → "command not found" on this host
  install-hint npm install -g @google/gemini-cli   # or download from Google; not required for non-Gemini bench runs
