# state/kick/registry/backends/claude_code.hexa
# kick(ω-cycle) backend registry — Anthropic claude code CLI.
# Format: indented key/value DSL (parsed by tool/kick_tree.hexa).
# Shape verbatim from architecture witness next_cycle_handoff.registry_dsl_example.

backend 1 active "claude code cli — Anthropic CLI in headless -p mode"
  slug claude_code
  cli-binary claude
  invocation -p --output-format stream-json
  prepare-prompt-fn _kick_prompt_claude_code
  spawn-fn _kick_spawn_claude_code
  stream-fn _kick_stream_claude_code
  capture-witness-fn _kick_capture_witness_claude_code
  teardown-fn _kick_teardown_claude_code
  cost-estimate-fn _kick_cost_claude_code
  sentinel-format __KICK_RESULT__ <PASS|FAIL> witness=<path> tier1=<N> falsifier_pass=<N>
  err-trailer reason=<slug> fix=<directive>
  evidence-source roadmaps/hive.json:152 (providers/claude_code.hexa)
  multi-slot-pool ~/.claude-claude<N>
  slot-helper tool/claude_slot_pick.hexa
  slot-policy lru
  slot-cooldown-cache .kick_limit_until (per-slot, JSON; session 5h + weekly 7d)
  slot-last-used-cache .kick_last_used (per-slot, ISO line)
  slot-rate-limit-signals stream-json:rate_limit_event hive-terminal:Claude-Pro/Max-quota-exhausted
  phantom-guard literal-glob ls -1d ~/.claude-claude* + digits-only suffix validation
  slots-list-cli nexus kick slots [--json] [--include-phantom] [--refresh]
  multi-slot-landed-ts 2026-04-26T(this-omega-cycle)
  multi-slot-landed-evidence design/kick/2026-04-26_nexus-kick-claude-code-backend-multi-slot-autopick-slots-lis_omega_cycle.json
