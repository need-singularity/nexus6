# state/kick/registry/noise_sources/bridges/bridge_claude_changelog.hexa
# kick(ω-cycle) noise-source registry — bridge:claude_changelog (γ source, kind=web-fetch).
#
# U1 wave Layer (γ-bridge wave U1 2026-05-01) — 19th of 22 bridges in the
# enriched γ rotation. Provides a slow-cadence release-signal envelope: what
# is the latest Claude Code release / changelog entry? Tracks upstream feature
# velocity as a γ noise source (semantic, not stochastic).
#
# URL (constant):
#   https://docs.anthropic.com/en/release-notes/claude-code
#
# Payload contract (≤ 200 chars):
#   "latest_version=<X.Y.Z> entries=<N> first_title=<truncated>"
# Example:
#   "latest_version=1.27.4 entries=42 first_title=fix:tool_search_ranking"
#
# Implementation: tool/claude_changelog_bridge_fetcher.hexa invokes M-Y
# browser-harness (tui_extract_text_from) to fetch the rendered changelog HTML
# then substring-extracts the first <h2>/<h3> entry + a semver token. If the
# harness is absent, OFFLINE-FALLBACK emits status=offline_fallback (raw 91).
#
# Prompt-injection protection (HARD requirement, U1 charter):
#   - reject substring scan: <task-notification>, <system-reminder>, IMPORTANT:
#   - HTML/JS strip: drop <script>...</script>, on<event>=, javascript:, <style>
#   - control-char strip + executable pattern reject (`$(`, backtick, "rm -rf")
#   - payload_summary clamped to 200 chars after sanitize
#
# Default state: 0 inactive (opt-in via env KICK_USE_WEB_BRIDGES=1).
# kind=web-fetch — distinguishes from kind=static / kind=hardware.
#
# raw refs: raw 9, raw 47, raw 91, raw 232.

noise-source 0 inactive "bridge:claude_changelog — Claude Code release notes feed (web-fetch)"
  slug bridge_claude_changelog
  kind web-fetch
  invocation tool/claude_changelog_bridge_fetcher.hexa --fetch
  offline-fallback true
  source-tag claude_changelog
  registry-of-record state/kick/registry/noise_sources/bridges/bridge_claude_changelog.hexa
  evidence-source tool/claude_changelog_bridge_fetcher.hexa::fetch (M-Y tui_extract_text_from)
  fetch-url https://docs.anthropic.com/en/release-notes/claude-code
  opt-in-gate KICK_USE_WEB_BRIDGES=1
  payload-summary-format "latest_version=<X.Y.Z> entries=<N> first_title=<truncated>"
  payload-summary-max-chars 200
  prompt-injection-strip true
  design-tier 2026-05-01
  raw-refs raw_9 raw_47 raw_91 raw_232
