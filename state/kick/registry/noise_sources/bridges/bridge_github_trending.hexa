# state/kick/registry/noise_sources/bridges/bridge_github_trending.hexa
# kick(ω-cycle) noise-source registry — bridge:github_trending (γ source, kind=web-fetch).
#
# U1 wave Layer (γ-bridge wave U1 2026-05-01) — 21st of 22 bridges in the
# enriched γ rotation. Provides a daily ecosystem-velocity signal: which Python
# repos are trending today on GitHub? Useful as a reframe seed for "is the ω
# discovery I'm doing already a trending OSS project" sanity checks.
#
# URL (constant):
#   https://github.com/trending/python?since=daily
#
# Payload contract (≤ 200 chars):
#   "n_repos=<N> top_repo=<owner/name> stars_today=<N>"
# Example:
#   "n_repos=25 top_repo=anthropic/claude-code stars_today=1421"
#
# Implementation: tool/github_trending_bridge_fetcher.hexa invokes M-Y
# browser-harness (tui_extract_text_from) on the rendered trending page then
# substring-extracts the first <h2><a href="/owner/name"> match + a "stars
# today" integer. OFFLINE-FALLBACK on harness absence (raw 91).
#
# Prompt-injection protection (HARD requirement, U1 charter):
#   - reject substring scan: <task-notification>, <system-reminder>, IMPORTANT:
#   - HTML/JS strip: drop <script>...</script>, on<event>=, javascript:, <style>
#   - control-char strip + executable pattern reject (`$(`, backtick, "rm -rf")
#   - payload_summary clamped to 200 chars after sanitize
#
# Default state: 0 inactive (opt-in via env KICK_USE_WEB_BRIDGES=1).
# kind=web-fetch.
#
# raw refs: raw 9, raw 47, raw 91, raw 232.

noise-source 0 inactive "bridge:github_trending — GitHub trending Python daily listing (web-fetch)"
  slug bridge_github_trending
  kind web-fetch
  invocation tool/github_trending_bridge_fetcher.hexa --fetch
  offline-fallback true
  source-tag github_trending
  registry-of-record state/kick/registry/noise_sources/bridges/bridge_github_trending.hexa
  evidence-source tool/github_trending_bridge_fetcher.hexa::fetch (M-Y tui_extract_text_from)
  fetch-url https://github.com/trending/python?since=daily
  opt-in-gate KICK_USE_WEB_BRIDGES=1
  payload-summary-format "n_repos=<N> top_repo=<owner/name> stars_today=<N>"
  payload-summary-max-chars 200
  prompt-injection-strip true
  design-tier 2026-05-01
  raw-refs raw_9 raw_47 raw_91 raw_232
