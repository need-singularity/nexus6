# state/kick/registry/noise_sources/bridges/bridge_anthropic_status.hexa
# kick(ω-cycle) noise-source registry — bridge:anthropic_status (γ source, kind=web-fetch).
#
# U1 wave Layer (γ-bridge wave U1 2026-05-01) — 18th of 22 bridges in the
# enriched γ rotation. Provides a low-frequency operational-signal envelope:
# is the upstream Anthropic API healthy, degraded, or down? Real production
# correlate for Claude-binary kick slots — when status=degraded the dispatcher
# can de-prioritise web-fetch γ picks even before a 401/5xx surfaces.
#
# URL (constant — no query params, no user input substitutable):
#   https://status.anthropic.com/api/v2/incidents/unresolved.json
#
# Payload contract (≤ 200 chars):
#   "incidents=<N> latest=<iso_ts> components=[<csv>] status=op|degraded|down"
# Example:
#   "incidents=0 latest=2026-04-30T22:11:03Z components=[api,console] status=op"
#
# Implementation: tool/anthropic_status_bridge_fetcher.hexa invokes the M-Y
# browser-harness primitive (tui_extract_text_from) to fetch + extract the
# incidents JSON. If browser-harness is absent, OFFLINE-FALLBACK emits a
# documented sentinel envelope (status=offline_fallback, byte_hash from ts)
# rather than fabricating data (raw 91 honest C3).
#
# Prompt-injection protection (HARD requirement, U1 charter):
#   - reject substring scan: <task-notification>, <system-reminder>, IMPORTANT:
#   - HTML/JS strip: drop <script>...</script>, on<event>=, javascript:, <style>
#   - control-char strip + executable pattern reject (`$(`, backtick, "rm -rf")
#   - payload_summary clamped to 200 chars after sanitize
#
# Default state: 0 inactive (opt-in via env KICK_USE_WEB_BRIDGES=1).
# kind=web-fetch — distinguishes from kind=static (16 legacy bridges) and
# kind=hardware (Akida). Selector reads kind via _registry_field; gating
# logic in tool/kick_dispatch.hexa:_gamma_envelope (line 449-468 area).
#
# raw refs: raw 9 hexa-only, raw 47 cross-repo-trawl-witness 강화,
#           raw 91 honest C3 (OFFLINE-FALLBACK never fakes signal),
#           raw 232 atomic-commit-coupling cross-link (hive r58 Stage 19 #61).

noise-source 0 inactive "bridge:anthropic_status — Anthropic upstream status incidents feed (web-fetch)"
  slug bridge_anthropic_status
  kind web-fetch
  invocation tool/anthropic_status_bridge_fetcher.hexa --fetch
  offline-fallback true
  source-tag anthropic_status
  registry-of-record state/kick/registry/noise_sources/bridges/bridge_anthropic_status.hexa
  evidence-source tool/anthropic_status_bridge_fetcher.hexa::fetch (M-Y tui_extract_text_from)
  fetch-url https://status.anthropic.com/api/v2/incidents/unresolved.json
  opt-in-gate KICK_USE_WEB_BRIDGES=1
  payload-summary-format "incidents=<N> latest=<iso_ts> components=[<csv>] status=op|degraded|down"
  payload-summary-max-chars 200
  prompt-injection-strip true
  design-tier 2026-05-01
  raw-refs raw_9 raw_47 raw_91 raw_232
