# state/kick/registry/noise_sources/bridges/bridge_akida_inference.hexa
# kick(ω-cycle) noise-source registry — bridge:akida_inference (γ source).
#
# Layer 2 of the 4-layer Akida ω-cycle integration (DESIGN-TIER 2026-05-01).
# Provides a quota-free, cloud-free, on-device inference fact (model output)
# as a γ-bridge noise envelope. Distinct from Layer-1 β QRNG: this is a
# substantive payload (model classification / keyword spot / anomaly flag)
# — semantic noise, not just stochastic entropy.
#
# Format mirrors all other 16 γ bridges parsed by tool/kick_tree.hexa.
# raw 47 cross-repo-trawl-witness 강화 — adds a 17th bridge entry alongside
# arxiv / cmb / codata / gaia / gw / horizons / icecube / lhc / nanograv /
# nist_atomic / oeis / openalex / pubchem / simbad / uniprot / wikipedia.
#
# Default state: 0 inactive (opt-in via env KICK_AKIDA_BRIDGE=1 + hardware).
# When hardware lands and operator opts in, kick_dispatch γ-bridge selector
# rolls this slug into the bridge rotation.
#
# Payload contract (≤ 200 chars):
#   "model=<id> top_class=<label> confidence=<float> latency_ms=<n>"
# Example:
#   "model=mobilenet_v1 top_class=tabby_cat confidence=0.91 latency_ms=4"
#
# Prompt-injection protection: M-AK build_akida_inference_cmd whitelists
# model_id to [a-z0-9_-]+; payload_summary copy-out strips control chars
# and rejects executable patterns (`$(`, backtick, "rm -rf", etc.).
#
# raw refs: raw 9 hexa-only, raw 47 strengthen, raw 91 honest C3 (HW absent
# → bridge skipped, never silently mocked into the rotation), raw 169.

noise-source 0 inactive "bridge:akida_inference — Akida AKD1000 on-device inference output (cloud-free, quota-free)"
  slug bridge_akida_inference
  kind bridge
  invocation tool/akida_dispatch.hexa --bridge-emit
  offline-fallback false
  source-tag akida_inference
  registry-of-record state/kick/registry/noise_sources/bridges/bridge_akida_inference.hexa
  evidence-source tool/akida_neuromorphic_module.hexa::akida_invoke (M-AK io_seam)
  hardware-gate AKIDA_HW_PRESENT=1
  opt-in-gate KICK_AKIDA_BRIDGE=1
  payload-summary-format "model=<id> top_class=<label> confidence=<float> latency_ms=<n>"
  payload-summary-max-chars 200
  prompt-injection-strip true
  design-tier 2026-05-01
  raw-refs raw_9 raw_47 raw_91 raw_169
