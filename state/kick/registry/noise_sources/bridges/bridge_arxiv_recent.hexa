# state/kick/registry/noise_sources/bridges/bridge_arxiv_recent.hexa
# kick(ω-cycle) noise-source registry — bridge:arxiv_recent (γ source, kind=web-fetch).
#
# U1 wave Layer (γ-bridge wave U1 2026-05-01) — 20th of 22 bridges in the
# enriched γ rotation. Distinct from the existing kind=static bridge_arxiv
# (Atom-API based, see arxiv.hexa) — this is the *web-rendered recent listing*
# (HTML page, no API key, daily refresh) which is a different surface and a
# different failure mode. Cross-source diversity > raw_47.
#
# URL (constant):
#   https://arxiv.org/list/cs.AI/recent
#
# Payload contract (≤ 200 chars):
#   "n_papers=<N> first_title=<truncated> first_id=arxiv:<YYMM.NNNNN>"
# Example:
#   "n_papers=37 first_title=spectral_GNN_for_lattice_QCD first_id=arxiv:2604.21859"
#
# Implementation: tool/arxiv_recent_bridge_fetcher.hexa invokes M-Y
# browser-harness (tui_extract_text_from) on the rendered listing then
# substring-extracts the first paper-id pattern (YYMM.NNNNN) + truncated title.
# OFFLINE-FALLBACK on harness absence (raw 91 honest C3).
#
# Prompt-injection protection (HARD requirement, U1 charter):
#   - reject substring scan: <task-notification>, <system-reminder>, IMPORTANT:
#   - HTML/JS strip: drop <script>...</script>, on<event>=, javascript:, <style>
#   - control-char strip + executable pattern reject (`$(`, backtick, "rm -rf")
#   - payload_summary clamped to 200 chars after sanitize
#
# Default state: 0 inactive (opt-in via env KICK_USE_WEB_BRIDGES=1).
# kind=web-fetch.
#
# raw refs: raw 9, raw 47, raw 91, raw 232.

noise-source 0 inactive "bridge:arxiv_recent — arXiv cs.AI recent listing (HTML web-fetch, distinct from kind=static arxiv API bridge)"
  slug bridge_arxiv_recent
  kind web-fetch
  invocation tool/arxiv_recent_bridge_fetcher.hexa --fetch
  offline-fallback true
  source-tag arxiv_recent
  registry-of-record state/kick/registry/noise_sources/bridges/bridge_arxiv_recent.hexa
  evidence-source tool/arxiv_recent_bridge_fetcher.hexa::fetch (M-Y tui_extract_text_from)
  fetch-url https://arxiv.org/list/cs.AI/recent
  opt-in-gate KICK_USE_WEB_BRIDGES=1
  payload-summary-format "n_papers=<N> first_title=<truncated> first_id=arxiv:<YYMM.NNNNN>"
  payload-summary-max-chars 200
  prompt-injection-strip true
  design-tier 2026-05-01
  raw-refs raw_9 raw_47 raw_91 raw_232
