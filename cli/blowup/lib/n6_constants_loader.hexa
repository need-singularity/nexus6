// ═══════════════════════════════════════════════════════════
// n6_constants_loader.hexa — 공유 상수 로더 + /tmp 캐시
// ROI #12: 5 모듈 각 19MB I/O → 1회 로드 + 캐시 재사용
//
// 사용법 (standalone):
//   hexa n6_constants_loader.hexa           캐시 생성/갱신
//   hexa n6_constants_loader.hexa --force   강제 재생성
//
// 캐시 파일:
//   /tmp/.n6_constants_cache       파싱된 TSV (name\tvalue)
//   /tmp/.n6_constants_cache.mtime 원본 mtime 스탬프
//
// 모듈 내 copy-paste 패턴 (atlas_guard.hexa.inc 방식):
//   → lib/n6_constants_loader.hexa의 load_n6_consts() 함수를
//     모듈 상단에 복사. 전체 파서 대신 캐시 TSV만 읽음.
//
// 병렬 안전: flock 기반 배타 잠금. 동시 실행 시 1개만 파싱,
// 나머지는 잠금 해제 후 캐시 읽기.
// ═══════════════════════════════════════════════════════════

let _HOME = exec("printenv HOME").trim()
let _N6C_SOURCE = _HOME + "/Dev/nexus/n6/n6_constants.jsonl"
let _N6C_CACHE = "/tmp/.n6_constants_cache"
let _N6C_MTIME = "/tmp/.n6_constants_cache.mtime"
let _N6C_LOCK  = "/tmp/.n6_constants_cache.lock"

// ─── 원본 mtime 조회 ───
fn _get_source_mtime() -> string {
    let mt = exec("stat -f '%m' '" + _N6C_SOURCE + "' 2>/dev/null || stat --format='%Y' '" + _N6C_SOURCE + "' 2>/dev/null || echo 0").trim()
    return mt
}

// ─── 캐시 유효성 검사 ───
fn _cache_valid() -> bool {
    let check = exec("[ -f '" + _N6C_CACHE + "' ] && [ -f '" + _N6C_MTIME + "' ] && echo Y || echo N").trim()
    if check != "Y" { return false }
    let cached_mt = exec("cat '" + _N6C_MTIME + "' 2>/dev/null").trim()
    let source_mt = _get_source_mtime()
    return cached_mt == source_mt && source_mt != "0"
}

// ─── 원본 파싱 → TSV 캐시 생성 (flock 배타 잠금) ───
fn _build_cache() {
    // R37/AN13/L3-PY violation — python3 cache-builder stubbed 2026-04-18
    // Original: exec("... /usr/bin/python3 -c 'import json, sys; ...' ...") — jsonl→TSV cache
    // No-op: load_n6_consts() catches read_file(cache) failure → _load_n6_consts_direct() hexa fallback.
    eprintln("[R37] n6_constants_loader._build_cache: python3 cache-builder disabled; using hexa-native fallback parser.")
    return
}

// ─── 캐시에서 TSV 로드 → [names, values] 반환 ───
fn load_n6_consts() -> list {
    if !_cache_valid() { _build_cache() }
    let mut raw = ""
    try { raw = read_file(_N6C_CACHE) } catch e {
        // 캐시 실패 시 원본 직접 파싱 (fallback)
        return _load_n6_consts_direct()
    }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let t = line.trim()
        if t == "" { continue }
        let parts = t.split("\t")
        if parts.len() < 2 { continue }
        names = names + [parts[0]]
        values = values + [to_float(parts[1])]
    }
    [names, values]
}

// ─── Fallback: 원본 직접 파싱 (캐시 불가 환경용) ───
fn _load_n6_consts_direct() -> list {
    let mut raw = ""
    try { raw = read_file(_N6C_SOURCE) } catch e { return [[], []] }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let t = line.trim()
        if t == "" { continue }
        let mut name = ""
        let mut value = 0.0
        if t.contains("\"name\":\"") {
            let p = t.split("\"name\":\"")
            if p.len() >= 2 { name = p[1].split("\"")[0] }
        }
        if t.contains("\"value\":") {
            let p = t.split("\"value\":")
            if p.len() >= 2 {
                let num_str = p[1].split(",")[0].split("}")[0].trim()
                value = to_float(num_str)
            }
        }
        if name != "" {
            names = names + [name]
            values = values + [value]
        }
    }
    [names, values]
}

// ─── Standalone 실행: 캐시 생성/갱신 ───
let args = exec("echo $@").trim()
if args == "--force" {
    exec("rm -f '" + _N6C_CACHE + "' '" + _N6C_MTIME + "' 2>/dev/null")
    println("[n6_constants_loader] forced rebuild")
}
_build_cache()
let result = load_n6_consts()
let names: list = result[0]
println("[n6_constants_loader] " + to_string(len(names)) + " constants ready")
