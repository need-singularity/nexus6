}

if mode == "meta" {
    // hexa ouroboros.hexa meta math 3 6
    let domain = if a.len() >= 4 { a[3] } else { "general" }
    let max_meta = if a.len() >= 5 { to_int(a[4]) } else { 3 }
    let max_evo = if a.len() >= 6 { to_int(a[5]) } else { 6 }

    println("=== OUROBOROS MetaLoop ===")
    println("domain: " + domain)
