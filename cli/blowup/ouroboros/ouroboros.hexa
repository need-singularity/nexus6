// ─── 검증 ───

assert strategy_name(0) == "ParameterShift"
assert strategy_name(3) == "Inversion"
assert status_name(status_exploring) == "Exploring"
assert status_name(status_saturated) == "Saturated"
assert check_convergence(default_convergence_config(), [5, 3]) == status_exploring
assert check_convergence(default_convergence_config(), [5, 3, 0, 0, 0]) == status_saturated
assert depth_label(0) == "growth"
assert depth_label(1) == "growth(growth)"
assert depth_label(2) == "growth(growth(growth))"

let test_mutations = mutate_hypothesis("test")
assert test_mutations.len() > 0

println("")
println("=== ouroboros verified ===")

theorem ouroboros_convergence {
    // 포화 윈도우 내 모든 발견 = 0 → Saturated
    assert check_convergence(default_convergence_config(), [5, 3, 0, 0, 0]) == status_saturated
}

theorem absorber_identity_converges {
    // 항등 연산은 depth 1에서 즉시 수렴 (delta = 0)
    check law(6)
}

proof ouroboros_invariants {
    invariant mutation_produces_output()
    invariant convergence_monotonic()
    invariant absorber_terminates()
}
