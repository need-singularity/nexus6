    let input = [ GrowthEvent { source: "lens_grower", kind: "discovery", value: 2.0 }, GrowthEvent { source: "mirror", kind: "resonance", value: 2.1 }, GrowthEvent { source: "ouroboros", kind: "mutation", value: 3.0 }, GrowthEvent { source: "dream", kind: "hypothesis", value: 1.5 }, GrowthEvent { source: "forge", kind: "lens_created", value: 4.0 }, GrowthEvent { source: "bus", kind: "feedback", value: 1.8 } ]

    let chain = run_absorber(input)

    println("=== Absorption Chain (depth=" + to_string(chain.final_depth) + ", converged=" + to_string(chain.converged) + ") ===")
