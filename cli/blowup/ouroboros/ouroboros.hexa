    let mut s = 0
    while s <= 3 {
        let mutations = mutate_with_strategy(base, s)
        println("[" + strategy_name(s) + "] (" + to_string(mutations.len()) + " variants)")
        let show = if mutations.len() > 3 { 3 } else { mutations.len() }
        let mut i = 0
        while i < show {
            println("  " + mutations[i])
            i = i + 1
        }
        if mutations.len() > 3 { println("  ... (" + to_string(mutations.len() - 3) + " more)") }
