}

if mode == "mutate" {
    // hexa ouroboros.hexa mutate "hypothesis text"
    let base = if a.len() >= 4 { a[3] } else { "n=6 constrains transformer head count" }
    println("=== Mutation Strategies ===")
    println("base: " + base)
