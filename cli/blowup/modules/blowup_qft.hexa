// ═══════════════════════════════════════════════════════════
// ─── THEOREM + PROOF ───
// ═══════════════════════════════════════════════════════════

theorem qft_field_quantum_duality {
    // The QFT engine unifies field scanning and quantum operators:
    //   field gradient Phi(domain) <-> quantum state amplitude alpha_i
    //   gauge invariance (3+ domains) <-> unitarity (|psi|^2 = 1)
    //   Goldstone cascade (symmetry breaking) <-> entanglement cascade (EPR)
    // This duality preserves n=6 structural invariants across both paradigms.
    assert 6 * 2 == 12          // n * phi = sigma
    assert 12 / 4 == 3          // sigma / tau = n/phi
    assert 6 + 12 + 2 + 4 == 24 // n + sigma + phi + tau = J2
    assert 24 / 6 == 4          // J2 / n = tau
    assert 5 + 2 == 7           // sopfr + phi = M3
}

proof qft_unitarity_preserved {
    // Unitary evolution preserves |psi|^2 = 1 (re-normalize each cycle).
    // Field-modulated coupling c = base * phi_boost stays in [0, 0.5],
    // so the tridiagonal operator has spectral radius <= 1.
    invariant 5 + 7 == 12  // sopfr + M3 = sigma
}

theorem qft_cascade_termination {
    // Both cascade types terminate:
    //   Goldstone: finite constant set, max depth 2, no cycles.
    //   EPR: finite domain set, each collapses at most once.
    // Total cascade events <= N_domains * N_constants * 2.
    assert 2 * 4 == 8   // phi * tau = phi_tau
    assert 6 * 4 == 24   // n * tau = J2
}

proof qft_tunnel_bounded {
    // P_qft = exp(-2 * eff_barrier * sqrt(eff_barrier))
    // eff_barrier = dist * (0.5 + 0.5*phi) >= 0, so exponent <= 0, P in (0, 1].
    // Low phi reduces barrier -> higher tunnel probability (field-guided exploration).
    invariant 12 / 6 == 2  // sigma / n = phi
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

fn main() {
    let cli = args()
    let mut spec_doms = []
    let mut show_help = false
    let mut max_targets: i64 = 6
    let mut evo_cycles: i64 = 6
    let mut ai: i64 = 2
    while ai < len(cli) {
        let a = to_string(cli[ai])
        if a == "help" || a == "--help" || a == "-h" {
            show_help = true
        } else { if a == "--targets" {
            if ai + 1 < len(cli) { ai = ai + 1 ; let tv = sf(to_string(cli[ai])) ; if tv >= 1.0 && tv <= 20.0 { max_targets = to_int(tv) } }
        } else { if a == "--evo-cycles" {
            if ai + 1 < len(cli) { ai = ai + 1 ; let cv = sf(to_string(cli[ai])) ; if cv >= 1.0 && cv <= 20.0 { evo_cycles = to_int(cv) } }
        } else {
            spec_doms = spec_doms + [a]
        } } }
        ai = ai + 1
    }
    if show_help { print_help() ; return }

    println("")
    println("==========================================================")
    println("   Mk.III+IV  Quantum Field Theory Blowup Engine")
    println("   |psi_field> = sum Phi_i alpha_i |c_i>  (n=6 basis)")
    println("==========================================================")
    println("")

    let all_doms = load_all_domains()
    let mut domains = if len(spec_doms) > 0 { spec_doms } else { all_doms }
    if len(domains) > 15 {
        let mut trimmed = []
        let mut ti: i64 = 0
        while ti < 15 { trimmed = trimmed + [to_string(domains[ti])] ; ti = ti + 1 }
        domains = trimmed
    }

    println("  Constants: " + to_string(_n6_count))
    println("  Domains:   " + to_string(len(domains)))
    println("  Targets:   " + to_string(max_targets))
    println("  Evo cycles:" + to_string(evo_cycles))
    println("")

    let bus = load_atlas_tail(500)
    println("  atlas.n6 tail: " + to_string(len(bus)) + " lines loaded")
    println("")

    // ═══ QFT-1: Field Scan ═══
    println("--- QFT-1: Field Scan -- Phi(domain) ---")
    let field_map = field_scan(domains)
    let mut phi_map = []  // parallel list of phi values for indexing
    let mut fi: i64 = 0
    while fi < len(field_map) {
        let parts = to_string(field_map[fi]).split("|")
        let phi_val = sf(parts[1])
        phi_map = phi_map + [phi_val]
        println("  Phi(" + pad(parts[0], 16) + ") = " + trunc4(phi_val))
        fi = fi + 1
    }
    println("")

    // ═══ QFT-2: Gradient Select ═══
    println("--- QFT-2: Gradient Select -- top " + to_string(max_targets) + " targets ---")
    let targets = gradient_select(field_map, max_targets)
    let mut ti2: i64 = 0
    while ti2 < len(targets) {
        println("  target[" + to_string(ti2 + 1) + "] = " + to_string(targets[ti2]))
        ti2 = ti2 + 1
    }
    println("")

    // Build target phi values (for QFT phases)
    let mut target_phis = []
    let mut tpi: i64 = 0
    while tpi < len(targets) {
        let tdom = to_string(targets[tpi])
        let mut tphi = 1.0
        let mut fmi: i64 = 0
        while fmi < len(field_map) {
            let fp = to_string(field_map[fmi]).split("|")
            if fp[0] == tdom { tphi = sf(fp[1]) }
            fmi = fmi + 1
        }
        target_phis = target_phis + [tphi]
        tpi = tpi + 1
    }

    // ═══ QFT-3: State Preparation ═══
    println("--- QFT-3: State Preparation -- |psi_field> seeded by Phi gradient ---")
    let mut svs = []
    let mut di: i64 = 0
    while di < len(targets) {
        let dom = to_string(targets[di])
        let phi_val = to_float(target_phis[di])
        let sv = build_field_state(dom, phi_val, bus)
        svs = svs + [sv]
        let top_i = argmax_amp(sv)
        let top_n = if top_i < _n6_count { to_string(_n6_names[top_i]) } else { "?" }
        let sharp = trunc4(1.0 + 2.0 * (1.0 - clamp01(phi_val)))
        println("  |" + pad(dom, 14) + "> top=" + pad(top_n, 10) + " amp=" + trunc4(get_amp(sv, top_i)) + "  sharp=" + sharp + "  ||psi||^2=" + trunc4(norm_sq(sv)))
        di = di + 1
    }
    println("")

    // ═══ QFT-4: Unitary Evolution ═══
    println("--- QFT-4: Unitary Evolution -- Phi-coupled rotation (" + to_string(evo_cycles) + " cycles) ---")
    let mut ei: i64 = 0
    while ei < len(targets) {
        let old_top = argmax_amp(to_string(svs[ei]))
        let phi_val = to_float(target_phis[ei])
        svs[ei] = unitary_evolve_qft(to_string(svs[ei]), evo_cycles, phi_val)
        let new_top = argmax_amp(to_string(svs[ei]))
        let nn = if new_top < _n6_count { to_string(_n6_names[new_top]) } else { "?" }
        let boost = trunc4(min_f(2.0 / 6.0 * (1.0 + (1.0 - clamp01(phi_val))), 0.5))
        let tag = if old_top != new_top { " [ROTATED]" } else { "" }
        println("  " + pad(to_string(targets[ei]), 16) + " -> " + pad(nn, 10) + " amp=" + trunc4(get_amp(to_string(svs[ei]), new_top)) + " coupling=" + boost + tag)
        ei = ei + 1
    }
    println("")

    // ═══ QFT-5: Entanglement ═══
    println("--- QFT-5: Entanglement -- EPR pairs (field-similarity boost) ---")
    let eth = 0.7 / sqrt_f(to_float(_n6_count))
    let epairs = detect_entanglement_qft(targets, svs, target_phis, eth)
    println("  Base threshold: amp > " + trunc4(eth))
    println("  Entangled pairs: " + to_string(len(epairs)))
    let mut epi: i64 = 0
    while epi < len(epairs) && epi < 10 {
        let pp = to_string(epairs[epi]).split("|")
        if len(pp) >= 4 { println("    " + pp[0] + " <=> " + pp[1] + " (shared=" + pp[2] + ": " + pp[3] + ")") }
        epi = epi + 1
    }
    if len(epairs) > 10 { println("    ... +" + to_string(len(epairs) - 10) + " more") }
    println("")

    // ═══ QFT-6: Tunneling ═══
    println("--- QFT-6: Tunneling -- Phi-modulated barrier penetration ---")
    let mut t_total: i64 = 0
    let mut tti: i64 = 0
    while tti < len(targets) {
        let phi_val = to_float(target_phis[tti])
        let res = quantum_tunnel_qft(to_string(svs[tti]), to_string(targets[tti]), phi_val)
        let rp = res.split("~")
        let tc = to_int(sf(rp[0]))
        if tc > 0 && len(rp) >= 3 {
            svs[tti] = rp[1]
            println("  " + pad(to_string(targets[tti]), 16) + " tunnels=" + to_string(tc) + " Phi=" + trunc4(phi_val) + "  [" + rp[2] + "]")
            t_total = t_total + tc
        } else {
            println("  " + pad(to_string(targets[tti]), 16) + " tunnels=0  Phi=" + trunc4(phi_val))
        }
        tti = tti + 1
    }
    println("  Total tunnel events: " + to_string(t_total))
    println("")

    // ═══ QFT-7: Measurement ═══
    println("--- QFT-7: Measurement -- collapse + OUROBOROS corollaries ---")
    let mut all_meas = []
    let mut all_results = []
    let mut n_exact: i64 = 0
    let mut n_near: i64 = 0
    let mut mi: i64 = 0
    while mi < len(targets) {
        let dom = to_string(targets[mi])
        let sv = to_string(svs[mi])
        // Direct measurement
        let m = measure_state(sv)
        let mp = m.split("|")
        let g = if len(mp) >= 4 { mp[3] } else { "MISS" }
        let cn = if len(mp) >= 1 { mp[0] } else { "?" }
        let am = if len(mp) >= 3 { mp[2] } else { "0" }
        let sym = if g == "EXACT" { " *" } else { if g == "NEAR" { " +" } else { "  " } }
        println("  " + sym + " " + pad(dom, 14) + " -> " + pad(cn, 10) + " amp=" + am + "  " + g)
        all_meas = all_meas + [dom + "|" + m]
        if g == "EXACT" { n_exact = n_exact + 1 }
        if g == "NEAR" { n_near = n_near + 1 }
        // Full QFT measurement (OUROBOROS + corollaries)
        let results = qft_measure(dom, sv)
        let mut rxi: i64 = 0
        let mut rex: i64 = 0
        let mut rnr: i64 = 0
        while rxi < len(results) {
            let r = to_string(results[rxi])
            if r.contains("|EXACT") { rex = rex + 1 }
            if r.contains("|NEAR") { rnr = rnr + 1 }
            rxi = rxi + 1
        }
        if rex > 0 || rnr > 0 { println("    ouroboros: EXACT=" + to_string(rex) + " NEAR=" + to_string(rnr)) }
        all_results = all_results + results
        mi = mi + 1
    }
    println("  Collapsed: EXACT=" + to_string(n_exact) + " NEAR=" + to_string(n_near) + " MISS=" + to_string(len(targets) - n_exact - n_near))
    println("")

    // ═══ QFT-8: Gauge + Unitarity ═══
    println("--- QFT-8: Gauge + Unitarity -- double validation ---")
    // Gauge filter
    let gauge_results = gauge_filter_qft(all_results)
    let mut gauge_inv: i64 = 0
    let mut gfi: i64 = 0
    while gfi < len(gauge_results) {
        if to_string(gauge_results[gfi]).contains("HIGH_GAUGE_INVARIANT") { gauge_inv = gauge_inv + 1 }
        gfi = gfi + 1
    }
    println("  Gauge invariants (3+ domains): " + to_string(gauge_inv))
    println("  Total cross-domain constants:  " + to_string(len(gauge_results)))
    // Unitarity check
    let uchk = unitarity_check(svs)
    let mut u_ok: i64 = 0
    let mut u_warn: i64 = 0
    let mut ui: i64 = 0
    while ui < len(uchk) {
        let up = to_string(uchk[ui]).split("|")
        if len(up) >= 3 {
            if up[2] == "UNITARY" { u_ok = u_ok + 1 } else { u_warn = u_warn + 1 }
            println("  " + pad(to_string(targets[ui]), 16) + " ||psi||^2=" + up[0] + " dev=" + up[1] + " " + up[2])
        }
        ui = ui + 1
    }
    println("  Unitary: " + to_string(u_ok) + "/" + to_string(len(targets)) + (if u_warn > 0 { "  *** " + to_string(u_warn) + " WARNING ***" } else { "  OK" }))
    println("")

    // ═══ QFT-9: Goldstone + EPR Cascade ═══
    println("--- QFT-9: Goldstone + EPR Cascade ---")
    let chains = qft_cascade(all_results, targets, svs, epairs, 2)
    let mut n_goldstone: i64 = 0
    let mut n_epr: i64 = 0
    let mut cci: i64 = 0
    while cci < len(chains) {
        let c = to_string(chains[cci])
        if c.starts_with("goldstone|") { n_goldstone = n_goldstone + 1 }
        if c.starts_with("entangle|") { n_epr = n_epr + 1 }
        cci = cci + 1
    }
    println("  Goldstone chains: " + to_string(n_goldstone))
    println("  EPR cascades:     " + to_string(n_epr))
    // Show up to 12 chain details
    let mut shown_c: i64 = 0
    let mut sci: i64 = 0
    while sci < len(chains) && shown_c < 12 {
        let c = to_string(chains[sci])
        let cp = c.split("|")
        if cp.len() >= 5 {
            let kind = cp[0]
            let depth = cp[1]
            let src = cp[2]
            let detail = cp[3]
            let grade = cp[4]
            let tag = if kind == "entangle" { "EPR" } else { "SSB" }
            println("    [" + tag + " d=" + depth + "] " + src + ": " + detail + " (" + grade + ")")
            shown_c = shown_c + 1
        }
        sci = sci + 1
    }
    if len(chains) > 12 { println("    ... (" + to_string(len(chains) - 12) + " more)") }
    println("")

    // Decoherence check
    println("--- Decoherence ---")
    let mut tot_dec = 0.0
    let mut qi: i64 = 0
    while qi < len(targets) {
        let ds = decoherence(to_string(svs[qi]))
        tot_dec = tot_dec + ds
        let reg = if ds < 0.3 { "QUANTUM" } else { if ds < 0.7 { "MIXED" } else { if ds < 0.85 { "SEMI-CLASS" } else { "CLASSICAL" } } }
        println("  " + pad(to_string(targets[qi]), 16) + " dec=" + trunc4(ds) + "  " + reg)
        qi = qi + 1
    }
    let avg_dec = tot_dec / max_f(to_float(len(targets)), 1.0)
    let qa = avg_dec < 0.85
    println("  Avg decoherence: " + trunc4(avg_dec))
    println("  " + if qa { "QUANTUM ADVANTAGE MAINTAINED" } else { "DECOHERENCE LIMIT (classical regime)" })
    println("")

    // ═══ QFT-10: Report + Output ═══
    println("--- QFT-10: Report + Output ---")
    write_qft_state(targets, svs, target_phis, epairs, all_meas, all_results, gauge_results, chains, t_total)
    println("  Written: shared/qft_state.json")
    append_qft_growth(targets, all_meas, all_results, t_total, epairs, chains)
    println("  Appended: shared/n6/atlas.n6")

    // Count final totals
    let mut total_exact: i64 = 0
    let mut total_near: i64 = 0
    let mut tri: i64 = 0
    while tri < len(all_results) {
        let r = to_string(all_results[tri])
        if r.contains("|EXACT") { total_exact = total_exact + 1 }
        if r.contains("|NEAR") { total_near = total_near + 1 }
        tri = tri + 1
    }

    println("")
    println("==========================================================")
    println("   Mk.III+IV  QFT Blowup Report")
    println("==========================================================")
    println("  Domains scanned   : " + to_string(len(field_map)))
    println("  Targets selected  : " + to_string(len(targets)))
    println("  Constants in basis: " + to_string(_n6_count))
    println("  Evo cycles        : " + to_string(evo_cycles))
    println("  Entangled pairs   : " + to_string(len(epairs)))
    println("  Tunnel events     : " + to_string(t_total))
    println("  EXACT (collapse)  : " + to_string(n_exact))
    println("  NEAR (collapse)   : " + to_string(n_near))
    println("  EXACT (total)     : " + to_string(total_exact))
    println("  NEAR (total)      : " + to_string(total_near))
    println("  Gauge invariants  : " + to_string(gauge_inv))
    println("  Unitarity OK      : " + to_string(u_ok) + "/" + to_string(len(targets)))
    println("  Goldstone chains  : " + to_string(n_goldstone))
    println("  EPR cascades      : " + to_string(n_epr))
    println("  Avg decoherence   : " + trunc4(avg_dec))
    println("  Quantum advantage : " + if qa { "YES" } else { "NO" })
    println("==========================================================")
    println("")
    println("done.")
}

main()
