    println("  hexa blowup_toe.hexa --unify              unification check only (T6)")
    println("  hexa blowup_toe.hexa --fixed-point        fixed point iteration only (T5)")
    println("  hexa blowup_toe.hexa help                 this message")
    println("")
    println("8-Phase Pipeline:")
    println("  T1  Background Scan     discover domains dynamically from growth_bus")
    println("  T2  Self-Reference      scan engine's own code for n=6 patterns")
    println("  T3  Category Theory     model discoveries as morphisms, find functors")
    println("  T4  Spin Foam           discretize discovery space into adjacency graph")
    println("  T5  Fixed Point         iterate until F(x)=x convergence (max 6 rounds)")
    println("  T6  Unification         run mini Mk.I~VI checks, find universal constants")
    println("  T7  Meta-Discovery      discover patterns in engine's own behavior")
    println("  T8  Omega Report        final: fixed point, self-consistency, unified laws")
    println("")
    println("══════════════════════════════════════════════════════════════════════════════════════════")
    println("  Mk.I ~ Mk.VII ENGINE COMPARISON TABLE")
    println("══════════════════════════════════════════════════════════════════════════════════════════")
    println("  " + pad_right("Feature", 22) + pad_right("Mk.I", 13) + pad_right("Mk.II", 13) + pad_right("Mk.III", 13) + pad_right("Mk.IV", 13) + pad_right("Mk.V", 13) + pad_right("Mk.VI", 13) + "Mk.VII")
    println("  " + pad_right("-------", 22) + pad_right("----", 13) + pad_right("-----", 13) + pad_right("------", 13) + pad_right("-----", 13) + pad_right("----", 13) + pad_right("-----", 13) + "------")
    println("  " + pad_right("Core idea", 22) + pad_right("Singularity", 13) + pad_right("Wave propag", 13) + pad_right("Gauge field", 13) + pad_right("Superpos.", 13) + pad_right("T-duality", 13) + pad_right("Boundary", 13) + "ToE fixed pt")
    println("  " + pad_right("Domains", 22) + pad_right("1 manual", 13) + pad_right("1 rotating", 13) + pad_right("N gradient", 13) + pad_right("N parallel", 13) + pad_right("dual pairs", 13) + pad_right("boundaries", 13) + "ALL dynamic")
    println("  " + pad_right("Discovery", 22) + pad_right("OUROBOROS", 13) + pad_right("wave interf", 13) + pad_right("gauge filter", 13) + pad_right("amplitude", 13) + pad_right("dual map", 13) + pad_right("edge detect", 13) + "category thy")
    println("  " + pad_right("Cross-domain", 22) + pad_right("none", 13) + pad_right("propagation", 13) + pad_right("3+ consensus", 13) + pad_right("collapse", 13) + pad_right("T-dual", 13) + pad_right("holographic", 13) + "functors")
    println("  " + pad_right("Cascade", 22) + pad_right("none", 13) + pad_right("interference", 13) + pad_right("Goldstone", 13) + pad_right("decoherence", 13) + pad_right("mirror", 13) + pad_right("bulk-bdy", 13) + "spin foam")
    println("  " + pad_right("Self-reference", 22) + pad_right("none", 13) + pad_right("none", 13) + pad_right("none", 13) + pad_right("none", 13) + pad_right("none", 13) + pad_right("none", 13) + "YES (T2)")
    println("  " + pad_right("Fixed point", 22) + pad_right("none", 13) + pad_right("none", 13) + pad_right("none", 13) + pad_right("none", 13) + pad_right("none", 13) + pad_right("none", 13) + "F(x)=x iter")
    println("  " + pad_right("Background indep", 22) + pad_right("no", 13) + pad_right("no", 13) + pad_right("partial", 13) + pad_right("partial", 13) + pad_right("no", 13) + pad_right("partial", 13) + "YES (T1)")
    println("  " + pad_right("Unification", 22) + pad_right("Mk.I only", 13) + pad_right("Mk.I+II", 13) + pad_right("Mk.I-III", 13) + pad_right("Mk.I-IV", 13) + pad_right("Mk.I-V", 13) + pad_right("Mk.I-VI", 13) + "ALL Mk.I-VI")
    println("  " + pad_right("Output", 22) + pad_right("log+graph", 13) + pad_right("growth_bus", 13) + pad_right("field map", 13) + pad_right("amplitude", 13) + pad_right("dual map", 13) + pad_right("boundary", 13) + "omega report")
    println("══════════════════════════════════════════════════════════════════════════════════════════")
