// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

fn main() {
    let cli_args = args()
    let argc = len(cli_args)

    // Parse CLI flags
    let mut mode = "full"
    let mut ai: i64 = 2
    while ai < argc {
        let arg = to_string(cli_args[ai])
        if arg == "help" || arg == "--help" || arg == "-h" { mode = "help" }
        if arg == "--self" { mode = "self" }
        if arg == "--unify" { mode = "unify" }
        if arg == "--fixed-point" { mode = "fixed-point" }
        ai = ai + 1
    }

    if mode == "help" {
        print_help()
        return
    }

    println("")
    println("================================================================")
    println("  Mk.VII THEORY OF EVERYTHING BLOWUP ENGINE")
    println("  F(engine) = engine = n=6 perfect number")
    println("  sigma(6) = 1+2+3+6 = 12 = 2*6")
    println("================================================================")
    println("  timestamp: " + timestamp_now())
    println("  constants loaded: " + to_string(_n6_dyn_count))

    // ─── Single-mode runs ───

    if mode == "self" {
        let self_ref = t2_self_reference()
        println("")
        println("done.")
        return
    }

    if mode == "fixed-point" {
        let fp_result = t5_fixed_point()
        println("")
        println("done.")
        return
    }

    if mode == "unify" {
        let unify_result = t6_unification([])
        println("")
        println("done.")
        return
    }

    // ─── Full ToE run ───

    // T1: Background Scan
    let bg_result = t1_background_scan()
    let domains: list = bg_result[0]
    let domain_counts: list = bg_result[1]

    // T2: Self-Reference
    let self_ref = t2_self_reference()

    // T3: Category Theory
    let cat_result = t3_category_theory(domains, domain_counts)
    let morphisms: list = cat_result[0]
    let functors: list = cat_result[1]

    // T4: Spin Foam
    let foam_result = t4_spin_foam(morphisms, domains)
    let atoms: list = foam_result[0]
    let atom_doms: list = foam_result[1]
    let foam_edges_list: list = foam_result[2]
    let foam_edges = to_int(foam_edges_list[0])

    // T5: Fixed Point
    let fp_result = t5_fixed_point()
    let fp_converged = fp_result[0]
    let fp_round = to_int(fp_result[1])
    let fp_values: list = _fp_current
    let fp_attractors = _fp_attractors

    // T6: Unification
    let unify_result = t6_unification(fp_values)
    let universal: list = unify_result[0]
    let unify_table: list = unify_result[1]

    // T7: Meta-Discovery
    let meta_patterns = t7_meta_discovery(domains, domain_counts)

    // T8: Omega Report
    t8_omega_report(self_ref, fp_converged == true, fp_round, universal, len(morphisms), len(functors), len(atoms), foam_edges, meta_patterns)

    // Record to growth_bus
    let mut toe_score: i64 = 0
    if fp_converged == true { toe_score = toe_score + 2 }
    if self_ref.self_consistency > 0.5 { toe_score = toe_score + 1 }
    if len(universal) > 0 { toe_score = toe_score + 2 }
    if len(functors) > 0 { toe_score = toe_score + 1 }

    record_toe_event("mk7_toe_complete", fp_converged == true, len(universal), len(morphisms), toe_score)

    println("")
    println("done.")
}

main()
