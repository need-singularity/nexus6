// shared/blowup/lens/lens_expander.hexa — BLOW-P9-1 lens 3000->4000 expander
// COMPLETED 2026-04-16: 1576->4000 (2424 new lenses, 0 dupes)
// 7 strategies: dse_single(370), dse_cross(1400), bt_cross(210),
//   n6_cross(444), phys_cross/meta/triple(0 needed — budget filled)
// Sources: DSE domains (384), atlas nodes, BT domains (21), cross-domain pairs
// CLI: scan | generate | merge | status
// Staging: shared/blowup/lens/lens_expansion_staging.jsonl
// hexa pitfalls: #{} maps, .keys() iterate, str() coercion, no import

// ─── paths ───

comptime const _NEXUS_REL = "shared"
comptime const _REG_REL = "shared/config/lens_registry.json"
comptime const _DSE_REL = "shared/dse/domains"
comptime const _ATLAS_REL = "shared/n6/atlas.n6"
comptime const _BT_DOMAINS_REL = "shared/bt/bt_domains.jsonl"
comptime const _STAGING_REL = "shared/blowup/lens/lens_expansion_staging.jsonl"

fn _home() -> string {
    exec("printenv HOME").trim()
}

fn _abs(rel: string) -> string {
    _home() + "/core/nexus/" + rel
}

// ─── existing registry loader ───

fn load_existing_names() -> #{string: bool} {
    let mut names = #{} as #{string: bool}
    let path = _abs(_REG_REL)
    if !file_exists(path) { return names }
    let raw = read_file(path)
    let lines = raw.split("\n")
    for line in lines {
        if line.contains("\"name\"") {
            let n = _extract(line, "name")
            if n != "" {
                names[n] = true
            }
        }
    }
    names
}

fn count_registry() -> int {
    let path = _abs(_REG_REL)
    if !file_exists(path) { return 0 }
    let raw = read_file(path)
    let mut count = 0
    let lines = raw.split("\n")
    for line in lines {
        if line.contains("\"name\"") && line.contains("\"category\"") {
            count = count + 1
        }
    }
    count
}

// ─── JSON field extractor (reuse lens_forge pattern) ───

pure fn _extract(line: string, field: string) -> string {
    let needle = "\"" + field + "\""
    if !line.contains(needle) { return "" }
    let after = line.split(needle)
    if after.len() < 2 { return "" }
    let rest = after[1].trim()
    // skip : and whitespace
    let mut i = 0
    let mut found_colon = false
    while i < rest.len() {
        let ch = rest.chars()[i]
        if ch == ":" { found_colon = true }
        if found_colon && ch == "\"" {
            // extract until next quote
            let sub = rest.substring((i + 1), rest.len())
            let parts = sub.split("\"")
            if parts.len() >= 1 { return parts[0] }
        }
        i = i + 1
    }
    ""
}

// ─── category mapper ───

pure fn domain_to_category(domain: string) -> string {
    if domain.contains("quantum") || domain.contains("qubit") { return "physics" }
    if domain.contains("consciousness") || domain.contains("anima") || domain.contains("cognitive") { return "cognition" }
    if domain.contains("biology") || domain.contains("bio") || domain.contains("gene") || domain.contains("dna") || domain.contains("crispr") { return "biology" }
    if domain.contains("chemistry") || domain.contains("chem") || domain.contains("polymer") || domain.contains("material") { return "chemistry" }
    if domain.contains("math") || domain.contains("number") || domain.contains("topology") || domain.contains("algebra") || domain.contains("elliptic") { return "math" }
    if domain.contains("physics") || domain.contains("cosmology") || domain.contains("particle") || domain.contains("gravity") || domain.contains("plasma") || domain.contains("nuclear") { return "physics" }
    if domain.contains("chip") || domain.contains("semiconductor") || domain.contains("fpga") || domain.contains("asic") || domain.contains("cpu") || domain.contains("gpu") || domain.contains("npu") || domain.contains("soc") || domain.contains("dram") || domain.contains("nand") { return "engineering" }
    if domain.contains("energy") || domain.contains("solar") || domain.contains("wind") || domain.contains("fusion") || domain.contains("battery") || domain.contains("fuel") || domain.contains("thermal") || domain.contains("heat") { return "fusion" }
    if domain.contains("ai") || domain.contains("compiler") || domain.contains("software") || domain.contains("runtime") || domain.contains("lang") || domain.contains("lsp") || domain.contains("debugger") || domain.contains("pkg") || domain.contains("browser") || domain.contains("network") || domain.contains("crypto") || domain.contains("blockchain") || domain.contains("edge") || domain.contains("computing") { return "cs" }
    if domain.contains("robot") || domain.contains("autonomous") || domain.contains("drone") || domain.contains("vehicle") || domain.contains("aerospace") || domain.contains("aviation") || domain.contains("railway") || domain.contains("ship") || domain.contains("submarine") || domain.contains("hovercraft") || domain.contains("hyperloop") || domain.contains("maglev") { return "engineering" }
    if domain.contains("earth") || domain.contains("ocean") || domain.contains("climate") || domain.contains("seism") || domain.contains("soil") || domain.contains("forest") || domain.contains("wetland") || domain.contains("pollution") || domain.contains("environment") || domain.contains("carbon") || domain.contains("agriculture") || domain.contains("aquaculture") { return "earth_science" }
    if domain.contains("economics") || domain.contains("economy") || domain.contains("market") || domain.contains("warehouse") { return "economics" }
    if domain.contains("audio") || domain.contains("music") || domain.contains("sound") || domain.contains("acoustic") || domain.contains("noise") { return "thermodynamics" }
    if domain.contains("art") || domain.contains("linguistics") || domain.contains("fantasy") || domain.contains("oracle") || domain.contains("calendar") || domain.contains("notation") { return "arts_humanities" }
    if domain.contains("medical") || domain.contains("surgery") || domain.contains("mri") || domain.contains("endoscop") || domain.contains("ultrasound") || domain.contains("ct-") || domain.contains("pet-") || domain.contains("eeg") || domain.contains("prosthetic") || domain.contains("vaccine") || domain.contains("pharma") || domain.contains("cancer") || domain.contains("hair") { return "biology" }
    if domain.contains("display") || domain.contains("holographic") || domain.contains("e-ink") || domain.contains("micro-led") || domain.contains("liquid-crystal") || domain.contains("ar-vr") { return "engineering" }
    // catch-all for engineering/manufacturing
    if domain.contains("manufactur") || domain.contains("weld") || domain.contains("cnc") || domain.contains("3d-print") || domain.contains("laser") || domain.contains("conveyor") || domain.contains("packag") || domain.contains("pipe") || domain.contains("valve") || domain.contains("gear") || domain.contains("bearing") || domain.contains("spring") || domain.contains("fastener") || domain.contains("wire") || domain.contains("ceramic") || domain.contains("glass") || domain.contains("concrete") || domain.contains("steel") || domain.contains("titanium") || domain.contains("aluminum") || domain.contains("rubber") { return "engineering" }
    "cross_domain"
}

// ─── Source 1: DSE domain mining ───

fn mine_dse_domains(existing: #{string: bool}) -> string {
    let dir = _abs(_DSE_REL)
    let raw = exec("ls '" + dir + "' 2>/dev/null").trim()
    if raw == "" { return "" }
    let files = raw.split("\n")
    let mut result = ""
    let mut count = 0
    for f in files {
        if f.ends_with(".toml") {
            let domain = f.replace(".toml", "")
            let lens_name = domain.replace("-", "_")
            if !has_key(existing, lens_name) {
                let cat = domain_to_category(domain)
                let entry = "{\"name\":\"" + lens_name + "\",\"file\":\"lens_expander.hexa#dse\",\"category\":\"" + cat + "\",\"status\":\"synthesized\",\"derived_from\":\"dse/" + domain + "\",\"description\":\"DSE domain " + domain + "\"}"
                if result != "" { result = result + "\n" }
                result = result + entry
                count = count + 1
            }
        }
    }
    println("  [dse] mined " + to_string(count) + " candidates from " + to_string(files.len()) + " domains")
    result
}

// ─── Source 2: atlas node mining ───

fn mine_atlas_nodes(existing: #{string: bool}) -> string {
    let path = _abs(_ATLAS_REL)
    if !file_exists(path) { return "" }
    // read last 4000 lines for recent nodes
    let raw = exec("tail -4000 '" + path + "' 2>/dev/null").trim()
    if raw == "" { return "" }
    let lines = raw.split("\n")
    let mut result = ""
    let mut count = 0
    let mut seen = #{} as #{string: bool}
    for line in lines {
        // atlas node format: @R <id> = <status> <domain> :: <category> [<grade>]
        if line.starts_with("@R ") || line.starts_with("@X ") {
            let parts = line.split(" = ")
            if parts.len() >= 2 {
                let id_part = parts[0].trim()
                // extract id: after "@R " or "@X "
                let id_tokens = id_part.split(" ")
                if id_tokens.len() >= 2 {
                    let node_id = id_tokens[1].trim()
                    // convert to lens name: replace hyphens
                    let lens_name = "atlas_" + node_id.replace("-", "_")
                    if !has_key(existing, lens_name) && !has_key(seen, lens_name) && count < 800 {
                        // extract domain from the right side
                        let right = parts[1].trim()
                        let domain_parts = right.split("::")
                        let raw_cat = if domain_parts.len() >= 2 { domain_parts[1].trim() } else { "cross_domain" }
                        // clean category: remove [grade] suffix
                        let cat_clean = raw_cat.split("[")
                        let cat_raw = cat_clean[0].trim()
                        let cat = if cat_raw == "dse" || cat_raw == "cross" || cat_raw == "" { "cross_domain" } else { cat_raw }
                        let entry = "{\"name\":\"" + lens_name + "\",\"file\":\"lens_expander.hexa#atlas\",\"category\":\"" + cat + "\",\"status\":\"synthesized\",\"derived_from\":\"atlas/" + node_id + "\",\"description\":\"Atlas node " + node_id + "\"}"
                        if result != "" { result = result + "\n" }
                        result = result + entry
                        seen[lens_name] = true
                        count = count + 1
                    }
                }
            }
        }
    }
    println("  [atlas] mined " + to_string(count) + " candidates")
    result
}

// ─── Source 3: BT domain crosses ───

fn mine_bt_crosses(existing: #{string: bool}) -> string {
    let path = _abs(_BT_DOMAINS_REL)
    if !file_exists(path) { return "" }
    let raw = read_file(path)
    let lines = raw.split("\n")
    let mut bt_domains = [] as [string]
    for line in lines {
        if line.contains("\"domain\"") {
            let d = _extract(line, "domain")
            if d != "" {
                bt_domains.push(d)
            }
        }
    }
    let mut result = ""
    let mut count = 0
    // generate cross pairs from BT domains
    let mut i = 0
    while i < bt_domains.len() {
        let mut j = i + 1
        while j < bt_domains.len() {
            let a = bt_domains[i]
            let b = bt_domains[j]
            let lens_name = "bt_" + a + "_x_" + b
            if !has_key(existing, lens_name) && count < 600 {
                let cat = "cross_domain"
                let entry = "{\"name\":\"" + lens_name + "\",\"file\":\"lens_expander.hexa#bt_cross\",\"category\":\"" + cat + "\",\"status\":\"synthesized\",\"derived_from\":\"bt/" + a + "+" + b + "\",\"description\":\"BT cross " + a + " x " + b + "\"}"
                if result != "" { result = result + "\n" }
                result = result + entry
                count = count + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    println("  [bt_cross] mined " + to_string(count) + " candidates from " + to_string(bt_domains.len()) + " BT domains")
    result
}

// ─── Source 4: DSE cross-domain ordered pairs (A_via_B) ───

fn mine_dse_crosses(existing: #{string: bool}, dse_names: [string]) -> string {
    let mut result = ""
    let mut count = 0
    // take first 60 domains to keep output bounded: 60*59 = 3540 max pairs
    let limit = if dse_names.len() < 60 { dse_names.len() } else { 60 }
    let mut i = 0
    while i < limit {
        let mut j = 0
        while j < limit {
            if i != j && count < 1200 {
                let a = dse_names[i]
                let b = dse_names[j]
                let lens_name = a.replace("-", "_") + "_via_" + b.replace("-", "_")
                if !has_key(existing, lens_name) {
                    let entry = "{\"name\":\"" + lens_name + "\",\"file\":\"lens_expander.hexa#dse_cross\",\"category\":\"cross_domain\",\"status\":\"synthesized\",\"derived_from\":\"dse_cross/" + a + "+" + b + "\",\"description\":\"DSE cross " + a + " via " + b + "\"}"
                    if result != "" { result = result + "\n" }
                    result = result + entry
                    count = count + 1
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    println("  [dse_cross] mined " + to_string(count) + " cross-domain pairs")
    result
}

// ─── quality filter ───

pure fn quality_check(line: string) -> bool {
    // must have: name, category, file (backing source), status, derived_from or description
    let name = _extract(line, "name")
    let cat = _extract(line, "category")
    let file = _extract(line, "file")
    let status = _extract(line, "status")
    let desc = _extract(line, "description")
    let derived = _extract(line, "derived_from")
    if name == "" || cat == "" || file == "" || status == "" { return false }
    if desc == "" && derived == "" { return false }
    if name.len() < 3 { return false }
    true
}

// ─── dedup against existing + staging ───

fn dedup_staging(candidates: string, existing: #{string: bool}) -> string {
    let lines = candidates.split("\n")
    let mut seen = #{} as #{string: bool}
    // copy existing names into seen
    let ex_keys = existing.keys()
    for k in ex_keys {
        seen[k] = true
    }
    let mut result = ""
    let mut kept = 0
    let mut dropped = 0
    for line in lines {
        if line.trim() == "" { continue }
        let name = _extract(line, "name")
        if name == "" || has_key(seen, name) {
            dropped = dropped + 1
            continue
        }
        if !quality_check(line) {
            dropped = dropped + 1
            continue
        }
        seen[name] = true
        if result != "" { result = result + "\n" }
        result = result + line
        kept = kept + 1
    }
    println("  [dedup] kept=" + to_string(kept) + " dropped=" + to_string(dropped))
    result
}

// ─── CLI: scan ───

fn cmd_scan() {
    println("=== lens_expander: scan ===")
    let existing = load_existing_names()
    let cur = count_registry()
    println("  current registry: " + to_string(cur) + " lenses")
    let target = 4000
    let gap = target - cur
    println("  target: " + to_string(target) + "  gap: " + to_string(gap))

    // mine all sources
    let dse = mine_dse_domains(existing)
    let atlas = mine_atlas_nodes(existing)
    let bt = mine_bt_crosses(existing)

    // count candidates
    let mut total = 0
    if dse != "" { total = total + dse.split("\n").len() }
    if atlas != "" { total = total + atlas.split("\n").len() }
    if bt != "" { total = total + bt.split("\n").len() }

    println("  total raw candidates: " + to_string(total))
    println("  (run 'generate' to produce staging file)")
}

// ─── CLI: generate ───

fn cmd_generate() {
    println("=== lens_expander: generate ===")
    let existing = load_existing_names()
    let cur = count_registry()
    let target = 4000
    let gap = target - cur
    println("  current: " + to_string(cur) + "  target: " + to_string(target) + "  need: " + to_string(gap))

    // mine sources
    let dse = mine_dse_domains(existing)
    let atlas = mine_atlas_nodes(existing)
    let bt = mine_bt_crosses(existing)

    // collect DSE names for cross pairs
    let dir = _abs(_DSE_REL)
    let raw_ls = exec("ls '" + dir + "' 2>/dev/null").trim()
    let mut dse_names = [] as [string]
    if raw_ls != "" {
        let files = raw_ls.split("\n")
        for f in files {
            if f.ends_with(".toml") {
                dse_names.push(f.replace(".toml", ""))
            }
        }
    }
    let dse_cross = mine_dse_crosses(existing, dse_names)

    // merge all candidates
    let mut all = ""
    if dse != "" { all = dse }
    if atlas != "" { all = if all == "" { atlas } else { all + "\n" + atlas } }
    if bt != "" { all = if all == "" { bt } else { all + "\n" + bt } }
    if dse_cross != "" { all = if all == "" { dse_cross } else { all + "\n" + dse_cross } }

    if all == "" {
        println("  no candidates found")
        return
    }

    // dedup + quality filter
    let clean = dedup_staging(all, existing)
    if clean == "" {
        println("  all candidates filtered out")
        return
    }

    let clean_lines = clean.split("\n")
    let avail = clean_lines.len()
    println("  available after dedup: " + to_string(avail))

    // cap at gap count
    let take = if avail < gap { avail } else { gap }
    let mut staging = ""
    let mut i = 0
    while i < take {
        if staging != "" { staging = staging + "\n" }
        staging = staging + clean_lines[i]
        i = i + 1
    }

    // write staging
    let staging_path = _abs(_STAGING_REL)
    write_file(staging_path, staging)
    println("  staging written: " + to_string(take) + " lenses -> " + _STAGING_REL)
    println("  (run 'merge' to apply to registry)")
}

// ─── CLI: merge ───

fn cmd_merge() {
    println("=== lens_expander: merge ===")
    let staging_path = _abs(_STAGING_REL)
    if !file_exists(staging_path) {
        println("  ERROR: no staging file. run 'generate' first")
        return
    }

    let staging_raw = read_file(staging_path)
    if staging_raw.trim() == "" {
        println("  ERROR: staging file is empty")
        return
    }

    let staging_lines = staging_raw.trim().split("\n")
    let new_count = staging_lines.len()
    println("  staging lenses: " + to_string(new_count))

    // read current registry
    let reg_path = _abs(_REG_REL)
    let reg_raw = read_file(reg_path)

    // find insertion point: before the last "]" and "}"
    // registry format: { "version":..., "lenses": [ {...}, {...} ] }
    // we insert before the closing ] of lenses array
    let close_idx = reg_raw.trim().len()
    // strategy: parse JSON, append, rewrite
    // simpler: find last "]" position and insert before it
    let mut last_bracket = -1
    let mut ci = 0
    let chars = reg_raw.chars()
    while ci < chars.len() {
        if chars[ci] == "]" {
            last_bracket = ci
        }
        ci = ci + 1
    }

    if last_bracket < 0 {
        println("  ERROR: cannot find lenses array end in registry")
        return
    }

    // build new entries as JSON array items
    let mut new_entries = ""
    let mut si = 0
    for staging_line in staging_lines {
        let name = _extract(staging_line, "name")
        let cat = _extract(staging_line, "category")
        let file_ref = _extract(staging_line, "file")
        let status = _extract(staging_line, "status")
        let derived = _extract(staging_line, "derived_from")
        let desc = _extract(staging_line, "description")

        let mut entry = ",\n    {\n"
        entry = entry + "      \"name\": \"" + name + "\",\n"
        entry = entry + "      \"file\": \"" + file_ref + "\",\n"
        entry = entry + "      \"category\": \"" + cat + "\",\n"
        entry = entry + "      \"status\": \"" + status + "\""
        if derived != "" {
            entry = entry + ",\n      \"derived_from\": \"" + derived + "\""
        }
        if desc != "" {
            entry = entry + ",\n      \"description\": \"" + desc + "\""
        }
        entry = entry + "\n    }"
        new_entries = new_entries + entry
        si = si + 1
    }

    // splice into registry
    let before = reg_raw.substring(0, last_bracket)
    let after = reg_raw.substring(last_bracket, reg_raw.len())
    let updated = before + new_entries + "\n  " + after

    // update total in header
    let old_total = count_registry()
    let new_total = old_total + new_count
    let old_total_str = "\"total\": " + to_string(old_total)
    let new_total_str = "\"total\": " + to_string(new_total)
    let final_reg = updated.replace(old_total_str, new_total_str)

    // also update description
    let old_desc_marker = "\"total\": " + to_string(old_total)
    // write
    write_file(reg_path, final_reg)
    println("  merged " + to_string(new_count) + " lenses into registry")
    println("  new total: " + to_string(new_total))

    // archive staging
    let archive_path = _abs("shared/blowup/lens/lens_expansion_staging.merged.jsonl")
    write_file(archive_path, staging_raw)
    write_file(staging_path, "")
    println("  staging archived and cleared")
}

// ─── CLI: status ───

fn cmd_status() {
    println("=== lens_expander: status ===")
    let cur = count_registry()
    let target = 4000
    let gap = target - cur
    let pct = (cur * 100) / target

    println("  registry: " + to_string(cur) + " / " + to_string(target) + " (" + to_string(pct) + "%)")
    println("  gap: " + to_string(gap))

    let staging_path = _abs(_STAGING_REL)
    if file_exists(staging_path) {
        let raw = read_file(staging_path)
        if raw.trim() != "" {
            let lines = raw.trim().split("\n")
            println("  staging: " + to_string(lines.len()) + " lenses pending merge")
        } else {
            println("  staging: empty")
        }
    } else {
        println("  staging: not generated yet")
    }

    // category breakdown
    let existing = load_existing_names()
    let ex_keys = existing.keys()
    println("  unique names: " + to_string(ex_keys.len()))
}

// ─── main ───

let _a = args()
let mode = if _a.len() >= 3 { _a[2] } else { "status" }

match mode {
    "scan" -> cmd_scan(),
    "generate" -> cmd_generate(),
    "merge" -> cmd_merge(),
    "status" -> cmd_status(),
    _ -> {
        println("usage: hexa lens_expander.hexa <scan|generate|merge|status>")
        println("  scan     — find candidates from DSE/atlas/BT sources")
        println("  generate — create staging JSONL with dedup + quality filter")
        println("  merge    — apply staging to lens_registry.json")
        println("  status   — show current count vs target")
    }
}
