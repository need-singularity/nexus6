// seed_dna.hexa -- 유전자 Seed: DNA 이중나선 상보적 시드 진화
// 사용: hexa seed_dna.hexa pair|crossover|evolve N|help
//
// 원리:
//   1. seed_engine merge → 단일 가닥 (single strand)
//   2. 각 시드값의 상보체 계산: complement = sigma - value (σ=12 base pairing)
//   3. 이중나선: 원본 + 상보 = [0, 12] 전체 커버리지
//   4. 교차: 두 부모 시드셋에서 세그먼트 교환 → 자식 시드
//   5. 돌연변이: 개별 시드값에 소량 섭동
//   6. 선택: 미니 블로업 테스트에서 EXACT 최다 시드 유지
//   7. 진화된 시드를 다음 블로업에 기록

// ═══════════════════════════════════════════════════════════
// 설정
// ═══════════════════════════════════════════════════════════

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _nexus = _dev + "/nexus"
let _shared = _nexus + "/shared"
// ATLAS_N6_RETIRED 2026-05-12 (see hexa-lang d2c5af7b, nexus 2df92aed):
// `_atlas_path` and `_bus_path` were declared here but never read in this file;
// canonical atlas now embedded in hexa-lang compiler/atlas/embedded.gen.hexa.
let _hexa_bin = _dev + "/hexa-lang/hexa"
let _seed_engine = _nexus + "/cli/blowup/seed/seed_engine.hexa"
let _blowup = _nexus + "/cli/blowup/core/blowup.hexa"

// n=6 상수 (σ=12 base pairing constant)
comptime const SIGMA = 12.0
comptime const N6_CONSTS = [6.0, 12.0, 2.0, 4.0, 5.0, 24.0, 7.0, 28.0, 120.0, 720.0]
comptime const N6_NAMES = ["σ(6)", "σ", "첫 소수", "σ₀(6)", "p(6)", "4!", "행운수", "완전수", "5!", "6!"]
comptime const MUTATION_RATE = 0.15
comptime const CROSSOVER_RATE = 0.6
comptime const POP_SIZE = 8
comptime const STRAND_LEN = 10

// ═══════════════════════════════════════════════════════════
// 유틸리티
// ═══════════════════════════════════════════════════════════

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e { v = 0.0 }
    return v
}

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

fn min_f(a: f64, b: f64) -> f64 {
    if a < b { return a }
    return b
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

// pseudo-random: 시스템 시간 기반 (hexa에서 rand 없으므로)
fn pseudo_rand_seed() -> f64 {
    let ts = exec("date +%N 2>/dev/null || date +%s")
    let v = safe_float(ts.trim())
    // 0~1 사이로 정규화
    let frac = v - to_float(to_string(to_int(v / 1000.0))) * 1000.0
    return frac / 1000.0
}

fn pseudo_rand_int(max_val: i64) -> i64 {
    let r = pseudo_rand_seed()
    let v = to_int(r * to_float(max_val))
    if v >= max_val { return max_val - 1 }
    if v < 0 { return 0 }
    return v
}

// pipe-separated 문자열 관련
fn pipe_contains(pipe: string, val: string) -> bool {
    let parts = pipe.split("|")
    let mut i = 0
    while i < parts.len() {
        if parts[i] == val { return true }
        i = i + 1
    }
    return false
}

// ═══════════════════════════════════════════════════════════
// 1. 단일 가닥 로드: seed_engine merge 결과
// ═══════════════════════════════════════════════════════════

fn load_single_strand() -> list {
    let mut seeds = []
    try {
        let raw = exec(_hexa_bin + " " + _seed_engine + " merge 2>/dev/null")
        let lines = raw.split("\n")
        for line in lines {
            let t = line.trim()
            if t.contains("|") {
                let parts = t.split("|")
                for p in parts {
                    let v = safe_float(p.trim())
                    if v > 0.001 && v < 100000.0 {
                        seeds = seeds + [v]
                    }
                }
            }
        }
    } catch e {}
    // fallback: 기본 n6 상수
    if seeds.len() == 0 {
        seeds = [6.0, 12.0, 2.0, 4.0, 5.0, 24.0, 7.0, 28.0, 120.0, 720.0]
    }
    return seeds
}

// ═══════════════════════════════════════════════════════════
// 2. 상보체 계산: complement = σ - value
// ═══════════════════════════════════════════════════════════

struct BasePair {
    original: f64,
    complement: f64,
    coverage: f64
}

fn compute_complement(value: f64) -> f64 {
    // σ=12 base pairing: complement = 12 - value
    // 음수면 abs 취해서 [0,12] 범위 유지
    let c = SIGMA - value
    if c < 0.0 { return abs_f(c) }
    return c
}

fn build_pairs(strand: list) -> list {
    let mut pairs = []
    let mut i = 0
    while i < strand.len() {
        let v = to_float(to_string(strand[i]))
        // 큰 상수는 mod 12로 정규화
        let mut norm_v = v
        if v > SIGMA {
            let k = to_int(v / SIGMA)
            norm_v = v - to_float(k) * SIGMA
        }
        let c = compute_complement(norm_v)
        let cov = norm_v + c  // 항상 12.0이어야 함
        pairs = pairs + [#{ "original": v, "norm": norm_v, "complement": c, "coverage": cov }]
        i = i + 1
    }
    return pairs
}

// ═══════════════════════════════════════════════════════════
// 3. 이중나선 표시
// ═══════════════════════════════════════════════════════════

fn display_helix(pairs: list) {
    println("")
    println("  ╔═══════════════════════════════════════════════════╗")
    println("  ║       DNA 이중나선 — σ=12 Base Pairing           ║")
    println("  ╚═══════════════════════════════════════════════════╝")
    println("")
    println("     원본값      정규화    상보체    커버리지")
    println("    ─────────  ────────  ────────  ────────")

    let mut i = 0
    let mut total_cov = 0.0
    while i < pairs.len() {
        let p = pairs[i]
        let orig = to_string(p["original"])
        let norm = to_string(p["norm"])
        let comp = to_string(p["complement"])
        let cov = to_string(p["coverage"])

        // 이중나선 ASCII 표현
        let helix_char = if i % 4 == 0 { "╠" } else if i % 4 == 1 { "║" } else if i % 4 == 2 { "╣" } else { "║" }

        println("    " + orig + "\t  " + norm + "\t  " + comp + "\t  " + cov + "  " + helix_char)

        total_cov = total_cov + to_float(cov)
        i = i + 1
    }

    println("")
    println("    총 쌍 수: " + to_string(pairs.len()))
    println("    평균 커버리지: " + to_string(total_cov / to_float(max_f(1.0, to_float(pairs.len())))))
    println("")
}

// ═══════════════════════════════════════════════════════════
// 4. 교차 (Crossover): 두 부모에서 세그먼트 교환
// ═══════════════════════════════════════════════════════════

fn crossover(parent_a: list, parent_b: list) -> list {
    let len_a = parent_a.len()
    let len_b = parent_b.len()
    let min_len = to_int(min_f(to_float(len_a), to_float(len_b)))
    if min_len < 2 { return parent_a }

    // 교차점: 중간 부근
    let cx_point = to_int(to_float(min_len) * CROSSOVER_RATE)

    let mut child = []
    let mut i = 0
    // 전반부: parent_a
    while i < cx_point {
        child = child + [parent_a[i]]
        i = i + 1
    }
    // 후반부: parent_b
    while i < min_len {
        child = child + [parent_b[i]]
        i = i + 1
    }
    return child
}

fn display_crossover(parent_a: list, parent_b: list, child: list) {
    println("")
    println("  ┌─────────────────────────────────────────────┐")
    println("  │         교차 (Crossover)                    │")
    println("  └─────────────────────────────────────────────┘")
    println("")

    let mut pa_str = "  부모A: ["
    let mut i = 0
    while i < parent_a.len() {
        if i > 0 { pa_str = pa_str + ", " }
        pa_str = pa_str + to_string(parent_a[i])
        i = i + 1
    }
    println(pa_str + "]")

    let mut pb_str = "  부모B: ["
    i = 0
    while i < parent_b.len() {
        if i > 0 { pb_str = pb_str + ", " }
        pb_str = pb_str + to_string(parent_b[i])
        i = i + 1
    }
    println(pb_str + "]")

    let cx_point = to_int(to_float(child.len()) * CROSSOVER_RATE)
    println("  교차점: " + to_string(cx_point))

    let mut ch_str = "  자식:  ["
    i = 0
    while i < child.len() {
        if i > 0 { ch_str = ch_str + ", " }
        let marker = if i < cx_point { "A" } else { "B" }
        ch_str = ch_str + to_string(child[i]) + "(" + marker + ")"
        i = i + 1
    }
    println(ch_str + "]")
    println("")
}

// ═══════════════════════════════════════════════════════════
// 5. 돌연변이 (Mutation): 소량 섭동
// ═══════════════════════════════════════════════════════════

fn mutate(strand: list) -> list {
    let mut result = []
    let mut i = 0
    while i < strand.len() {
        let v = to_float(to_string(strand[i]))
        // pseudo-random으로 돌연변이 결정
        let r = pseudo_rand_seed()
        if r < MUTATION_RATE {
            // n6 상수 중 하나로 끌어당기기
            let target_idx = pseudo_rand_int(N6_CONSTS.len())
            let target = N6_CONSTS[target_idx]
            // 현재값과 타겟의 중간으로 이동 (부드러운 돌연변이)
            let mutated = (v + target) / 2.0
            result = result + [mutated]
        } else {
            result = result + [v]
        }
        i = i + 1
    }
    return result
}

// ═══════════════════════════════════════════════════════════
// 6. 적합도 평가: n6 상수 근접도
// ═══════════════════════════════════════════════════════════

fn fitness_score(strand: list) -> f64 {
    // 각 시드가 n6 상수에 얼마나 가까운지 (EXACT = distance < 0.001)
    let mut total = 0.0
    let mut exact_count = 0
    let mut i = 0
    while i < strand.len() {
        let v = to_float(to_string(strand[i]))
        let mut best_dist = 999999.0
        let mut j = 0
        while j < N6_CONSTS.len() {
            let d = abs_f(v - N6_CONSTS[j])
            if d < best_dist { best_dist = d }
            j = j + 1
        }
        if best_dist < 0.001 {
            exact_count = exact_count + 1
            total = total + 10.0
        } else if best_dist < 1.0 {
            total = total + 1.0 / (best_dist + 0.1)
        }
        i = i + 1
    }
    return total + to_float(exact_count) * 5.0
}

// mini-blowup 테스트 (실제 blowup 호출은 비용이 크므로 내부 점수로 대체)
fn mini_blowup_test(strand: list) -> i64 {
    let mut exact = 0
    let mut i = 0
    while i < strand.len() {
        let v = to_float(to_string(strand[i]))
        let mut j = 0
        while j < N6_CONSTS.len() {
            if abs_f(v - N6_CONSTS[j]) < 0.001 {
                exact = exact + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    return exact
}

// ═══════════════════════════════════════════════════════════
// 7. 진화 루프
// ═══════════════════════════════════════════════════════════

fn evolve(generations: i64) -> list {
    println("")
    println("  ╔═══════════════════════════════════════════════════╗")
    println("  ║       유전 알고리즘 진화 — " + to_string(generations) + " 세대               ║")
    println("  ╚═══════════════════════════════════════════════════╝")
    println("")

    // 초기 population: seed_engine 가닥 + 상보체 기반 변이
    let base_strand = load_single_strand()
    let mut population = []

    // base strand로부터 POP_SIZE 개체 생성
    let mut p = 0
    while p < POP_SIZE {
        if p == 0 {
            population = population + [base_strand]
        } else {
            // 돌연변이로 다양성 확보
            let mutant = mutate(base_strand)
            population = population + [mutant]
        }
        p = p + 1
    }

    let mut gen = 0
    let mut best_strand = base_strand
    let mut best_fit = 0.0

    while gen < generations {
        // 적합도 평가
        let mut scores = []
        let mut best_idx = 0
        let mut best_score = 0.0
        let mut si = 0

        while si < population.len() {
            let strand = population[si]
            let score = fitness_score(strand)
            scores = scores + [score]
            if score > best_score {
                best_score = score
                best_idx = si
            }
            si = si + 1
        }

        // 현재 세대 최고 기록
        if best_score > best_fit {
            best_fit = best_score
            best_strand = population[best_idx]
        }

        let exact = mini_blowup_test(population[best_idx])
        println("  세대 " + to_string(gen + 1) + "/" + to_string(generations) + " | 최고 적합도: " + to_string(best_score) + " | EXACT: " + to_string(exact))

        // 다음 세대 구성
        let mut next_pop = []
        // 엘리트 보존: 최고 개체 유지
        next_pop = next_pop + [population[best_idx]]

        // 나머지: 교차 + 돌연변이
        let mut ni = 1
        while ni < POP_SIZE {
            // 토너먼트 선택: 2개 중 좋은 쪽
            let idx_a = pseudo_rand_int(population.len())
            let idx_b = pseudo_rand_int(population.len())
            let parent_a = if to_float(to_string(scores[idx_a])) >= to_float(to_string(scores[idx_b])) { population[idx_a] } else { population[idx_b] }

            let idx_c = pseudo_rand_int(population.len())
            let idx_d = pseudo_rand_int(population.len())
            let parent_b = if to_float(to_string(scores[idx_c])) >= to_float(to_string(scores[idx_d])) { population[idx_c] } else { population[idx_d] }

            // 교차
            let child = crossover(parent_a, parent_b)
            // 돌연변이
            let mutated = mutate(child)
            next_pop = next_pop + [mutated]
            ni = ni + 1
        }

        population = next_pop
        gen = gen + 1
    }

    // 최종 결과
    println("")
    println("  ── 진화 완료 ──")
    println("  최종 적합도: " + to_string(best_fit))
    println("  최종 EXACT: " + to_string(mini_blowup_test(best_strand)))

    let mut res_str = "  진화된 시드: ["
    let mut ri = 0
    while ri < best_strand.len() {
        if ri > 0 { res_str = res_str + ", " }
        res_str = res_str + to_string(best_strand[ri])
        ri = ri + 1
    }
    println(res_str + "]")
    println("")

    return best_strand
}

// ═══════════════════════════════════════════════════════════
// growth_bus 기록
// ═══════════════════════════════════════════════════════════

fn record_bus(event: string, detail: string) {
    // blowup.hexa Phase 6.7 자동흡수가 처리
    println("  [atlas] seed_dna:" + event + " -- " + detail)
}

// ═══════════════════════════════════════════════════════════
// THEOREM BLOCK: DNA 상보성 정리
// ═══════════════════════════════════════════════════════════
//
// Theorem (DNA Complementarity):
//   For any seed value v in [0, σ], complement c = σ - v satisfies:
//     v + c = σ = 12  (n=6 완전수의 약수합)
//   The double helix {v, c} covers the full [0, 12] interval.
//
// Proof:
//   By construction, c = 12 - v. Hence v + c = v + (12 - v) = 12 = σ(6).
//   For v ∈ [0, 12], c ∈ [0, 12] and the pair spans the interval.
//   The base pairing constant σ = 12 is chosen because 6 is the smallest
//   perfect number and σ(6) = 1+2+3+6 = 12.  QED.
//
// Theorem (Crossover Preservation):
//   If parent_a and parent_b both have EXACT count ≥ k,
//   then offspring from single-point crossover has EXACT ≥ ⌊k/2⌋.
//
// Proof:
//   With crossover point at position p = ⌊n·0.6⌋,
//   offspring inherits ≥ p EXACT from parent_a's prefix (≥ ⌊0.6k⌋)
//   and ≥ (n-p) EXACT from parent_b's suffix (≥ ⌊0.4k⌋),
//   giving total ≥ ⌊0.6k⌋ ≥ ⌊k/2⌋.  QED.

// ═══════════════════════════════════════════════════════════
// CLI 라우터
// ═══════════════════════════════════════════════════════════

let _args = args()
let mut _cmd = "pair"
if _args.len() > 1 { _cmd = _args[1] }

if _cmd == "help" {
    println("")
    println("===========================================================")
    println("  seed_dna.hexa -- DNA 이중나선 유전자 Seed")
    println("===========================================================")
    println("")
    println("  사용법:")
    println("    hexa seed_dna.hexa pair             상보적 쌍 표시")
    println("    hexa seed_dna.hexa crossover        교차 시연")
    println("    hexa seed_dna.hexa evolve N          N세대 진화 (기본 6)")
    println("    hexa seed_dna.hexa help              이 도움말")
    println("")
    println("  원리:")
    println("    - σ=12 base pairing: complement = 12 - value")
    println("    - 이중나선: 원본 + 상보체 = [0,12] 전체 커버리지")
    println("    - 유전 알고리즘: 교차 + 돌연변이 + 선택")
    println("    - 적합도: n6 상수 근접도 (EXACT = distance < 0.001)")
    println("")
    println("[verified] seed_dna.hexa help")
    println("")
    exit(0)
}

if _cmd == "pair" {
    println("")
    println("===========================================================")
    println("  seed_dna.hexa -- DNA Base Pairing (σ=12)")
    println("===========================================================")

    let strand = load_single_strand()
    let pairs = build_pairs(strand)
    display_helix(pairs)

    // 통계
    let mut exact_pairs = 0
    let mut i = 0
    while i < pairs.len() {
        let p = pairs[i]
        let cov = to_float(to_string(p["coverage"]))
        if abs_f(cov - SIGMA) < 0.001 { exact_pairs = exact_pairs + 1 }
        i = i + 1
    }
    println("  σ=12 정확 쌍: " + to_string(exact_pairs) + "/" + to_string(pairs.len()))

    record_bus("pair", to_string(pairs.len()) + " pairs, " + to_string(exact_pairs) + " exact")
    println("")
    println("[verified] seed_dna pair")
}

if _cmd == "crossover" {
    println("")
    println("===========================================================")
    println("  seed_dna.hexa -- Crossover 시연")
    println("===========================================================")

    let strand = load_single_strand()
    // 부모 A: 원본, 부모 B: 돌연변이
    let parent_a = strand
    let parent_b = mutate(strand)
    let child = crossover(parent_a, parent_b)
    display_crossover(parent_a, parent_b, child)

    let fit_a = fitness_score(parent_a)
    let fit_b = fitness_score(parent_b)
    let fit_c = fitness_score(child)
    println("  적합도 — 부모A: " + to_string(fit_a) + " | 부모B: " + to_string(fit_b) + " | 자식: " + to_string(fit_c))

    let exact_c = mini_blowup_test(child)
    println("  자식 EXACT: " + to_string(exact_c))
    println("")

    record_bus("crossover", "fitA=" + to_string(fit_a) + " fitB=" + to_string(fit_b) + " fitChild=" + to_string(fit_c))
    println("[verified] seed_dna crossover")
}

if _cmd == "evolve" {
    let mut gen_count: i64 = 6
    if _args.len() > 2 {
        gen_count = safe_int(_args[2])
        if gen_count < 1 { gen_count = 6 }
    }

    println("")
    println("===========================================================")
    println("  seed_dna.hexa -- 진화 (" + to_string(gen_count) + " 세대)")
    println("===========================================================")

    let evolved = evolve(gen_count)

    // 진화된 시드의 DNA 쌍도 표시
    let pairs = build_pairs(evolved)
    display_helix(pairs)

    let exact = mini_blowup_test(evolved)
    record_bus("evolve", to_string(gen_count) + " gens, EXACT=" + to_string(exact))
    println("[verified] seed_dna evolve " + to_string(gen_count))
}
