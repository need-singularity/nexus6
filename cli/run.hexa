fn _kick_tree() -> void {
    let script = nexus_root() + "/tool/kick_tree.hexa"
    if !pfs_file_exists(script) {
        eprintln("nexus kick tree: script missing at " + script)
        eprintln("reason=kick-tree-missing fix=ls " + nexus_root() + "/tool/kick_tree.hexa")
        exit(1)
    }
    let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(script)
