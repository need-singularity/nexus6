    println("  s3→blackhole '닫힌 우주 → 블랙홀 형성' (collapse)")
    println("  t3→wormhole  '도넛 우주 → 웜홀 형성' (handle attachment)")
    println("env override: NEXUS_UNIVERSE_TOPOLOGY={name}, NEXUS_UNIVERSE_EVOLVE_FROM/TO/AT")
    println("source: " + nexus_root() + "/sim_bridge/anu_time/topology_universe.hexa")
}

fn cmd_universe(a: [str]) -> void {
    let n = len(a)
    let sub = if n >= 4 { a[3] } else { "" }
    if sub.len() == 0 || sub == "help" || sub == "-h" || sub == "--help" {
        _universe_help(); return
    }
    // Stage 6 candidate: state-propagation pipeline (cross-feed)
    if sub == "propagation" {
        let prscript = nexus_root() + "/sim_bridge/anu_time/universe_propagation.hexa"
        let prsub = if n >= 5 { a[4] } else { "" }
        if prsub == "selftest" || prsub == "--selftest" {
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(prscript) + " --selftest"
            print(exec(cmd + " 2>&1"))
            return
        }
        if prsub == "run" {
            if n < 6 { println("usage: nexus universe propagation run <topology> [ticks_per_stage]"); return }
            let prtopo = a[5]
            let prticks = if n >= 7 { a[6] } else { "12" }
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(prscript) + " " + shell_quote(prtopo) + " " + shell_quote(prticks)
            print(exec(cmd + " 2>&1"))
            return
        }
        println("[universe propagation] usage: nexus universe propagation {selftest|run <topo> [ticks_per_stage]}")
        println("  Stage 6 candidate: cross-feed pipeline (Stage 1 → 2 → 3 → 4 with state propagation)")
        println("  topology: flat | t3 | s3 | blackhole | wormhole")
        println("  source: " + prscript)
        return
    }
    // unified pipeline runner (Stage 1-5 sequential)
    if sub == "pipeline" {
        let pscript = nexus_root() + "/sim_bridge/anu_time/universe_pipeline.hexa"
        let psub = if n >= 5 { a[4] } else { "" }
        if psub == "selftest" || psub == "--selftest" {
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(pscript) + " --selftest"
            print(exec(cmd + " 2>&1"))
            return
        }
        if psub == "list-topo" {
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(pscript) + " list-topo"
            print(exec(cmd + " 2>&1"))
            return
        }
        if psub == "run" {
            if n < 6 { println("usage: nexus universe pipeline run <topology> [ticks]"); return }
            let ptopo = a[5]
            let pticks = if n >= 7 { a[6] } else { "50" }
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(pscript) + " " + shell_quote(ptopo) + " " + shell_quote(pticks)
            print(exec(cmd + " 2>&1"))
            return
        }
        println("[universe pipeline] usage: nexus universe pipeline {selftest|list-topo|run <topo> [ticks]}")
        println("  unified Stage 1-5 runner: quantum + Lorentz + field + anchor + scale on single topology")
        println("  topology: flat | t3 | s3 | blackhole | wormhole")
        println("  source: " + pscript)
        return
    }
    // Stage 5 scale-up evolution
    if sub == "scale" {
        let sscript = nexus_root() + "/sim_bridge/anu_time/scale_universe.hexa"
        let ssub = if n >= 5 { a[4] } else { "" }
        if ssub == "selftest" || ssub == "--selftest" {
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(sscript) + " --selftest"
            print(exec(cmd + " 2>&1"))
            return
        }
        if ssub == "benchmark" {
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(sscript) + " benchmark"
            print(exec(cmd + " 2>&1"))
            return
        }
        if ssub == "run" {
            if n < 7 { println("usage: nexus universe scale run <ticks> <sigma2>"); return }
            let sticks = a[5]
            let ssigma = a[6]
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(sscript) + " " + shell_quote(sticks) + " " + shell_quote(ssigma)
            print(exec(cmd + " 2>&1"))
            return
        }
        println("[universe scale] usage: nexus universe scale {selftest|benchmark|run <ticks> <sigma2=64|512|1024|4096>}")
        println("  source: " + sscript)
        return
    }
    // Stage 4 v2 — bias-free anchor (iter-27 honest baseline)
    if sub == "anchor-v2" {
        let a2script = nexus_root() + "/sim_bridge/anu_time/empirical_anchor_v2.hexa"
        let a2sub = if n >= 5 { a[4] } else { "" }
        if a2sub == "selftest" || a2sub == "--selftest" {
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(a2script) + " --selftest"
            print(exec(cmd + " 2>&1"))
            return
        }
        if a2sub == "topo" {
            if n < 6 { println("usage: nexus universe anchor-v2 topo <topology> [ticks]"); return }
            let a2topo = a[5]
            let a2ticks = if n >= 7 { a[6] } else { "50" }
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(a2script) + " " + shell_quote(a2ticks) + " " + shell_quote(a2topo)
            print(exec(cmd + " 2>&1"))
            return
        }
        if a2sub == "compare" {
            if n < 6 { println("usage: nexus universe anchor-v2 compare <topology>"); return }
            let a2topo = a[5]
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(a2script) + " compare-v1-v2 " + shell_quote(a2topo)
            print(exec(cmd + " 2>&1"))
            return
        }
        println("[universe anchor-v2] usage: nexus universe anchor-v2 {selftest|topo <topo> [ticks]|compare <topo>}")
        println("  iter-27 honest baseline: PURE sim observables, no reference-range hardcoding")
        println("  source: " + a2script)
        return
    }
    // Stage 4 empirical anchor evolution
    if sub == "anchor" {
        let ascript = nexus_root() + "/sim_bridge/anu_time/empirical_anchor.hexa"
        let asub = if n >= 5 { a[4] } else { "" }
        if asub == "selftest" || asub == "--selftest" {
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(ascript) + " --selftest"
            print(exec(cmd + " 2>&1"))
            return
        }
        if asub == "list" {
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(ascript) + " list"
            print(exec(cmd + " 2>&1"))
            return
        }
        if asub == "topo" {
            if n < 6 { println("usage: nexus universe anchor topo <topology> [ticks]"); return }
            let atopo = a[5]
            let aticks = if n >= 7 { a[6] } else { "50" }
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(ascript) + " " + shell_quote(aticks) + " " + shell_quote(atopo)
            print(exec(cmd + " 2>&1"))
            return
        }
        println("[universe anchor] usage: nexus universe anchor {selftest|list|topo <topo> [ticks]}")
        println("  references: Planck 2018 n_s, BMW 2008 pion mass, LIGO GW150914 chirp, CODATA α^-1, PDG m_p/m_e")
        println("  topology: flat | t3 | s3 | blackhole | wormhole")
        println("  source: " + ascript)
        return
    }
    // Stage 3 field-theoretic action evolution
    if sub == "field" {
        let fscript = nexus_root() + "/sim_bridge/anu_time/field_action.hexa"
        let fsub = if n >= 5 { a[4] } else { "" }
        if fsub == "selftest" || fsub == "--selftest" {
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(fscript) + " --selftest"
            print(exec(cmd + " 2>&1"))
            return
        }
        if fsub == "topo" {
            if n < 7 { println("usage: nexus universe field topo <topology> <mode> [ticks] [m2] [lambda]"); return }
            let ftopo = a[5]
            let fmode = a[6]
            let fticks = if n >= 8 { a[7] } else { "50" }
            let fm2 = if n >= 9 { a[8] } else { "100" }
            let flambda = if n >= 10 { a[9] } else { "50" }
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(fscript) + " " + shell_quote(fticks) + " " + shell_quote(ftopo) + " " + shell_quote(fmode) + " " + shell_quote(fm2) + " " + shell_quote(flambda)
            print(exec(cmd + " 2>&1"))
            return
        }
        println("[universe field] usage: nexus universe field {selftest|topo <topology> <mode> [ticks] [m2] [lambda]}")
        println("  topology: flat | t3 | s3 | blackhole | wormhole | minkowski")
        println("  mode: phi4 (φ⁴ scalar) | ym (Yang-Mills toy plaquette)")
        println("  source: " + fscript)
        return
    }
    // Stage 2 Lorentz-causality evolution
    if sub == "lorentz" {
        let lscript = nexus_root() + "/sim_bridge/anu_time/lorentz_metric.hexa"
        let lsub = if n >= 5 { a[4] } else { "" }
        if lsub == "selftest" || lsub == "--selftest" {
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(lscript) + " --selftest"
            print(exec(cmd + " 2>&1"))
            return
        }
        if lsub == "topo" {
            if n < 6 { println("usage: nexus universe lorentz topo <name> [ticks] [c]"); return }
            let ltopo = a[5]
            let lticks = if n >= 7 { a[6] } else { "50" }
            let lc = if n >= 8 { a[7] } else { "1" }
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(lscript) + " " + shell_quote(lticks) + " " + shell_quote(ltopo) + " " + shell_quote(lc)
            print(exec(cmd + " 2>&1"))
            return
        }
        println("[universe lorentz] usage: nexus universe lorentz {selftest|topo <name> [ticks] [c=1|2]}")
        println("  topology subset (Stage 2): flat | t3 | s3 | blackhole | wormhole | minkowski")
        println("  c = speed-of-light cap (1 = slow-light, 2 = faster cone)")
        println("  source: " + lscript)
        return
    }
    // Stage 1 quantum-amplitude evolution
    if sub == "quantum" {
        let qscript = nexus_root() + "/sim_bridge/anu_time/quantum_universe.hexa"
        let qsub = if n >= 5 { a[4] } else { "" }
        if qsub == "selftest" || qsub == "--selftest" {
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(qscript) + " --selftest"
            print(exec(cmd + " 2>&1"))
            return
        }
        if qsub == "topo" {
            if n < 6 { println("usage: nexus universe quantum topo <name> [ticks]"); return }
            let qtopo = a[5]
            let qticks = if n >= 7 { a[6] } else { "100" }
            let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(qscript) + " " + shell_quote(qticks) + " " + shell_quote(qtopo)
            print(exec(cmd + " 2>&1"))
            return
        }
        println("[universe quantum] usage: nexus universe quantum {selftest|topo <name> [ticks]}")
        println("  topology subset (Stage 1): flat | t3 | s3 | blackhole | wormhole")
        println("  source: " + qscript)
        return
    }
    let script = nexus_root() + "/sim_bridge/anu_time/topology_universe.hexa"
    if sub == "selftest" {
        let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(script) + " --selftest"
        print(exec(cmd + " 2>&1"))
        return
    }
    if sub == "topo" {
        if n < 5 { _universe_help(); return }
        let topo = a[4]
        let ticks = if n >= 6 { a[5] } else { "100" }
        let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(script) + " " + shell_quote(ticks) + " " + shell_quote(topo)
        print(exec(cmd + " 2>&1"))
        return
    }
    if sub == "evolve" {
        if n < 7 { _universe_help(); return }
        let from = a[4]
        let to = a[5]
        let at = a[6]
        let ticks = if n >= 8 { a[7] } else { "100" }
        let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(script) + " " + shell_quote(ticks) + " evolve " + shell_quote(from) + " " + shell_quote(to) + " " + shell_quote(at)
        print(exec(cmd + " 2>&1"))
        return
    }
    println("[universe] ERROR unknown subcommand: " + sub)
    println("  reason: validation-fail unknown-subcommand")
    println("  fix: 1) nexus universe selftest  2) nexus universe topo t3  3) nexus universe evolve s3 t3 50  4) nexus universe help")
}

fn cmd_hexa_sim(a: [str]) -> void {
    // nexus hexa-sim verify [--axis NAME] [--json] [--selftest]
    // nexus hexa-sim falsifier [--id F#] [--json] [--selftest]
    // nexus hexa-sim bridge <name> [args...]
    // nexus hexa-sim doc
    let n = len(a)
    let sub = if n >= 4 { a[3] } else { "" }
    if sub.len() == 0 || sub == "help" || sub == "-h" || sub == "--help" {
        _hexa_sim_help(); return
    }
    if sub == "bridge" { _hexa_sim_bridge_dispatch(a); return }
    // Tier-1 bash tools (runtime-down 시에도 작동)
    if sub == "search" {
        let n = len(a)
        let mut fwd = ""
        let mut k = 4
        while k < n {
            if fwd.len() > 0 { fwd = fwd + " " }
            fwd = fwd + shell_quote(a[k])
            k = k + 1
        }
        print(exec("bash " + nexus_root() + "/tool/atlas_search.sh " + fwd + " 2>&1"))
        return
    }
    if sub == "runtime-check" {
        let n = len(a)
        let mut fwd = ""
        let mut k = 4
        while k < n {
            if fwd.len() > 0 { fwd = fwd + " " }
            fwd = fwd + shell_quote(a[k])
            k = k + 1
        }
        print(exec(nexus_root() + "/tool/hexa_runtime_check.sh " + fwd + " 2>&1"))
        return
    }
    if sub == "provenance" {
        let n = len(a)
        let mut fwd = ""
        let mut k = 4
        while k < n {
            if fwd.len() > 0 { fwd = fwd + " " }
            fwd = fwd + shell_quote(a[k])
            k = k + 1
        }
        print(exec("bash " + nexus_root() + "/tool/atlas_provenance.sh " + fwd + " 2>&1"))
        return
    }
    if sub == "diff-per-type" {
        let n = len(a)
        let mut fwd = ""
        let mut k = 4
        while k < n {
            if fwd.len() > 0 { fwd = fwd + " " }
            fwd = fwd + shell_quote(a[k])
            k = k + 1
        }
        print(exec("bash " + nexus_root() + "/tool/atlas_diff_per_type.sh " + fwd + " 2>&1"))
        return
    }
    if sub == "dashboard" {
        let n = len(a)
        let mut fwd = ""
        let mut k = 4
        while k < n {
            if fwd.len() > 0 { fwd = fwd + " " }
            fwd = fwd + shell_quote(a[k])
            k = k + 1
        }
        print(exec("bash " + nexus_root() + "/tool/atlas_cross_repo_dashboard.sh " + fwd + " 2>&1"))
        return
    }
    if sub == "precommit" {
        let n = len(a)
        let mut fwd = ""
        let mut k = 4
        while k < n {
            if fwd.len() > 0 { fwd = fwd + " " }
            fwd = fwd + shell_quote(a[k])
            k = k + 1
        }
        print(exec("bash " + nexus_root() + "/tool/atlas_precommit_check.sh " + fwd + " 2>&1"))
