fn cmd_promote(id: str, grade: str, audit: str) -> void {
    if id.len() == 0 || grade.len() == 0 || audit.len() == 0 {
        eprintln("nexus promote: --id / --grade / --audit-log required")
        return
    }
    let valid = grade == "10star" || grade == "10starstar" || grade == "11star" || grade == "12star"
    if !valid {
        eprintln("nexus promote: --grade must be 10star|10starstar|11star|12star")
        return
    }
    let script = nexus_root() + "/n6/atlas_health.hexa"
    let mut cmd = hexa_bin() + " run " + shell_quote(script) + " promote_grade "
               + shell_quote(id) + " " + shell_quote(grade) + " " + shell_quote(audit)
    print(exec(cmd + " 2>&1"))
}

fn cmd_atlas(a: [str]) -> void {
    // nexus atlas search "..." [--limit N]  — grep atlas.n6
    // nexus atlas append --node <json> | --edge <json>  — atlas_health append
    // nexus atlas status  — atlas_health 상태 보고 (legacy)
    let n = len(a)
    let sub = if n >= 4 { a[3] } else { "" }

    if sub == "search" {
        // first non-flag positional after "search" = query
        let mut query = ""
        let mut j = 4
        while j < n {
            if !a[j].starts_with("--") {
                query = a[j]
                break
            }
            j = j + 2  // skip flag + value
        }
        let limit = find_flag(a, "--limit", "10")
        if query.len() == 0 {
            eprintln("nexus atlas search: query required")
            exit(2)
        }
        let atlas_path = nexus_root() + "/n6/atlas.n6"
        let cmd = "grep -i " + shell_quote(query) + " " + shell_quote(atlas_path) + " | head -n " + limit
        print(exec(cmd + " 2>&1"))
        return
    }

    if sub == "append" {
        let node_json = find_flag(a, "--node", "")
        let edge_json = find_flag(a, "--edge", "")
        if node_json.len() == 0 && edge_json.len() == 0 {
            eprintln("nexus atlas append: --node or --edge required")
            exit(2)
        }
        let script = nexus_root() + "/n6/atlas_health.hexa"
        let arg = if node_json.len() > 0 { node_json } else { edge_json }
        print(exec(hexa_bin() + " run " + shell_quote(script) + " append " + shell_quote(arg) + " 2>&1"))
        return
    }

    // iter-70: nexus atlas absorb — delegates to LOCKED nexus/n6/atlas_absorb.hexa module
    //   nexus atlas absorb [--target n6-arch|nexus] [--glob "<pattern>"] [--archive] [--dry-run]
    //   Module: nexus/n6/atlas_absorb.hexa (chflags uchg-locked per user directive)
    //   Procedure: unlock atlas.n6 → append shard contents → relock (via os_level_lock.hexa)
    if sub == "absorb" {
        let target = find_flag(a, "--target", "n6-arch")
        let target_root = if target == "n6-arch" {
            "/Users/ghost/core/n6-architecture"
        } else if target == "nexus" {
            nexus_root()
        } else {
            eprintln("nexus atlas absorb: --target must be n6-arch | nexus")
            exit(2)
            ""
        }
        // forward remaining flags to module
        let mut module_args = shell_quote(target_root)
        let mut _ai = 4
        while _ai < n {
            if a[_ai] != "--target" {
                module_args = module_args + " " + shell_quote(a[_ai])
            } else {
                _ai = _ai + 1   // skip flag value
            }
            _ai = _ai + 1
        }
        let absorb_module = nexus_root() + "/n6/atlas_absorb.hexa"
        let cmd = hexa_bin() + " run " + shell_quote(absorb_module) + " " + module_args + " 2>&1"
        print(exec(cmd))
        return
    }

    // legacy: forward remaining args to atlas_health.hexa (status/verify 등)
    let mut args = ""
    let mut i = 3
    while i < n {
        if args.len() > 0 { args = args + " " }
        args = args + shell_quote(a[i])
        i = i + 1
    }
    let script = nexus_root() + "/n6/atlas_health.hexa"
    print(exec(hexa_bin() + " run " + shell_quote(script) + " " + args + " 2>&1"))
}

fn cmd_roadmap(a: [str]) -> void {
    let n = len(a)
    let mut args = ""
    let mut i = 3  // skip [hexa, script, "roadmap", ...]
    while i < n {
        if args.len() > 0 { args = args + " " }
        args = args + shell_quote(a[i])
        i = i + 1
    }
    let mut cmd = hexa_bin() + " run " + shell_quote(entry_hexa()) + " roadmap"
    if args.len() > 0 { cmd = cmd + " " + args }
    print(exec(cmd + " 2>&1"))
}

