        let mut fwd = ""
        let mut k = 4
        while k < n {
            if fwd.len() > 0 { fwd = fwd + " " }
            fwd = fwd + shell_quote(a[k])
            k = k + 1
        }
        print(exec("bash " + nexus_root() + "/tool/atlas_bridge_aging.sh " + fwd + " 2>&1"))
        return
    }
    // 2026-04-26: `nexus honesty-fix` subcommand removed. Its sole purpose was
    // generating CC-coupled artifact templates (CLAUDE.md / AGENT.md /
    // .claude/agents/) for honesty triad precondition-e. After the
    // CC-dependency-0 sweep, precondition-e checks `.own` (universal repo-
    // identity SSOT, present in all 4 repos) — no per-repo template fix needed.
    // Companion: tool/honesty_precondition_e_fix.sh deleted.
    if sub == "index" {
        let n = len(a)
        let mut fwd = ""
        let mut k = 4
        while k < n {
            if fwd.len() > 0 { fwd = fwd + " " }
            fwd = fwd + shell_quote(a[k])
            k = k + 1
        }
        print(exec("bash " + nexus_root() + "/tool/atlas_index.sh " + fwd + " 2>&1"))
        return
    }
    if sub == "falsifier-spawn" {
        let n = len(a)
        let mut fwd = ""
        let mut k = 4
        while k < n {
            if fwd.len() > 0 { fwd = fwd + " " }
            fwd = fwd + shell_quote(a[k])
            k = k + 1
        }
        print(exec("bash " + nexus_root() + "/tool/atlas_falsifier_auto_spawn.sh " + fwd + " 2>&1"))
        return
    }
    if sub == "glob-since" {
        let n = len(a)
        let mut fwd = ""
        let mut k = 4
        while k < n {
            if fwd.len() > 0 { fwd = fwd + " " }
            fwd = fwd + shell_quote(a[k])
            k = k + 1
        }
        print(exec("bash " + nexus_root() + "/tool/atlas_omega_glob_since.sh " + fwd + " 2>&1"))
        return
    }
    if sub == "v2-regression" {
        let n = len(a)
        let mut fwd = ""
        let mut k = 4
        while k < n {
            if fwd.len() > 0 { fwd = fwd + " " }
            fwd = fwd + shell_quote(a[k])
            k = k + 1
        }
        print(exec("bash " + nexus_root() + "/tool/atlas_dsl_v2_regression.sh " + fwd + " 2>&1"))
        return
    }
    let mut script = ""
    if sub == "verify" { script = nexus_root() + "/tool/hexa_sim_verify_grid.hexa" }
    else if sub == "falsifier" { script = nexus_root() + "/tool/hexa_sim_falsifier.hexa" }
    else if sub == "ci" { script = nexus_root() + "/tool/hexa_sim_ci.hexa" }
    else if sub == "atlas-ingest" { script = nexus_root() + "/tool/hexa_sim_atlas_ingest.hexa" }
    else if sub == "omega-ingest" { script = nexus_root() + "/tool/omega_cycle_atlas_ingest.hexa" }
    else if sub == "supercycle" { script = nexus_root() + "/tool/atlas_omega_supercycle.hexa" }
    else if sub == "doc" {
        let path = nexus_root() + "/design/hexa_sim/README.md"
        if !pfs_file_exists(path) {
            eprintln("nexus hexa-sim doc: README missing at " + path)
            exit(1)
        }
        print(exec("cat " + shell_quote(path) + " 2>&1"))
        return
    }
    else {
        eprintln("nexus hexa-sim: unknown sub `" + sub + "` — try `nexus hexa-sim help`")
        exit(1)
    }
    let mut fwd = ""
    let mut i = 4  // skip [hexa, script, "hexa-sim", "<sub>", ...]
    while i < n {
        if fwd.len() > 0 { fwd = fwd + " " }
        fwd = fwd + shell_quote(a[i])
        i = i + 1
    }
    let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(script) + (if fwd.len() > 0 { " " + fwd } else { "" })
    print(exec(cmd + " 2>&1"))
}

