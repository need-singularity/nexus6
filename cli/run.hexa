// ─── nexus doctor — local + remote 원격 dispatch 진단 ───
// 2026-04-21 n6-architecture 팀 요청:
//   Mac 에서 drill 호출 시 원격 dispatch 실패 → OOM kill 패턴 발생.
//   사전 진단 + 복구 가이드 제공 커맨드.
//
// 모드:
//   nexus doctor            기존 로컬 헬스 (hexa bin, atlas.n6, lens)
//   nexus doctor --remote   ssh probe + remote hexa bin + remote project tree
//   nexus doctor --all      로컬 + 원격 (둘 다)
//
// stderr JSON:
//   NEXUS_REMOTE_DOCTOR {"verdict":"HEALTHY|WARN|ERROR","hosts":[...]}
// exit code:
//   HEALTHY/WARN → 0, ERROR → 74 (A2 와 일관)
//
// 참조: shared/scripts/bin/hexa_remote (ssh probe 로직 SSOT)
fn _doctor_local() -> void {
    let hx = hexa_bin()
    let root = nexus_root()
    println("=== nexus doctor — local ===")
    println("hexa bin      : " + hx)
    let hx_exist = exec("[ -x " + shell_quote(hx) + " ] && echo y || echo n").trim()
    println("  executable  : " + hx_exist)
    let atlas_path = root + "/shared/n6/atlas.n6"
    let atlas_size = exec("[ -f " + shell_quote(atlas_path) + " ] && wc -c < " + shell_quote(atlas_path) + " | tr -d ' \\n' || echo MISSING").trim()
    println("atlas.n6      : " + atlas_path)
    println("  size(bytes) : " + atlas_size)
    let lens_dir = root + "/cli/blowup/lens"
    let lens_count = exec("ls " + shell_quote(lens_dir) + "/lens*.hexa 2>/dev/null | wc -l | tr -d ' \\n'").trim()
    println("lens count    : " + lens_count + " (dir=" + lens_dir + ")")
}

fn _doctor_probe_host(host: str, ctimeout: str) -> str {
    // ssh probe 1회. 반환: "OK|<elapsed_s>" 또는 "FAIL|<reason>".
    // reason 분류는 hexa_remote 와 일관 (DNS / Connection refused / Auth / Timeout / 기타).
    let t0_cmd = "date +%s"
    let t0 = exec(t0_cmd).trim()
    let ssh_cmd = "ssh -o ConnectTimeout=" + ctimeout + " -o BatchMode=yes -o ServerAliveInterval=5 -o ServerAliveCountMax=1 " + shell_quote(host) + " true 2>&1 1>/dev/null; echo __RC=$?"
    let out = exec(ssh_cmd)
    let t1 = exec(t0_cmd).trim()
    let mut elapsed = 0
    try {
        let a = to_int(t0)
        let b = to_int(t1)
        elapsed = b - a
    } catch e { elapsed = 0 }
    // rc 추출
    let rc_idx = str_find(out, "__RC=")
    let mut rc = "0"
    if rc_idx >= 0 {
        let tail = out.substring(rc_idx + 5, out.len()).trim()
        rc = tail
    }
    if rc == "0" { return "OK|" + to_string(elapsed) }
    // 실패 — reason 분류
    let err = if rc_idx >= 0 { out.substring(0, rc_idx) } else { out }
    let mut reason = "unknown(rc=" + rc + ")"
    if str_find(err, "Could not resolve hostname") >= 0
        || str_find(err, "Name or service not known") >= 0
        || str_find(err, "nodename nor servname") >= 0 {
        reason = "DNS 해석 실패"
    } else if str_find(err, "Connection refused") >= 0 {
        reason = "SSH 거부 (sshd down? 포트 차단?)"
    } else if str_find(err, "Permission denied") >= 0
        || str_find(err, "publickey") >= 0
        || str_find(err, "Authentication failed") >= 0 {
        reason = "인증 실패 (키/agent 확인)"
    } else if str_find(err, "Connection timed out") >= 0
        || str_find(err, "Operation timed out") >= 0
        || str_find(err, "timed out") >= 0 {
        reason = "타임아웃 (네트워크/방화벽)"
    } else if str_find(err, "Host key verification failed") >= 0 {
        reason = "호스트 키 불일치"
    } else if str_find(err, "No route to host") >= 0 {
        reason = "라우팅 없음"
    } else if err.trim().len() > 0 {
        let lim = if err.len() < 120 { err.len() } else { 120 }
        reason = err.substring(0, lim).trim()
    }
    return "FAIL|" + reason
}

fn _doctor_pick_preferred() -> str {
    // 우선순위: env HEXA_REMOTE_HOST → dispatch_state.json 의 selection.compute → "ubu"
    // 주의(2026-04-21): hexa 런타임의 env() 는 HOME/NEXUS 외 whitelist 만. HEXA_* 는 노출 X.
    //   exec() 조차 HEXA_* 는 scrub 됨 → printenv/env | grep 도 빈값.
    //   따라서 HEXA_REMOTE_HOST override 는 doctor 레벨에서 --host 플래그로 병행 제공 (main() 파싱).
    let state = nexus_root() + "/shared/dispatch_state.json"
    let state_exists = exec("[ -r " + shell_quote(state) + " ] && echo y || echo n").trim()
    if state_exists != "y" { return "ubu" }
    let jq_exists = exec("command -v jq >/dev/null 2>&1 && echo y || echo n").trim()
    if jq_exists != "y" { return "ubu" }
    let h = exec("jq -r '.selection.compute // \"ubu\"' " + shell_quote(state) + " 2>/dev/null").trim()
    if h == "ubu" || h == "ubu2" { return h }
    return "ubu"
}

fn _doctor_remote_hexa_bin(host: str) -> str {
    // remote 에 $HOME/Dev/hexa-lang/hexa 가 실행 가능한지 확인.
    let path = "$HOME/Dev/hexa-lang/hexa"
    let cmd = "ssh -o ConnectTimeout=5 -o BatchMode=yes " + shell_quote(host) + " 'test -x " + path + " && echo OK || echo MISSING' 2>/dev/null"
    let r = exec(cmd).trim()
    if r == "OK" { return "OK" }
    return "MISSING (path=" + path + ")"
}

fn _doctor_remote_project(host: str) -> str {
    let path = "$HOME/Dev/nexus"
    let cmd = "ssh -o ConnectTimeout=5 -o BatchMode=yes " + shell_quote(host) + " 'test -d " + path + " && echo OK || echo MISSING' 2>/dev/null"
    let r = exec(cmd).trim()
    if r == "OK" { return "OK" }
    return "MISSING (path=" + path + ")"
}

fn _doctor_env_line(name: str) -> str {
    let v = env(name)
    if v.len() == 0 { return name + " = (unset)" }
    return name + " = " + v
}

fn cmd_doctor_remote(host_override: str, timeout_override: str) -> int {
    // 반환: exit code (0=HEALTHY/WARN, 74=ERROR)
    println("=== nexus doctor --remote ===")
    let preferred = if host_override.len() > 0 { host_override } else { _doctor_pick_preferred() }
    let src = if host_override.len() > 0 { "--host CLI override" } else { "dispatch_state.json" }
    println("preferred host: " + preferred + "  (" + src + ")")
    println("")
    let ctimeout = if timeout_override.len() > 0 { timeout_override } else { "8" }
    println("env snapshot (주의: hexa 런타임은 HEXA_* env 를 whitelist 하지 않음 — 아래는 runtime 관점):")
    println("  " + _doctor_env_line("HEXA_LOCAL"))
    println("  " + _doctor_env_line("HEXA_REMOTE"))
    println("  " + _doctor_env_line("HEXA_ALLOW_LOCAL_FALLBACK"))
    println("  " + _doctor_env_line("HEXA_REMOTE_HOST"))
    println("  HEXA_REMOTE_CONNECT_TIMEOUT = " + ctimeout + "  (CLI 반영)")
    println("  " + _doctor_env_line("HEXA_REMOTE_PROBE_RETRY"))
    println("  " + _doctor_env_line("NEXUS_RSS_CAP_MB"))
    println("")
    // host 목록: host_override 있으면 해당 host 단독, 아니면 preferred + ubu + ubu2 (중복 제거).
    let mut hosts: [str] = [preferred]
    if host_override.len() == 0 {
        if preferred != "ubu" { hosts = hosts + ["ubu"] }
        if preferred != "ubu2" { hosts = hosts + ["ubu2"] }
    }
    let mut ok_count = 0
    let mut fail_count = 0
    let mut json_hosts = ""
    let mut i = 0
    while i < len(hosts) {
        let h = hosts[i]
        println("--- host: " + h + " ---")
        let probe = _doctor_probe_host(h, ctimeout)
        let pipe_idx = str_find(probe, "|")
        let status = if pipe_idx >= 0 { probe.substring(0, pipe_idx) } else { probe }
        let detail = if pipe_idx >= 0 { probe.substring(pipe_idx + 1, probe.len()) } else { "" }
        let mut bin_status = "SKIP"
        let mut tree_status = "SKIP"
        if status == "OK" {
            println("  ✓ reachable (" + detail + "s)")
            bin_status = _doctor_remote_hexa_bin(h)
            tree_status = _doctor_remote_project(h)
            println("  hexa bin    : " + bin_status)
            println("  project tree: " + tree_status)
            if bin_status == "OK" && tree_status == "OK" {
                ok_count = ok_count + 1
            } else {
                fail_count = fail_count + 1
            }
        } else {
            println("  ✗ unreachable — " + detail)
            fail_count = fail_count + 1
        }
        // JSON host entry
        let entry = "{\"host\":\"" + h + "\",\"reachable\":" + (if status == "OK" { "true" } else { "false" }) + ",\"hexa_bin\":\"" + bin_status + "\",\"project\":\"" + tree_status + "\"}"
        if json_hosts.len() == 0 { json_hosts = entry } else { json_hosts = json_hosts + "," + entry }
        i = i + 1
    }
    println("")
    // 판정
    let mut verdict = "ERROR"
    if ok_count >= len(hosts) { verdict = "HEALTHY" }
    else if ok_count >= 1 { verdict = "WARN" }
    println("=== verdict: " + verdict + " (ok=" + to_string(ok_count) + "/" + to_string(len(hosts)) + ") ===")
    if verdict == "ERROR" {
        println("")
        println("복구 가이드:")
        println("  1) ssh ubu true  — 직접 연결 확인 (batch mode off)")
        println("  2) ~/.ssh/config — ubu/ubu2 호스트 정의 (HostName/User/IdentityFile) 확인")
        println("  3) VPN/네트워크 상태 점검 (회사망/외부망 전환 필요?)")
        println("  4) 긴급 우회: HEXA_ALLOW_LOCAL_FALLBACK=1 nexus drill ...  (⚠ Mac OOM 위험)")
    } else if verdict == "WARN" {
        println("")
        println("일부 host 만 가용 — 정상 동작 하지만 리던던시 줄어듦. 실패 host 의 ssh 설정 확인 권장.")
    }
    eprintln("NEXUS_REMOTE_DOCTOR {\"verdict\":\"" + verdict + "\",\"ok\":" + to_string(ok_count) + ",\"total\":" + to_string(len(hosts)) + ",\"hosts\":[" + json_hosts + "]}")
    if verdict == "ERROR" { return 74 }
    return 0
}

fn cmd_doctor(remote_flag: bool, all_flag: bool, host_override: str, timeout_override: str) -> int {
    // 반환: exit code
    if all_flag {
        _doctor_local()
        println("")
        return cmd_doctor_remote(host_override, timeout_override)
    }
    if remote_flag {
        return cmd_doctor_remote(host_override, timeout_override)
    }
    _doctor_local()
    return 0
}

// ─── W (2026-04-21) — nexus→anima cross-engine drill chain ───
// SSOT: cli/scripts/cross_chain.hexa — orchestrator (shim: no live exec).
// nexus drill 이 쓴 /tmp/nexus_drill_last_total.txt sentinel 을 소비 →
// anima 존재 시 shim consume → 통합 리포트 JSON.
// anima 미발견 시: stderr 에 NEXUS_CROSS_CHAIN {"status":"anima_missing"} + rc=2.
// 규칙: `>=`/`<=` 금지 — 본 블록 전부 `<`/`>` 만 사용.
fn cmd_chain(seed: str, engines_csv: str, report_path: str) -> int {
    let seed_t = seed.trim()
    if seed_t.len() == 0 {
        eprintln("nexus chain: --seed required — e.g. nexus chain --seed 'Riemann zeta zero spacing GUE deviation' --engines nexus,anima")
        return 3
    }
    let script = nexus_root() + "/cli/scripts/cross_chain.hexa"
    // script 존재 확인 — 미발견 시 fail-fast
    let chk = exec("[ -f '" + script + "' ] && echo y || echo n").trim()
    if chk != "y" {
        eprintln("NEXUS_CROSS_CHAIN {\"status\":\"script_missing\",\"path\":\"" + script + "\"}")
        return 4
    }
    let mut cmd = shell_quote(hexa_bin()) + " run " + shell_quote(script) + " run"
    cmd = cmd + " --seed " + shell_quote(seed_t)
    let engines = if engines_csv.len() > 0 { engines_csv } else { "nexus,anima" }
    cmd = cmd + " --engines " + shell_quote(engines)
    if report_path.len() > 0 {
        cmd = cmd + " --report " + shell_quote(report_path)
    }
    // 2>&1 은 쓰지 않음 — stderr typed error 는 caller 에 분리 전달되도록.
    let out = exec(cmd)
    print(out)
    // exit code 회수 — exec() 는 stdout 만 반환하므로 shell wrapper 로 rc 전달.
    // 간이 체크: out 에 unified_abs_total 토큰이 있으면 성공으로 간주.
    if out.contains("unified_abs_total") { return 0 }
    if out.contains("anima_missing") { return 2 }
    return 0
}

fn main() -> void {
    // argv 정규화: Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // .hexa 앵커 스캔 → [hexa, script, user...] 로 재구성 (cc2ec688 argv.hexa.inc 패턴)
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let _user_start = if _script_idx >= 0 { _script_idx + 1 } else {
        if _raw_argv.len() >= 3 && (_raw_argv[1] == "run" || _raw_argv[1] == "eval") { 3 } else { 2 }
    }
    let _script_token = if _script_idx >= 0 { _raw_argv[_script_idx] } else { "" }
    let mut a: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        a = a + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    let n = len(a)
    if n < 3 {
        cmd_help()
        return
    }
    let sub = a[2]
    if sub == "version" { cmd_version(); return }
    if sub == "help" { cmd_help(); return }
    if sub == "-h" { cmd_help(); return }
    if sub == "--help" { cmd_help(); return }
    if sub == "status" { cmd_status(); return }
    if sub == "self-check" { cmd_self_check(); return }
    if sub == "gap" { cmd_gap(); return }
    if sub == "doctor" {
        let remote_flag = has_flag(a, "--remote")
        let all_flag = has_flag(a, "--all")
        let host_override = find_flag(a, "--host", "")
        let timeout_override = find_flag(a, "--timeout", "")
        let rc = cmd_doctor(remote_flag, all_flag, host_override, timeout_override)
        if rc != 0 { exit(rc) }
        return
    }
    if sub == "thinking" {
        cmd_thinking(find_flag(a, "--query", ""))
        return
    }
    if sub == "smash" {
        cmd_smash(find_flag(a, "--seed", ""), find_flag(a, "--depth", ""))
        return
    }
    if sub == "free" {
        cmd_free(find_flag(a, "--seed", ""), find_flag(a, "--dfs", ""))
        return
    }
    if sub == "absolute" {
        cmd_absolute(find_flag(a, "--seed", ""))
        return
    }
    if sub == "drill" {
        // E1 (2026-04-21) — CLI flag 3-layer:
        //   master: --depth N  (env NEXUS_DRILL_DEPTH)
        //   per-stage: --smash-depth --free-dfs --abs-depth --meta-depth --hyper-depth --res-depth
        //   preset: --preset fast|probe|coarse|standard
        //   adaptive: --adaptive 또는 --depth auto
        // E9 (2026-04-21, fast-resume 2026-04-21) — checkpoint/resume flags:
        //   --resume        → 명시적 on (기본값이 이미 on 이므로 사실상 no-op)
        //   --fresh         → opt-out (legacy 동작): checkpoint 무시 + 기존 파일 삭제 후 round 0 시작
        //   --no-resume     → --fresh 의 별칭
        //   --checkpoint-dir <path>  → state file 디렉토리 (기본 /tmp/nexus_checkpoint 또는 env NEXUS_CHECKPOINT_DIR)
        let _smash_d = _parse_flag_int(a, "--smash-depth")
        let _free_d  = _parse_flag_int(a, "--free-dfs")
        let _abs_d   = _parse_flag_int(a, "--abs-depth")
        let _meta_d  = _parse_flag_int(a, "--meta-depth")
        let _hyper_d = _parse_flag_int(a, "--hyper-depth")
        let _res_d   = _parse_flag_int(a, "--res-depth")
        let per_stage = [_smash_d, _free_d, _abs_d, _meta_d, _hyper_d, _res_d]
        let adaptive = has_flag(a, "--adaptive")
        let fresh_flag = has_flag(a, "--fresh") || has_flag(a, "--no-resume")
        let resume_flag = !fresh_flag  // 기본 ON; --fresh / --no-resume 로 OFF.
        let checkpoint_dir = find_flag(a, "--checkpoint-dir", "")
        if fresh_flag {
            // --fresh 는 기존 checkpoint 파일을 즉시 제거하여 완전한 legacy fresh-run 보장.
            // seed 는 아직 파싱 전이므로 여기서 할 수 없음 — cmd_drill 내부에서 resume_flag=false 분기가 처리.
            // 다만 기록용으로 stderr 한 줄 emit.
            eprintln("NEXUS_DRILL_CHECKPOINT {\"op\":\"fresh\",\"reason\":\"--fresh/--no-resume flag\",\"action\":\"ignore_and_clear\"}")
        }
        // E8 (2026-04-21) — --problem <name> per-millennium preset (drill.json .problem_presets)
        let problem_flag = find_flag(a, "--problem", "")
        // E12 (2026-04-21) — seed batch: --seeds "a,b,c" 또는 --seeds-file path (sequential).
        //   단일 --seed 공존 — --seeds/--seeds-file 지정 시 우선.
        let seeds_flag = find_flag(a, "--seeds", "")
        let seeds_file = find_flag(a, "--seeds-file", "")
        // E17 (2026-04-21) — --speculate N: same-round N-way fork + best-keep.
        let speculate_flag = find_flag(a, "--speculate", "")
        if seeds_flag.len() > 0 || seeds_file.len() > 0 {
            let batch_seeds = _seed_batch_load(seeds_flag, seeds_file)
            cmd_drill_batch(
                batch_seeds,
                find_flag(a, "--max-rounds", ""),
                find_flag(a, "--engine", ""),
                find_flag(a, "--preset", ""),
                find_flag(a, "--depth", ""),
                per_stage,
                adaptive,
                resume_flag,
                checkpoint_dir,
                problem_flag,
                speculate_flag
            )
            return
        }
        cmd_drill(
            find_flag(a, "--seed", ""),
            find_flag(a, "--max-rounds", ""),
            find_flag(a, "--engine", ""),
            find_flag(a, "--preset", ""),
            find_flag(a, "--depth", ""),
            per_stage,
            adaptive,
            resume_flag,
            checkpoint_dir,
            problem_flag,
            speculate_flag
        )
        return
    }
    if sub == "meta-closure" {
        cmd_meta_closure(find_flag(a, "--seed", ""))
        return
    }
    if sub == "hyperarithmetic" {
        cmd_hyperarithmetic(find_flag(a, "--prop", ""))
        return
    }
    if sub == "promote" {
        cmd_promote(find_flag(a, "--id", ""), find_flag(a, "--grade", ""), find_flag(a, "--audit-log", ""))
        return
    }
    if sub == "atlas" {
        cmd_atlas(a); return
    }
    if sub == "roadmap" {
        cmd_roadmap(a); return
    }
    if sub == "projects" {
        let fmt = if n >= 4 { a[3] } else { "" }
        cmd_projects(fmt); return
    }
    if sub == "contracts" { cmd_contracts(); return }
    if sub == "verify" { cmd_verify(); return }
    if sub == "sync" {
        let apply_flag = if n >= 4 { a[3] } else { "" }
        cmd_sync(apply_flag); return
    }
    if sub == "chain" {
        // W (2026-04-21) — nexus→anima cross-engine drill chain.
        // nexus chain --seed <seed> [--engines nexus,anima] [--report <path>]
        let rc = cmd_chain(
            find_flag(a, "--seed", ""),
            find_flag(a, "--engines", "nexus,anima"),
            find_flag(a, "--report", "")
        )
        if rc != 0 { exit(rc) }
        return
    }
    eprintln("nexus: unknown subcommand '" + sub + "'")
    cmd_help()
}

main()
