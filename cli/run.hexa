// run.hexa — nexus 단일 진입점 (hx package entry)
//
// hx install ~/Dev/nexus --entry run.hexa
// hx run nexus <sub> [args...]
//
// 역할: 외부(hive 등)가 nexus 엔진을 호출하는 얇은 래퍼.
//       기존 엔진 재사용, 재구현 금지. harness entry.hexa / blowup / atlas_health 위임.
//
// 서브커맨드:
//   nexus status                       전체 헬스 (harness self_check + health)
//   nexus thinking --query "..."       anima 6-phase reflection (entry.hexa thinking)
//   nexus smash --seed "..." [depth]   blowup 9-phase 돌파 (발견)
//   nexus free --seed "..." [dfs]      compose DFS 탐색 (6-core)
//   nexus absolute --seed "..."        Mk.VIII Δ₀-absolute 검증 ([10*]→[11*])
//   nexus drill --seed "..." [N] [--engine mk9|mk10]   smash→free→absolute→meta-closure→hyperarithmetic→resonance (Mk.IX/Mk.X)
//     Mk.X adds stage 6 transcendental_closure() (mkx_engine.hexa sidecar) when:
//       --engine mk10  OR  NEXUS_DRILL_ENGINE=mk10  OR  G1 saturation auto-detect (sweep_p5_progress mk_x_trigger_gates.G1_saturation_verdict=tripped)
//   nexus meta-closure --seed "..."    Phase 10 🛸16 self-ref 검증 ([10*]→[10**])
//   nexus hyperarithmetic --prop "..." Mk.IX Π₀² reverse-math 판정
//   nexus promote --id ... --grade ... --audit-log "..."  수동 등급 승급
//   nexus atlas <sub> [args]           atlas_health 위임
//   nexus roadmap <sub> [args]         entry.hexa roadmap 위임
//   nexus projects [fmt]               entry.hexa projects
//   nexus gap                          gap_monitor
//   nexus self-check                   entry.hexa self_check
//   nexus version
//   nexus help
//
// 환경:
//   NEXUS          기본 $HOME/Dev/nexus
//   HEXA           hexa 인터프리터 (미지정 시 자동탐지)

let VERSION = "0.1.0-hive-hub"

// ─── E12-B (2026-04-21) — batch-shared Phase-1 init caches ───
// SSOT: shared/config/drill.json .seed_batch (field "share_init" pending).
// 배치 모드 --seeds 에서 seed 간 반복되는 Phase-1 init (hexa_bin lookup, engine 경로 resolve,
// sigint trap install) 을 1회로 amortize 한다. 단일-seed drill 은 영향 없음 (cache miss → 기존 경로).
// 모듈 범위 mutable — hexa-lang 탑레벨 `let mut` 허용 (smoke: /tmp/globtest.hexa 검증).
// bypass: env NEXUS_BATCH_SHARE_INIT=0 → batch 진입 시 shared_init 건너뜀 (cache 도 primed 되지 않음).
let mut _hexa_bin_cache: str = ""
let mut _hexa_bin_cache_set: bool = false
let mut _nexus_root_cache: str = ""
let mut _nexus_root_cache_set: bool = false
let mut _sigint_installed: bool = false
let mut _batch_share_active: bool = false

// ─── Linux stage1 hexa polyfill (cli/blowup/lib/str_compat.hexa.inc) ───
// @include cli/blowup/lib/str_compat.hexa.inc (str_find) — inlined below
fn str_find(s: str, needle: str) -> i64 {
    let n = s.len()
    let m = needle.len()
    if m == 0 { return 0 }
    if m > n { return -1 }
    if !s.contains(needle) { return -1 }
    let mut i: i64 = 0
    let end = n - m
    while i <= end {
        if s.substring(i, i + m) == needle { return i }
        i = i + 1
    }
    return -1
}

fn str_find_from(s: str, needle: str, start: i64) -> i64 {
    if start <= 0 { return str_find(s, needle) }
    let n = s.len()
    if start >= n { return -1 }
    let tail = s.substring(start, n)
    let r = str_find(tail, needle)
    if r < 0 { return -1 }
    return r + start
}

fn nexus_root() -> str {
    // E12-B: 배치 모드에서 shared_init 으로 primed 될 경우 cache 히트 (env lookup 회피).
    if _nexus_root_cache_set { return _nexus_root_cache }
    let n = env("NEXUS")
    if n.len() > 0 { return n }
    return env("HOME") + "/Dev/nexus"
}

fn hexa_bin() -> str {
    // E12-B: 배치 모드에서 shared_init 으로 primed 될 경우 cache 히트.
    // 단일 drill 에서도 여러 stage 호출마다 cand 스캔 반복 회피 가능하지만 기존 동작 유지를 위해
    // cache 갱신은 shared_init 경로에서만 수행 (단일-seed 경로 변경 최소화 원칙).
    if _hexa_bin_cache_set { return _hexa_bin_cache }
    let h = env("HEXA")
    if h.len() > 0 { return h }
    let cands = [env("HOME") + "/Dev/hexa-lang/hexa", env("HOME") + "/.hx/bin/hexa", nexus_root() + "/shared/bin/hexa"]
    let mut i = 0
    while i < len(cands) {
        let c = cands[i]
        let chk = exec("[ -x '" + c + "' ] && echo y || echo n").trim()
        if chk == "y" { return c }
        i = i + 1
    }
    return "hexa"
}

fn entry_hexa() -> str {
    return nexus_root() + "/shared/harness/entry.hexa"
}

fn exec_validated() -> str {
    // DEPRECATED (2026-04-20): harness 폐기 — hexa_bin() 직접 호출로 전환. 하위 호환 위해 함수 유지만.
    return nexus_root() + "/shared/harness/exec_validated"
}

fn _reject_seed(seed: str, cmd: str) -> bool {
    // cmd_gate validation 알고리즘 inline (harness 폐기 후) — smash/free/drill seed 품질 검증.
    // 참조: shared/harness/cmd_gate.hexa check_smash/check_free. 길이/추상토큰 체크만 수행.
    // 반환: true = REJECT (ai-native JSON error stderr 출력), false = pass
    let trimmed = seed.trim()
    if trimmed.len() == 0 {
        eprintln("NEXUS_CMD_REJECT {\"cmd\":\"" + cmd + "\",\"reason\":\"empty_seed\"}")
        return true
    }
    if cmd == "smash" && trimmed.len() < 2 {
        eprintln("NEXUS_CMD_REJECT {\"cmd\":\"smash\",\"reason\":\"seed_too_short\",\"len\":" + to_string(trimmed.len()) + "}")
        return true
    }
    if trimmed.len() > 300 {
        eprintln("NEXUS_CMD_REJECT {\"cmd\":\"" + cmd + "\",\"reason\":\"seed_too_long\",\"len\":" + to_string(trimmed.len()) + ",\"max\":300}")
        return true
    }
    return false
}

fn shell_quote(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn run_entry(mode: str, arg1: str, arg2: str) -> void {
    let mut cmd = hexa_bin() + " run " + shell_quote(entry_hexa()) + " " + mode
    if arg1.len() > 0 { cmd = cmd + " " + shell_quote(arg1) }
    if arg2.len() > 0 { cmd = cmd + " " + shell_quote(arg2) }
    print(exec(cmd + " 2>&1"))
}

fn find_flag(a: [str], flag: str, default_val: str) -> str {
    let n = len(a)
    let mut i = 0
    while i < n {
        if a[i] == flag {
            if i + 1 < n { return a[i + 1] }
        }
        i = i + 1
    }
    return default_val
}

fn has_flag(a: [str], flag: str) -> bool {
    let n = len(a)
    let mut i = 0
    while i < n {
        if a[i] == flag { return true }
        i = i + 1
    }
    return false
}

fn _parse_flag_int(a: [str], flag: str) -> int {
    // find_flag 을 int 로 파싱. 미지정/실패 시 -1.
    let v = find_flag(a, flag, "")
    if v.len() == 0 { return -1 }
    let mut n = -1
    try { n = to_int(v) } catch e { n = -1 }
    return n
}

