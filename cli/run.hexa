}

fn _kick_bench(a: [str]) -> void {
    let n = len(a)
    let script = nexus_root() + "/tool/kick_bench.hexa"
    if !pfs_file_exists(script) {
        eprintln("nexus kick bench: script missing at " + script)
        eprintln("reason=kick-bench-missing fix=ls " + nexus_root() + "/tool/kick_bench.hexa")
        exit(1)
    }
    // forward args after `kick bench` (skip [hexa, run.hexa, kick, bench])
    let mut fwd = ""
    let mut i = 4
    while i < n {
        if fwd.len() > 0 { fwd = fwd + " " }
        fwd = fwd + shell_quote(a[i])
        i = i + 1
    }
    let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(script) + (if fwd.len() > 0 { " " + fwd } else { "" })
    print(exec(cmd + " 2>&1"))
}

fn _kick_run(a: [str]) -> void {
    let n = len(a)
    let script = nexus_root() + "/tool/kick_dispatch.hexa"
    if !pfs_file_exists(script) {
        eprintln("nexus kick run: script missing at " + script)
        eprintln("reason=kick-dispatch-missing fix=ls " + nexus_root() + "/tool/kick_dispatch.hexa")
        exit(1)
    }
    // Sub-BV 2026-04-27 (closed-loop kick CLI preflight): invoke kick_slot_gate
    // before firing kick_dispatch. If saturation gate returns DEFER (rc=1),
    // abort with raw 66 trailer instead of feeding the cron-burst → external
    // saturation → docker fallback → Sub-BO refusal cascade. Bypass via
    // env NEXUS_KICK_SKIP_PREFLIGHT=1 for emergency / debug.
    let _bypass = env_var("NEXUS_KICK_SKIP_PREFLIGHT")
    if _bypass != "1" {
        let _gate_cmd = "/Users/ghost/.hx/bin/hive-exec kick_slot_gate --max 6 >/dev/null 2>&1; echo $?"
        let _gate_rc = exec(_gate_cmd).trim()
        if _gate_rc == "1" {
            eprintln("nexus kick run: aborted by Sub-BV preflight — slot gate DEFER")
            eprintln("reason: slot-saturated: kick_slot_gate reports Mac kick-chain ≥ 6 (Sub-BR threshold)")
            eprintln("fix: 1) hive-exec kick_slot_gate  # confirm DEFER  2) wait for Mac saturation to clear (auto-reaped by Sub-BU at 15min) 3) NEXUS_KICK_SKIP_PREFLIGHT=1 nexus kick <topic>  # bypass for emergency")
            eprintln("ref: raw 100 P305 falsifier + convergence/r4_kick_perf_fallback_synthesis_2026_04_27 §Sub-BV")
            exit(64)
        }
    }
    // Skip [hexa, run.hexa, kick] — but if a[3] == "run" also skip it.
    let mut start = 3
    if n >= 4 && a[3] == "run" { start = 4 }
    let mut fwd = ""
    let mut i = start
    while i < n {
        if fwd.len() > 0 { fwd = fwd + " " }
        fwd = fwd + shell_quote(a[i])
        i = i + 1
    }
    let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(script) + (if fwd.len() > 0 { " " + fwd } else { "" })
    print(exec(cmd + " 2>&1"))
}

// _kick_slots 폐지 (2026-04-26) — 멱등성 보장. claude_code slot pool 은
// hive CLI 단독 surface (`hive-exec claude_slot_pick --list [--json]`) 로만 노출.
// kick_dispatch internal 은 _slot_pick_invocation_prefix() 가 hive-exec 경유.
// 사용자가 `nexus kick slots` 입력 시 hive-exec redirection 안내만 출력 (raw 66 fix).

// R4 ISSUE#6 (2026-04-27): `nexus kick status` — holistic resource-management dashboard.
// Single-entry-point invariant preserved: status reporting lives within `nexus kick`,
// NOT a separate top-level command. Surfaces 3 layers in one view:
//   1) external host load (RAM avail + PSI memory + load avg) — host inventory from
//      `hive-exec resource_lint --path ~/core/hive/.resource --json`
//      (kind=host AND ssh_alias != local). 2026-04-27 migration off hardcoded list.
//   2) claude slot pool state (12 slots, available/cooldown/unknown counts)
//   3) resolver caches (blacklist files + neg_cache mtime + ttl)
// Plus actionable raw 66 fix directives when any layer is degraded.
fn _kick_status() -> void {
    println("nexus kick status — hive resource-management dashboard")
    println("=====================================================")
    println("")
    println("[1/3] external hosts (cross-host kick targets)")
    // 2026-04-27: dynamic host list from hive resource JSON (single source-of-truth).
    // jq filter: kind=host AND ssh_alias != local, ordered by scoring_weight DESC.
    // Falls back to legacy ["ubu","ubu2","htz"] if hive-exec unavailable / JSON empty.
    let _r_path = exec("printf '%s' \"${HIVE_RESOURCE_PATH:-$HOME/core/hive/.resource}\"").trim()
    let _r_bin = exec("printf '%s' \"${HIVE_EXEC:-$HOME/.hx/bin/hive-exec}\"").trim()
    let _hosts_csv = exec(_r_bin + " resource_lint --path " + shell_quote(_r_path) + " --json 2>/dev/null | jq -r '[.[] | select(.kind==\"host\" and .ssh_alias!=\"local\")] | sort_by(-(.scoring_weight // 0)) | .[].ssh_alias' 2>/dev/null | tr '\\n' ',' | sed 's/,$//'").trim()
    let mut hosts = if _hosts_csv.len() > 0 { _hosts_csv.split(",") } else { ["ubu", "ubu2", "htz"] }
    let mut hi = 0
    while hi < len(hosts) {
        let h = hosts[hi]
        let probe = "ssh -o ConnectTimeout=5 -o BatchMode=yes " + h + " \"awk '/MemAvailable:/ {printf \\\"avail=%dMB \\\", \\$2/1024}' /proc/meminfo; awk -F'[= ]' '/^some/ {printf \\\"PSI_mem=%s \\\", \\$5}' /proc/pressure/memory; uptime | awk -F'load average: ' '{print \\\"load=\\\" \\$2}'\" 2>&1"
        let line = exec(probe).trim()
        let status_label = if line.len() > 0 && line.index_of("avail=") >= 0 { "  ✓" } else { "  ✗" }
        println(status_label + " " + h + ": " + line)
        hi = hi + 1
    }
    println("")
    println("[2/3] claude_code slot pool (12 slots, mac-side)")
    let slot_cmd = hexa_bin() + " run " + shell_quote(nexus_root() + "/../hive/tool/claude_slot_pick.hexa") + " --list 2>&1"
    let slot_out = exec(slot_cmd)
    // Count avail/cooldown/unknown
    let avail_n = slot_out.split("available").len() - 1
    let cooldown_n = slot_out.split("cooldown").len() - 1
    let unknown_n = slot_out.split("unknown").len() - 1
    println("  available=" + to_string(avail_n) + " cooldown=" + to_string(cooldown_n) + " unknown=" + to_string(unknown_n) + " (target: ≥3 available for healthy fan-out)")
    if avail_n < 3 {
        println("  ⚠ slot pool depleted — fix: hexa run hive/tool/claude_slot_pick.hexa --probe-all  (refreshes 'unknown' status)")
    }
    println("")
    println("[3/3] resolver caches (stale = silent host-skip)")
    let bl_cmd = "ls /tmp/hexa_remote.blacklist.* 2>/dev/null | wc -l"
    let bl_count = exec(bl_cmd).trim()
    let nc_cmd = "ls /tmp/hexa_resolver.connectivity 2>/dev/null"
    let nc_path = exec(nc_cmd).trim()
    println("  blacklist files: " + bl_count + " present (300s TTL — fresh probe blocked)")
    if bl_count != "0" {
        let bl_list = exec("ls -la /tmp/hexa_remote.blacklist.* 2>/dev/null | awk '{print $9, \"(mtime=\" $6, $7, $8 \")\"}'")
        print(bl_list)
        println("  ⚠ blacklist may be stale — fix: rm -f /tmp/hexa_remote.blacklist.*  (forces fresh probe)")
    }
    if nc_path.len() > 0 {
        println("  neg_cache: " + nc_path + " (60s TTL — bare-Mac fallback blocked)")
        println("  ⚠ may need: rm -f /tmp/hexa_resolver.connectivity  (clears resolver memo)")
    }
    println("")
    println("=====================================================")
    println("note: stale caches block fresh probes silently. when in doubt:")
    println("  rm -f /tmp/hexa_remote.blacklist.* /tmp/hexa_resolver.connectivity")
    println("  hexa run /Users/ghost/core/hive/tool/claude_slot_pick.hexa --probe-all")
    println("then re-run: nexus kick run <topic>")
}

fn cmd_kick(a: [str]) -> void {
    let n = len(a)
    let sub = if n >= 4 { a[3] } else { "" }
    if sub.len() == 0 || sub == "help" || sub == "-h" || sub == "--help" {
        _kick_help(); return
    }
    if sub == "tree" { _kick_tree(); return }
    if sub == "bench" { _kick_bench(a); return }
    if sub == "run" { _kick_run(a); return }
    if sub == "status" { _kick_status(); return }   // R4 ISSUE#6 — holistic resource-management dashboard
    if sub == "slots" {
        // 멱등성 가드 (2026-04-26 helper relocation) — slot pool surface 는 hive 단독.
        // status 안에 통합됐으니 안내만.
        eprintln("nexus kick slots: REMOVED — use `nexus kick status` (holistic dashboard) or `hive-exec claude_slot_pick --list`")
        eprintln("reason=nexus-kick-slots-deprecated fix=nexus kick status   # full dashboard with slot pool inline")
        exit(2)
    }
    // default: treat as topic (run mode)
    _kick_run(a)
}

fn cmd_qrng(a: [str]) -> void {
    let n = len(a)
    let sub = if n >= 4 { a[3] } else { "" }
    if sub.len() == 0 || sub == "help" || sub == "-h" || sub == "--help" {
        _qrng_help(); return
    }
    if sub == "status" {
        let root = nexus_root()
        let probes = [
            "tool/nxs_002_qrng_axiom.py",
            "sim_bridge/qpu_bridge/vqe_h2_demo.hexa",
            "sim_bridge/qpu_bridge/anu_noise_model.hexa",
            "sim_bridge/qpu_bridge/README.md",
            "sim_bridge/ouroboros_qrng/ouroboros_shadow.hexa",
            "sim_bridge/ouroboros_qrng/qrng_perturbation.hexa",
            "sim_bridge/bostrom_test/anu_collector.hexa",
            "lenses/sedi_quantum_rng_bias.hexa"
        ]
        println("nexus qrng status — file presence audit (root=" + root + ")")
        println("---")
        let mut i = 0
        while i < len(probes) {
            let p = probes[i]
            let full = root + "/" + p
            let mark = if pfs_file_exists(full) { "OK   " } else { "MISS " }
            println("  " + mark + p)
            i = i + 1
        }
        println("---")
        println("verdict: nxs-002 cycle 10 = NULL (paper-worthy negative). see design/abstraction_ceiling.md §9.")
        return
    }
    let mut runner = ""
    let mut script = ""
    let mut use_resolver_bypass = true
    if sub == "axiom" {
        runner = "python3"
        script = nexus_root() + "/tool/nxs_002_qrng_axiom.py"
        use_resolver_bypass = false
    }
    else if sub == "vqe-h2" {
        runner = hexa_bin() + " run"
        script = nexus_root() + "/sim_bridge/qpu_bridge/vqe_h2_demo.hexa"
    }
    else if sub == "ouroboros" {
        runner = hexa_bin() + " run"
        script = nexus_root() + "/sim_bridge/ouroboros_qrng/ouroboros_shadow.hexa"
    }
    else if sub == "perturbation" {
        runner = hexa_bin() + " run"
        script = nexus_root() + "/sim_bridge/ouroboros_qrng/qrng_perturbation.hexa"
    }
    else if sub == "anu-collect" {
        runner = hexa_bin() + " run"
        script = nexus_root() + "/sim_bridge/bostrom_test/anu_collector.hexa"
    }
    else {
        eprintln("nexus qrng: unknown sub `" + sub + "` — try `nexus qrng help`")
        exit(1)
    }
    if !pfs_file_exists(script) {
        eprintln("nexus qrng " + sub + ": script missing at " + script)
        exit(1)
    }
    let mut fwd = ""
    let mut i = 4
    while i < n {
        if fwd.len() > 0 { fwd = fwd + " " }
        fwd = fwd + shell_quote(a[i])
        i = i + 1
    }
    let prefix = if use_resolver_bypass { "HEXA_RESOLVER_NO_REROUTE=1 " } else { "" }
    let cmd = prefix + runner + " " + shell_quote(script) + (if fwd.len() > 0 { " " + fwd } else { "" })
    print(exec(cmd + " 2>&1"))
}

