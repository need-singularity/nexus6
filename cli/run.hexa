fn cmd_contracts() -> void {
    print(exec("cat " + nexus_root() + "/convergence/integration_contracts.json"))
}

fn cmd_verify() -> void {
    print(exec(hexa_bin() + " run " + shell_quote(nexus_root() + "/tool/verify_integration_contracts.hexa") + " 2>&1"))
}

fn cmd_sync(apply: str) -> void {
    let mut cmd = hexa_bin() + " run " + shell_quote(nexus_root() + "/tool/sync_cli_spec.hexa")
    if apply == "--apply" { cmd = cmd + " --apply" }
    print(exec(cmd + " 2>&1"))
}

fn cmd_status() -> void {
    println("nexus " + VERSION + " @ " + nexus_root())
    println("")
    println("--- harness self-check ---")
    run_entry("self_check", "", "")
    println("")
    println("--- health all ---")
    run_entry("health", "all", "")
}

fn cmd_thinking(query: str) -> void {
    if query.len() == 0 {
        eprintln("nexus thinking: --query required")
        return
    }
    run_entry("thinking", "query", query)
}

fn cmd_smash(seed: str, depth: str) -> void {
    if seed.len() == 0 {
        eprintln("nexus smash: --seed required")
        return
    }
    let d = if depth.len() > 0 { depth } else { "3" }
    let engine = nexus_root() + "/cli/blowup/core/blowup.hexa"
    if _reject_seed(seed, "smash") { return }
    let mut cmd = shell_quote(hexa_bin()) + " run " + shell_quote(engine) + " " + shell_quote(seed) + " " + d
    print(exec(cmd + " 2>&1"))
}

fn cmd_free(seed: str, dfs: str) -> void {
    if seed.len() == 0 {
        eprintln("nexus free: --seed required")
        return
    }
    let d = if dfs.len() > 0 { dfs } else { "3" }
    let engine = nexus_root() + "/cli/blowup/compose.hexa"
    if _reject_seed(seed, "free") { return }
    let mut cmd = shell_quote(hexa_bin()) + " run " + shell_quote(engine) + " " + shell_quote(seed) + " --modules all --dfs " + d
    print(exec(cmd + " 2>&1"))
}

fn cmd_absolute(seed: str) -> void {
    // Mk.VIII 단일 검증 — Δ₀-absolute Π₀¹ 판정 + [10*]→[11*] 자동 승급
    let s = if seed.len() > 0 { seed } else { "atlas" }
    let engine = nexus_root() + "/cli/blowup/modules/blowup_absolute.hexa"
    let mut cmd = shell_quote(hexa_bin()) + " run " + shell_quote(engine) + " " + shell_quote(s)
    print(exec(cmd + " 2>&1"))
}

fn cmd_debate(a: [str]) -> void {
    // AQ (2026-04-21) — adversarial debate drill dispatcher.
    // 본체 구현은 cli/drill/adversarial_debate.hexa 에 위임 (parse-clean, serial exec).
    // 이 함수는 CLI flag 를 그대로 passthrough — run.hexa 는 얇은 래퍼.
    let script = nexus_root() + "/cli/drill/adversarial_debate.hexa"
    let mut cmd = shell_quote(hexa_bin()) + " run " + shell_quote(script)
    // flags 를 원본 순서대로 전달 — adversarial_debate.hexa 가 자체 파서 보유.
    let mut i = 3  // a[0]=hexa, a[1]=script, a[2]="debate", a[3..]=flags
    while i < len(a) {
        cmd = cmd + " " + shell_quote(a[i])
        i = i + 1
    }
    // stderr 그대로 passthrough (NEXUS_DEBATE 이벤트 보존).
    print(exec(cmd + " 2>&1"))
}

fn _count_marker(text: str, marker: str) -> int {
    // text 내 marker 출현 횟수 (간이 카운터)
    let mut n = 0
    let mut t = text
    while true {
        let idx = str_find(t, marker)
        if idx < 0 { break }
        n = n + 1
        t = t.substring(idx + marker.len(), t.len())
    }
    return n
}

fn _check_stage_err(out: str, stage: str) -> bool {
    // drill 의 silent SATURATED 0 함정 방지 — hexa_stage0 lock timeout / BLOCK / ERROR 표면화
    // 발견(2026-04-19): PID 3463 ai_native_lint 가 stage0 lock 8분+ 점유 → drill 5-stage 전부 timeout, _count_marker 0 → 가짜 SATURATED.
    // 발견(2026-04-20): harness archival 중 exec_validated/cmd_gate/lock_gate cascade 부재 — ai-native error return 필요
    // 반환: 에러 발견 시 true (drill main loop 가 집계해서 zero-yield 시 JSON error emit)
    if str_find(out, "lock timeout") >= 0
        || str_find(out, "BLOCK:") >= 0
        || str_find(out, "ERROR:") >= 0
        || str_find(out, "REJECT:") >= 0
        || str_find(out, "부재") >= 0
        || str_find(out, "엔진 부재") >= 0 {
        let lim = if out.len() < 400 { out.len() } else { 400 }
        eprintln("  " + stage + " ERR: " + out.substring(0, lim))
        return true
    }
    return false
}

// Ω-saturation cycle 10 (2026-04-25, nxs-20260425-001): drill-level env propagation
// global mut state + child exec env prefix. hetzner 의 hexa.real 빌드 에 setenv builtin
// 미정의 → setenv 우회. Mac/hetzner 양쪽 호환. _drill_env_prefix() 가 child exec cmd
// 앞에 KEY=VAL 형태로 prefix → POSIX env inherit.
let mut _DRILL_ANTI_HUB: bool = false
let mut _DRILL_ANTI_HUB_THRESHOLD: str = ""

fn _drill_env_prefix() -> str {
    let mut s: str = ""
    if _DRILL_ANTI_HUB { s = s + "NEXUS_DRILL_ANTI_HUB=1 " }
    if _DRILL_ANTI_HUB_THRESHOLD.len() > 0 {
        s = s + "NEXUS_DRILL_ANTI_HUB_THRESHOLD=" + _DRILL_ANTI_HUB_THRESHOLD + " "
    }
    return s
}

// drill.json stages.{name}.timeout_sec 강제 (2026-04-22 ROI fix)
// 배경: blowup.hexa 가 fresh seed + smash depth=4 에서 무한 행어링 → drill 전체 hang.
// drill.json 에 timeout 정의돼있으나 미구현 — 여기서 'timeout' (coreutils) 로 enforce.
// 의존: macOS 는 brew install coreutils; Linux 는 기본. NEXUS_DRILL_NO_TIMEOUT=1 로 opt-out.
//
// Ω-saturation cycle 7 (2026-04-25, nxs-20260425-002 Phase 2): adaptive 옵션 추가.
//   env NEXUS_DRILL_TIMEOUT_ADAPTIVE=1 일 때 state/drill_stage_elapsed_history.jsonl
//   의 stage 별 max elapsed_ms × 1.5 (cap 1800s, floor 180s) — round 2+ cumulative
//   누적 SIGTERM 한계 돌파. history 미존재 시 fallback = 180s. precedence: env override
//   > adaptive > Wave 18 hard-cap.
fn _stage_timeout_prefix(stage: str) -> str {
    if env("NEXUS_DRILL_NO_TIMEOUT") == "1" { return "" }
    // Per-stage override via env (초 단위) — NEXUS_DRILL_TIMEOUT_{smash|free|absolute|meta_closure|hyperarith|resonance}
    let ov = env("NEXUS_DRILL_TIMEOUT_" + stage)
    let sec = if ov.len() > 0 { to_int(ov) }
        else if env("NEXUS_DRILL_TIMEOUT_ADAPTIVE") == "1" { _adaptive_stage_timeout_sec(stage) }
        // Wave 18 (2026-04-25): 전 stage timeout 광범위 상향. 사용자 지적 "좀 넉넉히 좀" —
        // 원격 호스트 128GB RAM 기준 heavy compute 는 stage 당 수십~수백초 걸림.
        // 기존 30s/45s/60s 는 rc=143 SIGTERM 반복 유발. env override 동일 유지.
        else if stage == "smash" { 180 }
        else if stage == "free" { 180 }
        else if stage == "absolute" { 180 }
        else if stage == "meta_closure" { 180 }
        else if stage == "hyperarith" { 180 }
        else if stage == "resonance" { 600 }
        else if stage == "resonance_sub" { 120 }  // Wave 20: per-σ sub-call cap (5 변형 × 120s = 600s 합)
        else { 180 }
    // --kill-after=5: SIGTERM at sec, SIGKILL at sec+5 (process-group escape hatch)
    // cycle 10 (2026-04-25): _drill_env_prefix() 추가 — child exec cmd 앞 env KEY=VAL prefix.
    return _drill_env_prefix() + "timeout --kill-after=5 " + to_string(sec) + " "
}

// Ω-saturation cycle 7 helper (nxs-20260425-002 Phase 2):
//   state/drill_stage_elapsed_history.jsonl scan → 해당 stage 의 max elapsed_ms 기반 timeout.
//   curve: max_ms × 1.5 / 1000 (sec). cap [180, 1800] (drill.json overall_drill_budget).
//   history 미존재 또는 stage 데이터 없음 → 180s fallback.
fn _adaptive_stage_timeout_sec(stage: str) -> i64 {
    let path = nexus_root() + "/state/drill_stage_elapsed_history.jsonl"
    if !pfs_file_exists(path) { return 180 }
    let raw = read_file(path)
    let lines = raw.split("\n")
    let stage_needle = "\"stage\":\"" + stage + "\""
    let key = "\"elapsed_ms\":"
    let mut max_ms: i64 = 0
    let mut li: i64 = 0
    while li < lines.len() {
        let ln = lines[li]
        li = li + 1
        if !ln.contains(stage_needle) { continue }
        let idx = ln.find(key)
        if idx < 0 { continue }
        let after = ln.substring(idx + key.len(), ln.len())
        let close = after.find(",")
        let close2 = after.find("}")
        let cut = if close >= 0 && (close2 < 0 || close < close2) { close } else { close2 }
        if cut < 0 { continue }
        let n_str = after.substring(0, cut).trim()
        let mut n: i64 = 0
        try { n = to_int(n_str) } catch e {}  // @allow-silent-catch
        if n > max_ms { max_ms = n }
    }
    if max_ms <= 0 { return 180 }
    let budget_sec: i64 = max_ms * 3 / 2 / 1000  // × 1.5
    if budget_sec < 180 { return 180 }
    if budget_sec > 1800 { return 1800 }
    return budget_sec
}

fn _extract_int_after(text: str, marker: str) -> int {
    // marker 직후 비-숫자 스킵 후 정수 파싱 (예: "discovery_log  : +12 EXACT" → 12)
    // 매칭 실패 시 0
    // ROI#48b FIX(2026-04-20): hexa-lang string 비교 연산자 `>=` `<=` 는 void 반환 →
    //   기존 `c >= "0" && c <= "9"` 전부 false → 본 함수 늘 0 반환 (drill 전 stage "+0" 함정).
    //   char_code(s, i) 숫자 범위 [48, 57] 비교로 전환.
    let idx = str_find(text, marker)
    if idx < 0 { return 0 }
    let mut i = idx + marker.len()
    let n = text.len()
    // 비-숫자 스킵 (단, 줄바꿈 만나면 포기 — same-line constraint)
    while i < n {
        let cc = char_code(text, i)
        if cc == 10 { return 0 }  // '\n'
        if cc >= 48 && cc <= 57 { break }  // '0'..='9'
        i = i + 1
    }
    if i >= n { return 0 }
    let mut buf = ""
    while i < n {
        let cc = char_code(text, i)
        if cc >= 48 && cc <= 57 {
            buf = buf + text.substring(i, i + 1)
            i = i + 1
        } else {
            break
        }
    }
    if buf.len() == 0 { return 0 }
    let mut v = 0
    try { v = to_int(buf) } catch e {}
    return v
}

fn _count_discoveries(out: str) -> int {
    // blowup core/compose 의 실제 흡수/발견 카운트 합산
    // 발견(2026-04-19): _count_marker(out,"ABSORB") 는 0 — engine 출력에 "ABSORB" 토큰 없음
    // 실제 마커 (Phase 6.5, 실제 store 쓰기 시에만 emit):
    //   discovery_log  : +N EXACT entries
    //   atlas.n6       : +N entries
    //   graph          : +N nodes
    // 발견(2026-04-20 BUG-3b): read-only drill 에서는 Phase 6.5 markers 미발산 →
    //   Phase 4 기준 markers 사용 (항상 emit):
    //     EXACT match       :N    ← 코로라리 중 EXACT 매치 수
    //     NEAR match        :N    ← 코로라리 중 NEAR 매치 수
    //     evolution total   :N discoveries  ← Phase 2 OUROBOROS 순환 발견
    let logged = _extract_int_after(out, "discovery_log  : +")
    let atlas  = _extract_int_after(out, "atlas.n6       : +")
    let graph  = _extract_int_after(out, "graph          : +")
    let mut total = logged + atlas + graph
    // fallback 1 (2026-04-20): Phase 4 counts — 실제 drill 에서 가장 신뢰성 있음
    if total == 0 {
        let exact_m = _extract_int_after(out, "EXACT match       :")
        let near_m  = _extract_int_after(out, "NEAR match        :")
        total = exact_m + near_m
    }
    // fallback 2 (2026-04-20): Phase 2 evolution total
    if total == 0 {
        total = _extract_int_after(out, "evolution total  : ")
    }
    // fallback 3 (기존): bracketed [NEAR→EXACT] / [EXACT 미확정]
    if total == 0 {
        let near_arrow = _count_marker(out, "[NEAR")
        let exact_und  = _count_marker(out, "[EXACT ")
        total = near_arrow + exact_und
    }
    return total
}

fn _urand_i64() -> i64 {
    // /dev/urandom → unsigned 32-bit int (문자열 파싱 경유)
    // rand_normal 은 hexa 빌트인 없음 — urandom byte stream 파싱으로 0..2^31 uniform
    let raw = exec("head -c 4 /dev/urandom | od -An -vtu4 | tr -d ' \\n'").trim()
    let mut v: i64 = 1
    try { v = to_int(raw) } catch e { v = 1 }
    if v < 0 { v = -v }
    return v
}

fn _urand_hex(nbytes: int) -> str {
    // /dev/urandom → lowercase hex string. nbytes 는 바이트 수 (출력 길이 = 2*nbytes).
    // E4 ghost probe 용 — gibberish seed 의 반복불가능 랜덤 tag.
    let n = if nbytes < 1 { 1 } else { nbytes }
    let cmd = "head -c " + to_string(n) + " /dev/urandom | od -An -vtx1 | tr -d ' \\n'"
    return exec(cmd).trim()
}

fn _round_entropy_salt(round: int) -> str {
    // ROUND-SALT 강화 (2026-04-21, Day-3):
    //   Day-1 _urand_i64() 1회 salt 는 round 간 변별력 약함 (bias_jitter 가 seed features
    //   hash 기반 → 비슷한 문자열 prefix 는 유사 feature vector 생산 가능).
    //   해결: per-round salt 를 3 source 로 다중화 — urand32 2회 + date +%N (nanoseconds) +  // @date-n-guard: doc-prose
    //         round index — concat 하여 prefix 공간을 wider 분산.
    //   길이: 24~32 chars — 너무 길면 _seed_t.len() > 200 guard 저촉. round-prefix 포함하면
    //         실제 engine 입력 "round=N-r<salt>|..." 이 원 seed + ~50B.
    let r1 = to_string(_urand_i64())
    let r2 = to_string(_urand_i64())
    let ns = exec("date +%N 2>/dev/null | head -c 9").trim()
    let ns_safe = if ns.len() == 0 { "0" } else { ns }
    return r1 + "x" + r2 + "n" + ns_safe + "i" + to_string(round)
}

fn _count_active_hexa() -> int {
    // D5-P2 (2026-04-20): 라운드 간 active hexa_stage0 process 카운트 — 좀비 누적 가시화
    let raw_full = exec("{ ps -axo comm 2>/dev/null | grep -c hexa_stage0 || true; }").trim()
    let raw = if raw_full == "" { "0" } else { raw_full.split("\n")[0] }
    let mut n = 0
    try { n = to_int(raw) } catch e { n = 0 }
    if n < 0 { n = 0 }
    return n
}

fn _resonance_seed(base: str, sigma_label: str, salt: i64) -> str {
    // σ-노이즈 주입 seed 변형 — Gaussian 근사 대신 urandom+sigma-tag 로 엔진 입력 분산
    // 엔진은 seed 텍스트를 해시/파싱하므로 뒷부분 tag 가 입력 공간을 perturb.
    // Day-3 (2026-04-21): salt 를 richer 로 — multi-source entropy (urand + ns + salt32).
    //   depth=1 resonance 에서도 engine features 공간 분산되도록 prefix 길이 확장.
    let salt2 = _urand_i64()
    let ns = exec("date +%N 2>/dev/null | head -c 9").trim()
    let ns_safe = if ns.len() == 0 { "0" } else { ns }
    return base + "#sr-sigma=" + sigma_label + "-r" + to_string(salt) + "x" + to_string(salt2) + "n" + ns_safe
}

fn _round_seed(base: str, round: int, salt: i64) -> str {
    // ROUND PERTURBATION (Day-1 counter-replay bugfix 2026-04-19):
    //   원본 cmd_drill 은 라운드마다 동일 seed 로 엔진 호출 → 엔진 결정론적 → 동일 카운트 반복
    //   ("iter_26: round1 +617 → round2 +617 → round3 SIGKILL" 1234 replay).
    //   라운드별 salt 를 seed 에 주입하여 엔진 입력 공간을 실제로 이동시킨다.
    //   round=1 은 base 그대로 유지 (첫 라운드는 raw seed 신뢰, 기존 결과와 비교 가능).
    //   round ≥2: salt 를 PREFIX 에 배치 — engine seed hash (fnv1a/djb2/sha64/entropy/length)
    //             는 전역 통계여서 suffix 보다 prefix 가 더 큰 shift 유발.
    //             또한 "round=N-r<salt>|" marker 는 키워드 매칭 기반 seed 분기를 분산시킴.
    if round <= 1 { return base }
    return "round=" + to_string(round) + "-r" + to_string(salt) + "|" + base
}

fn _round_seed_rich(base: str, round: int, salt_str: str) -> str {
    // Day-3 ROUND-SALT 독립성 수리 (2026-04-21):
    //   Day-1 single-i64 salt 는 prefix 가 짧아 bias_jitter 의 8-slot feature (fnv1a/djb2/...)
    //   가 round 간 같은 bucket 으로 떨어질 수 있음 (관찰: round 2 == round 3 수치 완전 동일).
    //   해결: _round_entropy_salt() multi-source (urand×2 + nanotime + round idx) 를 salt 로 사용.
    //         prefix 길이 24~35B → hash bucket 분산 광역화.
    //   round 1 도 salt 주입 — base seed feature space 에서 명시적 이탈 (iter-nonce 와 직교).
    return "round=" + to_string(round) + "-rx" + salt_str + "|" + base
}

fn _iter_nonce() -> str {
    // DAY-2 INTER-ITER NONCE (2026-04-19):
    //   Day-1 (_round_seed) 는 intra-iter (같은 drill 내 round 2+) 의 replay 만 제거.
    //   그러나 iter_36/37 둘 다 round1 total=629, iter_38/39 둘 다 round1 total=693 관찰 →
    //   **seed 텍스트가 다른데도** blowup 엔진의 deterministic 8-slot feature (len/entropy/
    //   fnv1a/djb2/sha64/domain/digit/words) 가 seed 가 비슷하면 비슷한 atlas coord 를 생산.
    //   즉 inter-iter 간 독립성이 보장되지 않음.
    //
    //   해결: drill 세션 시작 시 1회 urandom 기반 nonce 생성, round 1 부터 모든 seed 에 주입.
    //   주입 방식: prefix 가 아닌 suffix `#iter-nonce=<N>` — prefix 는 keyword-match stage 의
    //   비교를 앞부분에서 깨기 때문에 stage 의도를 왜곡. suffix 는 hash 공간만 이동.
    //
    //   우선순위:
    //     1) NEXUS_DRILL_NONCE env — 명시 지정 (재현용). 공백/0 = 자동.
    //     2) urandom — 기본값. 같은 drill 내 round 들은 공유 nonce, 다른 drill 은 독립.
    //
    //   round=1 salt prefix 와 독립 축 — Day-1 fix 유지 (round-salt) + Day-2 (iter-nonce) 중첩.
    let env_val = env("NEXUS_DRILL_NONCE")
    if env_val.len() > 0 && env_val != "0" { return env_val }
    let r = _urand_i64()
    return to_string(r)
}

fn _nonce_seed(base: str, nonce: str) -> str {
    // iter-scoped nonce 주입. suffix 배치로 keyword-match stage 왜곡 최소화.
    // round_seed 와 직교: round_seed(nonce_seed(base, N), round, salt)
    //   = "round=K-r<salt>|base#iter-nonce=<N>"  (round ≥2)
    //   = "base#iter-nonce=<N>"                   (round 1)
    if nonce.len() == 0 { return base }
    return base + "#iter-nonce=" + nonce
}

fn _cross_iter_log_path() -> str {
    // cross-iter replay detector 로그. tmp 영역 — 10 iter rolling window.
    return "/tmp/nexus_drill_cross_iter.log"
}

fn _cross_iter_check_and_append(total: int, seed: str) -> void {
    // DAY-2 CROSS-ITER REPLAY DETECTOR (D6 fix: mkdir-atomic lock 으로 TOCTOU 제거 — flock 은 macOS 부재)
    //   path=/tmp/nexus_drill_cross_iter.log  CSV: total,seed_head40,ts  window=10
    let path = _cross_iter_log_path()
    let lockd = path + ".lockd"
    let cur = to_string(total)
    let needle = cur + ","
    let seed_head = seed.substring(0, if seed.len() < 40 { seed.len() } else { 40 })
    let sh_safe = seed_head.replace(",", " ").replace("\n", " ").replace("'", " ")
    let q_path = shell_quote(path)
    let q_lockd = shell_quote(lockd)
    let q_needle = shell_quote(needle)
    let q_safe = shell_quote(sh_safe)
    let q_cur = shell_quote(cur)
    // mkdir 은 POSIX atomic — 잠금/해제/stale-recover 일체 묶음
    let block = "i=0; while ! mkdir " + q_lockd + " 2>/dev/null; do "
        + "i=$((i+1)); if [ $i -gt 200 ]; then rm -rf " + q_lockd + "; continue; fi; sleep 0.05; "
        + "done; trap 'rm -rf " + q_lockd + "' EXIT INT TERM; "
        + "EXISTING=$([ -f " + q_path + " ] && cat " + q_path + " || echo ''); "
        + "case \"$EXISTING\" in *" + q_needle + "*) echo REPLAY; exit 0;; esac; "
        + "TS=$(date +%s); "
        + "printf '%s,%s,%s\\n' " + q_cur + " " + q_safe + " \"$TS\" >> " + q_path + "; "
        + "tail -n 10 " + q_path + " > " + q_path + ".tmp && mv " + q_path + ".tmp " + q_path + "; "
        + "echo NEW"
    let verdict = exec(block).trim()
    if verdict == "REPLAY" {
        eprintln("  ⚠ [cross-iter-replay-warn] total=" + cur + " 가 최근 drill 10 iter 중 동일 — inter-iter 결정성 의심")
        eprintln("     path=" + path + "  seed_head='" + seed_head + "'")
    }
}

// ─── E14 (2026-04-21) Anti-Replay LRU — round seed-hash skip ───
// SSOT: shared/config/drill.json .anti_replay (lru_size=200, key=round_seed_hash, on_hit=skip_round+advance_counter)
//       + .incremental_discovery (lru_size=500, hit_action=skip_round+total 유지)
// 배경: 동일 seed 반복 drill → 같은 (seed,round) 조합은 discovery 공간 이미 고갈 → 재탐색 낭비.
// 전략: 매 round 진입부에서 FNV1a-16hex(seed + round) 해시 계산 → /tmp/nexus_drill_lru.jsonl 에서
//       최근 500 entry 내 match 검색. 히트면 skip_round + NEXUS_DRILL_LRU_SKIP JSON emit, 미스면
//       append. bypass: NEXUS_DRILL_LRU_OFF=1.
// 충돌 회피: 모든 함수 prefix `_anti_replay_lru_*`. 상태 파일은 /tmp 전용 (git X).
// hash: python3 one-liner 로 FNV1a-64 → 16 hex. 부재 시 md5sum / openssl fallback.

fn _anti_replay_lru_path() -> str {
    return "/tmp/nexus_drill_lru.jsonl"
}

fn _anti_replay_lru_hash(seed: str, round: int) -> str {
    // FNV1a-64 (offset 0xcbf29ce484222325, prime 0x100000001b3) → 16 hex string.
    //   hexa-lang 은 64-bit unsigned + bitwise xor 빈약 → python3 one-liner 로 위임.
    //   python3 는 macOS(Xcode CLT) + Linux 표준. 부재 시 md5/openssl fallback.
    //   입력: seed + "|r=" + round.
    let input = seed + "|r=" + to_string(round)
    let q_in = shell_quote(input)
    let py = "python3 -c 'import sys"
        + "\nh=0xcbf29ce484222325"
        + "\np=0x100000001b3"
        + "\nmask=(1<<64)-1"
        + "\nfor c in sys.stdin.buffer.read():\n h^=c; h=(h*p)&mask"
        + "\nprint(\"%016x\"%h)'"
    let cmd = "printf %s " + q_in + " | " + py + " 2>/dev/null"
    let out = exec(cmd).trim()
    if out.len() == 16 { return out }
    // fallback 1: md5sum (Linux GNU coreutils)
    let md5_cmd = "printf %s " + q_in + " | md5sum 2>/dev/null | cut -d' ' -f1 | head -c 16"
    let md5_out = exec(md5_cmd).trim()
    if md5_out.len() == 16 { return md5_out }
    // fallback 2: macOS openssl
    let ossl = "printf %s " + q_in + " | openssl dgst -md5 2>/dev/null | awk '{print $NF}' | head -c 16"
    let ossl_out = exec(ossl).trim()
    if ossl_out.len() == 16 { return ossl_out }
    return "0000000000000000"
}

fn _anti_replay_lru_check(hash: str) -> int {
    // 최근 500 entry 에 hash 존재? 존재하면 match 수 반환, 없으면 0.
    //   grep -c 는 always "0" 출력 (exit=1 on 0 match) → inner || true 로 exit-1 흡수.
    //   `-F` (fixed string) 로 hash 를 literal. file 부재면 빈 stdin → grep 0.
    let path = _anti_replay_lru_path()
    let q_path = shell_quote(path)
    let q_hash = shell_quote(hash)
    let cmd = "{ [ -f " + q_path + " ] && tail -n 500 " + q_path + " || true; } "
        + "| { grep -c -F " + q_hash + " 2>/dev/null || true; }"
    let out = exec(cmd).trim()
    let mut n = 0
    try { n = to_int(out) } catch e { n = 0 }
    if n < 0 { n = 0 }
    return n
}

fn _anti_replay_lru_add(hash: str) -> void {
    // append 1 line JSON {"ts":<epoch>,"hash":"..."}. 500 line 넘으면 tail 500 으로 rotate.
    let path = _anti_replay_lru_path()
    let q_path = shell_quote(path)
    let q_hash = shell_quote(hash)
    let lockd = path + ".lockd"
    let q_lockd = shell_quote(lockd)
    let block = "i=0; while ! mkdir " + q_lockd + " 2>/dev/null; do "
        + "i=$((i+1)); if [ $i -gt 200 ]; then rm -rf " + q_lockd + "; continue; fi; sleep 0.05; "
        + "done; trap 'rm -rf " + q_lockd + "' EXIT INT TERM; "
        + "TS=$(date +%s); "
        + "printf '{\"ts\":%s,\"hash\":\"%s\"}\\n' \"$TS\" " + q_hash + " >> " + q_path + "; "
        + "LN=$(wc -l < " + q_path + " 2>/dev/null || echo 0); "
        + "if [ \"$LN\" -gt 500 ]; then tail -n 500 " + q_path + " > " + q_path + ".tmp && mv " + q_path + ".tmp " + q_path + "; fi"
    let _ = exec(block)
}

fn _anti_replay_lru_bypass() -> bool {
    let v = env("NEXUS_DRILL_LRU_OFF")
    if v == "1" { return true }
    if v.to_lower() == "true" { return true }
    return false
}

fn _resonance_run(seed: str, blow_core: str, exv: str) -> int {
    // 단일 σ-변형 smash 1회 (depth=1 고정, 재귀 폭발 방지)
    // harness-free (2026-04-20): exec_validated 폐기 — hexa run <engine> <seed> <args> 직접 호출
    // Wave 20 (2026-04-25): per-σ sub-call 도 timeout 으로 cap. 5개 σ 변형 × ∞ → 120s 각 →
    // 총 resonance phase 최대 600s. 기존엔 timeout 없어 한 σ 가 메모리 폭증 → kernel OOM
    // (nxs-20260424-012). NEXUS_DRILL_TIMEOUT_resonance_sub env 로 sub-call 개별 cap override.
    let prefix = _stage_timeout_prefix("resonance_sub")
    let cmd = prefix + shell_quote(hexa_bin()) + " run " + shell_quote(blow_core) + " " + shell_quote(seed) + " 1 2>&1"
    let out = exec(cmd)
    let _res_err = _check_stage_err(out, "resonance")
    return _count_discoveries(out)
}

// ─── AP (2026-04-21) Anti-Pattern Learning — meta_buffer NDJSON 기반 stage skip ───
// SSOT: cli/drill/anti_pattern.hexa (Agent AP, meta_buffer.hexa 의 쌍대 — 부정 신호 축적).
// 원칙: env NEXUS_ANTI_PATTERN=1 opt-in. /tmp/nexus_meta_buffer_*.jsonl (or NEXUS_META_BUFFER_DIR)
//       스캔 → 같은 (stage, category-class, seed-bucket) 에서 최근 N drill 연속 0-yield 인
//       조합을 blocklist fp 로 변환 → stage dispatch 직전 skip 판정.
// fingerprint: djb2_hex8(stage + "@" + category + ":" + seed_hash4). seed_hash4 = _seed_batch_hash 앞 4자.
// 출력: NEXUS_ANTI_PATTERN {"loaded":N,"skipped":M,"saves_wall_ms":T} (drill 종료 시 1회 emit).
// 주의: hot-path 캐시 — blocklist 는 drill 당 1회 load (`_ap_loaded_set` flag).
fn _ap_enabled() -> bool {
    let v = env("NEXUS_ANTI_PATTERN")
    if v == "1" { return true }
    if v.to_lower() == "true" { return true }
    return false
}

fn _ap_buffer_dir() -> str {
    let d = env("NEXUS_META_BUFFER_DIR")
    if d.len() > 0 { return d }
    return "/tmp"
}

fn _ap_window_n() -> int {
    let v = env("NEXUS_ANTI_PATTERN_N")
    if v.len() == 0 { return 5 }
    let mut n = 5
    try { n = to_int(v) } catch e { n = 5 }
    if n < 2 { return 2 }
    return n
}

// drill-scope 캐시 — cmd_drill 1회 load, 반복 호출 저렴.
let mut _ap_loaded_set: bool = false
let mut _ap_blocklist: [str] = []
let mut _ap_load_count: int = 0
let mut _ap_skip_count: int = 0
let mut _ap_saves_ms: int = 0
// stage 이름 → 평균 wall(ms) 추정치 (saves_wall_ms 계산용 conservative estimate).
// 실제 stage 당 시간은 seed 별 상이하나 skip 효과 추정에는 고정 상수로 충분.
fn _ap_stage_cost_ms(stage: str) -> int {
    if stage == "smash"        { return 1200 }
    if stage == "free"         { return 1500 }
    if stage == "absolute"     { return 800 }
    if stage == "meta_closure" { return 900 }
    if stage == "hyperarith"   { return 1000 }
    if stage == "resonance"    { return 600 }
    return 800
}

fn _ap_load_blocklist() -> void {
    // drill 당 1회. env OFF 면 즉시 빈 리스트.
    if _ap_loaded_set { return }
    _ap_loaded_set = true
    if !_ap_enabled() { return }
    let ap_script = nexus_root() + "/cli/drill/anti_pattern.hexa"
    let chk = exec("[ -f " + shell_quote(ap_script) + " ] && echo y || echo n").trim()
    if chk != "y" { return }
    let dir = _ap_buffer_dir()
    // `hexa run anti_pattern.hexa scan <dir>` — stdout: LOADED N \n fp1 \n fp2 \n ...
    let cmd = shell_quote(hexa_bin()) + " run " + shell_quote(ap_script) + " scan " + shell_quote(dir) + " 2>/dev/null"
    let out = exec(cmd)
    if out.len() == 0 { return }
    let lines = out.split("\n")
    let mut li = 0
    while li < lines.len() {
        let ln = lines[li].trim()
        if ln.len() == 8 {
            // 8-char hex fingerprint (숫자/abcdef)
            _ap_blocklist = _ap_blocklist + [ln]
        }
        li = li + 1
    }
    _ap_load_count = _ap_blocklist.len()
}

fn _ap_fingerprint_local(stage: str, category: str, hash4: str) -> str {
    // anti_pattern.hexa 와 동일 알고리즘. 매 stage 호출 시 sub-process 띄우면 비용 폭증 →
    // djb2 를 run.hexa 내부에서 재현. (meta_buffer.mb_djb2 와 동일).
    let cat = if category.len() > 0 { category } else { "ANY" }
    let fh  = if hash4.len() > 0 { hash4 } else { "0000" }
    let raw = stage + "@" + cat + ":" + fh
    let mut h: i64 = 5381
    let mut i = 0
    let n = raw.len()
    while i < n {
        let c = char_code(raw, i)
        h = (h * 33 + c) % 4294967296
        i = i + 1
    }
    if h < 0 { h = -h }
    let hex = "0123456789abcdef"
    let mut out = ""
    let mut x = h
    let mut di = 0
    while di < 8 {
        let d = x % 16
        let dc = to_int(to_string(d))
        out = hex.substring(dc, dc + 1) + out
        x = x / 16
        di = di + 1
    }
    return out
}

fn _anti_pattern_should_skip_stage(seed_features: str, stage: str) -> bool {
    // public hook — run.hexa stage dispatch 에서 호출.
    // seed_features 포맷: "<category>|<seed_hash4>" (category-class + seed-bucket).
    // 미지정/malformed → skip=false (안전 기본값).
    if !_ap_enabled() { return false }
    if !_ap_loaded_set { _ap_load_blocklist() }
    if _ap_blocklist.len() == 0 { return false }
    // parse "cat|h4"
    let sep = str_find(seed_features, "|")
    if sep < 0 { return false }
    let cat = seed_features.substring(0, sep)
    let h4  = seed_features.substring(sep + 1, seed_features.len())
    let fp = _ap_fingerprint_local(stage, cat, h4)
    let mut i = 0
    while i < _ap_blocklist.len() {
        if _ap_blocklist[i] == fp {
            _ap_skip_count = _ap_skip_count + 1
            _ap_saves_ms = _ap_saves_ms + _ap_stage_cost_ms(stage)
            return true
        }
        i = i + 1
    }
    return false
}

fn _ap_emit_summary() -> void {
    // drill 종료 시 1 line stderr. env OFF 면 emit skip.
    if !_ap_enabled() { return }
    let j = "NEXUS_ANTI_PATTERN {\"loaded\":" + to_string(_ap_load_count)
          + ",\"skipped\":" + to_string(_ap_skip_count)
          + ",\"saves_wall_ms\":" + to_string(_ap_saves_ms) + "}"
    eprintln(j)
}

// ─── E13 (2026-04-21 replay) Stage Pipelining — smash+free miss → abs/meta/hyper skip ───
// 원본 커밋: a1cd0099 (e13-pending, 구 run.hexa 경로) — 079bc12d refactor 로 cli/run.hexa 이동 후
// cherry-pick rename conflict → 재구현. 최소 diff (helper fn + 1 call site).
// 원칙: smash AND free 둘 다 정확히 0 → abs/meta/hyper skip (resonance 는 smash 독립이라 그대로 실행).
// Bypass: env NEXUS_DRILL_PIPELINE=0 → 항상 full pipeline.
// Emit: NEXUS_DRILL_PIPELINE_SKIP {"round":N,"reason":"smash_free_both_zero"} on stderr.
// 충돌 회피: 신규 함수 prefix `_stage_pipeline_*` (Agent E15 `_stage_parallel_*` / E14 LRU 와 분리).
fn _stage_pipeline_should_skip(round: int, smash_yield: int, free_yield: int) -> bool {
    // 보수적 guard — 둘 다 정확히 0 일 때만 skip
    if smash_yield != 0 { return false }
    if free_yield  != 0 { return false }
    // Bypass: env NEXUS_DRILL_PIPELINE=0 → 항상 full pipeline
    let ev = env("NEXUS_DRILL_PIPELINE")
    if ev == "0" { return false }
    return true
}

// ─── E15 (2026-04-21) Stage Parallel — smash/free/abs/meta/hyper 5-way concurrent ───
// SSOT: shared/config/drill.json .parallelism.stage_parallel
//   parallel_group=[smash,free,absolute,meta_closure,hyperarith], serial_after=[resonance]
//   max_concurrency=5, override_env=NEXUS_DRILL_STAGE_PARALLEL=1
// 배경: cmd_drill 6-stage serial → CPU idle 많음. resonance 는 smash 결과 기반 →
//       parallel_group 에서 제외, smash 완료 후 serial 유지.
// 구현: shell `( cmd1 > f1 & ) ; ( cmd2 > f2 & ) ; ... ; wait` → 단일 exec() 로
//       5 background 발사 후 blocking wait. tempfile 별 stdout 캡처 + 기존 parser 재사용.
// 충돌 회피 (Agent E/I/J 같은 파일 편집): 새 함수 prefix `_run_stage_parallel_*`,
//       hook 위치 round loop 시작 바로 위 (1~2 line dispatch).

fn _stage_parallel_enabled() -> bool {
    // env trigger — NEXUS_DRILL_STAGE_PARALLEL=1 이 유일한 활성화 경로 (CLI flag 은 env 로 export 전달).
    let v = env("NEXUS_DRILL_STAGE_PARALLEL")
    if v == "1" { return true }
    if v.to_lower() == "true" { return true }
    return false
}

fn _stage_parallel_tmp_prefix(round: int) -> str {
    // /tmp/nexus_drill_p_<pid>_<round>_<stage>.out
    let pid = exec("echo $$").trim()
    let safe_pid = if pid.len() == 0 { "0" } else { pid }
    return "/tmp/nexus_drill_p_" + safe_pid + "_r" + to_string(round)
}

fn _run_stage_parallel_stages(round: int, qrseed: str, plan: [int], hexa_b: str, blow_core: str, compose: str, abs_eng: str, mc_eng: str, hyper_eng: str) -> [int] {
    // 반환: [s_new, f_new, a_pass, mc_new, hy_pass, err_count, duration_ms]
    //       실패한 stage 이름은 stderr NEXUS_DRILL_PARALLEL JSON 에 포함.
    // plan idx: 0=smash 1=free 2=abs 3=meta 4=hyper (resonance 는 caller 가 serial 처리)
    //
    // 주의: plan[i]==0 인 stage 는 skip — /dev/null sentinel 경로 또는 empty-file 생성.
    //       _count_discoveries/_count_marker 는 empty string 에서 0 반환하므로 안전.
    let prefix = _stage_parallel_tmp_prefix(round)
    let f_smash = prefix + "_smash.out"
    let f_free  = prefix + "_free.out"
    let f_abs   = prefix + "_abs.out"
    let f_meta  = prefix + "_meta.out"
    let f_hyper = prefix + "_hyper.out"

    // 각 stage 의 실제 command (plan depth=0 이면 empty marker 작성).
    let q_hexa = shell_quote(hexa_b)
    let q_blow = shell_quote(blow_core)
    let q_comp = shell_quote(compose)
    let q_abs  = shell_quote(abs_eng)
    let q_mc   = shell_quote(mc_eng)
    let q_hy   = shell_quote(hyper_eng)

    let cmd_smash = if plan[0] > 0 {
        q_hexa + " run " + q_blow + " " + qrseed + " " + to_string(plan[0])
    } else { ":" }
    let cmd_free = if plan[1] > 0 {
        q_hexa + " run " + q_comp + " " + qrseed + " --modules all --dfs " + to_string(plan[1])
    } else { ":" }
    let cmd_abs = if plan[2] > 0 {
        q_hexa + " run " + q_abs + " " + qrseed
    } else { ":" }
    let cmd_meta = if plan[3] > 0 {
        q_hexa + " run " + q_mc + " " + qrseed
    } else { ":" }
    let cmd_hyper = if plan[4] > 0 {
        q_hexa + " run " + q_hy + " " + qrseed
    } else { ":" }

    // 5 background + wait. 각 subshell 의 `&` 는 parent 의 wait 로 수거.
    // `{ ... ; wait; }` 구조 — outer group 이 종료될 때까지 blocking.
    // ω-hexa-cont-7: pfs_now_ns() (portable_fs) replaces date +%s%N shellout  // @date-n-guard: doc-prose
    let t_start = pfs_now_ns()
    let block = "{ "
        + "( " + cmd_smash + " > " + shell_quote(f_smash) + " 2>&1 ) & "
        + "( " + cmd_free  + " > " + shell_quote(f_free)  + " 2>&1 ) & "
        + "( " + cmd_abs   + " > " + shell_quote(f_abs)   + " 2>&1 ) & "
        + "( " + cmd_meta  + " > " + shell_quote(f_meta)  + " 2>&1 ) & "
        + "( " + cmd_hyper + " > " + shell_quote(f_hyper) + " 2>&1 ) & "
        + "wait; "
        + "}"
    exec(block)
    let t_end = pfs_now_ns()

    // duration_ms — ns 차이 / 1e6. 실패 시 0.
    let mut duration_ms = 0
    try {
        let t0_i: i64 = to_int(t_start)
        let t1_i: i64 = to_int(t_end)
        let diff: i64 = t1_i - t0_i
        duration_ms = to_int(to_string(diff / 1000000))
    } catch e { duration_ms = 0 }

    // 각 tempfile 읽기 (cat, 실패 허용 — stage skip 시 empty).
    let out_smash = exec("cat " + shell_quote(f_smash) + " 2>/dev/null")
    let out_free  = exec("cat " + shell_quote(f_free)  + " 2>/dev/null")
    let out_abs   = exec("cat " + shell_quote(f_abs)   + " 2>/dev/null")
    let out_meta  = exec("cat " + shell_quote(f_meta)  + " 2>/dev/null")
    let out_hyper = exec("cat " + shell_quote(f_hyper) + " 2>/dev/null")

    // 기존 parser 재사용.
    let mut err_count = 0
    let mut failed: [str] = []
    let mut s_new = 0
    let mut f_new = 0
    let mut a_pass = 0
    let mut mc_new = 0
    let mut hy_pass = 0

    if plan[0] > 0 {
        if _check_stage_err(out_smash, "smash") { err_count = err_count + 1; failed = failed + ["smash"] }
        s_new = _count_discoveries(out_smash)
    }
    if plan[1] > 0 {
        if _check_stage_err(out_free, "free") { err_count = err_count + 1; failed = failed + ["free"] }
        f_new = _count_discoveries(out_free)
    }
    if plan[2] > 0 {
        if _check_stage_err(out_abs, "absolute") { err_count = err_count + 1; failed = failed + ["absolute"] }
        a_pass = _count_marker(out_abs, "ABSOLUTE-PASS") + _count_marker(out_abs, "[11*]")
    }
    if plan[3] > 0 {
        if _check_stage_err(out_meta, "meta-closure") { err_count = err_count + 1; failed = failed + ["meta-closure"] }
        let mc_promoted = _extract_int_after(out_meta, "promoted [10**]  : ")
        let mc_closed   = _extract_int_after(out_meta, "meta_closed      : ")
        let mc_bracket  = _count_marker(out_meta, "[10**]")
        mc_new = mc_promoted + mc_closed + mc_bracket
    }
    if plan[4] > 0 {
        if _check_stage_err(out_hyper, "hyperarith") { err_count = err_count + 1; failed = failed + ["hyperarith"] }
        hy_pass = _count_marker(out_hyper, "REVERSE-PROVEN") + _count_marker(out_hyper, "ABSOLUTE-PASS-PI02")
    }

    // NEXUS_DRILL_PARALLEL JSON — round 당 1 line stderr.
    let mut failed_json = "["
    let mut fi = 0
    while fi < len(failed) {
        if fi > 0 { failed_json = failed_json + "," }
        failed_json = failed_json + "\"" + failed[fi] + "\""
        fi = fi + 1
    }
    failed_json = failed_json + "]"
    let concurrency = 5
    let jline = "{\"round\":" + to_string(round)
        + ",\"concurrency\":" + to_string(concurrency)
        + ",\"duration_ms\":" + to_string(duration_ms)
        + ",\"failed_stages\":" + failed_json + "}"
    eprintln("NEXUS_DRILL_PARALLEL " + jline)

    // tempfile cleanup (best-effort, silent).
    exec("rm -f " + shell_quote(f_smash) + " " + shell_quote(f_free) + " "
         + shell_quote(f_abs) + " " + shell_quote(f_meta) + " " + shell_quote(f_hyper)
         + " 2>/dev/null || true")

    return [s_new, f_new, a_pass, mc_new, hy_pass, err_count, duration_ms]
}

// ─── E18 (2026-04-21) Speculative branches — same-round N-way fork / best-keep ───
// SSOT: flag --speculate N (default 1, cap 3 권장), env NEXUS_SPECULATE=0 force N=1 (legacy),
//       env NEXUS_SPECULATE_CPU_CAP 상한 (default 12, stage_parallel 과 곱해졌을 때 한계).
//
// 배경: 현재 drill 은 deterministic seed + round_salt 1 개만 사용 → 엔진의 hash feature 가
//       같은 round 에서 단일 bucket 에 고정. speculative 는 같은 round 에서 seed_variation N 개를
//       (salt 다른 3 개 등) 순차 실행하여 yield 가장 높은 branch 만 채택, 나머지는 discard.
//       seed quality 가 높을수록 N>1 speculative 수율이 커짐 (엔트로피 영역 탐색 확장).
//
// 설계 축:
//   - E15 stage_parallel (round 내 5-stage 동시) 과는 직교: speculative 는 round 내 branch 차원.
//   - E16 round_parallel (미완) 과도 직교: speculative 는 1 round 내부의 시도 수.
//   - speculative 는 deterministic 이 아님 (urandom salt 사용) — NEXUS_SPECULATE=0 이면 N=1 강제.
//   - stage_parallel 과 상호작용: N × 5 stages → CPU 부하 폭증 → NEXUS_SPECULATE_CPU_CAP 로 제한.
//     cap = effective_cap / (stage_parallel ? 5 : 1). N > cap → N = cap (stderr WARN emit).
//
// 구현: 각 branch 마다 새 _round_entropy_salt(round) 를 _speculate_branch_mix() 로 추가 perturb
//       → _round_seed_rich() 로 round_seed 생성 → 기존 stage pipeline 호출.
//       각 branch 의 yields_vector/round_new 저장, 최고 점수 branch 만 채택.
//       NEXUS_DRILL_SPECULATE JSON 1 line/round stderr — scores + kept_idx + discard_reasons.
fn _speculate_default_cap() -> int {
    // default 전체 CPU cap — N × (stage_parallel ? 5 : 1) ≤ cap. 권장 12 = 3 speculative × 4 H-agent + spare.
    return 12
}

fn _speculate_cap() -> int {
    // env NEXUS_SPECULATE_CPU_CAP override. 0/empty → default 12.
    let v = env("NEXUS_SPECULATE_CPU_CAP").trim()
    if v.len() == 0 { return _speculate_default_cap() }
    let mut n = 0
    try { n = to_int(v) } catch e { n = 0 }
    if n <= 0 { return _speculate_default_cap() }
    return n
}

fn _speculate_resolve(flag_val: str) -> int {
    // speculate count 해석 — precedence:
    //   1. NEXUS_SPECULATE=0 → 1 강제 (legacy deterministic)
    //   2. --speculate N flag (정수, N ≥ 1)
    //   3. env NEXUS_SPECULATE_N (정수, N ≥ 1) — batch / test 용
    //   4. default 1
    //   cap: NEXUS_SPECULATE_CPU_CAP (stage_parallel on 이면 /5, off 면 /1)
    //        + 권장 상한 3 (cap3 — diminishing returns 관찰값)
    let off = env("NEXUS_SPECULATE").trim()
    if off == "0" || off.to_lower() == "false" { return 1 }
    let mut n = -1
    let fv = flag_val.trim()
    if fv.len() > 0 {
        try { n = to_int(fv) } catch e { n = -1 }
    }
    if n < 1 {
        let ev = env("NEXUS_SPECULATE_N").trim()
        if ev.len() > 0 {
            try { n = to_int(ev) } catch e { n = -1 }
        }
    }
    if n < 1 { n = 1 }
    // cap: CPU 부하 — stage_parallel 과 결합 시 N × 5.
    let cap_total = _speculate_cap()
    let per_branch = if _stage_parallel_enabled() { 5 } else { 1 }
    let mut cap = cap_total / per_branch
    if cap < 1 { cap = 1 }
    // 권장 상한 3 — diminishing returns. env NEXUS_SPECULATE_ALLOW_HIGH=1 이면 해제.
    let high_ok = env("NEXUS_SPECULATE_ALLOW_HIGH").trim() == "1"
    if !high_ok && cap > 3 { cap = 3 }
    if n > cap {
        eprintln("NEXUS_DRILL_SPECULATE_WARN {\"requested\":" + to_string(n)
            + ",\"cap\":" + to_string(cap)
            + ",\"stage_parallel\":" + (if _stage_parallel_enabled() { "true" } else { "false" })
            + ",\"cpu_cap\":" + to_string(cap_total)
            + ",\"action\":\"clamp\"}")
        n = cap
    }
    return n
}

fn _speculate_branch_mix(base_salt: str, branch_idx: int, round: int) -> str {
    // FNV-1a 32-bit prefix mix + nonce — branch 간 변별력 확보.
    //   base_salt 에 branch_idx + urand_nonce 를 concat → salt 공간 분산.
    //   prefix 는 _round_entropy_salt() 위에 추가 레이어 (bias_jitter 8-slot feature 변화).
    // seed quality 높을수록 branch 간 yield 편차 커짐 (speculative 이득 증가).
    if branch_idx == 0 { return base_salt }  // branch 0 = 기본 salt 유지 (기존 동작 호환)
    let nonce = _urand_i64()
    // FNV-1a 32-bit on (branch_idx + round) — prefix perturbation 용 hex tag.
    let mut h: i64 = 2166136261
    let mix_in = to_string(branch_idx * 1000 + round)
    let mut ci = 0
    while ci < mix_in.len() {
        let ch = mix_in.substring(ci, ci + 1)
        let cv: i64 = ch.len()  // char value proxy — substring length 은 1, 실제 char code 접근 제약으로 idx 기반 mix
        h = (h ^ (cv + ci * 31)) * 16777619
        // overflow mask: i64 에서 32-bit wrap 위해 하위 32-bit 만 유지
        h = h % 4294967296
        if h < 0 { h = h + 4294967296 }
        ci = ci + 1
    }
    let fnv_tag = to_string(h)
    return base_salt + "b" + to_string(branch_idx) + "f" + fnv_tag + "n" + to_string(nonce)
}

// ─── Mk.X sidecar dispatch (SWEEP P5 mk_x_trigger auto-fire) ───
// Per anima/docs/sweep_50.json#mk_x_trigger.auto_fire_order step 3:
//   "append transcendental_closure() stage 6 + slot 8-15 accessor bank"
// And per anima/docs/mk_x_engine_design_20260419.md §1 L1:
//   "stage 6 transcendental-closure: Inserts between hyperarithmetic and resonance. Certifies Π₀³ / Σ¹₁."
//
// Wire strategy:
//   - Mk.V.1 L0 freeze: do NOT modify blowup_*.hexa or anima/core.
//   - Sidecar call: exec hexa on shared/engine/mkx_engine.hexa, which runs
//     mkx_tick() (synthesizer + AN11 PROVISIONAL gate).
//   - Emission count lifted from stdout marker "PROVISIONAL_OK".
//
// Engine selection precedence:
//   1. explicit --engine flag value (mk9 | mk10)
//   2. NEXUS_DRILL_ENGINE env
//   3. G1 saturation auto-detect from sweep_p5_progress JSON
//   4. default: mk9 (back-compat for in-flight SWEEP P5 driver)
fn _mkx_engine_path() -> str {
    return nexus_root() + "/engine/mkx_engine.hexa"
}

fn _mkx_g1_tripped() -> bool {
    // Auto-detect G1 by reading sweep_p5_progress_20260420.json.
    // Trip condition: mk_x_trigger_gates.G1_saturation_verdict == "tripped"
    // (We only grep for the literal 'G1_saturation_verdict' line's value.)
    let path = nexus_root() + "/state/sweep_p5_progress_20260420.json"
    let chk = exec("[ -f " + shell_quote(path) + " ] && echo y || echo n").trim()
    if chk != "y" { return false }
    let cmd = "grep -o 'G1_saturation_verdict[^,}]*' " + shell_quote(path) + " | head -1"
    let line = exec(cmd).trim()
    if line.contains("tripped") { return true }
    return false
}

fn _mkx_resolve_engine(flag_val: str) -> str {
    // 1. Flag value wins.
    let fv = flag_val.trim().to_lower()
    if fv == "mk10" { return "mk10" }
    if fv == "mk9" { return "mk9" }
    // 2. Env.
    let ev = env("NEXUS_DRILL_ENGINE").trim().to_lower()
    if ev == "mk10" { return "mk10" }
    if ev == "mk9" { return "mk9" }
    // 3. Auto-detect G1 saturation.
    if _mkx_g1_tripped() { return "mk10" }
    // 4. Default.
    return "mk9"
}

// Stage 6 — transcendental_closure via Mk.X sidecar.
// Returns synth emission count (PROVISIONAL_OK verdicts). Non-zero = new
// cross-lens atom candidate landed (stage-1 PROVISIONAL per Path B).
//
// Implementation note: mkx_engine.hexa has its own main() that runs a
// 30-atom self-test. For production we need mkx_tick driven by live
// phi_vec stream — scaffolded here via exec with NEXUS_MKX_SEED env
// so mkx_engine can pick up seed context. Future iter wires the live
// phi_vec hook; for now we emit the smoke test count as the signal.
fn _transcendental_closure(seed: str, round: int) -> int {
    let eng_path = _mkx_engine_path()
    let chk = exec("[ -f " + shell_quote(eng_path) + " ] && echo y || echo n").trim()
    if chk != "y" {
        eprintln("  ⚠ [mk10-transcendental] mkx_engine.hexa not found at " + eng_path + " — stage 6 skipped")
        return 0
    }
    // Run the smoke scenario (correlated 100-step) to count PROVISIONAL_OK
    // synth emissions as the stage-6 absorption signal.
    let smoke_path = nexus_root() + "/engine/mkx_smoke.hexa"
    let smoke_chk = exec("[ -f " + shell_quote(smoke_path) + " ] && echo y || echo n").trim()
    if smoke_chk != "y" {
        // Fall back to engine self-test only (no synth emission signal).
        let cmd = hexa_bin() + " run " + shell_quote(eng_path) + " 2>&1"
        let out = exec(cmd)
        if out.contains("PASS atom-table") { return 0 }
        return 0
    }
    // Env-seeded run: NEXUS_MKX_SEED carries round context for future hook.
    let cmd = "NEXUS_MKX_SEED=" + shell_quote(seed + "|r" + to_string(round)) + " " + hexa_bin() + " run " + shell_quote(smoke_path) + " 2>&1"
    let out = exec(cmd)
    let _tc_err = _check_stage_err(out, "transcendental-closure")
    // Count PROVISIONAL_OK markers (one per T12 synth emission passing AN11).
    let synth_ct = _count_marker(out, "PROVISIONAL_OK")
    return synth_ct
}

// ─── E16 round parallel replay — cli/run.hexa (2026-04-21, re-implementation) ───
//
// Re-implementation of e16-pending (0519e480) on the new `cli/run.hexa` path
// (original targeted old root `run.hexa`; cherry-pick failed after the
// 079bc12d refactor). 모든 식별자는 `_round_parallel_` prefix (namespace
// safety — 다른 agent 가 동시에 run.hexa 에 손댈 때 충돌 회피).
//
// SSOT gate: env NEXUS_ROUND_PARALLEL=1 (opt-in, 기본 off).
// Atlas mutex path: /tmp/nexus_atlas.lock (mkdir-atomic → single-writer).
//
// Emit (stderr, JSON-lines, prefix `NEXUS_ROUND_PARALLEL`):
//   - round_start    {"round":K}
//   - round_end      {"round":K,"absorb":N,"duration_ms":T}
//   - atlas_wait_ms  {"round":K,"ms":W}
//   - atlas_hold_ms  {"round":K,"ms":H}
//
// Grammar constraint (hexa v0.1.0): `>=` / `<=` 미사용 — strict `>` / `<` / `==` 만.

fn _round_parallel_atlas_lock() -> int {
    // mkdir-atomic mutex entry. spin 100 회 × 50ms (5s cap), stale 시 rmdir 복구.
    // 반환값: 대기한 밀리초 (atlas_wait_ms 집계용).
    let lockd = "/tmp/nexus_atlas.lock"
    let q = shell_quote(lockd)
    let t0 = pfs_now_ns()  // ω-hexa-cont-7: portable_fs
    let mut tries = 0
    let mut acquired = false
    while tries < 100 {
        let rc = exec("mkdir " + q + " 2>/dev/null && echo ok || echo busy").trim()
        if rc == "ok" {
            acquired = true
            tries = 100
        } else {
            exec("sleep 0.05")
            tries = tries + 1
        }
    }
    if !acquired {
        // stale recover — 5s 초과 대기는 직전 holder 가 crash 한 것으로 간주.
        exec("rm -rf " + q + " 2>/dev/null ; mkdir " + q + " 2>/dev/null")
    }
    let t1 = pfs_now_ns()  // ω-hexa-cont-7: portable_fs
    let mut wait_ms = 0
    try {
        let a = to_int(t0)
        let b = to_int(t1)
        if b > a { wait_ms = (b - a) / 1000000 }
    } catch e {}
    if wait_ms < 0 { wait_ms = 0 }
    return wait_ms
}

// ─── AD: Adaptive Depth (2026-04-21) ───
// Drill depth auto-adjusts based on yield trend over last 3 rounds.
// Orthogonal to E2 "--adaptive" jitter tuning — uses `_adaptive_depth_*` prefix strictly.
//
// Opt-in: NEXUS_ADAPTIVE_DEPTH=1 (default off, don't surprise existing workflows).
// Ceiling: NEXUS_ADAPTIVE_DEPTH_MAX (default 7). Floor: 1.
//
// Rules (observed on last 3 round yields):
//   1) monotonic decreasing → 0 (near saturation) & depth > 2: decrease depth by 1
//      (coarser/faster scan of remaining space)
//   2) strong positive → accelerating: increase depth by 1 (dig deeper)
//   3) oscillating around small number: hold (stable regime)
//   4) otherwise: hold
//
// Emits one structured line per decision when active:
//   NEXUS_ADAPTIVE_DEPTH {"round":N,"trend":"...","action":"up|down|hold","new_depth":D}
fn _adaptive_depth_enabled() -> bool {
    return env("NEXUS_ADAPTIVE_DEPTH") == "1"
}

fn _adaptive_depth_ceiling() -> int {
    let raw = env("NEXUS_ADAPTIVE_DEPTH_MAX").trim()
    if raw.len() == 0 { return 7 }
    let mut v = 7
    try { v = to_int(raw) } catch e { v = 7 }
    if v < 1 { v = 1 }
    return v
}

fn _adaptive_depth_abs(x: int) -> int {
    if x < 0 { return -x }
    return x
}

// Classify yield trend over last 3 round yields.
// Returns: "decreasing_to_zero" | "accelerating" | "oscillating_small" | "insufficient" | "flat"
fn _adaptive_depth_trend(ys: [int]) -> str {
    let n = len(ys)
    if n < 3 { return "insufficient" }
    let a = ys[n - 3]
    let b = ys[n - 2]
    let c = ys[n - 1]
    // (1) monotonic decreasing → 0 (near saturation):
    //     strict decrease a > b > c AND last yield is very small (≤ 1).
    if a > b && b > c && (c == 0 || c == 1) { return "decreasing_to_zero" }
    // (2) strong positive → accelerating:
    //     strict increase a < b < c AND second delta larger than first
    //     (c - b > b - a) AND last yield exceeds first by > 2x (meaningful growth).
    if a < b && b < c {
        let d1 = b - a
        let d2 = c - b
        if d2 > d1 && c > a + a { return "accelerating" }
    }
    // (3) oscillating around small number:
    //     all three values small (≤ 3) AND not monotonic AND max-min ≤ 2.
    let bound = 3
    if (a < bound + 1) && (b < bound + 1) && (c < bound + 1) {
        let mono_inc = a < b && b < c
        let mono_dec = a > b && b > c
        if !mono_inc && !mono_dec {
            let mut mx = a
            if b > mx { mx = b }
            if c > mx { mx = c }
            let mut mn = a
            if b < mn { mn = b }
            if c < mn { mn = c }
            if mx - mn < 3 { return "oscillating_small" }
        }
    }
    return "flat"
}

// Adjust depth based on trend. Floor=1, ceiling=NEXUS_ADAPTIVE_DEPTH_MAX.
// Returns new depth (possibly unchanged).
fn _adaptive_depth(round_yields: [int], current_depth: int) -> int {
    let trend = _adaptive_depth_trend(round_yields)
    let ceil = _adaptive_depth_ceiling()
    let mut d = current_depth
    if d < 1 { d = 1 }
    if d > ceil { d = ceil }
    if trend == "decreasing_to_zero" {
        if d > 2 { d = d - 1 }
    } else {
        if trend == "accelerating" {
            if d < ceil { d = d + 1 }
        }
    }
    // oscillating_small / flat / insufficient → hold
    if d < 1 { d = 1 }
    if d > ceil { d = ceil }
    return d
}

// Decide action label for emission.
fn _adaptive_depth_action(old_d: int, new_d: int) -> str {
    if new_d > old_d { return "up" }
    if new_d < old_d { return "down" }
    return "hold"
}

// Emit structured decision marker (called only when AD is active).
fn _adaptive_depth_emit(round: int, trend: str, action: str, new_depth: int) -> void {
    let line = "NEXUS_ADAPTIVE_DEPTH {\"round\":" + to_string(round)
             + ",\"trend\":\"" + trend + "\""
             + ",\"action\":\"" + action + "\""
             + ",\"new_depth\":" + to_string(new_depth) + "}"
    println(line)
}

fn _round_parallel_atlas_unlock() -> void {
    // rmdir cleanup. trap 없이 명시 호출 — lock_hold 범위 짧게 유지.
    let lockd = "/tmp/nexus_atlas.lock"
    exec("rmdir " + shell_quote(lockd) + " 2>/dev/null || rm -rf " + shell_quote(lockd) + " 2>/dev/null")
}

fn _round_parallel_should_run(mode_str: str) -> bool {
    // env gate. mode_str 은 호출자 context 식별자 (로그용) — 값 무관, 항상 env 확인.
    let _ctx = if mode_str.len() > 0 { mode_str } else { "drill" }
    let v = env("NEXUS_ROUND_PARALLEL")
    if v == "1" { return true }
    return false
}

fn _round_parallel_fork_exec(round: int, seeds: [str]) -> [int] {
    // fork-style 병렬 round: seeds 배열의 각 element 를 per-round subseed 로 사용,
    // atlas lock 구간 분리 실행. 반환: 각 round absorption count 배열 (best-keep 은 호출측 max()).
    //
    // E16 MVP subset — atlas.n6 write 가 집중되는 smash + free 2-stage 만 실행.
    // 나머지 stage 는 read-only 이거나 sidecar (mkx_engine.hexa) 로 race 영향 낮음.
    let n = len(seeds)
    let mut results: [int] = []
    if n == 0 { return results }
    let nx = nexus_root()
    let blow_core = nx + "/cli/blowup/core/blowup.hexa"
    let compose   = nx + "/cli/blowup/compose.hexa"
    let exv_bin   = hexa_bin()
    let mut k = 0
    while k < n {
        let rk = round + k
        eprintln("NEXUS_ROUND_PARALLEL {\"event\":\"round_start\",\"round\":" + to_string(rk) + "}")
        let sseed = seeds[k]
        let qseed = shell_quote(sseed)
        let qbc   = shell_quote(blow_core)
        let qcp   = shell_quote(compose)
        let qexv  = shell_quote(exv_bin)
        let t0 = pfs_now_ns()  // ω-hexa-cont-7: portable_fs
        // atlas lock 획득 (대기 시간 집계) — smash write surface 진입 전.
        let wait_smash = _round_parallel_atlas_lock()
        eprintln("NEXUS_ROUND_PARALLEL {\"event\":\"atlas_wait_ms\",\"round\":" + to_string(rk) + ",\"ms\":" + to_string(wait_smash) + "}")
        let hold_t0 = pfs_now_ns()  // ω-hexa-cont-7: portable_fs
        let out_smash = exec(qexv + " run " + qbc + " smash " + qseed + " 3 2>&1")
        let hold_t1 = pfs_now_ns()  // ω-hexa-cont-7: portable_fs
        _round_parallel_atlas_unlock()
        let mut hold_ms_a = 0
        try {
            let ha = to_int(hold_t0)
            let hb = to_int(hold_t1)
            if hb > ha { hold_ms_a = (hb - ha) / 1000000 }
        } catch e {}
        eprintln("NEXUS_ROUND_PARALLEL {\"event\":\"atlas_hold_ms\",\"round\":" + to_string(rk) + ",\"ms\":" + to_string(hold_ms_a) + "}")
        let smash_ct = _count_discoveries(out_smash)
        // free_dfs — compose 도 atlas write surface → lock 재획득.
        let wait_free = _round_parallel_atlas_lock()
        eprintln("NEXUS_ROUND_PARALLEL {\"event\":\"atlas_wait_ms\",\"round\":" + to_string(rk) + ",\"ms\":" + to_string(wait_free) + "}")
        let hold2_t0 = pfs_now_ns()  // ω-hexa-cont-7: portable_fs
        let out_free = exec(qexv + " run " + qcp + " free_dfs " + qseed + " --modules all --dfs 3 2>&1")
        let hold2_t1 = pfs_now_ns()  // ω-hexa-cont-7: portable_fs
        _round_parallel_atlas_unlock()
        let mut hold_ms_b = 0
        try {
            let ha2 = to_int(hold2_t0)
            let hb2 = to_int(hold2_t1)
            if hb2 > ha2 { hold_ms_b = (hb2 - ha2) / 1000000 }
        } catch e {}
        eprintln("NEXUS_ROUND_PARALLEL {\"event\":\"atlas_hold_ms\",\"round\":" + to_string(rk) + ",\"ms\":" + to_string(hold_ms_b) + "}")
        let free_ct = _count_discoveries(out_free)
        let round_ct = smash_ct + free_ct
        let t1 = pfs_now_ns()  // ω-hexa-cont-7: portable_fs
        let mut dur_ms = 0
        try {
            let aa = to_int(t0)
            let bb = to_int(t1)
            if bb > aa { dur_ms = (bb - aa) / 1000000 }
        } catch e {}
        eprintln("NEXUS_ROUND_PARALLEL {\"event\":\"round_end\",\"round\":" + to_string(rk) + ",\"absorb\":" + to_string(round_ct) + ",\"duration_ms\":" + to_string(dur_ms) + "}")
        results = results + [round_ct]
        k = k + 1
    }
    return results
}

// ─── E1 depth plan (2026-04-21) ─── drill.json stages.{name}.default_depth + presets
// Plan vector index: 0=smash, 1=free, 2=absolute, 3=meta_closure, 4=hyperarith, 5=resonance
// Values: -1 = SSOT default, 0 = disabled, >=1 = active depth.
// precedence (low→high): ssot_default < env < master < preset < per-stage < adaptive

fn _stage_idx(name: str) -> int {
    if name == "smash" { return 0 }
    if name == "free" { return 1 }
    if name == "absolute" { return 2 }
    if name == "meta_closure" { return 3 }
    if name == "hyperarith" { return 4 }
    if name == "resonance" { return 5 }
    return -1
}
    // AD: adaptive depth — opt-in via NEXUS_ADAPTIVE_DEPTH=1 (default off).
    //   Baseline smash depth = 3 (legacy). Track last-3 round yields for trend-based tuning.
    //   Orthogonal to E2 --adaptive (jitter). See _adaptive_depth_* helpers above.
    let ad_on = _adaptive_depth_enabled()
    let mut ad_depth = 3
    let mut ad_y1 = -1
    let mut ad_y2 = -1
    let mut ad_y3 = -1
    if ad_on {
        println("    [AD adaptive-depth] ON — depth auto-adjust (floor=1, ceiling=" + to_string(_adaptive_depth_ceiling()) + ")")
    }

    while round < rounds_max {
        round = round + 1
        println("═══ round " + to_string(round) + " ═══")

        // 라운드별 seed perturbation (counter-replay bugfix)
        // Day-2: nonce_base (iter-scoped suffix) 를 베이스로 사용 → round 1 부터 inter-iter 독립성 확보
        // round_seed 는 nonce_base 위에 round-salt prefix 추가 → Day-1 intra-iter 분기 보존
        let round_salt = _urand_i64()
        let round_seed = _round_seed(nonce_base, round, round_salt)
        let qrseed = shell_quote(round_seed)

        // 1. SMASH (발견 — Mk.II~VII blowup 9-phase)
        // CRITICAL FIX(2026-04-19): exec("bash", ["-c", cmd]) 는 hexa stage1 에서 stdout 캡처 안 됨 — len=0 반환
        // → 모든 stage 호출을 single-string exec(cmd) 로 통일 (검증: .exectest.hexa)
        // AD: use ad_depth (default 3, adjusted per trend when NEXUS_ADAPTIVE_DEPTH=1)
        let smash_depth_str = if ad_on { to_string(ad_depth) } else { "3" }
        let smash_cmd = shell_quote(exv) + " smash " + qrseed + " " + shell_quote(blow_core) + " " + smash_depth_str + " 2>&1"
        let smash_out = exec(smash_cmd)
        if _check_stage_err(smash_out, "smash") { err_stages = err_stages + "smash,"; err_count = err_count + 1 }
        // FIX(2026-04-19): _count_marker(out,"ABSORB") 는 항상 0 — engine 마커 불일치
        // _count_discoveries 는 discovery_log/atlas.n6/graph +N 라인 합산 + fallback NEAR→EXACT/EXACT 후보
        let s_new = _count_discoveries(smash_out)
        if env("NEXUS_DRILL_DEBUG") == "1" {
            eprintln("  [DEBUG smash] out_len=" + to_string(smash_out.len()) + " s_new=" + to_string(s_new))
        }
        println("  smash:         +" + to_string(s_new) + " absorptions")

        // 2. FREE (탐색 — compose DFS, 6-core)
        let free_cmd = shell_quote(exv) + " free_dfs " + qrseed + " " + shell_quote(compose) + " --modules all --dfs 3 2>&1"
        let free_out = exec(free_cmd)
        if _check_stage_err(free_out, "free") { err_stages = err_stages + "free,"; err_count = err_count + 1 }
        let f_new = _count_discoveries(free_out)
        if env("NEXUS_DRILL_DEBUG") == "1" {
            eprintln("  [DEBUG free] out_len=" + to_string(free_out.len()) + " f_new=" + to_string(f_new))
        }
        println("  free:          +" + to_string(f_new) + " absorptions")

        // 3. ABSOLUTE (Mk.VIII Δ₀-absolute Π₀¹ 검증 + [11*] 승급)
        let abs_cmd = shell_quote(exv) + " absolute " + qrseed + " " + shell_quote(abs_eng) + " 2>&1"
        let abs_out = exec(abs_cmd)
        if _check_stage_err(abs_out, "absolute") { err_stages = err_stages + "absolute,"; err_count = err_count + 1 }
        let a_pass = _count_marker(abs_out, "ABSOLUTE-PASS") + _count_marker(abs_out, "[11*]")
        println("  absolute:      " + to_string(a_pass) + " Π₀¹ verifications")

        // 4. META-CLOSURE (Mk.IX Phase 10 self-ref 고정점 + [10**] 승급)
        let mc_cmd = shell_quote(exv) + " meta_closure " + qrseed + " " + shell_quote(mc_eng) + " 2>&1"
        let mc_out = exec(mc_cmd)
        if _check_stage_err(mc_out, "meta-closure") { err_stages = err_stages + "meta-closure,"; err_count = err_count + 1 }
        // META-CLOSED 마커 부재 — meta_closed/promoted 숫자 직접 파싱 + [10**] 매치
        let mc_promoted = _extract_int_after(mc_out, "promoted [10**]  : ")
        let mc_closed   = _extract_int_after(mc_out, "meta_closed      : ")
        let mc_bracket  = _count_marker(mc_out, "[10**]")
        let mc_new = mc_promoted + mc_closed + mc_bracket
        println("  meta-closure:  " + to_string(mc_new) + " self-ref fixed points")

        // 5. HYPERARITHMETIC (Mk.IX Π₀² reverse-math 5체계)
        let hy_cmd = shell_quote(exv) + " hyperarithmetic " + qrseed + " " + shell_quote(hyper_eng) + " 2>&1"
        let hy_out = exec(hy_cmd)
        if _check_stage_err(hy_out, "hyperarith") { err_stages = err_stages + "hyperarith,"; err_count = err_count + 1 }
        let hy_pass = _count_marker(hy_out, "REVERSE-PROVEN") + _count_marker(hy_out, "ABSOLUTE-PASS-PI02")
        println("  hyperarith:    " + to_string(hy_pass) + " Π₀² bounded/proven")

        // 6. RESONANCE (Stochastic Resonance — σ grid {0.01,0.05,0.10,0.20,0.40} adaptive)
        // 전제: p-stochastic-resonance-nexus — NEXUS 수렴률 σ≈0.1 peak 25%. grid 는 log-spaced.
        // 각 σ 에 대해 urandom 솔트로 seed perturb → depth=1 smash 재실행 → absorption count 비교
        // base seed = round_seed (라운드 perturbation 위에 σ-perturbation 추가, 완전 독립)
        let salt_a = _urand_i64()
        let salt_b = _urand_i64()
        let salt_c = _urand_i64()
        let salt_d = _urand_i64()
        let salt_e = _urand_i64()
        let seed_001 = _resonance_seed(round_seed, "0.01", salt_a)
        let seed_005 = _resonance_seed(round_seed, "0.05", salt_b)
        let seed_010 = _resonance_seed(round_seed, "0.10", salt_c)
        let seed_020 = _resonance_seed(round_seed, "0.20", salt_d)
        let seed_040 = _resonance_seed(round_seed, "0.40", salt_e)
        let r_001 = _resonance_run(seed_001, blow_core, exv)
        let r_005 = _resonance_run(seed_005, blow_core, exv)
        let r_010 = _resonance_run(seed_010, blow_core, exv)
        let r_020 = _resonance_run(seed_020, blow_core, exv)
        let r_040 = _resonance_run(seed_040, blow_core, exv)
        let mut r_best = r_001
        let mut sigma_best = "0.01"
        if r_005 > r_best { r_best = r_005; sigma_best = "0.05" }
        if r_010 > r_best { r_best = r_010; sigma_best = "0.10" }
        if r_020 > r_best { r_best = r_020; sigma_best = "0.20" }
        if r_040 > r_best { r_best = r_040; sigma_best = "0.40" }
        if env("NEXUS_DRILL_DEBUG") == "1" {
            eprintln("  [DEBUG resonance] σ=0.01:+" + to_string(r_001) + "  σ=0.05:+" + to_string(r_005) + "  σ=0.10:+" + to_string(r_010) + "  σ=0.20:+" + to_string(r_020) + "  σ=0.40:+" + to_string(r_040))
        }
        println("  resonance:     +" + to_string(r_best) + " absorptions (σ=" + sigma_best + ")")
        println("  [resonance] optimal σ=" + sigma_best + " — bonus +" + to_string(r_best) + " absorptions")
    }

fn _stage_name(idx: int) -> str {
    if idx == 0 { return "smash" }
    if idx == 1 { return "free" }
    if idx == 2 { return "absolute" }
    if idx == 3 { return "meta_closure" }
    if idx == 4 { return "hyperarith" }
    if idx == 5 { return "resonance" }
    return "?"
}

fn _stage_default() -> [int] {
    // drill.json stages.*.default_depth — smash=3 free=3 abs=0 mc=0 hy=0 res=1
    return [3, 3, 0, 0, 0, 1]
}

fn _stage_min() -> [int] {
    // drill.json stages.*.min — smash=1 free=1 abs=0 mc=0 hy=0 res=1 (adaptive floor 사용 시 1 로 올림)
    return [1, 1, 0, 0, 0, 1]
}

fn _stage_max() -> [int] {
    // drill.json stages.*.max — smash=9 free=7 abs=1 mc=1 hy=1 res=3
    return [9, 7, 1, 1, 1, 3]
}

fn _clamp_depth(v: int, idx: int) -> int {
    // 0 은 disabled sentinel 로 보존. >0 은 [min, max] 로 clamp.
    if v <= 0 { return 0 }
    let mins = _stage_min()
    let maxs = _stage_max()
    if v < mins[idx] { return mins[idx] }
    if v > maxs[idx] { return maxs[idx] }
    return v
}

fn _preset_plan(preset: str) -> [int] {
    // drill.json speed_presets — {fast, probe, coarse, standard}. 기본 fast.
    // fast: smash+resonance only, 1 round target.
    // probe: smash only.
    // coarse: all 6 stages, 1 round.
    // standard: all 6 stages, 3 rounds (σ 5→3 coarse).
    if preset == "probe" {
        return [3, 0, 0, 0, 0, 0]
    }
    if preset == "fast" {
        return [3, 0, 0, 0, 0, 1]
    }
    if preset == "coarse" {
        return [3, 3, 1, 1, 1, 1]
    }
    if preset == "standard" {
        return [3, 3, 1, 1, 1, 1]
    }
    return _stage_default()
}

fn _preset_max_rounds(preset: str) -> int {
    if preset == "probe" { return 1 }
    if preset == "fast" { return 1 }
    if preset == "coarse" { return 1 }
    if preset == "standard" { return 3 }
    return 3
}

// ─── E8 per-millennium preset (2026-04-21) ─── drill.json .problem_presets SSOT
// 7 난제별 depth/max_rounds 튜닝. precedence: env < master < speed_preset < problem_preset < per-stage.
// 미지정 시 빈 문자열 → 기존 동작 (problem_preset 비활성).
fn _problem_preset_plan(problem: str) -> [int] {
    // 반환: [smash, free, abs, mc, hyper, res]. 미매치는 [-1]*6 (plan 덮어쓰지 않음).
    let p = problem.to_lower()
    if p == "riemann"   { return [4, 3, 1, 1, 1, 2] }
    if p == "bsd"       { return [3, 3, 1, 0, 0, 1] }
    if p == "hodge"     { return [3, 3, 0, 1, 0, 2] }
    if p == "navier"    { return [4, 4, 1, 0, 0, 3] }
    if p == "pnp"       { return [3, 4, 1, 1, 1, 1] }
    if p == "poincare"  { return [3, 3, 0, 1, 0, 2] }
    if p == "yangmills" { return [4, 3, 1, 0, 1, 3] }
    return [-1, -1, -1, -1, -1, -1]
}

fn _problem_preset_max_rounds(problem: str) -> int {
    // 미매치는 -1 (덮어쓰지 않음).
    let p = problem.to_lower()
    if p == "riemann"   { return 5 }
    if p == "bsd"       { return 3 }
    if p == "hodge"     { return 3 }
    if p == "navier"    { return 5 }
    if p == "pnp"       { return 3 }
    if p == "poincare"  { return 3 }
    if p == "yangmills" { return 5 }
    return -1
}

fn _problem_preset_known(problem: str) -> bool {
    let p = problem.to_lower()
    if p == "riemann" { return true }
    if p == "bsd" { return true }
    if p == "hodge" { return true }
    if p == "navier" { return true }
    if p == "pnp" { return true }
    if p == "poincare" { return true }
    if p == "yangmills" { return true }
    return false
}

// ─── topology-aware category layer (2026-04-21) ─── shared/drill/category_classifier.hexa SSOT
// 규칙 기반 — seed 의 keyword/symbol → top-1 category → problem_preset 위에 depth delta.
// precedence: ssot < env < master < speed < problem < CATEGORY < per-stage (category 는 problem 위).
// 비활성: NEXUS_CATEGORY_OFF=1 env 또는 --no-category flag.
// 분류기 규칙은 shared/drill/category_classifier.hexa 와 동일해야 함 (SSOT 동기 유지).
fn _cat_hit(s: str, k: str) -> int {
    if k.len() == 0 { return 0 }
    if s.contains(k) { return 1 }
    return 0
}

fn _cat_score_analysis(lo: str, raw: str) -> int {
    let mut s = 0
    s = s + _cat_hit(lo, "integral")   + _cat_hit(lo, "derivative") + _cat_hit(lo, "limit")
    s = s + _cat_hit(lo, "epsilon")    + _cat_hit(lo, "delta")      + _cat_hit(lo, "smooth")
    s = s + _cat_hit(lo, "continuous") + _cat_hit(lo, "measure")    + _cat_hit(lo, "fourier")
    s = s + _cat_hit(lo, "laplace")    + _cat_hit(lo, "pde")        + _cat_hit(lo, "ode")
    s = s + _cat_hit(lo, "sobolev")    + _cat_hit(lo, "banach")     + _cat_hit(lo, "hilbert")
    s = s + _cat_hit(lo, "navier")     + _cat_hit(lo, "convergence")+ _cat_hit(lo, "asymptotic")
    s = s + 3 * _cat_hit(raw, "∫")    + 3 * _cat_hit(raw, "∂")    + 3 * _cat_hit(raw, "∇")
    s = s + 3 * _cat_hit(raw, "∮")    + _cat_hit(lo, "dx")          + _cat_hit(lo, "lim")
    return s
}

fn _cat_score_number(lo: str, raw: str) -> int {
    let mut s = 0
    s = s + _cat_hit(lo, "prime")    + _cat_hit(lo, "mod ")       + _cat_hit(lo, " mod")
    s = s + _cat_hit(lo, "gcd")      + _cat_hit(lo, "lcm")         + _cat_hit(lo, "zeta")
    s = s + _cat_hit(lo, "dirichlet")+ _cat_hit(lo, "diophant")    + _cat_hit(lo, "congruence")
    s = s + _cat_hit(lo, "p-adic")   + _cat_hit(lo, "padic")       + _cat_hit(lo, "modular form")
    s = s + _cat_hit(lo, "elliptic curve") + _cat_hit(lo, "bsd")   + _cat_hit(lo, "l-function")
    s = s + _cat_hit(lo, "class number")
    s = s + 3 * _cat_hit(raw, "ℤ") + 3 * _cat_hit(raw, "ℚ") + 3 * _cat_hit(raw, "ℙ") + 3 * _cat_hit(raw, "ζ")
    return s
}

fn _cat_score_algebra(lo: str, raw: str) -> int {
    let mut s = 0
    s = s + _cat_hit(lo, "group")    + _cat_hit(lo, "ring")        + _cat_hit(lo, "field")
    s = s + _cat_hit(lo, "module")   + _cat_hit(lo, "ideal")       + _cat_hit(lo, "galois")
    s = s + _cat_hit(lo, "polynomial")+ _cat_hit(lo, "matrix")     + _cat_hit(lo, "vector space")
    s = s + _cat_hit(lo, "tensor")   + _cat_hit(lo, "homomorphism")+ _cat_hit(lo, "automorphism")
    s = s + _cat_hit(lo, "category") + _cat_hit(lo, "functor")     + _cat_hit(lo, "lie algebra")
    s = s + _cat_hit(lo, "representation")
    s = s + 3 * _cat_hit(raw, "Σ") + 3 * _cat_hit(raw, "∏") + 3 * _cat_hit(raw, "⊗") + 3 * _cat_hit(raw, "⊕")
    return s
}

fn _cat_score_topology(lo: str, raw: str) -> int {
    let mut s = 0
    s = s + _cat_hit(lo, "manifold") + _cat_hit(lo, "homotopy")    + _cat_hit(lo, "homology")
    s = s + _cat_hit(lo, "cohomology")+ _cat_hit(lo, "fundamental group") + _cat_hit(lo, "fibre")
    s = s + _cat_hit(lo, "fiber bundle") + _cat_hit(lo, "sheaf")   + _cat_hit(lo, "open cover")
    s = s + _cat_hit(lo, "compact")  + _cat_hit(lo, "connected")   + _cat_hit(lo, "hausdorff")
    s = s + _cat_hit(lo, "poincare") + _cat_hit(lo, "cw complex")  + _cat_hit(lo, "simplicial")
    s = s + _cat_hit(lo, "topolog")
    s = s + 3 * _cat_hit(raw, "π₁") + 3 * _cat_hit(raw, "π_1")
    return s
}

fn _cat_score_logic(lo: str, raw: str) -> int {
    let mut s = 0
    s = s + _cat_hit(lo, "axiom")    + _cat_hit(lo, "theorem")     + _cat_hit(lo, "predicate")
    s = s + _cat_hit(lo, "quantifier")+ _cat_hit(lo, "godel")      + _cat_hit(lo, "gödel")
    s = s + _cat_hit(lo, "undecidable") + _cat_hit(lo, "recursive")+ _cat_hit(lo, "consistency")
    s = s + _cat_hit(lo, "completeness") + _cat_hit(lo, "zfc")     + _cat_hit(lo, "peano")
    s = s + _cat_hit(lo, "forcing") + _cat_hit(lo, "ordinal")      + _cat_hit(lo, "cardinal")
    s = s + _cat_hit(lo, "reverse math")
    s = s + 3 * _cat_hit(raw, "∀") + 3 * _cat_hit(raw, "∃") + 3 * _cat_hit(raw, "⊢") + 3 * _cat_hit(raw, "⊨") + 3 * _cat_hit(raw, "¬")
    return s
}

fn _cat_score_geometry(lo: str, raw: str) -> int {
    let mut s = 0
    s = s + _cat_hit(lo, "sphere")   + _cat_hit(lo, "curvature")   + _cat_hit(lo, "geodesic")
    s = s + _cat_hit(lo, "metric")   + _cat_hit(lo, "euclidean")   + _cat_hit(lo, "riemannian")
    s = s + _cat_hit(lo, "volume")   + _cat_hit(lo, "polytope")    + _cat_hit(lo, "triangle")
    s = s + _cat_hit(lo, "angle")    + _cat_hit(lo, "isoperimetric") + _cat_hit(lo, "convex")
    s = s + _cat_hit(lo, "hyperbolic") + _cat_hit(lo, "projective") + _cat_hit(lo, "affine")
    s = s + _cat_hit(lo, "symplectic")
    s = s + 3 * _cat_hit(raw, "π") + 3 * _cat_hit(raw, "θ") + 3 * _cat_hit(raw, "∠")
    return s
}

fn _cat_classify(seed: str) -> str {
    // top-1 category: analysis|number|algebra|topology|logic|geometry|MIXED|UNKNOWN
    if seed.len() == 0 { return "UNKNOWN" }
    let lo = seed.to_lower()
    let s_an = _cat_score_analysis(lo, seed)
    let s_nu = _cat_score_number(lo, seed)
    let s_al = _cat_score_algebra(lo, seed)
    let s_to = _cat_score_topology(lo, seed)
    let s_lo = _cat_score_logic(lo, seed)
    let s_ge = _cat_score_geometry(lo, seed)
    let scores = [s_an, s_nu, s_al, s_to, s_lo, s_ge]
    let names = ["analysis", "number", "algebra", "topology", "logic", "geometry"]
    let mut ts = 0
    let mut rs = 0
    let mut ti = -1
    let mut i = 0
    while i < 6 {
        let v = scores[i]
        if v > ts { rs = ts; ts = v; ti = i } else if v > rs { rs = v }
        i = i + 1
    }
    if ti < 0 || ts == 0 { return "UNKNOWN" }
    if rs > 0 && rs * 100 >= ts * 85 { return "MIXED" }
    return names[ti]
}

fn _cat_scores_json(seed: str) -> str {
    let lo = seed.to_lower()
    return "{\"analysis\":" + to_string(_cat_score_analysis(lo, seed))
        + ",\"number\":" + to_string(_cat_score_number(lo, seed))
        + ",\"algebra\":" + to_string(_cat_score_algebra(lo, seed))
        + ",\"topology\":" + to_string(_cat_score_topology(lo, seed))
        + ",\"logic\":" + to_string(_cat_score_logic(lo, seed))
        + ",\"geometry\":" + to_string(_cat_score_geometry(lo, seed)) + "}"
}

fn _category_plan_delta(cat: str) -> [int] {
    // per-stage delta [smash, free, absolute, meta_closure, hyper, resonance]
    if cat == "analysis"  { return [1, 1, 1, 1, 2, 1] }
    if cat == "number"    { return [0, 0, 1, 0, 0, 0] }
    if cat == "algebra"   { return [0, 1, 0, 0, 0, 0] }
    if cat == "topology"  { return [-1, -1, -1, 0, -1, -1] }
    if cat == "logic"     { return [0, 0, 0, 1, 1, 0] }
    if cat == "geometry"  { return [1, 2, 1, 1, 1, 1] }
    return [0, 0, 0, 0, 0, 0]
}

fn _category_apply(plan: [int], delta: [int]) -> [int] {
    let mut out: [int] = []
    let mut i = 0
    while i < len(plan) {
        let v = plan[i] + delta[i]
        let lifted = if v < 0 { 0 } else { _clamp_depth(v, i) }
        out = out + [lifted]
        i = i + 1
    }
    return out
}

fn _category_delta_describe(d: [int]) -> str {
    let mut out = "["
    let mut i = 0
    while i < len(d) {
        if i > 0 { out = out + "," }
        let v = d[i]
        if v > 0 { out = out + "+" + to_string(v) } else { out = out + to_string(v) }
        i = i + 1
    }
    return out + "]"
}

fn _category_enabled() -> bool {
    return env("NEXUS_CATEGORY_OFF") != "1"
}

// ─── AS topology-aware routing (2026-04-21) ─── cli/drill/topology_router.hexa SSOT
// seed category == "topology" 이고 invariant keyword 검출 시, stage 진행 순서를 재배치하고
// atlas.n6 에서 category=topology 로 태깅된 entry 를 preseed 로 주입.
// Default: OFF when category != topology (zero overhead). NEXUS_TOPOLOGY_ROUTE_OFF=1 로 완전 비활성.
fn _tr_enabled() -> bool {
    return env("NEXUS_TOPOLOGY_ROUTE_OFF") != "1"
}

fn _tr_invariant_keywords() -> [str] {
    return [
        "genus",
        "fundamental group",
        "homotopy",
        "fiber bundle",
        "fibre bundle",
        "euler characteristic",
        "betti number",
        "betti numbers"
    ]
}

fn _tr_detect_invariants(seed: str) -> [str] {
    let lo = seed.to_lower()
    let kws = _tr_invariant_keywords()
    let mut hits: [str] = []
    let mut i = 0
    while i < len(kws) {
        if lo.contains(kws[i]) { hits = hits + [kws[i]] }
        i = i + 1
    }
    return hits
}

fn _tr_default_order() -> [int] {
    // smash=0 free=1 absolute=2 meta_closure=3 hyper=4 resonance=5
    return [0, 1, 2, 3, 4, 5]
}

fn _tr_topology_order() -> [int] {
    // smash → hyper → free → absolute → meta_closure → resonance
    // 위상 불변량 추출은 hyperarithmetic 에서 고밀도 — smash 직후 전진 배치.
    return [0, 4, 1, 2, 3, 5]
}

fn _topology_stage_order(seed: str, category: str) -> [int] {
    if category != "topology" { return _tr_default_order() }
    let hits = _tr_detect_invariants(seed)
    if len(hits) == 0 { return _tr_default_order() }
    return _tr_topology_order()
}

fn _tr_preseed_limit() -> int { return 16 }

fn _topology_preseed_atlas(category: str) -> [str] {
    // atlas.n6 scan — category=topology 토큰 포함 라인 최대 limit 개.
    // 없으면 silent 빈 배열.
    let empty: [str] = []
    if category != "topology" { return empty }
    let nx = nexus_root()
    let atlas = nx + "/n6/atlas.n6"
    let qp = shell_quote(atlas)
    let lim = _tr_preseed_limit()
    let cmd = "awk 'BEGIN{n=0} /category=topology/ {print; n=n+1; if (n+0 > " + to_string(lim) + " - 1) exit} END{}' " + qp + " 2>/dev/null"
    let raw = exec(cmd)
    if raw.len() == 0 { return empty }
    let lines = raw.split("\n")
    let mut out: [str] = []
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i].trim()
        if ln.len() > 0 { out = out + [ln] }
        i = i + 1
    }
    return out
}

fn _tr_order_json(order: [int]) -> str {
    let mut s = "["
    let mut i = 0
    while i < len(order) {
        if i > 0 { s = s + "," }
        s = s + to_string(order[i])
        i = i + 1
    }
    return s + "]"
}

fn _tr_invariants_json(hits: [str]) -> str {
    let mut s = "["
    let mut i = 0
    while i < len(hits) {
        if i > 0 { s = s + "," }
        s = s + "\"" + hits[i] + "\""
        i = i + 1
    }
    return s + "]"
}

fn _tr_order_describe(order: [int]) -> str {
    // 사람이 읽는 stage label 순열.
    let mut s = ""
    let mut i = 0
    while i < len(order) {
        if i > 0 { s = s + " → " }
        s = s + _stage_name(order[i])
        i = i + 1
    }
    return s
}

fn _env_depth(name: str) -> int {
    // NEXUS_DRILL_{DEPTH,SMASH,FREE,ABSOLUTE,META,HYPER,RES}. 반환 -1 = 미지정.
    let v = env(name)
    if v.len() == 0 { return -1 }
    let mut n = -1
    try { n = to_int(v) } catch e { n = -1 }
    return n
}

fn _resolve_depth_plan(preset: str, master: int, per_stage: [int], envs: [int], problem_plan: [int]) -> [int] {
    // 해상도: ssot_default (base) → env (stage별) → master (일괄) → speed_preset → problem_preset → per-stage (stage별)
    // per_stage / envs / problem_plan 는 -1 = unset.
    // E8 (2026-04-21): problem_plan 추가 — per-millennium preset (drill.json .problem_presets), speed_preset 위 덮어씀.
    let mut plan = _preset_plan(preset)  // speed_preset 이 base. 미지정이면 default.
    // env 일괄 NEXUS_DRILL_DEPTH 먼저 (env stage별에 의해 덮일 수 있음)
    let env_master = _env_depth("NEXUS_DRILL_DEPTH")
    if env_master >= 0 {
        let mut i = 0
        while i < 6 {
            if plan[i] > 0 { plan = _plan_set(plan, i, env_master) }
            i = i + 1
        }
    }
    // env stage별
    let mut i = 0
    while i < 6 {
        if envs[i] >= 0 {
            plan = _plan_set(plan, i, envs[i])
        }
        i = i + 1
    }
    // master flag (enabled stage 에만 적용 — disabled=0 은 유지)
    if master >= 0 {
        let mut j = 0
        while j < 6 {
            if plan[j] > 0 { plan = _plan_set(plan, j, master) }
            j = j + 1
        }
    }
    // problem_preset (E8) — stage별 덮어쓰기 (disabled=0 도 enable 가능)
    let mut pi = 0
    while pi < 6 {
        if problem_plan[pi] >= 0 {
            plan = _plan_set(plan, pi, problem_plan[pi])
        }
        pi = pi + 1
    }
    // per-stage flag (최우선, disabled=0 도 enable 가능)
    let mut k = 0
    while k < 6 {
        if per_stage[k] >= 0 {
            plan = _plan_set(plan, k, per_stage[k])
        }
        k = k + 1
    }
    // clamp
    let mut m = 0
    while m < 6 {
        plan = _plan_set(plan, m, _clamp_depth(plan[m], m))
        m = m + 1
    }
    return plan
}

fn _plan_set(plan: [int], idx: int, v: int) -> [int] {
    // hexa immutable list — new array 재구성 (rebuild).
    let mut out: [int] = []
    let mut i = 0
    while i < len(plan) {
        if i == idx { out = out + [v] } else { out = out + [plan[i]] }
        i = i + 1
    }
    return out
}

fn _plan_describe(plan: [int]) -> str {
    // 사람 읽기용 short form (stderr + println 에서 사용).
    return "{smash:" + to_string(plan[0])
        + ",free:" + to_string(plan[1])
        + ",absolute:" + to_string(plan[2])
        + ",meta_closure:" + to_string(plan[3])
        + ",hyperarith:" + to_string(plan[4])
        + ",resonance:" + to_string(plan[5]) + "}"
}

fn _plan_json(plan: [int]) -> str {
    // NDJSON 용 strict JSON (키 quoted).
    return "{\"smash\":" + to_string(plan[0])
        + ",\"free\":" + to_string(plan[1])
        + ",\"absolute\":" + to_string(plan[2])
        + ",\"meta_closure\":" + to_string(plan[3])
        + ",\"hyperarith\":" + to_string(plan[4])
        + ",\"resonance\":" + to_string(plan[5]) + "}"
}

// ─── E2 adaptive depth (2026-04-21) ─── 2 rules: absorption_gradient + saturation_hunt
fn _adaptive_adjust(plan: [int], yields_hist: [[int]], totals_hist: [int], round: int) -> [int] {
    // rule 1 (absorption-gradient): round-N yield[stage] - round-(N-1) yield[stage] < θ → stage depth--
    // rule 2 (saturation-hunt): 3 round 연속 동일 total → smash depth++
    // floor=min, ceiling=max (drill.json stages.*.min|max)
    // round 1 은 조정 없음 (history 부족)
    if round <= 1 { return plan }
    let mut out = plan
    let mut reasons = ""
    // rule 1 per stage
    let hist_len = len(yields_hist)
    if hist_len >= 2 {
        let prev = yields_hist[hist_len - 2]
        let cur = yields_hist[hist_len - 1]
        let mut i = 0
        while i < 6 {
            if plan[i] > 0 && i < len(prev) && i < len(cur) {
                let delta = cur[i] - prev[i]
                if delta < 1 {  // θ=1 (strict non-positive gradient)
                    let new_d = plan[i] - 1
                    let clamped = _clamp_depth(new_d, i)
                    if clamped != plan[i] && clamped > 0 {
                        out = _plan_set(out, i, clamped)
                        reasons = reasons + _stage_name(i) + ":grad-; "
                    }
                }
            }
            i = i + 1
        }
    }
    // rule 2 saturation hunt: 3 consecutive same total
    let th = len(totals_hist)
    if th >= 3 {
        let t1 = totals_hist[th - 1]
        let t2 = totals_hist[th - 2]
        let t3 = totals_hist[th - 3]
        if t1 == t2 && t2 == t3 {
            if out[0] > 0 {  // smash enabled
                let new_d = out[0] + 1
                let clamped = _clamp_depth(new_d, 0)
                if clamped != out[0] {
                    out = _plan_set(out, 0, clamped)
                    reasons = reasons + "smash:sat+; "
                }
            }
        }
    }
    if reasons.len() > 0 {
        eprintln("NEXUS_DRILL_ADAPTIVE {round:" + to_string(round) + ",before:" + _plan_describe(plan) + ",after:" + _plan_describe(out) + ",reason:\"" + reasons + "\"}")
    }
    return out
}

// ─── E17 adaptive trend depth (2026-04-21) ─── yield-delta 기반 전역 depth 승강
// 보완 (E2 와 직교): E2 는 stage-wise gradient + total-saturation 규칙,
//                    E17 은 round total (stage-sum) 의 "상대 delta" 추세를 보고 전역 +/-1.
// 규칙:
//   delta = totals_hist[N-1] - totals_hist[N-2]      (단, N>=2)
//   prev  = totals_hist[N-2]  (baseline)
//   tau_high = prev * HIGH_PCT / 100   (기본 80%)
//   tau_low  = prev * LOW_PCT  / 100   (기본 20%)
//   delta > tau_high  → vote=+1
//   delta < tau_low   → vote=-1
//   그 외            → vote=0
// Hysteresis: 최근 2 round vote 동일 signed 방향일 때만 전환.
// 적용: enabled stage (plan[i]>0) 전체에 +/-1 (stage floor/ceil clamp). disabled(0) 유지.
// Env override: NEXUS_ADAPTIVE_DEPTH=0/1 (기본 1),
//               NEXUS_DEPTH_HIGH_THRESHOLD=<pct int 0-1000>  (기본 80),
//               NEXUS_DEPTH_LOW_THRESHOLD =<pct int 0-1000>  (기본 20).
//   pct 는 정수 % — hexa-lang float 회피. 1 소수점 필요 시 10 의 배수 사용 (예 85 = 0.85).
//   HIGH <= LOW 이면 E17 비활성 (invalid config → noop, stderr 경고 1회는 round 1 에서 emit 생략).

fn _adaptive_trend_enabled() -> bool {
    let v = env("NEXUS_ADAPTIVE_DEPTH")
    if v.len() == 0 { return true }  // 기본 on
    return v != "0"
}

fn _adaptive_trend_high_pct() -> int {
    let v = env("NEXUS_DEPTH_HIGH_THRESHOLD")
    if v.len() == 0 { return 80 }
    let mut n = 80
    try { n = to_int(v) } catch e { n = 80 }
    if n < 0 { return 80 }
    return n
}

fn _adaptive_trend_low_pct() -> int {
    let v = env("NEXUS_DEPTH_LOW_THRESHOLD")
    if v.len() == 0 { return 20 }
    let mut n = 20
    try { n = to_int(v) } catch e { n = 20 }
    if n < 0 { return 20 }
    return n
}

fn _adaptive_trend_vote(totals_hist: [int]) -> int {
    // 반환: +1 promote, -1 demote, 0 hold.
    // totals_hist 가 < 2 이면 vote 불가 → 0.
    let n = len(totals_hist)
    if n < 2 { return 0 }
    let prev = totals_hist[n - 2]
    let cur  = totals_hist[n - 1]
    let delta = cur - prev
    // prev == 0 특수: delta > 0 이면 promote 후보, delta <=0 이면 demote.
    if prev <= 0 {
        if delta > 0 { return 1 }
        return -1
    }
    let hi = _adaptive_trend_high_pct()
    let lo = _adaptive_trend_low_pct()
    if hi <= lo { return 0 }  // invalid config → hold
    // delta * 100 vs prev * hi  (정수 비교 — float 회피)
    let d100 = delta * 100
    if d100 > prev * hi { return 1 }
    if d100 < prev * lo { return -1 }
    return 0
}

fn _adaptive_trend_apply(plan: [int], direction: int) -> [int] {
    // direction: +1 → enabled stage depth +1, -1 → -1, 0 → no-op. floor/ceil clamp.
    if direction == 0 { return plan }
    let mut out: [int] = []
    let mut i = 0
    while i < len(plan) {
        let v = plan[i]
        if v > 0 {
            let nv = v + direction
            let cv = _clamp_depth(if nv < 1 { 1 } else { nv }, i)
            out = out + [cv]
        } else {
            out = out + [0]
        }
        i = i + 1
    }
    return out
}

fn _adaptive_trend_adjust(plan: [int], totals_hist: [int], vote_hist: [int], round: int) -> [int] {
    // 진입점 — cmd_drill round loop 에서 호출.
    //   plan        : 현재 cur_plan (E2 adjust 직후)
    //   totals_hist : 과거 round 의 total (이번 round 아직 미 append — 즉 N-1 길이)
    //   vote_hist   : 과거 round 의 vote (마찬가지로 N-1)
    //   round       : 현재 round idx (1-based)
    // 반환: 조정된 plan.
    //
    // Hysteresis 정의: vote_hist 의 "마지막 2 vote" 가 동일 방향(+1 or -1) 일 때만 전환.
    //   round N 진입 시점에 vote_hist 는 r2..r(N-1) 의 vote (총 N-2 entries).
    //   → hysteresis-2 충족 최소 조건 N-2 >= 2 → round >= 4.
    //   round 2/3 는 history 부족 → no-op.
    //
    //   주의 (설계 pitfall): cur-round 에서 새 vote 를 계산해 vote_hist[-1] 와 비교하면,
    //   두 값 모두 동일 totals_hist 로부터 계산되어 hysteresis 가 무력화됨 (유효 윈도우=1).
    //   따라서 전환 조건은 반드시 "이미 기록된 2 votes 의 일치" 여야 함.
    if !_adaptive_trend_enabled() { return plan }
    if round <= 3 { return plan }
    let vh = len(vote_hist)
    if vh < 2 { return plan }
    let v_last = vote_hist[vh - 1]
    let v_prev = vote_hist[vh - 2]
    if v_last == 0 { return plan }
    if v_last != v_prev { return plan }
    let adjusted = _adaptive_trend_apply(plan, v_last)
    let dir_str = if v_last > 0 { "promote+1" } else { "demote-1" }
    eprintln("NEXUS_DRILL_TREND {\"round\":" + to_string(round)
        + ",\"vote\":" + to_string(v_last)
        + ",\"dir\":\"" + dir_str + "\""
        + ",\"before\":" + _plan_json(plan)
        + ",\"after\":" + _plan_json(adjusted) + "}")
    return adjusted
}

fn _adaptive_trend_record_vote(vote_hist: [int], totals_hist: [int]) -> [int] {
    // 매 round 끝에서 vote 계산 결과를 append — hysteresis 윈도우 유지.
    let v = _adaptive_trend_vote(totals_hist)
    return vote_hist + [v]
}

// ─── E12 seed-batch helpers (2026-04-21) ───
// SSOT: shared/config/drill.json .seed_batch
// Sequential (parallel 은 engine_daemon 의존 — E12 범위 밖).
// CLI: --seeds seed1,seed2 또는 --seeds-file path.txt (1 seed/line, '#' 주석 허용).
fn _seed_batch_hash(seed: str) -> str {
    // 가벼운 deterministic 8-char hex — ndjson seed_hash 필드용.
    // openssl/sha256/sha1 중 접근 가능한 것 사용. 전부 실패 시 length 기반 fallback.
    let q = shell_quote(seed)
    let h1 = exec("printf '%s' " + q + " | openssl dgst -sha1 2>/dev/null | awk '{print $NF}' | cut -c1-8").trim()
    if h1.len() == 8 { return h1 }
    let h2 = exec("printf '%s' " + q + " | (sha1sum 2>/dev/null || shasum 2>/dev/null) | cut -c1-8").trim()
    if h2.len() == 8 { return h2 }
    // fallback: seed length + first 4 char codes (매우 약한 해시지만 non-empty 보장)
    let n = seed.len()
    return "l" + to_string(n) + "x"
}

fn _seed_batch_load(flag_val: str, file_path: str) -> [str] {
    // flag_val: "seed1,seed2,seed3" comma-separated (우선)
    // file_path: 1 seed per line (# 주석 및 빈 줄 무시)
    // 둘 다 비어있으면 [] 반환.
    let mut out: [str] = []
    if flag_val.len() > 0 {
        // comma split (수동 — hexa .split 부재)
        let mut buf = ""
        let mut i = 0
        let n = flag_val.len()
        while i < n {
            let ch = flag_val.substring(i, i + 1)
            if ch == "," {
                let t = buf.trim()
                if t.len() > 0 { out = out + [t] }
                buf = ""
            } else {
                buf = buf + ch
            }
            i = i + 1
        }
        let tail = buf.trim()
        if tail.len() > 0 { out = out + [tail] }
        return out
    }
    if file_path.len() > 0 {
        // exec cat + line split on \n (수동)
        let raw = exec("cat " + shell_quote(file_path) + " 2>/dev/null")
        let mut buf2 = ""
        let mut j = 0
        let m = raw.len()
        while j < m {
            let c = raw.substring(j, j + 1)
            if c == "\n" {
                let ln = buf2.trim()
                if ln.len() > 0 && ln.substring(0, 1) != "#" { out = out + [ln] }
                buf2 = ""
            } else {
                buf2 = buf2 + c
            }
            j = j + 1
        }
        let tail2 = buf2.trim()
        if tail2.len() > 0 && tail2.substring(0, 1) != "#" { out = out + [tail2] }
        return out
    }
    return out
}

fn _seed_batch_emit_summary(seed_count: int, total_abs: int, durations_ms: [i64]) -> void {
    // stderr JSON 1 line — batch 전체 summary.
    let mut ds = "["
    let mut i = 0
    while i < len(durations_ms) {
        if i > 0 { ds = ds + "," }
        ds = ds + to_string(durations_ms[i])
        i = i + 1
    }
    ds = ds + "]"
    let ts = exec("date +%s").trim()
    let line = "NEXUS_DRILL_BATCH {\"seed_count\":" + to_string(seed_count)
        + ",\"total_abs\":" + to_string(total_abs)
        + ",\"durations_ms\":" + ds
        + ",\"ts\":" + ts + "}"
    eprintln(line)
}

// ─── E5 depth trace NDJSON (2026-04-21) ───
fn _ndjson_emit(round: int, plan_planned: [int], plan_actual: [int], yields: [int], total: int, adaptive_reason: str, seed_hash: str) -> void {
    // append 1 line to /tmp/nexus_drill_depth.ndjson. schema v1.
    // E15 (2026-04-21): "parallel" field 추가 — env NEXUS_DRILL_STAGE_PARALLEL 활성 여부. schema backward-compat (optional key).
    // E12 (2026-04-21): "seed_hash" field 추가 — batch drill 에서 seed 별 분리 식별.
    let path = "/tmp/nexus_drill_depth.ndjson"
    let ts = exec("date +%s").trim()
    let par_flag = if _stage_parallel_enabled() { "true" } else { "false" }
    let sh = if seed_hash.len() > 0 { seed_hash } else { "-" }
    let line = "{\"ts\":" + ts
        + ",\"round\":" + to_string(round)
        + ",\"plan\":" + _plan_json(plan_planned)
        + ",\"actual\":" + _plan_json(plan_actual)
        + ",\"yield\":{\"smash\":" + to_string(yields[0])
          + ",\"free\":" + to_string(yields[1])
          + ",\"absolute\":" + to_string(yields[2])
          + ",\"meta_closure\":" + to_string(yields[3])
          + ",\"hyperarith\":" + to_string(yields[4])
          + ",\"resonance\":" + to_string(yields[5]) + "}"
        + ",\"total\":" + to_string(total)
        + ",\"parallel\":" + par_flag
        + ",\"seed_hash\":\"" + sh + "\""
        + ",\"adaptive_reason\":\"" + adaptive_reason.replace("\"", "'") + "\"}"
    // escape single quotes carefully for shell
    let safe_line = line.replace("'", "'\\''")
    let cmd = "printf '%s\\n' '" + safe_line + "' >> " + shell_quote(path)
    exec(cmd)
}

// ─── N (2026-04-21) Live Progress — NEXUS_DRILL_PROGRESS stage start/end JSON ───
// 긴 drill (수 분+) 에서 stage 진행 즉시성 확보. stderr JSON 1 line / event.
// event ∈ {start, end, abort}. stdout 불변 (stderr only).
// bypass: env NEXUS_DRILL_PROGRESS_OFF=1 → 아무것도 emit 하지 않음 (CI noise off).
// 총 cost: stage 당 2 JSON + 종료 summary 1 JSON.
fn _progress_emit(round: int, stage: str, event: str, elapsed_ms: int) -> void {
    if env("NEXUS_DRILL_PROGRESS_OFF") == "1" { return }
    let ts = exec("date +%s").trim()
    let line = "NEXUS_DRILL_PROGRESS {\"round\":" + to_string(round)
        + ",\"stage\":\"" + stage + "\""
        + ",\"event\":\"" + event + "\""
        + ",\"elapsed_ms\":" + to_string(elapsed_ms)
        + ",\"ts\":" + ts + "}"
    eprintln(line)
    // Ω-saturation cycle 6 (2026-04-25, nxs-20260425-002 Phase 1):
    //   stage end event 시 elapsed_ms history append → adaptive timeout 계산용.
    //   _stage_timeout_prefix() 의 hard-cap 180s 대체할 history-aware adaptive curve 산출 데이터.
    //   bypass: env NEXUS_DRILL_HISTORY_OFF=1.
    if event == "end" && elapsed_ms > 0 && env("NEXUS_DRILL_HISTORY_OFF") != "1" {
        let hist_line = "{\"ts\":" + ts + ",\"round\":" + to_string(round)
            + ",\"stage\":\"" + stage + "\""
            + ",\"elapsed_ms\":" + to_string(elapsed_ms) + "}\n"
        try { append_file(nexus_root() + "/state/drill_stage_elapsed_history.jsonl", hist_line) } catch e {}  // @allow-silent-catch
    }
}

fn _progress_now_ms() -> i64 {
    // ms epoch — linux 는 %s%N (ns), macOS 는 %s*1000 fallback.
    // ω-hexa-cont-7: pfs_now_ns() (portable_fs) handles BSD/GNU divergence internally;
    // residual length-check fallback retained for defense-in-depth (literal 'N' edge cases).
    let raw = pfs_now_ns()
    let mut v: i64 = 0
    try { v = to_int(raw) } catch e { v = 0 }
    if v > 1000000000000000 {
        // ns precision (linux) — 16+ digits. ms 로 축소.
        return v / 1000000
    }
    // macOS 또는 파싱 실패 — seconds * 1000
    let sec = exec("date +%s").trim()
    let mut s: i64 = 0
    try { s = to_int(sec) } catch e { s = 0 }
    return s * 1000
}

fn _progress_ms_diff(t0: i64, t1: i64) -> int {
    // i64 ms diff → int (음수/overflow 는 0 으로 clamp).
    let d = t1 - t0
    if d < 0 { return 0 }
    let mut out = 0
    try { out = to_int(to_string(d)) } catch e { out = 0 }
    return out
}

fn _progress_summary(total_abs: int, total_ms: i64) -> void {
    if env("NEXUS_DRILL_PROGRESS_OFF") == "1" { return }
    let ts = exec("date +%s").trim()
    let line = "NEXUS_DRILL_PROGRESS {\"round\":-1,\"stage\":\"drill\",\"event\":\"end\""
        + ",\"total_abs\":" + to_string(total_abs)
        + ",\"total_ms\":" + to_string(total_ms)
        + ",\"ts\":" + ts + "}"
    eprintln(line)
}

// ─── Validation layers A/B/D (2026-04-21) ───
// A: cross-round uniformity (축소 구현 — single-seed, round 간 stage-vector 동일성 감시)
// B: ghost probe — 1 extra round with gibberish seed, compare with real round-1
// D: stage-dead column — across N rounds, stage column 전부 0 감지
fn _ghost_seed() -> str {
    // schema: __NEXUS_GHOST_<urand_hex16>__ (40 chars total — seed-length guard 통과)
    let h = _urand_hex(12)
    return "__NEXUS_GHOST_" + h + "__xyz_placeholder_tag_not_math"
}

fn _validation_verdict(score: int) -> str {
    // thresholds from drill.json .validation.verdict_thresholds
    if score < 3 { return "PASS" }
    if score < 7 { return "SUSPICIOUS" }
    return "REJECT"
}

fn _emit_validation(signals: [str], score: int, recommendation: str) -> void {
    // NEXUS_DRILL_VALIDATION {verdict, score, signals[], recommendation}
    let verdict = _validation_verdict(score)
    let mut sig_join = ""
    let mut i = 0
    while i < len(signals) {
        if i > 0 { sig_join = sig_join + "," }
        sig_join = sig_join + signals[i]
        i = i + 1
    }
    let safe_rec = recommendation.replace("\"", "'")
    let j = "{\"verdict\":\"" + verdict + "\",\"score\":" + to_string(score)
        + ",\"signals\":[" + sig_join + "]"
        + ",\"recommendation\":\"" + safe_rec + "\"}"
    eprintln("NEXUS_DRILL_VALIDATION " + j)
}

fn _run_drill_validation(real_seed: str, nonce_base: str, totals_hist: [int], stage_matrix: [[int]], base_plan: [int], blow_core: str, hexa_bin: str, preset: str) -> void {
    // Validation layer A + B + D — drill 종료 시 1회 호출.
    //   A (축소): single-seed round 간 stage-vector 동일성 감시 — round 2+ 가 round 1 과 완전 동일 시 flag.
    //   B: ghost probe — 1 round 동안 gibberish seed 병행 smash, real round-1 total 과 동일 시 flag.
    //   D: stage-dead column — stage_matrix 에서 각 stage 전 round 0 이면 flag (enabled 한 stage 만).
    //   점수 합산 → verdict (drill.json .validation.verdict_thresholds): <3 PASS, [3,6] SUSPICIOUS, >=7 REJECT.
    let mut score = 0
    let mut signals: [str] = []
    let mut rec = ""

    let nr = len(totals_hist)
    let ns = len(stage_matrix)

    // Layer A — round uniformity (축소)
    if nr >= 2 {
        let mut uniform = true
        let r0 = stage_matrix[0]
        let mut i = 1
        while i < ns {
            let ri = stage_matrix[i]
            let mut eq = true
            let mut k = 0
            while k < 6 {
                if k < len(r0) && k < len(ri) {
                    if r0[k] != ri[k] { eq = false; break }
                }
                k = k + 1
            }
            if !eq { uniform = false; break }
            i = i + 1
        }
        if uniform {
            score = score + 3  // weight
            signals = signals + ["{\"kind\":\"uniform_result\",\"rounds\":" + to_string(nr) + ",\"unique_vectors\":1}"]
            rec = rec + "A: round 간 stage-vector 동일 — salt 미반영 의심; "
        }
    }

    // Layer B — ghost probe (preset=probe 는 skip, 시간 절약)
    if preset != "probe" && nr >= 1 {
        let ghost = _ghost_seed()
        let gs_cmd = shell_quote(hexa_bin) + " run " + shell_quote(blow_core) + " " + shell_quote(ghost) + " 1 2>&1"
        let gs_out = exec(gs_cmd)
        let gs_n = _count_discoveries(gs_out)
        let real_r1 = if ns >= 1 && len(stage_matrix[0]) > 0 { stage_matrix[0][0] } else { 0 }
        if gs_n > 0 && gs_n == real_r1 {
            score = score + 5  // weight
            signals = signals + ["{\"kind\":\"ghost_match\",\"real\":" + to_string(real_r1) + ",\"ghost\":" + to_string(gs_n) + "}"]
            rec = rec + "B: ghost seed 와 real seed 동일 smash yield — engine seed-insensitive; "
        }
        eprintln("  [validation B/ghost] real_r1_smash=" + to_string(real_r1) + " ghost_smash=" + to_string(gs_n))
    }

    // Layer D — stage-dead column (enabled stages 중 전부 0 인 stage flag)
    let mut d_i = 0
    while d_i < 6 {
        if base_plan[d_i] > 0 {
            let mut all_zero = true
            let mut rr = 0
            while rr < ns {
                if d_i < len(stage_matrix[rr]) {
                    if stage_matrix[rr][d_i] > 0 { all_zero = false; break }
                }
                rr = rr + 1
            }
            if all_zero && ns >= 1 {
                score = score + 2  // weight per dead stage
                signals = signals + ["{\"kind\":\"stage_dead\",\"stage\":\"" + _stage_name(d_i) + "\",\"column_zeros\":" + to_string(ns) + "}"]
                rec = rec + "D: " + _stage_name(d_i) + " 전 round 0 yield — engine 또는 parser 문제; "
            }
        }
        d_i = d_i + 1
    }

    if rec.len() == 0 { rec = "signals within tolerance — drill 결과 정상" }
    _emit_validation(signals, score, rec)
}

// ─── E9 drill checkpoint / resume (2026-04-21, fast-resume 2026-04-21) ───
// round N 종료 시 state JSON flush → 다음 실행 시 seed-hash 매치로 fast-resume.
// state file: <dir>/nexus_drill_cp_<seed_hash12>.json  (기본 dir=/tmp/nexus_checkpoint)
// schema: {"seed":"...","seed_hash":"...","round_done":N,"total":M,"yields_hist":[[...]],"plan":[...],"ts":T}
// 기본 동작: --resume ON (SIGKILL/OOM/jetsam/kill -9 후 재시작 → round 0 중복 회피).
// opt-out: --fresh — checkpoint 무시 + 기존 파일 삭제 후 legacy fresh-run.
// stale: ts 가 현재 시각 기준 7일 (604800 s) 이상이면 자동 무시 (stale skip emit).
// seed-hash 충돌 회피: 12-hex dual-FNV1a (정/역방향 salt) = 2^48 (≈281 T) space.
// resume 성공 시 NEXUS_RESUME {seed_hash, skipped_rounds, resumed_from, total} 1 line stderr.
fn _checkpoint_hex8(v: i64) -> str {
    // i64 → 8-char lowercase hex (low 32 bits).
    let digits = "0123456789abcdef"
    let mut x = v & 4294967295
    let mut out = ""
    let mut i = 0
    while i < 8 {
        let nib = x & 15
        out = digits.substring(nib, nib + 1) + out
        x = x / 16
        i = i + 1
    }
    return out
}

fn _checkpoint_fnv_hex12(seed: str) -> str {
    // FNV-1a 32-bit 2회 (정방향/역방향) 혼합 → 12-hex prefix. i64 mask 로 u32 semantics.
    // hexa-lang u64 부재 — 64-bit FNV 오버플로우 회피. 충돌 공간 은 12-hex = 2^48.
    let n = seed.len()
    let mut h1: i64 = 2166136261
    let mut h2: i64 = 2166136261
    let prime: i64 = 16777619
    let mask: i64 = 4294967295
    let mut i = 0
    while i < n {
        let cc = char_code(seed, i)
        h1 = (h1 ^ cc) * prime
        h1 = h1 & mask
        let cc2 = char_code(seed, n - 1 - i)
        h2 = (h2 ^ cc2) * prime
        h2 = h2 & mask
        i = i + 1
    }
    let hx1 = _checkpoint_hex8(h1)
    let hx2 = _checkpoint_hex8(h2)
    return hx1.substring(2, 8) + hx2.substring(2, 8)
}

fn _checkpoint_dir_default() -> str {
    // 기본 체크포인트 디렉터리 — env NEXUS_CHECKPOINT_DIR 우선, 없으면 /tmp/nexus_checkpoint.
    // /tmp 하위 서브디렉터리는 fast-resume 파일이 OS tmp-sweep 과 함께 사라지지만,
    // 7일 stale 정책과 round-level save 주기를 고려하면 실용상 충분하다.
    let e = env("NEXUS_CHECKPOINT_DIR")
    if e.len() > 0 { return e }
    return "/tmp/nexus_checkpoint"
}

fn _checkpoint_ensure_dir(dir: str) -> void {
    // mkdir -p — 존재 시 no-op. 경로 미존재 시 save 가 조용히 실패하는 것을 방지.
    let q = shell_quote(dir)
    exec("mkdir -p " + q + " 2>/dev/null")
}

fn _checkpoint_path(seed: str, dir: str) -> str {
    let d = if dir.len() > 0 { dir } else { _checkpoint_dir_default() }
    let h = _checkpoint_fnv_hex12(seed)
    return d + "/nexus_drill_cp_" + h + ".json"
}

fn _checkpoint_stale_age_sec() -> i64 {
    // 7일 — env NEXUS_CHECKPOINT_STALE_SEC 로 오버라이드 가능 (테스트용).
    let e = env("NEXUS_CHECKPOINT_STALE_SEC")
    if e.len() > 0 {
        let mut v: i64 = 0
        try { v = to_int(e) } catch e2 {}
        if v > 0 { return v }
    }
    return 604800
}

fn _checkpoint_yields_json(yields_hist: [[int]]) -> str {
    let mut out = "["
    let mut i = 0
    while i < len(yields_hist) {
        if i > 0 { out = out + "," }
        let r = yields_hist[i]
        let mut inner = "["
        let mut k = 0
        while k < len(r) {
            if k > 0 { inner = inner + "," }
            inner = inner + to_string(r[k])
            k = k + 1
        }
        inner = inner + "]"
        out = out + inner
        i = i + 1
    }
    return out + "]"
}

fn _checkpoint_plan_flat_json(plan: [int]) -> str {
    let mut out = "["
    let mut i = 0
    while i < len(plan) {
        if i > 0 { out = out + "," }
        out = out + to_string(plan[i])
        i = i + 1
    }
    return out + "]"
}

fn _checkpoint_save(seed: str, round: int, total: int, yields_hist: [[int]], plan: [int], dir: str) -> void {
    // atomic write: tmpfile + mv -f. 같은 seed → 같은 path. 디렉터리 자동 생성.
    let d = if dir.len() > 0 { dir } else { _checkpoint_dir_default() }
    _checkpoint_ensure_dir(d)
    let path = _checkpoint_path(seed, d)
    let seed_esc = seed.replace("\\", "\\\\").replace("\"", "\\\"")
    let ts = exec("date +%s").trim()
    let seed_hash = _checkpoint_fnv_hex12(seed)
    let json = "{\"seed\":\"" + seed_esc + "\""
        + ",\"seed_hash\":\"" + seed_hash + "\""
        + ",\"round_done\":" + to_string(round)
        + ",\"total\":" + to_string(total)
        + ",\"yields_hist\":" + _checkpoint_yields_json(yields_hist)
        + ",\"plan\":" + _checkpoint_plan_flat_json(plan)
        + ",\"ts\":" + ts + "}"
    let safe = json.replace("'", "'\\''")
    let q_path = shell_quote(path)
    let q_tmp  = shell_quote(path + ".tmp")
    let cmd = "printf '%s\\n' '" + safe + "' > " + q_tmp + " && mv -f " + q_tmp + " " + q_path
    exec(cmd)
    eprintln("NEXUS_DRILL_CHECKPOINT {\"op\":\"save\",\"seed_hash\":\"" + seed_hash + "\",\"round\":" + to_string(round) + ",\"path\":\"" + path + "\"}")
}

fn _checkpoint_load(seed: str, dir: str) -> [int] {
    // 반환: [round_done, total, y00..y05, y10..y15, ...] flat. empty = null (not found / corrupt / stale / hash-mismatch).
    // stale: ts 가 _checkpoint_stale_age_sec() 이상 오래됨 → skip + NEXUS_DRILL_CHECKPOINT stale emit.
    // hash-mismatch: 내부 seed_hash 필드가 path 기반 계산값과 다르면 skip (충돌 방어).
    let d = if dir.len() > 0 { dir } else { _checkpoint_dir_default() }
    let path = _checkpoint_path(seed, d)
    let q_path = shell_quote(path)
    let exists = exec("[ -f " + q_path + " ] && echo y || echo n").trim()
    if exists != "y" { return [] }
    let raw = exec("cat " + q_path + " 2>/dev/null").trim()
    if raw.len() == 0 { return [] }
    let r_done = _extract_int_after(raw, "\"round_done\":")
    let tot = _extract_int_after(raw, "\"total\":")
    if r_done <= 0 { return [] }
    // stale 검사 — ts 필드 기반. ts 0/누락이면 legacy (과거 저장분) 으로 간주하여 fresh 처리.
    let ts = _extract_int_after(raw, "\"ts\":")
    let now_s = exec("date +%s").trim()
    let mut now_i: i64 = 0
    try { now_i = to_int(now_s) } catch e {}
    let stale_age = _checkpoint_stale_age_sec()
    let expected_hash = _checkpoint_fnv_hex12(seed)
    if ts > 0 && now_i > 0 && (now_i - ts) > stale_age {
        eprintln("NEXUS_DRILL_CHECKPOINT {\"op\":\"stale\",\"seed_hash\":\"" + expected_hash
            + "\",\"age_sec\":" + to_string(now_i - ts) + ",\"threshold_sec\":" + to_string(stale_age)
            + ",\"path\":\"" + path + "\",\"action\":\"skip_fresh\"}")
        // stale 파일은 자동 제거하여 다음 실행 시 누적 방지.
        exec("rm -f " + q_path)
        return []
    }
    // seed_hash 교차검증 — 필드 존재 시 path 계산값과 일치해야 함.
    let hash_marker = "\"seed_hash\":\""
    let hi = str_find(raw, hash_marker)
    if hi >= 0 {
        let hstart = hi + hash_marker.len()
        let mut he = hstart
        let nraw = raw.len()
        while he < nraw {
            let cc = char_code(raw, he)
            if cc == 34 { break }
            he = he + 1
        }
        if he > hstart {
            let stored = raw.substring(hstart, he)
            if stored != expected_hash {
                eprintln("NEXUS_DRILL_CHECKPOINT {\"op\":\"hash_mismatch\",\"expected\":\"" + expected_hash
                    + "\",\"stored\":\"" + stored + "\",\"path\":\"" + path + "\",\"action\":\"skip_fresh\"}")
                return []
            }
        }
    }
    let mut out: [int] = [r_done, tot]
    // yields_hist flat 파싱 — 외부 `[` 시작부터 depth=0 복귀까지 digit 누적.
    let yh_marker = "\"yields_hist\":"
    let idx0 = str_find(raw, yh_marker)
    if idx0 < 0 { return out }
    let start = idx0 + yh_marker.len()
    let n = raw.len()
    let mut i = start
    let mut depth = 0
    let mut cur_num = ""
    while i < n {
        let cc = char_code(raw, i)
        if cc == 91 {
            depth = depth + 1
        } else if cc == 93 {
            if cur_num.len() > 0 {
                let mut v = 0
                try { v = to_int(cur_num) } catch e {}
                out = out + [v]
                cur_num = ""
            }
            depth = depth - 1
            if depth == 0 { break }
        } else if cc == 44 {
            if cur_num.len() > 0 {
                let mut v = 0
                try { v = to_int(cur_num) } catch e {}
                out = out + [v]
                cur_num = ""
            }
        } else if cc >= 48 && cc <= 57 {
            cur_num = cur_num + raw.substring(i, i + 1)
        } else if cc == 45 {
            cur_num = cur_num + "-"
        }
        i = i + 1
    }
    return out
}

fn _checkpoint_clear(seed: str, dir: str) -> void {
    let d = if dir.len() > 0 { dir } else { _checkpoint_dir_default() }
    let path = _checkpoint_path(seed, d)
    let q_path = shell_quote(path)
    exec("rm -f " + q_path + " " + shell_quote(path + ".tmp"))
}


// ─── E6 failure-mode recovery (2026-04-21) ─── 5 modes: runaway / oscillate / imbalance / OOM / SIGINT
// SSOT: shared/convergence/drill_stability.convergence C3 failure modes
//   - adaptive 폭주 (depth=max 3 round 연속) → cap 절반
//   - oscillate (high-freq +/-1) → hysteresis gate 3 round cooldown
//   - stage-imbalance (1 stage 점유 과도) → floor 보장
//   - OOM-imminent (RSS > cap * 0.80) → depth-- + NDJSON flush
//   - SIGINT → 현 round 완주 후 graceful abort flag
// 충돌 회피: prefix _recovery_*, 기존 _stage_pipeline_* / _anti_replay_lru_* / _run_stage_parallel* 건드리지 않음.
// hook: cmd_drill round loop 말미 (NDJSON emit 이후) 5 check 순차 수행. 다음 round 에 영향.

fn _recovery_adaptive_runaway(depth_hist: [[int]]) -> bool {
    // adaptive 폭주: plan 이 _stage_max() 의 enabled stage 전체에서 max 값과 같은 round 가 3 연속.
    // depth_hist[i] = round i 의 cur_plan (6-slot). 마지막 3 원소 검사.
    let h = len(depth_hist)
    if h < 3 { return false }
    let maxs = _stage_max()
    let mut all_max_count = 0
    let mut k = h - 3
    while k < h {
        let p = depth_hist[k]
        if len(p) < 6 { return false }
        let mut at_max = true
        let mut i = 0
        while i < 6 {
            // enabled stage (plan[i] > 0) 만 max 비교. disabled(0) 은 skip.
            if p[i] > 0 {
                if p[i] < maxs[i] { at_max = false }
            }
            i = i + 1
        }
        if at_max { all_max_count = all_max_count + 1 }
        k = k + 1
    }
    return all_max_count == 3
}

fn _recovery_halve_plan(plan: [int]) -> [int] {
    // cap 절반 — enabled stage 의 depth 를 /2, min 으로 clamp.
    let mut out: [int] = []
    let mut i = 0
    while i < len(plan) {
        let v = plan[i]
        if v > 0 {
            let hv = v / 2
            out = out + [_clamp_depth(if hv < 1 { 1 } else { hv }, i)]
        } else {
            out = out + [0]
        }
        i = i + 1
    }
    return out
}

fn _recovery_oscillate(depth_hist: [[int]]) -> bool {
    // 최근 5 round smash slot 이 +/-1 진동 (a,b,a,b,a with |a-b|==1).
    // smash (stage 0) 가 adaptive 조정 주 대상 — 진동 감지 핵심 slot.
    let h = len(depth_hist)
    if h < 5 { return false }
    let mut seq: [int] = []
    let mut k = h - 5
    while k < h {
        let p = depth_hist[k]
        if len(p) < 1 { return false }
        seq = seq + [p[0]]
        k = k + 1
    }
    // 패턴: seq[0]==seq[2]==seq[4], seq[1]==seq[3], |seq[0]-seq[1]|==1
    if seq[0] != seq[2] { return false }
    if seq[2] != seq[4] { return false }
    if seq[1] != seq[3] { return false }
    let diff = if seq[0] > seq[1] { seq[0] - seq[1] } else { seq[1] - seq[0] }
    return diff == 1
}

fn _recovery_stage_imbalance(yield_hist: [[int]]) -> [int] {
    // 직전 round yields 에서 1 stage 가 total 의 >80% 점유면 adj (floor-bump mask) 반환.
    // imbalance 없으면 [0,0,0,0,0,0].
    let h = len(yield_hist)
    let mut adj: [int] = [0, 0, 0, 0, 0, 0]
    if h < 1 { return adj }
    let y = yield_hist[h - 1]
    if len(y) < 6 { return adj }
    let mut total = 0
    let mut i = 0
    while i < 6 {
        total = total + y[i]
        i = i + 1
    }
    if total < 10 { return adj }  // 너무 작으면 의미 없음
    // imbalance: yield[i] * 100 > total * 80 (정수 비교 — string 경계 회피)
    let mut j = 0
    let mut dominant = -1
    while j < 6 {
        if y[j] * 100 > total * 80 { dominant = j }
        j = j + 1
    }
    if dominant < 0 { return adj }
    // adj: dominant 외 slot 을 1(bump-marker) 로 mark — floor=2 로 올림.
    let mut k = 0
    while k < 6 {
        if k != dominant { adj = _plan_set(adj, k, 1) }
        k = k + 1
    }
    return adj
}

fn _recovery_apply_floor(plan: [int], adj: [int]) -> [int] {
    // adj[i]==1 인 slot 을 floor=2 로 bump (plan[i]==1 만 올림; disabled=0 유지; 2 이상 유지).
    let mut out: [int] = []
    let mut i = 0
    while i < len(plan) {
        let v = plan[i]
        let a = if i < len(adj) { adj[i] } else { 0 }
        if a == 1 && v > 0 && v < 2 {
            out = out + [_clamp_depth(2, i)]
        } else {
            out = out + [v]
        }
        i = i + 1
    }
    return out
}

fn _recovery_rss_cap_mb() -> int {
    // NEXUS_RSS_CAP_MB env 우선, 없으면 HEXA_STAGE0_RSS_CAP_KB (KB→MB), 없으면 4096 default.
    let v = env("NEXUS_RSS_CAP_MB")
    if v.len() > 0 {
        let mut n = 0
        try { n = to_int(v) } catch e { n = 0 }
        if n > 0 { return n }
    }
    let vk = env("HEXA_STAGE0_RSS_CAP_KB")
    if vk.len() > 0 {
        let mut k = 0
        try { k = to_int(vk) } catch e { k = 0 }
        if k > 0 { return k / 1024 }
    }
    return 4096
}

fn _recovery_current_rss_mb() -> int {
    // Linux: /proc/self/status VmRSS (kB) → MB. Darwin: ps -o rss= -p $$ (kB) → MB.
    // 두 경로 모두 실패 시 0 반환 (false negative — recovery 미발동).
    let linux_cmd = "awk '/^VmRSS:/ {print $2; exit}' /proc/self/status 2>/dev/null"
    let mut kb = 0
    let raw_linux = exec(linux_cmd).trim()
    if raw_linux.len() > 0 {
        try { kb = to_int(raw_linux) } catch e { kb = 0 }
    }
    if kb <= 0 {
        let raw_mac = exec("ps -o rss= -p $$ 2>/dev/null").trim()
        if raw_mac.len() > 0 {
            try { kb = to_int(raw_mac) } catch e { kb = 0 }
        }
    }
    if kb <= 0 { return 0 }
    return kb / 1024
}

fn _recovery_oom_imminent() -> bool {
    // RSS > cap * 0.80 판정. 정수 연산 (cap*80)/100.
    let cap = _recovery_rss_cap_mb()
    if cap <= 0 { return false }
    let cur = _recovery_current_rss_mb()
    if cur <= 0 { return false }
    let threshold = (cap * 80) / 100
    return cur > threshold
}

fn _recovery_oom_depth_decrement(plan: [int]) -> [int] {
    // depth-- per enabled stage (floor=min).
    let mut out: [int] = []
    let mut i = 0
    while i < len(plan) {
        let v = plan[i]
        if v > 1 { out = out + [_clamp_depth(v - 1, i)] }
        else { out = out + [v] }
        i = i + 1
    }
    return out
}

fn _recovery_ndjson_flush() -> void {
    // checkpoint flush — /tmp/nexus_drill_depth.ndjson 에 sync marker 추가.
    // hexa fs sync 빌트인 없음 → shell sync 실행 (OOM 임박 시 disk 손실 방어).
    exec("sync 2>/dev/null || true")
}

fn _recovery_sigint_flag_path() -> str {
    // 외부 handler (shell wrapper 또는 user) 가 touch 할 수 있는 flag 파일.
    // SSOT: /tmp/nexus_drill_sigint_<pid>.flag
    let pid = exec("echo $$").trim()
    let safe_pid = if pid.len() == 0 { "0" } else { pid }
    return "/tmp/nexus_drill_sigint_" + safe_pid + ".flag"
}

fn _recovery_sigint_install() -> void {
    // hexa 에는 signal() 빌트인이 없음 — shell trap 으로 flag 파일 touch.
    // drill 은 매 round 종료 후 flag 파일을 검사하여 graceful exit. drill 시작 1회 호출.
    // (exec() subshell 은 휘발성이므로 user 가 직접 touch 해도 동일하게 동작 — 이중 경로.)
    // E12-B (2026-04-21): 배치 모드에서 이미 install 완료이면 중복 exec 생략.
    if _sigint_installed { return }
    let flag = _recovery_sigint_flag_path()
    let cmd = "trap 'touch " + shell_quote(flag) + "' INT TERM 2>/dev/null || true"
    exec(cmd)
    _sigint_installed = true
}

fn _recovery_sigint_handler() -> bool {
    // flag 파일 존재 여부 — drill 시작 시 install. 외부 SIGINT 로 touch 되면 true.
    let flag = _recovery_sigint_flag_path()
    let chk = exec("[ -f " + shell_quote(flag) + " ] && echo y || echo n").trim()
    return chk == "y"
}

fn _recovery_sigint_cleanup() -> void {
    // 종료 시 flag 파일 제거 (남겨두면 다음 drill 이 즉시 abort).
    let flag = _recovery_sigint_flag_path()
    exec("rm -f " + shell_quote(flag) + " 2>/dev/null || true")
}

fn _recovery_emit(mode: str, action: str, round: int) -> void {
    // 단일 stderr NEXUS_DRILL_RECOVERY JSON emit.
    eprintln("NEXUS_DRILL_RECOVERY {\"mode\":\"" + mode + "\",\"action\":\"" + action + "\",\"round\":" + to_string(round) + "}")
}

// ─── Ω-saturation cycle 13 hexa native metric hook (2026-04-25) ───
// composite_v3_prime ≥ 0.9 paper_trigger 통과 시 publication 신호 emit.
// drill / omega 종료 시 자동 호출. bypass: NEXUS_OMEGA_METRICS_OFF=1.
// hexa.real direct exec — resolver 우회 (remote routing 으로 file path mismatch 방지).
fn _omega_metric_hook(context: str) -> void {
    if env("NEXUS_OMEGA_METRICS_OFF") == "1" { return }
    let real_bin_env = env("HEXA_REAL")
    let bin = if real_bin_env != "" { real_bin_env } else { "/Users/ghost/core/hexa-lang/build/hexa.real" }
    let chk_bin = exec("[ -x " + shell_quote(bin) + " ] && echo y || echo n").trim()
    if chk_bin != "y" { return } // silent skip if hexa.real missing
    let metric_tool = nexus_root() + "/tool/nxs_002_omega_metrics.hexa"
    let chk_tool = exec("[ -f " + shell_quote(metric_tool) + " ] && echo y || echo n").trim()
    if chk_tool != "y" { return }
    let cmd = shell_quote(bin) + " run " + shell_quote(metric_tool) + " 2>/dev/null"
    let mut out: str = ""
    try { out = exec(cmd).trim() } catch e { return } // @allow-silent-catch
    if out.len() == 0 { return }
    eprintln("NEXUS_OMEGA_METRIC {\"context\":\"" + context + "\",\"metric\":" + out + "}")
}

fn cmd_drill(seed: str, max_rounds: str, engine_flag: str, preset: str, master_depth: str, per_stage_depths: [int], adaptive_flag: bool, resume_flag: bool, checkpoint_dir: str, problem: str, speculate_flag: str) -> void {
    // 단일 명령어 — smash → free → absolute → meta-closure → hyperarithmetic → resonance (Mk.IX 6-stage)
    // Mk.X: stage 6 (transcendental_closure via mkx_engine.hexa sidecar) 추가 — 사이드카, L0 미수정.
    // 고갈(absorption=0) 까지 반복
    // D2 가드 (2026-04-20): 빈/짧음/길이초과/placeholder 단독 fail-fast (silent reject 차단)
    // E1 (2026-04-21): preset=fast|probe 는 smoke 전용 → 짧은 seed 허용 (≥10 chars).
    // Ω-saturation cycle 5 (2026-04-25, nxs-20260425-001 Phase 3 진단):
    //   cmd_drill 진입 emit — anti_hub env 가 자식 process 까지 propagate 됐는지 확인용.
    //   - env_active="1" + env_threshold=실값 → main 의 setenv 가 inherit 됨, blowup.hexa 의
    //     graph_append_edge guard 가 활성화되어야 함.
    //   - env_active="" → main dispatch 의 setenv 가 child exec 으로 forward 안 됨 (hexa_remote
    //     SSH env stripping 가능성). cycle 6 에서 hexa_remote env forward 추가 필요.
    let _ah_env = env("NEXUS_DRILL_ANTI_HUB")
    let _ah_th_env = env("NEXUS_DRILL_ANTI_HUB_THRESHOLD")
    // cycle 15 (2026-04-25, nxs-20260425-002): adaptive timeout 상태 같이 emit.
    //   sample stage 의 _adaptive_stage_timeout_sec 호출 결과 → history p95 × 1.5
    //   적용 여부 직접 확인. NEXUS_DRILL_TIMEOUT_ADAPTIVE=1 일 때만 의미.
    let _adapt_env = env("NEXUS_DRILL_TIMEOUT_ADAPTIVE")
    let mut _smash_to: i64 = 180
    if _adapt_env == "1" { _smash_to = _adaptive_stage_timeout_sec("smash") }
    eprintln("NEXUS_DRILL_ANTI_HUB_TRACE {\"cmd_drill_entry\":true,\"env_active\":\"" + _ah_env + "\",\"env_threshold\":\"" + _ah_th_env + "\",\"adaptive_env\":\"" + _adapt_env + "\",\"smash_timeout_sec\":" + to_string(_smash_to) + "}")
    // cycle 36 (2026-04-25, nxs-20260425-003 Phase 1): PSI threshold default 조정.
    //   hexa_remote 의 small class default = 70 — 평소 host load 77~92% 보다 엄격.
    //   본 세션 cycle 13 발견 → 모든 host reject → docker fallback → drill_zero_yield.
    //   해결: cmd_drill 진입 시 HEXA_REMOTE_PSI_REJECT_PCT default 85 set (env unset 일 때만).
    //   user 가 explicit set 했으면 그대로. setenv try-catch (cycle 11 hetzner setenv 미정의 우회).
    let _psi_env = env("HEXA_REMOTE_PSI_REJECT_PCT")
    if _psi_env == "" {
        try { setenv("HEXA_REMOTE_PSI_REJECT_PCT", "85") } catch e {}  // @allow-silent-catch
        eprintln("NEXUS_DRILL_PSI_DEFAULT {\"applied\":85,\"reason\":\"평소 host load 77~92% 보다 엄격한 default 70 우회 (nxs-20260425-003 Phase 1)\",\"override_env\":\"HEXA_REMOTE_PSI_REJECT_PCT\"}")
    } else {
        eprintln("NEXUS_DRILL_PSI_DEFAULT {\"user_set\":\"" + _psi_env + "\",\"skipped_default\":true}")
    }
    let mut _seed_t = seed.trim()
    let _preset = if preset.len() > 0 { preset.to_lower() } else { "" }
    let _is_smoke_preset = _preset == "fast" || _preset == "probe"
    let _min_seed_len = if _is_smoke_preset { 10 } else { 30 }
    if _seed_t.len() == 0 {
        eprintln("nexus drill: --seed 필수 — 비어있음. 예: nexus drill --seed \"P=NP barrier\"")
        return
    }
    if _seed_t.len() < _min_seed_len {
        eprintln("nexus drill: --seed 너무 짧음 (" + to_string(_seed_t.len()) + "자 < " + to_string(_min_seed_len) + ") — 구체적 문제 진술 필요. 예: 'Riemann zeta zero spacing GUE deviation'")
        return
    }
    if _seed_t.len() > 200 {
        // D2-soft (2026-04-25): hard reject → auto-truncate + WARN (drill 계속 진행).
        //   boundary 우선순위: 문장끝(. ? !) > 공백/탭/줄바꿈 > hard cut @200.
        //   다중 태스크 의심(길이 폭주)은 stderr 가이드로 parallel subagent 분할 권고.
        let _orig_len = _seed_t.len()
        let mut _last_sent: i64 = -1
        let mut _last_space: i64 = -1
        let mut _ti: i64 = 0
        while _ti < 200 {
            let _tc = _seed_t.substring(_ti, _ti + 1)
            if _tc == " " || _tc == "\t" || _tc == "\n" {
                _last_space = _ti
                if _ti > 0 {
                    let _prev = _seed_t.substring(_ti - 1, _ti)
                    if _prev == "." || _prev == "?" || _prev == "!" { _last_sent = _ti }
                }
            }
            _ti = _ti + 1
        }
        let mut _cut: i64 = 200
        let mut _boundary = "hard"
        if _last_sent > 80 {
            _cut = _last_sent
            _boundary = "sentence"
        } else if _last_space > 80 {
            _cut = _last_space
            _boundary = "word"
        }
        let _truncated = _seed_t.substring(0, _cut).trim()
        eprintln("nexus drill: WARN --seed 길이 " + to_string(_orig_len) + " > 200 — " + to_string(_truncated.len()) + "자로 자동 절단 (boundary=" + _boundary + "). 다중 태스크면 parallel subagent 분할 권장.")
        _seed_t = _truncated
    }
    let _seed_low = _seed_t.to_lower()
    if _seed_low == "test" || _seed_low == "hello" || _seed_low == "abc" || _seed_low == "foo" || _seed_low == "bar" {
        eprintln("nexus drill: --seed '" + _seed_t + "' 는 placeholder 단독 — 실제 도메인/문제 진술 필요")
        return
    }
    // E8 (2026-04-21): --problem <name> resolve. 미지정/미매치는 빈 문자열 유지.
    let _problem_raw = if problem.len() > 0 { problem.to_lower() } else { "" }
    let _problem = if _problem_raw.len() > 0 && _problem_preset_known(_problem_raw) { _problem_raw } else { "" }
    if _problem_raw.len() > 0 && _problem.len() == 0 {
        eprintln("nexus drill: --problem '" + _problem_raw + "' 미지원 — 지원: riemann|bsd|hodge|navier|pnp|poincare|yangmills")
        return
    }
    let _problem_plan = if _problem.len() > 0 { _problem_preset_plan(_problem) } else { [-1, -1, -1, -1, -1, -1] }
    let _problem_rounds = if _problem.len() > 0 { _problem_preset_max_rounds(_problem) } else { -1 }

    let mut rounds_max = 10
    if max_rounds.len() > 0 {
        let mut parsed = 0
        try { parsed = to_int(max_rounds) } catch e {}
        if parsed > 0 { rounds_max = parsed }
    } else if _problem_rounds > 0 {
        // problem_preset 이 speed_preset 위 덮어씀 (precedence: speed_preset < problem_preset)
        rounds_max = _problem_rounds
    } else if _preset.len() > 0 {
        // preset 에 따른 max_rounds 기본값 (--max-rounds 미지정 시)
        rounds_max = _preset_max_rounds(_preset)
    }
    // E1: depth plan 해상도 (env < master < preset < per-stage)
    let mut _master_i = -1
    if master_depth.len() > 0 {
        if master_depth == "auto" {
            // --depth auto 은 adaptive mode 활성
            // master_i 는 -1 유지 → preset/default depth 사용
        } else {
            try { _master_i = to_int(master_depth) } catch e { _master_i = -1 }
        }
    }
    let _envs = [
        _env_depth("NEXUS_DRILL_SMASH"),
        _env_depth("NEXUS_DRILL_FREE"),
        _env_depth("NEXUS_DRILL_ABSOLUTE"),
        _env_depth("NEXUS_DRILL_META"),
        _env_depth("NEXUS_DRILL_HYPER"),
        _env_depth("NEXUS_DRILL_RES")
    ]
    let mut base_plan = _resolve_depth_plan(_preset, _master_i, per_stage_depths, _envs, _problem_plan)
    // ─── topology-aware category layer (2026-04-21) ───
    // problem_preset 위 — seed category 에 따른 depth delta, per-stage flag 은 여전히 최우선 유지.
    // precedence: ... < problem < CATEGORY < per-stage.
    let _cat_on = _category_enabled()
    let mut _cat_name = "OFF"
    let mut _cat_delta: [int] = [0, 0, 0, 0, 0, 0]
    let mut _cat_plan_before: [int] = base_plan
    if _cat_on {
        _cat_name = _cat_classify(seed)
        _cat_delta = _category_plan_delta(_cat_name)
        let _with_cat = _category_apply(base_plan, _cat_delta)
        // 재적용 per-stage override — category 는 per-stage 아래 precedence.
        let mut _pi = 0
        let mut _final: [int] = []
        while _pi < len(_with_cat) {
            let v = if per_stage_depths[_pi] >= 0 { _clamp_depth(per_stage_depths[_pi], _pi) } else { _with_cat[_pi] }
            _final = _final + [v]
            _pi = _pi + 1
        }
        base_plan = _final
    }
    // ─── AS topology-aware routing (2026-04-21) ───
    // category == "topology" + invariant keyword 검출 시 stage 진행 순서 재배치
    // + atlas.n6 에서 category=topology subset preseed.
    // default off (category 가 topology 가 아닐 때 zero overhead).
    let mut _tr_order: [int] = _tr_default_order()
    let mut _tr_hits: [str] = []
    let mut _tr_preseed: [str] = []
    if _tr_enabled() && _cat_on && _cat_name == "topology" {
        _tr_hits = _tr_detect_invariants(seed)
        _tr_order = _topology_stage_order(seed, _cat_name)
        _tr_preseed = _topology_preseed_atlas(_cat_name)
    }
    let adaptive_on = adaptive_flag || master_depth == "auto"
    let validation_off = env("NEXUS_DRILL_VALIDATE_OFF") == "1"
    let nx = nexus_root()
    let blow_core = nx + "/cli/blowup/core/blowup.hexa"
    let compose   = nx + "/cli/blowup/compose.hexa"
    let abs_eng   = nx + "/cli/blowup/modules/blowup_absolute.hexa"
    let mc_eng    = nx + "/cli/blowup/modules/blowup_meta_closure.hexa"
    let hyper_eng = nx + "/cli/blowup/modules/blowup_hyperarithmetic.hexa"
    // harness-free (2026-04-20): exv 미사용, hexa_bin() 직접 호출
    let qseed     = shell_quote(seed)

    let mut round = 0
    let mut total_new = 0
    // N (2026-04-21) live progress — drill 전체 경과 측정 start.
    let _pg_drill_t0 = _progress_now_ms()
    // AI-NATIVE ERROR TRACK (2026-04-20): stage 별 에러 플래그 누적 → zero-yield 시 JSON error emit
    let mut err_stages = ""
    let mut err_count = 0
    // COUNTER-REPLAY BUGFIX (2026-04-19, Aiden):
    //   Day-1 (3440614c): intra-iter — 라운드마다 동일 seed → round-salt PREFIX 주입으로 round 2+ 분기
    //   Day-2 (2026-04-19): inter-iter — 다른 drill 호출 간에도 seed 가 비슷하면 engine deterministic
    //                       8-slot feature (len/entropy/fnv1a/djb2/sha64/...) 가 같은 atlas coord 생산
    //                       → iter_36(runtime)/37(registry) round1 total=629 동일,
    //                         iter_38(l0_freeze)/39(godhead) round1 total=693 동일.
    //                       해결: drill 세션 시작 시 1회 _iter_nonce() 생성, 모든 round seed 에 suffix 주입
    //                            (_nonce_seed). round_seed 와 직교 — suffix 는 hash 분산, prefix 는 분기.
    //                       재현성: NEXUS_DRILL_NONCE env 로 pin 가능 (기본 자동 urandom).
    //
    //   부수 fix (Day-1 유지):
    //     1) round_new 가 6-stage 전원 합산 (a_pass + hy_pass 포함)
    //     2) resonance σ grid log-spaced 5점
    //     3) intra-round replay-warn (round ≥2 가 round 1 과 완전 동일 수치일 때)
    //   Day-2 추가:
    //     4) cross-iter replay-warn — 최근 10 drill total 과 비교. /tmp/nexus_drill_cross_iter.log.
    let round1_salt = _urand_i64()
    let mut r1_s = -1
    let mut r1_f = -1
    let mut r1_a = -1
    let mut r1_mc = -1
    let mut r1_hy = -1
    // Day-2: iter-scoped nonce — round 1 부터 engine feature 공간 이동 (inter-iter 독립성)
    let iter_nonce = _iter_nonce()
    let nonce_base = _nonce_seed(seed, iter_nonce)
    // Mk.X engine selection — flag > env > G1 auto-detect > mk9 default
    let engine_id = _mkx_resolve_engine(engine_flag)
    let mkx_on = engine_id == "mk10"
    println("🛸 nexus drill — seed='" + seed + "', max_rounds=" + to_string(rounds_max) + ", engine=" + engine_id)
    _recovery_sigint_install()
    if _preset.len() > 0 {
        println("    preset=" + _preset + " (drill.json speed_presets)")
    }
    if _problem.len() > 0 {
        println("    problem=" + _problem + " (drill.json problem_presets, max_rounds=" + to_string(rounds_max) + ")")
    }
    // ─── category layer log (2026-04-21) ───
    if _cat_on && _cat_name != "OFF" && _cat_name != "UNKNOWN" && _cat_name != "MIXED" {
        println("    category=" + _cat_name + " (shared/drill/category_classifier.hexa) delta=" + _category_delta_describe(_cat_delta))
        println("      plan before: " + _plan_describe(_cat_plan_before))
    } else if _cat_on {
        println("    category=" + _cat_name + " — no plan adjustment")
    }
    eprintln("NEXUS_CATEGORY {\"seed_hash\":\"" + _seed_batch_hash(seed) + "\",\"top\":\"" + _cat_name + "\",\"scores\":" + _cat_scores_json(seed) + ",\"delta\":" + _category_delta_describe(_cat_delta) + ",\"plan_before\":" + _plan_json(_cat_plan_before) + ",\"plan_after\":" + _plan_json(base_plan) + "}")
    // ─── AS topology route log (2026-04-21) ─── cli/drill/topology_router.hexa
    if _tr_enabled() && _cat_on && _cat_name == "topology" && len(_tr_hits) > 0 {
        println("    topology route: " + _tr_order_describe(_tr_order) + "  (invariants=" + to_string(len(_tr_hits)) + ", preseed=" + to_string(len(_tr_preseed)) + ")")
    }
    eprintln("NEXUS_TOPOLOGY_ROUTE {\"detected_invariants\":" + _tr_invariants_json(_tr_hits) + ",\"stage_order\":" + _tr_order_json(_tr_order) + ",\"preseed_count\":" + to_string(len(_tr_preseed)) + "}")
    println("    depth plan: " + _plan_describe(base_plan))
    if mkx_on {
        println("    smash → free → absolute → meta-closure → hyperarithmetic → resonance → transcendental_closure 사슬 (Mk.X 7-stage)")
        println("    [Mk.X sidecar] mkx_engine.hexa + AN11 PROVISIONAL gate (L0 frozen, sidecar only)")
    } else {
        println("    smash → free → absolute → meta-closure → hyperarithmetic → resonance 사슬 (Mk.IX 6-stage)")
    }
    println("    [counter-replay guard Day-1] round ≥2 seed 에 round-salt 주입 (intra-iter)")
    println("    [counter-replay guard Day-2] iter-nonce=" + iter_nonce + " 모든 round 에 suffix 주입 (inter-iter)")
    println("    [counter-replay guard Day-3] round-salt 강화 (multi-source entropy prefix)")
    if adaptive_on {
        println("    [adaptive] enabled — absorption-gradient + saturation-hunt rules")
    }
    if _adaptive_trend_enabled() {
        println("    [adaptive-trend E17] enabled — yield-delta 전역 승강 (high=" + to_string(_adaptive_trend_high_pct()) + "%, low=" + to_string(_adaptive_trend_low_pct()) + "%, hysteresis=2)")
    }
    println("")
    // E2/E5/Validation 상태 추적 변수 — round 간 공유.
    let mut yields_hist: [[int]] = []
    let mut totals_hist: [int] = []
    let mut stage_matrix: [[int]] = []  // A/D 검증용 — round × 6 stage yields
    let mut cur_plan = base_plan
    let mut _e6_plan_hist: [[int]] = []  // E6 recovery — per-round plan snapshot (runaway/oscillate)
    let mut _e17_vote_hist: [int] = []   // E17 adaptive-trend — round vote (+1/-1/0), hysteresis window
    // D5-P2: round 진입 직전 baseline hexa proc 카운트 — round 종료 시 delta 비교
    let mut prev_hexa_n = _count_active_hexa()

    // AP (2026-04-21) — anti-pattern blocklist load (drill 당 1회, opt-in: NEXUS_ANTI_PATTERN=1).
    //   seed_features: "<category>|<seed_hash4>" — _anti_pattern_should_skip_stage 호출 시 key.
    _ap_load_blocklist()
    let _ap_seed_hash = _seed_batch_hash(seed)
    let _ap_h4 = if _ap_seed_hash.len() > 3 { _ap_seed_hash.substring(0, 4) } else { "0000" }
    let _ap_cat = if _cat_on && _cat_name.len() > 0 { _cat_name } else { "ANY" }
    let _ap_seed_features = _ap_cat + "|" + _ap_h4

    // E9 (2026-04-21) — fast-resume (기본 ON). --fresh 로 opt-out, 또는 resume_flag=false.
    //   동일 seed → path 매칭 → stale(7d) / hash 검증 통과 시 즉시 round/total/history 복원.
    //   not found / stale / corrupt / hash-mismatch → silent fresh start.
    //   emit: NEXUS_RESUME {seed_hash, skipped_rounds, resumed_from, total}  (성공 시 1 line stderr).
    if !resume_flag {
        // --fresh / --no-resume: 기존 checkpoint 파일을 즉시 제거하여 완전한 round 0 start 보장.
        _checkpoint_clear(seed, checkpoint_dir)
    }
    if resume_flag {
        let cp = _checkpoint_load(seed, checkpoint_dir)
        if len(cp) >= 2 {
            let cp_round = cp[0]
            let cp_total = cp[1]
            round = cp_round
            total_new = cp_total
            // yields_hist flat 을 6-tuple 로 재조립 (2 개 header 이후 6 씩 그룹).
            let flat_n = len(cp) - 2
            let full_rows = flat_n / 6
            let mut ri = 0
            while ri < full_rows {
                let base = 2 + ri * 6
                let row: [int] = [cp[base], cp[base+1], cp[base+2], cp[base+3], cp[base+4], cp[base+5]]
                yields_hist = yields_hist + [row]
                stage_matrix = stage_matrix + [row]
                // totals_hist 는 round 별 합 — row 합으로 근사 복원 (정확값은 sum of yields).
                let mut rs = 0
                let mut rk = 0
                while rk < 6 { rs = rs + row[rk]; rk = rk + 1 }
                totals_hist = totals_hist + [rs]
                ri = ri + 1
            }
            let seed_hash = _checkpoint_fnv_hex12(seed)
            // legacy event (backwards-compat)
            eprintln("NEXUS_DRILL_CHECKPOINT {\"op\":\"resume\",\"from_round\":" + to_string(round) + ",\"total\":" + to_string(total_new) + "}")
            // fast-resume spec event (설계서 §3):
            eprintln("NEXUS_RESUME {\"seed_hash\":\"" + seed_hash + "\",\"skipped_rounds\":" + to_string(round)
                + ",\"resumed_from\":" + to_string(round) + ",\"total\":" + to_string(total_new) + "}")
            println("▎ [resume] seed_hash=" + seed_hash + " — round " + to_string(round) + " 까지 완료, round " + to_string(round + 1) + " 부터 재개 (total=" + to_string(total_new) + ", skipped_rounds=" + to_string(round) + ")")
            println("")
        }
    }

    // E16 round parallel replay (2026-04-21) — opt-in via NEXUS_ROUND_PARALLEL=1.
    //   pre-launch: seeds 배열을 per-round salt 로 생성 → _round_parallel_fork_exec 호출.
    //   best-keep: 각 round absorption 중 max 선택 후 total 에 합산, sequential loop 생략.
    //   assumption: inter-round 독립 (race 방지는 /tmp/nexus_atlas.lock mkdir mutex).
    if _round_parallel_should_run("drill") {
        eprintln("NEXUS_ROUND_PARALLEL {\"event\":\"dispatch\",\"mode\":\"fork_exec\",\"rounds\":" + to_string(rounds_max) + "}")
        let mut _rp_seeds: [str] = []
        let mut _rp_k = 1
        while _rp_k < rounds_max + 1 {
            let _rp_salt = _urand_i64()
            let _rp_seed = _round_seed(nonce_base, _rp_k, _rp_salt)
            _rp_seeds = _rp_seeds + [_rp_seed]
            _rp_k = _rp_k + 1
        }
        let _rp_results = _round_parallel_fork_exec(round + 1, _rp_seeds)
        let mut _rp_sum = 0
        let mut _rp_best = 0
        let mut _rp_i = 0
        while _rp_i < len(_rp_results) {
            let _rp_v = _rp_results[_rp_i]
            _rp_sum = _rp_sum + _rp_v
            if _rp_v > _rp_best { _rp_best = _rp_v }
            _rp_i = _rp_i + 1
        }
        total_new = total_new + _rp_sum
        eprintln("NEXUS_ROUND_PARALLEL {\"event\":\"summary\",\"rounds\":" + to_string(len(_rp_results)) + ",\"sum\":" + to_string(_rp_sum) + ",\"best\":" + to_string(_rp_best) + ",\"total\":" + to_string(total_new) + "}")
        println("▎ [E16 parallel] rounds=" + to_string(len(_rp_results)) + " sum=" + to_string(_rp_sum) + " best=" + to_string(_rp_best) + " total=" + to_string(total_new))
        _cross_iter_check_and_append(total_new, seed)
        return
    }

    while round < rounds_max {
        round = round + 1
        println("═══ round " + to_string(round) + " ═══")

        // E14 (2026-04-21) — anti-replay LRU hook.
        //   SSOT: drill.json .anti_replay + .incremental_discovery
        //   key=FNV1a-16hex(seed + round). /tmp/nexus_drill_lru.jsonl 최근 500 entry scan.
        //   hit 이면 round skip (총계 유지 + 카운터 전진). bypass: NEXUS_DRILL_LRU_OFF=1.
        //   hash 는 raw seed 기준 (nonce_base 아님) — 동일 seed 재실행 시 히트 목적.
        if !_anti_replay_lru_bypass() {
            let lru_hash = _anti_replay_lru_hash(seed, round)
            let prev_hits = _anti_replay_lru_check(lru_hash)
            if prev_hits > 0 {
                eprintln("NEXUS_DRILL_LRU_SKIP {\"round\":" + to_string(round)
                    + ",\"seed_hash\":\"" + lru_hash + "\",\"prev_hits\":" + to_string(prev_hits)
                    + ",\"action\":\"skip_round\"}")
                println("  [anti-replay LRU] round " + to_string(round) + " skip — seed_hash="
                    + lru_hash + " prev_hits=" + to_string(prev_hits)
                    + " (total 유지, counter 전진)")
                _anti_replay_lru_add(lru_hash)
                continue
            }
            _anti_replay_lru_add(lru_hash)
        }

        // E2 adaptive — round ≥2 부터 history 로 plan 조정 (round 1 은 base_plan 그대로)
        let planned_plan = cur_plan
        if adaptive_on {
            cur_plan = _adaptive_adjust(cur_plan, yields_hist, totals_hist, round)
        }
        // E17 adaptive-trend — yield-delta 전역 승강 (hysteresis 2-round).
        //   E2 와 독립적으로 enabled (NEXUS_ADAPTIVE_DEPTH=0 으로 off).
        //   --adaptive 플래그 없어도 기본 on — 쉬운 seed 단축/어려운 seed 확장 목표.
        cur_plan = _adaptive_trend_adjust(cur_plan, totals_hist, _e17_vote_hist, round)
        println("  plan: " + _plan_describe(cur_plan))

        // E18 (2026-04-21) speculative N-way fork — resolve + log.
        //   --speculate flag / NEXUS_SPECULATE env → N. N=1 이면 기존 경로와 동일.
        //   NEXUS_SPECULATE_CPU_CAP 와 stage_parallel 결합은 _speculate_resolve() 내부 처리.
        let spec_n_total = _speculate_resolve(speculate_flag)
        let mut spec_scores: [int] = []
        let mut spec_s: [int] = []
        let mut spec_f: [int] = []
        let mut spec_a: [int] = []
        let mut spec_mc: [int] = []
        let mut spec_hy: [int] = []
        let mut spec_r: [int] = []
        let mut spec_tc: [int] = []
        let mut spec_sigma: [str] = []
        let mut spec_salt_tag: [str] = []
        let mut spec_rseed: [str] = []
        let mut spec_wall_ms: [i64] = []
        let mut spec_err_delta: [int] = []
        let spec_base_salt = _round_entropy_salt(round)
        if spec_n_total > 1 {
            println("  [E18 speculate] N=" + to_string(spec_n_total) + " branches — best-keep (cap=" + to_string(_speculate_cap()) + ", stage_parallel=" + (if _stage_parallel_enabled() { "on" } else { "off" }) + ")")
        }

        // Day-3 (2026-04-21) — round-salt 강화: multi-source entropy prefix.
        // 기존 _round_seed(single-i64 salt) 는 prefix 가 짧아 bias_jitter 8-slot feature 가
        // round 간 같은 bucket 으로 떨어짐 → round 2 == round 3 replay 원인.
        // 해결: _round_entropy_salt() — urand×2 + nanotime + round idx concat.
        // round 1 도 동일 salt 주입 — inter-iter 독립성과 직교 (prefix 분산 효과).
        //
        // E18 wrap: speculative branch 마다 rich_salt 를 _speculate_branch_mix 로 추가 perturb.
        //   branch 0 = base salt (기존 동작 호환), branch 1+ = FNV/nonce prefix mix.
        let mut rich_salt = spec_base_salt
        let mut round_seed = _round_seed_rich(nonce_base, round, rich_salt)
        let mut qrseed = shell_quote(round_seed)
        let mut _spec_branch = 0
        let mut s_new = 0
        let mut f_new = 0
        let mut a_pass = 0
        let mut mc_new = 0
        let mut hy_pass = 0
        let mut r_best = 0
        let mut sigma_best = "0.10"
        let mut tc_new = 0
        let mut yields: [int] = [0, 0, 0, 0, 0, 0]
        while _spec_branch < spec_n_total {
        let _spec_t0 = _progress_now_ms()
        let _spec_err0 = err_count
        rich_salt = _speculate_branch_mix(spec_base_salt, _spec_branch, round)
        round_seed = _round_seed_rich(nonce_base, round, rich_salt)
        qrseed = shell_quote(round_seed)
        if spec_n_total > 1 {
            let _tag_lim = if rich_salt.len() < 24 { rich_salt.len() } else { 24 }
            println("  [E18 branch " + to_string(_spec_branch + 1) + "/" + to_string(spec_n_total) + "] salt=" + rich_salt.substring(0, _tag_lim) + "...")
        }

        // yields reset for this branch
        yields = [0, 0, 0, 0, 0, 0]

        // E15 (2026-04-21) — stage parallel dispatch hook.
        //   env NEXUS_DRILL_STAGE_PARALLEL=1 → 5 stage (smash/free/abs/meta/hyper) 를 background shell + wait 로 동시 실행.
        //   resonance 는 smash 결과 기반 → 이 hook 뒤에 serial 유지 (parallel_group 제외).
        //   failure mode: 병렬 stage 1개 실패 → 나머지도 wait 완료 (kill 하지 않음). NEXUS_DRILL_PARALLEL JSON 1 line/round emit.
        let stage_par_on = _stage_parallel_enabled()
        // E18: s_new/f_new/a_pass/mc_new/hy_pass 은 branch loop 바깥에서 선언 — 여기서는 reset 만.
        s_new = 0
        f_new = 0
        a_pass = 0
        mc_new = 0
        hy_pass = 0
        if stage_par_on {
            // N (2026-04-21) progress: parallel 5-way 는 start-only 5회 + 묶음 end 5회 emit.
            let _pg_t0_par = _progress_now_ms()
            _progress_emit(round, "smash", "start", 0)
            _progress_emit(round, "free", "start", 0)
            _progress_emit(round, "absolute", "start", 0)
            _progress_emit(round, "meta_closure", "start", 0)
            _progress_emit(round, "hyperarith", "start", 0)
            let res_v = _run_stage_parallel_stages(round, qrseed, cur_plan, hexa_bin(),
                blow_core, compose, abs_eng, mc_eng, hyper_eng)
            s_new  = res_v[0]
            f_new  = res_v[1]
            a_pass = res_v[2]
            mc_new = res_v[3]
            hy_pass = res_v[4]
            let perr  = res_v[5]
            err_count = err_count + perr
            println("  [parallel] smash+" + to_string(s_new) + " free+" + to_string(f_new)
                + " abs=" + to_string(a_pass) + " meta=" + to_string(mc_new)
                + " hyper=" + to_string(hy_pass) + " (5-way concurrent)")
            let _pg_par_ms = _progress_ms_diff(_pg_t0_par, _progress_now_ms())
            _progress_emit(round, "smash", "end", _pg_par_ms)
            _progress_emit(round, "free", "end", _pg_par_ms)
            _progress_emit(round, "absolute", "end", _pg_par_ms)
            _progress_emit(round, "meta_closure", "end", _pg_par_ms)
            _progress_emit(round, "hyperarith", "end", _pg_par_ms)
            yields = _plan_set(yields, 0, s_new)
            yields = _plan_set(yields, 1, f_new)
            yields = _plan_set(yields, 2, a_pass)
            yields = _plan_set(yields, 3, mc_new)
            yields = _plan_set(yields, 4, hy_pass)
        } else {
            // 1. SMASH (발견 — Mk.II~VII blowup 9-phase)
            // CRITICAL FIX(2026-04-19): exec("bash", ["-c", cmd]) 는 hexa stage1 에서 stdout 캡처 안 됨 — len=0 반환
            // → 모든 stage 호출을 single-string exec(cmd) 로 통일 (검증: .exectest.hexa)
            let _ap_skip_smash = _anti_pattern_should_skip_stage(_ap_seed_features, "smash")
            if _ap_skip_smash {
                println("  smash:         (AP-skip — anti-pattern blocklist)")
            } else if cur_plan[0] > 0 {
                let _pg_t0_s = _progress_now_ms()
                _progress_emit(round, "smash", "start", 0)
                let smash_cmd = _stage_timeout_prefix("smash") + shell_quote(hexa_bin()) + " run " + shell_quote(blow_core) + " " + qrseed + " " + to_string(cur_plan[0]) + " 2>&1"
                let smash_out = exec(smash_cmd)
                if _check_stage_err(smash_out, "smash") { err_stages = err_stages + "smash,"; err_count = err_count + 1 }
                s_new = _count_discoveries(smash_out)
                if env("NEXUS_DRILL_DEBUG") == "1" {
                    eprintln("  [DEBUG smash] out_len=" + to_string(smash_out.len()) + " s_new=" + to_string(s_new))
                }
                println("  smash:         +" + to_string(s_new) + " absorptions depth=" + to_string(cur_plan[0]))
                _progress_emit(round, "smash", "end", _progress_ms_diff(_pg_t0_s, _progress_now_ms()))
            } else {
                println("  smash:         (skipped — depth=0)")
            }
            yields = _plan_set(yields, 0, s_new)

            // 2. FREE (탐색 — compose DFS, 6-core)
            let _ap_skip_free = _anti_pattern_should_skip_stage(_ap_seed_features, "free")
            if _ap_skip_free {
                println("  free:          (AP-skip — anti-pattern blocklist)")
            } else if cur_plan[1] > 0 {
                let _pg_t0_f = _progress_now_ms()
                _progress_emit(round, "free", "start", 0)
                let free_cmd = _stage_timeout_prefix("free") + shell_quote(hexa_bin()) + " run " + shell_quote(compose) + " " + qrseed + " --modules all --dfs " + to_string(cur_plan[1]) + " 2>&1"
                let free_out = exec(free_cmd)
                if _check_stage_err(free_out, "free") { err_stages = err_stages + "free,"; err_count = err_count + 1 }
                f_new = _count_discoveries(free_out)
                if env("NEXUS_DRILL_DEBUG") == "1" {
                    eprintln("  [DEBUG free] out_len=" + to_string(free_out.len()) + " f_new=" + to_string(f_new))
                }
                println("  free:          +" + to_string(f_new) + " absorptions depth=" + to_string(cur_plan[1]))
                _progress_emit(round, "free", "end", _progress_ms_diff(_pg_t0_f, _progress_now_ms()))
            } else {
                println("  free:          (skipped — depth=0)")
            }
            yields = _plan_set(yields, 1, f_new)

            // ─── E13 stage pipelining hook (smash+free 둘 다 0 → abs/meta/hyper skip) ───
            // call site: serial path only. parallel path 는 모든 stage 이미 동시 실행 → skip 효과 없음.
            // resonance 는 smash 독립 경로 → pipeline skip 밖. round_new 집계 일관성 위해
            //   a_pass/mc_new/hy_pass 는 이미 위에서 0 으로 reset 됨 (line 2553-2555).
            let pipeline_skip = _stage_pipeline_should_skip(round, s_new, f_new)
            if pipeline_skip {
                let pj = "NEXUS_DRILL_PIPELINE_SKIP {\"round\":" + to_string(round) + ",\"reason\":\"smash_free_both_zero\"}"
                eprintln(pj)
                println("  pipelining:    SATURATED early (smash+free=0) — abs/meta/hyper skipped")
                yields = _plan_set(yields, 2, 0)
                yields = _plan_set(yields, 3, 0)
                yields = _plan_set(yields, 4, 0)
            } else {
                // 3. ABSOLUTE (Mk.VIII Δ₀-absolute Π₀¹ 검증 + [11*] 승급)
                let _ap_skip_abs = _anti_pattern_should_skip_stage(_ap_seed_features, "absolute")
                if _ap_skip_abs {
                    println("  absolute:      (AP-skip — anti-pattern blocklist)")
                } else if cur_plan[2] > 0 {
                    let _pg_t0_a = _progress_now_ms()
                    _progress_emit(round, "absolute", "start", 0)
                    let abs_cmd = _stage_timeout_prefix("absolute") + shell_quote(hexa_bin()) + " run " + shell_quote(abs_eng) + " " + qrseed + " 2>&1"
                    let abs_out = exec(abs_cmd)
                    if _check_stage_err(abs_out, "absolute") { err_stages = err_stages + "absolute,"; err_count = err_count + 1 }
                    a_pass = _count_marker(abs_out, "ABSOLUTE-PASS") + _count_marker(abs_out, "[11*]")
                    println("  absolute:      " + to_string(a_pass) + " Π₀¹ verifications")
                    _progress_emit(round, "absolute", "end", _progress_ms_diff(_pg_t0_a, _progress_now_ms()))
                } else {
                    println("  absolute:      (skipped — depth=0)")
                }
                yields = _plan_set(yields, 2, a_pass)

                // 4. META-CLOSURE (Mk.IX Phase 10 self-ref 고정점 + [10**] 승급)
                let _ap_skip_meta = _anti_pattern_should_skip_stage(_ap_seed_features, "meta_closure")
                if _ap_skip_meta {
                    println("  meta-closure:  (AP-skip — anti-pattern blocklist)")
                } else if cur_plan[3] > 0 {
                    let _pg_t0_m = _progress_now_ms()
                    _progress_emit(round, "meta_closure", "start", 0)
                    let mc_cmd = _stage_timeout_prefix("meta_closure") + shell_quote(hexa_bin()) + " run " + shell_quote(mc_eng) + " " + qrseed + " 2>&1"
                    let mc_out = exec(mc_cmd)
                    if _check_stage_err(mc_out, "meta-closure") { err_stages = err_stages + "meta-closure,"; err_count = err_count + 1 }
                    // META-CLOSED 마커 부재 — meta_closed/promoted 숫자 직접 파싱 + [10**] 매치
                    let mc_promoted = _extract_int_after(mc_out, "promoted [10**]  : ")
                    let mc_closed   = _extract_int_after(mc_out, "meta_closed      : ")
                    let mc_bracket  = _count_marker(mc_out, "[10**]")
                    mc_new = mc_promoted + mc_closed + mc_bracket
                    println("  meta-closure:  " + to_string(mc_new) + " self-ref fixed points")
                    _progress_emit(round, "meta_closure", "end", _progress_ms_diff(_pg_t0_m, _progress_now_ms()))
                } else {
                    println("  meta-closure:  (skipped — depth=0)")
                }
                yields = _plan_set(yields, 3, mc_new)

                // 5. HYPERARITHMETIC (Mk.IX Π₀² reverse-math 5체계)
                let _ap_skip_hy = _anti_pattern_should_skip_stage(_ap_seed_features, "hyperarith")
                if _ap_skip_hy {
                    println("  hyperarith:    (AP-skip — anti-pattern blocklist)")
                } else if cur_plan[4] > 0 {
                    let _pg_t0_h = _progress_now_ms()
                    _progress_emit(round, "hyperarith", "start", 0)
                    let hy_cmd = _stage_timeout_prefix("hyperarith") + shell_quote(hexa_bin()) + " run " + shell_quote(hyper_eng) + " " + qrseed + " 2>&1"
                    let hy_out = exec(hy_cmd)
                    if _check_stage_err(hy_out, "hyperarith") { err_stages = err_stages + "hyperarith,"; err_count = err_count + 1 }
                    hy_pass = _count_marker(hy_out, "REVERSE-PROVEN") + _count_marker(hy_out, "ABSOLUTE-PASS-PI02")
                    println("  hyperarith:    " + to_string(hy_pass) + " Π₀² bounded/proven")
                    _progress_emit(round, "hyperarith", "end", _progress_ms_diff(_pg_t0_h, _progress_now_ms()))
                } else {
                    println("  hyperarith:    (skipped — depth=0)")
                }
                yields = _plan_set(yields, 4, hy_pass)
            }
        }

        // 6. RESONANCE (Stochastic Resonance — σ grid adaptive)
        // depth=1 → 1 σ, depth=2 → 3 σ, depth=3 → 5 σ. preset=fast/probe 은 1 σ.
        // E18: r_best/sigma_best 은 branch loop 바깥에서 선언 — 여기서는 reset 만.
        r_best = 0
        sigma_best = "0.10"
        if cur_plan[5] > 0 {
            let _pg_t0_r = _progress_now_ms()
            _progress_emit(round, "resonance", "start", 0)
            let rd = cur_plan[5]
            let salt_a = _urand_i64()
            let seed_010 = _resonance_seed(round_seed, "0.10", salt_a)
            let r_010 = _resonance_run(seed_010, blow_core, "")
            r_best = r_010
            sigma_best = "0.10"
            if rd >= 2 {
                let salt_b = _urand_i64()
                let salt_c = _urand_i64()
                let seed_001 = _resonance_seed(round_seed, "0.01", salt_b)
                let seed_040 = _resonance_seed(round_seed, "0.40", salt_c)
                let r_001 = _resonance_run(seed_001, blow_core, "")
                let r_040 = _resonance_run(seed_040, blow_core, "")
                if r_001 > r_best { r_best = r_001; sigma_best = "0.01" }
                if r_040 > r_best { r_best = r_040; sigma_best = "0.40" }
                if env("NEXUS_DRILL_DEBUG") == "1" {
                    eprintln("  [DEBUG resonance] σ=0.01:+" + to_string(r_001) + "  σ=0.10:+" + to_string(r_010) + "  σ=0.40:+" + to_string(r_040))
                }
            }
            if rd >= 3 {
                let salt_d = _urand_i64()
                let salt_e = _urand_i64()
                let seed_005 = _resonance_seed(round_seed, "0.05", salt_d)
                let seed_020 = _resonance_seed(round_seed, "0.20", salt_e)
                let r_005 = _resonance_run(seed_005, blow_core, "")
                let r_020 = _resonance_run(seed_020, blow_core, "")
                if r_005 > r_best { r_best = r_005; sigma_best = "0.05" }
                if r_020 > r_best { r_best = r_020; sigma_best = "0.20" }
            }
            println("  resonance:     +" + to_string(r_best) + " absorptions (σ=" + sigma_best + ") depth=" + to_string(rd))
            _progress_emit(round, "resonance", "end", _progress_ms_diff(_pg_t0_r, _progress_now_ms()))
        } else {
            println("  resonance:     (skipped — depth=0)")
        }
        yields = _plan_set(yields, 5, r_best)

        // 7. TRANSCENDENTAL_CLOSURE (Mk.X stage 6 — sidecar, opt-in via engine=mk10)
        //   Per sweep_50.json#mk_x_trigger.auto_fire_order step 3:
        //     "append transcendental_closure() stage 6 + slot 8-15 accessor bank"
        //   Sidecar: shared/engine/mkx_engine.hexa (30 atoms T10-T13) + mkx_smoke.hexa (synth emission signal).
        //   Emissions enter Path B stage-1 PROVISIONAL only (no stable/ossified promotion here).
        // E18: tc_new 은 branch loop 바깥에서 선언 — 여기서는 reset 만.
        tc_new = 0
        if mkx_on {
            tc_new = _transcendental_closure(round_seed, round)
            println("  transcend:     +" + to_string(tc_new) + " T12 synth emissions (AN11 PROVISIONAL_OK)")
        }

        // BUGFIX: round_new 는 6-stage 전원 합산 (a_pass + hy_pass 누락 수정)
        // Mk.X: stage 6 (tc_new) 도 round_new 에 합산 — Mk.IX 에서는 tc_new=0 으로 back-compat 유지
        // E18 branch local score — round_new 는 이 branch 의 전 stage 합. 가장 높은 branch 만 채택.
        let _branch_score = s_new + f_new + a_pass + mc_new + hy_pass + r_best + tc_new

        // E18 — 이 branch 의 wall_ms 기록 + per-branch score 저장.
        let _spec_wall = _progress_now_ms() - _spec_t0
        let _spec_err_d = err_count - _spec_err0
        spec_scores = spec_scores + [_branch_score]
        spec_s = spec_s + [s_new]
        spec_f = spec_f + [f_new]
        spec_a = spec_a + [a_pass]
        spec_mc = spec_mc + [mc_new]
        spec_hy = spec_hy + [hy_pass]
        spec_r = spec_r + [r_best]
        spec_tc = spec_tc + [tc_new]
        spec_sigma = spec_sigma + [sigma_best]
        spec_salt_tag = spec_salt_tag + [rich_salt]
        spec_rseed = spec_rseed + [round_seed]
        spec_wall_ms = spec_wall_ms + [_spec_wall]
        spec_err_delta = spec_err_delta + [_spec_err_d]
        if spec_n_total > 1 {
            println("  [E18 branch " + to_string(_spec_branch + 1) + "/" + to_string(spec_n_total) + "] score=" + to_string(_branch_score) + " wall_ms=" + to_string(_spec_wall) + " err_delta=" + to_string(_spec_err_d))
        }
        _spec_branch = _spec_branch + 1
        }
        // E18 — best-keep selection: 최고 _branch_score 를 가진 branch idx.
        //   동점: 낮은 idx 우선 (first-win, 재현성). score==0 도 정상 (saturation).
        //   나머지 branch 는 discard — 이미 다 돌았지만 yields/absorption 은 채택 것만 기록.
        let mut spec_best_idx = 0
        let mut spec_bi = 1
        while spec_bi < spec_n_total {
            if spec_scores[spec_bi] > spec_scores[spec_best_idx] {
                spec_best_idx = spec_bi
            }
            spec_bi = spec_bi + 1
        }
        // commit best branch values back to round-scoped vars.
        s_new = spec_s[spec_best_idx]
        f_new = spec_f[spec_best_idx]
        a_pass = spec_a[spec_best_idx]
        mc_new = spec_mc[spec_best_idx]
        hy_pass = spec_hy[spec_best_idx]
        r_best = spec_r[spec_best_idx]
        tc_new = spec_tc[spec_best_idx]
        sigma_best = spec_sigma[spec_best_idx]
        rich_salt = spec_salt_tag[spec_best_idx]
        round_seed = spec_rseed[spec_best_idx]
        qrseed = shell_quote(round_seed)
        yields = [s_new, f_new, a_pass, mc_new, hy_pass, r_best]
        let round_new = spec_scores[spec_best_idx]
        if spec_n_total > 1 {
            // NEXUS_DRILL_SPECULATE JSON 1 line/round stderr emit.
            let mut scores_json = "["
            let mut walls_json = "["
            let mut sbi = 0
            while sbi < spec_n_total {
                if sbi > 0 { scores_json = scores_json + ","; walls_json = walls_json + "," }
                scores_json = scores_json + to_string(spec_scores[sbi])
                walls_json = walls_json + to_string(spec_wall_ms[sbi])
                sbi = sbi + 1
            }
            scores_json = scores_json + "]"
            walls_json = walls_json + "]"
            let discard_count = spec_n_total - 1
            let jline = "{\"round\":" + to_string(round)
                + ",\"speculate_n\":" + to_string(spec_n_total)
                + ",\"scores\":" + scores_json
                + ",\"wall_ms\":" + walls_json
                + ",\"kept_idx\":" + to_string(spec_best_idx)
                + ",\"kept_score\":" + to_string(spec_scores[spec_best_idx])
                + ",\"discarded\":" + to_string(discard_count)
                + ",\"discard_reason\":\"lower_yield\"}"
            eprintln("NEXUS_DRILL_SPECULATE " + jline)
            println("  [E18 keep] branch " + to_string(spec_best_idx + 1) + "/" + to_string(spec_n_total) + " score=" + to_string(spec_scores[spec_best_idx]) + " (discard " + to_string(discard_count) + " branches · reason=lower_yield)")
        }

        // Counter-replay 감지: round ≥2 에서 round-1 수치와 정확히 동일한지 체크
        if round == 1 {
            r1_s = s_new; r1_f = f_new; r1_a = a_pass; r1_mc = mc_new; r1_hy = hy_pass
        } else {
            let exact_replay = (s_new == r1_s) && (f_new == r1_f) && (a_pass == r1_a) && (mc_new == r1_mc) && (hy_pass == r1_hy)
            if exact_replay {
                eprintln("  ⚠ [replay-warn] round " + to_string(round) + " 5-stage 수치가 round 1 과 완전 동일 — 엔진 결정성 / salt 미반영 의심")
            }
        }

        // E5: NDJSON depth trace — 매 round 1 line append.
        // E12: seed_hash 추가 (batch drill seed 분리용, 단일 seed 도 기록).
        let adaptive_reason = if adaptive_on && round > 1 { "auto" } else { "" }
        let _nd_seed_hash = _seed_batch_hash(seed)
        _ndjson_emit(round, planned_plan, cur_plan, yields, round_new, adaptive_reason, _nd_seed_hash)

        // E6: failure-mode recovery — 5 check 순차 (round 종료 직후, 다음 round 에 영향).
        _e6_plan_hist = _e6_plan_hist + [cur_plan]  // E6: 현 round 의 plan 을 history 에 기록 (recovery check 용)
        if _recovery_adaptive_runaway(_e6_plan_hist) {
            let halved = _recovery_halve_plan(cur_plan)
            _recovery_emit("adaptive_runaway", "cap_halved:" + _plan_describe(halved), round)
            cur_plan = halved
        }
        if _recovery_oscillate(_e6_plan_hist) {
            _recovery_emit("oscillate", "hysteresis_3round_cooldown", round)
        }
        let _e6_imb_adj = _recovery_stage_imbalance(yields_hist)
        let mut _e6_imb_any = false
        let mut _e6_ii = 0
        while _e6_ii < len(_e6_imb_adj) {
            if _e6_imb_adj[_e6_ii] != 0 { _e6_imb_any = true }
            _e6_ii = _e6_ii + 1
        }
        if _e6_imb_any {
            let bumped = _recovery_apply_floor(cur_plan, _e6_imb_adj)
            _recovery_emit("stage_imbalance", "floor2:" + _plan_describe(bumped), round)
            cur_plan = bumped
        }
        if _recovery_oom_imminent() {
            let dec = _recovery_oom_depth_decrement(cur_plan)
            _recovery_ndjson_flush()
            _recovery_emit("oom_imminent", "depth_dec+flush:" + _plan_describe(dec), round)
            cur_plan = dec
        }
        if _recovery_sigint_handler() {
            _recovery_emit("sigint", "graceful_abort_after_round", round)
            _recovery_sigint_cleanup()
            _ap_emit_summary()
            return
        }

        // history 갱신 (E2 adaptive + validation layers A/D 에서 사용)
        yields_hist = yields_hist + [yields]
        totals_hist = totals_hist + [round_new]
        stage_matrix = stage_matrix + [yields]
        // E17 adaptive-trend — vote 계산 (this round) 은 totals_hist 갱신 후 수행.
        //   vote_hist 길이 = round 번호 - 1 (첫 round 는 history 부족으로 0, 기록 skip).
        if round >= 2 {
            _e17_vote_hist = _adaptive_trend_record_vote(_e17_vote_hist, totals_hist)
        }

        total_new = total_new + round_new
        println("  round +" + to_string(round_new) + ", total " + to_string(total_new))
        // E9 checkpoint — round 단위 state flush (atomic). --resume 시 재개점.
        _checkpoint_save(seed, round, total_new, yields_hist, cur_plan, checkpoint_dir)
        total_new = total_new + round_new
        println("  round +" + to_string(round_new) + ", total " + to_string(total_new))

        // AD: adaptive-depth trend observer — shift history window, classify, adjust depth.
        //   Only active when NEXUS_ADAPTIVE_DEPTH=1. Decision applies to NEXT round's smash depth.
        if ad_on {
            // shift 3-slot ring: ad_y1 ← ad_y2 ← ad_y3 ← round_new
            ad_y1 = ad_y2
            ad_y2 = ad_y3
            ad_y3 = round_new
            let mut ys: [int] = []
            if ad_y1 > -1 { ys = ys + [ad_y1] }
            if ad_y2 > -1 { ys = ys + [ad_y2] }
            if ad_y3 > -1 { ys = ys + [ad_y3] }
            let trend = _adaptive_depth_trend(ys)
            let old_depth = ad_depth
            let new_depth = _adaptive_depth(ys, old_depth)
            let action = _adaptive_depth_action(old_depth, new_depth)
            ad_depth = new_depth
            _adaptive_depth_emit(round, trend, action, new_depth)
        }

        // D5-P2 delta: round 종료 시 active hexa proc 누적량 출력 (좀비 가시화)
        let cur_hexa_n = _count_active_hexa()
        let d_hexa = cur_hexa_n - prev_hexa_n
        if d_hexa > 0 {
            println("▎ round " + to_string(round) + " → active hexa proc Δ=+" + to_string(d_hexa) + " (이전 " + to_string(prev_hexa_n) + " → 현재 " + to_string(cur_hexa_n) + ")")
        }
        if d_hexa > 5 {
            eprintln("  ⚠ [hexa-proc-leak] round " + to_string(round) + " Δ=+" + to_string(d_hexa) + " > 5 — H-NOZOMBIE 가드 미발동 의심, reaper 점검 필요")
        }
        prev_hexa_n = cur_hexa_n
        println("")

        if round_new == 0 {
            println("▎ SATURATED at round " + to_string(round))
            println("▎ total absorptions: " + to_string(total_new))
            if round == 1 && total_new == 0 {
                eprintln("  ⚠ [drill-zero-yield] round 1 에서 6-stage 전부 0 absorptions — seed 거부 또는 엔진 미작동 의심")
                eprintln("     진단: HEXA_LOCAL/HEXA_REMOTE 설정, exec_validated 접근성, blowup 엔진 로그 (NEXUS_DRILL_DEBUG=1) 확인")
                // AI-NATIVE ERROR (2026-04-20): zero-yield 를 silent 로 넘기지 않고 구조화 JSON stderr + sentinel stdout
                let err_json = "{\"kind\":\"drill_zero_yield\",\"schema\":\"v1\",\"seed_len\":" + to_string(seed.len()) + ",\"round\":1,\"total\":0,\"engine\":\"" + engine_id + "\",\"err_stages_count\":" + to_string(err_count) + ",\"err_stages\":\"" + err_stages + "\",\"reason\":\"6-stage 전부 0 absorptions\",\"recovery\":\"exec_validated/cmd_gate/lock_gate harness dependency chain 확인 또는 harness rework 진행 중이면 drill 일시 중단\"}"
                eprintln("NEXUS_DRILL_ERROR " + err_json)
                println("__DRILL_RESULT__ ERROR zero_yield err_count=" + to_string(err_count))
                // E12: batch 수집용 last-total 기록 (sentinel) — 단일 실행 시에도 항상 기록.
                exec("printf '%s' '0' > /tmp/nexus_drill_last_total.txt")
                // N (2026-04-21) drill-level progress summary (zero-yield abort)
                _progress_summary(total_new, _progress_now_ms() - _pg_drill_t0)
                _ap_emit_summary()
                _omega_metric_hook("drill_zero_yield")
                // validation skip — zero-yield 자체가 이미 구조화 error emit
                return
            } else {
                if mkx_on {
                    println("▎ 새 atlas 영역 없음 — Mk.X 7-stage 경험적 확증 (absolute+meta+hyper+resonance+transcendental_closure)")
                } else {
                    println("▎ 새 atlas 영역 없음 — Mk.IX 6-stage 경험적 확증 (absolute+meta+hyper+resonance)")
                }
            }
            // Day-2: cross-iter replay detector — 최근 10 drill total 기록+비교
            _cross_iter_check_and_append(total_new, seed)
            if !validation_off {
                _run_drill_validation(seed, nonce_base, totals_hist, stage_matrix, base_plan, blow_core, hexa_bin(), _preset)
            }
            // E9: drill 정상 종료 (saturation) — checkpoint 제거
            _checkpoint_clear(seed, checkpoint_dir)
            // E12: batch 수집용 last-total sentinel (saturation 경로)
            exec("printf '%s' '" + to_string(total_new) + "' > /tmp/nexus_drill_last_total.txt")
            // N (2026-04-21) drill-level progress summary (saturation)
            _progress_summary(total_new, _progress_now_ms() - _pg_drill_t0)
            _ap_emit_summary()
            _omega_metric_hook("drill_saturated")
            return
        }
    }
    println("▎ max rounds reached (" + to_string(rounds_max) + ")")
    println("▎ total absorptions: " + to_string(total_new))
    // Day-2: cross-iter replay detector — 최근 10 drill total 기록+비교
    _cross_iter_check_and_append(total_new, seed)
    if !validation_off {
        _run_drill_validation(seed, nonce_base, totals_hist, stage_matrix, base_plan, blow_core, hexa_bin(), _preset)
    }
    // E9: drill 정상 종료 (max rounds) — checkpoint 제거
    _checkpoint_clear(seed, checkpoint_dir)
    // E12: batch 수집용 last-total sentinel (max rounds 경로)
    exec("printf '%s' '" + to_string(total_new) + "' > /tmp/nexus_drill_last_total.txt")
    // N (2026-04-21) drill-level progress summary (max rounds)
    _progress_summary(total_new, _progress_now_ms() - _pg_drill_t0)
    _ap_emit_summary()
    _omega_metric_hook("drill_complete")
}

// ─── E12-B (2026-04-21) — batch-shared Phase-1 init helpers ───
// seed 간 공유 가능 아이템을 1회 resolve:
//   (1) hexa_bin() — env("HEXA") + 3 후보 [ -x ] 스캔 결과.
//   (2) nexus_root() — env lookup.
//   (3) engine_id — _mkx_resolve_engine(flag) = 2~3 exec (file 존재 + grep).
//   (4) sigint trap — _recovery_sigint_install() 1회 install (_sigint_installed flag).
// 공유 불가 (seed 별 fresh):
//   - _iter_nonce / _nonce_seed (seed 입력 의존 + round 1 부터 independence 보장 필요)
//   - round_entropy_salt (round 별 fresh urand)
//   - checkpoint / LRU hash / ndjson / cross-iter log (seed-specific state)
// bypass: env NEXUS_BATCH_SHARE_INIT=0 → _batch_shared_init no-op.
fn _batch_share_bypass() -> bool {
    return env("NEXUS_BATCH_SHARE_INIT") == "0"
}

fn _batch_shared_init(engine_flag: str) -> void {
    // idempotent — 같은 배치 내 재호출 무해.
    if _batch_share_bypass() {
        eprintln("NEXUS_DRILL_BATCH_INIT {\"op\":\"bypass\",\"reason\":\"NEXUS_BATCH_SHARE_INIT=0\"}")
        return
    }
    if _batch_share_active { return }
    let t0 = _progress_now_ms()
    // (2) nexus_root prime — env 경로 resolve 고정 (1회 env lookup).
    let nr_env = env("NEXUS")
    let nr_val = if nr_env.len() > 0 { nr_env } else { env("HOME") + "/Dev/nexus" }
    _nexus_root_cache = nr_val
    _nexus_root_cache_set = true
    // (1) hexa_bin prime — candidate 스캔 1회.
    let h_env = env("HEXA")
    let mut hb = ""
    if h_env.len() > 0 {
        hb = h_env
    } else {
        let cands = [env("HOME") + "/Dev/hexa-lang/hexa", env("HOME") + "/.hx/bin/hexa", _nexus_root_cache + "/bin/hexa"]
        let mut i = 0
        while i < len(cands) {
            let c = cands[i]
            let chk = exec("[ -x '" + c + "' ] && echo y || echo n").trim()
            if chk == "y" { hb = c; break }
            i = i + 1
        }
        if hb.len() == 0 { hb = "hexa" }
    }
    _hexa_bin_cache = hb
    _hexa_bin_cache_set = true
    // (3) engine_id — 로그용 resolve (cmd_drill 은 flag/env 기반 재호출하지만 동일 입력 → 동일 결과).
    let eid = _mkx_resolve_engine(engine_flag)
    // (4) sigint install — 이후 per-seed drill 은 _sigint_installed flag 로 skip.
    _recovery_sigint_install()
    _batch_share_active = true
    let t1 = _progress_now_ms()
    let dt = _progress_ms_diff(t0, t1)
    eprintln("NEXUS_DRILL_BATCH_INIT {\"op\":\"shared\",\"hexa_bin\":\"" + _hexa_bin_cache
        + "\",\"nexus_root\":\"" + _nexus_root_cache
        + "\",\"engine\":\"" + eid
        + "\",\"sigint_installed\":" + (if _sigint_installed { "true" } else { "false" })
        + ",\"init_ms\":" + to_string(dt) + "}")
}

fn _batch_shared_cleanup() -> void {
    if _batch_share_bypass() { return }
    if !_batch_share_active { return }
    // sigint in-process flag 해제 — 다음 단일 drill 이 다시 install 하도록.
    // (cache 는 process 생애 동안 재사용 가능하므로 유지.)
    _batch_share_active = false
    _sigint_installed = false
    eprintln("NEXUS_DRILL_BATCH_INIT {\"op\":\"cleanup\"}")
}

// ─── omega — APEX (L_ω) orchestrator (2026-04-25) ───
// 사다리 위계: L1 atomic → L2 drill (round loop) → L3 fan-out → L4 super-orch → ... → L_ω omega.
// 의미: 「도달 가능한 최상위 통합 명령」. apex preset (depth=auto, speculate=3, adaptive=on) +
//       L3 다축 (multi-engine chain / multi-variant debate / multi-seed drill_batch) 자동 dispatch.
// 명명 근거: design/abstraction_ceiling.md — 그리스 Ω + 무한 서수 ω + Chaitin Ω 정보천장 3 축 매핑.
//
// dispatch priority (가장 넓은 axis 우선):
//   --engines 에 ',' (≥2) 있음     → cmd_chain     (L3 cross-engine)
//   else --variants ≥ 2            → debate script  (L3 N-variant adversarial)
//   else --seeds / --seeds-file    → cmd_drill_batch (L3 multi-seed)
//   else                            → cmd_drill      (L2 single-seed apex preset)
//
// emits:
//   NEXUS_OMEGA {"event":"dispatch", "axes":N, "path":"chain|debate|batch|drill", ...}
//   axes ≥ 3 일 때 "ghost_ceiling_approach" 추가 emit (3 axis 동시 활성 = 사다리 끝 근접 신호).
fn _omega_invoke_debate(seed: str, variants_n: int, max_rounds: str, engine_flag: str, preset: str) -> void {
    let script = nexus_root() + "/cli/drill/adversarial_debate.hexa"
    let chk = exec("[ -f '" + script + "' ] && echo y || echo n").trim()
    if chk != "y" {
        eprintln("NEXUS_OMEGA {\"status\":\"debate_script_missing\",\"path\":\"" + script + "\"}")
        return
    }
    let mut cmd = shell_quote(hexa_bin()) + " run " + shell_quote(script)
    cmd = cmd + " --seed " + shell_quote(seed)
    cmd = cmd + " --variants " + to_string(variants_n)
    cmd = cmd + " --arbitrate"
    if max_rounds.len() > 0 { cmd = cmd + " --max-rounds " + shell_quote(max_rounds) }
    if engine_flag.len() > 0 { cmd = cmd + " --engine " + shell_quote(engine_flag) }
    if preset.len() > 0 { cmd = cmd + " --preset " + shell_quote(preset) }
    print(exec(cmd + " 2>&1"))
}

fn cmd_omega(seed: str, max_rounds: str, engine_flag: str, preset: str, master_depth: str, per_stage_depths: [int], adaptive_flag: bool, resume_flag: bool, checkpoint_dir: str, problem: str, speculate_flag: str, variants_flag: str, engines_flag: str, seeds_flag: str, seeds_file: str) -> void {
    // apex defaults — user 가 명시한 값이 있으면 그대로 유지
    let _depth = if master_depth.len() > 0 { master_depth } else { "auto" }
    let _spec = if speculate_flag.len() > 0 { speculate_flag } else { "3" }
    // axis detection
    let mut variants_n: i64 = 1
    if variants_flag.len() > 0 {
        try { variants_n = to_int(variants_flag) } catch e { variants_n = 1 }
        if variants_n < 1 { variants_n = 1 }
    }
    let multi_engine = engines_flag.len() > 0 && engines_flag.contains(",")
    let multi_seed   = seeds_flag.len() > 0 || seeds_file.len() > 0
    let multi_variant = variants_n > 1
    let mut axes: i64 = 0
    if multi_engine  { axes = axes + 1 }
    if multi_variant { axes = axes + 1 }
    if multi_seed    { axes = axes + 1 }
    // dispatch path 결정
    let mut path = "drill"
    if multi_engine { path = "chain" }
    else if multi_variant { path = "debate" }
    else if multi_seed { path = "batch" }
    println("⊙ omega — APEX (L_ω) orchestration  axes=" + to_string(axes) + " path=" + path)
    // ─── cycle 13 dashboard pre-snapshot ───
    let _snap_path = nexus_root() + "/bisociation/spectra/g_atlas_composite_v3.json"
    if pfs_file_exists(_snap_path) {
        let mut _v3p: str = ""
        let mut _pass: str = ""
        try {
            let _raw = read_file(_snap_path).trim()
            let _key = "\"composite_v3_prime\":"
            let _p = _raw.index_of(_key)
            if _p >= 0 {
                let _rest = _raw.substring(_p + len(_key), len(_raw))
                let mut _i: int = 0
                while _i < len(_rest) {
                    let _c = _rest.substring(_i, _i + 1)
                    if _c == "," || _c == "}" { break }
                    _v3p = _v3p + _c
                    _i = _i + 1
                }
            }
            let _key2 = "\"paper_trigger_passed_v3_prime\":"
            let _p2 = _raw.index_of(_key2)
            if _p2 >= 0 {
                let _rest2 = _raw.substring(_p2 + len(_key2), len(_raw))
                let mut _j: int = 0
                while _j < len(_rest2) {
                    let _c = _rest2.substring(_j, _j + 1)
                    if _c == "," || _c == "}" { break }
                    _pass = _pass + _c
                    _j = _j + 1
                }
            }
        } catch e {} // @allow-silent-catch
        if _v3p.len() > 0 {
            let _flag = if _pass == "true" { "✓ PASS" } else { "· wait" }
            println("⊙ snapshot — composite_v3_prime=" + _v3p + " paper_trigger 0.9 " + _flag)
        }
    }
    eprintln("NEXUS_OMEGA {\"event\":\"dispatch\",\"axes\":" + to_string(axes)
        + ",\"path\":\"" + path + "\""
        + ",\"engines_multi\":" + (if multi_engine { "true" } else { "false" })
        + ",\"variants\":" + to_string(variants_n)
        + ",\"seeds_multi\":" + (if multi_seed { "true" } else { "false" })
        + ",\"depth\":\"" + _depth + "\""
        + ",\"speculate\":" + _spec + "}")
    if axes >= 3 {
        eprintln("NEXUS_OMEGA {\"event\":\"ghost_ceiling_approach\",\"reason\":\"all_3_L3_axes_active\",\"meaning\":\"사다리 L4 surge 영역 — L_ω 근접 신호\"}")
    }
    // 실제 dispatch
    if multi_engine {
        let _rc = cmd_chain(seed, engines_flag, "")
        eprintln("NEXUS_OMEGA {\"event\":\"complete\",\"path\":\"chain\",\"rc\":" + to_string(_rc) + "}")
        return
    }
    if multi_variant {
        _omega_invoke_debate(seed, variants_n, max_rounds, engine_flag, preset)
        eprintln("NEXUS_OMEGA {\"event\":\"complete\",\"path\":\"debate\",\"variants\":" + to_string(variants_n) + "}")
        return
    }
    if multi_seed {
        let batch_seeds = _seed_batch_load(seeds_flag, seeds_file)
        cmd_drill_batch(batch_seeds, max_rounds, engine_flag, preset, _depth, per_stage_depths, true, resume_flag, checkpoint_dir, problem, _spec)
        eprintln("NEXUS_OMEGA {\"event\":\"complete\",\"path\":\"batch\",\"seeds\":" + to_string(len(batch_seeds)) + "}")
        return
    }
    cmd_drill(seed, max_rounds, engine_flag, preset, _depth, per_stage_depths, true, resume_flag, checkpoint_dir, problem, _spec)
    eprintln("NEXUS_OMEGA {\"event\":\"complete\",\"path\":\"drill\"}")
    _omega_metric_hook("omega_complete")
}

// ─── surge — L4 super-orchestrator (2026-04-25) ───
// 사다리 위치: L4 (omega 의 sub-axis fan-out 형). omega 는 가장 넓은 axis 만 dispatch 하지만
// surge 는 (engines × variants × seeds) Cartesian product 로 모든 조합을 실행.
// 명명: design/abstraction_ceiling.md — multi-axis 동시 폭증 직설 (atlas bloom filter 와 충돌 회피).
//
// CAP 정책: 조합 폭주 차단 — total_runs > NEXUS_SURGE_MAX (기본 12) 시 reject + 가이드 emit.
// Mac 4GB RSS / hetzner 32GB 동시성 제약 고려. NEXUS_SURGE_MAX 로 override 가능.
//
// emits:
//   NEXUS_SURGE {"event":"plan", "engines":N, "variants":N, "seeds":N, "total_runs":N, "cap":N}
//   NEXUS_SURGE {"event":"run", "idx":i/N, "engine":"...", "variant":i, "seed_idx":i}
//   NEXUS_SURGE {"event":"complete", "ran":N, "errors":N, "total_abs":sum}
fn _surge_max_runs() -> int {
    let v = env("NEXUS_SURGE_MAX")
    if v.len() == 0 { return 12 }
    let mut n = 12
    try { n = to_int(v) } catch e { n = 12 }
    if n < 1 { return 1 }
    return n
}

fn cmd_surge(seed: str, max_rounds: str, engine_flag: str, preset: str, master_depth: str, per_stage_depths: [int], adaptive_flag: bool, resume_flag: bool, checkpoint_dir: str, problem: str, speculate_flag: str, variants_flag: str, engines_flag: str, seeds_flag: str, seeds_file: str) -> void {
    let _depth = if master_depth.len() > 0 { master_depth } else { "auto" }
    let _spec = if speculate_flag.len() > 0 { speculate_flag } else { "3" }
    // axis 추출 — empty 이면 단일 element 로 정규화
    let mut engines_arr: [str] = []
    if engines_flag.len() > 0 {
        let parts = engines_flag.split(",")
        let mut i = 0
        while i < len(parts) {
            let p = parts[i].trim()
            if p.len() > 0 { engines_arr = engines_arr + [p] }
            i = i + 1
        }
    }
    if len(engines_arr) == 0 { engines_arr = ["nexus"] }
    let mut variants_n: i64 = 1
    if variants_flag.len() > 0 {
        try { variants_n = to_int(variants_flag) } catch e { variants_n = 1 }
        if variants_n < 1 { variants_n = 1 }
    }
    let mut seeds_arr: [str] = []
    if seeds_flag.len() > 0 || seeds_file.len() > 0 {
        seeds_arr = _seed_batch_load(seeds_flag, seeds_file)
    }
    if len(seeds_arr) == 0 {
        if seed.trim().len() == 0 {
            eprintln("nexus surge: --seed 또는 --seeds 필수")
            return
        }
        seeds_arr = [seed]
    }
    let n_eng = len(engines_arr)
    let n_var = variants_n
    let n_seed = len(seeds_arr)
    let total = n_eng * n_var * n_seed
    let cap = _surge_max_runs()
    println("⊕ surge — L4 super-orchestrator  Cartesian (engines×variants×seeds) = " + to_string(n_eng) + "×" + to_string(n_var) + "×" + to_string(n_seed) + " = " + to_string(total) + " runs")
    eprintln("NEXUS_SURGE {\"event\":\"plan\",\"engines\":" + to_string(n_eng)
        + ",\"variants\":" + to_string(n_var)
        + ",\"seeds\":" + to_string(n_seed)
        + ",\"total_runs\":" + to_string(total)
        + ",\"cap\":" + to_string(cap) + "}")
    if total > cap {
        eprintln("NEXUS_SURGE {\"event\":\"reject\",\"reason\":\"total_runs_exceeds_cap\",\"total\":" + to_string(total) + ",\"cap\":" + to_string(cap) + ",\"hint\":\"NEXUS_SURGE_MAX env 으로 override 또는 axis 축소\"}")
        println("nexus surge: 조합 " + to_string(total) + " > cap " + to_string(cap) + " — NEXUS_SURGE_MAX env 으로 override 또는 axis 축소")
        return
    }
    let mut ran: i64 = 0
    let mut errors: i64 = 0
    let mut total_abs: i64 = 0
    let mut ei: i64 = 0
    while ei < n_eng {
        let _eng = engines_arr[ei]
        let mut vi: i64 = 0
        while vi < n_var {
            let mut si: i64 = 0
            while si < n_seed {
                let _sd = seeds_arr[si]
                ran = ran + 1
                println("─── surge run " + to_string(ran) + "/" + to_string(total) + " — engine=" + _eng + " variant=" + to_string(vi + 1) + "/" + to_string(n_var) + " seed_idx=" + to_string(si + 1) + "/" + to_string(n_seed) + " ───")
                eprintln("NEXUS_SURGE {\"event\":\"run\",\"idx\":" + to_string(ran) + ",\"of\":" + to_string(total)
                    + ",\"engine\":\"" + _eng + "\""
                    + ",\"variant\":" + to_string(vi + 1)
                    + ",\"seed_idx\":" + to_string(si + 1) + "}")
                // engine!=nexus 일 때 chain 1 회로 dispatch (seed + 단일 engine).
                // engine==nexus 일 때 drill (variant 차원은 speculate 로 흡수 — N-way fork).
                let var_spec = if n_var > 1 { to_string(n_var) } else { _spec }
                if _eng != "nexus" {
                    let _rc = cmd_chain(_sd, "nexus," + _eng, "")
                    if _rc != 0 { errors = errors + 1 }
                } else {
                    cmd_drill(_sd, max_rounds, engine_flag, preset, _depth, per_stage_depths, true, resume_flag, checkpoint_dir, problem, var_spec)
                }
                si = si + 1
            }
            vi = vi + 1
        }
        ei = ei + 1
    }
    eprintln("NEXUS_SURGE {\"event\":\"complete\",\"ran\":" + to_string(ran) + ",\"errors\":" + to_string(errors) + ",\"total_abs\":" + to_string(total_abs) + "}")
    println("⊕ surge complete — ran=" + to_string(ran) + " errors=" + to_string(errors))
}

// ─── dream — L5 self-seed orchestrator (2026-04-25) ───
// 사다리 위치: L5 (omega/surge 의 reflexive 형). 직전 iteration 의 출력에서 신호를 추출,
//   다음 iteration 의 seed 로 변환하여 self-seeded 루프 실행.
// 명명: design/abstraction_ceiling.md — 자기 자극으로 새 발현 (REM 의 seed 자율 생성 metaphor).
// 차별:
//   - drill (L2)  : seed 1 개 × N rounds
//   - omega (L_ω) : 1 회 dispatch (가장 넓은 axis)
//   - surge (L4)  : Cartesian product fan-out
//   - dream (L5)  : N iteration, seed_(i+1) = f(output_i) — feedback loop
//
// signal extraction (단순 MVP):
//   1) `unified_abs_total` 또는 `total=N` 파싱 → `prev_abs=K` 로 next seed 에 주입.
//   2) `[EXACT` / `[NEAR` 마커 카운트 → `signals=N` 로 주입.
//   3) seed 길이 [30, 200] 강제 — overflow 시 hash-prefix 로 압축.
//   parsing 실패 시 `(dream-iter-N)` suffix 만 부착 (deterministic perturbation).
//
// CAP: max iterations 기본 3. NEXUS_DREAM_MAX env override (안전 cap=10).
// emits:
//   NEXUS_DREAM {"event":"plan", "iterations":N}
//   NEXUS_DREAM {"event":"iter", "i":i/N, "seed_len":L, "extracted":{...}}
//   NEXUS_DREAM {"event":"complete", "iterations":N, "abs_history":[a,b,c]}
fn _dream_extract_signal(out: str) -> str {
    // 직전 출력에서 신호 추출 → JSON-ish payload 문자열 반환.
    let mut abs_total: i64 = -1
    let mut exact_n: i64 = 0
    let mut near_n: i64 = 0
    // 1) unified_abs_total 우선 (chain 출력)
    let idx = str_find(out, "unified_abs_total")
    if idx >= 0 {
        let mut i = idx + 17
        // skip non-digit
        let n = out.len()
        while i < n {
            let cc = char_code(out, i)
            if cc >= 48 && cc <= 57 { break }
            if cc == 10 { break }
            i = i + 1
        }
        if i < n {
            let mut buf = ""
            while i < n {
                let cc = char_code(out, i)
                if cc >= 48 && cc <= 57 {
                    buf = buf + out.substring(i, i + 1)
                    i = i + 1
                } else { break }
            }
            if buf.len() > 0 {
                try { abs_total = to_int(buf) } catch e { abs_total = -1 }
            }
        }
    }
    // 2) drill `total=N` (cmd_drill 의 round 별 총합 출력) — 마지막 매치 사용
    if abs_total < 0 {
        let mut t = out
        let mut last_total: i64 = -1
        while true {
            let _idx = str_find(t, "total=")
            if _idx < 0 { break }
            let mut i = _idx + 6
            let n = t.len()
            let mut buf = ""
            while i < n {
                let cc = char_code(t, i)
                if cc >= 48 && cc <= 57 {
                    buf = buf + t.substring(i, i + 1)
                    i = i + 1
                } else { break }
            }
            if buf.len() > 0 {
                try { last_total = to_int(buf) } catch e {}
            }
            t = t.substring(_idx + 6, t.len())
        }
        if last_total >= 0 { abs_total = last_total }
    }
    // 3) marker 카운트
    exact_n = _count_marker(out, "[EXACT")
    near_n  = _count_marker(out, "[NEAR")
    let mut payload = "abs=" + to_string(abs_total) + ",ex=" + to_string(exact_n) + ",ne=" + to_string(near_n)
    return payload
}

fn _dream_next_seed(orig: str, iter_idx: i64, signal: str) -> str {
    // next seed = "{trunc_orig} #dream-iter={N}#{signal}"
    // cap = NEXUS_SEED_CAP (기본 280, [30, 1000] clamp) — _seed_clamp 와 일치.
    // 자기-합성단 (dream/wake/molt 가 호출) 도 입력단과 동일 cap 적용.
    let suffix = " #dream-iter=" + to_string(iter_idx) + " " + signal
    let cap_env = env("NEXUS_SEED_CAP")
    let mut cap: i64 = 280
    if cap_env.len() > 0 {
        try { cap = to_int(cap_env) } catch e { cap = 280 }
    }
    if cap < 30 { cap = 30 }
    if cap > 1000 { cap = 1000 }
    let max_main = cap - suffix.len()
    let mut main = orig
    if main.len() > max_main {
        if max_main < 1 { main = "" } else { main = main.substring(0, max_main) }
    }
    let combined = main + suffix
    return combined
}

fn _dream_max_iters() -> int {
    let v = env("NEXUS_DREAM_MAX")
    if v.len() == 0 { return 3 }
    let mut n = 3
    try { n = to_int(v) } catch e { n = 3 }
    if n < 1 { return 1 }
    if n > 10 { return 10 }
    return n
}

fn cmd_dream(seed: str, iterations_flag: str, max_rounds: str, engine_flag: str, preset: str, master_depth: str, per_stage_depths: [int], resume_flag: bool, checkpoint_dir: str, problem: str, speculate_flag: str) -> void {
    let _seed_t = seed.trim()
    if _seed_t.len() == 0 {
        eprintln("nexus dream: --seed required — initial seed 필수")
        return
    }
    let cap = _dream_max_iters()
    let mut iters = 3
    if iterations_flag.len() > 0 {
        try { iters = to_int(iterations_flag) } catch e { iters = 3 }
        if iters < 1 { iters = 1 }
        if iters > cap { iters = cap }
    } else {
        iters = if cap < 3 { cap } else { 3 }
    }
    println("◇ dream — L5 self-seed orchestration (iterations=" + to_string(iters) + ", cap=" + to_string(cap) + ")")
    eprintln("NEXUS_DREAM {\"event\":\"plan\",\"iterations\":" + to_string(iters) + ",\"cap\":" + to_string(cap) + "}")
    let _depth = if master_depth.len() > 0 { master_depth } else { "auto" }
    let _spec = if speculate_flag.len() > 0 { speculate_flag } else { "3" }
    let mut current = _seed_t
    let mut i: i64 = 0
    while i < iters {
        i = i + 1
        println("─── dream iter " + to_string(i) + "/" + to_string(iters) + " — seed_len=" + to_string(current.len()) + " ───")
        // omega-style 단일 dispatch: drill apex preset 으로 1 회 실행 (axis 합성은 미사용 — 단순화).
        // out 캡처 위해 직접 hexa run 호출 + exec().
        let core = nexus_root() + "/cli/blowup/core/blowup.hexa"
        let qs = shell_quote(current)
        let cmd = shell_quote(hexa_bin()) + " run " + shell_quote(core) + " " + qs + " 1 --fast 2>&1"
        let out = exec(cmd)
        print(out)
        let signal = _dream_extract_signal(out)
        eprintln("NEXUS_DREAM {\"event\":\"iter\",\"i\":" + to_string(i) + ",\"of\":" + to_string(iters)
            + ",\"seed_len\":" + to_string(current.len())
            + ",\"signal\":\"" + signal + "\"}")
        if i < iters {
            current = _dream_next_seed(_seed_t, i + 1, signal)
        }
    }
    eprintln("NEXUS_DREAM {\"event\":\"complete\",\"iterations\":" + to_string(iters) + "}")
    println("◇ dream complete — iterations=" + to_string(iters))
}

// ─── reign — L6 autonomous orchestrator (2026-04-25) ───
// 사다리 위치: L6 (dream 위 자율층). dream 은 fixed iter count, reign 은 자율 종료
//   판정 — 직전 K cycle 동안 signal 이 stagnant 하면 saturation 으로 자동 STOP.
// 명명: design/abstraction_ceiling.md — 「휴면-각성 자율」, 사람 개입 없이 자기 결정.
//
// 차별:
//   - dream  (L5): iterations=N 명시 필요, N 회 고정 반복
//   - reign  (L6): max_cycles 는 cap, 실제 종료는 「signal stagnation」 으로 자동 판정
//
// stagnation 판정: 최근 K 개 signal 이 동일 → saturation. K 는 고정 2 (NEXUS_REIGN_K env override).
// CAP: max_cycles 기본 10, NEXUS_REIGN_MAX env override (안전 ceiling=20).
//
// emits:
//   NEXUS_REIGN {"event":"plan","max_cycles":N,"stagnation_k":K}
//   NEXUS_REIGN {"event":"iter","cycle":i/N,"signal":"...","history_len":n}
//   NEXUS_REIGN {"event":"saturation","cycle":i,"reason":"signal_stagnant","k":K}
//   NEXUS_REIGN {"event":"complete","cycles_run":n,"saturated":bool}
fn _reign_max_cycles() -> int {
    let v = env("NEXUS_REIGN_MAX")
    if v.len() == 0 { return 10 }
    let mut n = 10
    try { n = to_int(v) } catch e { n = 10 }
    if n < 1 { return 1 }
    if n > 20 { return 20 }
    return n
}

fn _reign_stagnation_k() -> int {
    let v = env("NEXUS_REIGN_K")
    if v.len() == 0 { return 2 }
    let mut n = 2
    try { n = to_int(v) } catch e { n = 2 }
    if n < 2 { return 2 }
    if n > 5 { return 5 }
    return n
}

fn _reign_signal_stagnant(history: [str], k: int) -> bool {
    let n = len(history)
    if n < k { return false }
    let last = history[n - 1]
    let mut i = n - k
    while i < n - 1 {
        if history[i] != last { return false }
        i = i + 1
    }
    return true
}

fn cmd_reign(seed: str, max_cycles_flag: str) -> void {
    let _seed_t = seed.trim()
    if _seed_t.len() == 0 {
        eprintln("nexus reign: --seed required — initial seed 필수")
        return
    }
    let cap = _reign_max_cycles()
    let stagnation_k = _reign_stagnation_k()
    let mut max_cycles = cap
    if max_cycles_flag.len() > 0 {
        try { max_cycles = to_int(max_cycles_flag) } catch e { max_cycles = cap }
        if max_cycles < 1 { max_cycles = 1 }
        if max_cycles > cap { max_cycles = cap }
    }
    println("⊚ reign — L6 autonomous orchestration (max_cycles=" + to_string(max_cycles) + ", stagnation_k=" + to_string(stagnation_k) + ")")
    eprintln("NEXUS_REIGN {\"event\":\"plan\",\"max_cycles\":" + to_string(max_cycles) + ",\"stagnation_k\":" + to_string(stagnation_k) + ",\"cap\":" + to_string(cap) + "}")
    let core = nexus_root() + "/cli/blowup/core/blowup.hexa"
    let mut current = _seed_t
    let mut history: [str] = []
    let mut cycles_run: i64 = 0
    let mut saturated = false
    let mut cycle: i64 = 0
    while cycle < max_cycles {
        cycle = cycle + 1
        cycles_run = cycle
        println("─── reign cycle " + to_string(cycle) + "/" + to_string(max_cycles) + " — seed_len=" + to_string(current.len()) + " ───")
        let qs = shell_quote(current)
        let cmd = shell_quote(hexa_bin()) + " run " + shell_quote(core) + " " + qs + " 1 --fast 2>&1"
        let out = exec(cmd)
        print(out)
        let signal = _dream_extract_signal(out)
        history = history + [signal]
        eprintln("NEXUS_REIGN {\"event\":\"iter\",\"cycle\":" + to_string(cycle)
            + ",\"of\":" + to_string(max_cycles)
            + ",\"signal\":\"" + signal + "\""
            + ",\"history_len\":" + to_string(len(history)) + "}")
        if _reign_signal_stagnant(history, stagnation_k) {
            saturated = true
            eprintln("NEXUS_REIGN {\"event\":\"saturation\",\"cycle\":" + to_string(cycle)
                + ",\"reason\":\"signal_stagnant\",\"k\":" + to_string(stagnation_k)
                + ",\"signal\":\"" + signal + "\"}")
            println("⊚ reign — autonomous STOP (signal stagnant " + to_string(stagnation_k) + " cycles): " + signal)
            cycle = max_cycles  // break
            continue
        }
        current = _dream_next_seed(_seed_t, cycle + 1, signal)
    }
    eprintln("NEXUS_REIGN {\"event\":\"complete\",\"cycles_run\":" + to_string(cycles_run) + ",\"saturated\":" + (if saturated { "true" } else { "false" }) + "}")
    println("⊚ reign complete — cycles=" + to_string(cycles_run) + " saturated=" + (if saturated { "true" } else { "false" }))
}

// ─── swarm — L7 population orchestrator (2026-04-25) ───
// 사다리 위치: L7 (reign 위 ecology 층). 단일 에이전트 (reign) 가 아닌 군집 N 개체가
//   동시 진화 — perturbed population × generations × elitism. fittest survives.
// 명명: design/abstraction_ceiling.md — 군집 동시성, 자연 선택 metaphor.
//
// 차별:
//   - reign (L6) : 단일 에이전트 자율 종료
//   - swarm (L7) : 다중 에이전트 군집, generation 별 elitism + breeding
//
// 알고리즘 (간이 evolutionary):
//   gen 1: population[i] = perturb(seed, i) for i in 0..N
//   gen g: scores = [run_blowup(p).abs for p in population]
//          sort population by score desc
//          elite = top N/2
//          children = breed(elite[0], elite[1]) ... 채워서 N
//          population = elite + children
//
// CAP: population × generations ≤ NEXUS_SWARM_MAX (기본 12).
//      population [2,8], generations [1,5].
// emits:
//   NEXUS_SWARM {"event":"plan","population":N,"generations":G,"total_runs":N×G}
//   NEXUS_SWARM {"event":"gen","g":i/G,"scores":[s1,s2,...],"best":max}
//   NEXUS_SWARM {"event":"complete","best_score":N,"best_seed_idx":i}
fn _swarm_max_runs() -> int {
    let v = env("NEXUS_SWARM_MAX")
    if v.len() == 0 { return 12 }
    let mut n = 12
    try { n = to_int(v) } catch e { n = 12 }
    if n < 1 { return 1 }
    return n
}

fn _swarm_perturb_seed(orig: str, idx: i64) -> str {
    // gen 1 의 i 번째 individual 생성 — orig 에 deterministic suffix 추가.
    let suffix = " #swarm-i=" + to_string(idx)
    let max_main = 200 - suffix.len()
    let mut main = orig
    if main.len() > max_main {
        if max_main < 1 { main = "" } else { main = main.substring(0, max_main) }
    }
    return main + suffix
}

fn _swarm_breed(orig: str, gen: i64, child_idx: i64, parent1_score: i64, parent2_score: i64) -> str {
    // 두 부모 score 를 결합한 deterministic suffix.
    let suffix = " #swarm-g=" + to_string(gen) + "-c=" + to_string(child_idx) + "-p=" + to_string(parent1_score) + "+" + to_string(parent2_score)
    let max_main = 200 - suffix.len()
    let mut main = orig
    if main.len() > max_main {
        if max_main < 1 { main = "" } else { main = main.substring(0, max_main) }
    }
    return main + suffix
}

fn _swarm_extract_abs(signal: str) -> int {
    // signal = "abs=K,ex=M,ne=L" — abs 값만 추출
    let idx = str_find(signal, "abs=")
    if idx < 0 { return 0 }
    let mut i = idx + 4
    let n = signal.len()
    let mut buf = ""
    let mut neg = false
    if i < n && char_code(signal, i) == 45 { neg = true; i = i + 1 }  // '-'
    while i < n {
        let cc = char_code(signal, i)
        if cc >= 48 && cc <= 57 {
            buf = buf + signal.substring(i, i + 1)
            i = i + 1
        } else { break }
    }
    if buf.len() == 0 { return 0 }
    let mut v: i64 = 0
    try { v = to_int(buf) } catch e { v = 0 }
    if neg { v = 0 - v }
    return v
}

fn cmd_swarm(seed: str, population_flag: str, generations_flag: str) -> void {
    let _seed_t = seed.trim()
    if _seed_t.len() == 0 {
        eprintln("nexus swarm: --seed required")
        return
    }
    let cap = _swarm_max_runs()
    let mut pop_n: i64 = 4
    if population_flag.len() > 0 {
        try { pop_n = to_int(population_flag) } catch e { pop_n = 4 }
    }
    if pop_n < 2 { pop_n = 2 }
    if pop_n > 8 { pop_n = 8 }
    let mut gens: i64 = 3
    if generations_flag.len() > 0 {
        try { gens = to_int(generations_flag) } catch e { gens = 3 }
    }
    if gens < 1 { gens = 1 }
    if gens > 5 { gens = 5 }
    let total = pop_n * gens
    if total > cap {
        eprintln("NEXUS_SWARM {\"event\":\"reject\",\"reason\":\"total_runs_exceeds_cap\",\"total\":" + to_string(total) + ",\"cap\":" + to_string(cap) + "}")
        println("nexus swarm: " + to_string(total) + " > cap " + to_string(cap) + " — population/generations 축소 또는 NEXUS_SWARM_MAX 상향")
        return
    }
    println("⌬ swarm — L7 population orchestration (population=" + to_string(pop_n) + ", generations=" + to_string(gens) + ", total=" + to_string(total) + ")")
    eprintln("NEXUS_SWARM {\"event\":\"plan\",\"population\":" + to_string(pop_n) + ",\"generations\":" + to_string(gens) + ",\"total_runs\":" + to_string(total) + ",\"cap\":" + to_string(cap) + "}")
    let core = nexus_root() + "/cli/blowup/core/blowup.hexa"
    // gen 1 population: perturb(seed, i) for i in 0..N
    let mut population: [str] = []
    let mut scores: [int] = []
    let mut k: i64 = 0
    while k < pop_n {
        population = population + [_swarm_perturb_seed(_seed_t, k)]
        scores = scores + [0]
        k = k + 1
    }
    let mut best_score: i64 = 0
    let mut best_seed: str = population[0]
    let mut best_gen: i64 = 0
    let mut g: i64 = 0
    while g < gens {
        g = g + 1
        println("─── swarm generation " + to_string(g) + "/" + to_string(gens) + " ───")
        // evaluate each individual
        let mut i: i64 = 0
        while i < pop_n {
            let qs = shell_quote(population[i])
            let cmd = shell_quote(hexa_bin()) + " run " + shell_quote(core) + " " + qs + " 1 --fast 2>&1"
            let out = exec(cmd)
            let signal = _dream_extract_signal(out)
            let abs_v = _swarm_extract_abs(signal)
            scores[i] = abs_v
            if abs_v > best_score {
                best_score = abs_v
                best_seed = population[i]
                best_gen = g
            }
            println("  individual " + to_string(i) + ": signal=" + signal + " abs=" + to_string(abs_v))
            i = i + 1
        }
        // emit gen scores
        let mut sj = ""
        let mut sij: i64 = 0
        while sij < pop_n {
            if sj.len() > 0 { sj = sj + "," }
            sj = sj + to_string(scores[sij])
            sij = sij + 1
        }
        eprintln("NEXUS_SWARM {\"event\":\"gen\",\"g\":" + to_string(g) + ",\"of\":" + to_string(gens) + ",\"scores\":[" + sj + "],\"best\":" + to_string(best_score) + "}")
        if g >= gens { continue }  // 마지막 세대는 breeding 없이 종료
        // selection + breeding: 단순 sorting bypass (hexa array sort 미보장) — best 2 만 추출 후 자녀 재합성
        let mut top1_idx: i64 = 0
        let mut top1_score: i64 = scores[0]
        let mut top2_idx: i64 = 0
        let mut top2_score: i64 = -1
        let mut p: i64 = 1
        while p < pop_n {
            if scores[p] > top1_score {
                top2_idx = top1_idx
                top2_score = top1_score
                top1_idx = p
                top1_score = scores[p]
            } else if scores[p] > top2_score {
                top2_idx = p
                top2_score = scores[p]
            }
            p = p + 1
        }
        // 새 population = [top1, top2] + breed(top1, top2) × (N-2)
        let mut new_pop: [str] = []
        new_pop = new_pop + [population[top1_idx]]
        new_pop = new_pop + [population[top2_idx]]
        let mut c: i64 = 0
        while len(new_pop) < pop_n {
            new_pop = new_pop + [_swarm_breed(_seed_t, g + 1, c, top1_score, top2_score + c)]
            c = c + 1
        }
        population = new_pop
    }
    eprintln("NEXUS_SWARM {\"event\":\"complete\",\"best_score\":" + to_string(best_score) + ",\"best_gen\":" + to_string(best_gen) + ",\"generations_run\":" + to_string(gens) + "}")
    println("⌬ swarm complete — best_score=" + to_string(best_score) + " best_gen=" + to_string(best_gen) + " generations=" + to_string(gens))
}

// ─── wake — L8 reality-loop orchestrator (2026-04-25) ───
// 사다리 위치: L8 (swarm 위 reality-coupling 층). 엔진 내부 signal 만 보지 않고
//   외부 파일 (atlas health, growth bus, user-supplied)의 fingerprint 변화를
//   감지해 「외부 신호 변화 시에만 fire」 하는 자동 트리거.
// 명명: design/abstraction_ceiling.md — 외부 측정 피드백, 「깨어남」 metaphor.
//
// 차별:
//   - swarm (L7) : 군집 자체로 진화 (외부 무관)
//   - wake  (L8) : 외부 signal 변화로만 진동 — 외부 세계와 결합
//
// fingerprint = "<bytes>:<head256_first64chars>" — 파일 변하면 fp 변함.
// 알고리즘:
//   gen 1 fp = read(signal_file)
//   loop max_cycles:
//     sleep cooldown
//     cur_fp = read(signal_file)
//     if cur_fp != prev_fp: fire blowup → record signal → prev_fp = cur_fp
//     else: skip (no external change)
//
// CAP: max_cycles 기본 5, NEXUS_WAKE_MAX env override (안전 ceiling=10).
// signal_file: --signal-file 플래그 > NEXUS_WAKE_SIGNAL_FILE env > state/atlas_health.json default.
// cooldown: NEXUS_WAKE_COOLDOWN_SEC 기본 0 (즉시), 양수면 sleep.
//
// emits:
//   NEXUS_WAKE {"event":"plan","signal_file":"...","max_cycles":N,"cooldown":N}
//   NEXUS_WAKE {"event":"iter","cycle":i/N,"fp":"...","changed":bool}
//   NEXUS_WAKE {"event":"fire","cycle":i,"signal":"abs=K,..."}
//   NEXUS_WAKE {"event":"skip","cycle":i,"reason":"fp_unchanged"}
//   NEXUS_WAKE {"event":"complete","cycles_run":N,"fires":N,"skips":N}
fn _wake_max_cycles() -> int {
    let v = env("NEXUS_WAKE_MAX")
    if v.len() == 0 { return 5 }
    let mut n = 5
    try { n = to_int(v) } catch e { n = 5 }
    if n < 1 { return 1 }
    if n > 10 { return 10 }
    return n
}

fn _wake_cooldown_sec() -> int {
    let v = env("NEXUS_WAKE_COOLDOWN_SEC")
    if v.len() == 0 { return 0 }
    let mut n = 0
    try { n = to_int(v) } catch e { n = 0 }
    if n < 0 { return 0 }
    if n > 60 { return 60 }
    return n
}

fn _wake_default_signal_file() -> str {
    let v = env("NEXUS_WAKE_SIGNAL_FILE")
    if v.len() > 0 { return v }
    return nexus_root() + "/state/atlas_health.json"
}

fn _wake_read_fp(path: str) -> str {
    // fingerprint = "<size_bytes>:<head_first_64_chars>". MISSING 시 "MISSING".
    let q = shell_quote(path)
    let chk = exec("[ -f " + q + " ] && echo Y || echo N").trim()
    if chk != "Y" { return "MISSING" }
    let sz = exec("wc -c < " + q + " 2>/dev/null").trim()
    let head = exec("head -c 256 " + q + " 2>/dev/null | tr -d '\\n\\r' | head -c 64").trim()
    return sz + ":" + head
}

fn cmd_wake(seed: str, signal_file_flag: str, max_cycles_flag: str) -> void {
    let _seed_t = seed.trim()
    if _seed_t.len() == 0 {
        eprintln("nexus wake: --seed required")
        return
    }
    let cap = _wake_max_cycles()
    let mut max_cycles = cap
    if max_cycles_flag.len() > 0 {
        try { max_cycles = to_int(max_cycles_flag) } catch e { max_cycles = cap }
        if max_cycles < 1 { max_cycles = 1 }
        if max_cycles > cap { max_cycles = cap }
    }
    let signal_file = if signal_file_flag.len() > 0 { signal_file_flag } else { _wake_default_signal_file() }
    let cooldown = _wake_cooldown_sec()
    println("◐ wake — L8 reality-loop (signal_file=" + signal_file + ", max_cycles=" + to_string(max_cycles) + ", cooldown=" + to_string(cooldown) + "s)")
    eprintln("NEXUS_WAKE {\"event\":\"plan\",\"signal_file\":\"" + signal_file + "\",\"max_cycles\":" + to_string(max_cycles) + ",\"cooldown\":" + to_string(cooldown) + ",\"cap\":" + to_string(cap) + "}")
    let core = nexus_root() + "/cli/blowup/core/blowup.hexa"
    let mut prev_fp: str = ""
    let mut fires: i64 = 0
    let mut skips: i64 = 0
    let mut cycles_run: i64 = 0
    let mut cycle: i64 = 0
    while cycle < max_cycles {
        cycle = cycle + 1
        cycles_run = cycle
        if cooldown > 0 && cycle > 1 {
            exec("sleep " + to_string(cooldown))
        }
        let cur_fp = _wake_read_fp(signal_file)
        let changed = (cur_fp != prev_fp) && (cur_fp != "MISSING")
        let fp_short = if cur_fp.len() > 40 { cur_fp.substring(0, 40) + "..." } else { cur_fp }
        println("─── wake cycle " + to_string(cycle) + "/" + to_string(max_cycles) + " — fp=" + fp_short + " changed=" + (if changed { "true" } else { "false" }) + " ───")
        eprintln("NEXUS_WAKE {\"event\":\"iter\",\"cycle\":" + to_string(cycle) + ",\"of\":" + to_string(max_cycles) + ",\"fp\":\"" + fp_short + "\",\"changed\":" + (if changed { "true" } else { "false" }) + "}")
        if !changed {
            skips = skips + 1
            eprintln("NEXUS_WAKE {\"event\":\"skip\",\"cycle\":" + to_string(cycle) + ",\"reason\":\"fp_unchanged_or_missing\"}")
            prev_fp = cur_fp
            continue
        }
        // fire — fp 와 cycle 을 seed 에 주입해 deterministic perturb
        let perturbed = _dream_next_seed(_seed_t, cycle, "wake-fp-cycle=" + to_string(cycle))
        let qs = shell_quote(perturbed)
        let cmd = shell_quote(hexa_bin()) + " run " + shell_quote(core) + " " + qs + " 1 --fast 2>&1"
        let out = exec(cmd)
        print(out)
        let signal = _dream_extract_signal(out)
        fires = fires + 1
        eprintln("NEXUS_WAKE {\"event\":\"fire\",\"cycle\":" + to_string(cycle) + ",\"signal\":\"" + signal + "\"}")
        prev_fp = cur_fp
    }
    eprintln("NEXUS_WAKE {\"event\":\"complete\",\"cycles_run\":" + to_string(cycles_run) + ",\"fires\":" + to_string(fires) + ",\"skips\":" + to_string(skips) + "}")
    println("◐ wake complete — cycles=" + to_string(cycles_run) + " fires=" + to_string(fires) + " skips=" + to_string(skips))
}

// ─── molt — L9 self-rewrite orchestrator (2026-04-25) ───
// 사다리 위치: L9 (wake 위 self-rewrite 층). 「엔진이 자기 파라미터를 진화」 — skin 변경.
// 명명: design/abstraction_ceiling.md — 「허물 벗기」 metaphor (생물학적 self-modification).
//
// 차별:
//   - wake (L8) : 외부 신호로 fire (외부 결합)
//   - molt (L9) : skin (engine 파라미터) 자체를 시도-수정-기억 (자기 코드 진화의 안전 sandbox)
//
// skin = (depth, fast_mode) 튜플. molt 가 N skin 을 순회하며 best abs 시드/스킨 발견.
// 영속: best skin 을 NEXUS_MOLT_SKIN_FILE (env, 기본 /tmp/nexus_molt_skin.json) 에 기록 →
//   다음 invocation 에서 starting skin 으로 재사용 가능 (다른 명령 외부 도구가 읽음).
//
// CAP: skins 최대 5 (hardcoded array). max_cycles 로 자른 첫 N skin 만 실행.
// emits:
//   NEXUS_MOLT {"event":"plan","skins":N,"max_cycles":N}
//   NEXUS_MOLT {"event":"iter","i":i/N,"skin":{"depth":D,"fast":bool},"signal":"...","abs":N}
//   NEXUS_MOLT {"event":"complete","best_skin_idx":i,"best_skin":{"depth":D,"fast":bool},"best_abs":N}
fn _molt_skin_file() -> str {
    let v = env("NEXUS_MOLT_SKIN_FILE")
    if v.len() > 0 { return v }
    return "/tmp/nexus_molt_skin.json"
}

fn _molt_max_cycles() -> int {
    let v = env("NEXUS_MOLT_MAX")
    if v.len() == 0 { return 5 }
    let mut n = 5
    try { n = to_int(v) } catch e { n = 5 }
    if n < 1 { return 1 }
    if n > 5 { return 5 }
    return n
}

fn cmd_molt(seed: str, max_cycles_flag: str) -> void {
    let _seed_t = seed.trim()
    if _seed_t.len() == 0 {
        eprintln("nexus molt: --seed required")
        return
    }
    // 5 hardcoded skins — depth × fast 직교. 검증 가능한 범위로 한정.
    let skin_depths = [1, 1, 2, 2, 3]
    let skin_fast   = [true, true, true, false, false]
    let n_skins_total = 5
    let cap = _molt_max_cycles()
    let mut max_c = cap
    if max_cycles_flag.len() > 0 {
        try { max_c = to_int(max_cycles_flag) } catch e { max_c = cap }
        if max_c < 1 { max_c = 1 }
        if max_c > cap { max_c = cap }
    }
    let n_skins = if max_c < n_skins_total { max_c } else { n_skins_total }
    println("◑ molt — L9 self-rewrite (skins=" + to_string(n_skins) + "/" + to_string(n_skins_total) + ", cap=" + to_string(cap) + ")")
    eprintln("NEXUS_MOLT {\"event\":\"plan\",\"skins\":" + to_string(n_skins) + ",\"total_skins\":" + to_string(n_skins_total) + ",\"cap\":" + to_string(cap) + "}")
    let core = nexus_root() + "/cli/blowup/core/blowup.hexa"
    let mut best_abs: i64 = 0
    let mut best_skin_idx: i64 = 0
    let mut best_signal: str = ""
    let mut i: i64 = 0
    while i < n_skins {
        let d = skin_depths[i]
        let f = skin_fast[i]
        let f_str = if f { "1" } else { "0" }
        let perturbed = _dream_next_seed(_seed_t, i + 1, "molt-skin=" + to_string(i) + ":d=" + to_string(d) + ":f=" + f_str)
        println("─── molt skin " + to_string(i + 1) + "/" + to_string(n_skins) + " — depth=" + to_string(d) + " fast=" + (if f { "true" } else { "false" }) + " ───")
        let qs = shell_quote(perturbed)
        let mut cmd = shell_quote(hexa_bin()) + " run " + shell_quote(core) + " " + qs + " " + to_string(d)
        if f { cmd = cmd + " --fast" }
        cmd = cmd + " 2>&1"
        let out = exec(cmd)
        let signal = _dream_extract_signal(out)
        let abs_v = _swarm_extract_abs(signal)
        eprintln("NEXUS_MOLT {\"event\":\"iter\",\"i\":" + to_string(i + 1) + ",\"of\":" + to_string(n_skins)
            + ",\"skin\":{\"depth\":" + to_string(d) + ",\"fast\":" + (if f { "true" } else { "false" }) + "}"
            + ",\"signal\":\"" + signal + "\""
            + ",\"abs\":" + to_string(abs_v) + "}")
        println("  signal=" + signal + " abs=" + to_string(abs_v))
        if abs_v > best_abs {
            best_abs = abs_v
            best_skin_idx = i
            best_signal = signal
        }
        i = i + 1
    }
    let best_d = skin_depths[best_skin_idx]
    let best_f = skin_fast[best_skin_idx]
    // best skin 영속 — JSON 한 줄.
    let skin_path = _molt_skin_file()
    let json = "{\"best_skin_idx\":" + to_string(best_skin_idx)
        + ",\"depth\":" + to_string(best_d)
        + ",\"fast\":" + (if best_f { "true" } else { "false" })
        + ",\"abs\":" + to_string(best_abs)
        + ",\"signal\":\"" + best_signal + "\""
        + ",\"timestamp\":\"2026-04-25\"}"
    let write_cmd = "printf '%s\\n' " + shell_quote(json) + " > " + shell_quote(skin_path)
    exec(write_cmd)
    eprintln("NEXUS_MOLT {\"event\":\"complete\",\"best_skin_idx\":" + to_string(best_skin_idx)
        + ",\"best_skin\":{\"depth\":" + to_string(best_d) + ",\"fast\":" + (if best_f { "true" } else { "false" }) + "}"
        + ",\"best_abs\":" + to_string(best_abs)
        + ",\"persisted\":\"" + skin_path + "\"}")
    println("◑ molt complete — best_skin_idx=" + to_string(best_skin_idx) + " (depth=" + to_string(best_d) + " fast=" + (if best_f { "true" } else { "false" }) + ") best_abs=" + to_string(best_abs) + " → " + skin_path)
}

// ─── forge — L10 bootstrap orchestrator (2026-04-25) ───
// 사다리 위치: L10 (molt 위 bootstrap 층). 「자기 부팅」 — engine 이 자기 상태 파일들을
//   읽어 seed/config 를 합성, 사용자 입력 없이도 의미 있는 작업 시작. creator → creation.
// 명명: design/abstraction_ceiling.md — 「단조/부팅」 (raw 영단어, 형상 잡기 + boot strap).
//
// 차별:
//   - molt (L9)  : skin 자기 진화 (parameter 만)
//   - forge (L10): 모든 자기 상태 (molt skin + atlas health + …) 읽고 다음 동작 자기 결정
//
// 자기 상태 소스 (우선순위):
//   1) molt skin file (NEXUS_MOLT_SKIN_FILE 또는 /tmp/nexus_molt_skin.json) — best skin 적용
//   2) atlas health (state/atlas_health.json) — 크기 기반 health hint 주입
//   3) timestamp (date +%Y%m%d-%H%M%S) — uniqueness
//   4) (옵션) --seed flag — 사용자 augment 입력 (없으면 bootstrap from scratch)
//
// 합성 seed:
//   if --seed: orig + " #forge-boot={ts} skin=d{D}{f|s} atlas={B}B"
//   else:      "nexus forge bootstrap {ts} skin=d{D}{f|s} atlas={B}B — self-derived seed for autonomous boot"
//
// emits:
//   NEXUS_FORGE {"event":"plan","seed_provided":bool,"skin_present":bool,"atlas_present":bool}
//   NEXUS_FORGE {"event":"boot","seed":"...","skin":{"depth":D,"fast":bool},"atlas_bytes":B,"timestamp":"..."}
//   NEXUS_FORGE {"event":"complete","status":"dispatched_to_drill"}
fn _forge_read_file_content(path: str) -> str {
    let q = shell_quote(path)
    let chk = exec("[ -f " + q + " ] && echo Y || echo N").trim()
    if chk != "Y" { return "" }
    return exec("cat " + q + " 2>/dev/null").trim()
}

fn _forge_extract_json_int(json: str, key: str) -> int {
    // "key":N 패턴에서 N 추출. 실패 시 -1.
    let needle = "\"" + key + "\":"
    let idx = str_find(json, needle)
    if idx < 0 { return -1 }
    let mut i = idx + needle.len()
    let n = json.len()
    let mut neg = false
    if i < n && char_code(json, i) == 45 { neg = true; i = i + 1 }  // '-'
    let mut buf = ""
    while i < n {
        let cc = char_code(json, i)
        if cc >= 48 && cc <= 57 {
            buf = buf + json.substring(i, i + 1)
            i = i + 1
        } else { break }
    }
    if buf.len() == 0 { return -1 }
    let mut v: i64 = 0
    try { v = to_int(buf) } catch e { v = -1 }
    if neg { v = 0 - v }
    return v
}

fn _forge_extract_json_bool(json: str, key: str) -> bool {
    // "key":true|false. 기본 false.
    let needle = "\"" + key + "\":"
    let idx = str_find(json, needle)
    if idx < 0 { return false }
    let i = idx + needle.len()
    if i + 4 > json.len() { return false }
    let head = json.substring(i, i + 4)
    if head == "true" { return true }
    return false
}

fn cmd_forge(seed_flag: str, max_rounds_flag: str) -> void {
    let _seed_t = seed_flag.trim()
    let has_seed = _seed_t.len() > 0
    println("⚒ forge — L10 bootstrap orchestration (seed_provided=" + (if has_seed { "true" } else { "false" }) + ")")
    // 0) canon-aware idempotent — 직전 seal 의 atlas.n6 hash 와 현재 hash 동일하면 boot reject.
    //    이유: atlas 변동 없이 forge 반복 → drill 슬롯 점유만 늘림. 진척 없으면 boot 의미 X.
    //    bypass: NEXUS_FORGE_FORCE=1 (atlas 변동 무관 boot).
    if env("NEXUS_FORGE_FORCE") != "1" {
        let canon_seal_path = nexus_root() + "/state/canon_seal.jsonl"
        let last_seal = exec("tail -1 " + shell_quote(canon_seal_path) + " 2>/dev/null").trim()
        if last_seal.len() > 0 {
            // 직전 seal 의 atlas.n6 hash16 추출 ("hash16":"<16chars>")
            let needle = "\"hash16\":\""
            let idx = str_find(last_seal, needle)
            if idx >= 0 {
                let i = idx + needle.len()
                let mut prev_hash = ""
                if i + 16 <= last_seal.len() { prev_hash = last_seal.substring(i, i + 16) }
                // 현재 atlas.n6 hash 계산
                let atlas_n6_env = env("NEXUS_ATLAS_N6_PATH")
                let atlas_n6_path = if atlas_n6_env.len() > 0 { atlas_n6_env } else { env("HOME") + "/core/n6-architecture/atlas/atlas.n6" }
                let cur_chk = exec("[ -f " + shell_quote(atlas_n6_path) + " ] && (sha256sum " + shell_quote(atlas_n6_path) + " 2>/dev/null || shasum -a 256 " + shell_quote(atlas_n6_path) + ") | awk '{print $1}' || echo ''").trim()
                let cur_hash = if cur_chk.len() >= 16 { cur_chk.substring(0, 16) } else { "" }
                if prev_hash.len() == 16 && cur_hash.len() == 16 && prev_hash == cur_hash {
                    eprintln("NEXUS_FORGE {\"event\":\"reject\",\"reason\":\"atlas_n6_unchanged_since_last_seal\",\"hash16\":\"" + cur_hash + "\",\"hint\":\"NEXUS_FORGE_FORCE=1 으로 bypass\"}")
                    println("⚠ forge reject — atlas.n6 hash 직전 seal 과 동일 (" + cur_hash + ")")
                    println("  bypass: NEXUS_FORGE_FORCE=1 또는 canon 새로 찍기 (~/.hx/bin/nexus canon)")
                    return
                }
            }
        }
    }
    // 1) molt skin
    let skin_path_env = env("NEXUS_MOLT_SKIN_FILE")
    let skin_path = if skin_path_env.len() > 0 { skin_path_env } else { "/tmp/nexus_molt_skin.json" }
    let skin_json = _forge_read_file_content(skin_path)
    let skin_present = skin_json.len() > 0
    let mut skin_depth: i64 = 1
    let mut skin_fast: bool = true
    if skin_present {
        let d = _forge_extract_json_int(skin_json, "depth")
        if d >= 1 { skin_depth = d }
        skin_fast = _forge_extract_json_bool(skin_json, "fast")
    }
    // 2) atlas health
    let atlas_path = nexus_root() + "/state/atlas_health.json"
    let atlas_chk = exec("[ -f " + shell_quote(atlas_path) + " ] && wc -c < " + shell_quote(atlas_path) + " || echo 0").trim()
    let mut atlas_bytes: i64 = 0
    try { atlas_bytes = to_int(atlas_chk) } catch e { atlas_bytes = 0 }
    let atlas_present = atlas_bytes > 0
    // 3) timestamp
    let timestamp = exec("date +%Y%m%d-%H%M%S 2>/dev/null").trim()
    // 4) 합성 seed
    let f_marker = if skin_fast { "f" } else { "s" }
    let suffix = " #forge-boot=" + timestamp + " skin=d" + to_string(skin_depth) + f_marker + " atlas=" + to_string(atlas_bytes) + "B"
    let max_main = 200 - suffix.len()
    let mut synthesized = ""
    if has_seed {
        let mut main = _seed_t
        if main.len() > max_main {
            if max_main < 1 { main = "" } else { main = main.substring(0, max_main) }
        }
        synthesized = main + suffix
    } else {
        // boot-from-scratch: hardcoded prefix + 자기 상태 suffix
        let boot_prefix = "nexus forge bootstrap — self-derived seed for autonomous boot from internal state"
        let mut main = boot_prefix
        if main.len() > max_main {
            if max_main < 1 { main = "" } else { main = main.substring(0, max_main) }
        }
        synthesized = main + suffix
    }
    eprintln("NEXUS_FORGE {\"event\":\"plan\",\"seed_provided\":" + (if has_seed { "true" } else { "false" })
        + ",\"skin_present\":" + (if skin_present { "true" } else { "false" })
        + ",\"atlas_present\":" + (if atlas_present { "true" } else { "false" }) + "}")
    eprintln("NEXUS_FORGE {\"event\":\"boot\",\"seed_len\":" + to_string(synthesized.len())
        + ",\"skin\":{\"depth\":" + to_string(skin_depth) + ",\"fast\":" + (if skin_fast { "true" } else { "false" }) + "}"
        + ",\"atlas_bytes\":" + to_string(atlas_bytes)
        + ",\"timestamp\":\"" + timestamp + "\"}")
    println("  synthesized seed (" + to_string(synthesized.len()) + " chars): " + synthesized)
    println("  skin: depth=" + to_string(skin_depth) + " fast=" + (if skin_fast { "true" } else { "false" }) + " (from " + skin_path + ")")
    println("  atlas: " + to_string(atlas_bytes) + " bytes (from " + atlas_path + ")")
    println("─── forge → dispatch to drill (apex preset) ───")
    let per_stage_zero = [0, 0, 0, 0, 0, 0]
    let depth_str = to_string(skin_depth)
    cmd_drill(synthesized, max_rounds_flag, "", "", depth_str, per_stage_zero, true, true, "", "", "3")
    eprintln("NEXUS_FORGE {\"event\":\"complete\",\"status\":\"dispatched_to_drill\"}")
    println("⚒ forge complete")
}

// ─── L11 canon — transfinite seal (2026-04-25) ───
// SSOT: state/canon_seal.jsonl (append-only).
// forge 의 역방향: 자기 상태 합성 → drill 부팅 (forward) ↔ canon 자기 상태 + 결과 → atlas-side 봉인 (closure).
// 의미: 「현재 self-state 를 한 entry 로 형식적으로 닫음」 — 사다리 마지막 단.
// 신규 파일 외 영속 자원 만들지 않음 (canon_seal.jsonl 한 곳에 한 줄 추가).
fn cmd_canon(seed_flag: str, note_flag: str) -> void {
    let _seed_t = seed_flag.trim()
    let _note_t = note_flag.trim()
    println("🔒 canon — L11 transfinite seal (sealing current self-state to canon log)")
    // 1) skin (from molt persistence)
    let skin_path_env = env("NEXUS_MOLT_SKIN_FILE")
    let skin_path = if skin_path_env.len() > 0 { skin_path_env } else { "/tmp/nexus_molt_skin.json" }
    let skin_json = _forge_read_file_content(skin_path)
    let skin_present = skin_json.len() > 0
    let mut skin_depth: i64 = 1
    let mut skin_fast: bool = true
    if skin_present {
        let d = _forge_extract_json_int(skin_json, "depth")
        if d >= 1 { skin_depth = d }
        skin_fast = _forge_extract_json_bool(skin_json, "fast")
    }
    // 2) atlas health bytes
    let atlas_path = nexus_root() + "/state/atlas_health.json"
    let atlas_chk = exec("[ -f " + shell_quote(atlas_path) + " ] && wc -c < " + shell_quote(atlas_path) + " || echo 0").trim()
    let mut atlas_bytes: i64 = 0
    try { atlas_bytes = to_int(atlas_chk) } catch e { atlas_bytes = 0 }
    // 2b) atlas.n6 hash (n6-architecture 측 본체) — 시점 비교용. 부재 시 빈 문자열.
    //    NEXUS_ATLAS_N6_PATH 로 override 가능 (sister repo 위치 변경 시).
    let atlas_n6_env = env("NEXUS_ATLAS_N6_PATH")
    let atlas_n6_path = if atlas_n6_env.len() > 0 { atlas_n6_env } else { env("HOME") + "/core/n6-architecture/atlas/atlas.n6" }
    let n6_chk = exec("[ -f " + shell_quote(atlas_n6_path) + " ] && (sha256sum " + shell_quote(atlas_n6_path) + " 2>/dev/null || shasum -a 256 " + shell_quote(atlas_n6_path) + ") | awk '{print $1}' || echo ''").trim()
    let atlas_n6_hash = if n6_chk.len() >= 16 { n6_chk.substring(0, 16) } else { "" }
    let n6_lines_chk = exec("[ -f " + shell_quote(atlas_n6_path) + " ] && wc -l < " + shell_quote(atlas_n6_path) + " || echo 0").trim()
    let mut atlas_n6_lines: i64 = 0
    try { atlas_n6_lines = to_int(n6_lines_chk) } catch e { atlas_n6_lines = 0 }
    // 3) last drill total (drill_batch sentinel — best-effort, 0 if absent)
    let drill_raw = exec("cat /tmp/nexus_drill_last_total.txt 2>/dev/null").trim()
    let mut drill_total: i64 = 0
    try { drill_total = to_int(drill_raw) } catch e { drill_total = 0 }
    // 4) timestamps + seal_id
    let ts_iso = exec("date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null").trim()
    let ts_compact = exec("date +%Y%m%d-%H%M%S 2>/dev/null").trim()
    let f_marker = if skin_fast { "f" } else { "s" }
    let seal_id = "canon-" + ts_compact + "-d" + to_string(skin_depth) + f_marker
    // 5) escape user-provided fields
    let seed_esc = _seed_t.replace("\\", "\\\\").replace("\"", "\\\"")
    let note_esc = _note_t.replace("\\", "\\\\").replace("\"", "\\\"")
    // 6) entry (one JSON line)
    let entry = "{\"ts\":\"" + ts_iso + "\""
        + ",\"seal_id\":\"" + seal_id + "\""
        + ",\"sealed_by\":\"canon_v2\""
        + ",\"skin\":{\"depth\":" + to_string(skin_depth) + ",\"fast\":" + (if skin_fast { "true" } else { "false" }) + "}"
        + ",\"atlas_bytes\":" + to_string(atlas_bytes)
        + ",\"atlas_n6\":{\"hash16\":\"" + atlas_n6_hash + "\",\"lines\":" + to_string(atlas_n6_lines) + "}"
        + ",\"last_drill_total\":" + to_string(drill_total)
        + ",\"seed\":\"" + seed_esc + "\""
        + ",\"note\":\"" + note_esc + "\"}"
    eprintln("NEXUS_CANON {\"event\":\"plan\",\"skin_present\":" + (if skin_present { "true" } else { "false" })
        + ",\"atlas_bytes\":" + to_string(atlas_bytes)
        + ",\"drill_total\":" + to_string(drill_total) + "}")
    // 7) append (atomic single-line write via printf) + rc check (silent fail 차단)
    let canon_path = nexus_root() + "/state/canon_seal.jsonl"
    let pre_lines_raw = exec("wc -l < " + shell_quote(canon_path) + " 2>/dev/null || echo 0").trim()
    let mut pre_lines: i64 = 0
    try { pre_lines = to_int(pre_lines_raw) } catch e { pre_lines = 0 }
    exec("printf '%s\\n' " + shell_quote(entry) + " >> " + shell_quote(canon_path))
    let post_lines_raw = exec("wc -l < " + shell_quote(canon_path) + " 2>/dev/null || echo 0").trim()
    let mut post_lines: i64 = 0
    try { post_lines = to_int(post_lines_raw) } catch e { post_lines = 0 }
    if post_lines != pre_lines + 1 {
        eprintln("NEXUS_CANON {\"event\":\"write_fail\",\"reason\":\"line_count_mismatch\",\"pre\":" + to_string(pre_lines) + ",\"post\":" + to_string(post_lines) + "}")
        println("⚠ canon write 검증 실패 — pre=" + to_string(pre_lines) + " post=" + to_string(post_lines))
        return
    }
    eprintln("NEXUS_CANON {\"event\":\"seal\",\"seal_id\":\"" + seal_id + "\",\"path\":\"" + canon_path + "\"}")
    println("  seal_id: " + seal_id)
    println("  skin: depth=" + to_string(skin_depth) + " fast=" + (if skin_fast { "true" } else { "false" }) + " (from " + skin_path + ")")
    println("  atlas.n6: " + (if atlas_n6_hash.len() > 0 { "hash16=" + atlas_n6_hash + " lines=" + to_string(atlas_n6_lines) } else { "absent" }) + " (from " + atlas_n6_path + ")")
    println("  atlas: " + to_string(atlas_bytes) + " bytes (" + atlas_path + ")")
    println("  last_drill_total: " + to_string(drill_total))
    println("  appended → " + canon_path)
    // 8) total seal count
    let count_raw = exec("wc -l < " + shell_quote(canon_path) + " 2>/dev/null").trim()
    let mut total_seals: i64 = 0
    try { total_seals = to_int(count_raw) } catch e { total_seals = 0 }
    println("  total seals in canon: " + to_string(total_seals))
    eprintln("NEXUS_CANON {\"event\":\"complete\",\"seal_id\":\"" + seal_id + "\",\"total_seals\":" + to_string(total_seals) + "}")
    println("🔒 canon complete")
}

// ─── E12 batch drill wrapper (2026-04-21) ───
// SSOT: shared/config/drill.json .seed_batch
// Sequential iterate — seed N 개를 순차 cmd_drill 호출. engine_daemon 미구현 시 naive 반복.
// 각 seed 별 stdout 구간 분리, per-seed duration 측정, 전체 NEXUS_DRILL_BATCH JSON stderr emit.
fn cmd_drill_batch(seeds_in: [str], max_rounds: str, engine_flag: str, preset: str, master_depth: str, per_stage_depths: [int], adaptive_flag: bool, resume_flag: bool, checkpoint_dir: str, problem: str, speculate_flag: str) -> void {
    // 입력단 견고화 — 각 seed 를 _seed_clamp 통과 (NEXUS_SEED_CAP 적용).
    let mut seeds: [str] = []
    let mut _ci = 0
    while _ci < len(seeds_in) {
        let _cs = _seed_clamp(seeds_in[_ci])
        if _cs.len() > 0 { seeds = seeds + [_cs] }
        _ci = _ci + 1
    }
    let n = len(seeds)
    if n == 0 {
        eprintln("nexus drill: --seeds/--seeds-file 에 유효한 seed 없음")
        return
    }
    // E12-B (2026-04-21): Phase-1 init 공유 — hexa_bin / nexus_root / engine_id / sigint trap 1회.
    //   bypass: NEXUS_BATCH_SHARE_INIT=0.
    _batch_shared_init(engine_flag)
    let batch_t0 = _progress_now_ms()
    println("🛸 nexus drill — batch mode (sequential), seed_count=" + to_string(n))
    if _batch_share_active {
        println("    [E12-B] Phase-1 init shared — hexa_bin/nexus_root/sigint cached (env NEXUS_BATCH_SHARE_INIT=0 로 bypass)")
    } else {
        println("    [E12-B] Phase-1 init share bypassed (NEXUS_BATCH_SHARE_INIT=0)")
    }
    println("")
    let mut durations: [i64] = []
    let mut grand_total = 0
    let mut idx = 0
    while idx < n {
        let sd = seeds[idx]
        let sh = _seed_batch_hash(sd)
        println("═══════════════════════════════════════════════════════════════")
        println("▎ seed[" + to_string(idx + 1) + "/" + to_string(n) + "] hash=" + sh + " len=" + to_string(sd.len()))
        println("▎ seed: '" + sd + "'")
        println("═══════════════════════════════════════════════════════════════")
        // sentinel 초기화 (이전 값 오염 방지)
        exec("printf '%s' '0' > /tmp/nexus_drill_last_total.txt")
        let t0 = _progress_now_ms()
        cmd_drill(sd, max_rounds, engine_flag, preset, master_depth, per_stage_depths, adaptive_flag, resume_flag, checkpoint_dir, problem, speculate_flag)
        let t1 = _progress_now_ms()
        let dur = t1 - t0
        durations = durations + [dur]
        // sentinel read
        let raw = exec("cat /tmp/nexus_drill_last_total.txt 2>/dev/null").trim()
        let mut tot = 0
        try { tot = to_int(raw) } catch e { tot = 0 }
        grand_total = grand_total + tot
        println("")
        println("▎ seed[" + to_string(idx + 1) + "/" + to_string(n) + "] done — total=" + to_string(tot) + " duration_ms=" + to_string(dur))
        println("")
        idx = idx + 1
    }
    let batch_t1 = _progress_now_ms()
    let batch_wall_ms = batch_t1 - batch_t0
    // sum_ms — 개별 seed duration 합. batch_wall_ms 와 근사해야 함 (wrapper 오버헤드만 차이).
    let mut sum_ms: i64 = 0
    let mut k = 0
    while k < len(durations) { sum_ms = sum_ms + durations[k]; k = k + 1 }
    println("═══════════════════════════════════════════════════════════════")
    println("▎ BATCH DONE — seed_count=" + to_string(n) + " grand_total=" + to_string(grand_total))
    println("▎ wall_ms(batch)=" + to_string(batch_wall_ms) + " sum_ms(per-seed)=" + to_string(sum_ms)
        + " share_active=" + (if _batch_share_active { "1" } else { "0" }))
    println("═══════════════════════════════════════════════════════════════")
    _seed_batch_emit_summary(n, grand_total, durations)
    _batch_shared_cleanup()
}

// ═══════════════════════════════════════════════════════════
// E11 Phase 1 — drill-daemon thin client
// SSOT: shared/design/engine_daemon_design.md §3 (Phase 1 scope)
// daemon entry: cli/scripts/nexus_drilld.hexa
// protocol: line-delimited JSON over UNIX FIFO /tmp/nexus_drilld.sock
// reply: per-request reply-FIFO (client creates + consumes, then unlinks).
// ═══════════════════════════════════════════════════════════
let DRILLD_FIFO = "/tmp/nexus_drilld.sock"
let DRILLD_PID  = "/tmp/nexus_drilld.pid"
let DRILLD_LOG  = "/tmp/nexus_drilld.log"

fn _drilld_alive() -> bool {
    let chk = exec("[ -p " + shell_quote(DRILLD_FIFO) + " ] && [ -f " + shell_quote(DRILLD_PID) + " ] && echo y || echo n").trim()
    if chk != "y" { return false }
    let pid = exec("cat " + shell_quote(DRILLD_PID) + " 2>/dev/null").trim()
    if pid.len() == 0 { return false }
    let alive = exec("kill -0 " + shell_quote(pid) + " 2>/dev/null && echo y || echo n").trim()
    return alive == "y"
}

fn _drilld_send(request: str, want_reply: bool) -> str {
    // 1. 선택적으로 reply-FIFO 생성 (per-request, 경합 회피)
    let reply_path = if want_reply {
        exec("mktemp -u /tmp/nexus_drilld_reply_XXXXXX").trim()
    } else { "" }
    let mut final_req = request
    if want_reply && reply_path.len() > 0 {
        exec("mkfifo -m 0600 " + shell_quote(reply_path) + " 2>/dev/null || true")
        // inject "reply":"<path>" — 요청 JSON 끝 } 앞에 삽입
        if final_req.ends_with("}") {
            let cut = final_req.substring(0, final_req.len() - 1)
            let sep = if cut.ends_with("{") { "" } else { "," }
            final_req = cut + sep + "\"reply\":\"" + reply_path + "\"}"
        }
    }
    // 2. write request 1 line
    let wcmd = "printf '%s\\n' " + shell_quote(final_req) + " > " + shell_quote(DRILLD_FIFO)
    exec(wcmd)
    // 3. read reply (blocking) — want_reply=false 시 스킵
    if !want_reply { return "" }
    if reply_path.len() == 0 { return "" }
    let rcmd = "IFS= read -r LINE < " + shell_quote(reply_path) + " && printf '%s' \"$LINE\" || true"
    let resp = exec(rcmd)
    exec("rm -f " + shell_quote(reply_path) + " 2>/dev/null || true")
    return resp
}

fn cmd_drill_daemon(sub: str, a: [str]) -> void {
    if sub == "start" {
        if _drilld_alive() {
            println("drill-daemon: already running (pid=" + exec("cat " + shell_quote(DRILLD_PID) + " 2>/dev/null").trim() + ")")
            return
        }
        let root = nexus_root()
        let script = root + "/cli/scripts/nexus_drilld.hexa"
        let cmd = "nohup " + shell_quote(hexa_bin()) + " run " + shell_quote(script)
            + " > " + shell_quote(DRILLD_LOG) + " 2>&1 &"
        exec(cmd)
        // give the daemon a short moment to mkfifo + write PID
        exec("i=0; while [ $i -lt 20 ] && [ ! -p " + shell_quote(DRILLD_FIFO) + " ]; do sleep 0.1; i=$((i+1)); done")
        if _drilld_alive() {
            println("drill-daemon: started (pid=" + exec("cat " + shell_quote(DRILLD_PID) + " 2>/dev/null").trim()
                + " fifo=" + DRILLD_FIFO + " log=" + DRILLD_LOG + ")")
        } else {
            eprintln("drill-daemon: start failed — check " + DRILLD_LOG)
            exit(1)
        }
        return
    }
    if sub == "status" {
        if !_drilld_alive() {
            println("drill-daemon: not running")
            exit(1)
        }
        let resp = _drilld_send("{\"op\":\"ping\"}", true)
        println("drill-daemon: alive")
        println(resp)
        return
    }
    if sub == "stop" {
        if !_drilld_alive() {
            println("drill-daemon: not running")
            return
        }
        // graceful — quit op 후 fallback SIGTERM
        let _ = _drilld_send("{\"op\":\"quit\"}", false)
        let pid = exec("cat " + shell_quote(DRILLD_PID) + " 2>/dev/null").trim()
        if pid.len() > 0 {
            exec("kill -TERM " + shell_quote(pid) + " 2>/dev/null || true")
            // poll up to 2s
            exec("i=0; while [ $i -lt 20 ] && kill -0 " + shell_quote(pid) + " 2>/dev/null; do sleep 0.1; i=$((i+1)); done")
        }
        println("drill-daemon: stopped")
        return
    }
    if sub == "send" {
        // raw JSON pass-through — user supplies `--req '{"op":"drill",...}'`
        let req = find_flag(a, "--req", "")
        if req.len() == 0 {
            eprintln("drill-daemon send: --req '<json>' required")
            exit(1)
        }
        if !_drilld_alive() {
            eprintln("drill-daemon send: daemon not running — run `nexus drill-daemon start` first")
            exit(1)
        }
        let resp = _drilld_send(req, true)
        println(resp)
        return
    }
    eprintln("drill-daemon: unknown sub '" + sub + "' — expected start|status|stop|send")
    exit(1)
}

