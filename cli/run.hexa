fn _hexa_sim_bridge_dispatch(a: [str]) -> void {
    // nexus hexa-sim bridge <codata|oeis|gw|horizons|arxiv|cmb|nanograv|simbad|icecube|nist_atomic|wikipedia|openalex|gaia|lhc|pubchem|uniprot> [args...]
    let n = len(a)
    let bsub = if n >= 5 { a[4] } else { "" }
    if bsub.len() == 0 || bsub == "help" || bsub == "-h" || bsub == "--help" {
        _hexa_sim_bridge_help(); return
    }
    let mut script = ""
    if bsub == "codata" { script = nexus_root() + "/tool/codata_bridge.hexa" }
    else if bsub == "oeis" { script = nexus_root() + "/tool/oeis_live_bridge.hexa" }
    else if bsub == "gw" { script = nexus_root() + "/tool/gw_observatory_bridge.hexa" }
    else if bsub == "horizons" { script = nexus_root() + "/tool/horizons_bridge.hexa" }
    else if bsub == "arxiv" { script = nexus_root() + "/tool/arxiv_realtime_bridge.hexa" }
    else if bsub == "cmb" { script = nexus_root() + "/tool/cmb_planck_bridge.hexa" }
    else if bsub == "nanograv" { script = nexus_root() + "/tool/nanograv_pulsar_bridge.hexa" }
    else if bsub == "simbad" { script = nexus_root() + "/tool/simbad_bridge.hexa" }
    else if bsub == "icecube" { script = nexus_root() + "/tool/icecube_neutrino_bridge.hexa" }
    else if bsub == "nist_atomic" { script = nexus_root() + "/tool/nist_atomic_bridge.hexa" }
    else if bsub == "wikipedia" { script = nexus_root() + "/tool/wikipedia_summary_bridge.hexa" }
    else if bsub == "openalex" { script = nexus_root() + "/tool/openalex_bridge.hexa" }
    else if bsub == "gaia" { script = nexus_root() + "/tool/gaia_bridge.hexa" }
    else if bsub == "lhc" { script = nexus_root() + "/tool/lhc_opendata_bridge.hexa" }
    else if bsub == "pubchem" { script = nexus_root() + "/tool/pubchem_bridge.hexa" }
    else if bsub == "uniprot" { script = nexus_root() + "/tool/uniprot_bridge.hexa" }
    else {
        eprintln("nexus hexa-sim bridge: unknown bridge `" + bsub + "` — try `nexus hexa-sim bridge help`")
        exit(1)
    }
    if !pfs_file_exists(script) {
        eprintln("nexus hexa-sim bridge " + bsub + ": script missing at " + script)
        exit(1)
    }
    let mut fwd = ""
    let mut i = 5  // skip [hexa, script, "hexa-sim", "bridge", "<bsub>", ...]
    while i < n {
        if fwd.len() > 0 { fwd = fwd + " " }
        fwd = fwd + shell_quote(a[i])
        i = i + 1
    }
    let cmd = "HEXA_RESOLVER_NO_REROUTE=1 " + hexa_bin() + " run " + shell_quote(script) + (if fwd.len() > 0 { " " + fwd } else { "" })
    print(exec(cmd + " 2>&1"))
}

