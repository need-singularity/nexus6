// nexus/cli/bio.hexa — hexa-bio subcommand router (NEW 2026-05-04)
//
// REFACTOR NOTE (anima cycle, 2026-05-04):
//   This router is the nexus-side thin pass-through to the standalone
//   hexa-bio CLI (qmirror pattern, see cli/qmirror.hexa v0.3.0):
//
//       nexus bio <subcmd> [flags...]
//          ↓
//       hexa-bio <subcmd> [flags...]   (standalone CLI from need-singularity/hexa-bio)
//
//   The standalone CLI lives at one of:
//     1. $HEXA_BIO_ROOT (env override)             ← preferred
//     2. /Users/ghost/core/hexa-bio                 ← Mac dev convention
//     3. $HOME/core/hexa-bio                        ← user-home convention
//     4. PATH-resolved `hexa-bio` binary            ← future hx-installed
//
//   In-tree modules at $NEXUS/modules/weave/ are scheduled for REMOVAL
//   after standalone smoke PASS (qmirror v0.3.0 deletion-irreversibility
//   pattern). Until then, this router co-exists with the legacy modules.
//
// Invoked via:  nexus bio <subcmd> [flags...]
//
// Subcommands (forwarded verbatim to standalone):
//   status      — 1/4-wired verb table + verdict + caveats
//   weave       — protein cage / polyhedral self-assembly      [WIRED]
//   nanobot     — molecular actuation primitive                [STUB]
//   ribozyme    — RNA-catalyst primitive                       [STUB]
//   virocapsid  — viral capsid assembly primitive              [STUB]
//   selftest    — full 4-verb sentinel sweep
//
// Constraints honored:
//   raw#9   — hexa-only (no .py created); standalone manages its own bridges
//   raw#15  — write-confined (audit log only on nexus side)
//   raw#10  — 4 honest C3 caveats embedded in cmd_help
//
// Cost: $0 (Mac local; weave python bridge opt-in via HEXA_BIO_WITH_NUMPY=1).
//
// @no-lock-needed
// @resolver-bypass(reason="Pure local CLI router; standalone manages its own bridges.")

let VERSION = "0.1.0"

// ─── env / path resolve ───

let HOME = env("HOME")
let NEXUS = env("NEXUS")
let HEXA_BIO_ROOT_ENV = env("HEXA_BIO_ROOT")

fn nexus_root() -> str {
    if NEXUS.len() > 0 { return NEXUS }
    return HOME + "/core/nexus"  // @allow-devpath
}

let NX = nexus_root()
let HEXA_BIN = NX + "/bin/hexa"
let LOG_PATH = NX + "/logs/nexus_cli.log"

// ─── arg helpers ───

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn has_flag(a: [str], flag: str) -> bool {
    let prefix = flag + "="
    for x in a {
        if x == flag { return true }
        if x.starts_with(prefix) { return true }
    }
    return false
}

fn json_mode(a: [str]) -> bool {
    return has_flag(a, "--json")
}

// ─── audit log (jsonl) ───

fn _ts_now() -> str {
    return exec("date -u '+%Y-%m-%dT%H:%M:%SZ'").trim()
}

fn _audit(subcmd: str, args_str: str, exit_code: int, route: str) {
    let line = "{\"ts\":\"" + _ts_now() + "\",\"caller\":\"hexa_bio_router\",\"subcmd\":\"bio " +
               subcmd + "\",\"args\":\"" + args_str.replace("\"", "\\\"") +
               "\",\"exit_code\":" + str(exit_code) +
               ",\"route\":\"" + route + "\"" +
               ",\"router_version\":\"" + VERSION + "\"}"
    exec("echo " + shq(line) + " >> " + shq(LOG_PATH) + " 2>/dev/null")
}

// ─── path / invocation resolution ───

fn _file_exists(p: str) -> bool {
    let r = exec("[ -f " + shq(p) + " ] && echo yes || echo no").trim()
    return r == "yes"
}

// 4-tier resolution (mirrors qmirror v0.3.0 pattern):
//   1. $HEXA_BIO_ROOT env
//   2. /Users/ghost/core/hexa-bio
//   3. $HOME/core/hexa-bio
//   4. PATH-resolved `hexa-bio`
//
// Returns "<route>|<command-prefix>"
fn _resolve_invocation() -> str {
    if HEXA_BIO_ROOT_ENV.len() > 0 {
        let cli = HEXA_BIO_ROOT_ENV + "/cli/hexa-bio.hexa"
        if _file_exists(cli) {
            return "standalone-env|HEXA_BIO_ROOT=" + shq(HEXA_BIO_ROOT_ENV) + " " + shq(HEXA_BIN) + " run " + shq(cli)
        }
    }
    let mac_root = "/Users/ghost/core/hexa-bio"
    let mac_cli = mac_root + "/cli/hexa-bio.hexa"
    if _file_exists(mac_cli) {
        return "standalone-mac|HEXA_BIO_ROOT=" + shq(mac_root) + " " + shq(HEXA_BIN) + " run " + shq(mac_cli)
    }
    let home_root = HOME + "/core/hexa-bio"
    let home_cli = home_root + "/cli/hexa-bio.hexa"
    if _file_exists(home_cli) {
        return "standalone-home|HEXA_BIO_ROOT=" + shq(home_root) + " " + shq(HEXA_BIN) + " run " + shq(home_cli)
    }
    let path_bin = exec("command -v hexa-bio 2>/dev/null || true").trim()
    if path_bin.len() > 0 {
        return "standalone-path|" + shq(path_bin)
    }
    return "none|"
}

fn _strip_rc_trailer(raw: str) -> str {
    let lines = raw.split("\n")
    let mut out = ""
    let mut k = 0
    while k < lines.len() {
        let l = lines[k]
        if l.trim().starts_with("__NEXUS_BIO_RC__:") == false {
            if out.len() > 0 { out = out + "\n" }
            out = out + l
        }
        k = k + 1
    }
    return out
}

fn _forward(sub: str, extra: [str]) -> str {
    let resolved = _resolve_invocation()
    let parts = resolved.split("|")
    let route = parts[0]
    let prefix = if parts.len() >= 2 { parts[1] } else { "" }

    if route == "none" {
        eprintln("nexus bio: ERROR — hexa-bio standalone not found (4-tier resolution failed)")
        eprintln("  tier 1 ($HEXA_BIO_ROOT env)             : not set or invalid")
        eprintln("  tier 2 (/Users/ghost/core/hexa-bio)     : not found")
        eprintln("  tier 3 ($HOME/core/hexa-bio)            : not found")
        eprintln("  tier 4 (PATH `hexa-bio`)                : not found")
        eprintln("")
        eprintln("  remediation: install via `hx install hexa-bio`,")
        eprintln("               or set $HEXA_BIO_ROOT to a checkout of need-singularity/hexa-bio,")
        eprintln("               or clone to /Users/ghost/core/hexa-bio (Mac dev convention).")
        _audit(sub, "no-hexa-bio-found", 127, "none")
        return route + "|127"
    }

    let mut cmd = prefix + " " + shq(sub)
    for x in extra {
        cmd = cmd + " " + shq(x)
    }
    let full = cmd + "; echo \"__NEXUS_BIO_RC__:$?\""
    let raw = exec(full + " 2>&1")
    let mut rc = 0
    let lines = raw.split("\n")
    let mut k = 0
    while k < lines.len() {
        let l = lines[k].trim()
        if l.starts_with("__NEXUS_BIO_RC__:") {
            rc = to_int(l.substr(17, l.len() - 17))
        }
        k = k + 1
    }
    print(_strip_rc_trailer(raw))
    let mut es = ""
    let mut e_i = 0
    while e_i < extra.len() {
        if e_i > 0 { es = es + " " }
        es = es + extra[e_i]
        e_i = e_i + 1
    }
    _audit(sub, es, rc, route)
    return route + "|" + str(rc)
}

// ─── help ───

fn cmd_help() {
    println("nexus bio " + VERSION + " — hexa-bio Molecular Toolkit subcommand router")
    println("")
    println("usage: nexus bio <subcmd> [flags...]")
    println("")
    println("ROUTING (v0.1.0 — 4-tier standalone resolution):")
    println("  This router shells out to the hexa-bio standalone CLI.")
    println("  Resolution order:")
    println("    1. $HEXA_BIO_ROOT env")
    println("    2. /Users/ghost/core/hexa-bio")
    println("    3. $HOME/core/hexa-bio")
    println("    4. PATH-resolved `hexa-bio` binary")
    println("  Hard fail (exit 127) when none resolve.")
    println("")
    println("subcommands (forwarded verbatim to standalone):")
    println("  status                                  1/4-wired verb table + caveats")
    println("  weave [--cage-assembly|--bayesian-audit|--all] [--t-end N]")
    println("                                          protein cage / polyhedral assembly  [WIRED]")
    println("  nanobot                                 molecular actuation primitive       [STUB]")
    println("  ribozyme                                RNA-catalyst primitive              [STUB]")
    println("  virocapsid                              viral capsid assembly primitive     [STUB]")
    println("  selftest                                full 4-verb sentinel sweep")
    println("")
    println("global flags (forwarded):")
    println("  --json     machine-parseable JSON tail")
    println("  --help,-h  this help (router-level) OR forwarded subhelp")
    println("")
    println("--- caveats (raw#10 C3) ---")
    println("  1. 1/4 verbs wired (weave); 3/4 ship as STUB modules with falsifier")
    println("     preregister only (nanobot/ribozyme/virocapsid). Sentinel PASS does")
    println("     NOT validate empirical claims.")
    println("  2. Fresh-install dependency: a clean nexus install (where hexa-bio is")
    println("     not reachable via the 4 tiers) hard-fails with exit 127. Pre-flight:")
    println("     `hx install hexa-bio` or set $HEXA_BIO_ROOT.")
    println("  3. weave python bridge (numpy/scipy) is opt-in via HEXA_BIO_WITH_NUMPY=1.")
    println("     Default path uses cached corpus result (posterior 0.97).")
    println("  4. Audit log enum: route ∈ { standalone-env, standalone-mac,")
    println("     standalone-home, standalone-path, none, rejected }.")
    println("")
    println("cost estimate (Mac local): $0 — all subcmds run as stubs by default.")
}

fn cmd_subhelp(sub: str) {
    let _ = _forward(sub, ["--help"])
}

// ─── main ───

fn main() {
    let _raw = args()
    let mut _sidx = -1
    let mut _i = 0
    while _i < _raw.len() {
        if _raw[_i].ends_with(".hexa") { _sidx = _i; break }
        _i = _i + 1
    }
    let mut _user_start = 2
    if _sidx >= 0 { _user_start = _sidx + 1 }

    let mut a: [str] = ["nexus_bio_cli", "hexa_bio_router"]
    let mut _ua = _user_start
    while _ua < _raw.len() {
        a = a + [_raw[_ua]]
        _ua = _ua + 1
    }
    let n = len(a)

    if n < 3 {
        cmd_help()
        return
    }

    let sub = a[2]

    if has_flag(a, "--help") || has_flag(a, "-h") {
        if sub == "--help" || sub == "-h" || sub == "help" {
            cmd_help()
        } else {
            cmd_subhelp(sub)
        }
        return
    }

    if sub == "help" { cmd_help(); return }

    let mut valid = false
    if sub == "status"     { valid = true }
    if sub == "weave"      { valid = true }
    if sub == "nanobot"    { valid = true }
    if sub == "ribozyme"   { valid = true }
    if sub == "virocapsid" { valid = true }
    if sub == "selftest"   { valid = true }
    if valid == false {
        eprintln("nexus bio: unknown subcommand '" + sub + "'")
        eprintln("run 'nexus bio help' for usage")
        _audit(sub, "", 2, "rejected")
        exit(2)
    }

    let mut extras: [str] = []
    let mut e_i = 3
    while e_i < n {
        extras = extras + [a[e_i]]
        e_i = e_i + 1
    }

    let result = _forward(sub, extras)
    let parts = result.split("|")
    let rc = if parts.len() >= 2 { to_int(parts[1]) } else { 0 }
    if rc != 0 { exit(rc) }
}
