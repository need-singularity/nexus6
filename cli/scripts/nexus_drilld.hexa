// ═══════════════════════════════════════════════════════════
// nexus_drilld.hexa — E11 Phase 1 MVP engine daemon
//
// Purpose:
//   `nexus drill` cold-start (hexa interpreter + n6 atlas + engine registry
//   load = ~12 s per invocation) 을 1 회 boot 에 amortize 한다.
//
// SSOT: shared/design/engine_daemon_design.md §3 (Phase 1).
//
// Phase 1 scope (MVP):
//   - stdin-less long-running process, listens on UNIX FIFO (request FIFO).
//   - line-delimited JSON protocol (§3 변형 — NDJSON).
//   - request  : {"op":"drill","seed":"...","max_rounds":N,"reply":"<path>"}
//                {"op":"ping","reply":"<path>"}
//                {"op":"quit"}
//   - response : {"status":"ok","absorptions":N,"wall_ms":M,"round":K}
//                {"status":"err","reason":"<tag>"}
//                {"status":"pong","served":N,"idle_s":S,"pid":P,"uptime_s":U}
//   - reply path 는 client 가 생성한 per-request reply-FIFO 경로.
//     (§3.2 "/tmp/nexus_blowup.ret.sock" 대신 per-request FIFO — 동시 다중
//      client 에서도 응답 섞임 차단, Phase 2~3 에서 단일 ret-FIFO 로 승격 가능.)
//   - boot 시 read-only pre-load: atlas.n6 mtime/size, hexa_bin path,
//     engine_registry.json mtime — warm-up 확인용 (Phase 2 에서 실제 in-proc
//     atlas 캐시로 확장).
//   - drill dispatch 는 여전히 `hexa run cli/run.hexa drill ...` exec 호출
//     (Phase 1 MVP — 실제 in-process dispatch 는 Phase 2. Phase 1 은 단지
//      소켓 프로토콜 + 서비스 lifecycle 만 증명.)
//   - graceful shutdown: SIGTERM → flag 파일 touch → 현 request 완료 후 exit.
//   - no PID file GC, no systemd/launchd integration (Phase 3).
//
// Hard rules:
//   - `>=` / `<=` 금지 — `<` / `>` 또는 `!(a<b)` 로 대체.
//   - Phase 1 MVP — ≤ 300 lines. Phase 2 가 in-process dispatch 와 state reset
//     (§4) 을 구현한다.
//
// Usage:
//   # foreground
//   hexa run cli/scripts/nexus_drilld.hexa
//
//   # backgrounded (nexus drill-daemon start 래퍼 권장)
//   nohup hexa run cli/scripts/nexus_drilld.hexa > /tmp/nexus_drilld.log 2>&1 &
// ═══════════════════════════════════════════════════════════

let VERSION = "0.1.0-phase1-mvp"

// ─── paths (SSOT) ───
let REQ_FIFO = "/tmp/nexus_drilld.sock"
let PID_FILE = "/tmp/nexus_drilld.pid"
let TERM_FLAG = "/tmp/nexus_drilld.term"
let LOG_FILE = "/tmp/nexus_drilld.log"
let ATLAS_LOCK = "shared/n6/.atlas.lock"    // Phase 2 §4.2 single-writer (relative to nexus root)

// ─── Phase 2 Step 7 lifetime limits (§2.4 + §5 risk table) ───
let IDLE_LIMIT_S    = 600      // 10 min without request → self-exit (request boundary only)
let MAX_LIFETIME_S  = 43200    // 12 h hard cap — launchd will re-spawn (Phase 3)
let CMD_TIMEOUT_S   = 180      // per-stage hard timeout — wraps exec()
// FIFO_POLL_S removed 2026-04-21 — htz verify showed hexa exec() + `read -t` lost
// data. Phase 3 external watchdog will handle true idle termination.

// ─── Phase 2 §4.1 state isolation — round-scoped mutable globals ───
// Each op handler must call _reset_round(seed) on entry. Boot-persistent state
// (atlas cache, lens registry, engine registry — §4.2) lives elsewhere and is
// NOT reset per round. Adding a new round-scoped var here is a **must-update**
// in _reset_round() — Step 4 byte-identity test guards against omissions.
let mut g_salt: int = 0
let mut g_jitter: int = 0
let mut g_rng_seed: int = 0
let mut g_partial_graph_delta: str = ""
let mut g_lens_consensus_buf: str = ""
let mut g_ouroboros_cycle: int = 0
let mut g_timer_acc: int = 0

// ─── Phase 2 §4.2 atlas single-writer — boot-only observed state ───
// Captured once at _setup_lifecycle(); _check_atlas_drift() compares at round
// end and raises NEXUS_ENGINE_WARN if external write detected. Actual
// single-writer enforcement (in-proc atlas cache + batched flush) lands in
// the Step 5 follow-up; Step 6 here scaffolds the observation + lock file.
let mut g_atlas_boot_size: int = 0
let mut g_atlas_boot_mtime: int = 0

// ─── util: shell-safe quote ───
fn _shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

// ─── util: nexus root / hexa bin (reuse cli/run.hexa 로직 요약) ───
fn _nexus_root() -> str {
    let n = env("NEXUS")
    if n.len() > 0 { return n }
    return env("HOME") + "/core/nexus"
}

fn _hexa_bin() -> str {
    let h = env("HEXA")
    if h.len() > 0 { return h }
    let cands = [
        env("HOME") + "/Dev/hexa-lang/hexa",
        env("HOME") + "/.hx/bin/hexa",
        _nexus_root() + "/bin/hexa"
    ]
    let mut i = 0
    while i < len(cands) {
        let c = cands[i]
        let chk = exec("[ -x " + _shq(c) + " ] && echo y || echo n").trim()
        if chk == "y" { return c }
        i = i + 1
    }
    return "hexa"
}

// ─── util: epoch seconds + ms (shell fallback — hexa time() 없음) ───
fn _now_s() -> int {
    let v = exec("date +%s").trim()
    let mut n = 0
    try { n = to_int(v) } catch e {}  // @allow-silent-catch
    return n
}

fn _now_ms() -> int {
    // macOS-correct cascade (date-percent-3n-macos-bypass-audit 2026-04-27):
    // BSD `date +%s%3N` emits literal "...N" and exits 0, so the `||` fallback
    // never fires; to_int catches → 0. Use explicit step-cascade instead.
    let s = exec("date +%s%3N 2>/dev/null").trim()
    let mut n = 0
    if s.len() > 0 && s.contains("N") == false {
        try { n = to_int(s) } catch e {}  // @allow-silent-catch
    }
    if n <= 0 {
        let s2 = exec("python3 -c 'import time; print(int(time.time()*1000))' 2>/dev/null").trim()
        try { n = to_int(s2) } catch e2 {}  // @allow-silent-catch
    }
    if n <= 0 {
        let s3 = exec("date +%s").trim()
        try { let sec = to_int(s3); n = sec * 1000 } catch e3 {}  // @allow-silent-catch
    }
    return n
}

// ─── util: log line (NDJSON to /tmp/nexus_drilld.log) ───
fn _log(event: str, kv: str) -> void {
    let ts = to_string(_now_s())
    let line = "{\"ts\":" + ts + ",\"event\":\"" + event + "\"" + kv + "}\n"
    exec("printf '%s' " + _shq(line) + " >> " + _shq(LOG_FILE) + " 2>/dev/null || true")
}

// ─── util: extract int/str JSON field (naive — Phase 1 is enough) ───
// protocol 은 1-line flat JSON 만 지원: {"op":"drill","seed":"...","max_rounds":3,"reply":"/tmp/xxx"}
fn _json_str(line: str, key: str) -> str {
    let pat = "\"" + key + "\":\""
    let i = line.index_of(pat)
    if i < 0 { return "" }
    let start = i + pat.len()
    let mut j = start
    let n = line.len()
    while j < n {
        let c = line.substring(j, j + 1)
        if c == "\"" { return line.substring(start, j) }
        if c == "\\" { j = j + 2; continue }  // naive escape skip
        j = j + 1
    }
    return ""
}

fn _json_int(line: str, key: str) -> int {
    let pat = "\"" + key + "\":"
    let i = line.index_of(pat)
    if i < 0 { return -1 }
    let mut j = i + pat.len()
    let n = line.len()
    // skip ws
    while j < n {
        let c = line.substring(j, j + 1)
        if c != " " && c != "\t" { break }
        j = j + 1
    }
    let start = j
    while j < n {
        let c = line.substring(j, j + 1)
        let is_digit = c == "0" || c == "1" || c == "2" || c == "3" || c == "4"
            || c == "5" || c == "6" || c == "7" || c == "8" || c == "9" || c == "-"
        if !is_digit { break }
        j = j + 1
    }
    if j == start { return -1 }
    let raw = line.substring(start, j)
    let mut v = -1
    try { v = to_int(raw) } catch e {}  // @allow-silent-catch
    return v
}

fn _json_bool(line: str, key: str) -> bool {
    // "<key>":true | "<key>":false — unquoted JSON bool.
    let pat = "\"" + key + "\":"
    let i = line.index_of(pat)
    if i < 0 { return false }
    let mut j = i + pat.len()
    let n = line.len()
    while j < n {
        let c = line.substring(j, j + 1)
        if c != " " && c != "\t" { break }
        j = j + 1
    }
    if j + 4 <= n && line.substring(j, j + 4) == "true" { return true }
    return false
}

fn _json_escape(s: str) -> str {
    // Minimal JSON string escape for payload building (\" \\ \n).
    let mut out = ""
    let mut i = 0
    let n = s.len()
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "\"" { out = out + "\\\"" }
        else if c == "\\" { out = out + "\\\\" }
        else if c == "\n" { out = out + "\\n" }
        else { out = out + c }
        i = i + 1
    }
    return out
}

// ─── util: write a single JSON line to reply path (blocking if FIFO) ───
fn _reply(reply_path: str, payload: str) -> void {
    if reply_path.len() == 0 { return }
    let cmd = "printf '%s\\n' " + _shq(payload) + " > " + _shq(reply_path) + " 2>/dev/null || true"
    exec(cmd)
}

// ─── util: AI-native engine error stderr channels (design §F') ───
// err_kind ∈ {"WARN","ERROR","DEAD","CRASH"}:
//   WARN  — recoverable, daemon keeps going
//   ERROR — request failed, daemon keeps going
//   DEAD  — fatal, daemon should restart (boot assert)
//   CRASH — hexa runtime threw (top-level catch)
fn _emit_engine_error(err_kind: str, reason: str, cmd: str, seed: str) -> void {
    let ej = "{\"reason\":\"" + _json_escape(reason)
        + "\",\"cmd\":\"" + _json_escape(cmd)
        + "\",\"seed\":\"" + _json_escape(seed) + "\"}"
    try { eprintln("NEXUS_ENGINE_" + err_kind + " " + ej) } catch e {}  // @allow-silent-catch
}

// ─── util: djb2 24-bit truncated → 6 hex chars ───
// Collision-resistant suffix for round_new ids so that same-ms + same-prefix
// requests do not collide. (daemon_main.hexa 에서 흡수, Phase 2 Step 1.)
fn _djb2_hex6(s: str) -> str {
    let mut h = 5381
    let mut i = 0
    let n = s.len()
    let hex = "0123456789abcdef"
    while i < n {
        let c = s.substring(i, i + 1)
        let mut v = 0
        if "0123456789".contains(c) { v = 48 + "0123456789".index_of(c) }
        else if "abcdefghijklmnopqrstuvwxyz".contains(c) { v = 97 + "abcdefghijklmnopqrstuvwxyz".index_of(c) }
        else if "ABCDEFGHIJKLMNOPQRSTUVWXYZ".contains(c) { v = 65 + "ABCDEFGHIJKLMNOPQRSTUVWXYZ".index_of(c) }
        else { v = 95 }
        h = ((h * 33) + v) % 16777216
        i = i + 1
    }
    if h < 0 { h = 0 - h }
    let mut out = ""
    let mut k = 0
    while k < 6 {
        let nib = h % 16
        out = hex.substring(nib, nib + 1) + out
        h = h / 16
        k = k + 1
    }
    return out
}

fn _round_id_from(ts_ms: int, seed: str) -> str {
    // r_<ts_ms>_<seed_prefix>_<hash6> — daemon_main.hexa 참조.
    let whitelist = "abcdefghijklmnopqrstuvwxyz0123456789_"
    let mut sh = seed
    if sh.len() > 8 { sh = sh.substring(0, 8) }
    let mut clean = ""
    let mut i = 0
    let shl = sh.len()
    while i < shl {
        let c = sh.substring(i, i + 1)
        if whitelist.contains(c) { clean = clean + c }
        i = i + 1
    }
    return "r_" + to_string(ts_ms) + "_" + clean + "_" + _djb2_hex6(seed)
}

// ─── Phase 2 §4.1 round-state reset ───
// Derive per-round state purely from seed (deterministic) so same seed yields
// byte-identical result regardless of prior rounds. Input = seed only. Output =
// all 7 round-scoped globals above. Step 4 byte-identity test enforces:
//   response(seed_A, N=1) == response(seed_A, N=3 in seed_A→B→A sequence)
fn _reset_round(seed: str) -> void {
    // djb2_hex6(seed) is 6 hex chars = 24-bit integer — fits in `int` safely.
    let h6 = _djb2_hex6(seed)
    let hex = "0123456789abcdef"
    let mut seed_int = 0
    let mut i = 0
    let hl = h6.len()
    while i < hl {
        let c = h6.substring(i, i + 1)
        let v = hex.index_of(c)
        seed_int = seed_int * 16 + v
        i = i + 1
    }
    g_salt = seed_int
    g_jitter = (seed_int * 7919) % 65536
    g_rng_seed = seed_int
    g_partial_graph_delta = ""
    g_lens_consensus_buf = ""
    g_ouroboros_cycle = 0
    g_timer_acc = 0
}

// ─── boot phase: pre-load engine state (Phase 1 = stat-check warm-up) ───
fn _preload_state() -> str {
    // Phase 1 MVP: atlas.n6 mtime/size + engine registry mtime 확인 만 수행.
    // 실제 in-process 캐싱은 Phase 2 (byte-identity test 후).
    let root = _nexus_root()
    let atlas = root + "/n6/atlas.n6"
    let reg = root + "/config/engine_registry.json"
    let mut parts: [str] = []
    parts = parts + ["\"atlas\":\""]
    if file_exists(atlas) {
        let sz = exec("wc -c < " + _shq(atlas) + " 2>/dev/null || echo 0").trim()
        parts = parts + [sz]
    } else {
        parts = parts + ["0"]
    }
    parts = parts + ["\",\"registry\":"]
    parts = parts + [if file_exists(reg) { "true" } else { "false" }]
    return parts.join("")
}

// ─── Phase 2 §4.2 atlas single-writer helpers ───
fn _atlas_path() -> str {
    return _nexus_root() + "/n6/atlas.n6"
}

fn _atlas_size() -> int {
    let v = exec("wc -c < " + _shq(_atlas_path()) + " 2>/dev/null || echo 0").trim()
    let mut n = 0
    try { n = to_int(v) } catch e {}  // @allow-silent-catch
    return n
}

fn _atlas_mtime() -> int {
    // stat -f %m on Darwin, stat -c %Y on Linux — try Darwin first.
    let v = exec("stat -f %m " + _shq(_atlas_path()) + " 2>/dev/null || stat -c %Y " + _shq(_atlas_path()) + " 2>/dev/null || echo 0").trim()
    let mut n = 0
    try { n = to_int(v) } catch e {}  // @allow-silent-catch
    return n
}

fn _atlas_lock_acquire() -> bool {
    // Cheap pidfile-style lock. Step 6 scaffolding — a full flock would use
    // `flock -x` but daemon runs single-process and we only need detection of
    // external writers, not atomicity of internal writes (Step 5 follow-up).
    let root = _nexus_root()
    let lk = root + "/" + ATLAS_LOCK
    // if exists + pid alive → another daemon running → refuse
    let exists = exec("[ -f " + _shq(lk) + " ] && echo y || echo n").trim() == "y"
    if exists {
        let other = exec("cat " + _shq(lk) + " 2>/dev/null || echo 0").trim()
        let alive = exec("kill -0 " + other + " 2>/dev/null && echo y || echo n").trim() == "y"
        if alive {
            _emit_engine_error("DEAD", "atlas_lock_busy", "boot", "")
            return false
        }
        // stale lock — reclaim
    }
    let pid = exec("echo $$").trim()
    write_file(lk, pid + "\n")
    return true
}

fn _atlas_lock_release() -> void {
    let root = _nexus_root()
    let lk = root + "/" + ATLAS_LOCK
    exec("rm -f " + _shq(lk) + " 2>/dev/null || true")
}

fn _check_atlas_drift(cmd: str, seed: str) -> void {
    // Called at end-of-round. If size/mtime moved without our write, flag it.
    // Current Step 6 scaffolding: warn only. Step 5 follow-up refuses.
    let sz_now = _atlas_size()
    let mt_now = _atlas_mtime()
    if sz_now != g_atlas_boot_size || mt_now != g_atlas_boot_mtime {
        _emit_engine_error("WARN", "atlas_external_write_detected", cmd, seed)
        // re-baseline so we do not warn every round — only the first drift
        // per externally-mutated epoch is actionable.
        g_atlas_boot_size = sz_now
        g_atlas_boot_mtime = mt_now
    }
}

// ─── lifecycle: PID file, FIFO, TERM trap ───
fn _setup_lifecycle() -> int {
    // PID file
    let pid_raw = exec("echo $$").trim()
    let pid = if pid_raw.len() > 0 { pid_raw } else { "0" }
    write_file(PID_FILE, pid + "\n")

    // FIFO (mkfifo fails cleanly if exists — we unlink first)
    exec("rm -f " + _shq(REQ_FIFO) + " 2>/dev/null || true")
    let rc = exec("mkfifo -m 0600 " + _shq(REQ_FIFO) + " 2>&1; echo RC=$?").trim()
    if !rc.contains("RC=0") {
        eprintln("nexus_drilld: mkfifo failed: " + rc)
        return 1
    }

    // SIGTERM trap — touch TERM_FLAG. (hexa exec subshell scope — drill pattern과 동일
    // 외부에서 `kill -TERM $(cat /tmp/nexus_drilld.pid)` 시 user 가 직접 touch 해도 OK.)
    exec("rm -f " + _shq(TERM_FLAG) + " 2>/dev/null || true")
    exec("trap 'touch " + _shq(TERM_FLAG) + "' INT TERM 2>/dev/null || true")

    // Phase 2 §4.2 atlas single-writer acquire + baseline observation.
    if !_atlas_lock_acquire() {
        eprintln("nexus_drilld: atlas lock busy — another daemon running")
        return 0
    }
    g_atlas_boot_size = _atlas_size()
    g_atlas_boot_mtime = _atlas_mtime()

    let mut v = 0
    try { v = to_int(pid) } catch e { v = 0 }  // @allow-silent-catch
    return v
}

fn _cleanup_lifecycle() -> void {
    _atlas_lock_release()
    exec("rm -f " + _shq(REQ_FIFO) + " " + _shq(PID_FILE) + " " + _shq(TERM_FLAG) + " 2>/dev/null || true")
}

fn _term_requested() -> bool {
    let chk = exec("[ -f " + _shq(TERM_FLAG) + " ] && echo y || echo n").trim()
    return chk == "y"
}

// ─── op handlers ───
fn _handle_ping(reply: str, served: int, boot_s: int, last_req_s: int) -> void {
    let now = _now_s()
    let uptime = now - boot_s
    let idle = now - last_req_s
    let pid = exec("echo $$").trim()
    let pid_safe = if pid.len() > 0 { pid } else { "0" }
    let payload = "{\"status\":\"pong\",\"served\":" + to_string(served)
        + ",\"idle_s\":" + to_string(idle)
        + ",\"uptime_s\":" + to_string(uptime)
        + ",\"pid\":" + pid_safe
        + ",\"version\":\"" + VERSION + "\"}"
    _reply(reply, payload)
}

// ─── Phase 2 Step 5 — unified stage dispatcher ───
// Shared body for all 6 stages (smash/free/absolute/meta/hyper/resonance). Each
// _handle_<stage> is a thin wrapper that calls _dispatch_stage(). Step 2
// introduced the exec-based scaffolding; Step 5 generalizes it to 5 more stages
// while keeping Phase 1 drill op untouched (backward compat).
//
// Body is still exec-based — Step 5 does NOT convert to in-proc (that is the
// follow-up work once blowup.hexa gains a --stage selector and state can be
// shared across stages in a single hexa process).
fn _dispatch_stage(stage: str, seed: str, depth: int, fast: bool, e14_skip: bool) -> str {
    // §4.1 reset — must happen on every op entry so same seed across B→A
    // sequence yields byte-identical result (Step 4 guard).
    _reset_round(seed)
    let t0 = _now_ms()

    if seed.len() == 0 {
        _emit_engine_error("ERROR", "seed_empty", stage, seed)
        return "{\"ok\":false,\"cmd\":\"" + _json_escape(stage) + "\",\"reason\":\"seed_empty\",\"ms\":0}"
    }
    if depth < 1 || depth > 7 {
        _emit_engine_error("ERROR", "depth_out_of_range", stage, seed)
        return "{\"ok\":false,\"cmd\":\"" + _json_escape(stage)
            + "\",\"seed\":\"" + _json_escape(seed)
            + "\",\"reason\":\"depth_out_of_range\",\"ms\":0}"
    }

    // E14 LRU compat — zero-work OK with cache_hit=true.
    if e14_skip {
        let t1_e = _now_ms()
        let ms_e = t1_e - t0
        let round_e = _round_id_from(t1_e, seed)
        return "{\"ok\":true,\"cmd\":\"" + _json_escape(stage)
            + "\",\"seed\":\"" + _json_escape(seed)
            + "\",\"depth\":" + to_string(depth)
            + ",\"ms\":" + to_string(ms_e)
            + ",\"round_new\":\"" + round_e
            + "\",\"metrics\":{\"" + _json_escape(stage) + "\":0,\"cache_hit\":true},\"stage_parallel\":false}"
    }

    // Exec blowup with stage selector. blowup.hexa is expected to read
    // NEXUS_BLOWUP_STAGE env (or fall back to legacy smash) — Step 5 uses env
    // so no blowup.hexa CLI change is required for Phase 2 Step 5 landing.
    //
    // Step 7 per-cmd hard timeout — if stage exceeds CMD_TIMEOUT_S, abort with
    // ERR timeout so a runaway round cannot wedge the daemon.
    let root = _nexus_root()
    let blowup = root + "/cli/blowup/core/blowup.hexa"
    let fast_arg = if fast { " --fast" } else { "" }
    let cmd = "NEXUS_BLOWUP_STAGE=" + _shq(stage) + " "
        + "timeout " + to_string(CMD_TIMEOUT_S) + " "
        + _hexa_bin() + " run " + _shq(blowup) + " math " + to_string(depth)
        + " --no-graph --seeds " + _shq(seed) + fast_arg + " 2>/dev/null | tail -40; echo RC=$?"
    let mut new_nodes = 0
    let mut timed_out = false
    try {
        let out = exec(cmd)
        // `timeout` exits 124 on SIGALRM; we detect via RC= sentinel.
        if out.contains("RC=124") { timed_out = true }
        else if out.len() > 0 { new_nodes = 1 }
    } catch e {
        _emit_engine_error("CRASH", stage + "_crash", stage, seed)
        return "{\"ok\":false,\"cmd\":\"" + _json_escape(stage)
            + "\",\"seed\":\"" + _json_escape(seed)
            + "\",\"reason\":\"" + _json_escape(stage) + "_crash\",\"ms\":0}"
    }
    if timed_out {
        _emit_engine_error("ERROR", "timeout", stage, seed)
        return "{\"ok\":false,\"cmd\":\"" + _json_escape(stage)
            + "\",\"seed\":\"" + _json_escape(seed)
            + "\",\"reason\":\"timeout\",\"ms\":" + to_string(CMD_TIMEOUT_S * 1000) + "}"
    }

    let t1 = _now_ms()
    let ms = t1 - t0
    let round_new = _round_id_from(t1, seed)
    // Phase 2 Step 6 — detect external writer drift (warn only; Step 5
    // follow-up will flush g_partial_graph_delta here and refuse drift).
    _check_atlas_drift(stage, seed)
    return "{\"ok\":true,\"cmd\":\"" + _json_escape(stage)
        + "\",\"seed\":\"" + _json_escape(seed)
        + "\",\"depth\":" + to_string(depth)
        + ",\"ms\":" + to_string(ms)
        + ",\"round_new\":\"" + round_new
        + "\",\"metrics\":{\"" + _json_escape(stage) + "\":" + to_string(new_nodes)
        + ",\"cache_hit\":false},\"stage_parallel\":false}"
}

fn _handle_smash(seed: str, depth: int, fast: bool, e14_skip: bool, reply: str) -> void {
    _reply(reply, _dispatch_stage("smash", seed, depth, fast, e14_skip))
}
fn _handle_free(seed: str, depth: int, fast: bool, e14_skip: bool, reply: str) -> void {
    _reply(reply, _dispatch_stage("free", seed, depth, fast, e14_skip))
}
fn _handle_absolute(seed: str, depth: int, fast: bool, e14_skip: bool, reply: str) -> void {
    _reply(reply, _dispatch_stage("absolute", seed, depth, fast, e14_skip))
}
fn _handle_meta(seed: str, depth: int, fast: bool, e14_skip: bool, reply: str) -> void {
    _reply(reply, _dispatch_stage("meta", seed, depth, fast, e14_skip))
}
fn _handle_hyper(seed: str, depth: int, fast: bool, e14_skip: bool, reply: str) -> void {
    _reply(reply, _dispatch_stage("hyper", seed, depth, fast, e14_skip))
}
fn _handle_resonance(seed: str, depth: int, fast: bool, e14_skip: bool, reply: str) -> void {
    _reply(reply, _dispatch_stage("resonance", seed, depth, fast, e14_skip))
}

fn _handle_drill(seed: str, max_rounds: int, reply: str) -> void {
    if seed.len() == 0 {
        _reply(reply, "{\"status\":\"err\",\"reason\":\"seed_empty\"}")
        return
    }
    let mr = if max_rounds > 0 { max_rounds } else { 1 }
    // Phase 1 MVP: dispatch by exec-ing `nexus drill` — still amortizes client-side hexa startup
    // (daemon 프로세스는 이미 부팅 완료 = 클라이언트가 매번 hexa run 을 돌리지 않아도 됨).
    // Phase 2 에서 in-process 호출로 치환.
    let root = _nexus_root()
    let run_hexa = root + "/cli/run.hexa"
    let cmd = _hexa_bin() + " run " + _shq(run_hexa) + " drill"
        + " --seed " + _shq(seed)
        + " --max-rounds " + to_string(mr)
        + " --preset fast 2>&1"
    let t0 = _now_ms()
    let out = exec(cmd)
    let t1 = _now_ms()
    let wall = t1 - t0

    // naive absorption count — parse stdout for "ROUND <k>" lines or final absorption count.
    // Phase 1 은 대충 round 수 만 추출 (실제 absorptions 은 Phase 2 에서 정확히).
    let lines = out.split("\n")
    let mut rounds = 0
    let mut absorb = 0
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if ln.contains("ROUND ") { rounds = rounds + 1 }
        if ln.contains("absorption") || ln.contains("ABSORB") { absorb = absorb + 1 }
        i = i + 1
    }
    let payload = "{\"status\":\"ok\""
        + ",\"absorptions\":" + to_string(absorb)
        + ",\"wall_ms\":" + to_string(wall)
        + ",\"rounds\":" + to_string(rounds)
        + ",\"seed\":\"" + seed.replace("\"", "\\\"") + "\"}"
    _reply(reply, payload)
}

// ─── main loop ───
fn _main_loop(boot_s: int) -> int {
    let mut served = 0
    let mut last_req_s = boot_s
    let mut draining = false

    _log("ready", ",\"version\":\"" + VERSION + "\",\"preload\":{" + _preload_state() + "}")

    while true {
        if _term_requested() {
            draining = true
            _log("sigterm_recv", ",\"served\":" + to_string(served))
            break
        }
        // Step 7 — max-lifetime + idle checks between requests. Note: FIFO open
        // itself blocks until a writer connects, so these only fire on the tick
        // right after a completed request. A Phase 3 launchd watchdog provides
        // the external guarantee; here we just self-shutdown on the next wake.
        let now_s = _now_s()
        if now_s - boot_s > MAX_LIFETIME_S {
            _log("max_lifetime_exit", ",\"served\":" + to_string(served)
                + ",\"uptime_s\":" + to_string(now_s - boot_s))
            draining = true
            break
        }
        if now_s - last_req_s > IDLE_LIMIT_S && served > 0 {
            _log("idle_exit", ",\"served\":" + to_string(served)
                + ",\"idle_s\":" + to_string(now_s - last_req_s))
            draining = true
            break
        }
        // blocking read one line from FIFO — exec("cat FIFO").
        //
        // History (2026-04-21 htz verify L1..L3):
        //   1) exec("bash -c 'IFS= read -r LINE < FIFO && printf %s $LINE'")
        //      FAILED — hexa exec() wrapper remaps child stdin; `read` never
        //      sees FIFO bytes. (L1/L2)
        //   2) read_file(FIFO) FAILED — runtime.c:3189 uses fseek(SEEK_END)
        //      + ftell + fread(buf,1,len,f); FIFOs report len=0, so fread
        //      reads zero bytes and returns empty. (L3)
        //   3) cat FIFO → hexa captures cat stdout via its pipe, no stdin
        //      redirect involved. cat handles FIFO open/EOF correctly.
        //
        // Each client writes one request line (`printf REQ > FIFO`) and closes,
        // producing FIFO EOF so cat terminates after one message. Multi-line
        // writers MUST close between messages (docs §3).
        let raw = exec("cat " + _shq(REQ_FIFO))
        let line = raw.trim()
        if line.len() == 0 { continue }

        let op = _json_str(line, "op")
        let reply = _json_str(line, "reply")
        // Guard: bogus input (no "op" field) must not count as served. L2 htz
        // verify 2026-04-21 saw the daemon log "served=1,2,.." with op="" due to
        // the now-fixed FIFO capture bug — keep the check so future transport
        // glitches don't poison `served` either.
        if op.len() == 0 {
            _log("malformed_request", ",\"raw\":\"" + _json_escape(line) + "\"")
            continue
        }
        served = served + 1
        last_req_s = _now_s()
        _log("request", ",\"op\":\"" + op + "\",\"served\":" + to_string(served))

        if op == "ping" {
            _handle_ping(reply, served - 1, boot_s, last_req_s)
            continue
        }
        if op == "quit" {
            _log("quit_recv", ",\"served\":" + to_string(served))
            _reply(reply, "{\"status\":\"ok\",\"msg\":\"bye\"}")
            draining = true
            break
        }
        if op == "drill" {
            let seed = _json_str(line, "seed")
            let mr = _json_int(line, "max_rounds")
            _handle_drill(seed, mr, reply)
            continue
        }
        // ─── Phase 2 stage ops (smash / free / absolute / meta / hyper / resonance) ───
        // Each stage shares the _dispatch_stage body; dispatch only differs by op name.
        if op == "smash" || op == "free" || op == "absolute"
            || op == "meta" || op == "hyper" || op == "resonance" {
            let seed = _json_str(line, "seed")
            let depth_raw = _json_int(line, "depth")
            let depth = if depth_raw > 0 { depth_raw } else { 3 }
            let fast = _json_bool(line, "fast")
            let e14_skip = _json_bool(line, "e14_skip")
            if op == "smash"     { _handle_smash(seed, depth, fast, e14_skip, reply) }
            else if op == "free"      { _handle_free(seed, depth, fast, e14_skip, reply) }
            else if op == "absolute"  { _handle_absolute(seed, depth, fast, e14_skip, reply) }
            else if op == "meta"      { _handle_meta(seed, depth, fast, e14_skip, reply) }
            else if op == "hyper"     { _handle_hyper(seed, depth, fast, e14_skip, reply) }
            else                      { _handle_resonance(seed, depth, fast, e14_skip, reply) }
            continue
        }
        _reply(reply, "{\"status\":\"err\",\"reason\":\"unknown_op\",\"op\":\"" + op + "\"}")
    }

    _log("shutdown", ",\"served\":" + to_string(served) + ",\"drain\":" + (if draining { "true" } else { "false" }))
    return 0
}

// ─── entry ───
fn main() -> void {
    let boot_s = _now_s()
    let pid = _setup_lifecycle()
    if pid == 0 {
        eprintln("nexus_drilld: lifecycle setup failed")
        exit(1)  // @allow-silent-exit
    }
    _log("boot", ",\"pid\":" + to_string(pid) + ",\"req_fifo\":\"" + REQ_FIFO + "\"")
    println("nexus_drilld: READY pid=" + to_string(pid) + " fifo=" + REQ_FIFO)
    let rc = _main_loop(boot_s)
    _cleanup_lifecycle()
    exit(rc)  // @allow-silent-exit
}

main()
