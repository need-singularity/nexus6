// shared/drill/category_classifier.hexa — topology-aware seed category classifier (2026-04-21)
//
// Role:
//   모든 seed 를 동일 drill 파이프라인으로 흘리는 대신, seed 문자열을 규칙 기반으로 분류하여
//   대수(algebra) · 해석(analysis) · 기하(geometry) · 수론(number) · 위상(topology) · 논리(logic)
//   중 top-1 category 를 판정. E8 problem_preset 과 직교로 depth plan 에 second layer 조정을 부여.
//
// 알고리즘 (ML 없이):
//   1) seed → to_lower + symbol 그대로 유지.
//   2) keyword/symbol 매칭 → category 별 weighted score.
//        analysis:  ∫ ∂ ∇ dx integral derivative limit lim epsilon delta smooth continuous measure
//        number:    prime mod gcd lcm zeta dirichlet riemann diophant congruence p-adic
//        algebra:   Σ ∏ group ring field module ideal galois polynomial matrix vector tensor
//        topology:  manifold homotopy homology fundamental_group fibre sheaf bundle open_cover
//        logic:     ∀ ∃ ⊢ ⊨ axiom theorem predicate quantifier godel undecidable recursive
//        geometry:  π sphere curvature geodesic metric euclidean riemannian volume area polytope
//   3) symbol density 보정: 유니코드 수학기호 (∫∂∇Σ∏∀∃π) 출현은 +3 가중, 일반 키워드는 +1.
//   4) top-1 score 결정. ratio(2위/1위) ≥ 0.85 이면 MIXED. score=0 이면 UNKNOWN.
//   5) category → depth 조정:
//        analysis:  depth +1 전체, hyper stage emphasize (+1 추가)
//        number:    depth same, absolute stage emphasize (+1)
//        algebra:   depth same, free stage emphasize (+1)
//        topology:  depth -1 (recursion 위험), meta stage emphasize (+1 보존)
//        geometry:  depth +1, free stage emphasize (+1)
//        logic:     depth same, meta+hyper stage emphasize
//        mixed/unknown: no-op.
//
// 사용 (standalone 검증 모드):
//   hexa run shared/drill/category_classifier.hexa --seed "Riemann zeta zero distribution GUE"
//   → stdout: NEXUS_CATEGORY {"seed_hash":"...","top":"number","score":7,"runner_up":"analysis",...}
//
// cli/run.hexa 에서는 동일 로직을 inline helper 로 호출 (per-drill-call, subprocess 오버헤드 회피).
// 이 파일은 SSOT — 규칙 수정 시 cli/run.hexa 의 _cat_* helper 도 동기 수정 필요.

fn _cat_sym_weight() -> int { return 3 }
fn _cat_kw_weight() -> int  { return 1 }

fn _cat_contains(s: str, k: str) -> bool {
    if k.len() == 0 { return false }
    return s.contains(k)
}

fn _cat_count_hits(lo: str, raw: str, keywords: [str], symbols: [str]) -> int {
    let mut score = 0
    let mut i = 0
    while i < len(keywords) {
        if _cat_contains(lo, keywords[i]) { score = score + _cat_kw_weight() }
        i = i + 1
    }
    let mut j = 0
    while j < len(symbols) {
        if _cat_contains(raw, symbols[j]) { score = score + _cat_sym_weight() }
        j = j + 1
    }
    return score
}

fn _cat_score_analysis(lo: str, raw: str) -> int {
    let kw: [str] = ["integral", "derivative", "limit", "epsilon", "delta", "smooth", "continuous", "measure", "fourier", "laplace", "pde", "ode", "sobolev", "banach", "hilbert", "navier", "convergence", "asymptotic"]
    let sy: [str] = ["∫", "∂", "∇", "∮", "dx", "lim"]
    return _cat_count_hits(lo, raw, kw, sy)
}

fn _cat_score_number(lo: str, raw: str) -> int {
    let kw: [str] = ["prime", "mod ", " mod", "gcd", "lcm", "zeta", "dirichlet", "riemann zeta", "diophant", "congruence", "p-adic", "padic", "modular form", "elliptic curve", "bsd", "l-function", "class number"]
    let sy: [str] = ["ℤ", "ℚ", "ℙ", "ζ"]
    return _cat_count_hits(lo, raw, kw, sy)
}

fn _cat_score_algebra(lo: str, raw: str) -> int {
    let kw: [str] = ["group", "ring", "field", "module", "ideal", "galois", "polynomial", "matrix", "vector space", "tensor", "homomorphism", "automorphism", "category", "functor", "lie algebra", "representation"]
    let sy: [str] = ["Σ", "∏", "⊗", "⊕"]
    return _cat_count_hits(lo, raw, kw, sy)
}

fn _cat_score_topology(lo: str, raw: str) -> int {
    let kw: [str] = ["manifold", "homotopy", "homology", "cohomology", "fundamental group", "fibre", "fiber bundle", "sheaf", "open cover", "compact", "connected", "hausdorff", "poincare", "cw complex", "simplicial", "topolog"]
    let sy: [str] = ["π₁", "π_1", "H^n", "H_n"]
    return _cat_count_hits(lo, raw, kw, sy)
}

fn _cat_score_logic(lo: str, raw: str) -> int {
    let kw: [str] = ["axiom", "theorem", "predicate", "quantifier", "godel", "gödel", "undecidable", "recursive", "consistency", "completeness", "zfc", "peano", "forcing", "ordinal", "cardinal", "reverse math"]
    let sy: [str] = ["∀", "∃", "⊢", "⊨", "¬"]
    return _cat_count_hits(lo, raw, kw, sy)
}

fn _cat_score_geometry(lo: str, raw: str) -> int {
    let kw: [str] = ["sphere", "curvature", "geodesic", "metric", "euclidean", "riemannian", "volume", "polytope", "triangle", "angle", "isoperimetric", "convex", "hyperbolic", "projective", "affine", "symplectic"]
    let sy: [str] = ["π", "θ", "∠"]
    return _cat_count_hits(lo, raw, kw, sy)
}

fn _cat_pick_top(scores: [int], names: [str]) -> [int] {
    // return [top_idx, top_score, runner_idx, runner_score]
    let mut ti = -1
    let mut ts = 0
    let mut ri = -1
    let mut rs = 0
    let mut i = 0
    while i < len(scores) {
        let s = scores[i]
        if s > ts {
            ri = ti
            rs = ts
            ti = i
            ts = s
        } else if s > rs {
            ri = i
            rs = s
        }
        i = i + 1
    }
    return [ti, ts, ri, rs]
}

fn classify_category(seed: str) -> str {
    // top-1 category string: analysis|number|algebra|topology|logic|geometry|MIXED|UNKNOWN
    let lo = seed.to_lower()
    let raw = seed
    let scores: [int] = [
        _cat_score_analysis(lo, raw),
        _cat_score_number(lo, raw),
        _cat_score_algebra(lo, raw),
        _cat_score_topology(lo, raw),
        _cat_score_logic(lo, raw),
        _cat_score_geometry(lo, raw)
    ]
    let names: [str] = ["analysis", "number", "algebra", "topology", "logic", "geometry"]
    let pick = _cat_pick_top(scores, names)
    let ti = pick[0]
    let ts = pick[1]
    let rs = pick[3]
    if ti < 0 || ts == 0 { return "UNKNOWN" }
    if rs > 0 && rs * 100 >= ts * 85 { return "MIXED" }
    return names[ti]
}

fn category_plan_delta(cat: str) -> [int] {
    // per-stage delta to ADD to base depth plan (smash, free, absolute, meta_closure, hyper, resonance)
    // clamping + floor≥0 is caller's responsibility.
    if cat == "analysis"  { return [1, 1, 1, 1, 2, 1] }  // depth +1, hyper +1 extra
    if cat == "number"    { return [0, 0, 1, 0, 0, 0] }  // absolute emphasize
    if cat == "algebra"   { return [0, 1, 0, 0, 0, 0] }  // free emphasize
    if cat == "topology"  { return [-1, -1, -1, 0, -1, -1] } // depth -1 (recursion 위험), meta 보존
    if cat == "logic"     { return [0, 0, 0, 1, 1, 0] }  // meta+hyper emphasize
    if cat == "geometry"  { return [1, 2, 1, 1, 1, 1] }  // depth +1, free +1 extra
    return [0, 0, 0, 0, 0, 0]  // MIXED / UNKNOWN → no-op
}

fn _cat_plan_apply(base: [int], delta: [int]) -> [int] {
    let mut out: [int] = []
    let mut i = 0
    while i < len(base) {
        let v = base[i] + delta[i]
        let clamped = if v < 0 { 0 } else if v > 6 { 6 } else { v }
        out = out + [clamped]
        i = i + 1
    }
    return out
}

fn _cat_args_get_any(a: [any], flag: str, default_val: str) -> str {
    let n = a.len()
    let mut i = 0
    while i < n {
        let t = to_string(a[i])
        if t == flag {
            if i + 1 < n { return to_string(a[i + 1]) }
        }
        i = i + 1
    }
    return default_val
}

fn _cat_plan_describe(p: [int]) -> str {
    return "[" + to_string(p[0]) + "," + to_string(p[1]) + "," + to_string(p[2])
        + "," + to_string(p[3]) + "," + to_string(p[4]) + "," + to_string(p[5]) + "]"
}

fn _cat_sh_quote(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _cat_seed_hash(seed: str) -> str {
    // deterministic 8-char hex — mirrors cli/run.hexa _seed_batch_hash style (openssl/shasum fallback).
    let q = _cat_sh_quote(seed)
    let h1 = exec("printf '%s' " + q + " | openssl dgst -sha1 2>/dev/null | awk '{print $NF}' | cut -c1-8").trim()
    if h1.len() == 8 { return h1 }
    let h2 = exec("printf '%s' " + q + " | shasum 2>/dev/null | cut -c1-8").trim()
    if h2.len() == 8 { return h2 }
    return "l" + to_string(seed.len()) + "x"
}

// ─────────── standalone CLI entrypoint ───────────
fn main() {
    let argv = args()
    let seed = _cat_args_get_any(argv, "--seed", "")
    if seed.len() == 0 {
        eprintln("category_classifier: --seed \"...\" 필수")
        return
    }
    let lo = seed.to_lower()
    let raw = seed
    let sc_an = _cat_score_analysis(lo, raw)
    let sc_nu = _cat_score_number(lo, raw)
    let sc_al = _cat_score_algebra(lo, raw)
    let sc_to = _cat_score_topology(lo, raw)
    let sc_lo = _cat_score_logic(lo, raw)
    let sc_ge = _cat_score_geometry(lo, raw)
    let cat = classify_category(seed)
    let delta = category_plan_delta(cat)
    let sh = _cat_seed_hash(seed)
    println("NEXUS_CATEGORY {"
        + "\"seed_hash\":\"" + sh + "\""
        + ",\"top\":\"" + cat + "\""
        + ",\"scores\":{\"analysis\":" + to_string(sc_an)
        + ",\"number\":" + to_string(sc_nu)
        + ",\"algebra\":" + to_string(sc_al)
        + ",\"topology\":" + to_string(sc_to)
        + ",\"logic\":" + to_string(sc_lo)
        + ",\"geometry\":" + to_string(sc_ge) + "}"
        + ",\"delta\":" + _cat_plan_describe(delta)
        + "}")
}

main()
