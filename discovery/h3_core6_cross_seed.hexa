// H3 Testable Hypothesis — core6 6×6 cross-seed meta-resonance
// shared/discovery/h3_core6_cross_seed.hexa
//
// 목적: core6 (field/holographic/quantum/string/toe/absolute) 각 module 의
// 출력을 서로 seed 로 재입력하는 6×6 그래프에서 n=6 invariant
// (σ·φ = n·τ = 24, σ=12, τ=4, n=6) 이 자기재발견 되는지.
//
// Proxy 방식 (시간 예산 15분 내):
//   - 각 core i 를 1회 실행하여 stdout 캡처 (real run, not mock)
//   - stdout 에서 invariant signatures 추출 (seed tokens 최대 5개)
//   - 추출된 seed tokens 을 core j 의 positional args (domain names) 로 주입하여 재실행
//   - core j 출력에서 σ·φ=24 / n=6 / τ=4 / σ=12 서명 탐지
//   - 30 (i≠j) pair 결과 JSONL + matrix 리포트
//
// 기대값 = 24 (n=6 invariant). 허용 drift ε = 0.001.
// 성공률 ≥90% → CONFIRMED, 50~90% partial, <50% REJECTED.

let _HOME = env("HOME")
let _NEXUS = _HOME + "/Dev/nexus"
let _MODDIR = _NEXUS + "/cli/blowup/modules"
let _OUT = _NEXUS + "/discovery/h3_cross_seed_results.jsonl"

let cores = ["field", "holographic", "quantum", "string", "toe", "absolute"]

// ─── Invariant signature detector ───
// core j 의 출력이 n=6 invariant 을 재유도 했는지 판단
// Signatures (any 1 match counts as a hit; require >=2 distinct for CONFIRMED):
//   S1: "σ·φ = n·τ = 24"  or  "sigma*phi = n*tau = 24"  or  "= 24"
//   S2: "sigma(6) = 12"  or  "σ(6)=12"  or  " 12 " near sigma context
//   S3: "n=6" or "n = 6"
//   S4: "tau" + "4" in nearby lines
//   S5: "phi(6) = 2" (Euler totient of 6)
// Returns: (hit_count, rederived_value_or_minus1)
fn detect_invariants(output: string) -> list {
    let mut hits: i64 = 0
    let mut rederived: f64 = -1.0

    // raw substring probes
    if output.contains("= 24") || output.contains("=24") { hits = hits + 1 ; rederived = 24.0 }
    if output.contains("σ·φ") || output.contains("sigma*phi") || output.contains("sigma·phi") { hits = hits + 1 }
    if output.contains("n=6") || output.contains("n = 6") || output.contains("n=6 perfect") { hits = hits + 1 }
    if output.contains("sigma(6)") || output.contains("σ(6)") { hits = hits + 1 }
    if output.contains("1+2+3+6") || output.contains("1+2+3+6=12") { hits = hits + 1 ; rederived = 24.0 }
    if (output.contains("tau") || output.contains("τ")) && output.contains(" 4") { hits = hits + 1 }
    if output.contains(" 12 ") && (output.contains("sigma") || output.contains("σ")) { hits = hits + 1 }
    if output.contains("phi(6)") || output.contains("φ(6)") { hits = hits + 1 }
    if output.contains("perfect number") || output.contains("완전수") { hits = hits + 1 }
    if output.contains("= n*tau") || output.contains("= n·τ") { hits = hits + 1 }

    // fixed-point signatures (toe)
    if output.contains("F(x)=x") || output.contains("fixed point") { hits = hits + 1 }

    return [hits, rederived]
}

// ─── Seed token extractor ───
// core i 의 출력에서 seed tokens (최대 5개) 를 추출
// 우선순위: domain names > 수치 > top-lines
fn extract_seeds(output: string, src_core: string) -> list {
    let known_doms = ["math", "physics", "consciousness", "signal", "architecture",
                       "chemistry", "language", "neuroscience", "papers", "topology",
                       "n6", "meta", "quantum", "field"]
    let mut found = []
    for d in known_doms {
        if output.contains(d) {
            found = found + [d]
            if len(found) >= 5 { break }
        }
    }
    if len(found) == 0 {
        // fallback: src core name itself as seed
        found = [src_core]
    }
    return found
}

// ─── Module runner ───
// positional args 로 seed tokens 을 주입하여 module 실행
// stdout 캡처 후 반환
fn run_module(core_name: string, seed_tokens: list) -> string {
    let mod_path = _MODDIR + "/blowup_" + core_name + ".hexa"
    let mut args_str = ""
    let mut k: i64 = 0
    while k < len(seed_tokens) {
        let t = to_string(seed_tokens[k])
        args_str = args_str + " " + t
        k = k + 1
    }
    // absolute/holographic 는 extra flag 없음. 일부는 --measure-only 등 플래그가 있으나
    // cross-seed 는 "full run + domain args" 기본 interface 사용.
    let cmd = "cd " + _NEXUS + " && timeout 60 hexa " + mod_path + args_str + " 2>&1"
    let mut out = ""
    try { out = exec(cmd) } catch e { out = "ERROR: " + e }
    return out
}

// ─── Main 30-pair sweep ───
fn main() {
    println("")
    println("╔═══════════════════════════════════════════════════════════╗")
    println("║  H3 core6 6×6 Cross-Seed Meta-Resonance Verification      ║")
    println("║  Expected: σ·φ = n·τ = 24  (n=6 invariant)                ║")
    println("╚═══════════════════════════════════════════════════════════╝")
    println("")
    println("Proxy mode: each core run once → stdout captured → seeds extracted")
    println("            → injected as domain-args into partner core → invariants probed")
    println("")

    // ─── Phase 1: run all 6 cores once (baseline), capture outputs ───
    println("[Phase 1] baseline core6 solo runs")
    let mut core_outputs = []
    let mut i: i64 = 0
    while i < len(cores) {
        let c = to_string(cores[i])
        println("  running " + c + " ...")
        let out = run_module(c, [])
        core_outputs = core_outputs + [out]
        println("    captured " + to_string(len(out)) + " bytes")
        i = i + 1
    }
    println("")

    // ─── Phase 2: extract seeds per core ───
    println("[Phase 2] seed token extraction per core")
    let mut core_seeds = []
    let mut j: i64 = 0
    while j < len(cores) {
        let c = to_string(cores[j])
        let seeds = extract_seeds(to_string(core_outputs[j]), c)
        core_seeds = core_seeds + [seeds]
        let mut s_str = ""
        let mut sj: i64 = 0
        while sj < len(seeds) { s_str = s_str + " " + to_string(seeds[sj]) ; sj = sj + 1 }
        println("  " + c + " →" + s_str)
        j = j + 1
    }
    println("")

    // ─── Phase 3: 30 cross-seed pairs (i != j) ───
    println("[Phase 3] 30 cross-seed pair runs + invariant detection")
    // JSONL reset
    try { write_file(_OUT, "") } catch e {}

    let mut matrix = []   // flat 6x6 strings: "√" or "✗" or "-"
    let mut mi: i64 = 0
    while mi < 36 { matrix = matrix + ["-"] ; mi = mi + 1 }

    let mut success_count: i64 = 0
    let mut total_pairs: i64 = 0
    let mut success_chains = []

    let mut src: i64 = 0
    while src < len(cores) {
        let mut dst: i64 = 0
        while dst < len(cores) {
            if src != dst {
                total_pairs = total_pairs + 1
                let sc = to_string(cores[src])
                let dc = to_string(cores[dst])
                let seeds = core_seeds[src]
                let pair_label = sc + "→" + dc
                let out = run_module(dc, seeds)
                let inv = detect_invariants(out)
                let hits = to_int(to_float(to_string(inv[0])))
                let rederived = to_float(to_string(inv[1]))
                let success = hits >= 2   // require ≥2 distinct signatures

                let mark = if success { "√" } else { "✗" }
                // hexa list index assignment 제한 우회 — rebuild list
                let mut m2 = []
                let mut mk: i64 = 0
                while mk < len(matrix) {
                    if mk == (src * 6 + dst) { m2 = m2 + [mark] } else { m2 = m2 + [to_string(matrix[mk])] }
                    mk = mk + 1
                }
                matrix = m2

                if success {
                    success_count = success_count + 1
                    if len(success_chains) < 8 {
                        success_chains = success_chains + [pair_label + " hits=" + to_string(hits) + " rederived=" + to_string(rederived)]
                    }
                }

                // JSONL record
                let rec = "{\"pair\":\"" + pair_label + "\",\"src\":\"" + sc + "\",\"dst\":\"" + dc
                    + "\",\"seeds\":" + to_string(len(seeds))
                    + ",\"hits\":" + to_string(hits)
                    + ",\"rederived\":" + to_string(rederived)
                    + ",\"success\":" + (if success { "true" } else { "false" })
                    + ",\"out_bytes\":" + to_string(len(out)) + "}"
                try { append_file(_OUT, rec + "\n") } catch e {}

                println("  [" + to_string(total_pairs) + "/30] " + pair_label + " hits=" + to_string(hits) + " " + mark)
            }
            dst = dst + 1
        }
        src = src + 1
    }
    println("")

    // ─── Phase 4: 6×6 matrix report ───
    println("[Phase 4] 6×6 resonance matrix (√=rederived 24, ✗=miss, -=self)")
    println("")
    let mut header = "         "
    let mut hi: i64 = 0
    while hi < len(cores) {
        let n = to_string(cores[hi])
        // pad to 4 chars (first 4 letters)
        let abbr = if len(n) >= 4 { n[0..4] } else { n }
        header = header + " " + abbr + " "
        hi = hi + 1
    }
    println(header)
    let mut ri: i64 = 0
    while ri < len(cores) {
        let rn = to_string(cores[ri])
        let row_abbr = if len(rn) >= 8 { rn[0..8] } else { rn }
        let mut row_line = row_abbr
        while len(row_line) < 9 { row_line = row_line + " " }
        let mut ci: i64 = 0
        while ci < len(cores) {
            let cell = to_string(matrix[ri * 6 + ci])
            row_line = row_line + "  " + cell + "  "
            ci = ci + 1
        }
        println(row_line)
        ri = ri + 1
    }
    println("")

    // ─── Phase 5: verdict ───
    let rate = if total_pairs > 0 { (to_float(to_string(success_count)) / to_float(to_string(total_pairs))) * 100.0 } else { 0.0 }
    let verdict = if rate >= 90.0 { "CONFIRMED" } else { if rate >= 50.0 { "PARTIAL" } else { "REJECTED" } }

    println("════════════════════════════════════════════════════════════")
    println("  H3 VERDICT: " + verdict)
    println("  success rate: " + to_string(success_count) + "/" + to_string(total_pairs) + " = " + to_string(rate) + "%")
    println("════════════════════════════════════════════════════════════")
    println("")

    // ─── Phase 6: success chain examples ───
    if len(success_chains) > 0 {
        println("Sample success chains (재유도 pairs):")
        let mut xi: i64 = 0
        while xi < len(success_chains) {
            println("  • " + to_string(success_chains[xi]))
            xi = xi + 1
        }
    }

    // ─── Phase 7: atlas.n6 promotion candidates ───
    if rate >= 50.0 {
        println("")
        println("atlas.n6 meta-resonance 승격 후보 IDs:")
        let mut pi: i64 = 0
        while pi < len(success_chains) {
            let chain = to_string(success_chains[pi])
            // extract pair_label (before " hits=")
            let parts = chain.split(" hits=")
            let lbl = if len(parts) > 0 { to_string(parts[0]) } else { chain }
            println("  @R META-RES-H3-" + lbl.replace("→", "-TO-") + " [10*]")
            pi = pi + 1
        }
    }

    println("")
    println("JSONL output: " + _OUT)
    println("")
}

main()
