// H1 — CODATA Vintage Drift Detector
// Reads pre-computed /tmp/h1_precomputed.tsv (per-constant atlas matches),
// computes drift, emits JSONL.
// Pre-step (shell): grep atlas.n6 for CODATA/PDG + nearest @-id + bridge count.

comptime const INP_PATH = "/tmp/h1_precomputed.tsv"
comptime const OUT_PATH = "/Users/ghost/Dev/nexus/discovery/h1_codata_drift_report.jsonl"

comptime const EPS_DRIFT = 0.000000001  // 1e-9

pure fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

pure fn rel_drift(a: float, b: float) -> float {
    let denom_raw = abs_f(b)
    let denom = if denom_raw > 0.0 { denom_raw } else { 1.0 }
    abs_f(a - b) / denom
}

let raw = read_file(INP_PATH)
let lines = raw.split("\n")
println("H1: tsv rows = " + to_string(lines.len()))

let mut rows = []
let mut n_total = 0
let mut n_drift = 0
let mut n_bridge = 0

let mut i = 0
while i < lines.len() {
    let ln = lines[i]
    if ln.len() < 5 { i = i + 1; continue }
    let c = ln.split("\t")
    if c.len() < 7 { i = i + 1; continue }

    let name   = c[0]
    let substr = c[1]
    let v18    = to_float(c[2])
    let v22    = to_float(c[3])
    let line_n = to_int(c[4])
    let atlas_id = c[5]
    let bridge = to_int(c[6])

    let drift = rel_drift(v18, v22)
    let has_drift = drift > EPS_DRIFT
    let bridge_affected = has_drift && bridge > 0

    n_total = n_total + 1
    if has_drift { n_drift = n_drift + 1 }
    if bridge_affected { n_bridge = n_bridge + 1 }

    let hd_s = if has_drift { "true" } else { "false" }
    let br_s = if bridge_affected { "true" } else { "false" }

    let parts = [
        "{\"const\":\"", name,
        "\",\"atlas_id\":\"", atlas_id,
        "\",\"atlas_line\":", to_string(line_n),
        ",\"substr\":\"", substr,
        "\",\"codata_2018\":", to_string(v18),
        ",\"codata_2022\":", to_string(v22),
        ",\"rel_drift\":", to_string(drift),
        ",\"has_drift\":", hd_s,
        ",\"bridge_mentions\":", to_string(bridge),
        ",\"bridge_affected\":", br_s,
        "}"
    ]
    rows.push(parts.join(""))
    println("  " + name + "  drift=" + to_string(drift) + "  line=" + to_string(line_n) + "  id=" + atlas_id + "  bridge=" + to_string(bridge))

    i = i + 1
}

let buf = rows.join("\n") + "\n"
write_file(OUT_PATH, buf)
println("H1: wrote " + OUT_PATH)
println("H1 summary: drifted=" + to_string(n_drift) + "/" + to_string(n_total) + " bridge_affected=" + to_string(n_bridge))
