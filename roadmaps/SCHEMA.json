{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://need-singularity.github.io/nexus/config/roadmaps/SCHEMA.json",
  "title": "NEXUS-6 Roadmap Schema",
  "description": "4 프로젝트 로드맵 스키마 (anima/nexus/n6-architecture/zeta-surpass) — 3-track 병렬 + phase gate + DAG. SPA 연동: https://need-singularity.github.io/nexus/roadmap/",
  "type": "object",
  "required": ["_meta", "tracks", "phases"],
  "additionalProperties": true,

  "properties": {
    "_meta": {
      "type": "object",
      "required": ["name", "project", "schema_version", "updated", "strategy", "mode", "exec_order"],
      "properties": {
        "name":           { "type": "string" },
        "project":        { "type": "string", "enum": ["nexus", "anima", "n6-architecture", "zeta-surpass", "anima-train", "hexa-lang", "papers", "void", "airgenome", "hive"] },
        "parent_project": { "type": "string", "enum": ["nexus", "anima", "n6-architecture", "hexa-lang", "papers", "void", "airgenome", "hive"], "description": "선택 — 서브로드맵일 경우 상위 프로젝트" },
        "parent_roadmap": { "type": "string", "description": "선택 — 상위 로드맵 JSON 경로" },
        "competitor":     { "type": "object", "description": "선택 — 경쟁사/벤치마킹 대상 메타" },
        "description":    { "type": "string" },
        "updated":        { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}" },
        "schema_version": { "type": "string" },
        "parent":         { "type": "string" },
        "strategy":       { "type": "string", "enum": ["parallel_3track_with_tier_gates", "parallel_Ntrack_with_tier_gates"] },
        "target":         { "type": "string" },
        "compression":    { "type": "string", "description": "예: '6w → 2.5w (2.4x)' — 단축율 선언" },
        "mode":           { "type": "string", "enum": ["smash_free", "smash_confirm", "manual"] },
        "exec_order":     { "type": "string", "description": "예: 'phases[] 순서대로, 각 phase 내 parallel[] 는 배열 원소 동시 실행'" },
        "superseded_by":  { "type": "string", "description": "레거시 파일이 가리키는 신 SSOT 경로" }
      }
    },

    "tracks": {
      "type": "object",
      "description": "독립 레인 정의. 일반 3트랙 (n=6 호환). 각 track은 parallel 발사 단위.",
      "minProperties": 2,
      "maxProperties": 6,
      "patternProperties": {
        "^[A-Z][A-Z0-9_]*$": {
          "type": "object",
          "required": ["owner", "independent_of"],
          "properties": {
            "owner":          { "type": "string", "description": "트랙 주도 주체 — 경로 또는 팀명" },
            "pod":            { "type": "string" },
            "host":           { "type": "string" },
            "independent_of": { "type": "array", "items": { "type": "string" }, "description": "이 트랙과 진짜 병렬로 돌 수 있는 다른 트랙 id 목록" }
          }
        }
      }
    },

    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "status", "parallel", "gate_exit"],
        "properties": {
          "id":              { "type": "string", "pattern": "^P[0-9]+$" },
          "name":            { "type": "string" },
          "duration_hours":  { "type": "number", "minimum": 0 },
          "status":          { "type": "string", "enum": ["planned", "in_progress", "done", "blocked", "aborted"] },
          "parallel": {
            "type": "array",
            "description": "phase 내 동시 실행 트랙 그룹. 각 원소는 하나의 track 의 이번 phase 작업 묶음",
            "items": {
              "type": "object",
              "required": ["track", "tasks"],
              "properties": {
                "track": { "type": "string" },
                "tasks": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "task"],
                    "properties": {
                      "id":             { "type": "string", "description": "TRACK-Pn-k 포맷 권장" },
                      "task":           { "type": "string" },
                      "depends_on":     { "type": "array", "items": { "type": "string" } },
                      "ssot_ref":       { "type": "string", "description": "연결된 ROI/ML 항목 경로" },
                      "done_criteria":  { "type": "string" },
                      "status":         { "type": "string", "enum": ["todo", "in_progress", "done", "blocked"] }
                    }
                  }
                }
              }
            }
          },
          "gate_exit": {
            "type": "object",
            "required": ["criteria", "fail_action"],
            "properties": {
              "criteria":    { "type": "array", "items": { "type": "string" }, "description": "AND 전체 PASS 시 이 phase 완료 + 다음 phase 진입" },
              "fail_action": { "type": "string", "description": "예: '실패 트랙만 연장, 다른 트랙은 다음 phase 진입'" }
            }
          }
        }
      }
    }
  },

  "examples_reference": {
    "canonical": "shared/roadmaps/roadmap_shortest.json",
    "_note": "이 파일의 3-track × phase × gate 구조가 표준. 7프로젝트 로드맵은 이 구조를 따라야 함."
  }
}
