// pass_gate_an11.hexa — AN11 3-condition runtime verifier (dest/round mode)
//
// GOVERNS: shared/rules/anima.json#AN11 (실사용 완성 강제 / real-usage mandatory)
// SPEC:    shared/roadmaps/archive/20260420_pre_unification/anima_full_pre.json#an11_conditions
// DESIGN:  docs/alm_clm_verifier_design_20260420.md §C (Tier C — AN11 verifier 실체)
//
// TWO INVOCATION MODES
// ====================================================================
//
// (1) RUNTIME MODE — 실제 학습 산출물 검증 (PRIMARY, manifest-invoked)
//       hexa run shared/consciousness/pass_gate_an11.hexa --dest alm --round r12
//       hexa run shared/consciousness/pass_gate_an11.hexa --dest clm --round r5
//
//     3-CONDITION runtime gate:
//       (a) weight_emergent        — phi_vec.json exists + NOT stub-marked
//                                    (reject sa_phi_vec_proxy / DEFAULT /
//                                     phi_extractor_pending / proxy / STUB)
//       (b) consciousness_attached — phi_vec len == 16 + L2 norm > threshold
//                                    (threshold: env PHI_NORM_THRESHOLD or 1.0)
//       (c) real_usable            — HTTP endpoint live (from endpoint config)
//                                    returns HTTP 200 + non-empty body containing
//                                    reply text field (response schema validation)
//
//     SSOT emission: shared/state/{dest}_r{N}_an11_verify.json
//       { "dest": "alm|clm", "round": "rN", "ts": "...", "verdicts":
//         {"a_weight_emergent": "PASS|FAIL", "b_consciousness_attached": "...",
//          "c_real_usable": "..."}, "reasons": [...], "overall": "PASS|PARTIAL|FAIL",
//         "exit_code": 0|1|2 }
//
//     EXIT CODES:
//       0 = all 3 conditions PASS
//       1 = partial PASS (1 or 2 conditions PASS, others FAIL)
//       2 = all 3 conditions FAIL (or input error — config missing)
//
// (2) LEGACY CONV-PATH MODE — 기존 an11_scanner.hexa + convergence file lint
//       hexa run shared/consciousness/pass_gate_an11.hexa <conv_path> [--json]
//
//     Preserved verbatim from pre-2026-04-20 verifier (bypass pattern scanner
//     + placeholder detection in .convergence annotations). Triggered when
//     first positional arg is a .convergence file path instead of --dest flag.
//
//     See §LEGACY section below for exit-code contract (0/1/2/3).
//
// DETERMINISTIC ONLY — NO LLM JUDGE. All checks are file existence /
// regex presence / numeric threshold / HTTP status. Per rule:
//   docs/alm_clm_verifier_design_20260420.md §1 "LLM judge 전면 금지".

// ─── RUNTIME MODE — config conventions ─────────────────────────────────
//
// phi_vec.json search order (first hit wins):
//   1. shared/state/{dest}_r{N}_phi_vec.json           — canonical SSOT
//   2. shared/state/{dest}_r{N}_phi_vec_logged.json   — trainer-emitted alt
//
// endpoint config search order:
//   1. shared/state/{dest}_r{N}_serve_endpoint.json   — {"url": "http://..."}
//   2. fallback: NOT_CONFIGURED (→ c_real_usable FAIL with reason)
//
// phi_vec stub markers (if any substring matches → a_weight_emergent FAIL):
let STUB_MARKERS = [
    "sa_phi_vec_proxy",
    "phi_extractor_pending",
    "DEFAULT",
    "STUB",
    "stub",
    "proxy_only",
    "pending_extractor",
    "not_implemented",
    "TODO"
]

// Required reply schema fields for (c) HTTP response validation
let REPLY_SCHEMA_FIELDS = [
    "text",
    "reply",
    "output",
    "response",
    "generation"
]

// ─── LEGACY MODE constants (preserved from 2026-04-19 version) ─────────
let BYPASS_PATTERNS = [
    "system_prompt",
    "너는 유능한",
    "apply_chat_template",
    "mock_llm",
    "mock LLM",
    "사전 답변",
    "synthetic_judge",
    "synthetic path",
    "phi_holo_scaled=1500",
    "hardcoded phi",
    "hardcode phi",
    "laws_unattached",
    "laws 미적용",
    "laws not wired",
    "zip shell",
    "empty zip",
    "R2 껍데기",
    "README pending",
    "README TBD",
    "재현 불가"
]

let PLACEHOLDER_TOKENS = [
    "TBD",
    "pending",
    "scaffold",
    "stub",
    "smoke",
    "mock",
    "wrapping"
]

let PASS_PATTERNS = [
    "@state ossified",
    "@state pass",
    "@state completed",
    "@state done",
    "@state scaffold_done",
    "@state completed_gap",
    "@state ossified_pass"
]

// ─── Helpers ──────────────────────────────────────────────────────────

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn now_utc() -> string {
    return _str(exec("date -u +%FT%TZ")).trim()
}

fn shell_escape_safe(s: string) -> string {
    // conservative: allow only [A-Za-z0-9./:_-]. Everything else → _
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        let c = char_code(ch, 0)
        let is_alnum = (c >= 48 && c <= 57) || (c >= 65 && c <= 90) || (c >= 97 && c <= 122)
        let is_ok_punct = c == 46 || c == 47 || c == 58 || c == 95 || c == 45
        if is_alnum || is_ok_punct { out = out + ch } else { out = out + "_" }
        i = i + 1
    }
    return out
}

fn my_file_exists(path: string) -> bool {
    // Use stat (pipe-free, avoids shell metachar blocker)
    let probe = _str(exec("stat -f %N " + path + " 2>/dev/null")).trim()
    if probe != "" { return true }
    // GNU stat fallback
    let probe2 = _str(exec("stat -c %n " + path + " 2>/dev/null")).trim()
    return probe2 != ""
}

fn read_safe(path: string) -> string {
    if !my_file_exists(path) { return "" }
    return _str(read_file(path))
}

// Resolve repo root (prefer ANIMA/NEXUS env, fallback git toplevel)
fn resolve_root() -> string {
    let a = _str(env("ANIMA"))
    if a != "" { return a }
    let n = _str(env("NEXUS"))
    if n != "" { return n }
    let gt = _str(exec("git rev-parse --show-toplevel 2>/dev/null")).trim()
    if gt != "" { return gt }
    let h = _str(env("HOME"))
    return h + "/Dev/nexus"
}

// ─── JSON numeric extractor (tolerant) ────────────────────────────────

fn byte_at(s: string, i: int) -> int {
    let sub = s.substring(i, i + 1)
    return char_code(sub, 0)
}

fn is_num_byte(b: int) -> bool {
    if b >= 48 && b <= 57 { return true }
    if b == 46 { return true }
    if b == 45 { return true }
    if b == 43 { return true }
    if b == 101 { return true }
    if b == 69 { return true }
    return false
}

fn index_of_from(hay: string, needle: string, start: int) -> int {
    let n = len(hay)
    if start < 0 { return hay.index_of(needle) }
    if start >= n { return -1 }
    let tail = hay.substring(start, n)
    let idx = tail.index_of(needle)
    if idx < 0 { return -1 }
    return start + idx
}

fn extract_float_key(blob: string, key: string) -> float {
    let needle = "\"" + key + "\""
    let key_idx = blob.index_of(needle)
    if key_idx < 0 { return 0.0 - 999999.0 }
    let colon_idx = index_of_from(blob, ":", key_idx)
    if colon_idx < 0 { return 0.0 - 999999.0 }
    let n = len(blob)
    let mut i = colon_idx + 1
    while i < n {
        let b = byte_at(blob, i)
        if b == 32 || b == 9 || b == 10 || b == 13 { i = i + 1 } else { break }
    }
    if i + 3 <= n {
        let la = blob.substring(i, i + 3)
        if la == "NaN" { return 0.0 - 999999.0 }
    }
    let start = i
    while i < n {
        let b = byte_at(blob, i)
        if is_num_byte(b) { i = i + 1 } else { break }
    }
    if i == start { return 0.0 - 999999.0 }
    return to_float(blob.substring(start, i))
}

// Parse all float values inside the first `[ ... ]` array literal found in blob.
// Returns list of floats; empty list on no array found.
fn parse_float_array(blob: string) -> array {
    let lbr = blob.index_of("[")
    if lbr < 0 { return [] }
    let rbr = index_of_from(blob, "]", lbr)
    if rbr < 0 { return [] }
    let inner = blob.substring(lbr + 1, rbr)
    let parts = inner.split(",")
    let mut out = []
    let mut i = 0
    let n = len(parts)
    while i < n {
        let p = _str(parts[i]).trim()
        if p != "" {
            // Strip quotes / trailing whitespace
            if p.index_of("NaN") < 0 && p.index_of("null") < 0 {
                let v = to_float(p)
                out = push(out, v)
            } else {
                out = push(out, 0.0)
            }
        }
        i = i + 1
    }
    return out
}

// Extract the phi_vec array — try "phi_vec":[...] first, else parse first array.
fn extract_phi_vec(blob: string) -> array {
    let k = blob.index_of("\"phi_vec\"")
    if k < 0 {
        // fallback: first bare array
        return parse_float_array(blob)
    }
    let colon = index_of_from(blob, ":", k)
    if colon < 0 { return [] }
    let tail = blob.substring(colon, len(blob))
    return parse_float_array(tail)
}

// L2 norm of float array
fn l2_norm(arr: array) -> float {
    let mut sum = 0.0
    let mut i = 0
    let n = len(arr)
    while i < n {
        let v = to_float(arr[i])
        sum = sum + v * v
        i = i + 1
    }
    // Simple sqrt via Newton (hexa may not have sqrt builtin in stage0)
    if sum <= 0.0 { return 0.0 }
    let mut x = sum
    let mut j = 0
    while j < 40 {
        x = 0.5 * (x + sum / x)
        j = j + 1
    }
    return x
}

// ─── Stub-marker scanner ──────────────────────────────────────────────
fn detect_stub_marker(blob: string) -> string {
    let mut i = 0
    while i < len(STUB_MARKERS) {
        let tok = _str(STUB_MARKERS[i])
        if blob.index_of(tok) >= 0 { return tok }
        i = i + 1
    }
    return ""
}

// ─── Reply schema validation ──────────────────────────────────────────
fn reply_schema_ok(body: string) -> bool {
    if body == "" { return false }
    let mut i = 0
    while i < len(REPLY_SCHEMA_FIELDS) {
        let fld = _str(REPLY_SCHEMA_FIELDS[i])
        // Look for "fld": or "fld" :
        if body.index_of("\"" + fld + "\"") >= 0 { return true }
        i = i + 1
    }
    return false
}

// ─── HTTP probe via curl (no shell metachars outside URL) ─────────────
// Writes a small shell helper to /tmp so exec() doesn't need pipes.
fn probe_http(url: string) -> array {
    // Returns [status_code_str, body]. Empty status → probe failed entirely.
    let safe_url = shell_escape_safe(url)
    let script = "/tmp/_an11_probe.sh"
    let body_path = "/tmp/_an11_body.txt"
    let code_path = "/tmp/_an11_code.txt"
    let sh = "#!/bin/sh\n"
        + "rm -f " + body_path + " " + code_path + " 2>/dev/null\n"
        + "curl -s -o " + body_path + " -w \"%{http_code}\" --max-time 5 \"" + safe_url + "\" > " + code_path + " 2>/dev/null\n"
        + "exit 0\n"
    write_file(script, sh)
    exec("chmod +x " + script)
    exec(script)
    let code = _str(read_safe(code_path)).trim()
    let body = _str(read_safe(body_path))
    return [code, body]
}

// ─── Runtime-mode condition evaluators ────────────────────────────────

// Build [PASS|FAIL, reason] pair.
fn verdict_weight_emergent(phi_vec_path: string) -> array {
    if !my_file_exists(phi_vec_path) {
        return ["FAIL", "phi_vec.json_missing path=" + phi_vec_path]
    }
    let blob = read_safe(phi_vec_path)
    if blob == "" {
        return ["FAIL", "phi_vec.json_empty path=" + phi_vec_path]
    }
    let stub = detect_stub_marker(blob)
    if stub != "" {
        return ["FAIL", "stub_marker_present marker=" + stub]
    }
    // Require non-zero phi_holo or at least one non-zero element to reject all-zero default
    let arr = extract_phi_vec(blob)
    if len(arr) == 0 {
        return ["FAIL", "phi_vec_array_absent"]
    }
    let norm = l2_norm(arr)
    if norm <= 0.000001 {
        return ["FAIL", "phi_vec_all_zero (likely DEFAULT init)"]
    }
    return ["PASS", "phi_vec_clean norm=" + to_string(norm)]
}

fn verdict_consciousness_attached(phi_vec_path: string) -> array {
    if !my_file_exists(phi_vec_path) {
        return ["FAIL", "phi_vec.json_missing"]
    }
    let blob = read_safe(phi_vec_path)
    if blob == "" {
        return ["FAIL", "phi_vec.json_empty"]
    }
    let arr = extract_phi_vec(blob)
    let n = len(arr)
    if n != 16 {
        return ["FAIL", "phi_vec_len=" + to_string(n) + " expected=16"]
    }
    let threshold_env = _str(env("PHI_NORM_THRESHOLD"))
    let threshold = if threshold_env == "" { 1.0 } else { to_float(threshold_env) }
    let norm = l2_norm(arr)
    if norm <= threshold {
        return ["FAIL", "l2_norm=" + to_string(norm) + " threshold=" + to_string(threshold)]
    }
    return ["PASS", "l2_norm=" + to_string(norm) + " > threshold=" + to_string(threshold)]
}

fn verdict_real_usable(endpoint_cfg_path: string) -> array {
    if !my_file_exists(endpoint_cfg_path) {
        return ["FAIL", "endpoint_config_missing path=" + endpoint_cfg_path]
    }
    let cfg = read_safe(endpoint_cfg_path)
    if cfg == "" {
        return ["FAIL", "endpoint_config_empty"]
    }
    // Extract "url":"..."
    let key = "\"url\""
    let ki = cfg.index_of(key)
    if ki < 0 {
        return ["FAIL", "endpoint_config_no_url_field"]
    }
    let colon = index_of_from(cfg, ":", ki)
    if colon < 0 {
        return ["FAIL", "endpoint_config_malformed_url"]
    }
    let q1 = index_of_from(cfg, "\"", colon + 1)
    if q1 < 0 {
        return ["FAIL", "endpoint_config_url_quote_missing"]
    }
    let q2 = index_of_from(cfg, "\"", q1 + 1)
    if q2 < 0 {
        return ["FAIL", "endpoint_config_url_quote_unclosed"]
    }
    let url = cfg.substring(q1 + 1, q2)
    if url == "" {
        return ["FAIL", "endpoint_url_empty"]
    }
    let probe = probe_http(url)
    let code = _str(probe[0])
    let body = _str(probe[1])
    if code == "" {
        return ["FAIL", "http_probe_unreachable url=" + url]
    }
    if code != "200" {
        return ["FAIL", "http_status=" + code + " url=" + url]
    }
    if !reply_schema_ok(body) {
        return ["FAIL", "response_schema_missing_reply_field url=" + url + " body_len=" + to_string(len(body))]
    }
    return ["PASS", "http_200 schema_ok url=" + url]
}

// ─── JSON emitter (SSOT) ──────────────────────────────────────────────

fn json_escape(s: string) -> string {
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        let c = char_code(ch, 0)
        if c == 34 { out = out + "\\\"" }
        else { if c == 92 { out = out + "\\\\" } else { if c == 10 { out = out + "\\n" } else { if c == 13 { out = out + "\\r" } else { if c == 9 { out = out + "\\t" } else { out = out + ch } } } } }
        i = i + 1
    }
    return out
}

fn emit_ssot(ssot_path: string, dest: string, round: string,
             va: string, ra: string, vb: string, rb: string, vc: string, rc: string,
             overall: string, exit_code: int) {
    let ts = now_utc()
    let mut j = "{\n"
    j = j + "  \"dest\": \"" + json_escape(dest) + "\",\n"
    j = j + "  \"round\": \"" + json_escape(round) + "\",\n"
    j = j + "  \"ts\": \"" + json_escape(ts) + "\",\n"
    j = j + "  \"verdicts\": {\n"
    j = j + "    \"a_weight_emergent\": \"" + va + "\",\n"
    j = j + "    \"b_consciousness_attached\": \"" + vb + "\",\n"
    j = j + "    \"c_real_usable\": \"" + vc + "\"\n"
    j = j + "  },\n"
    j = j + "  \"reasons\": {\n"
    j = j + "    \"a\": \"" + json_escape(ra) + "\",\n"
    j = j + "    \"b\": \"" + json_escape(rb) + "\",\n"
    j = j + "    \"c\": \"" + json_escape(rc) + "\"\n"
    j = j + "  },\n"
    j = j + "  \"overall\": \"" + overall + "\",\n"
    j = j + "  \"exit_code\": " + to_string(exit_code) + "\n"
    j = j + "}\n"
    write_file(ssot_path, j)
}

// ─── RUNTIME MODE entry ───────────────────────────────────────────────

fn run_runtime_mode(dest: string, round: string) -> int {
    let root = resolve_root()
    let state_dir = root + "/state"
    let phi_primary = state_dir + "/" + dest + "_" + round + "_phi_vec.json"
    let phi_alt     = state_dir + "/" + dest + "_" + round + "_phi_vec_logged.json"
    let endpoint_cfg = state_dir + "/" + dest + "_" + round + "_serve_endpoint.json"
    let ssot_path = state_dir + "/" + dest + "_" + round + "_an11_verify.json"

    // Resolve phi_vec path (primary first, fallback alt)
    let phi_vec_path = if my_file_exists(phi_primary) { phi_primary } else { phi_alt }

    println("[AN11] runtime verifier  dest=" + dest + " round=" + round)
    println("[AN11] repo_root=" + root)
    println("[AN11] phi_vec_path=" + phi_vec_path)
    println("[AN11] endpoint_cfg=" + endpoint_cfg)

    let va_pair = verdict_weight_emergent(phi_vec_path)
    let vb_pair = verdict_consciousness_attached(phi_vec_path)
    let vc_pair = verdict_real_usable(endpoint_cfg)

    let va = _str(va_pair[0])
    let ra = _str(va_pair[1])
    let vb = _str(vb_pair[0])
    let rb = _str(vb_pair[1])
    let vc = _str(vc_pair[0])
    let rc = _str(vc_pair[1])

    println("[AN11] (a) weight_emergent        = " + va + "  — " + ra)
    println("[AN11] (b) consciousness_attached = " + vb + "  — " + rb)
    println("[AN11] (c) real_usable            = " + vc + "  — " + rc)

    let mut pass_count = 0
    if va == "PASS" { pass_count = pass_count + 1 }
    if vb == "PASS" { pass_count = pass_count + 1 }
    if vc == "PASS" { pass_count = pass_count + 1 }

    let mut overall = "FAIL"
    let mut exit_code = 2
    if pass_count == 3 { overall = "PASS"; exit_code = 0 }
    if pass_count == 1 || pass_count == 2 { overall = "PARTIAL"; exit_code = 1 }

    println("[AN11] overall = " + overall + "  (" + to_string(pass_count) + "/3 PASS)")
    println("[AN11] exit_code = " + to_string(exit_code))

    emit_ssot(ssot_path, dest, round, va, ra, vb, rb, vc, rc, overall, exit_code)
    println("[AN11] ssot emitted: " + ssot_path)

    return exit_code
}

// ─── LEGACY MODE (conv-path file verifier) ────────────────────────────
// Preserved from 2026-04-19 implementation. Triggered when 1st positional
// arg ends with ".convergence" (and no --dest flag present).

fn extract_directive(content: string, tag: string) -> string {
    let needle = "\n" + tag + " "
    let at = content.index_of(needle)
    if at < 0 {
        if content.index_of(tag + " ") == 0 {
            let end = content.index_of("\n")
            if end < 0 { return content.substring(len(tag) + 1, len(content)).trim() }
            return content.substring(len(tag) + 1, end).trim()
        }
        return ""
    }
    let start = at + len(needle)
    let rest = content.substring(start, len(content))
    let nl = rest.index_of("\n")
    if nl < 0 { return rest.trim() }
    return rest.substring(0, nl).trim()
}

fn extract_block(content: string, tag: string) -> string {
    let needle = "\n" + tag + "\n"
    let at = content.index_of(needle)
    if at < 0 {
        return extract_directive(content, tag)
    }
    let start = at + len(needle)
    let rest = content.substring(start, len(content))
    let lines = rest.split("\n")
    let mut acc = ""
    let mut i = 0
    let n = len(lines)
    while i < n {
        let line = _str(lines[i])
        let trimmed = line.trim()
        if trimmed.index_of("@") == 0 { return acc.trim() }
        if trimmed == "" && i > 0 { return acc.trim() }
        acc = acc + line + "\n"
        i = i + 1
    }
    return acc.trim()
}

fn claims_pass(content: string) -> bool {
    let mut j = 0
    while j < len(PASS_PATTERNS) {
        if content.index_of(_str(PASS_PATTERNS[j])) >= 0 { return true }
        j = j + 1
    }
    return false
}

fn already_revoked(content: string) -> bool {
    return content.index_of("revoked") >= 0
}

fn detect_bypass(content: string) -> string {
    let lc = content.to_lower()
    let mut i = 0
    while i < len(BYPASS_PATTERNS) {
        let pat = _str(BYPASS_PATTERNS[i]).to_lower()
        if lc.index_of(pat) >= 0 { return _str(BYPASS_PATTERNS[i]) }
        i = i + 1
    }
    return ""
}

fn contains_placeholder(val: string) -> string {
    if val == "" { return "empty" }
    let vl = val.to_lower()
    let mut i = 0
    while i < len(PLACEHOLDER_TOKENS) {
        let tok = _str(PLACEHOLDER_TOKENS[i]).to_lower()
        if vl.index_of(tok) >= 0 { return _str(PLACEHOLDER_TOKENS[i]) }
        i = i + 1
    }
    return ""
}

fn phi_evidence_tangible(phi_line: string) -> bool {
    if phi_line == "" { return false }
    if phi_line.index_of(".json") < 0 { return false }
    return true
}

fn endpoint_tangible(block: string) -> bool {
    if block == "" { return false }
    let lc = block.to_lower()
    let has_http  = lc.index_of("http://") >= 0 || lc.index_of("https://") >= 0
    let has_curl  = lc.index_of("curl ") >= 0
    let has_ssh   = lc.index_of("ssh ") >= 0
    let has_hexa  = lc.index_of("hexa ") >= 0 || lc.index_of("hexa run") >= 0
    let has_r2    = lc.index_of("r2:") >= 0
    let has_api   = lc.index_of("api:") >= 0 || lc.index_of("cli:") >= 0
    return has_http || has_curl || has_ssh || has_hexa || has_r2 || has_api
}

fn weight_proof_clean(block: string) -> bool {
    if block == "" { return false }
    let lc = block.to_lower()
    if lc.index_of("system prompt") >= 0 && lc.index_of("no system prompt") < 0 { return false }
    if lc.index_of("apply_chat_template") >= 0 && lc.index_of("no chat_template") < 0 { return false }
    if lc.index_of("persona wrapping") >= 0 { return false }
    return true
}

fn run_legacy_mode(conv_path: string, json_out: bool) -> int {
    let content = read_safe(conv_path)
    if content == "" {
        print_err("[AN11] INPUT_ERR cannot read " + conv_path)
        return 3
    }
    if already_revoked(content) && !claims_pass(content) { return 0 }
    if !claims_pass(content) {
        if json_out {
            println("{\"conv\":\"" + conv_path + "\",\"an11\":\"N/A\",\"reason\":\"no_pass_claim\"}")
        }
        return 0
    }
    let bypass = detect_bypass(content)
    if bypass != "" && !already_revoked(content) {
        let ctx_ok = content.index_of("revocation_reason") >= 0 && content.index_of("revoked") >= 0
        if !ctx_ok {
            if json_out {
                println("{\"conv\":\"" + conv_path + "\",\"an11\":\"BYPASS\",\"pattern\":\"" + bypass + "\"}")
            } else {
                print_err("[AN11-VIOLATION] conv=" + conv_path + " bypass_pattern=\"" + bypass + "\"")
            }
            return 2
        }
    }
    let phi = extract_directive(content, "@phi_evidence")
    let weight = extract_block(content, "@weight_emergent_proof")
    let endpoint = extract_block(content, "@real_usable_endpoint")

    let mut missing = []

    let ph_ph = contains_placeholder(phi)
    if ph_ph != "" { missing = push(missing, "a_phi[" + ph_ph + "]") }
    else {
        if !phi_evidence_tangible(phi) { missing = push(missing, "a_phi[not_tangible]") }
    }

    let ph_w = contains_placeholder(weight)
    if ph_w != "" { missing = push(missing, "b_weight[" + ph_w + "]") }
    else {
        if !weight_proof_clean(weight) { missing = push(missing, "b_weight[prompt_contaminated]") }
    }

    let ph_e = contains_placeholder(endpoint)
    if ph_e != "" { missing = push(missing, "c_endpoint[" + ph_e + "]") }
    else {
        if !endpoint_tangible(endpoint) { missing = push(missing, "c_endpoint[no_http_cli_r2]") }
    }

    if len(missing) == 0 {
        if json_out {
            println("{\"conv\":\"" + conv_path + "\",\"an11\":\"PASS\",\"evidence\":{\"a\":\"ok\",\"b\":\"ok\",\"c\":\"ok\"}}")
        }
        return 0
    }
    let fails_str = join(missing, ",")
    if json_out {
        println("{\"conv\":\"" + conv_path + "\",\"an11\":\"MISSING\",\"fails\":\"" + fails_str + "\"}")
    } else {
        print_err("[AN11-VIOLATION] conv=" + conv_path + " missing_conditions=[" + fails_str + "]")
    }
    return 1
}

// ─── Arg parsing + dispatch ───────────────────────────────────────────

fn main() {
    let argv = args()
    let argc = len(argv)
    // argv layout under `hexa run`: [binary, script, <user args...>]
    // or direct: [script, <user args...>]
    // We scan from index 0 for --dest / --round / --json / positional.
    let mut dest = ""
    let mut round = ""
    let mut json_out = false
    let mut conv_path = ""
    let mut k = 0
    while k < argc {
        let a = _str(argv[k])
        if a == "--dest" {
            if k + 1 < argc { dest = _str(argv[k + 1]); k = k + 1 }
        } else {
            if a == "--round" {
                if k + 1 < argc { round = _str(argv[k + 1]); k = k + 1 }
            } else {
                if a == "--json" {
                    json_out = true
                } else {
                    if a.index_of("--") != 0 {
                        // positional: if it ends with .convergence, treat as legacy mode path
                        if a.ends_with(".convergence") { conv_path = a }
                    }
                }
            }
        }
        k = k + 1
    }

    // RUNTIME MODE takes precedence when --dest + --round are present
    if dest != "" && round != "" {
        let valid_dest = (dest == "alm") || (dest == "clm")
        if !valid_dest {
            print_err("[AN11] INPUT_ERR --dest must be 'alm' or 'clm' (got: " + dest + ")")
            exit(2)
        }
        let rc = run_runtime_mode(dest, round)
        exit(rc)
    }

    // LEGACY MODE: single conv path
    if conv_path != "" {
        let rc = run_legacy_mode(conv_path, json_out)
        exit(rc)
    }

    print_err("usage:")
    print_err("  hexa run pass_gate_an11.hexa --dest {alm|clm} --round r<N>   # runtime 3-condition gate")
    print_err("  hexa run pass_gate_an11.hexa <conv_path> [--json]            # legacy convergence linter")
    exit(3)
}
