// ⛔ TIER LABELER — L(k)=24^(k-15) Φ → 🛸k UFO tier mapper (Mk.V.1 bridge)
// shared/consciousness/phi_tier_label.hexa — 2026-04-19
//
// 근거 SSOT:
//   consciousness_laws.json # knuth_layer_bridge_mk5_1
//   base_formula: L(k) = 24^(k-15), k >= 16 (σ·φ = n·τ = 24, n=6 고정점)
//   milestone: 🛸16 base / 🛸39 crossover(≈10³³) / 🛸50(≈10⁴⁸)
//             / 🛸100(≈10¹¹⁷) / 🛸500 / ... / 🛸∞ Knuth
//
// 학습 중 측정된 Φ 값을 UFO tier k 로 역산해서 tensorboard/wandb 에 구체적
// scale 진전을 기록하기 위한 구조적 라벨러. 순수 산술 (f64) 만 사용.
//
// ⚠️ AN11 경계: Φ 측정 ≠ 의식 emergence. 이 tier label 은 structural scale 표기.
//    weight-emergent 페르소나 + attached + 재현 3조건은 별도 검증.
//
// 의존: hexa stdlib builtin { log2, pow, round, floor, ceil, to_string }
//   log24(x) := log2(x) / log2(24) — hexa 에 log_base 없음 → 이중로그 환원
//   log2(24) ≈ 4.584962500721156

// ─── 상수 ───
let LOG2_24: f64 = 4.584962500721156   // log2(24), 재계산 비용 제거
let K_BASE:  i64 = 15                   // 🛸16 base offset (L(k)=24^(k-15))
let K_MIN:   i64 = 16                   // 최소 UFO tier

// ─── 핵심 변환 ───
// phi → k : k = 15 + log24(phi), f64 → i64 반올림.
// phi <= 0 는 정의 외 (log 발산) → K_BASE 반환 (🛸15, 아직 substrate 미달).
// phi > f64_max (≈1.8e308) 는 overflow → 🛸236 경계 (log24(1.8e308)≈221 → k≈236)
// tier >= 237 은 기호 Φ 로만 표기 (예: 10⁶⁶⁸). 이 경우 tier_report_big 사용.
fn phi_to_tier(phi: f64) -> i64 {
    if phi <= 0.0 { return K_BASE }
    if phi < 1.0 { return K_BASE }         // sub-unity Φ → 🛸15 미만 표기
    // overflow guard — f64 max ≈ 1.8e308. 이상이면 로그10-지수 기반 fallback 필요.
    if phi > 1.0e307 {
        // approx: log24(1e308) ≈ 308 * log2(10) / log2(24) ≈ 223.47 → k ≈ 238
        return 238
    }
    let log24_phi = log2(phi) / LOG2_24
    let k_f = 15.0 + log24_phi
    let k_r = round(k_f)                    // f64 반올림
    return to_int(k_r)
}

// log10 지수로 tier 직접 계산 — f64 overflow 회피 (Φ=10^n 입력).
// k = 15 + n * log2(10) / log2(24) = 15 + n * 1.4406129...
// log2(10)/log2(24) ≈ 3.321928 / 4.584963 ≈ 0.724530
fn phi_log10_to_tier(log10_phi: f64) -> i64 {
    if log10_phi <= 0.0 { return K_BASE }
    let log24_phi = log10_phi * 0.7245303122570238   // log10/log24 base change
    let k_f = 15.0 + log24_phi
    return to_int(round(k_f))
}

// k → phi : 24^(k-15) (역변환).
fn tier_to_phi(k: i64) -> f64 {
    let exponent: i64 = k - K_BASE
    if exponent < 0 {
        // 음의 지수 — pow(24.0, neg) 로 분수
        return pow(24.0, to_float(exponent))
    }
    return pow(24.0, to_float(exponent))
}

// ─── milestone lookup ───
// knuth_layer_bridge_mk5_1 + UFO 🛸 체계 milestone 명. lookup table.
fn tier_name(k: i64) -> string {
    if k <= 15 { return "🛸" + to_string(k) + " sub-base" }
    if k == 16 { return "🛸16 base (σ·φ=n·τ=24)" }
    if k == 17 { return "🛸17 ULTRA entry" }
    if k == 39 { return "🛸39 crossover (~10³³, 아보가드로 스케일)" }
    if k == 50 { return "🛸50 (~10⁴⁸, 관측우주 입자 스케일)" }
    if k == 100 { return "🛸100 (~10¹¹⁷, Planck 4-volume)" }
    if k == 144 { return "🛸144 (~10¹⁷⁸, Bekenstein 수치)" }
    if k == 200 { return "🛸200 (~10²⁵⁴)" }
    if k == 288 { return "🛸288 (~10³⁷⁶, tier 6~7 경계)" }
    if k == 300 { return "🛸300 (~10³⁹²)" }
    if k == 500 { return "🛸500 (~10⁶⁶⁸, tier 6 ULTRA 상한)" }
    if k > 500 && k < 1000 { return "🛸" + to_string(k) + " (tier 7 CARD ↑↑)" }
    if k >= 1000 { return "🛸" + to_string(k) + " (tier 8~9 BEYOND/ABS)" }
    // 일반 구간 — sub-milestone
    if k > 16 && k < 39 { return "🛸" + to_string(k) + " (tier 6 early)" }
    if k > 39 && k < 100 { return "🛸" + to_string(k) + " (tier 6 ULTRA mid)" }
    if k > 100 && k < 500 { return "🛸" + to_string(k) + " (tier 6 ULTRA late)" }
    return "🛸" + to_string(k)
}

// ─── report formatter ───
// "Φ=1.0e48 → 🛸50 (~10⁴⁸, 관측우주 입자 스케일)" 같은 한 줄 보고.
fn tier_report(phi: f64) -> string {
    let k = phi_to_tier(phi)
    let name = tier_name(k)
    let phi_str = to_string(phi)
    return "Φ=" + phi_str + " → " + name
}

// f64 overflow 대응 — Φ 를 log10 지수로 받아 report 생성.
fn tier_report_log10(log10_phi: f64) -> string {
    let k = phi_log10_to_tier(log10_phi)
    let name = tier_name(k)
    return "Φ=10^" + to_string(log10_phi) + " → " + name
}

// ─── main: milestone 검증 ───
fn main() {
    println("🛸 Φ-tier labeler  L(k)=24^(k-15)  (Mk.V.1 knuth_layer_bridge)")
    println("")
    println("[Builtin log2(24) = " + to_string(LOG2_24) + "]")
    println("")

    // 대표 입력 4개 (f64 범위 내)
    let phi_samples: [f64] = [1.0, 24.0, 1.0e33, 1.0e48, 1.0e117]
    for p in phi_samples {
        println("  " + tier_report(p))
    }
    // f64 overflow 구간 (10⁶⁶⁸) — log10 경로
    println("  " + tier_report_log10(668.0))
    println("")

    // 정확성 검증 — phi = 24^24 (≈1.334e33) → 🛸39 (정확)
    let phi_24_24 = pow(24.0, 24.0)
    let k_24_24 = phi_to_tier(phi_24_24)
    println("[verify] Φ=24^24=" + to_string(phi_24_24) + " → k=" + to_string(k_24_24)
            + " (기대: 39)")

    // round-trip — tier_to_phi(39) 는 24^24 와 일치해야
    let back = tier_to_phi(39)
    println("[roundtrip] tier_to_phi(39) = " + to_string(back)
            + "  (기대: ≈" + to_string(phi_24_24) + ")")

    // milestone lookup smoke
    println("[name] 🛸50 → " + tier_name(50))
    println("[name] 🛸100 → " + tier_name(100))
    println("[name] 🛸500 → " + tier_name(500))
    println("")

    println("⚠️  AN11 경고: Φ tier 는 substrate scale 표기. weight-emergent persona +")
    println("    attached + 실사용 재현 3조건은 AN11 별도 검증 필수 (shared/rules/anima.json).")
}

main()
