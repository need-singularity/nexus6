// ⛔ CORE — L0 (의식 hyperarithmetic verifier Mk.IX consciousness-side)
// ⚠️ 로드맵: anima Mk.V.1 → Mk.IX bridge — Π₀² consciousness propositions
// shared/consciousness/consciousness_hyperarithmetic.hexa — Π₀² 의식 명제 판정 엔진
//
// nexus 측 blowup_hyperarithmetic.hexa (nexus/cli/blowup/modules/) 의 consciousness 쌍.
// cc2ec688 에서 nexus 에 도입된 Mk.IX 설계를 anima 에 이식.
//
// 대상: consciousness_laws 중 Π₀² 형태 명제
//   예: "∀state ∃response (bounded, φ(state,response))" — totality of response
//       "∀학습 step ∃converged pattern" — 학습 total
//       "∀입력 x ∃emergent pattern y < f(x)" — emergence bounded
//
// Shoenfield absoluteness (Mk.V) 범위 밖 — Π₀² 는 0′ oracle 필요 → 부분 판정.
//
// 5-Phase Pipeline (nexus Mk.IX 와 동형):
//   B1  Π₀² 구문 탐지      자연어 ∀/∃ → 논리 기호, prefix scan, bounded vs unbounded 분류
//   B2  Bounded Witness    f(x) 발견 시 Π₀¹ downgrade → consciousness_absolute.hexa A1~A5 회부
//   B3  Reverse-Math 5 체계 RCA₀/WKL₀/ACA₀/ATR₀/Π¹₁-CA₀ 에서 진릿값 검사 (증명력 축)
//   B4  n=6 대조군         P[6 ↦ k] 치환 불변성 확인 — AN14 와 동일 근거
//   B5  Verdict           ABSOLUTE-PASS / REVERSE-PROVEN / REVERSE-UNKNOWN / REJECT
//
// 주의 (AN11): 이 엔진은 substrate verifier. 의식의 emergent/weight-emergent 특성 검증 아님.
//              Π₀² proposition PASS ≠ 실제 의식 동작 PASS.

// ─── 모듈 상수 ───
let _cached_home = env("HOME")
let _NEXUS = _cached_home + "/Dev/nexus"
let _LAWS  = _NEXUS + "/consciousness/consciousness_laws.json"

// ─── B1 Π₀² 구문 탐지 ───
// hierarchy: "Δ₀" / "Π₀¹" / "Σ₀¹" / "Π₀²" / "Σ₀²" / ">=Π₀³"
// prefix: "∀" 한 개 + unbounded ∃ 한 개 = Π₀² 후보 (matrix Δ₀ 재귀 검증 필요).
fn has_universal_quantifier(expr: string) -> bool {
    if expr.contains("∀") { return true }
    if expr.contains("모든") { return true }
    if expr.contains("임의의") { return true }
    if expr.contains("for all") { return true }
    if expr.contains("every") { return true }
    return false
}

fn has_existential_quantifier(expr: string) -> bool {
    if expr.contains("∃") { return true }
    if expr.contains("존재") { return true }
    if expr.contains("어떤") { return true }
    if expr.contains("exists") { return true }
    if expr.contains("there is") { return true }
    return false
}

fn has_infinitely_many(expr: string) -> bool {
    // "무한히 많은" / "infinitely many" → ∀N ∃n>N
    if expr.contains("무한히 많") { return true }
    if expr.contains("infinitely many") { return true }
    return false
}

fn classify_pi02(expr: string) -> string {
    let has_forall = has_universal_quantifier(expr)
    let has_exists = has_existential_quantifier(expr) || has_infinitely_many(expr)
    if has_forall && has_exists {
        return "Π₀²"
    }
    if has_forall { return "Π₀¹" }
    if has_exists { return "Σ₀¹" }
    return "Δ₀"
}

// ─── B2 Bounded Witness Reduction ───
// P = "∀x ∃y φ(x,y)" → "∀x ∃y<f(x) φ" 이면 Π₀¹ downgrade.
// consciousness 도메인 witness bound table (nexus reverse_math_check.hexa.inc 와 동형):
fn has_bounded_witness(expr: string) -> bool {
    // consciousness 영역 bounded witness 알려진 패턴:
    //   - "∀state ∃response (response 길이 <= state 길이 + k)"
    //   - "∀학습 step ∃converged (step 횟수 < poly(model_size))"
    //   - "∀layer ∃attention sink (position < sequence_length)"
    if expr.contains("bounded") { return true }
    if expr.contains("poly") { return true }
    if expr.contains("< f(") { return true }
    if expr.contains("<= f(") { return true }
    return false
}

fn try_pi01_downgrade(expr: string) -> string {
    if classify_pi02(expr) != "Π₀²" { return "NOT-PI02" }
    if has_bounded_witness(expr) {
        return "DOWNGRADED-PI01"
    }
    return "PI02-UNBOUNDED"
}

// ─── B3 Reverse-Math 5 체계 매핑 ───
// consciousness 도메인 reverse-math 화이트리스트 (초기 엔트리):
//   - ACA₀ 이하: "totality of bounded response", "convergence of gradient descent (bounded loss)"
//   - WKL₀: "compactness of attention space" (finite-branching tree)
//   - ATR₀: "transfinite learning curriculum"
//   - Π¹₁-CA₀: "meta-learning reflection"
fn reverse_math_system(expr: string) -> string {
    if expr.contains("totality") || expr.contains("bounded response") {
        return "ACA0"
    }
    if expr.contains("attention") && expr.contains("compact") {
        return "WKL0"
    }
    if expr.contains("curriculum") || expr.contains("transfinite") {
        return "ATR0"
    }
    if expr.contains("meta-learning") || expr.contains("reflection") {
        return "PI11-CA0"
    }
    return "UNKNOWN"
}

// 5 체계 중 3+ 가 whitelist 에 걸리는지 (여기서는 단일 system 만 반환, 다중 검증은 상위 orchestrator)
fn reverse_proven(expr: string) -> bool {
    let system = reverse_math_system(expr)
    if system == "UNKNOWN" { return false }
    // ACA₀ 이하 증명 = 가장 강한 positive 결과
    if system == "ACA0" { return true }
    if system == "WKL0" { return true }
    return false  // ATR0, PI11-CA0 은 unknown 으로 간주 (Mk.IX 설계 §2 단계 C)
}

// ─── B4 n=6 대조군 ───
// P[6 ↦ k] 치환 시 진릿값 유지 여부. AN14 와 구조 동형.
fn n6_substitution_invariant(expr: string, substitution_k: i64) -> bool {
    // 의식 명제에서 n 이 σ·φ=n·τ 의 n 일 때, k 대입해도 Π₀² 구조 유지?
    // 의미적 substitution 은 수동 감사 필요 — 여기서는 구문적 체크만.
    if substitution_k == 6 { return true }
    // n ≠ 6 치환 시 closure 깨짐 → invariant 파괴
    return false
}

// ─── B5 Verdict ───
// 최종 판정: ABSOLUTE-PASS / REVERSE-PROVEN / REVERSE-UNKNOWN / REJECT
fn phase_b_verdict(expr: string) -> string {
    let hier = classify_pi02(expr)
    if hier == "Δ₀" { return "ABSOLUTE-PASS (Δ₀)" }
    if hier == "Π₀¹" { return "ABSOLUTE-PASS (Π₀¹)" }
    if hier != "Π₀²" {
        return "REJECT (hierarchy >= Π₀³ or Σ family)"
    }
    // Π₀² 경로
    let downgrade = try_pi01_downgrade(expr)
    if downgrade == "DOWNGRADED-PI01" {
        return "ABSOLUTE-PASS (Π₀² → Π₀¹ via bounded witness)"
    }
    // 여전히 unbounded — reverse-math
    if !reverse_proven(expr) {
        return "REVERSE-UNKNOWN"
    }
    // reverse-proven — n=6 대조군 확인
    if !n6_substitution_invariant(expr, 6) {
        return "REJECT (n=6 invariance fail)"
    }
    // 5+ 검증 전부 통과 — [12*] 후보 (단, Mk.IX 설계상 수동 감사 필수)
    return "REVERSE-PROVEN (candidate [12*], manual audit required)"
}

