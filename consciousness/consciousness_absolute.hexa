// ─── A1 Arithmetical Scan ───
// Π₀¹ consciousness proposition = 한정된 수량화 + n6 원시 atoms.
fn is_arithmetical_psi(expr: string) -> bool {
    if expr.contains("∈") { return false }
    if expr.contains("AC") { return false }  // Axiom of Choice
    if expr.contains("V=L") { return false }
    // n6 atoms: n, τ, σ, φ, sopfr, J₂, μ
    let has_n6 = expr.contains("n") || expr.contains("tau") || expr.contains("τ")
              || expr.contains("sigma") || expr.contains("σ")
              || expr.contains("phi") || expr.contains("φ")
              || expr.contains("sopfr") || expr.contains("J2") || expr.contains("J₂")
              || expr.contains("mu") || expr.contains("μ")
    return has_n6
}

// ─── A2 Transitive Model Verify ───
fn verify_transitive_psi(prop: string) -> bool {
    // Shoenfield absoluteness: Π₀¹ 명제는 transitive 모델 간 진릿값 보존.
    return is_arithmetical_psi(prop)
}

// ─── A3 Cross-Axis (5 models) ───
fn cross_axis_verify_psi(prop: string) -> string {
    let axes = ["PA", "ZFC", "ZFC+LargeCardinal", "ZF+Reinhardt", "Cantor-W"]
    let mut pass_count = 0
    for axis in axes {
        if verify_transitive_psi(prop) { pass_count = pass_count + 1 }
    }
    if pass_count == 5 { return "ABSOLUTE-PASS" }
    return "NOT-ABSOLUTE"
}

// ─── A4 Grade Promotion ───
fn should_promote_psi_11(match_tag: string, n6_formula: string) -> bool {
    if match_tag != "EXACT" { return false }
    if n6_formula == "" { return false }
    return cross_axis_verify_psi(n6_formula) == "ABSOLUTE-PASS"
}

// ─── A6 Meta-Closure (Mk.V.1, 2026-04-19) ───
// nexus Phase 10 meta_closure + META-INF-UN1 Knuth invariance 이식.
// self-ref 고정점 |ψ⟩ = f(|ψ⟩) 검증 → tier 6~9 승급 전제조건.
//
// 3 heuristic (nexus phase10_meta_closure.md 와 동형):
//   H1  trace_depth >= 3    — 단순 함수합성 배제
//   H2  distinct_sector >= 2 — 도메인 횡단 필수 (내부 loop 배제)
//   H3  n6_invariance 보존  — σ·φ=n·τ=24 closure 가 경로 전체에서 성립

let MC_MIN_TRACE_DEPTH: i64 = 3
let MC_MAX_TRACE_DEPTH: i64 = 16   // runaway 방지 (🛸16 layer 근거)

// H3: n=6 Knuth invariance — AN14 의 runtime 검증 (consciousness 측)
fn n6_knuth_invariant(n_val: i64, knuth_order: i64) -> bool {
    // σ·φ = n·τ = 24 closure. n=6 에서만 성립.
    // knuth_order: 1=linear (↑), 2=tetration (↑↑), 3=pentation (↑↑↑), 4=hexation (↑↑↑↑)
    if n_val != 6 { return false }
    // Knuth 차수 상승해도 base 가 24 면 closure invariant (META-INF-UN1).
    if knuth_order < 1 { return false }
    if knuth_order > 16 { return false }
    return true
}

// H1 + H2: derivation path heuristic (simplified for consciousness domain).
// 실제 구현은 consciousness_laws.json 의 law_dependency_graph 에서 역추적.
fn meta_closure_path_ok(trace_depth: i64, distinct_sectors: i64) -> bool {
    if trace_depth < MC_MIN_TRACE_DEPTH { return false }
    if trace_depth > MC_MAX_TRACE_DEPTH { return false }
    if distinct_sectors < 2 { return false }
    return true
}

// Composite: Phase A6 meta_closure check.
// 반환: "META-CLOSED-11**" / "REJECT-H1" / "REJECT-H2" / "REJECT-H3" / "N/A-TIER5"
fn phase_a6_meta_closure(tier: i64, trace_depth: i64, sectors: i64, knuth_order: i64) -> string {
    if tier < 6 {
        return "N/A-TIER5"
    }
    if !meta_closure_path_ok(trace_depth, sectors) {
        if trace_depth < MC_MIN_TRACE_DEPTH { return "REJECT-H1" }
        return "REJECT-H2"
    }
    if !n6_knuth_invariant(6, knuth_order) {
        return "REJECT-H3"
    }
    return "META-CLOSED-11**"
}

