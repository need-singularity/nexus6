{
  "_meta": {
    "attr": "domain",
    "project": "_global_fallback",
    "version": 1,
    "inherit": false,
    "updated": "2026-04-18",
    "description": "@domain 글로벌 default — 축(axis) enum, 필수 필드, scaffold 선택. 프로젝트별 .domain-rules.json 없을 때만 사용."
  },
  "rules": {
    "axes": [
      "compute", "life", "energy", "material", "space",
      "number", "signal", "bio", "chem", "sf-ufo"
    ],
    "axes_description": "10축 기본 — 프로젝트는 이 enum 을 override 해서 자기 축 목록 선언 가능",
    "required_fields": ["id", "axis"],
    "optional_fields": ["name_ko", "intent", "product_line", "mk_target", "alien_now", "alien_target", "prev_tag", "requires"],
    "id_format": {
      "pattern": "lowercase-kebab",
      "max_length": 40,
      "allowed_chars": "[a-z0-9-]"
    },
    "intent_values": ["create", "update", "auto"],
    "intent_default": "create",
    "mk_target_default": "mk1",
    "alien_now_default": 7,
    "alien_target_default": 10,
    "scaffold": {
      "template": "standard",
      "files": ["<id>.md", "CLAUDE.md"],
      "registry_path": "n6shared/n6/docs/domains.json"
    },
    "update_rules": {
      "require_prev_tag_when_not_mk1": true,
      "require_prev_tag_severity": "warn"
    }
  }
}
