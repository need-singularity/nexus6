{
  "_doc": "CLI 한도 감지 + handoff 저장 SSOT — 하네스 공통 규칙. 세션 JSONL usage 를 합산 → 임계치 시 handoff MD 생성",
  "budget": {
    "session_output_tokens": 100000,
    "session_input_tokens": 800000,
    "weekly_output_tokens": 2000000
  },
  "thresholds": {
    "notice": 0.50,
    "checkpoint": 0.70,
    "handoff": 0.85,
    "emergency": 0.95
  },
  "cooldown": {
    "prompts_between_checks": 5,
    "min_seconds_between_saves": 60
  },
  "handoff": {
    "filename": "handoff-latest.md",
    "tail_messages": 10,
    "include_git_delta": true,
    "include_task_list": true
  },
  "version": 1
}
