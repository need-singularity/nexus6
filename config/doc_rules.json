{
  "_meta": {
    "attr": "doc",
    "project": "_global_fallback",
    "version": 1,
    "inherit": false,
    "updated": "2026-04-18",
    "description": "@doc 글로벌 default — 프로젝트별 .doc-rules.json 없을 때만 사용. type 별 required sections + paper 추가 검증 토글"
  },
  "rules": {
    "paper": {
      "description": "논문/도메인 명세 — brief(§1-§7) + engineering(§8-§20) + impact(§21) 전체",
      "sections": [
        "WHY", "COMPARE", "REQUIRES", "STRUCT", "FLOW", "EVOLVE", "VERIFY",
        "EXEC SUMMARY", "SYSTEM REQUIREMENTS", "ARCHITECTURE", "CIRCUIT DESIGN",
        "PCB DESIGN", "FIRMWARE", "MECHANICAL", "MANUFACTURING", "TEST",
        "BOM", "VENDOR", "ACCEPTANCE", "APPENDIX", "IMPACT"
      ],
      "require_ascii_check": true,
      "require_verify": true,
      "require_mk_history": true,
      "mk_history_min_lines": 3
    },
    "rfc": {
      "description": "RFC — 기술 제안서",
      "sections": ["Status", "Abstract", "Introduction", "Requirements", "Security Considerations"],
      "require_ascii_check": false,
      "require_verify": false,
      "require_mk_history": false
    },
    "adr": {
      "description": "Architecture Decision Record",
      "sections": ["Context", "Decision", "Consequences"],
      "require_ascii_check": false,
      "require_verify": false,
      "require_mk_history": false
    },
    "spec": {
      "description": "API / 인터페이스 스펙",
      "sections": ["Overview", "Interface", "Behavior", "Errors", "Examples"],
      "require_ascii_check": false,
      "require_verify": false,
      "require_mk_history": false
    },
    "whitepaper": {
      "description": "화이트페이퍼 — 외부 공개용",
      "sections": ["Executive Summary", "Problem", "Solution", "Architecture", "Validation"],
      "require_ascii_check": false,
      "require_verify": false,
      "require_mk_history": false
    }
  }
}
