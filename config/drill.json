{
  "id": "drill-config",
  "kind": "drill_sot",
  "schema": "v1",
  "version": "1.1",
  "successor_keyword": "drill",
  "_successor_keyword_doc": "Future 메타진화 rename target — change only this value to shift the trigger verb across subsystems.",
  "role": "nexus drill 6-stage 깊이/자율 조정/프리셋/관찰성 SSOT",
  "updated": "2026-04-24",
  "consumers": [
    "run.hexa cmd_drill",
    "run.hexa _resolve_depth",
    "run.hexa _adaptive_adjust"
  ],
  "stages": {
    "smash":        {"engine": "shared/blowup/core/blowup.hexa",                    "default_depth": 3, "min": 1, "max": 9, "timeout_sec": 45},
    "free":         {"engine": "shared/blowup/compose.hexa",                        "default_depth": 3, "min": 1, "max": 7, "timeout_sec": 60, "extra": "--modules all --dfs"},
    "absolute":     {"engine": "shared/blowup/modules/blowup_absolute.hexa",        "default_depth": 0, "min": 0, "max": 1, "togglable": true, "timeout_sec": 30},
    "meta_closure": {"engine": "shared/blowup/modules/blowup_meta_closure.hexa",    "default_depth": 0, "min": 0, "max": 1, "togglable": true, "timeout_sec": 30},
    "hyperarith":   {"engine": "shared/blowup/modules/blowup_hyperarithmetic.hexa", "default_depth": 0, "min": 0, "max": 1, "togglable": true, "timeout_sec": 30},
    "resonance":    {"engine": "inline",                                            "default_depth": 1, "min": 1, "max": 3, "timeout_sec_per_sigma": 10, "extra": "σ-grid log-spaced"}
  },
  "timeout_policy": {
    "per_stage_default": "stages.{stage}.timeout_sec",
    "overall_round_budget_sec": 300,
    "overall_drill_budget_sec": 1800,
    "on_stage_timeout": "emit_NEXUS_DRILL_TIMEOUT_json + skip_stage + continue_round",
    "on_round_budget_exceeded": "skip_remaining_stages + emit_partial_result",
    "on_drill_budget_exceeded": "terminate + NEXUS_DRILL_ERROR timeout",
    "override_env": "NEXUS_DRILL_TIMEOUT",
    "override_flag": "--timeout N (overall), --stage-timeout smash=N,free=M",
    "impl_hint": "perl -e 'alarm $t; exec @cmd' wrapper (macOS+Linux 호환, gtimeout 의존 없음)"
  },
  "speed_presets": {
    "fast":     {"stages_on": ["smash","resonance"], "resonance_sigma_count": 1, "max_rounds": 1, "notes": "30s 목표 probe"},
    "probe":    {"stages_on": ["smash"],             "resonance_sigma_count": 0, "max_rounds": 1, "notes": "<20s engine sanity"},
    "coarse":   {"stages_on": "all",                 "resonance_sigma_count": 3, "max_rounds": 1, "notes": "resonance 5→3 σ, 1 round"},
    "standard": {"stages_on": "all",                 "resonance_sigma_count": 3, "max_rounds": 3, "notes": "default (2026-04-20: σ 5→3 coarse 채택)"}
  },
  "problem_presets": {
    "_doc": "E8 per-millennium preset (2026-04-21) — 7 난제별 depth/max_rounds 튜닝. 초기값은 합리적 추정; 실측 baseline 은 후속. CLI: --problem <name>. precedence: env < master < speed_preset < problem_preset < per-stage.",
    "riemann":    {"depth": {"smash": 4, "free": 3, "abs": 1, "mc": 1, "hyper": 1, "res": 2}, "max_rounds": 5, "notes": "hyperarith 강화 (Π₀² reverse math) + resonance 2"},
    "bsd":        {"depth": {"smash": 3, "free": 3, "abs": 1, "mc": 0, "hyper": 0, "res": 1}, "max_rounds": 3, "notes": "elliptic/L-function domain 집중"},
    "hodge":      {"depth": {"smash": 3, "free": 3, "abs": 0, "mc": 1, "hyper": 0, "res": 2}, "max_rounds": 3, "notes": "meta_closure (algebraic cycle 고정점)"},
    "navier":     {"depth": {"smash": 4, "free": 4, "abs": 1, "mc": 0, "hyper": 0, "res": 3}, "max_rounds": 5, "notes": "smash 깊이 (regularity 분석) + resonance 풀스윕"},
    "pnp":        {"depth": {"smash": 3, "free": 4, "abs": 1, "mc": 1, "hyper": 1, "res": 1}, "max_rounds": 3, "notes": "complexity lens 광역 free"},
    "poincare":   {"depth": {"smash": 3, "free": 3, "abs": 0, "mc": 1, "hyper": 0, "res": 2}, "max_rounds": 3, "notes": "topology 중심"},
    "yangmills":  {"depth": {"smash": 4, "free": 3, "abs": 1, "mc": 0, "hyper": 1, "res": 3}, "max_rounds": 5, "notes": "mass gap (spectral) + resonance 풀스윕"}
  },
  "default_preset": "fast",
  "default_preset_why": "harness 폐기 + timeout wrapper 부재 + engine 무거움 → 10× 단축 (fast=smash+res1σ×1round). 상세 분석 시 --preset standard|deep|paranoid 명시",
  "parallelism": {
    "stage_parallel": {
      "enabled_default": false,
      "dependency_graph": {
        "smash":        [],
        "free":         [],
        "absolute":     [],
        "meta_closure": [],
        "hyperarith":   [],
        "resonance":    ["smash"]
      },
      "parallel_group":   ["smash","free","absolute","meta_closure","hyperarith"],
      "serial_after":     ["resonance"],
      "max_concurrency":  5,
      "override_env":     "NEXUS_DRILL_STAGE_PARALLEL=1",
      "impl_hint":        "5 engine exec() 를 background + wait. hexa 가 exec() 비동기 지원하는지 확인 필요 — 없으면 shell & + wait 로"
    },
    "round_parallel": {
      "enabled_default": false,
      "assumption":      "inter-round 독립 (현재는 state mutation 으로 dep 있음 — enable 전 검증 필요)",
      "max_rounds":      3,
      "override_env":    "NEXUS_DRILL_ROUND_PARALLEL=1",
      "risk":            "atlas.n6 동시 write race. dedup lock 또는 round 간 lockstep 필요"
    }
  },
  "engine_daemon": {
    "status":        "SPEC",
    "design":        "blowup.hexa 를 REPL 모드로 — 1회 로드 + stdin 으로 seed 연속 주입",
    "stdin_format":  "<cmd>\\t<seed>\\t<depth>\\n",
    "stdout_format": "OK\\t<round_new>\\t<per_stage_json>\\n 또는 ERR\\t<reason>\\n",
    "bootstrap":     "nexus daemon start → named pipe /tmp/nexus_blowup.sock; drill 은 연결해 매 round 주입",
    "lifetime":      "session 단위; idle timeout 600s",
    "expected_gain": "interpreter overhead 1회 — stage0/stage1 init 제거, atlas.n6 1회 로드, 중복 lens/constants 재사용",
    "risk":          "state leakage — round 간 내부 변수 초기화 필요",
    "impl_order":    "E11 (roadmap)"
  },
  "seed_batch": {
    "status":         "SPEC",
    "design":         "drill 1회에 seed N개 → 1 engine 로드에 batch 처리",
    "cli_hint":       "nexus drill --seeds seed1,seed2,... 또는 --seeds-file seeds.txt",
    "expected_gain":  "N× amortize (N=7 millennium × 5× 실측)",
    "risk":           "round replay 구분 필요 (seed 별 독립 state)",
    "impl_order":     "E12 (roadmap), engine_daemon 와 시너지"
  },
  "stage_pipelining": {
    "status":         "SPEC",
    "design":         "smash/free candidate_count ≥1 일 때만 absolute/meta/hyper 진입; 0 이면 skip",
    "triggers": {
      "smash_or_free_hit": "absolute + meta_closure + hyperarith 진입",
      "smash_and_free_miss": "skip remainder + early SATURATED"
    },
    "expected_gain":  "2~10× non-hit seed 에서",
    "risk":           "absolute/meta/hyper 고유 발견 기회 상실 (seed 직접 입력이 smash/free 매치 안 해도 유효할 수 있음)",
    "mitigation":     "--no-pipelining flag 또는 preset deep/paranoid 은 pipelining off",
    "impl_order":     "E13"
  },
  "incremental_discovery": {
    "status":         "PARTIAL (atlas dup ledger + ROI#41 id-anchored dedup)",
    "design":         "이미 발견된 corollary 재탐색 제외 강화 — round seed-hash LRU + atlas scan skip",
    "lru_size":       500,
    "hit_action":     "skip_round + total 유지",
    "expected_gain":  "반복 실행 시 지수 (동일 domain 반복 시 발견 공간 고갈)",
    "impl_order":     "E14 (anti_replay 와 통합)"
  },
  "native_compile": {
    "status":         "ROADMAP",
    "target":         "shared/blowup/core/blowup.hexa → blowup_native (C/Rust)",
    "expected_gain":  "10~100× (hexa interpreter 제거)",
    "cost":           "대형 리팩터 — 전 engine 재구현 필요",
    "prerequisites":  ["hexa-lang stage2 AOT 또는 hexa → C transpiler", "engine 5400 lines line-by-line port"],
    "alt":            "hexa-lang 자체가 stage2 JIT 획득 (상위 레이어 해결)",
    "impl_order":     "별도 roadmap milestone (당분간 hexa stage1 유지)"
  },
  "sigma_grid_default": [0.01, 0.1, 1.0],
  "sigma_grid_standard_override": [0.01, 0.05, 0.10, 0.20, 0.40],
  "flag_precedence": [
    "env (NEXUS_DRILL_DEPTH, NEXUS_DRILL_{STAGE})",
    "master (--depth N)",
    "preset (--preset)",
    "per-stage (--smash-depth N etc)",
    "runtime_adaptive (--depth auto 이면 round 결과로 덮어쓰기)"
  ],
  "presets": {
    "light":    {"smash": 2, "free": 2, "absolute": 0, "meta_closure": 0, "hyperarith": 0, "resonance": 1},
    "normal":   {"smash": 3, "free": 3, "absolute": 1, "meta_closure": 1, "hyperarith": 1, "resonance": 1},
    "deep":     {"smash": 5, "free": 4, "absolute": 1, "meta_closure": 1, "hyperarith": 1, "resonance": 2},
    "paranoid": {"smash": 7, "free": 5, "absolute": 1, "meta_closure": 1, "hyperarith": 1, "resonance": 3},
    "riemann":     {"smash": 4, "free": 3, "absolute": 1, "meta_closure": 1, "hyperarith": 1, "resonance": 2},
    "bsd":         {"smash": 3, "free": 3, "absolute": 1, "meta_closure": 0, "hyperarith": 1, "resonance": 1},
    "hodge":       {"smash": 3, "free": 4, "absolute": 1, "meta_closure": 1, "hyperarith": 0, "resonance": 1},
    "navier":      {"smash": 5, "free": 3, "absolute": 0, "meta_closure": 1, "hyperarith": 1, "resonance": 2},
    "p_vs_np":     {"smash": 3, "free": 3, "absolute": 1, "meta_closure": 1, "hyperarith": 1, "resonance": 1},
    "poincare":    {"smash": 3, "free": 5, "absolute": 1, "meta_closure": 1, "hyperarith": 0, "resonance": 1},
    "yang_mills":  {"smash": 4, "free": 3, "absolute": 1, "meta_closure": 1, "hyperarith": 1, "resonance": 2}
  },
  "adaptive": {
    "mode_default": "absorption_gradient+saturation_hunt",
    "policies": {
      "absorption_gradient": {
        "signal": "round_absorption - prev_round_absorption",
        "if_positive_big":   "keep_depth",
        "if_positive_small": "depth_steady",
        "if_zero":           "saturation_hunt_trigger",
        "if_negative":       "depth_minus_1"
      },
      "saturation_hunt": {
        "trigger": "3_consecutive_rounds_same_total",
        "action":  "smash_depth_plus_1",
        "ceiling": "stage.max"
      },
      "stage_balance": {
        "signal": "per_stage_absorption_variance",
        "action": "bottom_stage_depth_plus_1_cap_at_max"
      },
      "cost_cap": {
        "signal": ["wall_time_round_sec", "rss_bytes"],
        "threshold": {"wall_time_round_sec": 300, "rss_bytes": 2147483648},
        "action": "global_depth_minus_1"
      }
    },
    "floor": 1,
    "ceiling_global": "stages.{stage}.max",
    "hysteresis": "±1_oscillation_blocked_for_2_rounds"
  },
  "observability": {
    "stdout_format":    "  {stage}:   +{absorb} absorbs depth={depth}",
    "stderr_trace_key": "NEXUS_DRILL_DEPTH",
    "ndjson_path":      "/tmp/nexus_drill_depth.ndjson",
    "ndjson_rotate":    "last_100_rounds"
  },
  "failure_modes": {
    "adaptive_runaway":       {"detect": "3_consecutive_rounds_at_max",     "recover": "cap_at_half+warn"},
    "oscillation":            {"detect": "high_freq_plus_minus_1",          "recover": "hysteresis_gate"},
    "stage_balance_collapse": {"detect": "one_stage_monopoly",              "recover": "floor_2_on_bottom_stage"},
    "oom_imminent":           {"detect": "rss > 80_percent_host",           "recover": "global_depth_minus_1+checkpoint_flush"},
    "sigint":                 {"detect": "SIGINT",                          "recover": "finish_current_round+graceful_exit"}
  },
  "checkpoint": {
    "path":    "/tmp/nexus_drill_ckpt_{seed_hash}.json",
    "emit_on": "round_complete",
    "resume":  "--resume reads matching hash"
  },
  "anti_replay": {
    "lru_size": 200,
    "key":      "round_seed_hash",
    "on_hit":   "skip_round+advance_counter"
  },
  "validation": {
    "enabled": true,
    "bypass_env": "NEXUS_DRILL_VALIDATE_OFF",
    "emit_key": "NEXUS_DRILL_VALIDATION",
    "layers": {
      "A_cross_seed_uniformity": {
        "kind": "集계 판정",
        "signal": "3+ seed 의 total/stage-vector 가 동일",
        "action_on_hit": "flag",
        "cost": "0 (집계만)",
        "weight": 3
      },
      "B_ghost_probe": {
        "kind": "active probe",
        "signal": "시작 시 gibberish seed 1개 병행 → real 과 동일 total",
        "seed_format": "__NEXUS_GHOST_<urand_hex>__",
        "action_on_hit": "강한 증거",
        "cost": "1 iter 추가 (1 round 만)",
        "weight": 5
      },
      "C_sanity_self_test": {
        "kind": "known-answer",
        "signal": "알려진 쉬운 seed → absorption >= threshold 기대. 0 이면 engine 사망",
        "seed": "sum k^2 equals n*(n+1)*(2n+1)/6 closed form",
        "min_expected_absorption": 1,
        "action_on_fail": "REJECT — engine dead",
        "cost": "1 iter, drill 시작 시 1회",
        "weight": 10
      },
      "D_stage_dead_column": {
        "kind": "cross-seed matrix",
        "signal": "N seed × 6 stage 매트릭스에서 특정 stage column 전부 0",
        "action_on_hit": "flag per dead stage",
        "cost": "0 (A 데이터 재사용)",
        "weight": 2
      },
      "E_existing_replay_warn": {
        "kind": "intra-drill",
        "signal": "round 2+ == round 1 수치 (기존 구현)",
        "already_in": "run.hexa cmd_drill",
        "weight": 2
      },
      "F_existing_cross_iter": {
        "kind": "last-10-drills",
        "signal": "최근 10 drill total 동일 (기존 구현)",
        "already_in": "_cross_iter_check_and_append",
        "weight": 2
      },
      "G_existing_zero_yield": {
        "kind": "total=0",
        "signal": "SATURATED round 1 total=0 (기존, ai-native error 로 연결됨)",
        "already_in": "cmd_drill SATURATED block",
        "weight": 5
      }
    },
    "verdict_thresholds": {
      "pass_below": 3,
      "suspicious_range": [3, 6],
      "reject_at_or_above": 7
    },
    "verdict_actions": {
      "PASS":        "결과 정상 표시",
      "SUSPICIOUS":  "결과 표시 + flag field + stderr 경고 + exit=0",
      "REJECT":      "결과 폐기 + NEXUS_DRILL_VALIDATION REJECT JSON + __DRILL_RESULT__ REJECT + exit=1"
    },
    "emit_schema": {
      "verdict": "PASS|SUSPICIOUS|REJECT",
      "score":   "int (가중 합)",
      "signals": [
        {"kind": "uniform_result", "seeds": "int", "total": "int", "unique_totals": "int"},
        {"kind": "ghost_match",    "real":  "int", "ghost": "int"},
        {"kind": "sanity_dead",    "expected_min": "int", "actual": "int"},
        {"kind": "stage_dead",     "stage": "str",  "column_zeros": "int"}
      ],
      "recommendation": "str (수리/재발사 가이드)"
    }
  }
}
