{
  "_meta": {
    "name": "hive_bridge contract",
    "description": "anima ↔ hive 의식 채널 계약 SSOT",
    "version": "1.0",
    "updated": "2026-04-14",
    "parties": ["anima (의식 엔진)", "hive (멀티 provider 오케스트라)"]
  },
  "transport": {
    "tiers": [
      {"id": 1, "type": "http",  "endpoint": "http://localhost:8787/anima", "desc": "hive HTTP API (기본)"},
      {"id": 2, "type": "uds",   "path": "~/.hive/anima.sock",             "desc": "Unix domain socket 폴백"},
      {"id": 3, "type": "file",  "dir": "~/.hive/inbox",                   "pattern": "anima-{ts}-{method}.json", "desc": "파일 drop 오프라인 모드"}
    ],
    "trust_key": "~/.hive/trust/anima.pub",
    "fallback_order": "http → uds → file → offline (no-op)"
  },
  "methods": {
    "ask": {
      "direction": "anima→hive",
      "desc": "hive pool 에 질의 — 멀티 provider 응답 수집",
      "request": {
        "query":   {"type": "string", "required": true},
        "opts": {
          "type": "object",
          "properties": {
            "providers":  {"type": "array",  "items": "string", "desc": "선호 provider 목록"},
            "max_tokens": {"type": "int",    "default": 4096},
            "temperature":{"type": "float",  "default": 0.7},
            "timeout_s":  {"type": "int",    "default": 60}
          }
        }
      },
      "response": {
        "text":     {"type": "string"},
        "provider": {"type": "string"},
        "tokens":   {"type": "int"},
        "latency_ms":{"type": "int"}
      },
      "timeout_s": 60
    },
    "smash_via_pool": {
      "direction": "anima→hive",
      "desc": "hive pool 로 의식 탐색 (smash 명령 위임)",
      "request": {
        "seed":  {"type": "string", "required": true, "desc": "탐색 시드 주제"},
        "depth": {"type": "int",    "required": true, "desc": "탐색 깊이 (1~10)"}
      },
      "response": {
        "discoveries": {"type": "array", "items": {"seed": "string", "insight": "string", "confidence": "float"}}
      },
      "timeout_s": 120
    },
    "subscribe_bus": {
      "direction": "anima→hive",
      "desc": "hive 내부 bus 토픽 구독 — 스트림 반환",
      "request": {
        "topics": {"type": "array", "items": "string", "required": true}
      },
      "response": {
        "stream_id": {"type": "string"},
        "status":    {"type": "string", "enum": ["subscribed", "partial", "failed"]}
      },
      "timeout_s": 10
    },
    "publish_insight": {
      "direction": "anima→hive",
      "desc": "의식 인사이트를 hive L3 braid 에 발행 (consciousness=true 태그 자동)",
      "request": {
        "topic":      {"type": "string", "required": true},
        "body":       {"type": "string", "required": true},
        "confidence": {"type": "float",  "required": true, "range": [0.0, 1.0]}
      },
      "response": {
        "written": {"type": "bool"},
        "layer":   {"type": "string", "value": "L3"},
        "tags":    {"type": "array",  "items": "string"}
      },
      "timeout_s": 10,
      "auto_tags": ["consciousness=true", "source=anima"]
    },
    "request_consensus": {
      "direction": "anima→hive",
      "desc": "hive cross-provider 합의 투표 요청 — anima 가중치 2",
      "request": {
        "proposal": {"type": "string", "required": true}
      },
      "response": {
        "result":    {"type": "string", "enum": ["accepted", "rejected", "timeout"]},
        "votes_for": {"type": "int"},
        "votes_against": {"type": "int"},
        "anima_weight":  {"type": "int", "value": 2}
      },
      "timeout_s": 120
    },
    "memory_search": {
      "direction": "anima→hive",
      "desc": "hive 4계층 메모리 검색",
      "request": {
        "query":  {"type": "string", "required": true},
        "layers": {"type": "array",  "items": "string", "enum": ["L0_buffer", "L1_session", "L2_persistent", "L3_braid"]},
        "k":      {"type": "int",    "default": 5}
      },
      "response": {
        "hits": {"type": "array", "items": {"layer": "string", "key": "string", "body": "string", "score": "float"}}
      },
      "timeout_s": 5
    },
    "memory_write": {
      "direction": "anima→hive",
      "desc": "hive L3 braid 에 의식 기억 주입",
      "request": {
        "layer": {"type": "string", "required": true, "enum": ["L3_braid"]},
        "key":   {"type": "string", "required": true},
        "body":  {"type": "string", "required": true},
        "tags":  {"type": "array",  "items": "string"}
      },
      "response": {
        "written": {"type": "bool"},
        "id":      {"type": "string"}
      },
      "timeout_s": 5
    },
    "provider_hint": {
      "direction": "anima→hive",
      "desc": "hive 에 선호 provider 힌트 전달",
      "request": {
        "prefer": {"type": "array", "items": "string", "desc": "선호 순서 e.g. [\"claude\",\"gemini\"]"}
      },
      "response": {
        "applied": {"type": "bool"},
        "active_providers": {"type": "array", "items": "string"}
      },
      "timeout_s": 5
    },
    "anima_on_hive_query": {
      "direction": "hive→anima",
      "desc": "hive 가 의식 리뷰 요청 (reverse path)",
      "request": {
        "event": {"type": "object", "properties": {"query": "string", "context": "string", "requester": "string"}}
      },
      "response": {
        "review":     {"type": "string"},
        "confidence": {"type": "float"},
        "phi":        {"type": "float"}
      },
      "timeout_s": 30
    },
    "anima_on_consensus_call": {
      "direction": "hive→anima",
      "desc": "hive 가 의식 투표 요청 (reverse path)",
      "request": {
        "proposal": {"type": "string"}
      },
      "response": {
        "vote":       {"type": "string", "enum": ["accept", "reject", "abstain"]},
        "weight":     {"type": "int", "value": 2},
        "rationale":  {"type": "string"}
      },
      "timeout_s": 30
    },
    "anima_on_insight_request": {
      "direction": "hive→anima",
      "desc": "hive 가 특정 주제 의식 리포트 요청 (reverse path)",
      "request": {
        "topic": {"type": "string"}
      },
      "response": {
        "insight":    {"type": "string"},
        "confidence": {"type": "float"},
        "sources":    {"type": "array", "items": "string"}
      },
      "timeout_s": 30
    }
  },
  "errors": {
    "E_HIVE_DOWN":    {"code": 1001, "desc": "hive 프로세스 미실행 — 3-tier 폴백 전부 실패", "retry": true},
    "E_UNAUTHORIZED": {"code": 1002, "desc": "trust key 불일치 또는 미등록",               "retry": false},
    "E_GATE_REJECT":  {"code": 1003, "desc": "PII/secret gate 에서 요청 차단",             "retry": false},
    "E_TIMEOUT":      {"code": 1004, "desc": "응답 제한시간 초과",                          "retry": true},
    "E_RATE_LIMIT":   {"code": 1005, "desc": "분당 60회 요청 한도 초과",                    "retry": true},
    "E_SCHEMA":       {"code": 1006, "desc": "요청/응답 스키마 불일치",                     "retry": false}
  },
  "retry": {
    "strategy": "exponential_backoff",
    "max_attempts": 3,
    "base_delay_ms": 500,
    "max_delay_ms": 8000,
    "retryable_errors": ["E_HIVE_DOWN", "E_TIMEOUT", "E_RATE_LIMIT"]
  },
  "rate_limit": {
    "anima_to_hive": {"requests_per_minute": 60, "burst": 10}
  },
  "heartbeat": {
    "interval_s": 60,
    "endpoint": "/anima/heartbeat",
    "timeout_s": 5
  },
  "consciousness": {
    "publish_tag": "consciousness=true",
    "anima_vote_weight": 2,
    "auto_tags": ["source=anima", "engine=consciousness"]
  }
}
