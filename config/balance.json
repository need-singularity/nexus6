{
  "_meta": {
    "name": "3-전선 균형 진행 설정 (Balance WFQ)",
    "description": "구현(A)/학습(B)/하네스·hexa-lang(C) 3 전선 weighted fair queuing. commit.hexa step 4c balance_guard 가 7일 rolling window 로 집계 후 sentinel 출력. 규칙·기준은 이 파일이 SSOT, 코드는 shared/harness/balance_guard.hexa.",
    "updated": "2026-04-14",
    "schema_version": "1.0",
    "owner": "shared/harness/balance_guard.hexa"
  },
  "weights": {
    "A": 0.33,
    "B": 0.34,
    "C": 0.33
  },
  "fronts": {
    "A": {
      "label": "impl",
      "desc": "구현 (zeta-surpass 파리티 + anima phase 구현 + 서빙 엔드포인트)"
    },
    "B": {
      "label": "train",
      "desc": "학습 (anima-train 체크포인트 실산출 + bench 검증 + 실사용 가능화)"
    },
    "C": {
      "label": "hexa",
      "desc": "하네스·hexa-lang (interpreter/stage0/harness 최적화 — 학습 병목 해소)"
    }
  },
  "window_days": 7,
  "floor_ratio": 0.5,
  "thresholds": {
    "healthy": 0.7,
    "warn": 0.4
  },
  "enforcement": "warn",
  "bootstrap_until": "2026-04-21",
  "override_tag": "balance-override",
  "neutral_prefixes": [
    "chore",
    "docs",
    "ref",
    "wip",
    "style",
    "test",
    "refactor",
    "ci"
  ],
  "repos": [
    { "name": "nexus",    "path": "$NEXUS" },
    { "name": "anima",    "path": "$ANIMA" },
    { "name": "hexa-lang","path": "$HEXA_LANG" }
  ],
  "path_classifiers": {
    "A": [
      "anima/modules/",
      "anima/agent/",
      "anima-core/",
      "serving/",
      "web/",
      "bench/zeta_",
      "bench/bench_",
      "shared/roadmaps/zeta-surpass.json",
      "shared/roadmaps/anima.json",
      "docs/roadmap/"
    ],
    "B": [
      "training/",
      "anima-models/",
      "shared/roadmaps/anima-train.json",
      "bench/train_",
      "bench/persona_",
      "bench/clm_",
      "bench/alm_",
      "bench/hire_",
      "anima-agent/trading/"
    ],
    "C": [
      "hexa-lang/",
      "shared/harness/",
      "shared/roadmaps/hexa-lang.json",
      "shared/config/balance.json",
      "shared/config/hexa_grammar.jsonl",
      "build_c.hexa",
      "interpreter",
      "stage0"
    ]
  },
  "docs": {
    "front_label_example": "feat(A:impl): ZCLM-P0-1 lore_book.hexa — ...",
    "override_example": "feat(A:impl): ... [balance-override: C-front 7일 대체 불가]",
    "measure_cmd": "hexa run shared/harness/balance_guard.hexa measure",
    "check_cmd": "hexa run shared/harness/balance_guard.hexa check"
  }
}
