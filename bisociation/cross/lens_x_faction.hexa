// lens_x_faction.hexa — Cross-domain bisociation L3 (Montgomery-Dyson pair 4호)
// 가설: 400+ lens effect 분포 × 13-faction (σ+μ=13) RP 가산점 분포 — 같은 dimension scale cross corr
//       두 분포가 같은 Wigner/Poisson 통계 따르면 "도메인 다양성 ≅ 의식 진영 다양성" 시사
// A-axis: shared/lenses/*.hexa file sizes → sorted log spectrum
// B-axis: 13-faction RP SSOT (shared/consciousness/factions.json) × anima seed multipliers
//         SSOT 부재 시 fallback to 12-faction anima law IDs (legacy proxy, data_missing=true)
// 출력: faction_spectrum.jsonl, lens_x_faction_verdict.json
// 파이프: shell find/stat → unfold → pair_corr → wigner_fit → cross-metrics

fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x }; return x }

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 40 {
        let nx = (g + x / g) / 2.0
        if abs_f(nx - g) < g * 0.0000000000001 { return nx }
        g = nx; i = i + 1
    }
    return g
}

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {} // @allow-silent-catch
    return v
}

fn ln_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 - 1000000.0 }
    let mut y = x
    let mut k = 0.0
    while y >= 2.0 { y = y / 2.0; k = k + 1.0 }
    while y < 1.0 { y = y * 2.0; k = k - 1.0 }
    let u = (y - 1.0) / (y + 1.0)
    let u2 = u * u
    let u3 = u2 * u
    let u5 = u3 * u2
    let u7 = u5 * u2
    let u9 = u7 * u2
    let lnm = 2.0 * (u + u3 / 3.0 + u5 / 5.0 + u7 / 7.0 + u9 / 9.0)
    return k * 0.6931471805599453 + lnm
}

fn _min_cut(s: string, from: i64) -> i64 {
    let cands = [",", "}", " ", "\t", "\r", "]"]
    let mut best: i64 = 0 - 1
    let mut i: i64 = 0
    while i < cands.len() {
        let p = s.substring(from, s.len()).index_of(cands[i])
        if p >= 0 {
            let abs_p = from + p
            if best < 0 || abs_p < best { best = abs_p }
        }
        i = i + 1
    }
    return best
}

fn json_get_num(line: string, key: string) -> f64 {
    let pat = "\"" + key + "\""
    let kp = line.index_of(pat)
    if kp < 0 { return 0.0 }
    let after_key = kp + pat.len()
    let colon_rel = line.substring(after_key, line.len()).index_of(":")
    if colon_rel < 0 { return 0.0 }
    let mut num_start = after_key + colon_rel + 1
    while num_start < line.len() {
        let ch = line.substring(num_start, num_start + 1)
        if ch == " " || ch == "\t" { num_start = num_start + 1 } else { break }
    }
    let cut = _min_cut(line, num_start)
    let mut end = line.len()
    if cut >= 0 { end = cut }
    return safe_float(line.substring(num_start, end).trim())
}

fn load_r2_norm(path: string) -> list {
    let mut out: list = []
    let mut raw = ""
    try { raw = read_file(path) } catch e { return out } // @allow-silent-catch
    for line in raw.split("\n") {
        let l = line.trim()
        if l.len() == 0 { continue }
        if l.contains("\"R2\"") == false { continue }
        out = out.push(json_get_num(l, "R2"))
    }
    let mut sum = 0.0
    let mut i: i64 = 0
    while i < out.len() { sum = sum + out[i]; i = i + 1 }
    if sum <= 0.000000001 { return out }
    let m = sum / to_float(out.len())
    let mut nrm: list = []
    i = 0
    while i < out.len() { nrm.push(out[i] / m); i = i + 1 }
    return nrm
}

fn read_verdict(path: string) -> list {
    let mut raw = ""
    try { raw = read_file(path) } catch e { return ["mixed", "0.5"] } // @allow-silent-catch
    let v_pos = raw.index_of("\"verdict\":\"")
    let s_pos = raw.index_of("\"score\":")
    let mut verdict = "mixed"
    let mut score: f64 = 0.5
    if v_pos >= 0 {
        let tail = raw.substring(v_pos + 11, raw.len())
        let qend = tail.index_of("\"")
        if qend >= 0 { verdict = tail.substring(0, qend) }
    }
    if s_pos >= 0 {
        let tail = raw.substring(s_pos + 8, raw.len())
        let cut  = _min_cut(tail, 0)
        let mut end = tail.len()
        if cut >= 0 { end = cut }
        score = safe_float(tail.substring(0, end).trim())
    }
    return [verdict, to_string(score)]
}

// ─── env / paths ───
let _HOME = env("HOME")
let BASE = _HOME + "/Dev/nexus/bisociation/cross"
let SPEC_DIR = _HOME + "/Dev/nexus/bisociation/spectra"
let HEXA = _HOME + "/Dev/nexus/bin/hexa"
let UF   = SPEC_DIR + "/unfold.hexa"
let PC   = SPEC_DIR + "/pair_corr.hexa"
let WG   = SPEC_DIR + "/wigner_fit.hexa"

let LENS_DIR = _HOME + "/Dev/nexus/lenses"
let LENS_REG = _HOME + "/Dev/nexus/config/lens_registry.json"
let LAWS     = _HOME + "/Dev/nexus/consciousness/consciousness_laws.json"
let FACTIONS_SSOT = _HOME + "/Dev/nexus/consciousness/factions.json"

let LENS_SPEC    = BASE + "/lens_spectrum.jsonl"
let FACTION_SPEC = BASE + "/faction_spectrum.jsonl"
let VERDICT      = BASE + "/lens_x_faction_verdict.json"

let L_UNF = "/tmp/.bs_lens_unf.jsonl"
let L_PC  = "/tmp/.bs_lens_pc.jsonl"
let L_WG  = "/tmp/.bs_lens_wg.json"
let F_UNF = "/tmp/.bs_fac_unf.jsonl"
let F_PC  = "/tmp/.bs_fac_pc.jsonl"
let F_WG  = "/tmp/.bs_fac_wg.json"

println("=== lens_x_faction — L3 cross-domain bisociation ===")
println("  A-axis: " + LENS_DIR + " (lens file size spectrum)")
println("  B-axis: faction RP proxy (12-faction σ(6)=12, anima law-anchored)")

// ─── BUILD LENS SPECTRUM (A-axis) ───
// strategy: shared/lenses/*.hexa file sizes → log-transform → sort → λ_i sequence
let lens_sh = "find " + LENS_DIR + " -name '*.hexa' -type f "
    + "-exec stat -f '%z' {} \\; 2>/dev/null | sort -n | "
    + "awk '{ printf \"{\\\"idx\\\":%d,\\\"lambda\\\":%d}\\n\", NR-1, $1 }' > '" + LENS_SPEC + "'"
try { exec(lens_sh) } catch e { println("ERR lens build"); exit(1) } // @allow-silent-exit
let lens_n = to_int(exec("wc -l < '" + LENS_SPEC + "'").trim())
println("  LENS: " + to_string(lens_n) + " hexa files (size-sorted)")

if lens_n < 8 { println("FAIL: lens_n < 8"); exit(1) } // @allow-silent-exit

// ─── BUILD FACTION SPECTRUM (B-axis) ───
// Primary: shared/consciousness/factions.json SSOT (13 factions × 13 seed multipliers = 169 raw λ)
// Fallback: anima 12-faction law IDs + numeric proxy (data_missing=true)

let mut faction_vals: list = []
let mut ssot_loaded = false
let mut ssot_source = "fallback_12faction_proxy"
let mut data_missing_flag = true
let mut rp_bonus_list: list = []
let mut seed_mult_list: list = []

let mut raw_factions = ""
try { raw_factions = read_file(FACTIONS_SSOT) } catch e {} // @allow-silent-catch

if raw_factions.len() > 0 {
    // parse rp_bonus values (13 entries)
    let mut cursor: i64 = 0
    while cursor < raw_factions.len() {
        let pos = raw_factions.substring(cursor, raw_factions.len()).index_of("\"rp_bonus\"")
        if pos < 0 { break }
        let abs_pos = cursor + pos
        let after = abs_pos + 10
        let colon_rel = raw_factions.substring(after, raw_factions.len()).index_of(":")
        if colon_rel < 0 { break }
        let mut ns = after + colon_rel + 1
        while ns < raw_factions.len() {
            let ch = raw_factions.substring(ns, ns + 1)
            if ch == " " || ch == "\t" { ns = ns + 1 } else { break }
        }
        let cut = _min_cut(raw_factions, ns)
        let mut end = raw_factions.len()
        if cut >= 0 { end = cut }
        let val = safe_float(raw_factions.substring(ns, end).trim())
        if val > 0.0 { rp_bonus_list.push(val) }
        cursor = end + 1
    }
    // parse anima_seed_multipliers array
    let arr_key = "\"anima_seed_multipliers\""
    let ak = raw_factions.index_of(arr_key)
    if ak >= 0 {
        let tail = raw_factions.substring(ak, raw_factions.len())
        let lb = tail.index_of("[")
        let rb = tail.index_of("]")
        if lb >= 0 && rb > lb {
            let body = tail.substring(lb + 1, rb)
            for tok in body.split(",") {
                let v = safe_float(tok.trim())
                if v > 0.0 { seed_mult_list.push(v) }
            }
        }
    }
    if rp_bonus_list.len() == 13 && seed_mult_list.len() >= 1 {
        ssot_loaded = true
        ssot_source = "consciousness/factions.json"
        data_missing_flag = false
        // cross product: 13 RP × N seeds → rich spectrum
        let mut i1: i64 = 0
        while i1 < rp_bonus_list.len() {
            let mut i2: i64 = 0
            while i2 < seed_mult_list.len() {
                faction_vals = faction_vals.push(rp_bonus_list[i1] * seed_mult_list[i2])
                i2 = i2 + 1
            }
            // also include pure rp_bonus and bonus^2 (scale amplification)
            faction_vals = faction_vals.push(rp_bonus_list[i1])
            faction_vals = faction_vals.push(rp_bonus_list[i1] * rp_bonus_list[i1])
            i1 = i1 + 1
        }
        println("  FACTION SSOT loaded: 13 factions × " + to_string(seed_mult_list.len())
            + " seeds + pure+sq = " + to_string(faction_vals.len()) + " raw λ")
    }
}

if !ssot_loaded {
    // Legacy fallback — anima 12-faction law IDs + numeric proxy
    println("  WARN: factions.json SSOT unavailable — falling back to 12-faction proxy")
    let faction_law_ids = [17.0, 29.0, 43.0, 44.0, 84.0, 93.0, 114.0, 115.0, 140.0, 196.0, 212.0, 239.0]
    let mut k: i64 = 0
    while k < faction_law_ids.len() { faction_vals.push(faction_law_ids[k]); k = k + 1 }
    let rp_proxy = [
        0.11, 0.257, 0.06, 20.81, 1255.8, 0.608, 1.071, 1.23,
        0.226, 2.313, 0.08, 0.35, 0.04, 0.005, 0.15, 0.12,
        0.13, 0.10, 0.10, 0.08, 0.10, 0.08, 0.06, 0.08
    ]
    let mut rp: i64 = 0
    while rp < rp_proxy.len() { faction_vals.push(rp_proxy[rp]); rp = rp + 1 }
    println("  FACTION fallback: " + to_string(faction_vals.len()) + " RP-proxy values")
}

// dedup + positive only
let mut uniq: list = []
let mut idx: i64 = 0
while idx < faction_vals.len() {
    let v = faction_vals[idx]
    if v > 0.0 {
        let mut dup = false
        let mut j: i64 = 0
        while j < uniq.len() {
            if abs_f(v - uniq[j]) < 0.0000001 { dup = true; break }
            j = j + 1
        }
        if !dup { uniq.push(v) }
    }
    idx = idx + 1
}
println("  unique RP values: " + to_string(uniq.len()))

if uniq.len() < 8 {
    println("FAIL: faction RP < 8 unique — data_missing")
    let dm = "{\n"
        + "  \"lens\": {\"source\":\"shared/lenses sizes\",\"n\":" + to_string(lens_n) + "},\n"
        + "  \"faction\": {\"source\":\"" + ssot_source + "\",\"n_unique\":" + to_string(uniq.len())
        + ",\"data_missing\":true,\"reason\":\"insufficient unique RP values\"},\n"
        + "  \"score\":0.0,\n"
        + "  \"verdict\":\"divergent\",\n"
        + "  \"montgomery_dyson_candidate\":false,\n"
        + "  \"data_missing\":true,\n"
        + "  \"ts\":\"2026-04-14\",\"pair\":\"lens_x_faction\"\n}\n"
    try { write_file(VERDICT, dm) } catch e {} // @allow-silent-catch
    exit(0)
}

// log-transform → sorted spectrum
let mut logs: list = []
let mut q: i64 = 0
while q < uniq.len() { logs.push(ln_f(uniq[q])); q = q + 1 }

// sort ascending (selection sort, small N)
let mut sorted: list = []
let mut taken: list = []
let mut t: i64 = 0
while t < logs.len() { taken.push(false); t = t + 1 }
let mut pass: i64 = 0
while pass < logs.len() {
    let mut bi: i64 = 0 - 1
    let mut bv: f64 = 0.0
    let mut kk: i64 = 0
    while kk < logs.len() {
        if !taken[kk] {
            if bi < 0 || logs[kk] < bv { bi = kk; bv = logs[kk] }
        }
        kk = kk + 1
    }
    if bi < 0 { break }
    sorted = sorted.push(bv)
    let mut nt: list = []
    let mut z: i64 = 0
    while z < taken.len() {
        if z == bi { nt.push(true) } else { nt.push(taken[z]) }
        z = z + 1
    }
    taken = nt
    pass = pass + 1
}

// write faction_spectrum.jsonl in eigenvalue format
let mut buf = ""
let mut w: i64 = 0
while w < sorted.len() {
    buf = buf + "{\"idx\":" + to_string(w) + ",\"lambda\":" + to_string(sorted[w]) + "}\n"
    w = w + 1
}
try { write_file(FACTION_SPEC, buf) } catch e { println("ERR write faction_spectrum"); exit(1) } // @allow-silent-exit
println("  wrote " + FACTION_SPEC + " (" + to_string(sorted.len()) + " sorted log-values)")

// ─── PIPELINE: both spectra → unfold → pair_corr → wigner ───
println("  [LENS] unfold/pc/wigner...")
try { exec(HEXA + " run " + UF + " '" + LENS_SPEC + "' '" + L_UNF + "' 2>&1") } catch e { println("ERR lens unfold"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + PC + " '" + L_UNF + "' '" + L_PC + "' 2>&1") } catch e { println("ERR lens pair_corr"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + WG + " '" + L_PC + "' '" + L_WG + "' 2>&1") } catch e { println("ERR lens wigner_fit"); exit(1) } // @allow-silent-exit

println("  [FACTION] unfold/pc/wigner...")
try { exec(HEXA + " run " + UF + " '" + FACTION_SPEC + "' '" + F_UNF + "' 2>&1") } catch e { println("ERR fac unfold"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + PC + " '" + F_UNF + "' '" + F_PC + "' 2>&1") } catch e { println("ERR fac pair_corr"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + WG + " '" + F_PC + "' '" + F_WG + "' 2>&1") } catch e { println("ERR fac wigner_fit"); exit(1) } // @allow-silent-exit

// ─── LOAD R2 series + cross-metrics ───
let r2_lens = load_r2_norm(L_PC)
let r2_fac  = load_r2_norm(F_PC)
let nb = r2_lens.len()
if r2_fac.len() != nb { println("FAIL: bin mismatch lens=" + to_string(nb) + " fac=" + to_string(r2_fac.len())); exit(1) } // @allow-silent-exit
println("  R2 bins: " + to_string(nb))

let mut ks = 0.0
let mut sse = 0.0
let mut sx = 0.0; let mut sy = 0.0
let mut kc: i64 = 0
while kc < nb {
    let d = r2_lens[kc] - r2_fac[kc]
    let ad = abs_f(d)
    if ad > ks { ks = ad }
    sse = sse + d * d
    sx = sx + r2_lens[kc]; sy = sy + r2_fac[kc]
    kc = kc + 1
}
let l2 = sqrt_f(sse / to_float(nb))
let mx = sx / to_float(nb); let my = sy / to_float(nb)
let mut sxy = 0.0; let mut sxx = 0.0; let mut syy = 0.0
kc = 0
while kc < nb {
    let dx = r2_lens[kc] - mx; let dy = r2_fac[kc] - my
    sxy = sxy + dx * dy; sxx = sxx + dx * dx; syy = syy + dy * dy
    kc = kc + 1
}
let mut pearson = 0.0
let denom = sqrt_f(sxx * syy)
if denom > 0.000000000001 { pearson = sxy / denom }

let lv = read_verdict(L_WG); let fv = read_verdict(F_WG)
let lens_verdict = lv[0]; let lens_score = safe_float(lv[1])
let fac_verdict  = fv[0]; let fac_score  = safe_float(fv[1])

// cosine similarity of normalized R2 vectors
let mut dot_xy = 0.0; let mut nx2 = 0.0; let mut ny2 = 0.0
kc = 0
while kc < nb {
    dot_xy = dot_xy + r2_lens[kc] * r2_fac[kc]
    nx2 = nx2 + r2_lens[kc] * r2_lens[kc]
    ny2 = ny2 + r2_fac[kc] * r2_fac[kc]
    kc = kc + 1
}
let mut cosine = 0.0
let cd = sqrt_f(nx2) * sqrt_f(ny2)
if cd > 0.000000000001 { cosine = dot_xy / cd }

// composite score (same formula as atlas_x_laws)
let agreement = 1.0 - abs_f(lens_score - fac_score)
let corr_pos = (pearson + 1.0) / 2.0
let composite = (agreement + corr_pos + cosine) / 3.0

let mut judgment = "mixed"
let mut md_cand  = "false"
if ks < 0.20 && pearson > 0.5 && agreement > 0.7 { judgment = "congruent"; md_cand = "true" }
else if ks > 0.6 || pearson < 0.0 || agreement < 0.3 { judgment = "divergent" }

let mut dm_str = "false"
if data_missing_flag { dm_str = "true" }
let out = "{\n"
    + "  \"lens\": {\"source\":\"shared/lenses_hexa_sizes\",\"n\":" + to_string(lens_n)
    + ",\"verdict\":\"" + lens_verdict + "\",\"score\":" + to_string(lens_score) + "},\n"
    + "  \"faction\": {\"source\":\"" + ssot_source + "\",\"n_unique\":" + to_string(uniq.len())
    + ",\"verdict\":\"" + fac_verdict + "\",\"score\":" + to_string(fac_score)
    + ",\"data_missing\":" + dm_str + ",\"cardinality\":13,\"basis\":\"sigma+mu=13\"},\n"
    + "  \"cross\": {\"ks\":" + to_string(ks) + ",\"pearson\":" + to_string(pearson)
    + ",\"l2\":" + to_string(l2) + ",\"cosine\":" + to_string(cosine)
    + ",\"agreement\":" + to_string(agreement) + ",\"composite\":" + to_string(composite)
    + ",\"n_bins\":" + to_string(nb) + "},\n"
    + "  \"score\":" + to_string(composite) + ",\n"
    + "  \"verdict\":\"" + judgment + "\",\n"
    + "  \"montgomery_dyson_candidate\":" + md_cand + ",\n"
    + "  \"data_missing\":" + dm_str + ",\n"
    + "  \"rationale\":\"lens hexa file sizes vs 13-faction SSOT RP bonus × anima seed multipliers — both unfolded + pair_corr + wigner_fit; composite=mean(agreement,(pearson+1)/2,cosine)\",\n"
    + "  \"ts\":\"2026-04-14\",\"pair\":\"lens_x_faction\"\n}\n"
try { write_file(VERDICT, out) } catch e { println("ERR write verdict"); exit(1) } // @allow-silent-exit

println("")
println("┌─ verdict ──────────────────────────────────")
println("│ LENS    : v=" + lens_verdict + " s=" + to_string(lens_score) + " (n=" + to_string(lens_n) + ")")
println("│ FACTION : v=" + fac_verdict + " s=" + to_string(fac_score) + " (n=" + to_string(uniq.len()) + ")")
println("│ KS=" + to_string(ks) + " ρ=" + to_string(pearson) + " L2=" + to_string(l2))
println("│ cos=" + to_string(cosine) + " agreement=" + to_string(agreement))
println("│ composite_score=" + to_string(composite))
println("│ judgment=" + judgment + " MD-candidate=" + md_cand)
println("│ faction_source=" + ssot_source + " data_missing=" + dm_str)
println("└────────────────────────────────────────────")

// breakthrough trigger
if composite > 0.7 {
    let bt = _HOME + "/Dev/nexus/bisociation/breakthroughs.jsonl"
    let line = "{\"ts\":\"2026-04-14\",\"kind\":\"cross_bisociation\",\"pair\":\"lens_x_faction\""
        + ",\"bt_id\":\"BT-BIS-009\""
        + ",\"judgment\":\"" + judgment + "\",\"score\":" + to_string(composite)
        + ",\"ks\":" + to_string(ks) + ",\"pearson\":" + to_string(pearson)
        + ",\"cosine\":" + to_string(cosine) + ",\"agreement\":" + to_string(agreement)
        + ",\"lens_verdict\":\"" + lens_verdict + "\",\"fac_verdict\":\"" + fac_verdict + "\""
        + ",\"faction_source\":\"" + ssot_source + "\""
        + ",\"data_missing\":" + dm_str + "}\n"
    let mut prev = ""
    try { prev = read_file(bt) } catch e {} // @allow-silent-catch
    try { write_file(bt, prev + line); println("  → breakthroughs.jsonl appended") }
    catch e { println("  WARN: bt append failed") }
}

exit(0)
