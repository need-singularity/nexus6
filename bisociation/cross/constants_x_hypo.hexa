// constants_x_hypo.hexa — Cross-domain bisociation L3 (Montgomery-Dyson pair 3호)
// 가설: n6_constants log-spectrum(전체, 46) × hypothesis-anchored 부분집합 spectrum
//       부분집합이 GUE 친화면 "BT-anchored 상수가 양자 카오스 spacing 따름" → mixed→GUE 돌파 가능
// A-axis: n6_constants 전체 log-spectrum (constants_spectrum.jsonl 재활용, mixed 0.358)
// B-axis: hypothesis subset = bt 필드 보유 + value>=100 기준 → log → unfold → pair_corr → wigner_fit
// 출력: hypo_spectrum.jsonl, constants_x_hypo_verdict.json

fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x }; return x }

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 40 {
        let nx = (g + x / g) / 2.0
        if abs_f(nx - g) < g * 0.0000000000001 { return nx }
        g = nx; i = i + 1
    }
    return g
}

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {} // @allow-silent-catch
    return v
}

// natural log via Newton-style halving + Taylor (atanh form)
fn ln_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 - 1000000.0 }
    let mut y = x
    let mut k = 0.0
    while y >= 2.0 { y = y / 2.0; k = k + 1.0 }
    while y < 1.0 { y = y * 2.0; k = k - 1.0 }
    let u = (y - 1.0) / (y + 1.0)
    let u2 = u * u
    let u3 = u2 * u
    let u5 = u3 * u2
    let u7 = u5 * u2
    let u9 = u7 * u2
    let lnm = 2.0 * (u + u3 / 3.0 + u5 / 5.0 + u7 / 7.0 + u9 / 9.0)
    return k * 0.6931471805599453 + lnm
}

fn _min_cut(s: string, from: i64) -> i64 {
    let cands = [",", "}", " ", "\t", "\r", "]"]
    let mut best: i64 = 0 - 1
    let mut i: i64 = 0
    while i < cands.len() {
        let p = s.substring(from, s.len()).index_of(cands[i])
        if p >= 0 {
            let abs_p = from + p
            if best < 0 || abs_p < best { best = abs_p }
        }
        i = i + 1
    }
    return best
}

fn json_get_num(line: string, key: string) -> f64 {
    let pat = "\"" + key + "\""
    let kp = line.index_of(pat)
    if kp < 0 { return 0.0 }
    let after_key = kp + pat.len()
    let colon_rel = line.substring(after_key, line.len()).index_of(":")
    if colon_rel < 0 { return 0.0 }
    let mut num_start = after_key + colon_rel + 1
    while num_start < line.len() {
        let ch = line.substring(num_start, num_start + 1)
        if ch == " " || ch == "\t" { num_start = num_start + 1 } else { break }
    }
    let cut = _min_cut(line, num_start)
    let mut end = line.len()
    if cut >= 0 { end = cut }
    return safe_float(line.substring(num_start, end).trim())
}

// load R2 series, normalize mean→1 for shape-only comparison
fn load_r2_norm(path: string) -> list {
    let mut out: list = []
    let mut raw = ""
    try { raw = read_file(path) } catch e { return out } // @allow-silent-catch
    for line in raw.split("\n") {
        let l = line.trim()
        if l.len() == 0 { continue }
        if l.contains("\"R2\"") == false { continue }
        out = out.push(json_get_num(l, "R2"))
    }
    let mut sum = 0.0
    let mut i: i64 = 0
    while i < out.len() { sum = sum + out[i]; i = i + 1 }
    if sum <= 0.000000001 { return out }
    let m = sum / to_float(out.len())
    let mut nrm: list = []
    i = 0
    while i < out.len() { nrm.push(out[i] / m); i = i + 1 }
    return nrm
}

fn read_verdict(path: string) -> list {
    let mut raw = ""
    try { raw = read_file(path) } catch e { return ["mixed", "0.5"] } // @allow-silent-catch
    let v_pos = raw.index_of("\"verdict\":\"")
    let s_pos = raw.index_of("\"score\":")
    let mut verdict = "mixed"
    let mut score: f64 = 0.5
    if v_pos >= 0 {
        let tail = raw.substring(v_pos + 11, raw.len())
        let qend = tail.index_of("\"")
        if qend >= 0 { verdict = tail.substring(0, qend) }
    }
    if s_pos >= 0 {
        let tail = raw.substring(s_pos + 8, raw.len())
        let cut  = _min_cut(tail, 0)
        let mut end = tail.len()
        if cut >= 0 { end = cut }
        score = safe_float(tail.substring(0, end).trim())
    }
    return [verdict, to_string(score)]
}

// ─── env / paths ───
let _HOME = env("HOME")
let BASE = _HOME + "/Dev/nexus/shared/bisociation/cross"
let SPEC_DIR = _HOME + "/Dev/nexus/shared/bisociation/spectra"
let HEXA = _HOME + "/Dev/nexus/shared/bin/hexa"
let UF   = SPEC_DIR + "/unfold.hexa"
let PC   = SPEC_DIR + "/pair_corr.hexa"
let WG   = SPEC_DIR + "/wigner_fit.hexa"

let CONST_SRC = _HOME + "/Dev/nexus/shared/n6/n6_constants.jsonl"
let CONST_SPEC = BASE + "/constants_spectrum.jsonl"     // A-axis (already exists, mixed 0.358)
let HYPO_SPEC = BASE + "/hypo_spectrum.jsonl"           // B-axis (this run produces)
let A_PC = "/tmp/.bs_const_x_pc.jsonl"
let A_UNF = "/tmp/.bs_const_x_unf.jsonl"
let A_WG  = "/tmp/.bs_const_x_wg.json"
let B_UNF = "/tmp/.bs_hypo_unf.jsonl"
let B_PC  = "/tmp/.bs_hypo_pc.jsonl"
let B_WG  = "/tmp/.bs_hypo_wg.json"
let VERDICT = BASE + "/constants_x_hypo_verdict.json"

println("=== constants_x_hypo — L3 cross-domain bisociation ===")
println("  A-axis: " + CONST_SPEC + " (n6_constants full log-spectrum, 46)")
println("  B-axis: " + HYPO_SPEC + " (hypothesis-anchored subset: bt+value>=100)")

// ─── BUILD HYPOTHESIS SPECTRUM (B-axis) ───
// strategy: parse n6_constants.jsonl; keep entries where line contains "bt" field
//           OR value >= 100 (paper-scale anchors); log-transform; sort ascending

let mut raw_const = ""
try { raw_const = read_file(CONST_SRC) } catch e { println("ERR read constants"); exit(1) } // @allow-silent-exit

let mut hypo_vals: list = []
let mut hypo_names: list = []
for line in raw_const.split("\n") {
    let l = line.trim()
    if l.len() == 0 { continue }
    if l.contains("\"value\"") == false { continue }
    let v = json_get_num(l, "value")
    if v <= 0.0 { continue }
    let has_bt = l.contains("\"bt\"")
    let big = v >= 100.0
    if has_bt || big {
        // extract name
        let np = l.index_of("\"name\":\"")
        let mut nm = ""
        if np >= 0 {
            let tail = l.substring(np + 8, l.len())
            let qe = tail.index_of("\"")
            if qe >= 0 { nm = tail.substring(0, qe) }
        }
        hypo_vals = hypo_vals.push(v)
        hypo_names = hypo_names.push(nm)
    }
}
println("  hypothesis-anchored constants: " + to_string(hypo_vals.len()))

// dedup by value (epsilon)
let mut uniq_v: list = []
let mut uniq_n: list = []
let mut i: i64 = 0
while i < hypo_vals.len() {
    let v = hypo_vals[i]
    let mut dup = false
    let mut j: i64 = 0
    while j < uniq_v.len() {
        if abs_f(v - uniq_v[j]) < 0.0000001 { dup = true; break }
        j = j + 1
    }
    if !dup { uniq_v.push(v); uniq_n.push(hypo_names[i]) }
    i = i + 1
}
println("  unique hypothesis values: " + to_string(uniq_v.len()))

if uniq_v.len() < 8 { println("FAIL: need >=8 unique hypothesis constants, got " + to_string(uniq_v.len())); exit(1) } // @allow-silent-exit

// log-transform → sorted spectrum
let mut logs: list = []
let mut q: i64 = 0
while q < uniq_v.len() { logs.push(ln_f(uniq_v[q])); q = q + 1 }

// selection sort ascending (small N)
let mut sorted: list = []
let mut sorted_names: list = []
let mut taken: list = []
let mut t: i64 = 0
while t < logs.len() { taken.push(false); t = t + 1 }
let mut pass: i64 = 0
while pass < logs.len() {
    let mut bi: i64 = 0 - 1
    let mut bv: f64 = 0.0
    let mut k: i64 = 0
    while k < logs.len() {
        if !taken[k] {
            if bi < 0 || logs[k] < bv { bi = k; bv = logs[k] }
        }
        k = k + 1
    }
    if bi < 0 { break }
    sorted = sorted.push(bv)
    sorted_names = sorted_names.push(uniq_n[bi])
    let mut nt: list = []
    let mut z: i64 = 0
    while z < taken.len() {
        if z == bi { nt.push(true) } else { nt.push(taken[z]) }
        z = z + 1
    }
    taken = nt
    pass = pass + 1
}

// write hypo_spectrum.jsonl (eigenvalue format for unfold)
let mut buf = ""
let mut w: i64 = 0
while w < sorted.len() {
    buf = buf + "{\"idx\":" + to_string(w) + ",\"lambda\":" + to_string(sorted[w])
        + ",\"name\":\"" + sorted_names[w] + "\"}\n"
    w = w + 1
}
try { write_file(HYPO_SPEC, buf) } catch e { println("ERR write hypo_spectrum"); exit(1) } // @allow-silent-exit
println("  wrote " + HYPO_SPEC + " (" + to_string(sorted.len()) + " sorted log-values)")

// log(sigma=12) reference — proximity check
let LOG_SIGMA = ln_f(12.0)
let LOG_N = ln_f(6.0)
let LOG_J2 = ln_f(24.0)
println("  refs: log(n=6)=" + to_string(LOG_N) + " log(sigma=12)=" + to_string(LOG_SIGMA) + " log(j2=24)=" + to_string(LOG_J2))

// ─── PIPELINE: A (constants spec) → unfold → pair_corr → wigner ───
println("  [A constants] unfold/pc/wigner...")
try { exec(HEXA + " run " + UF + " '" + CONST_SPEC + "' '" + A_UNF + "' 2>&1") } catch e { println("ERR A unfold"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + PC + " '" + A_UNF + "' '" + A_PC + "' 2>&1") } catch e { println("ERR A pair_corr"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + WG + " '" + A_PC + "' '" + A_WG + "' 2>&1") } catch e { println("ERR A wigner_fit"); exit(1) } // @allow-silent-exit

println("  [B hypo] unfold/pc/wigner...")
try { exec(HEXA + " run " + UF + " '" + HYPO_SPEC + "' '" + B_UNF + "' 2>&1") } catch e { println("ERR B unfold"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + PC + " '" + B_UNF + "' '" + B_PC + "' 2>&1") } catch e { println("ERR B pair_corr"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + WG + " '" + B_PC + "' '" + B_WG + "' 2>&1") } catch e { println("ERR B wigner_fit"); exit(1) } // @allow-silent-exit

// ─── LOAD R2 series + cross-metrics ───
let r2_a = load_r2_norm(A_PC)
let r2_b = load_r2_norm(B_PC)
let nb = r2_a.len()
if r2_b.len() != nb { println("FAIL: bin mismatch A=" + to_string(nb) + " B=" + to_string(r2_b.len())); exit(1) } // @allow-silent-exit
println("  R2 bins: " + to_string(nb))

// peak detection in B (hypo) R2 spectrum + report bins near sigma=12
// each R2 bin center r = (k+0.5)*0.1 in unfolded units; we also report raw spacing peaks
let mut ks = 0.0
let mut sse = 0.0
let mut sx = 0.0; let mut sy = 0.0
let mut k: i64 = 0
while k < nb {
    let d = r2_a[k] - r2_b[k]
    let ad = abs_f(d)
    if ad > ks { ks = ad }
    sse = sse + d * d
    sx = sx + r2_a[k]; sy = sy + r2_b[k]
    k = k + 1
}
let l2 = sqrt_f(sse / to_float(nb))
let mx = sx / to_float(nb); let my = sy / to_float(nb)
let mut sxy = 0.0; let mut sxx = 0.0; let mut syy = 0.0
k = 0
while k < nb {
    let dx = r2_a[k] - mx; let dy = r2_b[k] - my
    sxy = sxy + dx * dy; sxx = sxx + dx * dx; syy = syy + dy * dy
    k = k + 1
}
let mut pearson = 0.0
let denom = sqrt_f(sxx * syy)
if denom > 0.000000000001 { pearson = sxy / denom }

// cosine similarity over R2 vectors
let mut dot_xy = 0.0; let mut nx2 = 0.0; let mut ny2 = 0.0
k = 0
while k < nb {
    dot_xy = dot_xy + r2_a[k] * r2_b[k]
    nx2 = nx2 + r2_a[k] * r2_a[k]
    ny2 = ny2 + r2_b[k] * r2_b[k]
    k = k + 1
}
let mut cosine = 0.0
let cd = sqrt_f(nx2) * sqrt_f(ny2)
if cd > 0.000000000001 { cosine = dot_xy / cd }

// peak in B-spectrum: find max R2 bin index, report center + value
let mut bmax_i: i64 = 0
let mut bmax_v: f64 = 0.0
k = 0
while k < nb {
    if r2_b[k] > bmax_v { bmax_v = r2_b[k]; bmax_i = k }
    k = k + 1
}
let bmax_center = (to_float(bmax_i) + 0.5) * 0.1

// proximity: which sorted hypo log-value lies closest to log(sigma=12)?
let mut sigma_idx: i64 = 0
let mut sigma_dist: f64 = 1000000.0
let mut zi: i64 = 0
while zi < sorted.len() {
    let dd = abs_f(sorted[zi] - LOG_SIGMA)
    if dd < sigma_dist { sigma_dist = dd; sigma_idx = zi }
    zi = zi + 1
}
let sigma_anchor_name = sorted_names[sigma_idx]

// Wigner verdicts
let av = read_verdict(A_WG); let bv = read_verdict(B_WG)
let a_verdict = av[0]; let a_score = safe_float(av[1])
let b_verdict = bv[0]; let b_score = safe_float(bv[1])

let agreement = 1.0 - abs_f(a_score - b_score)
let corr_pos = (pearson + 1.0) / 2.0
let composite = (agreement + corr_pos + cosine) / 3.0

let mut judgment = "mixed"
let mut md_cand  = "false"
if ks < 0.20 && pearson > 0.5 && agreement > 0.7 { judgment = "congruent"; md_cand = "true" }
else if ks > 0.6 || pearson < 0.0 || agreement < 0.3 { judgment = "divergent" }

let out = "{\n"
    + "  \"constants\": {\"source\":\"n6_constants_log_full\",\"n_lambdas\":46"
    + ",\"verdict\":\"" + a_verdict + "\",\"score\":" + to_string(a_score) + "},\n"
    + "  \"hypothesis\": {\"source\":\"n6_constants_bt_anchored\",\"n_lambdas\":" + to_string(sorted.len())
    + ",\"verdict\":\"" + b_verdict + "\",\"score\":" + to_string(b_score) + "},\n"
    + "  \"cross\": {\"ks\":" + to_string(ks) + ",\"pearson\":" + to_string(pearson)
    + ",\"l2\":" + to_string(l2) + ",\"cosine\":" + to_string(cosine)
    + ",\"agreement\":" + to_string(agreement) + ",\"composite\":" + to_string(composite)
    + ",\"n_bins\":" + to_string(nb) + "},\n"
    + "  \"hypo_peak\": {\"bin_idx\":" + to_string(bmax_i)
    + ",\"r_center\":" + to_string(bmax_center)
    + ",\"R2\":" + to_string(bmax_v) + "},\n"
    + "  \"sigma12_anchor\": {\"log_sigma\":" + to_string(LOG_SIGMA)
    + ",\"closest_hypo_idx\":" + to_string(sigma_idx)
    + ",\"closest_lambda\":" + to_string(sorted[sigma_idx])
    + ",\"name\":\"" + sigma_anchor_name + "\""
    + ",\"distance\":" + to_string(sigma_dist) + "},\n"
    + "  \"score\":" + to_string(composite) + ",\n"
    + "  \"verdict\":\"" + judgment + "\",\n"
    + "  \"montgomery_dyson_candidate\":" + md_cand + ",\n"
    + "  \"rationale\":\"n6_constants full log-spectrum vs hypothesis-anchored subset (bt-tagged + value>=100); both unfolded + pair_corr + wigner_fit; composite=mean(agreement,(pearson+1)/2,cosine); peak bin highlights GUE clustering near n6 invariants\",\n"
    + "  \"ts\":\"2026-04-14\",\"pair\":\"constants_x_hypo\"\n}\n"
try { write_file(VERDICT, out) } catch e { println("ERR write verdict"); exit(1) } // @allow-silent-exit

println("")
println("┌─ verdict ──────────────────────────────────")
println("│ A constants : v=" + a_verdict + " s=" + to_string(a_score) + " (n=46)")
println("│ B hypothesis: v=" + b_verdict + " s=" + to_string(b_score) + " (n=" + to_string(sorted.len()) + ")")
println("│ KS=" + to_string(ks) + " ρ=" + to_string(pearson) + " L2=" + to_string(l2))
println("│ cos=" + to_string(cosine) + " agreement=" + to_string(agreement))
println("│ composite_score=" + to_string(composite))
println("│ judgment=" + judgment + " MD-candidate=" + md_cand)
println("│ B peak: bin=" + to_string(bmax_i) + " r=" + to_string(bmax_center) + " R2=" + to_string(bmax_v))
println("│ sigma12 anchor: " + sigma_anchor_name + " λ=" + to_string(sorted[sigma_idx]) + " dist=" + to_string(sigma_dist))
println("└────────────────────────────────────────────")

// breakthrough trigger
if composite > 0.7 {
    let bt = _HOME + "/Dev/nexus/shared/bisociation/breakthroughs.jsonl"
    let line = "{\"id\":\"BT-BIS-008\",\"ts\":\"2026-04-14\",\"kind\":\"cross_bisociation\",\"pair\":\"constants_x_hypo\""
        + ",\"judgment\":\"" + judgment + "\",\"score\":" + to_string(composite)
        + ",\"ks\":" + to_string(ks) + ",\"pearson\":" + to_string(pearson)
        + ",\"cosine\":" + to_string(cosine) + ",\"agreement\":" + to_string(agreement)
        + ",\"const_verdict\":\"" + a_verdict + "\",\"hypo_verdict\":\"" + b_verdict + "\""
        + ",\"hypo_peak_r\":" + to_string(bmax_center) + ",\"hypo_peak_R2\":" + to_string(bmax_v)
        + ",\"sigma12_anchor\":\"" + sigma_anchor_name + "\",\"sigma12_dist\":" + to_string(sigma_dist)
        + ",\"note\":\"L3 constants_x_hypo — full log-spectrum vs bt-anchored subset; peak/anchor 분포 보고\"}\n"
    let mut prev = ""
    try { prev = read_file(bt) } catch e {} // @allow-silent-catch
    try { write_file(bt, prev + line); println("  → breakthroughs.jsonl appended (BT-BIS-008)") }
    catch e { println("  WARN: bt append failed") }
}

exit(0)
