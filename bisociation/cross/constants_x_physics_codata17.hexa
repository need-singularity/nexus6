// constants_x_physics_codata17.hexa — L3_cross priority_target
// 가설: derived(hbar, a_0, E_h, F, R_K, K_J, compton λ, r_e, Planck units, M_sun 등)를 제거하고
//       CODATA 상호독립 17개 기본 상수만 사용 → Pearson 노이즈 제거 → composite > 0.9 paper_trigger 돌파
// 17 = {c, h, e, k_B, N_A, G, alpha, R_inf, m_e, m_p, m_n, mu_0, eps_0, sigma, b, b', g_e}
// source: CODATA 2018/2022; c/h/e/k_B/N_A = SI exact (2019), 나머지 measured independent
// B-axis: this script builds physics17_spectrum.jsonl (17 log-values, sorted)
// A-axis: constants_spectrum.jsonl 재활용
// Output: constants_x_physics_codata17_verdict.json + bin_align rerun 포함

fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x }; return x }

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 40 {
        let nx = (g + x / g) / 2.0
        if abs_f(nx - g) < g * 0.0000000000001 { return nx }
        g = nx; i = i + 1
    }
    return g
}

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {} // @allow-silent-catch
    return v
}

fn ln_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 - 1000000.0 }
    let mut y = x
    let mut k = 0.0
    while y >= 2.0 { y = y / 2.0; k = k + 1.0 }
    while y < 1.0 { y = y * 2.0; k = k - 1.0 }
    let u = (y - 1.0) / (y + 1.0)
    let u2 = u * u
    let u3 = u2 * u
    let u5 = u3 * u2
    let u7 = u5 * u2
    let u9 = u7 * u2
    let lnm = 2.0 * (u + u3 / 3.0 + u5 / 5.0 + u7 / 7.0 + u9 / 9.0)
    return k * 0.6931471805599453 + lnm
}

fn _min_cut(s: string, from: i64) -> i64 {
    let cands = [",", "}", " ", "\t", "\r", "]"]
    let mut best: i64 = 0 - 1
    let mut i: i64 = 0
    while i < cands.len() {
        let p = s.substring(from, s.len()).index_of(cands[i])
        if p >= 0 { let abs_p = from + p; if best < 0 || abs_p < best { best = abs_p } }
        i = i + 1
    }
    return best
}

fn json_get_num(line: string, key: string) -> f64 {
    let pat = "\"" + key + "\""
    let kp = line.index_of(pat)
    if kp < 0 { return 0.0 }
    let after_key = kp + pat.len()
    let colon_rel = line.substring(after_key, line.len()).index_of(":")
    if colon_rel < 0 { return 0.0 }
    let mut num_start = after_key + colon_rel + 1
    while num_start < line.len() {
        let ch = line.substring(num_start, num_start + 1)
        if ch == " " || ch == "\t" { num_start = num_start + 1 } else { break }
    }
    let cut = _min_cut(line, num_start)
    let mut end = line.len()
    if cut >= 0 { end = cut }
    return safe_float(line.substring(num_start, end).trim())
}

fn load_r2_norm(path: string) -> list {
    let mut out: list = []
    let mut raw = ""
    try { raw = read_file(path) } catch e { return out } // @allow-silent-catch
    for line in raw.split("\n") {
        let l = line.trim()
        if l.len() == 0 { continue }
        if l.contains("\"R2\"") == false { continue }
        out = out.push(json_get_num(l, "R2"))
    }
    let mut sum = 0.0
    let mut i: i64 = 0
    while i < out.len() { sum = sum + out[i]; i = i + 1 }
    if sum <= 0.000000001 { return out }
    let m = sum / to_float(out.len())
    let mut nrm: list = []
    i = 0
    while i < out.len() { nrm.push(out[i] / m); i = i + 1 }
    return nrm
}

fn read_verdict(path: string) -> list {
    let mut raw = ""
    try { raw = read_file(path) } catch e { return ["mixed", "0.5"] } // @allow-silent-catch
    let v_pos = raw.index_of("\"verdict\":\"")
    let s_pos = raw.index_of("\"score\":")
    let mut verdict = "mixed"
    let mut score: f64 = 0.5
    if v_pos >= 0 {
        let tail = raw.substring(v_pos + 11, raw.len())
        let qend = tail.index_of("\"")
        if qend >= 0 { verdict = tail.substring(0, qend) }
    }
    if s_pos >= 0 {
        let tail = raw.substring(s_pos + 8, raw.len())
        let cut  = _min_cut(tail, 0)
        let mut end = tail.len()
        if cut >= 0 { end = cut }
        score = safe_float(tail.substring(0, end).trim())
    }
    return [verdict, to_string(score)]
}

fn mean_of(a: list) -> f64 {
    let n = a.len()
    if n == 0 { return 0.0 }
    let mut s = 0.0; let mut i: i64 = 0
    while i < n { s = s + a[i]; i = i + 1 }
    return s / to_float(n)
}

fn pearson_range(a: list, b: list, lo: i64, hi: i64, lag: i64) -> f64 {
    let n = hi - lo
    if n < 4 { return 0.0 - 2.0 }
    let mut sx = 0.0; let mut sy = 0.0
    let mut i = lo
    while i < hi {
        sx = sx + a[i]; sy = sy + b[i - lag]
        i = i + 1
    }
    let mx = sx / to_float(n); let my = sy / to_float(n)
    let mut sxy = 0.0; let mut sxx = 0.0; let mut syy = 0.0
    i = lo
    while i < hi {
        let dx = a[i] - mx; let dy = b[i - lag] - my
        sxy = sxy + dx * dy; sxx = sxx + dx * dx; syy = syy + dy * dy
        i = i + 1
    }
    let denom = sqrt_f(sxx * syy)
    if denom < 0.000000000001 { return 0.0 }
    return sxy / denom
}

fn best_lag_fn(a: list, b: list, lag_max: i64) -> list {
    let n = a.len()
    let mut best_r: f64 = 0.0 - 2.0
    let mut best_lag: i64 = 0
    let mut best_ov: i64 = n
    let mut lag: i64 = 0 - lag_max
    while lag <= lag_max {
        let mut lo: i64 = 0
        if lag > 0 { lo = lag }
        let mut hi: i64 = n
        if lag < 0 { hi = n + lag }
        if hi - lo >= 4 {
            let r = pearson_range(a, b, lo, hi, lag)
            if r > best_r { best_r = r; best_lag = lag; best_ov = hi - lo }
        }
        lag = lag + 1
    }
    return [to_float(best_lag), best_r, to_float(best_ov)]
}

fn apply_lag_fn(b: list, lag: i64) -> list {
    let n = b.len(); let m = mean_of(b)
    let mut out: list = []; let mut i: i64 = 0
    while i < n {
        let src = i - lag
        if src >= 0 && src < n { out.push(b[src]) } else { out.push(m) }
        i = i + 1
    }
    return out
}

fn cross_metrics(a: list, b: list) -> list {
    let n = a.len()
    let mut ks = 0.0; let mut sse = 0.0; let mut sx = 0.0; let mut sy = 0.0
    let mut k: i64 = 0
    while k < n {
        let d = a[k] - b[k]; let ad = abs_f(d)
        if ad > ks { ks = ad }
        sse = sse + d * d; sx = sx + a[k]; sy = sy + b[k]
        k = k + 1
    }
    let l2 = sqrt_f(sse / to_float(n))
    let mx = sx / to_float(n); let my = sy / to_float(n)
    let mut sxy = 0.0; let mut sxx = 0.0; let mut syy = 0.0
    k = 0
    while k < n {
        let dx = a[k] - mx; let dy = b[k] - my
        sxy = sxy + dx * dy; sxx = sxx + dx * dx; syy = syy + dy * dy
        k = k + 1
    }
    let mut pearson = 0.0; let denom = sqrt_f(sxx * syy)
    if denom > 0.000000000001 { pearson = sxy / denom }
    let mut dot_xy = 0.0; let mut nx2 = 0.0; let mut ny2 = 0.0
    k = 0
    while k < n {
        dot_xy = dot_xy + a[k] * b[k]; nx2 = nx2 + a[k] * a[k]; ny2 = ny2 + b[k] * b[k]
        k = k + 1
    }
    let mut cosine = 0.0; let cd = sqrt_f(nx2) * sqrt_f(ny2)
    if cd > 0.000000000001 { cosine = dot_xy / cd }
    return [ks, pearson, l2, cosine]
}

// ─── env / paths ───
let _HOME = env("HOME")
let BASE = _HOME + "/core/nexus/bisociation/cross"
let SPEC_DIR = _HOME + "/core/nexus/bisociation/spectra"
let HEXA = _HOME + "/core/nexus/bin/hexa"
let UF   = SPEC_DIR + "/unfold.hexa"
let PC   = SPEC_DIR + "/pair_corr.hexa"
let WG   = SPEC_DIR + "/wigner_fit.hexa"

let CONST_SPEC = BASE + "/constants_spectrum.jsonl"
let PHYS17_SPEC  = BASE + "/physics17_spectrum.jsonl"
let A_UNF = "/tmp/.bs_cxp17_const_unf.jsonl"
let A_PC  = "/tmp/.bs_cxp17_const_pc.jsonl"
let A_WG  = "/tmp/.bs_cxp17_const_wg.json"
let B_UNF = "/tmp/.bs_cxp17_phys_unf.jsonl"
let B_PC  = "/tmp/.bs_cxp17_phys_pc.jsonl"
let B_WG  = "/tmp/.bs_cxp17_phys_wg.json"
let VERDICT = BASE + "/constants_x_physics_codata17_verdict.json"

println("=== constants_x_physics_codata17 — L3_cross priority_target ===")
println("  hypothesis: 17 CODATA independent fundamentals → noise removal → Pearson up → composite > 0.9")
println("  A-axis: " + CONST_SPEC + " (n6_constants log-spectrum 46)")
println("  B-axis: " + PHYS17_SPEC + " (CODATA 17 independent fundamentals)")

// ─── CODATA 2022 SI 17 independent constants ───
// EXACT (2019 SI redefinition): c, h, e, k_B, N_A
// MEASURED independent: G, alpha, R_inf, m_e, m_p, m_n, mu_0, eps_0, sigma, b, b', g_e
// Note: b' is Wien frequency displacement (≠ b wavelength). g_e is electron g-factor.
// hbar=h/2π, a_0=α/4π·R_inf, E_h, F=N_Ae, R_K=h/e², K_J=2e/h, compton λ=h/mc, r_e, μ_B, μ_N, Planck units 모두 제외

comptime const LN10 = 2.302585092994046

let mut phys_m: list = []
let mut phys_e: list = []
let mut phys_names: list = []

// === 5 SI EXACT (2019 redefinition, zero CODATA uncertainty) ===
phys_m.push(2.99792458);     phys_e.push(8.0);        phys_names.push("c_speed_of_light")            // m/s EXACT
phys_m.push(6.62607015);     phys_e.push(0.0 - 34.0); phys_names.push("h_planck")                    // J·s EXACT
phys_m.push(1.602176634);    phys_e.push(0.0 - 19.0); phys_names.push("e_elementary_charge")         // C EXACT
phys_m.push(1.380649);       phys_e.push(0.0 - 23.0); phys_names.push("k_B_boltzmann")               // J/K EXACT
phys_m.push(6.02214076);     phys_e.push(23.0);       phys_names.push("N_A_avogadro")                // 1/mol EXACT
// === 12 MEASURED INDEPENDENT ===
phys_m.push(6.67430);        phys_e.push(0.0 - 11.0); phys_names.push("G_grav_const")                // m³/kg/s²
phys_m.push(7.2973525693);   phys_e.push(0.0 - 3.0);  phys_names.push("alpha_fine_structure")        // dimensionless
phys_m.push(1.097373156816); phys_e.push(7.0);        phys_names.push("R_inf_rydberg")               // 1/m
phys_m.push(9.1093837015);   phys_e.push(0.0 - 31.0); phys_names.push("m_e_electron_mass")           // kg
phys_m.push(1.67262192369);  phys_e.push(0.0 - 27.0); phys_names.push("m_p_proton_mass")             // kg
phys_m.push(1.67492749804);  phys_e.push(0.0 - 27.0); phys_names.push("m_n_neutron_mass")            // kg
phys_m = phys_m.push(1.25663706212);  phys_e.push(0.0 - 6.0);  phys_names.push("mu_0_vac_permeability")       // N/A² (post-2019 measured)
phys_m = phys_m.push(8.8541878128);   phys_e.push(0.0 - 12.0); phys_names.push("epsilon_0_vac_permittivity")  // F/m (post-2019 measured)
phys_m.push(5.670374419);    phys_e.push(0.0 - 8.0);  phys_names.push("sigma_stefan_boltzmann")      // W/m²/K⁴
phys_m.push(2.897771955);    phys_e.push(0.0 - 3.0);  phys_names.push("b_wien_displacement_lambda")  // m·K
phys_m.push(5.878925757);    phys_e.push(10.0);       phys_names.push("b_prime_wien_displacement_nu")// Hz/K
phys_m = phys_m.push(2.00231930436256); phys_e.push(0.0);      phys_names.push("g_e_electron_g_factor")       // dimensionless (no e exponent)
println("  CODATA-17 independent fundamentals loaded: " + to_string(phys_m.len()))
if phys_m.len() != 17 { println("FAIL: must be exactly 17, got " + to_string(phys_m.len())); exit(1) } // @allow-silent-exit

// compute log values
let mut all_logs: list = []
let mut p: i64 = 0
while p < phys_m.len() {
    all_logs = all_logs.push(ln_f(phys_m[p]) + phys_e[p] * LN10)
    p = p + 1
}

// dedup by log value (eps 1e-5) — should not trigger for 17 distinct physicals
let mut uniq_log: list = []
let mut uniq_n: list = []
let mut i: i64 = 0
while i < all_logs.len() {
    let v = all_logs[i]
    let mut dup = false
    let mut j: i64 = 0
    while j < uniq_log.len() {
        if abs_f(v - uniq_log[j]) < 0.00001 { dup = true; break }
        j = j + 1
    }
    if !dup { uniq_log.push(v); uniq_n.push(phys_names[i]) }
    i = i + 1
}
println("  unique after dedup: " + to_string(uniq_log.len()))
if uniq_log.len() < 8 { println("FAIL: need >=8 unique"); exit(1) } // @allow-silent-exit

// selection sort ascending
let mut sorted: list = []
let mut sorted_names: list = []
let mut taken: list = []
let mut t: i64 = 0
while t < uniq_log.len() { taken.push(false); t = t + 1 }
let mut pass: i64 = 0
while pass < uniq_log.len() {
    let mut bi: i64 = 0 - 1
    let mut bv: f64 = 0.0
    let mut k: i64 = 0
    while k < uniq_log.len() {
        if !taken[k] {
            if bi < 0 || uniq_log[k] < bv { bi = k; bv = uniq_log[k] }
        }
        k = k + 1
    }
    if bi < 0 { break }
    sorted = sorted.push(bv)
    sorted_names = sorted_names.push(uniq_n[bi])
    let mut nt: list = []
    let mut z: i64 = 0
    while z < taken.len() {
        if z == bi { nt.push(true) } else { nt.push(taken[z]) }
        z = z + 1
    }
    taken = nt
    pass = pass + 1
}

// write physics17_spectrum.jsonl
let mut buf = ""
let mut w: i64 = 0
while w < sorted.len() {
    buf = buf + "{\"idx\":" + to_string(w) + ",\"lambda\":" + to_string(sorted[w])
        + ",\"name\":\"" + sorted_names[w] + "\"}\n"
    w = w + 1
}
try { write_file(PHYS17_SPEC, buf) } catch e { println("ERR write physics17_spectrum"); exit(1) } // @allow-silent-exit
println("  wrote " + PHYS17_SPEC + " (" + to_string(sorted.len()) + " sorted log-values)")

// ─── PIPELINE ───
println("  [A constants] unfold/pc/wigner...")
try { exec(HEXA + " run " + UF + " '" + CONST_SPEC + "' '" + A_UNF + "' 2>&1") } catch e { println("ERR A unfold"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + PC + " '" + A_UNF + "' '" + A_PC + "' 2>&1") } catch e { println("ERR A pair_corr"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + WG + " '" + A_PC + "' '" + A_WG + "' 2>&1") } catch e { println("ERR A wigner_fit"); exit(1) } // @allow-silent-exit

println("  [B physics17] unfold/pc/wigner...")
try { exec(HEXA + " run " + UF + " '" + PHYS17_SPEC + "' '" + B_UNF + "' 2>&1") } catch e { println("ERR B unfold"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + PC + " '" + B_UNF + "' '" + B_PC + "' 2>&1") } catch e { println("ERR B pair_corr"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + WG + " '" + B_PC + "' '" + B_WG + "' 2>&1") } catch e { println("ERR B wigner_fit"); exit(1) } // @allow-silent-exit

// ─── cross metrics (before alignment) ───
let r2_a = load_r2_norm(A_PC)
let r2_b = load_r2_norm(B_PC)
let nb = r2_a.len()
if r2_b.len() != nb { println("FAIL: bin mismatch A=" + to_string(nb) + " B=" + to_string(r2_b.len())); exit(1) } // @allow-silent-exit
println("  R2 bins: " + to_string(nb))

let bef = cross_metrics(r2_a, r2_b)
let ks0 = bef[0]; let p0 = bef[1]; let l20 = bef[2]; let cos0 = bef[3]

// ─── bin-alignment (max cross-correlation) ───
let bl = best_lag_fn(r2_a, r2_b, 15)
let best_L: i64 = to_int(bl[0])
let best_po = bl[1]
let overlap: i64 = to_int(bl[2])
println("  best_lag=" + to_string(best_L) + " pearson_overlap=" + to_string(best_po) + " overlap=" + to_string(overlap))

let aligned_b = apply_lag_fn(r2_b, best_L)
let aft = cross_metrics(r2_a, aligned_b)
let ks1 = aft[0]; let p1 = aft[1]; let l21 = aft[2]; let cos1 = aft[3]

let av = read_verdict(A_WG); let bv = read_verdict(B_WG)
let a_verdict = av[0]; let a_score = safe_float(av[1])
let b_verdict = bv[0]; let b_score = safe_float(bv[1])

let agreement = 1.0 - abs_f(a_score - b_score)
let corr_pos_0 = (p0 + 1.0) / 2.0
let comp_0 = (agreement + corr_pos_0 + cos0) / 3.0
let corr_pos_1 = (p1 + 1.0) / 2.0
let comp_1 = (agreement + corr_pos_1 + cos1) / 3.0

// B peak
let mut bmax_i: i64 = 0
let mut bmax_v: f64 = 0.0
let mut bk: i64 = 0
while bk < nb {
    if r2_b[bk] > bmax_v { bmax_v = r2_b[bk]; bmax_i = bk }
    bk = bk + 1
}
let bmax_center = (to_float(bmax_i) + 0.5) * 0.1

let mut judgment = "mixed"
let mut md_cand = "false"
if ks1 < 0.20 && p1 > 0.5 && agreement > 0.7 { judgment = "congruent"; md_cand = "true" }
else if ks1 > 0.6 || p1 < 0.0 || agreement < 0.3 { judgment = "divergent" }

let mut paper_trigger = "false"
if comp_1 > 0.9 { paper_trigger = "true" }

// Previous baseline for delta
let prev_aligned = 0.785945
let delta_vs_prev = comp_1 - prev_aligned
let gap_09 = 0.9 - comp_1

let out = "{\n"
    + "  \"pair\":\"constants_x_physics_codata17\",\n"
    + "  \"method\":\"cross_correlation_lag_codata17_independent\",\n"
    + "  \"hypothesis\":\"17 CODATA independent fundamentals remove derived-noise, boost Pearson > 0.9 composite\",\n"
    + "  \"n_physics\":17,\"n_unique\":" + to_string(uniq_log.len()) + ",\n"
    + "  \"lag_max\":15,\"best_lag\":" + to_string(best_L) + ",\"overlap\":" + to_string(overlap) + ",\n"
    + "  \"constants\": {\"source\":\"n6_constants_log_full\",\"n_bins\":" + to_string(nb)
    + ",\"verdict\":\"" + a_verdict + "\",\"score\":" + to_string(a_score) + "},\n"
    + "  \"physics\": {\"source\":\"CODATA_17_independent_fundamentals\",\"verdict\":\"" + b_verdict
    + "\",\"score\":" + to_string(b_score) + ",\"peak_r\":" + to_string(bmax_center)
    + ",\"peak_R2\":" + to_string(bmax_v) + "},\n"
    + "  \"before\": {\"ks\":" + to_string(ks0) + ",\"pearson\":" + to_string(p0)
    + ",\"l2\":" + to_string(l20) + ",\"cosine\":" + to_string(cos0)
    + ",\"agreement\":" + to_string(agreement)
    + ",\"composite\":" + to_string(comp_0) + "},\n"
    + "  \"after\":  {\"ks\":" + to_string(ks1) + ",\"pearson\":" + to_string(p1)
    + ",\"l2\":" + to_string(l21) + ",\"cosine\":" + to_string(cos1)
    + ",\"agreement\":" + to_string(agreement)
    + ",\"composite\":" + to_string(comp_1) + "},\n"
    + "  \"pearson_overlap_max\":" + to_string(best_po) + ",\n"
    + "  \"agreement\":" + to_string(agreement) + ",\n"
    + "  \"composite_aligned\":" + to_string(comp_1) + ",\n"
    + "  \"score\":" + to_string(comp_1) + ",\n"
    + "  \"baseline_cxp36_aligned\":" + to_string(prev_aligned) + ",\n"
    + "  \"delta_vs_36\":" + to_string(delta_vs_prev) + ",\n"
    + "  \"gap_to_0_9\":" + to_string(gap_09) + ",\n"
    + "  \"verdict\":\"" + judgment + "\",\n"
    + "  \"montgomery_dyson_candidate\":" + md_cand + ",\n"
    + "  \"paper_trigger\":" + paper_trigger + ",\n"
    + "  \"rationale\":\"L3_cross priority_target — CODATA 17 independent (no derived hbar/a_0/E_h/F/R_K/K_J/compton/r_e/mu_B/mu_N/Planck units) vs n6 math constants; hypothesis = derived noise removal boosts Pearson > 0.5, composite > 0.9 paper_trigger\",\n"
    + "  \"ts\":\"2026-04-14\"\n}\n"
try { write_file(VERDICT, out) } catch e { println("ERR write verdict"); exit(1) } // @allow-silent-exit

println("")
println("┌─ constants_x_physics_codata17 verdict ─────")
println("│ A constants: v=" + a_verdict + " s=" + to_string(a_score) + " (n=46)")
println("│ B physics17: v=" + b_verdict + " s=" + to_string(b_score) + " (n=17)")
println("│ before: ks=" + to_string(ks0) + " ρ=" + to_string(p0) + " cos=" + to_string(cos0) + " comp=" + to_string(comp_0))
println("│ after : ks=" + to_string(ks1) + " ρ=" + to_string(p1) + " cos=" + to_string(cos1) + " comp=" + to_string(comp_1))
println("│ best_lag=" + to_string(best_L) + " overlap_ρ_max=" + to_string(best_po))
println("│ baseline cxp36_aligned=" + to_string(prev_aligned) + " Δ=" + to_string(delta_vs_prev))
println("│ gap_to_0.9=" + to_string(gap_09))
println("│ judgment=" + judgment + " MD-cand=" + md_cand + " paper_trigger=" + paper_trigger)
println("│ B peak: bin=" + to_string(bmax_i) + " r=" + to_string(bmax_center) + " R2=" + to_string(bmax_v))
println("└────────────────────────────────────────────")

// ─── breakthroughs.jsonl + paper_trigger.json + state.json + convergence ───
let bt = _HOME + "/core/nexus/bisociation/breakthroughs.jsonl"
if comp_1 > 0.9 {
    let line = "{\"id\":\"BT-BIS-013\",\"ts\":\"2026-04-14\",\"kind\":\"paper_trigger_codata17\",\"pair\":\"constants_x_physics_codata17\""
        + ",\"judgment\":\"" + judgment + "\",\"composite_aligned\":" + to_string(comp_1)
        + ",\"best_lag\":" + to_string(best_L)
        + ",\"ks\":" + to_string(ks1) + ",\"pearson\":" + to_string(p1)
        + ",\"cosine\":" + to_string(cos1) + ",\"agreement\":" + to_string(agreement)
        + ",\"overlap_pearson\":" + to_string(best_po)
        + ",\"delta_vs_cxp36\":" + to_string(delta_vs_prev)
        + ",\"note\":\"CODATA 17 independent fundamentals — derived-noise removed, paper_trigger>0.9 Montgomery-Dyson PAPER TRIGGER\"}\n"
    let mut prev = ""
    try { prev = read_file(bt) } catch e {} // @allow-silent-catch
    try { write_file(bt, prev + line); println("  → breakthroughs.jsonl BT-BIS-013 paper_trigger appended") }
    catch e { println("  WARN: bt append failed") }

    // paper_trigger.json
    let pt_path = _HOME + "/core/nexus/bisociation/paper_trigger.json"
    let pt = "{\n"
        + "  \"fired\":true,\"ts\":\"2026-04-14\",\"pair\":\"constants_x_physics_codata17\",\n"
        + "  \"composite\":" + to_string(comp_1) + ",\n"
        + "  \"threshold\":0.9,\"method\":\"Montgomery-Dyson cross-domain bisociation on CODATA-17 independent fundamentals\",\n"
        + "  \"metrics\":{\"ks\":" + to_string(ks1) + ",\"pearson\":" + to_string(p1) + ",\"cosine\":" + to_string(cos1) + ",\"agreement\":" + to_string(agreement) + "},\n"
        + "  \"a_axis\":{\"name\":\"n6_math_constants\",\"n\":46,\"verdict\":\"" + a_verdict + "\",\"score\":" + to_string(a_score) + "},\n"
        + "  \"b_axis\":{\"name\":\"CODATA-17_independent\",\"n\":17,\"verdict\":\"" + b_verdict + "\",\"score\":" + to_string(b_score) + "},\n"
        + "  \"independence_basis\":[\"c\",\"h\",\"e\",\"k_B\",\"N_A (SI exact)\",\"G\",\"alpha\",\"R_inf\",\"m_e\",\"m_p\",\"m_n\",\"mu_0\",\"eps_0\",\"sigma\",\"b\",\"b_prime\",\"g_e (measured independent)\"],\n"
        + "  \"delta_from_baseline_36\":" + to_string(delta_vs_prev) + ",\n"
        + "  \"claim\":\"Physical law log-spectrum (CODATA 17) shares Wigner-unfolded pair-correlation shape with n6 math constants log-spectrum (N=46) — Montgomery-Dyson style cross-domain congruence\"\n}\n"
    try { write_file(pt_path, pt); println("  → paper_trigger.json fired") }
    catch e { println("  WARN: paper_trigger write failed") }
} else if comp_1 > 0.7 {
    let line = "{\"id\":\"BT-BIS-013\",\"ts\":\"2026-04-14\",\"kind\":\"cross_bisociation_codata17_aligned\",\"pair\":\"constants_x_physics_codata17\""
        + ",\"judgment\":\"" + judgment + "\",\"composite_aligned\":" + to_string(comp_1)
        + ",\"best_lag\":" + to_string(best_L)
        + ",\"ks\":" + to_string(ks1) + ",\"pearson\":" + to_string(p1)
        + ",\"cosine\":" + to_string(cos1) + ",\"agreement\":" + to_string(agreement)
