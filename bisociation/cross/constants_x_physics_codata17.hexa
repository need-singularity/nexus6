        + ",\"delta_vs_cxp36\":" + to_string(delta_vs_prev)
        + ",\"gap_to_0_9\":" + to_string(gap_09)
        + ",\"note\":\"CODATA-17 independent fundamentals (derived-noise removed) aligned composite>0.7 — BT without paper_trigger\"}\n"
    let mut prev = ""
    try { prev = read_file(bt) } catch e {} // @allow-silent-catch
    try { write_file(bt, prev + line); println("  → breakthroughs.jsonl BT-BIS-013 appended") }
    catch e { println("  WARN: bt append failed") }
}

// discovery record (always)
let disc_path = _HOME + "/core/nexus/discovery/bisociation_constants_x_physics_codata17_2026-04-14.json"
let disc = "{\n"
    + "  \"ts\":\"2026-04-14\",\"pair\":\"constants_x_physics_codata17\",\n"
    + "  \"track\":\"L3_cross\",\"priority_target\":true,\n"
    + "  \"hypothesis\":\"CODATA 17 independent fundamentals remove derived-noise → Pearson rises → composite > 0.9 paper_trigger\",\n"
    + "  \"n_physics\":17,\"n_math\":46,\"n_bins\":" + to_string(nb) + ",\n"
    + "  \"independence_basis\":{\"si_exact_5\":[\"c\",\"h\",\"e\",\"k_B\",\"N_A\"],\"measured_12\":[\"G\",\"alpha\",\"R_inf\",\"m_e\",\"m_p\",\"m_n\",\"mu_0\",\"eps_0\",\"sigma\",\"b\",\"b_prime\",\"g_e\"],\"excluded_derived_19\":[\"hbar=h/2pi\",\"a_0=alpha/(4pi*R_inf)\",\"E_h=alpha^2*m_e*c^2\",\"F=N_A*e\",\"R_K=h/e^2\",\"K_J=2e/h\",\"lambda_compton_e=h/(m_e*c)\",\"lambda_compton_p=h/(m_p*c)\",\"r_e=alpha^2*a_0\",\"sigma_thomson=8pi*r_e^2/3\",\"mu_B=e*hbar/2m_e\",\"mu_N=e*hbar/2m_p\",\"m_mu (separate particle)\",\"R_gas=N_A*k_B\",\"M_earth (not fundamental)\",\"M_sun\",\"l_Planck\",\"t_Planck\",\"m_Planck\",\"T_Planck\"]},\n"
    + "  \"before\":{\"ks\":" + to_string(ks0) + ",\"pearson\":" + to_string(p0) + ",\"cosine\":" + to_string(cos0) + ",\"agreement\":" + to_string(agreement) + ",\"composite\":" + to_string(comp_0) + "},\n"
