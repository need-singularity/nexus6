// constants_x_particles.hexa — Cross-domain bisociation L3_ext (Montgomery-Dyson pair 5호)
// 가설: n6_constants log-spectrum × Standard Model particle mass log-spectrum
//       같은 Wigner 통계 → "입자 질량 위계 = 수학 대칭 투영" → paper_trigger
// A-axis: n6_constants full log-spectrum (constants_spectrum.jsonl 재활용)
// B-axis: SM particle masses in eV/c² log-spectrum (leptons, quarks, bosons, neutrinos limits)
// 출력: particles_spectrum.jsonl, constants_x_particles_verdict.json
// 패턴: constants_x_physics.hexa 와 쌍둥이

fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x }; return x }

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 40 {
        let nx = (g + x / g) / 2.0
        if abs_f(nx - g) < g * 0.0000000000001 { return nx }
        g = nx; i = i + 1
    }
    return g
}

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {} // @allow-silent-catch
    return v
}

fn ln_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 - 1000000.0 }
    let mut y = x
    let mut k = 0.0
    while y >= 2.0 { y = y / 2.0; k = k + 1.0 }
    while y < 1.0 { y = y * 2.0; k = k - 1.0 }
    let u = (y - 1.0) / (y + 1.0)
    let u2 = u * u
    let u3 = u2 * u
    let u5 = u3 * u2
    let u7 = u5 * u2
    let u9 = u7 * u2
    let lnm = 2.0 * (u + u3 / 3.0 + u5 / 5.0 + u7 / 7.0 + u9 / 9.0)
    return k * 0.6931471805599453 + lnm
}

fn _min_cut(s: string, from: i64) -> i64 {
    let cands = [",", "}", " ", "\t", "\r", "]"]
    let mut best: i64 = 0 - 1
    let mut i: i64 = 0
    while i < cands.len() {
        let p = s.substring(from, s.len()).index_of(cands[i])
        if p >= 0 {
            let abs_p = from + p
            if best < 0 || abs_p < best { best = abs_p }
        }
        i = i + 1
    }
    return best
}

fn json_get_num(line: string, key: string) -> f64 {
    let pat = "\"" + key + "\""
    let kp = line.index_of(pat)
    if kp < 0 { return 0.0 }
    let after_key = kp + pat.len()
    let colon_rel = line.substring(after_key, line.len()).index_of(":")
    if colon_rel < 0 { return 0.0 }
    let mut num_start = after_key + colon_rel + 1
    while num_start < line.len() {
        let ch = line.substring(num_start, num_start + 1)
        if ch == " " || ch == "\t" { num_start = num_start + 1 } else { break }
    }
    let cut = _min_cut(line, num_start)
    let mut end = line.len()
    if cut >= 0 { end = cut }
    return safe_float(line.substring(num_start, end).trim())
}

fn load_r2_norm(path: string) -> list {
    let mut out: list = []
    let mut raw = ""
    try { raw = read_file(path) } catch e { return out } // @allow-silent-catch
    for line in raw.split("\n") {
        let l = line.trim()
        if l.len() == 0 { continue }
        if l.contains("\"R2\"") == false { continue }
        out = out.push(json_get_num(l, "R2"))
    }
    let mut sum = 0.0
    let mut i: i64 = 0
    while i < out.len() { sum = sum + out[i]; i = i + 1 }
    if sum <= 0.000000001 { return out }
    let m = sum / to_float(out.len())
    let mut nrm: list = []
    i = 0
    while i < out.len() { nrm.push(out[i] / m); i = i + 1 }
    return nrm
}

fn read_verdict(path: string) -> list {
    let mut raw = ""
    try { raw = read_file(path) } catch e { return ["mixed", "0.5"] } // @allow-silent-catch
    let v_pos = raw.index_of("\"verdict\":\"")
    let s_pos = raw.index_of("\"score\":")
    let mut verdict = "mixed"
    let mut score: f64 = 0.5
    if v_pos >= 0 {
        let tail = raw.substring(v_pos + 11, raw.len())
        let qend = tail.index_of("\"")
        if qend >= 0 { verdict = tail.substring(0, qend) }
    }
    if s_pos >= 0 {
        let tail = raw.substring(s_pos + 8, raw.len())
        let cut  = _min_cut(tail, 0)
        let mut end = tail.len()
        if cut >= 0 { end = cut }
        score = safe_float(tail.substring(0, end).trim())
    }
    return [verdict, to_string(score)]
}

// ─── env / paths ───
let _HOME = env("HOME")
let BASE = _HOME + "/core/nexus/bisociation/cross"
let SPEC_DIR = _HOME + "/core/nexus/bisociation/spectra"
let HEXA = _HOME + "/core/nexus/bin/hexa"
let UF   = SPEC_DIR + "/unfold.hexa"
let PC   = SPEC_DIR + "/pair_corr.hexa"
let WG   = SPEC_DIR + "/wigner_fit.hexa"

let CONST_SPEC = BASE + "/constants_spectrum.jsonl"
let PART_SPEC  = BASE + "/particles_spectrum.jsonl"
let A_PC = "/tmp/.bs_cxr_const_pc.jsonl"
let A_UNF = "/tmp/.bs_cxr_const_unf.jsonl"
let A_WG  = "/tmp/.bs_cxr_const_wg.json"
let B_UNF = "/tmp/.bs_cxr_part_unf.jsonl"
let B_PC  = "/tmp/.bs_cxr_part_pc.jsonl"
let B_WG  = "/tmp/.bs_cxr_part_wg.json"
let VERDICT = BASE + "/constants_x_particles_verdict.json"

println("=== constants_x_particles — L3_ext particle mass bisociation ===")
println("  A-axis: " + CONST_SPEC + " (n6_constants log-spectrum 46)")
println("  B-axis: " + PART_SPEC + " (SM particle masses in eV/c²)")

// ─── BUILD PARTICLE MASS SPECTRUM (B-axis) — PDG 2022 + CODATA ───
// source: Particle Data Group 2022 + neutrino limits (PDG oscillation + cosmological)
// 표기: (mantissa, exponent) pair — hexa-stage1 `NeX` parse fail 우회
// 모든 값 eV/c² (질량-에너지 통일 단위). massless(γ,g) skip.

comptime const LN10P = 2.302585092994046

let mut part_m: list = []
let mut part_e: list = []
let mut part_names: list = []

// charged leptons (eV/c²)
part_m.push(5.1099895);     part_e.push(5.0);         part_names.push("electron_mass")      // 0.511 MeV
part_m = part_m.push(1.056583745);   part_e.push(8.0);         part_names.push("muon_mass")
part_m = part_m.push(1.77686);       part_e.push(9.0);         part_names.push("tau_mass")
// neutrino anchors
part_m.push(1.0);           part_e.push(0.0 - 1.0);   part_names.push("nu_1_lightest_ub")   // 0.1 eV
part_m.push(1.0);           part_e.push(0.0 - 2.0);   part_names.push("sqrt_Delta_m21_sq")  // 0.01 eV
part_m.push(5.0);           part_e.push(0.0 - 2.0);   part_names.push("sqrt_Delta_m31_sq")  // 0.05 eV

// quarks
part_m = part_m.push(2.16);          part_e.push(6.0);         part_names.push("up_quark_mass")
part_m = part_m.push(4.67);          part_e.push(6.0);         part_names.push("down_quark_mass")
part_m = part_m.push(9.34);          part_e.push(7.0);         part_names.push("strange_quark_mass")
part_m = part_m.push(1.27);          part_e.push(9.0);         part_names.push("charm_quark_mass")
part_m = part_m.push(4.18);          part_e.push(9.0);         part_names.push("bottom_quark_mass")
part_m = part_m.push(1.7276);        part_e.push(11.0);        part_names.push("top_quark_mass")
// gauge bosons
part_m = part_m.push(8.0377);        part_e.push(10.0);        part_names.push("W_boson_mass")
part_m = part_m.push(9.11876);       part_e.push(10.0);        part_names.push("Z_boson_mass")
part_m = part_m.push(1.2525);        part_e.push(11.0);        part_names.push("Higgs_boson_mass")
// composite baryons
part_m = part_m.push(9.3827209);     part_e.push(8.0);         part_names.push("proton_mass")
part_m = part_m.push(9.39565421);    part_e.push(8.0);         part_names.push("neutron_mass")
part_m = part_m.push(1.3957039);     part_e.push(8.0);         part_names.push("pion_charged_mass")
part_m = part_m.push(1.3497684);     part_e.push(8.0);         part_names.push("pion_neutral_mass")
part_m = part_m.push(4.93677);       part_e.push(8.0);         part_names.push("kaon_charged_mass")
part_m = part_m.push(4.97611);       part_e.push(8.0);         part_names.push("kaon_neutral_mass")
part_m = part_m.push(1.115683);      part_e.push(9.0);         part_names.push("lambda_baryon_mass")
// heavier mesons
part_m = part_m.push(3.0969);        part_e.push(9.0);         part_names.push("J_psi_mass")
part_m = part_m.push(9.4603);        part_e.push(9.0);         part_names.push("Upsilon_1S_mass")
part_m = part_m.push(1.86966);       part_e.push(9.0);         part_names.push("D_meson_mass")
part_m = part_m.push(5.27965);       part_e.push(9.0);         part_names.push("B_meson_mass")
// QCD/EW/high-scale anchors
part_m = part_m.push(2.17);          part_e.push(8.0);         part_names.push("Lambda_QCD")
part_m = part_m.push(2.46);          part_e.push(11.0);        part_names.push("v_EW_VEV")
part_m.push(1.22);          part_e.push(28.0);        part_names.push("M_Planck_EV")        // 1.22e19 GeV
part_m.push(1.0);           part_e.push(25.0);        part_names.push("M_GUT_scale")        // 10^16 GeV
part_m.push(1.0);           part_e.push(21.0);        part_names.push("M_seesaw_heavy")     // heavy νR proxy

println("  SM particle masses loaded: " + to_string(part_m.len()))

// compute log values directly
let mut all_logs: list = []
let mut pq: i64 = 0
while pq < part_m.len() {
    all_logs = all_logs.push(ln_f(part_m[pq]) + part_e[pq] * LN10P)
    pq = pq + 1
}

// dedup by log value (epsilon 1e-5)
let mut uniq_log: list = []
let mut uniq_n: list = []
let mut i: i64 = 0
while i < all_logs.len() {
    let v = all_logs[i]
    let mut dup = false
    let mut j: i64 = 0
    while j < uniq_log.len() {
        if abs_f(v - uniq_log[j]) < 0.00001 { dup = true; break }
        j = j + 1
    }
    if !dup { uniq_log.push(v); uniq_n.push(part_names[i]) }
    i = i + 1
}
println("  unique particle masses (by log): " + to_string(uniq_log.len()))

if uniq_log.len() < 15 { println("FAIL: need >=15 unique masses, got " + to_string(uniq_log.len())); exit(1) } // @allow-silent-exit

// logs already computed — skip log transform
let mut logs: list = []
let mut q: i64 = 0
while q < uniq_log.len() { logs.push(uniq_log[q]); q = q + 1 }

let mut sorted: list = []
let mut sorted_names: list = []
let mut taken: list = []
let mut t: i64 = 0
while t < logs.len() { taken.push(false); t = t + 1 }
let mut pass: i64 = 0
while pass < logs.len() {
    let mut bi: i64 = 0 - 1
    let mut bv: f64 = 0.0
    let mut k: i64 = 0
    while k < logs.len() {
        if !taken[k] {
            if bi < 0 || logs[k] < bv { bi = k; bv = logs[k] }
        }
        k = k + 1
    }
    if bi < 0 { break }
    sorted = sorted.push(bv)
    sorted_names = sorted_names.push(uniq_n[bi])
    let mut nt: list = []
    let mut z: i64 = 0
    while z < taken.len() {
        if z == bi { nt.push(true) } else { nt.push(taken[z]) }
        z = z + 1
    }
    taken = nt
    pass = pass + 1
}

let mut buf = ""
let mut w: i64 = 0
while w < sorted.len() {
    buf = buf + "{\"idx\":" + to_string(w) + ",\"lambda\":" + to_string(sorted[w])
        + ",\"name\":\"" + sorted_names[w] + "\"}\n"
    w = w + 1
}
try { write_file(PART_SPEC, buf) } catch e { println("ERR write particles_spectrum"); exit(1) } // @allow-silent-exit
println("  wrote " + PART_SPEC + " (" + to_string(sorted.len()) + " sorted log-values)")

// ─── PIPELINE ───
println("  [A constants] unfold/pc/wigner...")
try { exec(HEXA + " run " + UF + " '" + CONST_SPEC + "' '" + A_UNF + "' 2>&1") } catch e { println("ERR A unfold"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + PC + " '" + A_UNF + "' '" + A_PC + "' 2>&1") } catch e { println("ERR A pair_corr"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + WG + " '" + A_PC + "' '" + A_WG + "' 2>&1") } catch e { println("ERR A wigner_fit"); exit(1) } // @allow-silent-exit

println("  [B particles] unfold/pc/wigner...")
try { exec(HEXA + " run " + UF + " '" + PART_SPEC + "' '" + B_UNF + "' 2>&1") } catch e { println("ERR B unfold"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + PC + " '" + B_UNF + "' '" + B_PC + "' 2>&1") } catch e { println("ERR B pair_corr"); exit(1) } // @allow-silent-exit
try { exec(HEXA + " run " + WG + " '" + B_PC + "' '" + B_WG + "' 2>&1") } catch e { println("ERR B wigner_fit"); exit(1) } // @allow-silent-exit

let r2_a = load_r2_norm(A_PC)
let r2_b = load_r2_norm(B_PC)
let nb = r2_a.len()
if r2_b.len() != nb { println("FAIL: bin mismatch A=" + to_string(nb) + " B=" + to_string(r2_b.len())); exit(1) } // @allow-silent-exit
println("  R2 bins: " + to_string(nb))

let mut ks = 0.0
let mut sse = 0.0
let mut sx = 0.0; let mut sy = 0.0
let mut k: i64 = 0
while k < nb {
    let d = r2_a[k] - r2_b[k]
    let ad = abs_f(d)
    if ad > ks { ks = ad }
    sse = sse + d * d
    sx = sx + r2_a[k]; sy = sy + r2_b[k]
    k = k + 1
}
let l2 = sqrt_f(sse / to_float(nb))
let mx = sx / to_float(nb); let my = sy / to_float(nb)
let mut sxy = 0.0; let mut sxx = 0.0; let mut syy = 0.0
k = 0
while k < nb {
    let dx = r2_a[k] - mx; let dy = r2_b[k] - my
    sxy = sxy + dx * dy; sxx = sxx + dx * dx; syy = syy + dy * dy
    k = k + 1
}
let mut pearson = 0.0
let denom = sqrt_f(sxx * syy)
if denom > 0.000000000001 { pearson = sxy / denom }

let mut dot_xy = 0.0; let mut nx2 = 0.0; let mut ny2 = 0.0
k = 0
while k < nb {
    dot_xy = dot_xy + r2_a[k] * r2_b[k]
    nx2 = nx2 + r2_a[k] * r2_a[k]
    ny2 = ny2 + r2_b[k] * r2_b[k]
    k = k + 1
}
let mut cosine = 0.0
let cd = sqrt_f(nx2) * sqrt_f(ny2)
if cd > 0.000000000001 { cosine = dot_xy / cd }

let mut bmax_i: i64 = 0
let mut bmax_v: f64 = 0.0
k = 0
while k < nb {
    if r2_b[k] > bmax_v { bmax_v = r2_b[k]; bmax_i = k }
    k = k + 1
}
let bmax_center = (to_float(bmax_i) + 0.5) * 0.1

let av = read_verdict(A_WG); let bv = read_verdict(B_WG)
let a_verdict = av[0]; let a_score = safe_float(av[1])
let b_verdict = bv[0]; let b_score = safe_float(bv[1])

let agreement = 1.0 - abs_f(a_score - b_score)
let corr_pos = (pearson + 1.0) / 2.0
let composite = (agreement + corr_pos + cosine) / 3.0

let mut judgment = "mixed"
let mut md_cand  = "false"
if ks < 0.20 && pearson > 0.5 && agreement > 0.7 { judgment = "congruent"; md_cand = "true" }
else if ks > 0.6 || pearson < 0.0 || agreement < 0.3 { judgment = "divergent" }

let mut paper_trigger = "false"
if composite > 0.9 { paper_trigger = "true" }

let out = "{\n"
    + "  \"constants\": {\"source\":\"n6_constants_log_full\",\"n_lambdas\":46"
    + ",\"verdict\":\"" + a_verdict + "\",\"score\":" + to_string(a_score) + "},\n"
    + "  \"particles\": {\"source\":\"PDG_2022_SM_masses_eV\",\"n_lambdas\":" + to_string(sorted.len())
    + ",\"verdict\":\"" + b_verdict + "\",\"score\":" + to_string(b_score) + "},\n"
    + "  \"cross\": {\"ks\":" + to_string(ks) + ",\"pearson\":" + to_string(pearson)
    + ",\"l2\":" + to_string(l2) + ",\"cosine\":" + to_string(cosine)
    + ",\"agreement\":" + to_string(agreement) + ",\"composite\":" + to_string(composite)
    + ",\"n_bins\":" + to_string(nb) + "},\n"
    + "  \"particles_peak\": {\"bin_idx\":" + to_string(bmax_i)
    + ",\"r_center\":" + to_string(bmax_center)
    + ",\"R2\":" + to_string(bmax_v) + "},\n"
    + "  \"score\":" + to_string(composite) + ",\n"
    + "  \"verdict\":\"" + judgment + "\",\n"
    + "  \"montgomery_dyson_candidate\":" + md_cand + ",\n"
    + "  \"paper_trigger\":" + paper_trigger + ",\n"
    + "  \"rationale\":\"field-theoretic path — n6 math constants log-spectrum (N=46) vs SM particle masses log-spectrum (leptons/quarks/bosons/neutrino anchors/composites, N≈32); both unfolded + pair_corr + wigner_fit; shared Wigner → mass hierarchy = math symmetry projection\",\n"
    + "  \"ts\":\"2026-04-14\",\"pair\":\"constants_x_particles\"\n}\n"
try { write_file(VERDICT, out) } catch e { println("ERR write verdict"); exit(1) } // @allow-silent-exit

println("")
println("┌─ verdict ──────────────────────────────────")
println("│ A constants : v=" + a_verdict + " s=" + to_string(a_score) + " (n=46)")
println("│ B particles : v=" + b_verdict + " s=" + to_string(b_score) + " (n=" + to_string(sorted.len()) + ")")
println("│ KS=" + to_string(ks) + " ρ=" + to_string(pearson) + " L2=" + to_string(l2))
println("│ cos=" + to_string(cosine) + " agreement=" + to_string(agreement))
println("│ composite_score=" + to_string(composite))
println("│ judgment=" + judgment + " MD-candidate=" + md_cand + " paper_trigger=" + paper_trigger)
println("│ B peak: bin=" + to_string(bmax_i) + " r=" + to_string(bmax_center) + " R2=" + to_string(bmax_v))
println("└────────────────────────────────────────────")

if composite > 0.7 {
    let bt = _HOME + "/core/nexus/bisociation/breakthroughs.jsonl"
    let line = "{\"id\":\"BT-BIS-010\",\"ts\":\"2026-04-14\",\"kind\":\"cross_bisociation_field\",\"pair\":\"constants_x_particles\""
        + ",\"judgment\":\"" + judgment + "\",\"score\":" + to_string(composite)
        + ",\"ks\":" + to_string(ks) + ",\"pearson\":" + to_string(pearson)
        + ",\"cosine\":" + to_string(cosine) + ",\"agreement\":" + to_string(agreement)
        + ",\"const_verdict\":\"" + a_verdict + "\",\"part_verdict\":\"" + b_verdict + "\""
        + ",\"part_peak_r\":" + to_string(bmax_center) + ",\"part_peak_R2\":" + to_string(bmax_v)
        + ",\"paper_trigger\":" + paper_trigger
        + ",\"note\":\"L3_ext particle-mass — SM masses eV log-spectrum vs n6 math constants; mass hierarchy ~ n6 symmetry test\"}\n"
    let mut prev = ""
    try { prev = read_file(bt) } catch e {} // @allow-silent-catch
    try { write_file(bt, prev + line); println("  → breakthroughs.jsonl appended (BT-BIS-010)") }
    catch e { println("  WARN: bt append failed") }
}

exit(0)
