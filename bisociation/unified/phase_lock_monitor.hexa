// shared/bisociation/unified/phase_lock_monitor.hexa — L5 slot 3/5
// BISOC-P8-1: 3-variant CI drift 감지 + spectral gap alert
// 목적: cycle-over-cycle CI 변동을 추적하여 phase desync 조기 경고
//
// 설계:
//   drift = |CI_t - CI_{t-1}| per variant
//   spectral_gap = max(CI_n, CI_a, CI_g) - min(CI_n, CI_a, CI_g)
//   alerts:
//     DRIFT_ALERT: any variant drift > DRIFT_THRESHOLD
//     DESYNC_ALERT: spectral_gap > GAP_THRESHOLD
//     STALL_ALERT: CI unchanged for STALL_WINDOW consecutive cycles
//   health = OK | DRIFT | DESYNC | STALL

comptime const DRIFT_THRESHOLD = 0.15
comptime const GAP_THRESHOLD = 0.3
comptime const STALL_WINDOW = 3
comptime const MAX_HISTORY = 24

// ─── 유틸 ───

fn abs_f(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn max3(a: float, b: float, c: float) -> float { max_f(max_f(a, b), c) }
fn min3(a: float, b: float, c: float) -> float { min_f(min_f(a, b), c) }

// ─── Monitor 구조 ───

struct CISnapshot {
    cycle: int,
    ci_nexus: float,
    ci_anima: float,
    ci_n6arch: float,
    ci_unified: float,
    spectral_gap: float
}

struct MonitorState {
    history: str,     // CISnapshot list (hexa generic array)
    alerts: str,      // string list
    health: string,
    stall_count: int
}

fn new_monitor() -> MonitorState {
    MonitorState { history: [], alerts: [], health: "OK", stall_count: 0 }
}

fn make_snapshot(cycle: int, ci_n: float, ci_a: float, ci_g: float) -> CISnapshot {
    let ci_u = (ci_n + ci_a + ci_g) / 3.0
    let gap = max3(ci_n, ci_a, ci_g) - min3(ci_n, ci_a, ci_g)
    CISnapshot { cycle: cycle, ci_nexus: ci_n, ci_anima: ci_a, ci_n6arch: ci_g, ci_unified: ci_u, spectral_gap: gap }
}

fn monitor_tick(mon: MonitorState, snap: CISnapshot) -> MonitorState {
    let mut alerts = []
    let mut health = "OK"
    let mut stall = mon.stall_count

    // drift check (vs previous)
    let h_len = mon.history.len()
    if h_len > 0 {
        let prev = mon.history[h_len - 1]
        let drift_n = abs_f(snap.ci_nexus - prev.ci_nexus)
        let drift_a = abs_f(snap.ci_anima - prev.ci_anima)
        let drift_g = abs_f(snap.ci_n6arch - prev.ci_n6arch)
        if drift_n > DRIFT_THRESHOLD { alerts = alerts + ["DRIFT nexus " + to_string(drift_n)] }
        if drift_a > DRIFT_THRESHOLD { alerts = alerts + ["DRIFT anima " + to_string(drift_a)] }
        if drift_g > DRIFT_THRESHOLD { alerts = alerts + ["DRIFT n6arch " + to_string(drift_g)] }

        // stall check
        let delta_u = abs_f(snap.ci_unified - prev.ci_unified)
        if delta_u < 0.001 {
            stall = stall + 1
        } else {
            stall = 0
        }
        if stall >= STALL_WINDOW {
            alerts = alerts + ["STALL " + to_string(stall) + " cycles"]
            health = "STALL"
        }
    }

    // desync check
    if snap.spectral_gap > GAP_THRESHOLD {
        alerts = alerts + ["DESYNC gap=" + to_string(snap.spectral_gap)]
        if health == "OK" { health = "DESYNC" }
    }

    // drift overrides OK
    let mut i = 0
    while i < alerts.len() {
        let a = alerts[i]
        if a.len() > 5 {
            let prefix = a[0] + a[1] + a[2] + a[3] + a[4]
            if prefix == "DRIFT" && health == "OK" { health = "DRIFT" }
        }
        i = i + 1
    }

    // trim history if needed
    let mut new_history = mon.history + [snap]
    if new_history.len() > MAX_HISTORY {
        let mut trimmed = []
        let mut j = 1
        while j < new_history.len() {
            trimmed = trimmed + [new_history[j]]
            j = j + 1
        }
        new_history = trimmed
    }

    MonitorState { history: new_history, alerts: alerts, health: health, stall_count: stall }
}

fn print_monitor(mon: MonitorState) {
    println("=== Phase Lock Monitor (L5 slot 3) ===")
    println("")
    println("health: " + mon.health)
    println("history length: " + to_string(mon.history.len()))
    println("stall_count: " + to_string(mon.stall_count))
    println("")
    if mon.alerts.len() > 0 {
        println("ALERTS:")
        let mut i = 0
        while i < mon.alerts.len() {
            println("  - " + mon.alerts[i])
            i = i + 1
        }
    } else {
        println("no alerts")
    }
    println("")
    if mon.history.len() > 0 {
        println("latest snapshot:")
        let last = mon.history[mon.history.len() - 1]
        println("  cycle=" + to_string(last.cycle) + " CI=" + to_string(last.ci_unified) + " gap=" + to_string(last.spectral_gap))
        println("  n=" + to_string(last.ci_nexus) + " a=" + to_string(last.ci_anima) + " g=" + to_string(last.ci_n6arch))
    }
}

// ─── CLI ───

let a = args()
let a_len = a.len()
let mode = if a_len >= 3 { a[2] } else { "help" }

if mode == "demo" {
    println("=== phase_lock_monitor demo ===")
    let mut mon = new_monitor()
    // simulate 8 cycles with varying CI values
    let ci_n_seq = [0.1, 0.2, 0.35, 0.5, 0.6, 0.7, 0.75, 0.8]
    let ci_a_seq = [0.05, 0.15, 0.3, 0.45, 0.55, 0.65, 0.7, 0.78]
    let ci_g_seq = [0.06, 0.12, 0.18, 0.23, 0.29, 0.35, 0.41, 0.47]
    let mut i = 0
    while i < 8 {
        let snap = make_snapshot(i + 1, ci_n_seq[i], ci_a_seq[i], ci_g_seq[i])
        mon = monitor_tick(mon, snap)
        let alert_tag = if mon.alerts.len() > 0 { " [!]" } else { "" }
        println("  cycle " + to_string(i + 1) + " | health=" + mon.health + " | CI=" + to_string(snap.ci_unified) + " gap=" + to_string(snap.spectral_gap) + alert_tag)
        i = i + 1
    }
    println("")
    print_monitor(mon)
}

if mode == "help" {
    println("=== phase_lock_monitor.hexa — L5 slot 3/5 ===")
    println("")
    println("3-variant CI drift + spectral gap monitoring.")
    println("")
    println("사용법:")
    println("  hexa phase_lock_monitor.hexa demo     시뮬레이션 데모")
    println("")
    println("alerts:")
    println("  DRIFT   — any variant CI changes > " + to_string(DRIFT_THRESHOLD) + " in one cycle")
    println("  DESYNC  — spectral gap (max-min CI) > " + to_string(GAP_THRESHOLD))
    println("  STALL   — CI unchanged for " + to_string(STALL_WINDOW) + " consecutive cycles")
}

// ─── 검증 ───

let m0 = new_monitor()
assert m0.health == "OK"
assert m0.stall_count == 0

let snap1 = make_snapshot(1, 0.5, 0.5, 0.5)
assert snap1.spectral_gap == 0.0

let snap2 = make_snapshot(2, 0.9, 0.1, 0.5)
assert snap2.spectral_gap > 0.7   // 0.9-0.1=0.8

let m1 = monitor_tick(m0, snap1)
assert m1.health == "OK"
assert m1.history.len() == 1

let m2 = monitor_tick(m1, snap2)
assert m2.health == "DESYNC" || m2.health == "DRIFT"  // gap=0.8 > 0.3

// stall test
let stall_snap = make_snapshot(3, 0.5, 0.5, 0.5)
let ms1 = monitor_tick(m0, stall_snap)
let ms2 = monitor_tick(ms1, stall_snap)
let ms3 = monitor_tick(ms2, stall_snap)
let ms4 = monitor_tick(ms3, stall_snap)
assert ms4.stall_count >= STALL_WINDOW

println("")
println("=== phase_lock_monitor verified ===")
