// shared/bisociation/unified/convergence_index_bridge.hexa — L5 slot 2/5
// BISOC-P8-1: EVO-P8-1 convergence index <-> bisociation composite score bridge
// 목적: ouroboros 3-variant CI [0,1] 와 L3 cross-pair composite [0,1] 를 연결하여
//        "진화 수렴"과 "분포 수렴"이 동기 진행되는지 추적
//
// 설계:
//   phase_alignment_score = w_evo * CI_unified + w_bis * composite_best
//   w_evo = 0.4, w_bis = 0.6 (bisociation composite 가 paper_trigger 지표이므로 가중)
//   phase_locked = |CI_unified - composite_best| < PHASE_LOCK_EPSILON
//   phase_gap = |CI_unified - composite_best|

comptime const W_EVO = 0.4
comptime const W_BIS = 0.6
comptime const PHASE_LOCK_EPSILON = 0.15
comptime const PAPER_TRIGGER = 0.9

// ─── 유틸 ───

fn abs_f(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn clamp_01(x: float) -> float {
    if x < 0.0 { return 0.0 }
    if x > 1.0 { return 1.0 }
    return x
}

// ─── Bridge 구조 ───

struct PhaseBridge {
    ci_unified: float,         // EVO-P8-1 convergence index (ouroboros 3-variant mean)
    composite_best: float,     // L3 cross-pair best composite score
    composite_pair: string,    // best pair name
    alignment_score: float,    // weighted blend
    phase_gap: float,          // |ci - composite|
    phase_locked: bool,        // gap < epsilon
    paper_distance: float,     // PAPER_TRIGGER - alignment_score
    status: string             // LOCKED / DRIFTING / DIVERGENT
}

fn compute_bridge(ci_unified: float, composite_best: float, composite_pair: string) -> PhaseBridge {
    let score = W_EVO * ci_unified + W_BIS * composite_best
    let gap = abs_f(ci_unified - composite_best)
    let locked = gap < PHASE_LOCK_EPSILON
    let paper_dist = PAPER_TRIGGER - score
    let status = if locked { "LOCKED" } else if gap < 0.3 { "DRIFTING" } else { "DIVERGENT" }
    PhaseBridge {
        ci_unified: ci_unified,
        composite_best: composite_best,
        composite_pair: composite_pair,
        alignment_score: score,
        phase_gap: gap,
        phase_locked: locked,
        paper_distance: if paper_dist < 0.0 { 0.0 } else { paper_dist },
        status: status
    }
}

fn print_bridge(b: PhaseBridge) {
    println("=== Phase Lock Bridge (L5 slot 2) ===")
    println("")
    println("EVO CI (unified)     : " + to_string(b.ci_unified))
    println("BIS composite (best) : " + to_string(b.composite_best) + " (" + b.composite_pair + ")")
    println("alignment_score      : " + to_string(b.alignment_score) + " (w_evo=" + to_string(W_EVO) + " w_bis=" + to_string(W_BIS) + ")")
    println("phase_gap            : " + to_string(b.phase_gap))
    println("phase_locked         : " + to_string(b.phase_locked) + " (epsilon=" + to_string(PHASE_LOCK_EPSILON) + ")")
    println("paper_distance       : " + to_string(b.paper_distance))
    println("status               : " + b.status)
}

// ─── CLI ───

let a = args()
let a_len = a.len()
let mode = if a_len >= 3 { a[2] } else { "help" }

if mode == "status" {
    // 현재 bisociation best composite 를 하드코딩 (state.json 에서 읽어야 하나 hexa file I/O 제약으로 인라인)
    let best_composite = 0.83379    // atlas_x_laws_aligned (2026-04-14 L3 best)
    let best_pair = "atlas_x_laws_aligned"
    // CI 는 외부에서 전달 — 여기서는 sample
    let sample_ci = 0.65
    let b = compute_bridge(sample_ci, best_composite, best_pair)
    print_bridge(b)
}

if mode == "compute" {
    // hexa convergence_index_bridge.hexa compute <ci_unified> <composite_best> <pair_name>
    if a_len >= 6 {
        let ci = to_float(a[3])
        let comp = to_float(a[4])
        let pair = a[5]
        let b = compute_bridge(ci, comp, pair)
        print_bridge(b)
    } else {
        println("usage: hexa convergence_index_bridge.hexa compute <ci_unified> <composite_best> <pair_name>")
    }
}

if mode == "help" {
    println("=== convergence_index_bridge.hexa — L5 slot 2/5 ===")
    println("")
    println("EVO-P8-1 convergence index (ouroboros 3-variant) 와")
    println("L3 bisociation composite score 를 연결하는 bridge.")
    println("")
    println("사용법:")
    println("  hexa convergence_index_bridge.hexa status                    현재 상태 (샘플)")
    println("  hexa convergence_index_bridge.hexa compute <ci> <comp> <pair> 직접 계산")
    println("")
    println("alignment_score = 0.4 * CI + 0.6 * composite")
    println("phase_locked = |CI - composite| < 0.15")
}

// ─── 검증 ───

let b1 = compute_bridge(0.8, 0.8, "test")
assert b1.phase_locked == true
assert b1.phase_gap == 0.0
assert abs_f(b1.alignment_score - 0.8) < 0.001

let b2 = compute_bridge(0.2, 0.9, "test2")
assert b2.phase_locked == false
assert b2.status == "DIVERGENT"

let b3 = compute_bridge(0.7, 0.8, "test3")
assert b3.phase_locked == true   // gap=0.1 < 0.15
assert b3.status == "LOCKED"

println("")
println("=== convergence_index_bridge verified ===")
