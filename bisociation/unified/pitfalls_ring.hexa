// pitfalls_ring.hexa — L_meta 3프로젝트 hexa pitfalls 수집/배포 링
// 안전: 다른 프로젝트 Write 절대 금지 (L0). dry-run 전용. SSOT: pitfalls_ring_map.json
// 회피: #1 split("") / #3 inline-if / #4 list[i]= / #5 has_key / #6 xs+[v]
//        #7 'verify' 예약 / #8 pure fn struct / #9 args() 변동 / #10 R19

let MAP_PATH = "$HOME/Dev/nexus/shared/bisociation/unified/pitfalls_ring_map.json"

// JSON micro-extractor (#1: split(needle) — 빈 문자열 X)
fn _extract_quoted(line: string, key: string) -> string {
    let needle = "\"" + key + "\""
    if !line.contains(needle) { return "" }
    let parts = line.split(needle)
    if parts.len() < 2 { return "" }
    let after = parts[1].split(":")
    if after.len() < 2 { return "" }
    let v = after[1].trim()
    if v.starts_with("\"") {
        let q = v.split("\"")
        if q.len() >= 2 { return q[1] }
        return ""
    }
    let b = v.split(","); if b.len() < 1 { return "" }
    let b0 = b[0].split("}")
    if b0.len() >= 1 { return b0[0].trim() }
    return ""
}

// map 파서 (parallel lists, #5)
fn _parse_map() -> list {
    let mut names: list = []; let mut paths: list = []
    let mut raw = ""
    try { raw = read_file(MAP_PATH) } catch e { return [names, paths] } // @allow-silent-catch
    let candidates = ["nexus", "anima", "n6arch"]
    let mut k: i64 = 0
    while k < candidates.len() {
        let key = candidates[k]
        let kp = raw.split("\"" + key + "\"")
        if kp.len() >= 2 {
            let block = kp[1]
            let eb = block.index_of("}")
            let mut blk = block
            if eb > 0 { blk = block[0..eb] }
            names = names.push(key); paths.push(_extract_quoted(blk, "path"))
        }
        k = k + 1
    }
    return [names, paths]
}

// jsonl 읽기 (#6: push O(1))
fn _read_jsonl(path: string) -> list {
    let mut out: list = []
    if !file_exists(path) { return out }
    let mut raw = ""
    try { raw = read_file(path) } catch e { return out } // @allow-silent-catch
    let lines = raw.split("\n")
    let mut i: i64 = 0
    while i < lines.len() {
        let s = lines[i].trim()
        if s != "" { if s.starts_with("{") { out.push(s) } }
        i = i + 1
    }
    return out
}

fn _issue(line: string)    -> string { return _extract_quoted(line, "issue") }
fn _severity(line: string) -> string { return _extract_quoted(line, "severity") }

// COLLECT
fn collect(m: list) -> list {
    let names = m[0]; let paths = m[1]
    let mut all: list = []; let mut origs: list = []
    let mut i: i64 = 0
    while i < names.len() {
        let lines = _read_jsonl(paths[i])
        let mut j: i64 = 0
        while j < lines.len() { all.push(lines[j]); origs.push(names[i]); j = j + 1 }
        i = i + 1
    }
    return [all, origs]
}

// DEDUPE
fn dedupe(merged: list) -> list {
    let lines = merged[0]; let origs = merged[1]
    let mut seen: list = []; let mut ol: list = []; let mut oo: list = []
    let mut i: i64 = 0
    while i < lines.len() {
        let key = _issue(lines[i])
        let mut dup = false; let mut k: i64 = 0
        while k < seen.len() { if seen[k] == key { dup = true; k = seen.len() } k = k + 1 }
        if !dup { seen.push(key); ol.push(lines[i]); oo.push(origs[i]) }
        i = i + 1
    }
    return [ol, oo]
}

// STATS (#4: rebuild)
fn stats(deduped: list) -> list {
    let lines = deduped[0]
    let keys: list = ["error", "warn", "perf", "info", "other"]
    let mut vals: list = [0, 0, 0, 0, 0]
    let mut i: i64 = 0
    while i < lines.len() {
        let s = _severity(lines[i]); let mut idx: i64 = 4
        let mut k: i64 = 0
        while k < 4 { if keys[k] == s { idx = k; k = 4 } k = k + 1 }
        let mut nv: list = []; let mut j: i64 = 0
        while j < vals.len() {
            if j == idx { nv.push(vals[j] + 1) } else { nv.push(vals[j]) }
            j = j + 1
        }
        vals = nv; i = i + 1
    }
    return [keys, vals]
}

// PUBLISH-DRY (실제 쓰기 X)
fn publish_dry(entry: string, m: list) -> list {
    let names = m[0]; let paths = m[1]
    let key = _issue(entry)
    let mut targets: list = []; let mut i: i64 = 0
    while i < names.len() {
        let ex = _read_jsonl(paths[i])
        let mut already = false; let mut j: i64 = 0
        while j < ex.len() { if _issue(ex[j]) == key { already = true; j = ex.len() } j = j + 1 }
        if !already { targets.push(names[i] + ":" + paths[i]) }
        i = i + 1
    }
    return targets
}

// DIFF
fn diff(m: list, a: string, b: string) -> list {
    let names = m[0]; let paths = m[1]
    let mut pa = ""; let mut pb = ""; let mut i: i64 = 0
    while i < names.len() {
        if names[i] == a { pa = paths[i] }
        if names[i] == b { pb = paths[i] }
        i = i + 1
    }
    let la = _read_jsonl(pa); let lb = _read_jsonl(pb)
    let mut kb: list = []; let mut k: i64 = 0
    while k < lb.len() { kb.push(_issue(lb[k])); k = k + 1 }
    let mut only: list = []; let mut j: i64 = 0
    while j < la.len() {
        let key = _issue(la[j])
        let mut found = false; let mut m2: i64 = 0
        while m2 < kb.len() { if kb[m2] == key { found = true; m2 = kb.len() } m2 = m2 + 1 }
        if !found { only.push(la[j]) }
        j = j + 1
    }
    return only
}

// argv resolver (#9: PITFALL_ARGV env)
fn _argv() -> list {
    let a = args()
    if a.len() >= 3 { return a }
    let mut env_str = ""
    try { env_str = exec("printenv PITFALL_ARGV").trim() } catch e { env_str = "" } // @allow-silent-catch
    if env_str == "" { return a }
    let parts = env_str.split(" ")
    let mut out: list = ["hexa", "pitfalls_ring.hexa"]
    let mut i: i64 = 0
    while i < parts.len() { let p = parts[i].trim(); if p != "" { out.push(p) } i = i + 1 }
    return out
}

// ─── CLI ───
fn cmd_collect(m: list) {
    let d = dedupe(collect(m))
    let lines = d[0]; let origs = d[1]
    let mut i: i64 = 0
    while i < lines.len() {
        let mut o = ""; if i < origs.len() { o = origs[i] }
        println("{\"origin\":\"" + o + "\",\"raw\":" + lines[i] + "}")
        i = i + 1
    }
}
fn cmd_stats(m: list) {
    let d = dedupe(collect(m)); let s = stats(d)
    let keys = s[0]; let vals = s[1]
    println("# pitfalls_ring stats — total=" + to_string(d[0].len()))
    let mut i: i64 = 0
    while i < keys.len() { println(keys[i] + "=" + to_string(vals[i])); i = i + 1 }
}
fn cmd_diff(m: list, a: string, b: string) {
    let only = diff(m, a, b)
    println("# diff " + a + " - " + b + " (only in " + a + "): " + to_string(only.len()))
    let mut i: i64 = 0
    while i < only.len() { println(only[i]); i = i + 1 }
}
fn cmd_publish_dry(m: list, entry: string) {
    let t = publish_dry(entry, m)
    println("# publish-dry — issue=\"" + _issue(entry) + "\"  targets=" + to_string(t.len()))
    let mut i: i64 = 0
    while i < t.len() { println(t[i]); i = i + 1 }
}
fn cmd_help() {
    println("pitfalls_ring.hexa — L_meta 3프로젝트 hexa pitfalls 배포 링")
    println("usage:")
    println("  hexa pitfalls_ring.hexa collect                       merge + origin tag + dedupe")
    println("  hexa pitfalls_ring.hexa stats                         severity 카운트")
    println("  hexa pitfalls_ring.hexa diff <A> <B>                  A 에만 있는 엔트리")
    println("  hexa pitfalls_ring.hexa publish-dry '<json-entry>'    배포 경로 산출 (쓰기 X)")
    println("registry: " + MAP_PATH)
    println("safety: 다른 프로젝트 Write 절대 금지 (L0). dry-run 전용.")
    println("argv: PITFALL_ARGV env var fallback (args() 변동 회피)")
}

// #7 회피: 'verify' 예약어 사용 X. #3 회피: inline if 대신 let mut + if.
fn main() {
    let a = _argv()
    let mut cmd = "help"
    if a.len() >= 3 { cmd = a[2] }
    let m = _parse_map()
    if cmd == "collect" { cmd_collect(m); return }
    if cmd == "stats" { cmd_stats(m); return }
    if cmd == "diff" {
        let mut pa = "nexus"; let mut pb = "anima"
        if a.len() >= 4 { pa = a[3] }
        if a.len() >= 5 { pb = a[4] }
        cmd_diff(m, pa, pb); return
    }
    if cmd == "publish-dry" {
        let mut entry = ""
        if a.len() >= 4 { entry = a[3] }
        if entry == "" { println("usage: hexa pitfalls_ring.hexa publish-dry '<json-entry>'"); return }
        cmd_publish_dry(m, entry); return
    }
    cmd_help()
}

main()
