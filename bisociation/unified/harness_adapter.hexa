// harness_adapter.hexa — L1_unified Harness Adapter (3프로젝트 단일 인터페이스)
// 목적: nexus/anima/n6arch 의 harness entry 를 단일 추상 vocab 으로 라우팅.
// 토폴로지: anima/.shared & n6arch/.shared → nexus/shared (심링크). 1 entry.hexa = 3 뷰.
// 안전: 다른 프로젝트 entry.hexa Write 금지 (L0). 본 파일은 호출만 (read/exec).
// 예산: 300줄. 회피: #1 split / #5 has_key / #6 push / #7 verify 예약 / #9 args() / pitfalls_ring 패턴 답습.
//
// CLI:
//   harness_adapter.hexa <project> <action> [extra...]
//     project ∈ nexus | anima | n6arch
//     action  ∈ prompt | pretool | post | guard | self_check
//                + 패스스루: health | sync | verify | errors | audit
//   harness_adapter.hexa list                       — 3 프로젝트 entry.hexa 상태
//   harness_adapter.hexa rosetta                    — 매핑표 (action → entry mode)
//   harness_adapter.hexa _verify                    — 모든 라우팅 검증
//   harness_adapter.hexa help

let HEXA = "$HOME/core/nexus/bin/hexa"
let ROSETTA_PATH = "$HOME/core/nexus/bisociation/unified/rosetta_harness.jsonl"

// 3 프로젝트 root → entry.hexa 경로 (parallel lists, #5 has_key 회피)
fn _project_roots() -> list {
    let names: list = ["nexus", "anima", "n6arch"]
    let entries: list = [
        "$HOME/core/nexus/tool/entry.hexa",
        "$HOME/Dev/anima/.shared/tool/entry.hexa",
        "$HOME/core/canon/.shared/tool/entry.hexa"
    ]
    return [names, entries]
}

fn _entry_for(project: string) -> string {
    let r = _project_roots()
    let names = r[0]; let entries = r[1]
    let mut i = 0
    while i < names.len() {
        if names[i] == project { return entries[i] }
        i = i + 1
    }
    return ""
}

// action vocab → entry.hexa mode (단일 추상 → 실제 모드)
fn _action_to_mode(action: string) -> string {
    if action == "prompt"      { return "prompt" }
    if action == "pretool"     { return "pre_tool" }
    if action == "post"        { return "post_bash" }       // post 단독 = bash 후
    if action == "post_edit"   { return "post_edit" }
    if action == "post_bash"   { return "post_bash" }
    if action == "guard"       { return "guard" }
    if action == "self_check"  { return "self_check" }
    // 패스스루 (entry.hexa 그대로 노출)
    if action == "health"      { return "health" }
    if action == "sync"        { return "sync" }
    if action == "verify"      { return "verify" }
    if action == "errors"      { return "errors" }
    if action == "audit"       { return "audit" }
    if action == "gauge"       { return "gauge" }
    if action == "instinct"    { return "instinct" }
    return ""
}

// 동일 inode 검출 — anima/n6arch 가 nexus 와 같은 entry 가리키는지
// 심링크 흡수 상태에서는 모두 동일 entry.hexa. 차후 split 시 변경 예상.
fn _is_pass_through(project: string) -> bool {
    if project == "nexus" { return true }
    let entry = _entry_for(project)
    if entry == "" { return false }
    // readlink 검사 — .shared 가 nexus/shared 로의 심링크면 pass-through
    let parent = "$HOME/Dev/" + (if project == "anima" { "anima" } else { "CANON" }) + "/.shared"
    let ll = to_string(exec("readlink " + parent + " 2>/dev/null")).trim()
    if ll.contains("nexus/shared") { return true }
    return false
}

// 안전 인자 escape (#9 args() / shell 인젝션 회피)
fn _esc(s: string) -> string {
    return s.replace("\"", "\\\"")
}

fn route(project: string, action: string, extras: list) -> int {
    let entry = _entry_for(project)
    if entry == "" {
        eprintln("REJECT: unknown project '" + project + "' (allowed: nexus|anima|n6arch)")
        return 2
    }
    if !file_exists(entry) {
        eprintln("REJECT: entry.hexa not found at " + entry)
        return 2
    }
    let mode = _action_to_mode(action)
    if mode == "" {
        eprintln("REJECT: unknown action '" + action + "' (run rosetta to list)")
        return 2
    }
    let pass = _is_pass_through(project)
    let mut cmd = HEXA + " run " + entry + " " + mode
    let mut i = 0
    while i < extras.len() {
        cmd = cmd + " \"" + _esc(extras[i]) + "\""
        i = i + 1
    }
    // pass-through 흡수 상태에서는 nexus 와 동일 결과 — 마킹만 다름
    eprintln("[adapter] project=" + project + " action=" + action + " mode=" + mode + " pass_through=" + to_string(pass))
    let out = to_string(exec(cmd + " 2>&1"))
    if out.trim().len() > 0 { print(out) }
    return 0
}

fn list_status() {
    let r = _project_roots()
    let names = r[0]; let entries = r[1]
    println("harness adapter — 3 project entry status")
    println("---")
    let mut i = 0
    while i < names.len() {
        let n = names[i]; let e = entries[i]
        let exists = file_exists(e)
        let pass = _is_pass_through(n)
        let mut st = "MISSING"
        if exists { st = "PRESENT" }
        let mut tag = "(direct)"
        if n != "nexus" && pass { tag = "(symlink → nexus)" }
        println("  " + n + "  " + st + "  " + tag)
        println("    " + e)
        i = i + 1
    }
}

fn rosetta() {
    let actions: list = ["prompt", "pretool", "post", "post_edit", "guard",
                         "self_check", "health", "sync", "verify", "errors",
                         "audit", "gauge", "instinct"]
    println("harness adapter — action → entry.hexa mode")
    println("---")
    let mut i = 0
    while i < actions.len() {
        let a = actions[i]; let m = _action_to_mode(a)
        println("  " + a + "  ->  " + m)
        i = i + 1
    }
}

// _verify: 모든 (project, action) 조합 dry-validate (호출 X, 경로/모드만)
fn verify_all() -> int {
    let r = _project_roots()
    let names = r[0]; let entries = r[1]
    let actions: list = ["prompt", "pretool", "post", "guard", "self_check"]
    let mut fails = 0
    let mut total = 0
    println("harness adapter verify")
    let mut i = 0
    while i < names.len() {
        let n = names[i]; let e = entries[i]
        if !file_exists(e) {
            println("  FAIL  " + n + "  entry missing: " + e)
            fails = fails + 1
            i = i + 1
            continue
        }
        let pass = _is_pass_through(n)
        let mut j = 0
        while j < actions.len() {
            let a = actions[j]; let m = _action_to_mode(a)
            total = total + 1
            if m == "" {
                println("  FAIL  " + n + "/" + a + "  no mode mapping")
                fails = fails + 1
            } else {
                let tag = if pass { "pass" } else { "direct" }
                println("  PASS  " + n + "/" + a + " -> " + m + " [" + tag + "]")
            }
            j = j + 1
        }
        i = i + 1
    }
    println("---")
    if fails == 0 { println("verify: ALL PASS  (" + to_string(total) + " routes)"); return 0 }
    println("verify: " + to_string(fails) + " FAIL of " + to_string(total))
    return 1
}

// rosetta JSONL 자동 emit (앞 unified/rosetta_ouroboros.jsonl 형식 답습)
fn emit_rosetta_jsonl() -> int {
    let r = _project_roots()
    let names = r[0]; let entries = r[1]
    let actions: list = ["prompt", "pretool", "post", "post_edit", "guard",
                         "self_check", "health", "sync", "verify", "errors",
                         "audit", "gauge", "instinct"]
    let mut buf = ""
    let mut count = 0
    let mut i = 0
    while i < names.len() {
        let n = names[i]; let e = entries[i]
        let pass = _is_pass_through(n)
        let mut kind = "direct"
        if n != "nexus" && pass { kind = "pass_through" }
        let mut j = 0
        while j < actions.len() {
            let a = actions[j]; let m = _action_to_mode(a)
            // {"variant":"<project>","term":"<action>","abstract":"<mode>","value":"<entry>","kind":"<pass|direct>","src":"adapter"}
            let line = "{\"variant\":\"" + n + "\",\"term\":\"" + a + "\",\"abstract\":\"" + m
                     + "\",\"value\":\"" + e + "\",\"kind\":\"" + kind + "\",\"src\":\"harness_adapter\"}"
            buf = buf + line + "\n"
            count = count + 1
            j = j + 1
        }
        i = i + 1
    }
    try { write_file(ROSETTA_PATH, buf) } catch e { eprintln("emit FAIL: " + to_string(e)); return 1 }
    println("rosetta_harness.jsonl written: " + to_string(count) + " entries -> " + ROSETTA_PATH)
    return 0
}

fn help() {
    println("harness_adapter.hexa — 3 프로젝트 단일 라우터")
    println("  <project> <action> [extra...]   — 라우팅 실행")
    println("    project: nexus|anima|n6arch")
    println("    action:  prompt|pretool|post|post_edit|guard|self_check")
    println("             health|sync|verify|errors|audit|gauge|instinct")
    println("  list                            — 3 프로젝트 entry 상태")
    println("  rosetta                         — action → entry mode 표")
    println("  emit                            — rosetta_harness.jsonl 재생성")
    println("  _verify                         — 모든 라우팅 dry 검증")
    println("  help")
}

fn _argv_safe() -> list {
    let a = args()
    if a.len() > 0 { return a }
    let mut e = ""
    try { e = to_string(exec("printenv HARNESS_ADAPTER_ARGV")).trim() } catch _ {} // @allow-silent-catch
    if e == "" { return [] }
    return e.split(" ")
}

fn main() {
    let a = _argv_safe()
    if a.len() < 3 { help(); return }
    let cmd = a[2]
    if cmd == "help" || cmd == "--help" || cmd == "-h" { help(); return }
    if cmd == "list"     { list_status(); return }
    if cmd == "rosetta"  { rosetta(); return }
    if cmd == "emit"     { let rc = emit_rosetta_jsonl(); return }
    if cmd == "_verify" || cmd == "verify-all" { let rc = verify_all(); return }
    // <project> <action> [extra...]
    if a.len() < 4 {
        eprintln("REJECT: missing action — usage: <project> <action> [extra...]")
        return
    }
    let project = a[2]
    let action = a[3]
    let mut extras: list = []
    let mut i = 4
    while i < a.len() { extras.push(a[i]); i = i + 1 }
    let rc = route(project, action, extras)
}

main()
