// rosetta_protocol.hexa — L_meta Rosetta Protocol (의미 충돌 번역 레이어)
// 3 OUROBOROS 변종(nexus/anima/n6arch) → 단일 추상 어휘. 원본 무수정(L0). 200줄 예산.
// 추상: convergence_kind,target_value,tolerance,floor,progress_metric,decay_window,
//      memory_weight,reset_ratio,max_iterations,branching_factor,divergence_cap,warmup
// CLI: translate <v> <t> | dictionary <v> | _verify | help (verify=reserved)

let DICT_PATH_DEFAULT = "$HOME/core/nexus/bisociation/unified/rosetta_ouroboros.jsonl"

fn _resolve_dict_path() -> string {
    let mut env = ""
    try { env = to_string(exec("printenv ROSETTA_DICT")).trim() } catch e {} // @allow-silent-catch
    if env != "" { return env }
    return DICT_PATH_DEFAULT
}

// JSONL 단일 라인 키 추출. value 가 number/null/string 모두 string 으로 반환.
// pitfall: composite slice expr (a[x+y .. z]) 불안정 → start/end 변수 바인딩 필수.
fn _field(line: string, key: string) -> string {
    let needle = "\"" + key + "\":"
    let k = line.index_of(needle)
    if k < 0 { return "" }
    let nl = needle.len()
    let s0 = k + nl
    let ll = line.len()
    let rest = line[s0..ll].trim()
    if rest.len() == 0 { return "" }
    let head = rest[0..1]
    let rl = rest.len()
    if head == "\"" {
        let inside = rest[1..rl]
        let q = inside.index_of("\"")
        if q < 0 { return "" }
        return inside[0..q]
    }
    // number / null / true / false: comma 또는 } 까지
    let c1 = rest.index_of(",")
    let c2 = rest.index_of("}")
    let mut end = rl
    if c1 >= 0 && c1 < end { end = c1 }
    if c2 >= 0 && c2 < end { end = c2 }
    return rest[0..end].trim()
}

// stage1 has_key 미지원 → 4 parallel lists
fn load_dict() -> list {
    let mut variants: list = []; let mut terms: list = []
    let mut abstracts: list = []; let mut values: list = []
    let path = _resolve_dict_path()
    if !file_exists(path) { return [variants, terms, abstracts, values] }
    let mut raw = ""
    try { raw = read_file(path) } catch e { return [variants, terms, abstracts, values] } // @allow-silent-catch
    for line in raw.split("\n") {
        let s = line.trim()
        if s == "" || !s.starts_with("{") { continue }
        let v = _field(s, "variant"); let t = _field(s, "term")
        let a = _field(s, "abstract"); let val = _field(s, "value")
        if v != "" && t != "" && a != "" {
            variants = variants + [v]; terms = terms + [t]
            abstracts = abstracts + [a]; values = values + [val]
        }
    }
    return [variants, terms, abstracts, values]
}

// translate(variant, term) -> "abstract=<key> value=<val>" or "MISS"
fn translate(variant: string, term: string) -> string {
    let d = load_dict()
    let vs = d[0]; let ts = d[1]; let abs_l = d[2]; let vals = d[3]
    let mut i = 0
    while i < vs.len() {
        if vs[i] == variant {
            if ts[i] == term {
                return "abstract=" + to_string(abs_l[i]) + " value=" + to_string(vals[i])
            }
        }
        i = i + 1
    }
    return "MISS"
}

// dictionary(variant) -> [(term,abstract,value), ...] 출력
fn dictionary(variant: string) -> int {
    let d = load_dict()
    let vs = d[0]; let ts = d[1]; let abs_l = d[2]; let vals = d[3]
    let mut shown = 0
    let mut i = 0
    while i < vs.len() {
        if vs[i] == variant {
            println("  " + to_string(ts[i]) + "  ->  " + to_string(abs_l[i]) + " = " + to_string(vals[i]))
            shown = shown + 1
        }
        i = i + 1
    }
    if shown == 0 { println("  (no entries for variant=" + variant + ")") }
    return shown
}

// _verify: 모든 variant 가 필수 추상 키 보유 검증
fn _has_abstract_for(d: list, variant: string, target_abs: string) -> bool {
    let vs = d[0]; let abs_l = d[2]
    let mut i = 0
    while i < vs.len() {
        if vs[i] == variant && abs_l[i] == target_abs { return true }
        i = i + 1
    }
    return false
}

fn _unique_variants(d: list) -> list {
    let vs = d[0]
    let mut out: list = []
    let mut i = 0
    while i < vs.len() {
        let v = vs[i]; let mut seen = false; let mut j = 0
        while j < out.len() { if out[j] == v { seen = true }; j = j + 1 }
        if !seen { out = out + [v] }
        i = i + 1
    }
    return out
}

fn _verify_run() -> int {
    let d = load_dict()
    let vs = d[0]
    println("rosetta verify: total entries = " + to_string(vs.len()))
    let variants = _unique_variants(d)
    let required = ["convergence_kind", "target_value"]
    let mut fails = 0
    let mut vi = 0
    while vi < variants.len() {
        let v = variants[vi]
        let mut ri = 0
        while ri < required.len() {
            let req = required[ri]
            if _has_abstract_for(d, v, req) {
                println("  PASS  " + v + "  has  " + req)
            } else {
                println("  FAIL  " + v + "  missing  " + req)
                fails = fails + 1
            }
            ri = ri + 1
        }
        vi = vi + 1
    }
    println("---")
    if fails == 0 { println("verify: ALL PASS"); return 0 }
    println("verify: " + to_string(fails) + " FAIL"); return 1
}

fn help() {
    println("rosetta_protocol.hexa — OUROBOROS 3종 의미 번역 레이어")
    println("  translate <variant> <term> | dictionary <variant> | _verify")
    println("  variants: nexus|nexus_meta|nexus_quantum|anima|n6arch")
    println("  abstract: convergence_kind,target_value,tolerance,floor,progress_metric,")
    println("            decay_window,memory_weight,reset_ratio,max_iterations,")
    println("            branching_factor,divergence_cap,warmup")
}

fn _argv_safe() -> list {
    let a = args()
    if a.len() > 0 { return a }
    let mut e = ""
    try { e = to_string(exec("printenv ROSETTA_ARGV")).trim() } catch _ {} // @allow-silent-catch
    if e == "" { return [] }
    return e.split(" ")
}

fn main() {
    let a = _argv_safe()
    let mut cmd = "help"
    if a.len() >= 3 { cmd = a[2] }
    if cmd == "translate" {
        if a.len() < 5 { println("usage: translate <variant> <term>"); return }
        println(translate(a[3], a[4])); return
    }
    if cmd == "dictionary" {
        if a.len() < 4 { println("usage: dictionary <variant>"); return }
        println("dictionary(" + a[3] + "):")
        let n = dictionary(a[3])
        println("---"); println("entries: " + to_string(n)); return
    }
    if cmd == "_verify" || cmd == "verify-all" { let rc = _verify_run(); return }
    help()
}

main()
