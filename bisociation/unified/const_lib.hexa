// const_lib.hexa — n=6 완전수 상수 SSOT wrapper
// SSOT: shared/n6/n6_constants.jsonl (primary) → hardcoded fallback
// 항등식: σ(n)·φ(n) == n·τ(n) → 12·2 == 6·4 → 24 == 24
// R1 HEXA-FIRST | R3 NO-HARDCODE(SSOT우선) | R14 shared SSOT
// 주의: stage1 hexa map write/has_key 제약 → 내부는 parallel-list
// CLI: hexa const_lib.hexa <verify|list|get NAME>

fn _resolve_ssot_path() -> string {
    let mut home = ""
    try { home = to_string(exec("printenv HOME")).trim() } catch e {} // @allow-silent-catch
    if home == "" { home = "$HOME" }
    return home + "/core/nexus/n6/n6_constants.jsonl"
}

// JSONL 단일 라인에서 "key":VALUE 또는 "key":"VALUE" 추출
fn _extract_field(line: string, key: string) -> string {
    let needle = "\"" + key + "\""
    if !line.contains(needle) { return "" }
    let parts = line.split(needle)
    if len(parts) < 2 { return "" }
    let ac = parts[1].split(":")
    if len(ac) < 2 { return "" }
    let v = ac[1].trim()
    if v.starts_with("\"") {
        let q = v.split("\"")
        if len(q) >= 2 { return q[1] }
        return ""
    }
    return v.split(",")[0].split("}")[0].trim()
}

fn _fallback_keys()   -> list { return ["n", "sigma", "phi", "tau", "sopfr", "j2", "mu"] }
fn _fallback_values() -> list { return ["6", "12", "2", "4", "5", "24", "1"] }

// SSOT 로드 → [keys, values] 쌍
fn load_ssot_lists() -> list {
    let mut ks: list = []
    let mut vs: list = []
    let path = _resolve_ssot_path()
    if !file_exists(path) { return [ks, vs] }
    let mut raw = ""
    try { raw = read_file(path) } catch e { return [ks, vs] } // @allow-silent-catch
    for line in raw.split("\n") {
        let s = line.trim()
        if s == "" || !s.starts_with("{") { continue }
        let nm = _extract_field(s, "name")
        let vl = _extract_field(s, "value")
        if nm != "" && vl != "" { ks = ks + [nm]; vs = vs + [vl] }
    }
    return [ks, vs]
}

fn load_from_ssot() -> list { return load_ssot_lists() }
fn all_constants() -> list {
    let pair = load_ssot_lists()
    if len(pair[0]) == 0 { return [_fallback_keys(), _fallback_values()] }
    return pair
}

fn _lookup_str(key: string) -> string {
    let pair = all_constants()
    let ks = pair[0]; let vs = pair[1]
    let mut i: i64 = 0
    while i < len(ks) {
        if ks[i] == key { return to_string(vs[i]) }
        i = i + 1
    }
    return ""
}

fn _get_int(key: string) -> i64 {
    let s = _lookup_str(key)
    if s == "" { return 0 }
    let mut r: i64 = 0
    try { r = to_int(s) } catch e { r = 0 } // @allow-silent-catch
    return r
}

fn get_n()     -> i64 { return _get_int("n") }
fn get_sigma() -> i64 { return _get_int("sigma") }
fn get_phi()   -> i64 { return _get_int("phi") }
fn get_tau()   -> i64 { return _get_int("tau") }
fn get_sopfr() -> i64 { return _get_int("sopfr") }
fn get_j2()    -> i64 { return _get_int("j2") }

fn verify_identity() -> bool {
    return get_sigma() * get_phi() == get_n() * get_tau()
}

fn main() {
    let a = args()
    let mut cmd = "list"
    if len(a) >= 3 { cmd = to_string(a[2]) }
    let ssot_exists = file_exists(_resolve_ssot_path())

    if cmd == "verify" {
        let s = get_sigma(); let p = get_phi()
        let n = get_n();     let t = get_tau()
        println("σ·φ = " + to_string(s) + "·" + to_string(p) + " = " + to_string(s*p))
        println("n·τ = " + to_string(n) + "·" + to_string(t) + " = " + to_string(n*t))
        if verify_identity() { println("PASS — identity σ(n)·φ(n) == n·τ(n) holds"); exit(0) } // @allow-silent-exit
        println("FAIL — identity mismatch"); exit(1) // @allow-silent-exit
    } else if cmd == "list" {
        let pair = all_constants()
        let ks = pair[0]; let vs = pair[1]
        let src = if ssot_exists && len(load_ssot_lists()[0]) > 0 { "ssot" } else { "fallback" }
        println("# const_lib n=6 constants (source=" + src + ", count=" + to_string(len(ks)) + ")")
        let mut i: i64 = 0
        while i < len(ks) { println(to_string(ks[i]) + "=" + to_string(vs[i])); i = i + 1 }
    } else if cmd == "get" {
        if len(a) < 4 { println("usage: hexa const_lib.hexa get <name>"); exit(2) } // @allow-silent-exit
        let v = _lookup_str(to_string(a[3]))
        if v == "" { println("unknown: " + to_string(a[3])); exit(3) } // @allow-silent-exit
        println(v)
    } else {
        println("usage: hexa const_lib.hexa <verify|list|get NAME>"); exit(2) // @allow-silent-exit
    }
}

main()
