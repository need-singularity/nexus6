// bin_align.hexa — max cross-correlation lag alignment for R2(r) vectors
// Two R2(r) spectra often show cosine high but Pearson~0 (phase misaligned).
// Finds integer lag lag in [-lag_max,+lag_max] maximizing Pearson(A, B_shifted),
// where B_shifted[i]=B[i-lag]; pads out-of-range with mean(B).
// ClagI: hexa bin_align.hexa <A_pc.jsonl> <B_pc.jsonl> <out.json> [lag_max]

fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x }; return x }

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 40 {
        let nx = (g + x / g) / 2.0
        if abs_f(nx - g) < g * 0.0000000000001 { return nx }
        g = nx; i = i + 1
    }
    return g
}

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {} // @allow-silent-catch
    return v
}

fn _min_cut(s: string, from: i64) -> i64 {
    let cands = [",", "}", " ", "\t", "\r", "]"]
    let mut best: i64 = 0 - 1
    let mut i: i64 = 0
    while i < cands.len() {
        let p = s.substring(from, s.len()).index_of(cands[i])
        if p >= 0 { let abs_p = from + p; if best < 0 || abs_p < best { best = abs_p } }
        i = i + 1
    }
    return best
}

fn json_get_num(line: string, key: string) -> f64 {
    let pat = "\"" + key + "\""
    let kp = line.index_of(pat)
    if kp < 0 { return 0.0 }
    let after_key = kp + pat.len()
    let colon_rel = line.substring(after_key, line.len()).index_of(":")
    if colon_rel < 0 { return 0.0 }
    let mut num_start = after_key + colon_rel + 1
    while num_start < line.len() {
        let ch = line.substring(num_start, num_start + 1)
        if ch == " " || ch == "\t" { num_start = num_start + 1 } else { break }
    }
    let cut = _min_cut(line, num_start)
    let mut end = line.len()
    if cut >= 0 { end = cut }
    return safe_float(line.substring(num_start, end).trim())
}

fn load_r2_norm(path: string) -> list {
    let mut out: list = []
    let mut raw = ""
    try { raw = read_file(path) } catch e { return out } // @allow-silent-catch
    for line in raw.split("\n") {
        let l = line.trim()
        if l.len() == 0 { continue }
        if l.contains("\"R2\"") == false { continue }
        out = out.push(json_get_num(l, "R2"))
    }
    let mut sum = 0.0
    let mut i: i64 = 0
    while i < out.len() { sum = sum + out[i]; i = i + 1 }
    if sum <= 0.000000001 { return out }
    let m = sum / to_float(out.len())
    let mut nrm: list = []
    i = 0
    while i < out.len() { nrm.push(out[i] / m); i = i + 1 }
    return nrm
}

fn mean_of(v: list) -> f64 {
    if v.len() == 0 { return 0.0 }
    let mut s = 0.0; let mut i: i64 = 0
    while i < v.len() { s = s + v[i]; i = i + 1 }
    return s / to_float(v.len())
}

// Pearson over aligned pairs (a[k], b[k]) for k in idxs
fn pearson_on(a: list, b: list, idxs: list) -> f64 {
    let n = idxs.len()
    if n < 2 { return 0.0 }
    let mut sx = 0.0; let mut sy = 0.0; let mut i: i64 = 0
    while i < n { let k = idxs[i]; sx = sx + a[k]; sy = sy + b[k]; i = i + 1 }
    let nf = to_float(n); let mx = sx / nf; let my = sy / nf
    let mut sxy = 0.0; let mut sxx = 0.0; let mut syy = 0.0
    i = 0
    while i < n {
        let k = idxs[i]; let dx = a[k] - mx; let dy = b[k] - my
        sxy = sxy + dx * dy; sxx = sxx + dx * dx; syy = syy + dy * dy
        i = i + 1
    }
    let denom = sqrt_f(sxx * syy)
    if denom <= 0.000000000001 { return 0.0 }
    return sxy / denom
}

// best_lag(a, b, lag_max) → [best_lag_f64, best_pearson, overlap_n_f64]
fn best_lag(a: list, b: list, lag_max: i64) -> list {
    let n = a.len()
    if n != b.len() || n < 4 { return [0.0, 0.0, to_float(n)] }
    let mut best_lag: i64 = 0
    let mut best_r: f64 = 0.0 - 2.0
    let mut best_overlap: i64 = n
    let mut lag: i64 = 0 - lag_max
    while lag <= lag_max {
        let mut lo: i64 = 0
        if lag > 0 { lo = lag }
        let mut hi: i64 = n
        if lag < 0 { hi = n + lag }
        if hi - lo >= 4 {
            let mut a_view: list = []
            let mut b_shift: list = []
            let mut idx_view: list = []
            let mut q: i64 = 0
            let mut i: i64 = lo
            while i < hi {
                a_view = a_view.push(a[i])
                b_shift = b_shift.push(b[i - lag])
                idx_view = idx_view.push(q)
                q = q + 1
                i = i + 1
            }
            let r = pearson_on(a_view, b_shift, idx_view)
            if r > best_r { best_r = r; best_lag = lag; best_overlap = hi - lo }
        }
        lag = lag + 1
    }
    return [to_float(best_lag), best_r, to_float(best_overlap)]
}

// apply_lag(B, lag) → same-length list; out[i]=B[i-lag] in-range else mean(B)
fn apply_lag(b: list, lag: i64) -> list {
    let n = b.len(); let m = mean_of(b)
    let mut out: list = []; let mut i: i64 = 0
    while i < n {
        let src = i - lag
        if src >= 0 && src < n { out.push(b[src]) } else { out.push(m) }
        i = i + 1
    }
    return out
}

// cross_metrics(a, b) → [ks, pearson, l2, cosine]
fn cross_metrics(a: list, b: list) -> list {
    let n = a.len()
    let mut ks = 0.0; let mut sse = 0.0; let mut sx = 0.0; let mut sy = 0.0
    let mut k: i64 = 0
    while k < n {
        let d = a[k] - b[k]; let ad = abs_f(d)
        if ad > ks { ks = ad }
        sse = sse + d * d; sx = sx + a[k]; sy = sy + b[k]
        k = k + 1
    }
    let l2 = sqrt_f(sse / to_float(n))
    let mx = sx / to_float(n); let my = sy / to_float(n)
    let mut sxy = 0.0; let mut sxx = 0.0; let mut syy = 0.0
    k = 0
    while k < n {
        let dx = a[k] - mx; let dy = b[k] - my
        sxy = sxy + dx * dy; sxx = sxx + dx * dx; syy = syy + dy * dy
        k = k + 1
    }
    let mut pearson = 0.0; let denom = sqrt_f(sxx * syy)
    if denom > 0.000000000001 { pearson = sxy / denom }
    let mut dot_xy = 0.0; let mut nx2 = 0.0; let mut ny2 = 0.0
    k = 0
    while k < n {
        dot_xy = dot_xy + a[k] * b[k]; nx2 = nx2 + a[k] * a[k]; ny2 = ny2 + b[k] * b[k]
        k = k + 1
    }
    let mut cosine = 0.0; let cd = sqrt_f(nx2) * sqrt_f(ny2)
    if cd > 0.000000000001 { cosine = dot_xy / cd }
    return [ks, pearson, l2, cosine]
}

// ─── standalone ClagI ───
fn main() {
    let argv = args()
    if argv.len() < 5 {
        println("usage: hexa bin_align.hexa <A_pc.jsonl> <B_pc.jsonl> <out_aligned_verdict.json> [lag_max]")
        exit(2)
    }
    let a_path = argv[2].trim()
    let b_path = argv[3].trim()
    let out_p = argv[4].trim()
    let mut lag_max: i64 = 10
    if argv.len() >= 6 {
        let lm = to_int(argv[5].trim())
        if lm > 0 && lm < 30 { lag_max = lm }
    }

    let a = load_r2_norm(a_path)
    let b = load_r2_norm(b_path)
    let n = a.len()
    if n == 0 || b.len() != n {
        println("FAIlag: bin mismatch A=" + to_string(n) + " B=" + to_string(b.len()))
        exit(1) // @allow-silent-exit
    }
    println("bin_align: N=" + to_string(n) + " lag_max=" + to_string(lag_max))

    // before metrics
    let before = cross_metrics(a, b)
    let ks0 = before[0]; let p0 = before[1]; let l20 = before[2]; let cos0 = before[3]

    // best lag
    let bl = best_lag(a, b, lag_max)
    let lag: i64 = to_int(bl[0])
    let best_p = bl[1]
    let overlap = to_int(bl[2])
    println("  best_lag=" + to_string(lag) + " pearson_overlap=" + to_string(best_p) + " overlap=" + to_string(overlap))

    // apply lag, recompute full-length metrics
    let b_aligned = apply_lag(b, lag)
    let after = cross_metrics(a, b_aligned)
    let ks1 = after[0]; let p1 = after[1]; let l21 = after[2]; let cos1 = after[3]

    let out = "{\n"
        + "  \"method\":\"cross_correlation_lag\",\n"
        + "  \"lag_max\":" + to_string(lag_max) + ",\n"
        + "  \"best_lag\":" + to_string(lag) + ",\n"
        + "  \"overlap\":" + to_string(overlap) + ",\n"
        + "  \"before\": {\"ks\":" + to_string(ks0) + ",\"pearson\":" + to_string(p0)
        + ",\"l2\":" + to_string(l20) + ",\"cosine\":" + to_string(cos0) + "},\n"
        + "  \"after\":  {\"ks\":" + to_string(ks1) + ",\"pearson\":" + to_string(p1)
        + ",\"l2\":" + to_string(l21) + ",\"cosine\":" + to_string(cos1) + "},\n"
        + "  \"pearson_overlap_max\":" + to_string(best_p) + ",\n"
        + "  \"n_bins\":" + to_string(n) + ",\n"
        + "  \"ts\":\"2026-04-14\"\n}\n"
    try { write_file(out_p, out) } catch e { println("ERR write " + out_p); exit(1) } // @allow-silent-exit
    println("  wrote " + out_p)
    println("  before: ks=" + to_string(ks0) + " ρ=" + to_string(p0) + " cos=" + to_string(cos0))
    println("  after : ks=" + to_string(ks1) + " ρ=" + to_string(p1) + " cos=" + to_string(cos1))
    exit(0)
}

main()
