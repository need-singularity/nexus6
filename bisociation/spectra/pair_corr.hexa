// pair_corr.hexa — Pair Correlation R₂(r) (L2 Bisociation Engine — Spectra)
// Role: From unfolded spacings {s_i}, compute R₂(r) histogram.
// Math: x_i = Σ_{j≤i} s_j ; R₂(r) ≈ #{(i,j): x_j−x_i ∈ (r, r+Δr), j>i} / (N·Δr)
// CLI:  hexa pair_corr.hexa <unfold.jsonl> <output.jsonl>
// IN:   {"idx": i, "s": s_i}   OUT: {"r": r_center, "R2": R2_r}

comptime const DR = 0.1
comptime const R_MAX = 5.0
comptime const N_BINS = 50

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {} // @allow-silent-catch
    return v
}

fn _min_cut(s: string, from: i64) -> i64 {
    let cands = [",", "}", " ", "\t", "\r", "]"]
    let mut best: i64 = 0 - 1
    let mut i: i64 = 0
    while i < cands.len() {
        let sub = s.substring(from, s.len())
        let p = sub.index_of(cands[i])
        if p >= 0 {
            let abs_p = from + p
            if best < 0 || abs_p < best { best = abs_p }
        }
        i = i + 1
    }
    return best
}

fn json_get_num(line: string, key: string) -> f64 {
    let pat = "\"" + key + "\""
    let kp = line.index_of(pat)
    if kp < 0 { return 0.0 }
    let after_key = kp + pat.len()
    let colon_rel = line.substring(after_key, line.len()).index_of(":")
    if colon_rel < 0 { return 0.0 }
    let mut num_start = after_key + colon_rel + 1
    while num_start < line.len() {
        let ch = line.substring(num_start, num_start + 1)
        if ch == " " || ch == "\t" { num_start = num_start + 1 } else { break }
    }
    let cut = _min_cut(line, num_start)
    let mut end = line.len()
    if cut >= 0 { end = cut }
    return safe_float(line.substring(num_start, end).trim())
}

fn main() {
    let argv = args()
    if argv.len() < 4 {
        eprintln("usage: hexa pair_corr.hexa <unfold.jsonl> <output.jsonl>")
        exit(2)
    }
    let inp = argv[2].trim()
    let outp = argv[3].trim()

    let mut raw = ""
    try { raw = read_file(inp) } catch e { // @allow-silent-catch
        eprintln("FAIL: read_file " + inp)
        exit(1) // @allow-silent-exit
    }

    // Parse spacings → cumulative positions
    let mut xs: list = []
    let mut cum = 0.0
    for line in raw.split("\n") {
        let l = line.trim()
        if l.len() == 0 { continue }
        if l.contains("\"s\"") == false { continue }
        cum = cum + json_get_num(l, "s")
        xs = xs + [cum]
    }

    let n = xs.len()
    if n < 2 {
        eprintln("FAIL: need >=2 spacings, got " + to_string(n))
        exit(1) // @allow-silent-exit
    }

    // Initialize bin counts
    let mut counts: list = []
    let mut b: i64 = 0
    while b < N_BINS { counts = counts + [0] ; b = b + 1 }

    // Count pairs; bin = floor((x_j - x_i)/DR). Rebuild list on increment (no index-assign).
    let mut total: i64 = 0
    let mut i: i64 = 0
    while i < n {
        let xi = xs[i]
        let mut j: i64 = i + 1
        while j < n {
            let d = xs[j] - xi
            if d >= R_MAX { break }
            if d > 0.0 {
                let bin = to_int(d / DR)
                if bin >= 0 && bin < N_BINS {
                    let mut nc: list = []
                    let mut k: i64 = 0
                    while k < counts.len() {
                        if k == bin { nc = nc + [counts[k] + 1] }
                        else { nc = nc + [counts[k]] }
                        k = k + 1
                    }
                    counts = nc
                    total = total + 1
                }
            }
            j = j + 1
        }
        i = i + 1
    }

    // R₂(r) = count / (N·Δr)
    let norm = to_float(n) * DR
    let mut out_buf = ""
    let mut bi: i64 = 0
    while bi < N_BINS {
        let r_center = (to_float(bi) + 0.5) * DR
        let r2 = to_float(counts[bi]) / norm
        out_buf = out_buf + "{\"r\":" + to_string(r_center) + ",\"R2\":" + to_string(r2) + "}\n"
        bi = bi + 1
    }

    try { write_file(outp, out_buf) } catch e { // @allow-silent-catch
        eprintln("FAIL: write_file " + outp)
        exit(1) // @allow-silent-exit
    }
    eprintln("pair_corr: n=" + to_string(n) + " pts, " + to_string(total) + " pairs, " + to_string(N_BINS) + " bins")
}

main()
