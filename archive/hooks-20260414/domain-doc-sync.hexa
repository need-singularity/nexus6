// domain-doc-sync.hexa — 도메인 .md 변경 시 _registry.json 자동 반영 + commit + push
// PostToolUse Write|Edit 훅으로 실행
// 트리거: domains/<axis>/<name>/<name>.md 변경 감지

let HOME = env("HOME")
let N6 = HOME + "/Dev/n6-architecture"
let REGISTRY = N6 + "/papers/_registry.json"

let stdin_data = read_stdin()

// 변경된 파일 경로 추출
let mut file_path = ""
if stdin_data.contains("\"file_path\":\"") {
    let parts = stdin_data.split("\"file_path\":\"")
    if parts.len() >= 2 {
        file_path = parts[1].split("\"")[0]
    }
}

if file_path == "" { return }

// 도메인 .md 변경인지 확인
// 패턴: .../domains/<axis>/<name>/<name>.md
if file_path.contains("/domains/") == false { return }
if file_path.ends_with(".md") == false { return }
if file_path.ends_with("CLAUDE.md") { return }
if file_path.ends_with("goal.md") { return }

// 경로 파싱: axis, domain_name 추출
let rel = file_path.split("/domains/")
if rel.len() < 2 { return }
let domain_parts = rel[1].split("/")
if domain_parts.len() < 3 { return }

let axis = domain_parts[0]
let domain_name = domain_parts[1]
let file_name = domain_parts[2]

// <name>.md 인지 확인 (도메인명과 파일명 일치)
if file_name != domain_name + ".md" { return }

// 문서에서 메타데이터 추출
let doc_content = read_file(file_path)
let lines = doc_content.split("\n")

// ufo 지수 추출 (🛸N 패턴)
let mut ufo = 0
for line in lines {
    if line.contains("🛸") {
        let after_ufo = line.split("🛸")
        if after_ufo.len() >= 2 {
            let num_str = after_ufo[1].trim()
            if num_str.starts_with("10") { ufo = 10 }
            else if num_str.starts_with("9") { ufo = 9 }
            else if num_str.starts_with("8") { ufo = 8 }
            else if num_str.starts_with("7") { ufo = 7 }
        }
        break
    }
}

// 제목 추출 (첫 번째 # 라인)
let mut title = domain_name
for line in lines {
    if line.starts_with("# ") {
        title = line.replace("# ", "").trim()
        break
    }
}

// _registry.json 에서 해당 도메인 엔트리 존재 확인
let registry_content = read_file(REGISTRY)
let domain_doc_path = "domains/" + axis + "/" + domain_name + "/" + domain_name + ".md"
let has_entry = registry_content.contains("\"" + domain_doc_path + "\"")

// 이미 올바른 경로로 등록되어 있으면 → commit/push 만 진행
// 아직 등록 안 되어있거나 구 docs/ 경로면 → systemMessage 로 알림
let old_docs_path = "docs/" + domain_name + "/"
let has_old_ref = registry_content.contains("\"" + old_docs_path)

let mut msg = ""

if has_old_ref {
    msg = "⚡ domain-doc-sync: " + domain_name + ".md 변경 감지. _registry.json 에 구 docs/ 경로 잔존 — 갱신 필요. 경로: " + old_docs_path + " → " + domain_doc_path
} else if has_entry == false {
    msg = "⚡ domain-doc-sync: " + domain_name + ".md 변경 감지. _registry.json 에 미등록 — 신규 추가 필요. 도메인 경로: " + domain_doc_path
}

// git auto-commit+push (도메인 문서 + 관련 json)
let git_status = to_string(exec("cd " + N6 + " && git diff --name-only HEAD -- papers/_registry.json README.md domains/" + axis + "/" + domain_name + "/ 2>/dev/null")).trim()

if git_status.len() > 0 {
    // 변경된 파일 스테이지 + 커밋 + 푸시
    let stage_cmd = "cd " + N6 + " && git add papers/_registry.json README.md domains/" + axis + "/" + domain_name + "/ 2>/dev/null"
    try { exec("bash", ["-c", stage_cmd]) } catch e {}

    let commit_msg = "sync(" + domain_name + "): 도메인 문서 → _registry.json 자동 반영"
    let commit_cmd = "cd " + N6 + " && git diff --cached --quiet || git commit -m '" + commit_msg + "' 2>/dev/null"
    try { exec("bash", ["-c", commit_cmd]) } catch e {}

    let push_cmd = "cd " + N6 + " && git push origin main 2>/dev/null &"
    try { exec("bash", ["-c", push_cmd]) } catch e {}

    if msg.len() == 0 {
        msg = "✅ domain-doc-sync: " + domain_name + " 문서 변경 → auto-commit+push 완료"
    } else {
        msg = msg + " | auto-commit+push 완료"
    }
}

if msg.len() > 0 {
    println("{\"systemMessage\":\"" + msg.replace("\"", "\\\"") + "\"}")
}
