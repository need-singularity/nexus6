// hook-entry.hexa — Claude Code 훅 진입점 (hook-entry.sh 대체)
// 사용: hexa hook-entry.hexa <mode> <target.hexa> [args...]
// mode: prompt | post | pretool | session
//
// 2026-04-13: target별 atomic mkdir lockdir 추가 (중복 실행 시 Load Avg 폭주 방지).
// stage0 bug: `if bool_var { ... }` 내부 실행 안 됨 (HexaVal pointer leak)
//             → 모든 분기는 "y"/"n" 또는 "ok"/"skip" 문자열 비교로 우회.
// stage0 bug: `if X { return }` 패턴 금지 (non-terminating return).
//             → fn main() 내부 positive-gate nested if 로 분기.

let HOME = env("HOME")
let HOOK_DIR = HOME + "/Dev/nexus/shared/hooks"
let STALE_SEC = 60

fn json_escape(s: string) -> string {
    s.replace("\\", "\\\\").replace("\"", "\\\"")
}

fn emit_block(msg: string) {
    println("{\"decision\":\"block\",\"reason\":\"" + json_escape(msg) + "\"}")
}

fn emit_message(msg: string) {
    println("{\"systemMessage\":\"" + json_escape(msg) + "\"}")
}

fn find_hexa() -> string {
    let candidates = [
        HOME + "/Dev/airgenome/nexus/shared/bin/hexa.real",
        HOME + "/.hx/bin/hexa",
        HOOK_DIR + "/../bin/hexa",
        HOME + "/Dev/nexus/shared/scripts/bin/hexa",
        HOME + "/Dev/hexa-lang/hexa"
    ]
    for c in candidates {
        if file_exists(c) { return c }
    }
    ""
}

// target path → lockdir basename
fn target_lock(target: string) -> string {
    let base = target.split("/")
    let name = base[base.len() - 1]
    let cleaned = name.replace(".hexa", "").replace(".", "_")
    return "/tmp/nexus-hook-" + cleaned + ".lockdir"
}

// atomic mkdir lock — shell 측에서 skip/takeover 결정 (hexa if 최소화).
// 반환 "ok" = 단독 소유, "no" = 중복 감지, 즉시 종료.
// stage0 bug: 복잡한 if/return 구조는 비결정적 — shell 파이프라인으로 단순화.
fn acquire_lock(dir: string) -> string {
    let mut got = "no"
    let r1 = to_string(exec("mkdir '" + dir + "' 2>/dev/null && echo ok || echo no")).trim()
    if r1 == "ok" {
        exec("echo $PPID > '" + dir + "/pid'")
        got = "ok"
    }
    if r1 == "no" {
        // pid 생존 + age 신선 → skip. pid 죽음/stale → atomic takeover.
        let cmd = "PID=$(cat '" + dir + "/pid' 2>/dev/null); AGE=$(( $(date +%s) - $(stat -f %m '" + dir + "' 2>/dev/null || echo 0) )); STALE=" + to_string(STALE_SEC) + "; if [ -z \"$PID\" ] && [ $AGE -lt 5 ]; then echo skip; elif [ -n \"$PID\" ] && kill -0 $PID 2>/dev/null && [ $AGE -lt $STALE ]; then echo skip; else rm -rf '" + dir + "' && mkdir '" + dir + "' 2>/dev/null && echo $PPID > '" + dir + "/pid' && echo ok || echo skip; fi"
        let r2 = to_string(exec(cmd)).trim()
        if r2 == "ok" { got = "ok" }
    }
    return got
}

fn run_target(mode: string, target: string, extra_args: string) {
    let hexa = find_hexa()
    let hexa_str = if len(hexa) > 0 { "y" } else { "n" }
    if hexa_str == "n" {
        let base = target.split("/")
        let name = base[base.len() - 1]
        if mode == "pretool" {
            emit_block("hook resolver 없음: " + name)
        }
        if mode != "pretool" {
            emit_message("hook resolver 없음: " + name)
        }
    }
    if hexa_str == "y" {
        let tmp_in = "/tmp/.nexus-hook-in-" + to_string(exec("echo $$")).trim()
        let stdin_data = read_stdin()
        let mut write_str = "y"
        try { write_file(tmp_in, stdin_data) } catch e { write_str = "n" }
        if write_str == "y" {
            let cmd = "cat " + tmp_in + " | " + hexa + " run " + target + " " + extra_args + " 2>/tmp/.nexus-hook-err"
            let mut result = ""
            let mut status = 0
            try {
                result = to_string(exec(cmd)).trim()
            } catch e {
                status = 1
            }

            if status == 0 {
                if result.len() > 0 { println(result) }
            }
            if status != 0 {
                let mut err = ""
                try { err = read_file("/tmp/.nexus-hook-err").trim() } catch e {}
                if err.len() > 240 { err = err.split("")[0] + "..." }
                let base = target.split("/")
                let name = base[base.len() - 1]
                let msg = name + " exit=" + to_string(status) + " " + err
                if mode == "pretool" {
                    emit_block("hook 실패: " + msg)
                }
                if mode != "pretool" {
                    emit_message("hook 실패 감지: " + msg)
                }
            }

            try { exec("rm -f " + tmp_in + " /tmp/.nexus-hook-err") } catch e {}
        }
    }
}

fn main() {
    let a = args()
    let mode = if a.len() >= 3 { a[2] } else { "" }
    let target = if a.len() >= 4 { a[3] } else { "" }

    let has_target_str = if len(target) > 0 { "y" } else { "n" }
    if has_target_str == "y" {
        let lockdir = target_lock(target)
        let got = acquire_lock(lockdir)
        // stage0 note: got == "ok" only; "no"/"skip" paths do nothing.
        if got == "ok" {
            let mut extra_args = ""
            let mut ai = 4
            while ai < a.len() {
                if extra_args.len() > 0 { extra_args = extra_args + " " }
                extra_args = extra_args + a[ai]
                ai = ai + 1
            }
            run_target(mode, target, extra_args)
        }
    }
}

main()
