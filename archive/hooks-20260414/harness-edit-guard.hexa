// harness-edit-guard.hexa — PreToolUse 훅
// Write/Edit 툴이 shared/harness/ 파일 수정 시 유저 확인 강제.
// stdin: Claude Code PreToolUse JSON
// stdout: {"decision":"block","systemMessage":"..."} 또는 empty (pass)
// 예외: env HARNESS_APPROVED=1 또는 로그/쿨다운 파일

let HOME = env("HOME")
let HOOK_DIR = HOME + "/Dev/nexus/shared/hooks"

// 화이트리스트 체크 (다른 nexus 훅과 동일 패턴)
fn is_whitelisted() -> bool {
    let repo_root = exec("git rev-parse --show-toplevel 2>/dev/null || echo ''").trim()
    if repo_root == "" { return false }
    let repo_name = exec("basename " + repo_root).trim()
    let cfg = HOOK_DIR + "/hooks-config.json"
    if !file_exists(cfg) { return false }
    return read_file(cfg).contains("\"" + repo_name + "\"")
}

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

if !is_whitelisted() { exit(0) }

// 환경변수 우회
let approved = _str(env("HARNESS_APPROVED")).trim()
if approved == "1" || approved == "true" { exit(0) }

// stdin JSON 읽기
let raw = exec("cat").trim()
if raw == "" { exit(0) }

// tool_name 추출 (간이 파싱)
fn _jfield(s: string, key: string) -> string {
    let m = "\"" + key + "\":"
    let i = s.index_of(m)
    if i < 0 { return "" }
    let after = s.substring(i + len(m), len(s))
    // 공백 스킵 + " 로 시작하면 따옴표 추출
    let t = after.trim()
    if t.substring(0, 1) != "\"" { return "" }
    let rest = t.substring(1, len(t))
    let end = rest.index_of("\"")
    if end < 0 { return "" }
    return rest.substring(0, end)
}

let tool = _jfield(raw, "tool_name")
if tool != "Write" && tool != "Edit" && tool != "NotebookEdit" { exit(0) }

let file_path = _jfield(raw, "file_path")
if file_path == "" { exit(0) }

// 대상이 shared/harness/ 아래인지 확인 (절대/상대 경로 양쪽)
let harness_rel = "shared/harness/"
let is_harness = file_path.index_of(harness_rel) >= 0
if !is_harness { exit(0) }

// 로그/쿨다운 예외
if file_path.index_of("_log.jsonl") >= 0 { exit(0) }
if file_path.index_of("mistakes.jsonl") >= 0 { exit(0) }
if file_path.index_of("autofix_proposals.jsonl") >= 0 { exit(0) }
if file_path.index_of("rules_usage.jsonl") >= 0 { exit(0) }
if file_path.index_of(".gc_weekly_cooldown") >= 0 { exit(0) }

// 차단 JSON 출력
let msg = "🔒 shared/harness/ 수정 감지 — 유저 승인 필요.\\n파일: " + file_path + "\\n승인 방법: 유저가 '승인' 또는 env HARNESS_APPROVED=1 후 재시도."
println("{\"decision\":\"block\",\"systemMessage\":\"" + msg + "\"}")
exit(0)
