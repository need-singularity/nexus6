// auto-sync.hexa — project-claude/*.md 또는 settings.json 변경 시 전 프로젝트 자동 동기화
// PostToolUse Write|Edit 훅으로 실행

let HOME = env("HOME")
let HEXA = HOME + "/Dev/hexa-lang/hexa"
let NEXUS = HOME + "/Dev/nexus"
let SCRIPTS = NEXUS + "/shared/scripts"

let stdin_data = read_stdin()

// 변경된 파일 경로 추출
let mut file_path = ""
if stdin_data.contains("\"file_path\":\"") {
    let parts = stdin_data.split("\"file_path\":\"")
    if parts.len() >= 2 {
        file_path = parts[1].split("\"")[0]
    }
}

if file_path == "" { return }

// project-claude/*.md 변경 → CLAUDE.md 동기화
if file_path.contains("project-claude/") && file_path.contains(".md") {
    // nexus CLAUDE.md도 갱신
    try { exec("cp " + NEXUS + "/shared/project-claude/nexus.md " + NEXUS + "/CLAUDE.md") } catch e {}
    // 전 프로젝트 동기화
    try { exec("bash", ["-c", HEXA + " " + SCRIPTS + "/sync_claude_md.hexa > /dev/null 2>&1 &"]) } catch e {}
    println("{\"systemMessage\":\"🔄 CLAUDE.md 전 프로젝트 자동 동기화 시작\"}")
}

// settings.json 변경 (nexus 자체) → 전 프로젝트 동기화
if file_path.contains(".claude/settings.json") && file_path.contains("nexus") {
    try { exec("bash", ["-c", HEXA + " " + SCRIPTS + "/sync_settings.hexa > /dev/null 2>&1 &"]) } catch e {}
    println("{\"systemMessage\":\"🔄 settings.json 전 프로젝트 자동 동기화 시작\"}")
}
