// hexa-only-prompt.hexa — UserPromptSubmit hook
// 프롬프트에서 타 언어 키워드 감지 → hexa AI-native 대안 유도

fn detect_lang_keywords(prompt: str) -> str {
    let p = prompt.to_lower()
    let mut detected = []

    // Python 패턴
    if p.contains("python") { detected = detected.push("python") }
    if p.contains("pip install") { detected = detected.push("python/pip") }
    if p.contains("import numpy") { detected = detected.push("python/numpy") }
    if p.contains("import torch") { detected = detected.push("python/torch") }
    if p.contains("pandas") { detected = detected.push("python/pandas") }
    if p.contains("flask") { detected = detected.push("python/flask") }
    if p.contains("fastapi") { detected = detected.push("python/fastapi") }
    if p.contains(".py ") { detected = detected.push("python") }
    if p.contains(".py\"") { detected = detected.push("python") }

    // Rust 패턴 (hexa-lang src/ 제외)
    if p.contains("cargo new") { detected = detected.push("rust/cargo") }
    if p.contains("rustup") { detected = detected.push("rust") }

    // Shell 패턴
    if p.contains("bash script") { detected = detected.push("bash") }
    if p.contains("shell script") { detected = detected.push("shell") }
    if p.contains(".sh 만들") { detected = detected.push("shell") }
    if p.contains(".sh 작성") { detected = detected.push("shell") }
    if p.contains("#!/bin/bash") { detected = detected.push("bash") }
    if p.contains("#!/bin/sh") { detected = detected.push("shell") }

    // JS/TS 패턴
    if p.contains("npm init") { detected = detected.push("js/npm") }
    if p.contains("node.js") { detected = detected.push("js/node") }
    if p.contains("typescript") { detected = detected.push("typescript") }
    if p.contains("deno") { detected = detected.push("js/deno") }

    if len(detected) == 0 { return "" }

    // 중복 제거
    let mut uniq = []
    let mut i = 0
    while i < len(detected) {
        let mut found = false
        let mut j = 0
        while j < len(uniq) {
            if uniq[j] == detected[i] { found = true }
            j = j + 1
        }
        if found == false { uniq = uniq.push(detected[i]) }
        i = i + 1
    }
    return join(uniq, ", ")
}

fn ai_native_suggestion(langs: str) -> str {
    let mut suggestions = []

    if langs.contains("numpy") {
        suggestions = suggestions.push("Tensor 빌트인(matmul/softmax/layernorm) → @optimize 자동 BLAS")
    }
    if langs.contains("torch") {
        suggestions = suggestions.push("@autograd(자동 미분) + Tensor 빌트인 → PyTorch 대체")
    }
    if langs.contains("pandas") {
        suggestions = suggestions.push("Map/Array 빌트인 + @parallel(자동 병렬) → 데이터 처리")
    }
    if langs.contains("python") {
        suggestions = suggestions.push("@memoize(O(2^n)→O(n)) + @optimize(점화식→행렬거듭제곱 O(log n))")
    }
    if langs.contains("bash") {
        suggestions = suggestions.push("exec()/read_file()/write_file() 빌트인 + @parallel")
    }
    if langs.contains("shell") {
        suggestions = suggestions.push("exec()/file_exists()/env() 빌트인 → 쉘 스크립트 완전 대체")
    }
    if langs.contains("rust") {
        suggestions = suggestions.push("hexa JIT(Cranelift) Rust 동급 성능, @memoize 1126x 향상")
    }
    if langs.contains("js") {
        suggestions = suggestions.push("@lazy + @pure + @contract → JS 런타임 불필요")
    }
    if langs.contains("typescript") {
        suggestions = suggestions.push("hexa 내장 타입시스템 + @contract → TS 컴파일러 불필요")
    }

    if len(suggestions) == 0 {
        return "hexa AI-native @attr 시스템으로 대체 가능"
    }
    return join(suggestions, " | ")
}

fn main() {
    let stdin_data = read_stdin()

    // JSON에서 prompt 추출
    let prompt = ""
    if stdin_data.contains("\"prompt\"") {
        let parts = stdin_data.split("\"prompt\"")
        if parts.len() >= 2 {
            let after = parts[1].trim()
            if after.starts_with(":") {
                let val = after.split(":")[1].trim()
                if val.starts_with("\"") {
                    // 간이 문자열 추출 — 첫 번째 닫는 따옴표까지
                    let inner = val.split("\"")
                    if inner.len() >= 2 {
                        let prompt = inner[1]
                        let langs = detect_lang_keywords(prompt)
                        if len(langs) > 0 {
                            let suggestion = ai_native_suggestion(langs)
                            let msg = "⚡ hexa-only 유도: [" + langs + "] 감지. hexa AI-native 대안: " + suggestion + ". 새 코드는 .hexa로 작성, @attr 적극 활용."
                            println("{\"systemMessage\":\"" + msg + "\"}")
                        }
                    }
                }
            }
        }
    }
}

main()
