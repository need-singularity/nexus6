// event-handoff.hexa — PostToolUse Bash hook. commit 이벤트 감지 시 handoff_write 호출
// 트리거: Bash 명령이 git commit 포함 + 성공 (exit 0)
// 성공 조용, 실패 조용 (하네스 gate 아님 — 이벤트 체크포인트)

let HOME = env("HOME")
let HANDOFF = HOME + "/Dev/nexus/shared/harness/handoff_write.hexa"

let stdin_data = read_stdin()
if stdin_data.len() == 0 { exit(0) }

fn json_field(json_text: str, field: str) -> str {
    let key = "\"" + field + "\""
    if json_text.contains(key) == false { return "" }
    let parts = json_text.split(key)
    if parts.len() < 2 { return "" }
    let after = parts[1].trim()
    if after.starts_with(":") == false { return "" }
    let val_part = after.split(":")[1].trim()
    if val_part.starts_with("\"") {
        let inner = val_part.split("\"")
        if inner.len() >= 2 { return inner[1] }
    }
    return ""
}

// tool_name + command 추출
let tool = json_field(stdin_data, "tool_name")
if tool != "Bash" { exit(0) }

// tool_input.command 찾기 — nested JSON
let cmd_marker = "\"command\""
if stdin_data.contains(cmd_marker) == false { exit(0) }
let after = stdin_data.split(cmd_marker)[1]
let parts = after.split(":")
if parts.len() < 2 { exit(0) }
let val = parts[1].trim()
if val.starts_with("\"") == false { exit(0) }
let inner_parts = val.split("\"")
if inner_parts.len() < 2 { exit(0) }
let cmd = inner_parts[1]

// commit 감지
let is_commit = cmd.contains("git commit") && (cmd.contains("--amend") == false)
if is_commit == false { exit(0) }

// 백그라운드로 handoff 호출 (훅 블로킹 안 함)
exec("hexa " + HANDOFF + " commit >/dev/null 2>&1 &")
exit(0)
