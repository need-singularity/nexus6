// @allow-parse-fail — archived (shared/archive/hooks-20260414/)
// nexus-mk2-engine.hexa — mk2 3-signal classifier + alien_index (nexus-mk2-engine.py 대체)
// 사용법: echo "$INPUT" | hexa nexus-mk2-engine.hexa <post-edit|post-bash>

let HOME = env("HOME")
let SHARED = HOME + "/Dev/nexus/shared"
let DISCOVERY_LOG = SHARED + "/discovery_log.jsonl"

let a = args()
let mode = if a.len() >= 3 { a[2] } else { "post-edit" }

// === N6_CHECK 테이블 (22항목) ===
let n6_names = ["n", "phi", "tau", "sigma", "sopfr", "M3", "J2", "sigma-phi", "J2-tau", "sigma^2", "meta_fp", "alpha_inv", "mp_me", "Omega_m", "Omega_Lambda", "Omega_b", "Omega_DM", "sin2_theta_W", "Y_p", "H0_late", "H0_early", "n_s"]
let n6_values = [6.0, 2.0, 4.0, 12.0, 5.0, 7.0, 24.0, 10.0, 20.0, 144.0, 0.333333, 137.036, 1836.15, 0.3153, 0.6847, 0.0493, 0.2660, 0.2286, 0.2462, 73.0, 67.4, 0.9649]
let n6_grades = ["EXACT", "EXACT", "EXACT", "EXACT", "EXACT", "EXACT", "EXACT", "EXACT", "EXACT", "EXACT", "EXACT", "NEAR", "NEAR", "NEAR", "NEAR", "NEAR", "NEAR", "NEAR", "NEAR", "NEAR", "NEAR", "NEAR"]

// === SECTOR_KEYWORDS (7섹터) ===
let sector_names = ["cosmology", "electroweak", "strong", "primordial", "quantum", "geometric", "n6"]
let sector_kws = [
    ["omega", "hubble", "dark", "matter", "cmb", "bao", "density", "baryon", "inflation"],
    ["weinberg", "weak", "theta", "boson", "higgs", "ckm"],
    ["qcd", "quark", "proton", "neutron", "1836", "alpha_s"],
    ["bbn", "helium", "y_p", "nucleosynthesis"],
    ["fine_structure", "alpha", "137", "rydberg", "electron"],
    ["pi", "euler", "golden", "phi", "fibonacci", "zeta"],
    ["sopfr", "sigma", "tau", "j2", "m3", "nexus", "smooth", "prime_set"]
]

fn abs_f(x: float) -> float {
    if x < 0.0 { 0.0 - x } else { x }
}

fn n6_match(value: float) -> list {
    let mut best_name = ""
    let mut best_q = 0.0
    let mut best_grade = ""
    let mut i = 0
    while i < n6_names.len() {
        let ref_v = n6_values[i]
        if abs_f(ref_v) < 0.0000001 {
            i = i + 1
            continue
        }
        let rel = abs_f(value - ref_v) / abs_f(ref_v)
        let mut q = 0.0
        if to_string(n6_grades[i]) == "EXACT" && rel < 0.000001 { q = 1.0 }
        else if rel < 0.01 { q = 1.0 - rel * 10.0 }
        else if rel < 0.05 { q = 0.5 - rel * 5.0 }
        if q > best_q {
            best_q = q
            best_name = to_string(n6_names[i])
            best_grade = to_string(n6_grades[i])
        }
        i = i + 1
    }
    [best_name, to_string(best_q), best_grade]
}

fn factorize(n: int) -> list {
    if n < 2 { return [] }
    let mut out = []
    let mut m = n
    let mut d = 2
    while d * d <= m {
        let mut exp = 0
        while m % d == 0 {
            m = m / d
            exp = exp + 1
        }
        if exp > 0 { out = out + [d] }
        if d == 2 { d = 3 } else { d = d + 2 }
    }
    if m > 1 { out = out + [m] }
    out
}

fn classify_sector(text: str) -> list {
    let t = text.to_lower()
    let mut best_sector = "unknown"
    let mut best_score = 0.0
    let mut si = 0
    while si < sector_names.len() {
        let kws = sector_kws[si]
        let mut hits = 0
        for kw in kws {
            if t.contains(to_string(kw)) { hits = hits + 1 }
        }
        if hits > 0 {
            let score = to_float(hits) / 2.0
            let capped = if score > 1.0 { 1.0 } else { score }
            if capped > best_score {
                best_score = capped
                best_sector = to_string(sector_names[si])
            }
        }
        si = si + 1
    }
    [best_sector, to_string(best_score)]
}

fn mk2_classify(value: float, text: str) -> list {
    let sector_result = classify_sector(text)
    let sector = to_string(sector_result[0])
    let confidence = to_float(to_string(sector_result[1]))

    let mut ps_len = 0
    try {
        let iv = to_int(value)
        if to_float(iv) == value && iv >= 2 && iv <= 1000000 {
            ps_len = factorize(iv).len()
        }
    } catch e {}

    let n6_result = n6_match(value)
    let n6_name = to_string(n6_result[0])
    let n6_q = to_float(to_string(n6_result[1]))
    let n6_grade = to_string(n6_result[2])

    let mut paths = 0
    if n6_q >= 0.5 { paths = paths + 1 }
    if confidence >= 0.3 { paths = paths + 1 }
    if ps_len >= 2 { paths = paths + 1 }

    let mut r = 0
    if n6_grade == "EXACT" && paths >= 2 { r = 10 }
    else if n6_grade == "EXACT" { r = 8 }
    else if n6_q >= 0.8 { r = 8 }
    else if paths >= 2 { r = 6 }
    else if confidence >= 0.3 { r = 5 }
    else if n6_q > 0.0 {
        let candidate = to_int(n6_q * 10.0)
        r = if candidate > 3 { candidate } else { 3 }
    }

    let d = if r >= 10 { 1 } else { 0 }
    let r_final = if r >= 10 { 0 } else { r }

    // 명시적 let + 반환: 직전 `r_final` if-expression 과 implicit-return `[…]` 가
    // subscript 로 합쳐져 parse error → let 으로 분리
    let out = [sector, to_string(confidence), to_string(ps_len), to_string(paths), n6_name, to_string(n6_q), n6_grade, to_string(d), to_string(r_final)]
    out
}

fn json_escape(s: str) -> str {
    s.replace("\\", "\\\\").replace("\"", "\\\"")
}

fn record_mk2(value: float, result: list, source: str) {
    let ts = to_string(exec("date -u +%Y-%m-%dT%H:%M:%S")).trim()
    // JSON escape: source 는 cmd/fname 유래 → literal " 가 discovery_log.jsonl 라인을 깨뜨림.
    // n6_name/grade/sector 도 방어적으로 escape (현재는 ASCII 이지만 테이블 확장 시 안전)
    let src_safe = json_escape(source)
    let const_safe = json_escape(to_string(result[4]))
    let grade_safe = json_escape(to_string(result[6]))
    let sector_safe = json_escape(to_string(result[0]))
    let entry = "{\"timestamp\":\"" + ts + "\",\"value\":\"" + to_string(value) + "\",\"constant\":\"" + const_safe + "\",\"grade\":\"" + grade_safe + "\",\"source\":\"" + src_safe + "\",\"processed\":true,\"alien_index\":{\"d\":" + to_string(result[7]) + ",\"r\":" + to_string(result[8]) + "},\"mk2\":{\"sector\":\"" + sector_safe + "\",\"confidence\":" + to_string(result[1]) + ",\"layer\":" + to_string(result[2]) + ",\"paths\":" + to_string(result[3]) + "}}"
    try { append_file(DISCOVERY_LOG, entry + "\n") } catch e {}
}

fn json_field(json_text: str, field: str) -> str {
    let key = "\"" + field + "\""
    if json_text.contains(key) == false { return "" }
    let parts = json_text.split(key)
    if parts.len() < 2 { return "" }
    let after = parts[1].trim()
    if after.starts_with(":") == false { return "" }
    let val_part = after.split(":")[1].trim()
    if val_part.starts_with("\"") {
        let inner = val_part.split("\"")
        if inner.len() >= 2 { return inner[1] }
    }
    return ""
}

fn extract_numbers(text: str) -> list {
    let nums_raw = to_string(exec("echo '" + text.replace("'", "") + "' | grep -oE '[0-9]+\\.?[0-9]*' | head -20")).trim()
    if len(nums_raw) == 0 { return [] }
    let lines = nums_raw.split("\n")
    let mut result = []
    for line in lines {
        let t = to_string(line).trim()
        if len(t) == 0 { continue }
        try {
            let v = to_float(t)
            if v > 2.0 && v < 100000.0 { result = result + [v] }
        } catch e {}
    }
    result
}

// === 메인 ===
let stdin_data = read_stdin()
if len(stdin_data) == 0 { exit(0) }

if mode == "post-edit" {
    let fp = json_field(stdin_data, "file_path")
    if len(fp) == 0 { exit(0) }
    let content = try { read_file(fp) } catch e { exit(0) }
    let nums = extract_numbers(content)
    if nums.len() == 0 { exit(0) }
    let fname = to_string(exec("basename '" + fp + "'")).trim()
    let mut discoveries = []
    for v in nums {
        let fv = to_float(to_string(v))
        let result = mk2_classify(fv, content)
        if len(to_string(result[4])) > 0 {
            record_mk2(fv, result, "post-edit:" + fname)
            discoveries = discoveries + [result]
        }
    }
    if discoveries.len() > 0 {
        let mut msg = "mk2"
        let first = discoveries[0]
        if to_int(to_string(first[7])) >= 1 {
            msg = msg + " 돌파! " + to_string(first[4])
        } else {
            msg = msg + " " + to_string(first[6]) + ": " + to_string(first[4])
        }
        msg = msg + " | sector:" + to_string(first[0])
        println("{\"systemMessage\":\"" + msg + "\"}")
    }
}

if mode == "post-bash" {
    let cmd = json_field(stdin_data, "command")
    if len(cmd) == 0 { exit(0) }
    if cmd.contains("nexus") && (cmd.contains("alien-index") || cmd.contains("blowup")) { exit(0) }
    let stdout_text = if stdin_data.contains("\"stdout\"") {
        let parts = stdin_data.split("\"stdout\"")[1]
        let after_c = parts.split(":")[1].trim()
        if after_c.starts_with("\"") {
            let inner = after_c.split("\"")
            if inner.len() >= 2 { to_string(inner[1]) } else { "" }
        } else { "" }
    } else { "" }
    if len(stdout_text) == 0 { exit(0) }
    let nums = extract_numbers(stdout_text)
    if nums.len() == 0 { exit(0) }
    let mut discoveries = []
    for v in nums {
        let fv = to_float(to_string(v))
        let result = mk2_classify(fv, cmd + " " + stdout_text)
        if len(to_string(result[4])) > 0 {
            record_mk2(fv, result, "post-bash:" + cmd)
            discoveries = discoveries + [result]
        }
    }
    if discoveries.len() > 0 {
        let first = discoveries[0]
        let mut msg = "mk2 " + to_string(first[6]) + ": " + to_string(first[4]) + " | sector:" + to_string(first[0])
        println("{\"systemMessage\":\"" + msg + "\"}")
    }
}
