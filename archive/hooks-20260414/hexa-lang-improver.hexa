// hexa-lang-improver.hexa — UserPromptSubmit hook (v2: AI-native dynamic)
// 'hexa-lang' 키워드 감지 → 실제 저장소 상태 수집 → 강제 MUST 지시 발사
// 쿨다운: shared/.hexa_lang_cooldown (60초 내 중복 발화 차단)

let stdin_data = read_stdin()

fn json_field(json_text: str, field: str) -> str {
    let key = "\"" + field + "\""
    if json_text.contains(key) == false { return "" }
    let parts = json_text.split(key)
    if parts.len() < 2 { return "" }
    let after = parts[1].trim()
    if after.starts_with(":") == false { return "" }
    let val_part = after.split(":")[1].trim()
    if val_part.starts_with("\"") {
        let inner = val_part.split("\"")
        if inner.len() >= 2 { return inner[1] }
    }
    return ""
}

let user_text = json_field(stdin_data, "prompt")
if len(user_text) == 0 { return }
let lower = user_text.to_lower()

// 키워드 감지 — hexa-lang / hexalang / 핵사랭
let hit = lower.contains("hexa-lang") || lower.contains("hexalang") || lower.contains("핵사랭")
if hit == false { return }

// 쿨다운 체크 (60초) — 연속 fire 방지
let home = env("HOME")
let cooldown_file = home + "/Dev/nexus/shared/.hexa_lang_cooldown"
let now = to_int(to_string(exec("date +%s")).trim())
let mut last: i64 = 0
if file_exists(cooldown_file) {
    try { last = to_int(read_file(cooldown_file).trim()) } catch e { last = 0 }
}
if now - last < 60 { return }
try { write_file(cooldown_file, to_string(now)) } catch e {}

// === 동적 상태 수집 (저장소 실제 상태) ===
let repo = home + "/Dev/hexa-lang"
let head = to_string(exec("cd " + repo + " && git log -1 --format='%h %s' 2>/dev/null")).trim()
let wip = to_string(exec("cd " + repo + " && git status --porcelain 2>/dev/null | head -3 | tr '\\n' ';'")).trim()
let bin = repo + "/hexa"
let mut build_state = "MISSING (hexa build_hexa.hexa 필요)"
if file_exists(bin) { build_state = "OK" }

// === AI-native 강제 지시 메시지 조립 ===
let mut msg = "⚡ HEXA-LANG 개선 모드. "
msg = msg + "HEAD: " + head + " | "
if len(wip) > 0 { msg = msg + "WIP: " + wip + " | " }
msg = msg + "build: " + build_state + " | "
msg = msg + "MUST 순서: (1) 증상 1문장 요약 + 최소 repro .hexa 경로 명시 (2) Grep self/{parser,interpreter,compiler}.hexa 로 책임 위치 특정 (3) hexa test 베이스라인 기록 (4) 수정 → hexa build_hexa.hexa → repro 재실행 → 전후 diff (5) 성공 시 shared/hexa/state.json breakthroughs 갱신 | "
msg = msg + "⚠ L0(self/) 변경 시 CORE_GUARD_SKIP=1 필수, --no-verify 금지 (feedback_l0_unlock_workflow) | "
msg = msg + "⚠ 최근 실제로 잡힌 버그 클래스 3종 — 선제 체크: (a) 빌트인 코드젠 case 매핑 누락 (str/len 등) → Undefined symbol (b) type_of() Call 핸들러에서 빌트인 반환 타입 오추정 → 이중 변환 (c) top-level let _ = main() + auto-append main() 의미 중복 → 2회 호출. 수정 영역이 self/build_c.hexa / 코드젠 / 타입 추론이면 세 패턴 grep 선제 | "
msg = msg + "DO NOW: 증상 요약과 repro 경로부터 한 줄로 답하라. 추측 전에 파일부터 읽어라."

// JSON escape
let msg_safe = msg.replace("\\", "\\\\").replace("\"", "\\\"")
println("{\"systemMessage\":\"" + msg_safe + "\",\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"" + msg_safe + "\"}}")
