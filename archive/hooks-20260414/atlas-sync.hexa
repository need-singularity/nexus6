// atlas-sync.hexa — atlas.n6 변경 시 docs/ 자동 복사 + commit + push
// PostToolUse Write|Edit 훅으로 실행

let HOME = env("HOME")
let NEXUS = HOME + "/Dev/nexus"
let SSOT = NEXUS + "/shared/n6/atlas.n6"
let DOCS = NEXUS + "/docs/_mirror_atlas.n6"

let stdin_data = read_stdin()

// 변경된 파일 경로 추출
let mut file_path = ""
if stdin_data.contains("\"file_path\":\"") {
    let parts = stdin_data.split("\"file_path\":\"")
    if parts.len() >= 2 {
        file_path = parts[1].split("\"")[0]
    }
}

if file_path == "" { return }

// atlas.n6 변경인지 확인
if file_path.contains("atlas.n6") == false { return }
if file_path.contains("/docs/") { return }

// SSOT → docs/ 복사
if file_exists(SSOT) == false { return }

try { exec("cp " + SSOT + " " + DOCS) } catch e { return }

// git add + commit + push (백그라운드)
let cmd = "cd " + NEXUS + " && git add docs/_mirror_atlas.n6 && git diff --cached --quiet || (git commit -m 'sync: atlas.n6 → docs/ 3D map 자동 동기화' && git push origin main 2>/dev/null) &"
try { exec("bash", ["-c", cmd]) } catch e {}

println("{\"systemMessage\":\"✅ atlas-sync: shared/n6/atlas.n6 → docs/atlas.n6 복사 + push 완료\"}")
