{
  "_doc": "nexus 드리프트 규칙 — loop-guard.hexa L5 에서 참조",
  "rules": [
    {
      "type": "inline_number",
      "doc": "README.md",
      "pattern": "\\d+ lenses",
      "actual_cmd": "python3 -c \"import json; d=json.load(open('shared/config/lens_registry.json')); print(d.get('total', len(d.get('lenses',[]))))\"",
      "label": "렌즈 수 (README)"
    },
    {
      "type": "inline_number",
      "doc": "README.md",
      "pattern": "\\d+노드",
      "actual_cmd": "grep -c '@R ' shared/n6/atlas.n6 2>/dev/null || echo 0",
      "label": "atlas 노드 수"
    },
    {
      "type": "file_count",
      "doc": "shared/hooks/CLAUDE.md",
      "pattern": "\\d+.*훅",
      "dir": "shared/hooks",
      "glob": "*.hexa",
      "label": "hooks .hexa 수"
    }
  ]
}
