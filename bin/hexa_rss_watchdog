#!/bin/bash
# hexa_rss_watchdog — global 1s polling daemon
# Kills any hexa_stage0.real / hexa_v2 / hexa_full / hexa_interp.real process
# exceeding RSS cap. 2026-04-27: hexa_interp.real added (actual Mac binary
# observed at 2.87 GiB during raw_all --target-rule raw:99 sweep; default cap
# lowered 4 -> 3 GiB to fit 24 GiB Mac envelope).
# 2026-05-06: ghost route.hexa + wraith vault subprocesses are exempted via
# cmdline pattern check (interactive prompts can spike RSS legitimately).
# claude / WindowServer / kernel_task / launchd / Finder / Terminal / iTerm 보호.

set -u
CAP_KB="${HEXA_STAGE0_RSS_CAP_KB:-4194304}"  # 4 GiB default (Mac 24 GiB envelope; raised 3 -> 4 GiB 2026-05-06)
SINK="${HEXA_RSS_WATCHDOG_LOG:-$HOME/.hx/rss-watchdog.jsonl}"

mkdir -p "$(dirname "$SINK")" 2>/dev/null || true

protected_name() {
    local n="$1"
    case "$n" in
        *claude*|*Claude*|*WindowServer*|*kernel_task*|launchd|*Finder*|*Terminal*|*iTerm*|*tmux*|*sshd*|*login*|*zsh*|*bash*)
            return 0 ;;
    esac
    return 1
}

# 2026-05-06: cmdline-based exemption for ghost route.hexa subprocesses and
# wraith-wallet vault interactive sessions. These tools legitimately hold
# secret material in memory during BIP39 / xpriv operations and a SIGKILL
# mid-prompt would corrupt user state. Match against full ps -o args.
protected_cmdline() {
    local cmd="$1"
    case "$cmd" in
        *ghost/route/module/route.hexa*) return 0 ;;
        *ghost/route/core/route.hexa*) return 0 ;;
        *wraith-wallet/vault/module/*) return 0 ;;
        *wraith-wallet/vault/core/*) return 0 ;;
    esac
    return 1
}

log_event() {
    local ts pid rss name reason
    ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    pid="$1"; rss="$2"; name="$3"; reason="$4"
    printf '{"ts":"%s","type":"rss_watchdog_kill","pid":%s,"rss_kb":%s,"name":"%s","reason":"%s","cap_kb":%s}\n' \
        "$ts" "$pid" "$rss" "$name" "$reason" "$CAP_KB" >> "$SINK" 2>/dev/null || true
}

# pid_tree <root> — BFS through descendants with 8 generation cap
pid_tree() {
    local root="$1" frontier next pid parent line
    frontier="$root"
    printf '%s\n' "$root"
    for _ in 1 2 3 4 5 6 7 8; do
        next=""
        while IFS= read -r line; do
            pid=$(printf '%s' "$line" | awk '{print $1}')
            parent=$(printf '%s' "$line" | awk '{print $2}')
            case " $frontier " in
                *" $parent "*)
                    printf '%s\n' "$pid"
                    next="$next $pid" ;;
            esac
        done < <(ps -Ao pid=,ppid= 2>/dev/null)
        [ -z "$next" ] && break
        frontier="$next"
    done
}

# sum_rss_kb <pid...> — csv aggregate RSS across pid list
sum_rss_kb() {
    local pids="$*"
    [ -z "$pids" ] && { echo 0; return; }
    local csv
    csv=$(printf '%s' "$pids" | tr ' \n' ',,' | sed 's/,,*/,/g; s/^,//; s/,$//')
    ps -o rss= -p "$csv" 2>/dev/null | awk '{s+=$1} END {print s+0}'
}

# pattern: hexa_stage0.real, hexa_interp.real, hexa_v2 (exact end), hexa_full (exact end)
# 2026-04-27: hexa_interp.real added — observed 2.87 GiB peak on Mac during
# `raw_all --target-rule raw:99 --report` (PID 6333, 50 s etime). Earlier
# PID 67652 hit 5.9 GiB. Without this rule the watchdog never fires for
# Mac-native interp loop.
PATTERN='hexa_stage0\.real|hexa_interp\.real|hexa_v2($|[[:space:]])|hexa_full($|[[:space:]])'

while true; do
    # pgrep -f matches full command line
    pids="$(pgrep -f "$PATTERN" 2>/dev/null || true)"
    if [ -n "$pids" ]; then
        for pid in $pids; do
            # Descendant aggregation: sum RSS across full process tree
            tree="$(pid_tree "$pid" | tr '\n' ' ')"
            rss_kb="$(sum_rss_kb $tree)"
            [ -z "$rss_kb" ] && continue
            case "$rss_kb" in
                ''|*[!0-9]*) continue ;;
            esac
            # Protection check on root process name
            name="$(ps -o comm= -p "$pid" 2>/dev/null | awk '{sub(/^ +/,""); print}')"
            if protected_name "$name"; then
                continue
            fi
            # 2026-05-06: cmdline-based exemption (ghost route / wraith vault).
            full_cmd="$(ps -o command= -p "$pid" 2>/dev/null)"
            if protected_cmdline "$full_cmd"; then
                continue
            fi
            if [ "$rss_kb" -gt "$CAP_KB" ]; then
                log_event "$pid" "$rss_kb" "$name" "tree_rss>cap tree=$tree"
                # Kill descendants first, then root, to prevent respawn
                for p in $tree; do
                    kill -KILL "$p" 2>/dev/null || true
                done
            fi
        done
    fi
    sleep 1
done
