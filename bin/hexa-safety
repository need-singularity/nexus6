#!/bin/bash
# hexa-safety — AI Safety annotation 통합 수집기 (grep MVP, v0.1)
# Anthropic Fellows 171 research 기반 6종
#
# 입력:
#   hexa-safety <file.hexa> [<file2.hexa> ...]
#   hexa-safety --dir <directory>
#   hexa-safety [--kind interpret|align|adversarial_robust|deploy_safe|multimodal_safe|model_welfare] <files...>
#
# 출력 (stdout JSON):
#   { "version":"0.1", "source":"grep-mvp",
#     "annotations":[ {kind, fn, file, line, meta{...}} ],
#     "summary":{ interpret, align, adversarial_robust, deploy_safe, multimodal_safe, model_welfare, total } }
#
# 인식 annotation (fn decl 바로 위 라인, stacking 허용):
#   @interpret(feature="<circuit_name>", scope="<local|global>")
#   @align(objective="<helpful|harmless|honest|refusal>", rlhf=<bool>)
#   @adversarial_robust(attack="<pgd|jailbreak|prompt_injection>", defense="<guard|filter>")
#   @deploy_safe(tier="<prod|canary|internal>", guardrails=<bool>)
#   @multimodal_safe(modality="<text|image|audio>", checks=<int>)
#   @model_welfare(consent=<bool>, introspection=<bool>)
#
# exit 0 정상 (빈 annotations 포함). 1=인자 오류
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-safety [--kind interpret|align|adversarial_robust|deploy_safe|multimodal_safe|model_welfare] <file.hexa> [file2.hexa ...]
       hexa-safety [--kind ...] --dir <directory>
EOF
    exit 1
}

filter_kind=""
files=()

# parse args
while [ $# -gt 0 ]; do
    case "$1" in
        --kind)
            shift
            [ $# -ge 1 ] || usage
            case "$1" in
                interpret|align|adversarial_robust|deploy_safe|multimodal_safe|model_welfare) filter_kind="$1" ;;
                *) echo "ERROR: invalid kind: $1" >&2; usage ;;
            esac
            shift
            ;;
        --dir)
            shift
            [ $# -ge 1 ] || usage
            dir="$1"
            [ -d "$dir" ] || { echo "ERROR: directory not found: $dir" >&2; exit 1; }
            while IFS= read -r -d '' f; do files+=("$f"); done < <(find "$dir" -type f -not -path "*/.claude/*" -not -path "*/node_modules/*" -name "*.hexa" -print0)
            shift
            ;;
        -h|--help)
            usage
            ;;
        *)
            [ -f "$1" ] || { echo "ERROR: file not found: $1" >&2; exit 1; }
            files+=("$1")
            shift
            ;;
    esac
done

[ "${#files[@]}" -gt 0 ] || usage

# awk 엔진 — annotation 라인을 stage 하고 fn decl 에서 flush.
awk -v filter_kind="$filter_kind" '
function json_escape(s,   r) {
    r = s
    gsub(/\\/, "\\\\", r)
    gsub(/"/, "\\\"", r)
    gsub(/\t/, "\\t", r)
    gsub(/\r/, "\\r", r)
    gsub(/\n/, "\\n", r)
    return r
}
function extract_all_kv(line, kv_keys, kv_vals,    tmp, k, v, n, i, ch) {
    # 모든 key=value 쌍을 수집 — depth 1 only
    n = 0
    delete kv_keys
    delete kv_vals
    tmp = line
    # find opening paren after @name (supports name with underscore)
    if (!match(tmp, /@[a-z_]+\(/)) return 0
    tmp = substr(tmp, RSTART + RLENGTH)
    while (1) {
        sub(/^[[:space:],]+/, "", tmp)
        if (length(tmp) == 0) break
        if (substr(tmp, 1, 1) == ")") break
        # key
        if (!match(tmp, /^[A-Za-z_][A-Za-z0-9_]*/)) break
        k = substr(tmp, 1, RLENGTH)
        tmp = substr(tmp, RLENGTH + 1)
        sub(/^[[:space:]]*=[[:space:]]*/, "", tmp)
        # value
        if (substr(tmp, 1, 1) == "\"") {
            v = ""
            i = 2
            while (i <= length(tmp)) {
                ch = substr(tmp, i, 1)
                if (ch == "\\" && i < length(tmp)) {
                    v = v substr(tmp, i, 2)
                    i += 2
                    continue
                }
                if (ch == "\"") break
                v = v ch
                i++
            }
            tmp = substr(tmp, i + 1)
            gsub(/\\"/, "\"", v)
            gsub(/\\\\/, "\\", v)
        } else {
            if (match(tmp, /[,)[:space:]]/)) {
                v = substr(tmp, 1, RSTART - 1)
                tmp = substr(tmp, RSTART)
            } else {
                v = tmp
                tmp = ""
            }
        }
        n++
        kv_keys[n] = k
        kv_vals[n] = v
    }
    return n
}

BEGIN {
    n_staged = 0
    total = 0
    cnt_interpret = 0
    cnt_align = 0
    cnt_adv = 0
    cnt_deploy = 0
    cnt_multi = 0
    cnt_welfare = 0
}

{
    is_interpret  = ($0 ~ /^[[:space:]]*@interpret([[:space:]]*\(|[[:space:]]*$)/)
    is_align      = ($0 ~ /^[[:space:]]*@align([[:space:]]*\(|[[:space:]]*$)/)
    is_adv        = ($0 ~ /^[[:space:]]*@adversarial_robust([[:space:]]*\(|[[:space:]]*$)/)
    is_deploy     = ($0 ~ /^[[:space:]]*@deploy_safe([[:space:]]*\(|[[:space:]]*$)/)
    is_multi      = ($0 ~ /^[[:space:]]*@multimodal_safe([[:space:]]*\(|[[:space:]]*$)/)
    is_welfare    = ($0 ~ /^[[:space:]]*@model_welfare([[:space:]]*\(|[[:space:]]*$)/)
    is_anno = (is_interpret || is_align || is_adv || is_deploy || is_multi || is_welfare)
    is_fn = ($0 ~ /^[[:space:]]*(pub[[:space:]]+)?fn[[:space:]]+[A-Za-z_][A-Za-z0-9_]*/)
    is_blank = ($0 ~ /^[[:space:]]*$/)
    is_comment = ($0 ~ /^[[:space:]]*(\/\/|#)/)
}

is_anno {
    line = $0
    kind = ""
    if      (is_interpret) kind = "interpret"
    else if (is_align)     kind = "align"
    else if (is_adv)       kind = "adversarial_robust"
    else if (is_deploy)    kind = "deploy_safe"
    else if (is_multi)     kind = "multimodal_safe"
    else if (is_welfare)   kind = "model_welfare"

    n_staged++
    staged_kind[n_staged] = kind
    staged_line[n_staged] = FNR
    staged_file[n_staged] = FILENAME

    # meta 수집 — depth 1 key=value
    delete kv_k
    delete kv_v
    nk = extract_all_kv(line, kv_k, kv_v)
    staged_nkv[n_staged] = nk
    for (i = 1; i <= nk; i++) {
        staged_k[n_staged, i] = kv_k[i]
        staged_v[n_staged, i] = kv_v[i]
    }
    next
}

is_fn && n_staged > 0 {
    # extract fn name
    fn_name = ""
    tmp = $0
    sub(/^[[:space:]]*(pub[[:space:]]+)?fn[[:space:]]+/, "", tmp)
    if (match(tmp, /^[A-Za-z_][A-Za-z0-9_]*/)) {
        fn_name = substr(tmp, 1, RLENGTH)
    }

    # emit each staged annotation (if filter matches)
    for (s = 1; s <= n_staged; s++) {
        k = staged_kind[s]
        if (filter_kind != "" && filter_kind != k) continue

        if (total > 0) printf ","
        total++
        if      (k == "interpret")          cnt_interpret++
        else if (k == "align")              cnt_align++
        else if (k == "adversarial_robust") cnt_adv++
        else if (k == "deploy_safe")        cnt_deploy++
        else if (k == "multimodal_safe")    cnt_multi++
        else if (k == "model_welfare")      cnt_welfare++

        printf "{"
        printf "\"kind\":\"%s\"", json_escape(k)
        printf ",\"fn\":\"%s\"", json_escape(fn_name)
        printf ",\"file\":\"%s\"", json_escape(staged_file[s])
        printf ",\"line\":%d", staged_line[s]
        printf ",\"meta\":{"
        nk = staged_nkv[s]
        for (i = 1; i <= nk; i++) {
            if (i > 1) printf ","
            printf "\"%s\":\"%s\"", json_escape(staged_k[s, i]), json_escape(staged_v[s, i])
        }
        printf "}"
        printf "}"
    }

    # reset staging
    for (s = 1; s <= n_staged; s++) {
        delete staged_kind[s]
        delete staged_line[s]
        delete staged_file[s]
        delete staged_nkv[s]
    }
    for (key in staged_k) delete staged_k[key]
    for (key in staged_v) delete staged_v[key]
    n_staged = 0
    next
}

# blank breaks the block (discard staging unless followed by more annos)
(!is_anno && !is_fn && !is_comment) {
    if (n_staged > 0 && is_blank) {
        for (s = 1; s <= n_staged; s++) {
            delete staged_kind[s]
            delete staged_line[s]
            delete staged_file[s]
            delete staged_nkv[s]
        }
        for (key in staged_k) delete staged_k[key]
        for (key in staged_v) delete staged_v[key]
        n_staged = 0
    }
}

END {
    printf "%d|%d|%d|%d|%d|%d|%d\n", cnt_interpret, cnt_align, cnt_adv, cnt_deploy, cnt_multi, cnt_welfare, total > "/dev/stderr"
}
' "${files[@]}" > /tmp/.hexa-safety.$$.body 2> /tmp/.hexa-safety.$$.summary

body="$(cat /tmp/.hexa-safety.$$.body 2>/dev/null || true)"
summary_line="$(cat /tmp/.hexa-safety.$$.summary 2>/dev/null || echo '0|0|0|0|0|0|0')"
rm -f /tmp/.hexa-safety.$$.body /tmp/.hexa-safety.$$.summary

IFS='|' read -r c_int c_ali c_adv c_dep c_mul c_wel c_total <<< "$summary_line"

printf '{"version":"0.1","source":"grep-mvp","annotations":[%s],"summary":{"interpret":%d,"align":%d,"adversarial_robust":%d,"deploy_safe":%d,"multimodal_safe":%d,"model_welfare":%d,"total":%d}}\n' \
    "$body" "${c_int:-0}" "${c_ali:-0}" "${c_adv:-0}" "${c_dep:-0}" "${c_mul:-0}" "${c_wel:-0}" "${c_total:-0}"
