#!/bin/bash
# hexa-learn — 학습 최적화 annotation 통합 수집기 (grep MVP, v0.1)
#
# 입력:
#   hexa-learn <file.hexa> [<file2.hexa> ...]
#   hexa-learn --dir <directory>
#   hexa-learn [--kind learn|curriculum|moe|chinchilla|synthetic_data] <files...>
#
# 출력 (stdout JSON):
#   { "version":"0.1", "source":"grep-mvp",
#     "annotations":[ {kind, fn, file, line, meta{...}} ],
#     "summary":{ learn, curriculum, moe, chinchilla, synthetic_data, total } }
#
# 인식 annotation (fn decl 바로 위 라인, stacking 허용):
#   @learn(lr=<float>, optimizer="<adamw|lion>", epochs=<int>)
#   @curriculum(stage="<easy|medium|hard>", order=<int>)
#   @moe(experts=<int>, top_k=<int>, gating="<softmax|topk>")
#   @chinchilla(token_param_ratio=<float>)
#   @synthetic_data(source="<model_id>", count=<int>, seed=<int>)
#
# exit 0 정상 (빈 annotations 포함). 1=인자 오류
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-learn [--kind learn|curriculum|moe|chinchilla|synthetic_data] <file.hexa> [file2.hexa ...]
       hexa-learn [--kind ...] --dir <directory>
EOF
    exit 1
}

filter_kind=""
files=()

# parse args
while [ $# -gt 0 ]; do
    case "$1" in
        --kind)
            shift
            [ $# -ge 1 ] || usage
            case "$1" in
                learn|curriculum|moe|chinchilla|synthetic_data) filter_kind="$1" ;;
                *) echo "ERROR: invalid kind: $1" >&2; usage ;;
            esac
            shift
            ;;
        --dir)
            shift
            [ $# -ge 1 ] || usage
            dir="$1"
            [ -d "$dir" ] || { echo "ERROR: directory not found: $dir" >&2; exit 1; }
            while IFS= read -r -d '' f; do files+=("$f"); done < <(find "$dir" -type f -not -path "*/.claude/*" -not -path "*/node_modules/*" -name "*.hexa" -print0)
            shift
            ;;
        -h|--help)
            usage
            ;;
        *)
            [ -f "$1" ] || { echo "ERROR: file not found: $1" >&2; exit 1; }
            files+=("$1")
            shift
            ;;
    esac
done

[ "${#files[@]}" -gt 0 ] || usage

# awk 엔진 — annotation 라인을 stage 하고 fn decl 에서 flush.
awk -v filter_kind="$filter_kind" '
function json_escape(s,   r) {
    r = s
    gsub(/\\/, "\\\\", r)
    gsub(/"/, "\\\"", r)
    gsub(/\t/, "\\t", r)
    gsub(/\r/, "\\r", r)
    gsub(/\n/, "\\n", r)
    return r
}
function extract_all_kv(line, kv_keys, kv_vals,    tmp, pos, rest, c, k, v, n, i, ch) {
    # 모든 key=value 쌍을 수집 — depth 1 only
    # strip leading @name( and trailing )
    n = 0
    delete kv_keys
    delete kv_vals
    tmp = line
    # find opening paren
    if (!match(tmp, /@[a-z_]+\(/)) return 0
    tmp = substr(tmp, RSTART + RLENGTH)
    # strip trailing ) optional — we just scan forward
    while (1) {
        sub(/^[[:space:],]+/, "", tmp)
        if (length(tmp) == 0) break
        if (substr(tmp, 1, 1) == ")") break
        # key
        if (!match(tmp, /^[A-Za-z_][A-Za-z0-9_]*/)) break
        k = substr(tmp, 1, RLENGTH)
        tmp = substr(tmp, RLENGTH + 1)
        sub(/^[[:space:]]*=[[:space:]]*/, "", tmp)
        # value
        if (substr(tmp, 1, 1) == "\"") {
            v = ""
            i = 2
            while (i <= length(tmp)) {
                ch = substr(tmp, i, 1)
                if (ch == "\\" && i < length(tmp)) {
                    v = v substr(tmp, i, 2)
                    i += 2
                    continue
                }
                if (ch == "\"") break
                v = v ch
                i++
            }
            tmp = substr(tmp, i + 1)
            gsub(/\\"/, "\"", v)
            gsub(/\\\\/, "\\", v)
        } else {
            if (match(tmp, /[,)[:space:]]/)) {
                v = substr(tmp, 1, RSTART - 1)
                tmp = substr(tmp, RSTART)
            } else {
                v = tmp
                tmp = ""
            }
        }
        n++
        kv_keys[n] = k
        kv_vals[n] = v
    }
    return n
}

BEGIN {
    n_staged = 0
    total = 0
    cnt_learn = 0
    cnt_curriculum = 0
    cnt_moe = 0
    cnt_chinchilla = 0
    cnt_synthetic_data = 0
}

{
    is_learn          = ($0 ~ /^[[:space:]]*@learn([[:space:]]*\(|[[:space:]]*$)/)
    is_curriculum     = ($0 ~ /^[[:space:]]*@curriculum([[:space:]]*\(|[[:space:]]*$)/)
    is_moe            = ($0 ~ /^[[:space:]]*@moe([[:space:]]*\(|[[:space:]]*$)/)
    is_chinchilla     = ($0 ~ /^[[:space:]]*@chinchilla([[:space:]]*\(|[[:space:]]*$)/)
    is_synthetic_data = ($0 ~ /^[[:space:]]*@synthetic_data([[:space:]]*\(|[[:space:]]*$)/)
    is_anno = (is_learn || is_curriculum || is_moe || is_chinchilla || is_synthetic_data)
    is_fn = ($0 ~ /^[[:space:]]*(pub[[:space:]]+)?fn[[:space:]]+[A-Za-z_][A-Za-z0-9_]*/)
    is_blank = ($0 ~ /^[[:space:]]*$/)
    is_comment = ($0 ~ /^[[:space:]]*(\/\/|#)/)
}

is_anno {
    line = $0
    kind = ""
    if      (is_learn)          kind = "learn"
    else if (is_curriculum)     kind = "curriculum"
    else if (is_moe)            kind = "moe"
    else if (is_chinchilla)     kind = "chinchilla"
    else if (is_synthetic_data) kind = "synthetic_data"

    n_staged++
    staged_kind[n_staged] = kind
    staged_line[n_staged] = FNR
    staged_file[n_staged] = FILENAME

    # meta 수집 — depth 1 key=value
    delete kv_k
    delete kv_v
    nk = extract_all_kv(line, kv_k, kv_v)
    staged_nkv[n_staged] = nk
    for (i = 1; i <= nk; i++) {
        staged_k[n_staged, i] = kv_k[i]
        staged_v[n_staged, i] = kv_v[i]
    }
    next
}

is_fn && n_staged > 0 {
    # extract fn name
    fn_name = ""
    tmp = $0
    sub(/^[[:space:]]*(pub[[:space:]]+)?fn[[:space:]]+/, "", tmp)
    if (match(tmp, /^[A-Za-z_][A-Za-z0-9_]*/)) {
        fn_name = substr(tmp, 1, RLENGTH)
    }

    # emit each staged annotation (if filter matches)
    for (s = 1; s <= n_staged; s++) {
        k = staged_kind[s]
        if (filter_kind != "" && filter_kind != k) continue

        if (total > 0) printf ","
        total++
        if      (k == "learn")          cnt_learn++
        else if (k == "curriculum")     cnt_curriculum++
        else if (k == "moe")            cnt_moe++
        else if (k == "chinchilla")     cnt_chinchilla++
        else if (k == "synthetic_data") cnt_synthetic_data++

        printf "{"
        printf "\"kind\":\"%s\"", json_escape(k)
        printf ",\"fn\":\"%s\"", json_escape(fn_name)
        printf ",\"file\":\"%s\"", json_escape(staged_file[s])
        printf ",\"line\":%d", staged_line[s]
        printf ",\"meta\":{"
        nk = staged_nkv[s]
        for (i = 1; i <= nk; i++) {
            if (i > 1) printf ","
            printf "\"%s\":\"%s\"", json_escape(staged_k[s, i]), json_escape(staged_v[s, i])
        }
        printf "}"
        printf "}"
    }

    # reset staging
    for (s = 1; s <= n_staged; s++) {
        delete staged_kind[s]
        delete staged_line[s]
        delete staged_file[s]
        delete staged_nkv[s]
    }
    # wipe 2D
    for (key in staged_k) delete staged_k[key]
    for (key in staged_v) delete staged_v[key]
    n_staged = 0
    next
}

# blank breaks the block (discard staging unless followed by more annos)
(!is_anno && !is_fn && !is_comment) {
    if (n_staged > 0 && is_blank) {
        for (s = 1; s <= n_staged; s++) {
            delete staged_kind[s]
            delete staged_line[s]
            delete staged_file[s]
            delete staged_nkv[s]
        }
        for (key in staged_k) delete staged_k[key]
        for (key in staged_v) delete staged_v[key]
        n_staged = 0
    }
}

END {
    # write summary to side channel (via tmpfile below)
    printf "%d|%d|%d|%d|%d|%d\n", cnt_learn, cnt_curriculum, cnt_moe, cnt_chinchilla, cnt_synthetic_data, total > "/dev/stderr"
}
' "${files[@]}" > /tmp/.hexa-learn.$$.body 2> /tmp/.hexa-learn.$$.summary

body="$(cat /tmp/.hexa-learn.$$.body 2>/dev/null || true)"
summary_line="$(cat /tmp/.hexa-learn.$$.summary 2>/dev/null || echo '0|0|0|0|0|0')"
rm -f /tmp/.hexa-learn.$$.body /tmp/.hexa-learn.$$.summary

IFS='|' read -r c_learn c_curr c_moe c_chin c_synth c_total <<< "$summary_line"

printf '{"version":"0.1","source":"grep-mvp","annotations":[%s],"summary":{"learn":%d,"curriculum":%d,"moe":%d,"chinchilla":%d,"synthetic_data":%d,"total":%d}}\n' \
    "$body" "${c_learn:-0}" "${c_curr:-0}" "${c_moe:-0}" "${c_chin:-0}" "${c_synth:-0}" "${c_total:-0}"
