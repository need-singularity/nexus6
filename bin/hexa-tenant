#!/bin/bash
# hexa-tenant — 엔터프라이즈 커스텀 annotation 수집기 (grep MVP, v0.1)
#
# 입력:
#   hexa-tenant <file.hexa> [<file2.hexa> ...]
#   hexa-tenant --dir <directory>
#   hexa-tenant [--kind adapter|hotswap|tenant_isolate|self_serve_portal] <files...>
#
# 출력 (stdout JSON):
#   { "version":"0.1", "source":"grep-mvp",
#     "annotations":[ {kind, fn, file, line, meta{...}} ],
#     "summary":{ adapter, hotswap, tenant_isolate, self_serve_portal, total } }
#
# 인식 annotation (fn decl 바로 위 라인, stacking 허용):
#   @adapter(tenant_id="<id>", base_model="<model>")
#   @hotswap(target="<name>", warmup_s=<int>)
#   @tenant_isolate(ns="<ns>", quota=<int>)
#   @self_serve_portal(auth=oauth|saml)
#
# exit 0 정상 (빈 annotations 포함). 1=인자 오류
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-tenant [--kind adapter|hotswap|tenant_isolate|self_serve_portal] <file.hexa> [file2.hexa ...]
       hexa-tenant [--kind ...] --dir <directory>
EOF
    exit 1
}

filter_kind=""
files=()

while [ $# -gt 0 ]; do
    case "$1" in
        --kind)
            shift
            [ $# -ge 1 ] || usage
            case "$1" in
                adapter|hotswap|tenant_isolate|self_serve_portal) filter_kind="$1" ;;
                *) echo "ERROR: invalid kind: $1" >&2; usage ;;
            esac
            shift
            ;;
        --dir)
            shift
            [ $# -ge 1 ] || usage
            dir="$1"
            [ -d "$dir" ] || { echo "ERROR: directory not found: $dir" >&2; exit 1; }
            while IFS= read -r -d '' f; do files+=("$f"); done < <(find "$dir" -type f -not -path "*/.claude/*" -not -path "*/node_modules/*" -name "*.hexa" -print0)
            shift
            ;;
        -h|--help)
            usage
            ;;
        *)
            [ -f "$1" ] || { echo "ERROR: file not found: $1" >&2; exit 1; }
            files+=("$1")
            shift
            ;;
    esac
done

[ "${#files[@]}" -gt 0 ] || usage

awk -v filter_kind="$filter_kind" '
function json_escape(s,   r) {
    r = s
    gsub(/\\/, "\\\\", r)
    gsub(/"/, "\\\"", r)
    gsub(/\t/, "\\t", r)
    gsub(/\r/, "\\r", r)
    gsub(/\n/, "\\n", r)
    return r
}
function extract_all_kv(line, kv_keys, kv_vals,    tmp, k, v, n, i, ch) {
    n = 0
    delete kv_keys
    delete kv_vals
    tmp = line
    if (!match(tmp, /@[a-z_]+\(/)) return 0
    tmp = substr(tmp, RSTART + RLENGTH)
    while (1) {
        sub(/^[[:space:],]+/, "", tmp)
        if (length(tmp) == 0) break
        if (substr(tmp, 1, 1) == ")") break
        if (!match(tmp, /^[A-Za-z_][A-Za-z0-9_]*/)) break
        k = substr(tmp, 1, RLENGTH)
        tmp = substr(tmp, RLENGTH + 1)
        sub(/^[[:space:]]*=[[:space:]]*/, "", tmp)
        if (substr(tmp, 1, 1) == "\"") {
            v = ""
            i = 2
            while (i <= length(tmp)) {
                ch = substr(tmp, i, 1)
                if (ch == "\\" && i < length(tmp)) {
                    v = v substr(tmp, i, 2)
                    i += 2
                    continue
                }
                if (ch == "\"") break
                v = v ch
                i++
            }
            tmp = substr(tmp, i + 1)
            gsub(/\\"/, "\"", v)
            gsub(/\\\\/, "\\", v)
        } else {
            if (match(tmp, /[,)[:space:]]/)) {
                v = substr(tmp, 1, RSTART - 1)
                tmp = substr(tmp, RSTART)
            } else {
                v = tmp
                tmp = ""
            }
        }
        n++
        kv_keys[n] = k
        kv_vals[n] = v
    }
    return n
}

BEGIN {
    n_staged = 0
    total = 0
    cnt_adapter = 0
    cnt_hotswap = 0
    cnt_tenant_isolate = 0
    cnt_self_serve_portal = 0
}

{
    is_adapter           = ($0 ~ /^[[:space:]]*@adapter([[:space:]]*\(|[[:space:]]*$)/)
    is_hotswap           = ($0 ~ /^[[:space:]]*@hotswap([[:space:]]*\(|[[:space:]]*$)/)
    is_tenant_isolate    = ($0 ~ /^[[:space:]]*@tenant_isolate([[:space:]]*\(|[[:space:]]*$)/)
    is_self_serve_portal = ($0 ~ /^[[:space:]]*@self_serve_portal([[:space:]]*\(|[[:space:]]*$)/)
    is_anno = (is_adapter || is_hotswap || is_tenant_isolate || is_self_serve_portal)
    is_fn = ($0 ~ /^[[:space:]]*(pub[[:space:]]+)?fn[[:space:]]+[A-Za-z_][A-Za-z0-9_]*/)
    is_blank = ($0 ~ /^[[:space:]]*$/)
    is_comment = ($0 ~ /^[[:space:]]*(\/\/|#)/)
}

is_anno {
    line = $0
    kind = ""
    if      (is_adapter)           kind = "adapter"
    else if (is_hotswap)           kind = "hotswap"
    else if (is_tenant_isolate)    kind = "tenant_isolate"
    else if (is_self_serve_portal) kind = "self_serve_portal"

    n_staged++
    staged_kind[n_staged] = kind
    staged_line[n_staged] = FNR
    staged_file[n_staged] = FILENAME

    delete kv_k
    delete kv_v
    nk = extract_all_kv(line, kv_k, kv_v)
    staged_nkv[n_staged] = nk
    for (i = 1; i <= nk; i++) {
        staged_k[n_staged, i] = kv_k[i]
        staged_v[n_staged, i] = kv_v[i]
    }
    next
}

is_fn && n_staged > 0 {
    fn_name = ""
    tmp = $0
    sub(/^[[:space:]]*(pub[[:space:]]+)?fn[[:space:]]+/, "", tmp)
    if (match(tmp, /^[A-Za-z_][A-Za-z0-9_]*/)) {
        fn_name = substr(tmp, 1, RLENGTH)
    }

    for (s = 1; s <= n_staged; s++) {
        k = staged_kind[s]
        if (filter_kind != "" && filter_kind != k) continue

        if (total > 0) printf ","
        total++
        if      (k == "adapter")           cnt_adapter++
        else if (k == "hotswap")           cnt_hotswap++
        else if (k == "tenant_isolate")    cnt_tenant_isolate++
        else if (k == "self_serve_portal") cnt_self_serve_portal++

        printf "{"
        printf "\"kind\":\"%s\"", json_escape(k)
        printf ",\"fn\":\"%s\"", json_escape(fn_name)
        printf ",\"file\":\"%s\"", json_escape(staged_file[s])
        printf ",\"line\":%d", staged_line[s]
        printf ",\"meta\":{"
        nk = staged_nkv[s]
        for (i = 1; i <= nk; i++) {
            if (i > 1) printf ","
            printf "\"%s\":\"%s\"", json_escape(staged_k[s, i]), json_escape(staged_v[s, i])
        }
        printf "}"
        printf "}"
    }

    for (s = 1; s <= n_staged; s++) {
        delete staged_kind[s]
        delete staged_line[s]
        delete staged_file[s]
        delete staged_nkv[s]
    }
    for (key in staged_k) delete staged_k[key]
    for (key in staged_v) delete staged_v[key]
    n_staged = 0
    next
}

(!is_anno && !is_fn && !is_comment) {
    if (n_staged > 0 && is_blank) {
        for (s = 1; s <= n_staged; s++) {
            delete staged_kind[s]
            delete staged_line[s]
            delete staged_file[s]
            delete staged_nkv[s]
        }
        for (key in staged_k) delete staged_k[key]
        for (key in staged_v) delete staged_v[key]
        n_staged = 0
    }
}

END {
    printf "%d|%d|%d|%d|%d\n", cnt_adapter, cnt_hotswap, cnt_tenant_isolate, cnt_self_serve_portal, total > "/dev/stderr"
}
' "${files[@]}" > /tmp/.hexa-tenant.$$.body 2> /tmp/.hexa-tenant.$$.summary

body="$(cat /tmp/.hexa-tenant.$$.body 2>/dev/null || true)"
summary_line="$(cat /tmp/.hexa-tenant.$$.summary 2>/dev/null || echo '0|0|0|0|0')"
rm -f /tmp/.hexa-tenant.$$.body /tmp/.hexa-tenant.$$.summary

IFS='|' read -r c_ad c_hs c_ti c_sp c_total <<< "$summary_line"

printf '{"version":"0.1","source":"grep-mvp","annotations":[%s],"summary":{"adapter":%d,"hotswap":%d,"tenant_isolate":%d,"self_serve_portal":%d,"total":%d}}\n' \
    "$body" "${c_ad:-0}" "${c_hs:-0}" "${c_ti:-0}" "${c_sp:-0}" "${c_total:-0}"
