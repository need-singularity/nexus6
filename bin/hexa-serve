#!/bin/bash
# hexa-serve — 에이전트 서빙 annotation 수집기 (grep MVP, v0.1)
#
# 입력:
#   hexa-serve <file.hexa> [<file2.hexa> ...]
#   hexa-serve --dir <directory>
#   hexa-serve [--kind ctx_compress|tool_cache|session_migrate|route_agent] <files...>
#
# 출력 (stdout JSON):
#   { "version":"0.1", "source":"grep-mvp",
#     "annotations":[ {kind, fn, file, line, meta{...}} ],
#     "summary":{ ctx_compress, tool_cache, session_migrate, route_agent, total } }
#
# 인식 annotation (fn decl 바로 위 라인, stacking 허용):
#   @ctx_compress(ratio=<float>, kv_retain=<int>)
#   @tool_cache(ttl_s=<int>, lru_cap=<int>)
#   @session_migrate(from_model="<id>", to_model="<id>", preserve_ctx=<bool>)
#   @route_agent(tier=cheap|fast|smart)
#
# exit 0 정상 (빈 annotations 포함). 1=인자 오류
set -eu

usage() {
    cat >&2 <<EOF
usage: hexa-serve [--kind ctx_compress|tool_cache|session_migrate|route_agent] <file.hexa> [file2.hexa ...]
       hexa-serve [--kind ...] --dir <directory>
EOF
    exit 1
}

filter_kind=""
files=()

while [ $# -gt 0 ]; do
    case "$1" in
        --kind)
            shift
            [ $# -ge 1 ] || usage
            case "$1" in
                ctx_compress|tool_cache|session_migrate|route_agent) filter_kind="$1" ;;
                *) echo "ERROR: invalid kind: $1" >&2; usage ;;
            esac
            shift
            ;;
        --dir)
            shift
            [ $# -ge 1 ] || usage
            dir="$1"
            [ -d "$dir" ] || { echo "ERROR: directory not found: $dir" >&2; exit 1; }
            while IFS= read -r -d '' f; do files+=("$f"); done < <(find "$dir" -type f -not -path "*/.claude/*" -not -path "*/node_modules/*" -name "*.hexa" -print0)
            shift
            ;;
        -h|--help)
            usage
            ;;
        *)
            [ -f "$1" ] || { echo "ERROR: file not found: $1" >&2; exit 1; }
            files+=("$1")
            shift
            ;;
    esac
done

[ "${#files[@]}" -gt 0 ] || usage

awk -v filter_kind="$filter_kind" '
function json_escape(s,   r) {
    r = s
    gsub(/\\/, "\\\\", r)
    gsub(/"/, "\\\"", r)
    gsub(/\t/, "\\t", r)
    gsub(/\r/, "\\r", r)
    gsub(/\n/, "\\n", r)
    return r
}
function extract_all_kv(line, kv_keys, kv_vals,    tmp, k, v, n, i, ch) {
    n = 0
    delete kv_keys
    delete kv_vals
    tmp = line
    if (!match(tmp, /@[a-z_]+\(/)) return 0
    tmp = substr(tmp, RSTART + RLENGTH)
    while (1) {
        sub(/^[[:space:],]+/, "", tmp)
        if (length(tmp) == 0) break
        if (substr(tmp, 1, 1) == ")") break
        if (!match(tmp, /^[A-Za-z_][A-Za-z0-9_]*/)) break
        k = substr(tmp, 1, RLENGTH)
        tmp = substr(tmp, RLENGTH + 1)
        sub(/^[[:space:]]*=[[:space:]]*/, "", tmp)
        if (substr(tmp, 1, 1) == "\"") {
            v = ""
            i = 2
            while (i <= length(tmp)) {
                ch = substr(tmp, i, 1)
                if (ch == "\\" && i < length(tmp)) {
                    v = v substr(tmp, i, 2)
                    i += 2
                    continue
                }
                if (ch == "\"") break
                v = v ch
                i++
            }
            tmp = substr(tmp, i + 1)
            gsub(/\\"/, "\"", v)
            gsub(/\\\\/, "\\", v)
        } else {
            if (match(tmp, /[,)[:space:]]/)) {
                v = substr(tmp, 1, RSTART - 1)
                tmp = substr(tmp, RSTART)
            } else {
                v = tmp
                tmp = ""
            }
        }
        n++
        kv_keys[n] = k
        kv_vals[n] = v
    }
    return n
}

BEGIN {
    n_staged = 0
    total = 0
    cnt_ctx_compress = 0
    cnt_tool_cache = 0
    cnt_session_migrate = 0
    cnt_route_agent = 0
}

{
    is_ctx_compress    = ($0 ~ /^[[:space:]]*@ctx_compress([[:space:]]*\(|[[:space:]]*$)/)
    is_tool_cache      = ($0 ~ /^[[:space:]]*@tool_cache([[:space:]]*\(|[[:space:]]*$)/)
    is_session_migrate = ($0 ~ /^[[:space:]]*@session_migrate([[:space:]]*\(|[[:space:]]*$)/)
    is_route_agent     = ($0 ~ /^[[:space:]]*@route_agent([[:space:]]*\(|[[:space:]]*$)/)
    is_anno = (is_ctx_compress || is_tool_cache || is_session_migrate || is_route_agent)
    is_fn = ($0 ~ /^[[:space:]]*(pub[[:space:]]+)?fn[[:space:]]+[A-Za-z_][A-Za-z0-9_]*/)
    is_blank = ($0 ~ /^[[:space:]]*$/)
    is_comment = ($0 ~ /^[[:space:]]*(\/\/|#)/)
}

is_anno {
    line = $0
    kind = ""
    if      (is_ctx_compress)    kind = "ctx_compress"
    else if (is_tool_cache)      kind = "tool_cache"
    else if (is_session_migrate) kind = "session_migrate"
    else if (is_route_agent)     kind = "route_agent"

    n_staged++
    staged_kind[n_staged] = kind
    staged_line[n_staged] = FNR
    staged_file[n_staged] = FILENAME

    delete kv_k
    delete kv_v
    nk = extract_all_kv(line, kv_k, kv_v)
    staged_nkv[n_staged] = nk
    for (i = 1; i <= nk; i++) {
        staged_k[n_staged, i] = kv_k[i]
        staged_v[n_staged, i] = kv_v[i]
    }
    next
}

is_fn && n_staged > 0 {
    fn_name = ""
    tmp = $0
    sub(/^[[:space:]]*(pub[[:space:]]+)?fn[[:space:]]+/, "", tmp)
    if (match(tmp, /^[A-Za-z_][A-Za-z0-9_]*/)) {
        fn_name = substr(tmp, 1, RLENGTH)
    }

    for (s = 1; s <= n_staged; s++) {
        k = staged_kind[s]
        if (filter_kind != "" && filter_kind != k) continue

        if (total > 0) printf ","
        total++
        if      (k == "ctx_compress")    cnt_ctx_compress++
        else if (k == "tool_cache")      cnt_tool_cache++
        else if (k == "session_migrate") cnt_session_migrate++
        else if (k == "route_agent")     cnt_route_agent++

        printf "{"
        printf "\"kind\":\"%s\"", json_escape(k)
        printf ",\"fn\":\"%s\"", json_escape(fn_name)
        printf ",\"file\":\"%s\"", json_escape(staged_file[s])
        printf ",\"line\":%d", staged_line[s]
        printf ",\"meta\":{"
        nk = staged_nkv[s]
        for (i = 1; i <= nk; i++) {
            if (i > 1) printf ","
            printf "\"%s\":\"%s\"", json_escape(staged_k[s, i]), json_escape(staged_v[s, i])
        }
        printf "}"
        printf "}"
    }

    for (s = 1; s <= n_staged; s++) {
        delete staged_kind[s]
        delete staged_line[s]
        delete staged_file[s]
        delete staged_nkv[s]
    }
    for (key in staged_k) delete staged_k[key]
    for (key in staged_v) delete staged_v[key]
    n_staged = 0
    next
}

(!is_anno && !is_fn && !is_comment) {
    if (n_staged > 0 && is_blank) {
        for (s = 1; s <= n_staged; s++) {
            delete staged_kind[s]
            delete staged_line[s]
            delete staged_file[s]
            delete staged_nkv[s]
        }
        for (key in staged_k) delete staged_k[key]
        for (key in staged_v) delete staged_v[key]
        n_staged = 0
    }
}

END {
    printf "%d|%d|%d|%d|%d\n", cnt_ctx_compress, cnt_tool_cache, cnt_session_migrate, cnt_route_agent, total > "/dev/stderr"
}
' "${files[@]}" > /tmp/.hexa-serve.$$.body 2> /tmp/.hexa-serve.$$.summary

body="$(cat /tmp/.hexa-serve.$$.body 2>/dev/null || true)"
summary_line="$(cat /tmp/.hexa-serve.$$.summary 2>/dev/null || echo '0|0|0|0|0')"
rm -f /tmp/.hexa-serve.$$.body /tmp/.hexa-serve.$$.summary

IFS='|' read -r c_ctx c_tool c_sess c_route c_total <<< "$summary_line"

printf '{"version":"0.1","source":"grep-mvp","annotations":[%s],"summary":{"ctx_compress":%d,"tool_cache":%d,"session_migrate":%d,"route_agent":%d,"total":%d}}\n' \
    "$body" "${c_ctx:-0}" "${c_tool:-0}" "${c_sess:-0}" "${c_route:-0}" "${c_total:-0}"
