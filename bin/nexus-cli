#!/bin/bash
# nexus-cli — 외부 프로젝트(hive 등) 전용 단일 CLI 진입점
# thin wrapper: hexa resolver 경유로 engine/nexus_cli.hexa 호출
# spec: engine/nexus_cli_spec.json
#
# usage: nexus-cli <subcmd> [flags...]
# exit codes: 0=성공 1=실행오류 2=인자오류 3=gate거부

set -e

NEXUS_ROOT="${NEXUS:-${HOME}/Dev/nexus}"
HEXA="${NEXUS_ROOT}/bin/hexa"
ENGINE="${NEXUS_ROOT}/engine/nexus_cli.hexa"

if [ ! -x "$HEXA" ]; then
    echo "ERROR(nexus-cli): hexa resolver 부재: $HEXA" >&2
    exit 127
fi

if [ ! -f "$ENGINE" ]; then
    echo "ERROR(nexus-cli): engine 부재: $ENGINE" >&2
    exit 127
fi

# --catalog: bypass hexa runtime to emit pure JSON (no runtime banner)
# spec sidecar SSOT. hive dynamic loader uses this.
if [ "${1:-}" = "--catalog" ]; then
    SPEC="${NEXUS_ROOT}/engine/nexus_cli_spec.json"
    if [ ! -f "$SPEC" ]; then
        echo "ERROR(nexus-cli --catalog): spec not found: $SPEC" >&2
        exit 1
    fi
    exec cat "$SPEC"
fi

# --contracts: integration invariants L0 (타프로젝트 실시간 인지용)
if [ "${1:-}" = "--contracts" ]; then
    CONTRACTS="${NEXUS_ROOT}/convergence/integration_contracts.json"
    if [ ! -f "$CONTRACTS" ]; then
        echo "ERROR(nexus-cli --contracts): contracts not found: $CONTRACTS" >&2
        exit 1
    fi
    exec cat "$CONTRACTS"
fi

# --verify: I1~I8 invariants 자동 검증 (위반 시 exit 1)
if [ "${1:-}" = "--verify" ]; then
    exec "$HEXA" run "${NEXUS_ROOT}/harness/verify_integration_contracts.hexa"
fi

# --sync: run.hexa cmd_* ↔ spec drift 검출 (--apply 로 spec 자동 갱신)
if [ "${1:-}" = "--sync" ]; then
    shift
    exec "$HEXA" run "${NEXUS_ROOT}/harness/sync_cli_spec.hexa" "$@"
fi

# `check` 는 nested hexa exec 패턴 (router → backend) 이라 원격 라우팅 시
# 원격 PATH 에 hexa 가 없어 실패. 로컬 강제 (raw 81 reachability override).
if [ "${1:-}" = "check" ]; then
    export HEXA_LOCAL=1
fi

exec "$HEXA" run "$ENGINE" "$@"
