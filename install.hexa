// install.hexa — hx build hook for nexus.
//
// Invoked by `hx install nexus` (hexa-lang package manager) right after
// the GitHub checkout (or symlink from ~/core/nexus) lands in $HX_PKG_DIR.
//
// hx passes:
//   HX_PKG_DIR   — absolute path to the package root
//   HX_BIN_DIR   — ~/.hx/bin
//   HX_PKG_NAME  — "nexus"
//
// Responsibilities (each idempotent):
//   1. Bootstrap runtime-package dependencies declared in hexa.toml
//      [dependencies] — currently: qmirror (^1.0.0), sim-universe (^1.0.0),
//      hexa-bio (^1.0.0), qrng (^1.0.0), mc-integrate (^1.0.0).
//      (honesty-monitor removed 2026-05-06 — absorbed into nexus check as
//      BT-AI2 auto-audit; see hexa.toml comment.)
//      Skipped when the dep CLI is already on PATH (idempotent re-install safe).
//   2. Verify canonical entry cli/run.hexa exists.
//   3. Ensure ~/.hx/bin/nexus shim points at $HX_PKG_DIR/cli/run.hexa
//      (hx generates this after the hook returns; this file only
//      performs verification + workspace registration — no shim write).
//   4. Register nexus as command in ~/core/.workspace (if present).
//   5. Guarded install of com.hexa.nexus-guard.plist LaunchAgent
//      (only if nexus/launchd/ provides the plist template).
//
// raw#9 hexa-only, raw#11 snake_case, raw#15 no-hardcode (HX_PKG_DIR-relative).

fn main() -> void {
    let mut root = env("HX_PKG_DIR")
    if root == "" { root = exec("pwd").trim() }
    println("[nexus/install] HX_PKG_DIR=" + root)

    // Phase 1: bootstrap runtime-package deps declared in hexa.toml.
    // Single source of truth = hexa.toml [dependencies]; this loop is the
    // imperative bootstrap until hx CLI grows nested-dep resolution.
    ensure_runtime_dep("qmirror", "^1.0.0")
    ensure_runtime_dep("sim-universe", "^1.0.0")
    ensure_runtime_dep("hexa-bio", "^1.0.0")
    // honesty-monitor removed 2026-05-06 — absorbed into nexus check as
    // BT-AI2 auto-audit (engine/nexus_cli.hexa bt_ai2_audit_run). See hexa.toml.
    ensure_runtime_dep("qrng", "^1.0.0")
    ensure_runtime_dep("mc-integrate", "^1.0.0")
    // NOTE: anima-agent removed 2026-05-04 — standalone is partial carve-out
    // (scaffold only; 30 origin files missing). See hexa.toml note above
    // mc-integrate entry. anima-agent treated as anima-monorepo-internal
    // until future hard-cut backport cycle.

    let entry_src = root + "/cli/run.hexa"
    if file_exists(entry_src) == false {
        eprintln("[nexus/install] ERROR: canonical entry missing: " + entry_src)
        exit(1)
    }
    println("[nexus/install] canonical entry OK: cli/run.hexa")

    ensure_workspace_command(root)
    maybe_install_launchd(root)

    println("[nexus/install] done — hx will generate " + env("HX_BIN_DIR") + "/nexus shim from registry entry")
}

// Idempotent runtime-package dep bootstrap.
// Skips when the dep CLI is already on PATH (or already in $HX_BIN_DIR);
// otherwise invokes `hx install <pkg>`. Failure is non-fatal — nexus
// scripts that need the dep will surface their own error at call time
// (raw#10: avoid cascading install-time aborts on optional substrates).
fn ensure_runtime_dep(pkg: string, semver: string) -> void {
    println("[nexus/install] dep check: " + pkg + " " + semver)
    let on_path = exec("command -v '" + pkg + "' >/dev/null 2>&1 && echo y || echo n").trim()
    if on_path == "y" {
        println("[nexus/install] dep " + pkg + " already on PATH — skip hx install")
        return
    }
    let hx_bin = env("HX_BIN_DIR")
    if hx_bin != "" {
        let shim = hx_bin + "/" + pkg
        if file_exists(shim) {
            println("[nexus/install] dep " + pkg + " present at " + shim + " — skip hx install")
            return
        }
    }
    let hx_present = exec("command -v hx >/dev/null 2>&1 && echo y || echo n").trim()
    if hx_present == "n" {
        eprintln("[nexus/install] WARN: hx CLI not on PATH — cannot install " + pkg + " (manual: hx install " + pkg + ")")
        return
    }
    println("[nexus/install] installing dep: hx install " + pkg)
    let rc = exec("hx install '" + pkg + "' 2>&1; echo __rc=$?").trim()
    if rc.contains("__rc=0") {
        println("[nexus/install] dep " + pkg + " installed OK")
    } else {
        eprintln("[nexus/install] WARN: hx install " + pkg + " did not exit clean — continuing (nexus runtime modules will surface errors if dep is required)")
    }
}

// Register `command nexus` block in ~/core/.workspace (idempotent).
// Adds the block only when absent — keeps workspace_sync lint clean.
fn ensure_workspace_command(root: string) -> void {
    let ws = env("HOME") + "/core/.workspace"
    if file_exists(ws) == false {
        println("[nexus/install] ~/core/.workspace not found — skip workspace register")
        return
    }
    let present = exec("grep -qE '^command nexus ' '" + ws + "' && echo y || echo n").trim()
    if present == "y" {
        println("[nexus/install] workspace: command nexus already registered")
        return
    }
    let block = "\ncommand nexus \"nexus perfect-number engine (n6-guard auto-start, drill/thinking/smash)\"\n" +
                "  owner    nexus\n" +
                "  bin      nexus\n" +
                "  entry    cli/run.hexa\n" +
                "  source   cli/run.hexa\n" +
                "  keywords nexus drill thinking smash absolute\n"
    let quoted = block.replace("'", "'\\''")
    let _ = exec("printf '%s' '" + quoted + "' >> '" + ws + "'")
    println("[nexus/install] appended command nexus to ~/core/.workspace")
    let sync = env("HOME") + "/core/hexa-lang/tool/workspace_sync.hexa"
    if file_exists(sync) {
        let _ = exec("hexa '" + sync + "' --regen-lock 2>/dev/null || true")
    }
}

// Install launchd plist template if present (idempotent; skip if already loaded).
fn maybe_install_launchd(root: string) -> void {
    let plist_src = root + "/launchd/com.hexa.nexus-guard.plist.template"
    if file_exists(plist_src) == false { return }
    let plist_dst = env("HOME") + "/Library/LaunchAgents/com.hexa.nexus-guard.plist"
    if file_exists(plist_dst) {
        println("[nexus/install] launchd plist already present — skip")
        return
    }
    let _ = exec("cp '" + plist_src + "' '" + plist_dst + "'")
    println("[nexus/install] launchd plist staged (not loaded — user opts in via launchctl bootstrap)")
}
