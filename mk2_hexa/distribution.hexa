// mk2_hexa/distribution.hexa — (d,r) 히스토그램 + ρ (draft)
// Rust 원본: src/alien_index/distribution.rs
// 의존: record.hexa, alien_index.hexa

struct HistogramBucket {
    d: int,
    r: int,
    count: int
}

// 레코드 배열 → (d,r) 버킷 카운트. (sorted by (d,r))
fn histogram(records) {
    let mut buckets = []
    let mut i = 0
    while i < len(records) {
        let d = records[i].current.d
        let r = records[i].current.r
        // 기존 버킷 찾기
        let mut found = false
        let mut j = 0
        while j < len(buckets) {
            if buckets[j].d == d && buckets[j].r == r {
                let mut b = buckets[j]
                b.count = b.count + 1
                buckets[j] = b
                found = true
                j = len(buckets)
            }
            j = j + 1
        }
        if !found {
            buckets = buckets.push(HistogramBucket { d: d, r: r, count: 1 })
        }
        i = i + 1
    }
    // 정렬 생략 (stdlib 정렬 루틴 대기 — TODO)
    return buckets
}

// (d,r) 내림차순 leaderboard. limit 상한.
fn leaderboard(records, limit) {
    let mut sorted = records
    // bubble sort (HEXA stdlib sort 대기 — TODO)
    let mut i = 0
    while i < len(sorted) {
        let mut j = 0
        while j < len(sorted) - 1 - i {
            let a = sorted[j].current
            let b = sorted[j + 1].current
            // descending: swap if a < b
            let swap = false
            if a.d < b.d { swap = true }
            if a.d == b.d && a.r < b.r { swap = true }
            if swap {
                let tmp = sorted[j]
                sorted[j] = sorted[j + 1]
                sorted[j + 1] = tmp
            }
            j = j + 1
        }
        i = i + 1
    }
    // truncate
    let mut out = []
    let mut k = 0
    while k < len(sorted) && k < limit {
        out = out.push(sorted[k])
        k = k + 1
    }
    return out
}

// ρ = |{d ≥ 1}| / |total|. 메타 FP 타겟 = 1/3.
fn breakthrough_ratio(records) {
    if len(records) == 0 { return 0.0 }
    let mut bt = 0
    let mut i = 0
    while i < len(records) {
        if records[i].current.d >= 1 { bt = bt + 1 }
        i = i + 1
    }
    return (bt * 1.0) / (len(records) * 1.0)
}

// 메타 FP 대비 오차.
fn rho_vs_meta_fp(records) {
    let rho = breakthrough_ratio(records)
    let target = 1.0 / 3.0
    let diff = rho - target
    if diff < 0.0 { diff = -diff }
    return diff
}
