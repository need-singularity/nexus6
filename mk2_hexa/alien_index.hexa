// mk2_hexa/alien_index.hexa — AlienIndex(d, r) (draft)
// Rust 원본: src/alien_index/index.rs
// 목적: (d=사이클 깊이, r=검증 등급 0..10) 통합 등급.
//       r=10 도달 시 자기유사 (d+1, 0) 으로 승격.

struct AlienIndex {
    d: int,    // cycle depth
    r: int     // grade within depth, 0..=10
}

fn alien_index_new(d, r) {
    // caller responsibility: 0 <= r <= 10
    return AlienIndex { d: d, r: r }
}

// True iff r == 10 (promotion eligible).
fn alien_can_promote(ai) {
    return ai.r == 10
}

// Promote (d, 10) → (d+1, 0). Returns empty-sentinel (d=-1) if not eligible.
fn alien_breakthrough(ai) {
    if alien_can_promote(ai) {
        return alien_index_new(ai.d + 1, 0)
    }
    return alien_index_new(-1, 0)  // sentinel: not promoted
}

fn alien_is_sentinel(ai) {
    return ai.d == -1
}

fn alien_to_string(ai) {
    return "(" + to_string(ai.d) + ", " + to_string(ai.r) + ")"
}
