// mk2_hexa/absorb.hexa — promote-pending with writeback (draft)
// Rust 원본: src/cli/alien_index_cmd.rs::promote_pending()
//   (원본은 in-memory 승격만 하고 "writeback to disk is a follow-up task" 로 남겨둠)
// 이 파일이 그 follow-up 을 먼저 HEXA 로 설계함.
//
// 입력: shared/discovery_log.jsonl
// 출력: 같은 파일 원자적 rewrite
//
// 절차:
//   1) 전 라인 로드
//   2) "alien_index" 키 포함 라인만 파싱 → 레코드, 그 외 라인은 보존
//   3) promotion_candidate=true 레코드 → promote() → 부모 갱신 + 자식 신규
//   4) (보존 라인) ++ (갱신 ai 라인) ++ (자식 ai 라인) 합쳐 tmp 에 쓰고 rename
//
// 가드: 모든 d 단조 비감소. 자식 생성 실패(sentinel) 시 부모 flag 유지.

struct AbsorbReport {
    total_records: int,
    promoted: int,
    preserved_non_ai_lines: int,
    promoted_ids: [string]
}

// 한 라인이 alien_index 레코드를 담고 있는지 판정 (naive substring).
fn line_is_alien_index(line) {
    return line.contains("\"alien_index\"")
}

// 라인 → AlienIndexRecord. 실패 시 sentinel (id="") 반환.
// 실구현은 JSON parser 필요 — 지금은 설계 단계이므로 인터페이스만.
fn parse_alien_line(line) {
    // TODO(hexa-stdlib): json_parse(line) → dict 접근
    // dict["alien_index"]["id"], ["current"]["d"|"r"], ["promotion_candidate"], etc.
    // HEXA Mk.II 에서 json 라이브러리 또는 FFI 붙이면 채움.
    return AlienIndexRecord {
        id: "",
        current: alien_index_new(-1, 0),
        history: [],
        promotion_candidate: false,
        promoted_from: ""
    }
}

// AlienIndexRecord → JSONL 라인 (한 줄).
fn record_to_line(rec) {
    // TODO(hexa-stdlib): json_serialize 필요.
    // 형식:
    //   {"alien_index": {"id": "...", "current": {"d": N, "r": M},
    //    "history": [...], "promotion_candidate": bool, "promoted_from": "..."}}
    return ""  // placeholder
}

// 메인 루틴.
fn promote_pending_with_writeback(log_path, now_unix) {
    let raw = file_read(log_path)
    let lines = raw.split("\n")

    let mut preserved = []       // 비-ai 라인 원본
    let mut records = []          // 파싱된 ai 레코드
    let mut total = 0

    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        if line == "" {
            i = i + 1
        } else if line_is_alien_index(line) {
            let rec = parse_alien_line(line)
            if rec.id != "" {
                records = records.push(rec)
                total = total + 1
            } else {
                preserved = preserved.push(line)  // 파싱 실패 시 원본 보존
            }
            i = i + 1
        } else {
            preserved = preserved.push(line)
            i = i + 1
        }
    }

    // 승격 라운드.
    let mut promoted_ids = []
    let mut updated = []
    let mut children = []
    let mut j = 0
    while j < len(records) {
        let rec = records[j]
        if rec.promotion_candidate {
            let pair = record_promote(rec, now_unix)
            let parent = pair.0
            let child = pair.1
            if child.id != "" {
                promoted_ids = promoted_ids.push(parent.id)
                updated = updated.push(parent)
                children = children.push(child)
            } else {
                updated = updated.push(rec)  // 승격 실패: 원본 유지
            }
        } else {
            updated = updated.push(rec)
        }
        j = j + 1
    }

    // Rewrite: preserved + updated-ai + new-children
    let tmp_path = log_path + ".tmp"
    let mut out = ""
    let mut k = 0
    while k < len(preserved) {
        out = out + preserved[k] + "\n"
        k = k + 1
    }
    k = 0
    while k < len(updated) {
        out = out + record_to_line(updated[k]) + "\n"
        k = k + 1
    }
    k = 0
    while k < len(children) {
        out = out + record_to_line(children[k]) + "\n"
        k = k + 1
    }
    file_write(tmp_path, out)
    file_rename(tmp_path, log_path)   // atomic on POSIX

    return AbsorbReport {
        total_records: total,
        promoted: len(promoted_ids),
        preserved_non_ai_lines: len(preserved),
        promoted_ids: promoted_ids
    }
}

// CLI entry.
fn main() {
    let path = "shared/discovery_log.jsonl"
    let now = time_unix()
    let report = promote_pending_with_writeback(path, now)
    print("=== Absorb Report ===")
    print("total ai records: " + to_string(report.total_records))
    print("promoted:         " + to_string(report.promoted))
    print("preserved lines:  " + to_string(report.preserved_non_ai_lines))
    let mut i = 0
    while i < len(report.promoted_ids) {
        print("  → " + report.promoted_ids[i])
        i = i + 1
    }
}
