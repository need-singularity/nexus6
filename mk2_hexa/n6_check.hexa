// mk2_hexa/n6_check.hexa — n6_match wrapper (draft)
// Rust 원본: src/verifier/n6_check.rs (mk2 흡수 완료된 껍데기)
// 의존: smooth.hexa, primes.hexa, rational.hexa
//
// 의도: mk1 API 표면 유지 (n6_match(value) → (name, quality)).
//       내부적으로 smooth(φ,σ,τ) + euler_ratio 기반 계산.

struct N6Match {
    name: string,
    quality: float      // 1.0 EXACT / 0.8 CLOSE / 0.5 WEAK / 0.0 NONE
}

// n=6 기본 상수 테이블 — smooth 함수로 실시간 계산.
fn n6_constants() {
    // smooth_self_test() 가 보증하는 기본값들을 초기화.
    let s = sigma(6)          // 12
    let p = phi(6)            // 2
    let t = tau(6)            // 4
    let sf = sopfr(6)         // 5
    return [
        ("n",         6.0),
        ("sigma",     s * 1.0),
        ("phi",       p * 1.0),
        ("tau",       t * 1.0),
        ("sopfr",     sf * 1.0),
        ("J2",        (s * 2) * 1.0),      // 24
        ("sigma-tau", (s - t) * 1.0),      // 8
        ("sigma-phi", (s - p) * 1.0),      // 10
        ("sigma*tau", (s * t) * 1.0),      // 48
        ("sigma^2",   (s * s) * 1.0),      // 144
        ("sigma*phi", (s * p) * 1.0),      // 24
        ("n/tau",     (6 * 1.0) / (t * 1.0)), // 1.5
        ("n/phi",     (6 * 1.0) / (p * 1.0)), // 3.0
        ("1/n",       1.0 / 6.0),
        ("1/sigma",   1.0 / 12.0),
        ("Omega_m (meta FP)", 1.0 / 3.0),
        ("Omega_Lambda",      2.0 / 3.0)
    ]
}

// 상대오차 기반 quality 판정.
fn quality_from_rel_err(rel_err) {
    if rel_err < 0.001 { return 1.0 }   // EXACT
    if rel_err < 0.05  { return 0.8 }   // CLOSE
    if rel_err < 0.10  { return 0.5 }   // WEAK
    return 0.0                           // NONE
}

// 값 → 가장 가까운 n6 상수 매치.
fn n6_match(value) {
    let table = n6_constants()
    let mut best_name = "none"
    let mut best_quality = 0.0
    let mut i = 0
    while i < len(table) {
        let entry = table[i]
        let name = entry.0
        let ref_val = entry.1
        let diff = value - ref_val
        if diff < 0.0 { diff = -diff }
        let base = ref_val
        if base < 0.0 { base = -base }
        if base < 0.0000001 { base = 1.0 }
        let rel = diff / base
        let q = quality_from_rel_err(rel)
        if q > best_quality {
            best_quality = q
            best_name = name
            if q >= 1.0 { return N6Match { name: name, quality: 1.0 } }
        }
        i = i + 1
    }
    return N6Match { name: best_name, quality: best_quality }
}

// EXACT 비율 — values 중 quality==1.0 인 것의 분율.
fn n6_exact_ratio(values) {
    if len(values) == 0 { return 0.0 }
    let mut hits = 0
    let mut i = 0
    while i < len(values) {
        let m = n6_match(values[i])
        if m.quality >= 1.0 { hits = hits + 1 }
        i = i + 1
    }
    return (hits * 1.0) / (len(values) * 1.0)
}

// 축소사상 반복: I_{k+1} = α·I_k + β → 부동점.
fn meta_iterate(initial, alpha, beta, tol, max_steps) {
    let mut val = initial
    let mut step = 0
    while step < max_steps {
        let next = alpha * val + beta
        let diff = next - val
        if diff < 0.0 { diff = -diff }
        if diff < tol { return (next, step + 1, true) }
        val = next
        step = step + 1
    }
    return (val, max_steps, false)
}

// 표준 축소사상(α=0.7, β=0.1) 하에 1/3 으로 수렴하는가.
fn meta_converges_to_third(value, tolerance) {
    let r = meta_iterate(value, 0.7, 0.1, 0.000000000001, 200)
    let fp = r.0
    let converged = r.2
    let diff = fp - (1.0 / 3.0)
    if diff < 0.0 { diff = -diff }
    return converged && diff < tolerance
}
