// mk2_hexa/assess.hexa — r 산출 로직 (draft)
// Rust 원본: src/alien_index/assess.rs + alien_index/mod.rs (combine_signals)
// 목적: 여러 신호 소스(n6 quality, lens consensus, atlas grade, mk2 confidence)
//       를 최대값으로 합쳐 r ∈ {0..10} 도출.

// n6 quality (1.0/0.8/0.5/0.0) → r.
fn rank_from_n6_quality(quality) {
    if quality >= 1.0 { return 9 }
    if quality >= 0.8 { return 7 }
    if quality >= 0.5 { return 5 }
    return 0
}

// 합의 렌즈 수 → r.
fn rank_from_lens_consensus(count) {
    if count >= 12 { return 8 }
    if count >= 7  { return 7 }
    if count >= 3  { return 6 }
    if count >= 1  { return 3 }
    return 0
}

// MATH_ATLAS 등급 이모지 → r (없으면 -1 sentinel).
fn rank_from_grade(grade) {
    let g = grade.trim()
    if g == "" { return -1 }
    if g == "-" { return -1 }
    if g == "none" { return -1 }
    if g.starts_with("⬜") { return 0 }
    if g == "⚪" { return 1 }
    if g == "🟥" { return 2 }
    if g == "🟥★" { return 3 }
    if g.starts_with("🟥★★") { return 4 }
    if g == "🟦" { return 5 }
    if g == "🟧" { return 6 }
    if g == "🟧★" { return 7 }
    if g.starts_with("🟧★★") { return 8 }
    if g == "🟩" { return 9 }
    return -1
}

// mk2 classify_v2 confidence → r.
fn rank_from_mk2_confidence(confidence) {
    if confidence >= 0.9 { return 10 }
    if confidence >= 0.7 { return 9 }
    if confidence >= 0.5 { return 8 }
    if confidence >= 0.3 { return 7 }
    return 0
}

fn imax(a, b) {
    if a > b { return a }
    return b
}

// 3-신호 결합.
fn combine_signals(n6_quality, lens_consensus, grade) {
    let r_n6 = 0
    if n6_quality >= 0.0 { r_n6 = rank_from_n6_quality(n6_quality) }
    let r_lens = 0
    if lens_consensus >= 0 { r_lens = rank_from_lens_consensus(lens_consensus) }
    let r_grade = 0
    let rg = rank_from_grade(grade)
    if rg >= 0 { r_grade = rg }
    return imax(imax(r_n6, r_lens), r_grade)
}

// 4-신호 결합 (+ mk2 confidence).
fn combine_signals_v2(n6_quality, lens_consensus, grade, mk2_confidence) {
    let base = combine_signals(n6_quality, lens_consensus, grade)
    let r_mk2 = 0
    if mk2_confidence >= 0.0 { r_mk2 = rank_from_mk2_confidence(mk2_confidence) }
    return imax(base, r_mk2)
}
