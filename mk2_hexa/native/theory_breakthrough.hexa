// mk2_hexa/native/theory_breakthrough.hexa — 합성 파이프라인 실행 + 돌파 등록
// composed_pipelines.jsonl 의 각 경로를 순차 실행 → growth_bus EXACT 증가량으로 돌파 판정
//
// CLI:
//   hexa theory_breakthrough.hexa run [N]   상위 N개 합성 실행 (기본 6)
//   hexa theory_breakthrough.hexa report    돌파 로그

let _home = exec("printenv HOME").trim()
let _root = _home + "/Dev/nexus"
let _hexa = _home + "/Dev/hexa-lang/target/release/hexa"
let _native = _root + "/mk2_hexa/native"
let _pipelines = _root + "/shared/discovery/composed_pipelines.jsonl"
let _bus = _root + "/shared/discovery/growth_bus.jsonl"
let _bt_log = _root + "/shared/theory_breakthrough_log.jsonl"

let EXEC_TIMEOUT = 60

pure fn jget(line: string, field: string) -> string {
    let needle = "\"" + field + "\":"
    if !line.contains(needle) { return "" }
    let rest = line.split(needle)[1]
    if rest.starts_with("\"") {
        let parts = rest.split("\"")
        if parts.len() >= 2 { return parts[1] }
    }
    let mut out = ""
    let mut i = 0
    while i < rest.len() {
        let ch = rest[i]
        if ch == "," || ch == "}" { break }
        out = out + ch
        i = i + 1
    }
    out.trim()
}

pure fn parse_int_safe(s: string) -> int {
    let mut v = 0
    let mut i = 0
    while i < s.len() {
        let ch = s[i]
        if ch >= "0" && ch <= "9" { v = v * 10 + (ch.to_int() - 48) }
        i = i + 1
    }
    v
}

fn bus_exact_count() -> int {
    let s = exec("grep -c 'EXACT' " + _bus + " 2>/dev/null || echo 0").trim()
    parse_int_safe(s)
}

fn now() -> string { exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim() }

fn run_path(path: string) -> int {
    let modules = path.split(" -> ")
    println("[run] " + to_string(modules.len()) + " module chain")
    let before = bus_exact_count()
    let mut i = 0
    while i < modules.len() {
        let m = modules[i].trim()
        let f = _native + "/" + m + ".hexa"
        let exists = exec("[ -f " + f + " ] && echo y || echo n").trim()
        if exists != "y" { println("  [skip] " + m); i = i + 1; continue }
        let cmd = "timeout " + to_string(EXEC_TIMEOUT) + " " + _hexa + " " + f + " 2>&1 | tail -1"
        let out = exec(cmd).trim()
        println("  [" + to_string(i + 1) + "/" + to_string(modules.len()) + "] " + m + ": " + out)
        i = i + 1
    }
    let after = bus_exact_count()
    let delta = after - before
    println("[delta] EXACT +" + to_string(delta) + " (" + to_string(before) + "->" + to_string(after) + ")")
    delta
}

fn cmd_run(n: int) {
    let raw = exec("tail -" + to_string(n) + " " + _pipelines + " 2>/dev/null")
    let lines = raw.split("\n")
    println("=== theory_breakthrough run - top " + to_string(n) + " ===")
    let mut total = 0
    let mut bts = 0
    let mut i = 0
    while i < lines.len() {
        let ln = lines[i].trim()
        if ln.len() < 5 { i = i + 1; continue }
        let seed = jget(ln, "seed")
        let path = jget(ln, "path")
        let score = jget(ln, "score")
        println("")
        println("--- compose " + to_string(i + 1) + " seed=" + seed + " score=" + score + " ---")
        let delta = run_path(path)
        total = total + delta
        if delta > 0 {
            bts = bts + 1
            let bt1 = "{\"ts\":\"" + now() + "\",\"seed\":\"" + seed + "\""
            let bt2 = ",\"score\":" + score + ",\"delta_exact\":" + to_string(delta)
            let bt3 = ",\"path\":\"" + path + "\"}"
            let bt_line = bt1 + bt2 + bt3
            exec("printf '%s\\n' '" + bt_line.replace("'", "\\''") + "' >> " + _bt_log)
        }
        i = i + 1
    }
    println("")
    println("=== result ===")
    println("total EXACT delta: +" + to_string(total))
    println("breakthroughs: " + to_string(bts) + " / " + to_string(n))
    println("log: " + _bt_log)
}

fn cmd_report() {
    println("=== theory_breakthrough recent 10 ===")
    println(exec("tail -10 " + _bt_log + " 2>/dev/null"))
}

fn main() {
    let argv = args()
    let mut cmd = "run"
    if argv.len() >= 2 { cmd = argv[1] }
    if cmd == "run" {
        let n = if argv.len() >= 3 { parse_int_safe(argv[2]) } else { 6 }
        cmd_run(n)
    }
    else if cmd == "report" { cmd_report() }
    else { println("usage: theory_breakthrough.hexa [run [N]|report]") }
}

main()
