// mk2_hexa/native/theory_composer.hexa — AI Native 이론 자유 조립기
// 어텐션 기반 모듈 합성 — 473 빌딩블록으로 자유 파이프라인 생성
//
// 알고리즘 (AI native):
//   1. 모듈 임베딩 = 해시 기반 32차원 결정적 벡터 (카테고리|도메인|지문)
//   2. 어텐션 = cosine(va,vb) * 카테고리 가중 * 도메인 공명 * 보상 부스트
//   3. 자유 조립 = 시드에서 K-step beam search (beam=B, depth=D)
//   4. 보상 = growth_bus 도메인별 EXACT 카운트 (즉시 평가)
//   5. 출력 = shared/composed_pipelines.jsonl
//
// CLI:
//   hexa theory_composer.hexa scout                          자동 시드 N개 합성
//   hexa theory_composer.hexa compose <seed> [depth] [beam]  특정 시드
//   hexa theory_composer.hexa show                            최근 합성 결과

comptime const EMBED_DIM = 32
comptime const DEFAULT_DEPTH = 5
comptime const DEFAULT_BEAM = 6

let _home = exec("printenv HOME").trim()
let _root = _home + "/Dev/nexus"
let _registry = _root + "/shared/theory_registry.jsonl"
let _bus = _root + "/shared/growth_bus.jsonl"
let _out = _root + "/shared/composed_pipelines.jsonl"

// ─── 카테고리 가중치 ────────────────────────────────────────
fn cat_weight(a: string, b: string) -> float {
    if a == b { return 1.0 }
    if a == "blowup" && b == "wave_probe" { return 1.5 }
    if a == "wave_probe" && b == "verify" { return 1.4 }
    if a == "wave_r1" && b == "wave_r2" { return 1.3 }
    if a == "wave_r2" && b == "wave_r3" { return 1.3 }
    if a == "dse" && b == "blowup" { return 1.2 }
    if a == "lens" && b == "blowup" { return 1.2 }
    if a == "quantum" && b == "wave_r3" { return 1.2 }
    0.8
}

// ─── 도메인 공명 ────────────────────────────────────────────
fn domain_resonance(a: string, b: string) -> float {
    if a == b { return 1.5 }
    if a == "" || b == "" { return 0.5 }
    let pa = a.split("_")
    let pb = b.split("_")
    let mut hits = 0
    let mut i = 0
    while i < pa.len() {
        if pa[i].len() >= 3 {
            let mut j = 0
            while j < pb.len() {
                if pa[i] == pb[j] { hits = hits + 1; j = pb.len() }
                j = j + 1
            }
        }
        i = i + 1
    }
    if hits == 0 { 0.7 } else { 0.7 + to_float(hits) * 0.3 }
}

// ─── 해시 (결정적) ─────────────────────────────────────────
fn str_hash(s: string, salt: int) -> int {
    let mut h = salt + 17
    let mut i = 0
    while i < s.len() {
        let ch = s[i]
        let mut cc = 0
        if ch == "a" { cc = 97 } else if ch == "b" { cc = 98 } else if ch == "c" { cc = 99 }
        else if ch == "d" { cc = 100 } else if ch == "e" { cc = 101 } else if ch == "f" { cc = 102 }
        else if ch == "g" { cc = 103 } else if ch == "h" { cc = 104 } else if ch == "i" { cc = 105 }
        else if ch == "j" { cc = 106 } else if ch == "k" { cc = 107 } else if ch == "l" { cc = 108 }
        else if ch == "m" { cc = 109 } else if ch == "n" { cc = 110 } else if ch == "o" { cc = 111 }
        else if ch == "p" { cc = 112 } else if ch == "q" { cc = 113 } else if ch == "r" { cc = 114 }
        else if ch == "s" { cc = 115 } else if ch == "t" { cc = 116 } else if ch == "u" { cc = 117 }
        else if ch == "v" { cc = 118 } else if ch == "w" { cc = 119 } else if ch == "x" { cc = 120 }
        else if ch == "y" { cc = 121 } else if ch == "z" { cc = 122 } else if ch == "_" { cc = 95 }
        else if ch == "|" { cc = 124 } else if ch == "0" { cc = 48 } else if ch == "1" { cc = 49 }
        else if ch == "2" { cc = 50 } else if ch == "3" { cc = 51 } else if ch == "4" { cc = 52 }
        else if ch == "5" { cc = 53 } else if ch == "6" { cc = 54 } else if ch == "7" { cc = 55 }
        else if ch == "8" { cc = 56 } else if ch == "9" { cc = 57 } else { cc = 33 }
        h = (h * 131 + cc + salt * 7) % 1000003
        i = i + 1
    }
    h
}

// ─── 결정적 32d 임베딩 (콤마 join 문자열) ───────────────────
fn embed(name: string, cat: string, domain: string, fp: string) -> string {
    let mix = name + "|" + cat + "|" + domain + "|" + fp
    let mut vec = ""
    let mut k = 0
    while k < EMBED_DIM {
        let h = str_hash(mix, k)
        let v = to_float(h) / 500000.0 - 1.0
        vec = vec + to_string(v)
        if k < EMBED_DIM - 1 { vec = vec + "," }
        k = k + 1
    }
    vec
}

fn parse_float_safe(s: string) -> float {
    let t = s.trim()
    if t == "" { return 0.0 }
    to_float(t)
}

fn parse_int_safe(s: string) -> int {
    let mut v = 0
    let mut i = 0
    while i < s.len() {
        let ch = s[i]
        if ch == "0" { v = v * 10 } else if ch == "1" { v = v * 10 + 1 }
        else if ch == "2" { v = v * 10 + 2 } else if ch == "3" { v = v * 10 + 3 }
        else if ch == "4" { v = v * 10 + 4 } else if ch == "5" { v = v * 10 + 5 }
        else if ch == "6" { v = v * 10 + 6 } else if ch == "7" { v = v * 10 + 7 }
        else if ch == "8" { v = v * 10 + 8 } else if ch == "9" { v = v * 10 + 9 }
        i = i + 1
    }
    v
}

fn sqrt_n(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i = 0
    while i < 20 {
        g = (g + x / g) / 2.0
        i = i + 1
    }
    g
}

// ─── 두 임베딩 문자열의 코사인 유사도 ───────────────────────
fn cosine_str(va: string, vb: string) -> float {
    let pa = va.split(",")
    let pb = vb.split(",")
    let mut dot = 0.0
    let mut na = 0.0
    let mut nb = 0.0
    let mut i = 0
    let n = if pa.len() < pb.len() { pa.len() } else { pb.len() }
    while i < n {
        let ai = parse_float_safe(pa[i])
        let bi = parse_float_safe(pb[i])
        dot = dot + ai * bi
        na = na + ai * ai
        nb = nb + bi * bi
        i = i + 1
    }
    if na == 0.0 || nb == 0.0 { return 0.0 }
    dot / (sqrt_n(na) * sqrt_n(nb))
}

// ─── JSONL 필드 추출 ────────────────────────────────────────
fn jget(line: string, field: string) -> string {
    let needle = "\"" + field + "\":"
    if !line.contains(needle) { return "" }
    let rest = line.split(needle)[1]
    if rest.starts_with("\"") {
        let parts = rest.split("\"")
        if parts.len() >= 2 { return parts[1] }
    }
    let mut out = ""
    let mut i = 0
    while i < rest.len() {
        let ch = rest[i]
        if ch == "," || ch == "}" { i = rest.len() } else { out = out + ch }
        i = i + 1
    }
    out.trim()
}

// ─── 도메인별 보상 (growth_bus EXACT) ───────────────────────
fn reward(domain: string) -> float {
    if domain == "" { return 0.0 }
    let cmd = "tail -3000 " + _bus + " 2>/dev/null | grep -F '\"domain\":\"" + domain + "\"' | grep -c 'EXACT' 2>/dev/null; true"
    let raw = exec(cmd).trim()
    let c = raw.split("\n")[0].trim()
    if c == "" { return 0.0 }
    parse_float_safe(c)
}

fn attention(va: string, vb: string, ca: string, cb: string, da: string, db: string, rew: float) -> float {
    let cs = cosine_str(va, vb)
    let cw = cat_weight(ca, cb)
    let dr = domain_resonance(da, db)
    let rb = if rew > 10.0 { 1.5 } else if rew > 3.0 { 1.2 } else { 1.0 }
    cs * cw * dr * rb
}

// ─── 레지스트리 로드 → 평행 배열 리턴 (struct) ─────────────
struct Registry {
    names: list,
    cats: list,
    doms: list,
    fps: list,
    vecs: list,
    rewards: list
}

// 도메인별 reward 1회만 계산 (bulk grep)
fn bulk_reward_for(doms: list) -> list {
    // 고유 도메인 추출
    let mut uniq = []
    let mut i = 0
    while i < doms.len() {
        let d = doms[i]
        let mut seen = false
        let mut k = 0
        while k < uniq.len() {
            if uniq[k] == d { seen = true; k = uniq.len() }
            k = k + 1
        }
        if !seen { uniq = uniq + [d] }
        i = i + 1
    }
    // growth_bus tail을 한 번만 읽어 cache
    let bus_tail = exec("tail -3000 " + _bus + " 2>/dev/null")
    let bus_lines = bus_tail.split("\n")
    // 고유 도메인별 점수
    let mut uniq_scores = []
    let mut ui = 0
    while ui < uniq.len() {
        let d = uniq[ui]
        if d == "" {
            uniq_scores = uniq_scores + [0.0]
        } else {
            let needle = "\"domain\":\"" + d + "\""
            let mut c = 0
            let mut li = 0
            while li < bus_lines.len() {
                let bln = bus_lines[li]
                if bln.contains(needle) && bln.contains("EXACT") { c = c + 1 }
                li = li + 1
            }
            uniq_scores = uniq_scores + [to_float(c)]
        }
        ui = ui + 1
    }
    // 원래 순서대로 리매핑
    let mut out = []
    let mut j = 0
    while j < doms.len() {
        let d = doms[j]
        let mut found = 0.0
        let mut k = 0
        while k < uniq.len() {
            if uniq[k] == d { found = uniq_scores[k]; k = uniq.len() }
            k = k + 1
        }
        out = out + [found]
        j = j + 1
    }
    out
}

fn load_registry() -> Registry {
    let raw = exec("cat " + _registry + " 2>/dev/null")
    let lines = raw.split("\n")
    let mut names = []
    let mut cats = []
    let mut doms = []
    let mut fps = []
    let mut vecs = []
    let mut i = 0
    while i < lines.len() {
        let ln = lines[i].trim()
        if ln.len() >= 5 {
            let name = jget(ln, "name")
            let cat = jget(ln, "cat")
            let domain = jget(ln, "domain")
            let fp = jget(ln, "fp")
            names = names + [name]
            cats = cats + [cat]
            doms = doms + [domain]
            fps = fps + [fp]
            vecs = vecs + [embed(name, cat, domain, fp)]
        }
        i = i + 1
    }
    println("[load] " + to_string(names.len()) + " modules; computing rewards...")
    let rewards = bulk_reward_for(doms)
    println("[load] rewards ready")
    Registry { names: names, cats: cats, doms: doms, fps: fps, vecs: vecs, rewards: rewards }
}

fn find_idx(names: list, name: string) -> int {
    let mut i = 0
    while i < names.len() {
        if names[i] == name { return i }
        i = i + 1
    }
    0 - 1
}

// ─── Beam search 합성 ───────────────────────────────────────
fn compose(reg: Registry, seed: string, depth: int, beam: int) -> string {
    let s = find_idx(reg.names, seed)
    if s < 0 { println("[err] seed not found: " + seed); return "" }
    let mut paths = [seed]
    let mut scores = [0.0]
    let mut step = 0
    while step < depth {
        let mut new_paths = []
        let mut new_scores = []
        let mut bi = 0
        while bi < paths.len() {
            let cur_path = paths[bi]
            let cur_score = scores[bi]
            let segs = cur_path.split(" -> ")
            let last_name = segs[segs.len() - 1]
            let li = find_idx(reg.names, last_name)
            if li >= 0 {
                let last_vec = reg.vecs[li]
                let last_cat = reg.cats[li]
                let last_dom = reg.doms[li]
                let mut top_idx = 0 - 1
                let mut top_score = 0.0 - 1000.0
                let mut second_idx = 0 - 1
                let mut second_score = 0.0 - 1000.0
                // 후보 샘플링: 매 7번째 + 카테고리 가중 동급은 전수조사
                let mut mi = 0
                while mi < reg.names.len() {
                    let cand = reg.names[mi]
                    let skip = (mi == li) || cur_path.contains(cand)
                    if !skip {
                        let rew = reg.rewards[mi]
                        let a = attention(last_vec, reg.vecs[mi], last_cat, reg.cats[mi], last_dom, reg.doms[mi], rew)
                        if a > top_score {
                            second_idx = top_idx
                            second_score = top_score
                            top_idx = mi
                            top_score = a
                        } else if a > second_score {
                            second_idx = mi
                            second_score = a
                        }
                    }
                    mi = mi + 1
                }
                if top_idx >= 0 {
                    new_paths = new_paths + [cur_path + " -> " + reg.names[top_idx]]
                    new_scores = new_scores + [cur_score + top_score]
                }
                if second_idx >= 0 && new_paths.len() < beam {
                    new_paths = new_paths + [cur_path + " -> " + reg.names[second_idx]]
                    new_scores = new_scores + [cur_score + second_score]
                }
            }
            bi = bi + 1
        }
        paths = new_paths
        scores = new_scores
        // 상위 beam만 유지
        while paths.len() > beam {
            let mut worst = 0
            let mut wi = 1
            while wi < paths.len() {
                if scores[wi] < scores[worst] { worst = wi }
                wi = wi + 1
            }
            let mut np = []
            let mut ns = []
            let mut k = 0
            while k < paths.len() {
                if k != worst {
                    np = np + [paths[k]]
                    ns = ns + [scores[k]]
                }
                k = k + 1
            }
            paths = np
            scores = ns
        }
        step = step + 1
    }
    if paths.len() == 0 { println("[warn] no paths after beam search"); return "" }
    let mut best = 0
    let mut bi2 = 1
    while bi2 < paths.len() {
        if scores[bi2] > scores[best] { best = bi2 }
        bi2 = bi2 + 1
    }
    let final_path = paths[best]
    let final_score = scores[best]
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
    let p1 = "{\"ts\":\"" + ts + "\",\"seed\":\"" + seed + "\""
    let p2 = ",\"depth\":" + to_string(depth) + ",\"beam\":" + to_string(beam)
    let p3 = ",\"score\":" + to_string(final_score) + ",\"path\":\"" + final_path + "\"}"
    let line = p1 + p2 + p3
    let safe = line.replace("'", "'\\''")
    exec("printf '%s\\n' '" + safe + "' >> " + _out)
    println("[compose] " + seed + " (d" + to_string(depth) + " b" + to_string(beam) + ") score=" + to_string(final_score))
    println("  -> " + final_path)
    final_path
}

fn cmd_scout() {
    let reg = load_registry()
    if reg.names.len() == 0 { println("[err] registry empty - run theory_registry.hexa build"); return }
    println("=== SCOUT (auto compose) - " + to_string(reg.names.len()) + " modules ===")
    let cats = ["blowup", "wave_probe", "wave_r3", "quantum", "dse", "lens"]
    let mut ci = 0
    while ci < cats.len() {
        let target = cats[ci]
        let mut picked = false
        let mut mi = 0
        while mi < reg.names.len() && !picked {
            if reg.cats[mi] == target {
                compose(reg, reg.names[mi], DEFAULT_DEPTH, DEFAULT_BEAM)
                picked = true
            }
            mi = mi + 1
        }
        ci = ci + 1
    }
    println("[ok] scout done -> " + _out)
}

fn cmd_compose(seed: string, depth: int, beam: int) {
    let reg = load_registry()
    compose(reg, seed, depth, beam)
}

fn cmd_show() {
    println(exec("tail -10 " + _out + " 2>/dev/null"))
}

// ─── CLI entrypoint ──────────────────────────────────────────
let argv = args()
let mut cmd = "scout"
if argv.len() >= 3 { cmd = argv[2] }
if cmd == "scout" {
    cmd_scout()
} else if cmd == "compose" {
    let seed = if argv.len() >= 4 { argv[3] } else { "blowup" }
    let depth = if argv.len() >= 5 { parse_int_safe(argv[4]) } else { DEFAULT_DEPTH }
    let beam = if argv.len() >= 6 { parse_int_safe(argv[5]) } else { DEFAULT_BEAM }
    cmd_compose(seed, depth, beam)
} else if cmd == "show" {
    cmd_show()
} else {
    println("usage: theory_composer.hexa [scout|compose <seed> [depth] [beam]|show]")
}
