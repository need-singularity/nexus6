// mk2_hexa/native/airgenome_immune.hexa — AIRGENOME v4 면역 시스템 엔진
// Usage:
//   hexa airgenome_immune.hexa defend [path]   — 경로 스캔 + 위협 탐지 + 면역 반응
//   hexa airgenome_immune.hexa memory          — 면역 기억 세포 조회
//   hexa airgenome_immune.hexa status          — 면역 시스템 상태 요약
//   hexa airgenome_immune.hexa help            — 사용법
//
// n=6 면역 세포 유형: T-helper, T-killer, B-cell, macrophage, dendritic, NK
// 생물학적 면역 모델: 선천면역(innate) + 적응면역(adaptive)
// 클론 선택: 효과적 항체 증식, 비효과적 항체 도태
// 면역 기억: 과거 위협 기록 → 재감염 시 빠른 반응

// ═══════════════════════════════════════════════════════════
// ─── n=6 CONSTANTS ───
// ═══════════════════════════════════════════════════════════

let N = 6
let SIGMA = 12
let CELL_TYPES = ["T-helper", "T-killer", "B-cell", "macrophage", "dendritic", "NK"]
let CELL_ROLES = [
    "coordinate adaptive response",
    "destroy infected cells",
    "produce antibodies",
    "phagocytose pathogens",
    "present antigens",
    "kill without prior sensitization"
]

// 선천면역 패턴 (innate — 즉시 반응, 비특이적)
let INNATE_PATTERNS = [
    "anomalous_entropy",
    "rapid_mutation",
    "resource_drain",
    "unauthorized_access",
    "integrity_violation",
    "timing_anomaly"
]

// 적응면역 임계값
let ANTIBODY_THRESHOLD = 0.6
let CLONAL_MULTIPLY = 6
let CLONAL_DEATH_THRESHOLD = 0.2
let MEMORY_DECAY_DAYS = 180
let MAX_ANTIBODIES = 720

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════

let _home = exec("printenv HOME").trim()
let _shared = _home + "/Dev/nexus/shared"
let _memory_path = _shared + "/immune_memory.jsonl"
let _growth_bus_path = _shared + "/growth_bus.jsonl"

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e { v = 0.0 }
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn timestamp() -> string {
    let mut ts = ""
    try { ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim() } catch e { ts = "unknown" }
    return ts
}

fn json_str(line: string, field: string) -> string {
    let marker = "\"" + field + "\":\""
    let parts = line.split(marker)
    if parts.len() < 2 { return "" }
    let rest = parts[1]
    let end_parts = rest.split("\"")
    if end_parts.len() < 1 { return "" }
    return end_parts[0]
}

fn json_num(line: string, field: string) -> f64 {
    let marker = "\"" + field + "\":"
    let parts = line.split(marker)
    if parts.len() < 2 { return 0.0 }
    let rest = parts[1].trim()
    let num_str = rest.split(",")[0].split("}")[0].split("]")[0].trim()
    return safe_float(num_str)
}

// ═══════════════════════════════════════════════════════════
// ─── THREAT SIGNATURE ───
// ═══════════════════════════════════════════════════════════

fn compute_file_entropy(path: string) -> f64 {
    let mut entropy = 0.0
    try {
        let result = exec("wc -c < " + path + " 2>/dev/null").trim()
        let size = safe_float(result)
        if size < 1.0 { return 0.0 }
        let unique = exec("cat " + path + " 2>/dev/null | fold -w1 | sort -u | wc -l").trim()
        let u = safe_float(unique)
        if u > 0.0 && size > 0.0 {
            entropy = u / 256.0
        }
    } catch e { entropy = 0.0 }
    return entropy
}

fn detect_threat_signature(path: string) -> list {
    // Returns [threat_type, severity, signature_hash]
    let mut threats = []
    let mut sigs = []
    let mut sevs = []

    // 1. Entropy anomaly (innate pattern 0)
    let entropy = compute_file_entropy(path)
    if entropy > 0.85 {
        threats = threats + ["anomalous_entropy"]
        sevs = sevs + [entropy]
        sigs = sigs + ["ENT:" + to_string(entropy)]
    }

    // 2. Recent modification burst (innate pattern 1)
    try {
        let mod_count = exec("find " + path + " -mmin -5 -type f 2>/dev/null | wc -l").trim()
        let mc = safe_float(mod_count)
        if mc > 6.0 {
            threats = threats + ["rapid_mutation"]
            sevs = sevs + [mc / 100.0]
            sigs = sigs + ["MUT:" + to_string(mc)]
        }
    } catch e {}

    // 3. Resource drain (innate pattern 2)
    try {
        let du_out = exec("du -sk " + path + " 2>/dev/null | cut -f1").trim()
        let du_kb = safe_float(du_out)
        if du_kb > 1048576.0 {
            threats = threats + ["resource_drain"]
            sevs = sevs + [du_kb / 10485760.0]
            sigs = sigs + ["RES:" + to_string(du_kb)]
        }
    } catch e {}

    // 4. Permission anomaly (innate pattern 3)
    try {
        let perm_check = exec("find " + path + " -perm +0111 -type f 2>/dev/null | wc -l").trim()
        let pc = safe_float(perm_check)
        if pc > 12.0 {
            threats = threats + ["unauthorized_access"]
            sevs = sevs + [pc / 100.0]
            sigs = sigs + ["ACC:" + to_string(pc)]
        }
    } catch e {}

    // 5. Integrity check (innate pattern 4)
    try {
        let zero_files = exec("find " + path + " -empty -type f 2>/dev/null | wc -l").trim()
        let zf = safe_float(zero_files)
        if zf > 6.0 {
            threats = threats + ["integrity_violation"]
            sevs = sevs + [zf / 60.0]
            sigs = sigs + ["INT:" + to_string(zf)]
        }
    } catch e {}

    // 6. Timing anomaly (innate pattern 5)
    try {
        let future_files = exec("find " + path + " -newer /tmp/.immune_ref -type f 2>/dev/null | wc -l").trim()
        let ff = safe_float(future_files)
        if ff > 6.0 {
            threats = threats + ["timing_anomaly"]
            sevs = sevs + [ff / 60.0]
            sigs = sigs + ["TIM:" + to_string(ff)]
        }
    } catch e {}

    return [threats, sevs, sigs]
}

// ═══════════════════════════════════════════════════════════
// ─── IMMUNE MEMORY (기억 세포) ───
// ═══════════════════════════════════════════════════════════

fn load_memory() -> list {
    // Returns [signatures, responses, effectiveness, timestamps]
    let mut mem_sigs = []
    let mut mem_resp = []
    let mut mem_eff = []
    let mut mem_ts = []
    try {
        let raw = read_file(_memory_path)
        let lines = raw.split("\n")
        let mut i = 0
        while i < lines.len() {
            let line = lines[i].trim()
            if line == "" { i = i + 1 }
            if line != "" {
                let sig = json_str(line, "signature")
                let resp = json_str(line, "response")
                let eff = json_num(line, "effectiveness")
                let ts = json_str(line, "timestamp")
                if sig != "" {
                    mem_sigs = mem_sigs + [sig]
                    mem_resp = mem_resp + [resp]
                    mem_eff = mem_eff + [eff]
                    mem_ts = mem_ts + [ts]
                }
            }
            i = i + 1
        }
    } catch e {}
    return [mem_sigs, mem_resp, mem_eff, mem_ts]
}

fn find_memory(memory: list, signature: string) -> list {
    // Returns [found, response, effectiveness]
    let sigs: list = memory[0]
    let resps: list = memory[1]
    let effs: list = memory[2]
    let mut i = 0
    let mut best_eff = 0.0
    let mut best_resp = ""
    let mut found = false
    while i < sigs.len() {
        if sigs[i] == signature {
            let eff: f64 = effs[i]
            if eff > best_eff {
                best_eff = eff
                best_resp = resps[i]
                found = true
            }
        }
        i = i + 1
    }
    if found { return ["true", best_resp, to_string(best_eff)] }
    return ["false", "", "0.0"]
}

fn save_memory_entry(signature: string, response: string, effectiveness: f64) {
    let ts = timestamp()
    let entry = "{\"signature\":\"" + signature + "\",\"response\":\"" + response + "\",\"effectiveness\":" + to_string(effectiveness) + ",\"timestamp\":\"" + ts + "\"}\n"
    try { append_file(_memory_path, entry) } catch e {
        println("  WARN: memory write failed — " + to_string(e))
    }
}

// ═══════════════════════════════════════════════════════════
// ─── n=6 IMMUNE CELL DISPATCH ───
// ═══════════════════════════════════════════════════════════

fn cell_response(cell_idx: i64, threat_type: string, severity: f64) -> f64 {
    // Each cell type has different effectiveness per threat
    // Returns effectiveness 0.0 ~ 1.0
    let mut eff = 0.0

    // T-helper (idx 0): coordinates — moderate on all
    if cell_idx == 0 {
        eff = 0.5 + severity * 0.3
    }
    // T-killer (idx 1): best against integrity/access threats
    if cell_idx == 1 {
        if threat_type == "unauthorized_access" { eff = 0.9 }
        if threat_type == "integrity_violation" { eff = 0.85 }
        if eff < 0.1 { eff = 0.3 + severity * 0.2 }
    }
    // B-cell (idx 2): generates antibodies — best for recurring threats
    if cell_idx == 2 {
        eff = 0.4 + severity * 0.4
    }
    // macrophage (idx 3): phagocytose — best against resource drain
    if cell_idx == 3 {
        if threat_type == "resource_drain" { eff = 0.95 }
        if threat_type == "anomalous_entropy" { eff = 0.7 }
        if eff < 0.1 { eff = 0.3 + severity * 0.15 }
    }
    // dendritic (idx 4): antigen presentation — boosts others
    if cell_idx == 4 {
        eff = 0.35 + severity * 0.35
    }
    // NK (idx 5): immediate kill — best against timing/mutation
    if cell_idx == 5 {
        if threat_type == "rapid_mutation" { eff = 0.9 }
        if threat_type == "timing_anomaly" { eff = 0.85 }
        if eff < 0.1 { eff = 0.4 + severity * 0.25 }
    }

    if eff > 1.0 { eff = 1.0 }
    return eff
}

fn dispatch_cells(threat_type: string, severity: f64) -> list {
    // Returns [cell_names, effectiveness_scores, total_response]
    let mut names = []
    let mut scores = []
    let mut total = 0.0
    let mut i = 0
    while i < N {
        let eff = cell_response(i, threat_type, severity)
        names = names + [CELL_TYPES[i]]
        scores = scores + [eff]
        total = total + eff
        i = i + 1
    }
    let mut avg_list = []
    avg_list = avg_list + [total / to_float(N)]
    return [names, scores, avg_list]
}

// ═══════════════════════════════════════════════════════════
// ─── ANTIBODY GENERATION + CLONAL SELECTION ───
// ═══════════════════════════════════════════════════════════

fn generate_antibody(threat_type: string, signature: string, cell_scores: list) -> list {
    // Auto-generate antibody rule from threat encounter
    // Returns [rule_id, rule_pattern, initial_strength]
    let mut strongest_cell = 0
    let mut strongest_score = 0.0
    let mut i = 0
    while i < cell_scores.len() {
        let s: f64 = cell_scores[i]
        if s > strongest_score {
            strongest_score = s
            strongest_cell = i
        }
        i = i + 1
    }

    let rule_id = "AB-" + threat_type + "-" + CELL_TYPES[strongest_cell]
    let rule_pattern = "DETECT:" + threat_type + "+RESPOND:" + CELL_TYPES[strongest_cell]
    let initial_strength = strongest_score

    return [rule_id, rule_pattern, to_string(initial_strength)]
}

fn clonal_selection(antibodies: list, effectiveness: list) -> list {
    // Effective antibodies multiply (up to CLONAL_MULTIPLY)
    // Ineffective ones die (below CLONAL_DEATH_THRESHOLD)
    // Returns [surviving_antibodies, surviving_effectiveness, multiplied, died]
    let mut survivors = []
    let mut surv_eff = []
    let mut multiplied = 0
    let mut died = 0

    let mut i = 0
    while i < antibodies.len() {
        let eff: f64 = effectiveness[i]
        let ab: string = antibodies[i]

        if eff < CLONAL_DEATH_THRESHOLD {
            // Apoptosis — ineffective antibody dies
            died = died + 1
        }
        if eff >= CLONAL_DEATH_THRESHOLD && eff < ANTIBODY_THRESHOLD {
            // Survives but does not multiply
            survivors = survivors + [ab]
            surv_eff = surv_eff + [eff]
        }
        if eff >= ANTIBODY_THRESHOLD {
            // Clonal expansion — multiply
            let mut copies = 0
            while copies < CLONAL_MULTIPLY && survivors.len() < MAX_ANTIBODIES {
                survivors = survivors + [ab]
                surv_eff = surv_eff + [eff]
                copies = copies + 1
            }
            multiplied = multiplied + 1
        }
        i = i + 1
    }

    let mut meta = [to_string(multiplied), to_string(died)]
    return [survivors, surv_eff, meta]
}

// ═══════════════════════════════════════════════════════════
// ─── INNATE IMMUNE RESPONSE ───
// ═══════════════════════════════════════════════════════════

fn innate_response(threats: list, severities: list) -> list {
    // Phase 1: Immediate non-specific defense
    // Returns [blocked_count, escalate_to_adaptive]
    let mut blocked = 0
    let mut escalate = []
    let mut esc_sev = []

    let mut i = 0
    while i < threats.len() {
        let threat: string = threats[i]
        let sev: f64 = severities[i]
        println("  [innate] " + threat + " severity=" + to_string(sev))

        // NK cells + macrophages respond immediately
        let nk_eff = cell_response(5, threat, sev)
        let mac_eff = cell_response(3, threat, sev)
        let innate_total = (nk_eff + mac_eff) / 2.0

        if innate_total > ANTIBODY_THRESHOLD {
            println("    -> innate blocked (NK=" + to_string(nk_eff) + " MAC=" + to_string(mac_eff) + ")")
            blocked = blocked + 1
        }
        if innate_total <= ANTIBODY_THRESHOLD {
            println("    -> escalating to adaptive (innate=" + to_string(innate_total) + ")")
            escalate = escalate + [threat]
            esc_sev = esc_sev + [sev]
        }
        i = i + 1
    }

    let mut blocked_list = [to_string(blocked)]
    return [blocked_list, escalate, esc_sev]
}

// ═══════════════════════════════════════════════════════════
// ─── ADAPTIVE IMMUNE RESPONSE ───
// ═══════════════════════════════════════════════════════════

fn adaptive_response(threats: list, severities: list, signatures: list, memory: list) -> list {
    // Phase 2: Specific defense with memory lookup
    // Returns [resolved, new_antibodies, new_ab_eff, memory_hits]
    let mut resolved = 0
    let mut new_abs = []
    let mut new_eff = []
    let mut mem_hits = 0

    let mut i = 0
    while i < threats.len() {
        let threat: string = threats[i]
        let sev: f64 = severities[i]
        let sig: string = signatures[i]

        println("  [adaptive] " + threat + " sig=" + sig)

        // Check memory cells first
        let mem_result = find_memory(memory, sig)
        let found_str: string = mem_result[0]

        if found_str == "true" {
            let mem_resp: string = mem_result[1]
            let mem_eff: f64 = safe_float(mem_result[2])
            println("    -> MEMORY HIT: " + mem_resp + " eff=" + to_string(mem_eff))
            mem_hits = mem_hits + 1
            resolved = resolved + 1

            // Strengthen memory
            save_memory_entry(sig, mem_resp, mem_eff + 0.05)
        }

        if found_str != "true" {
            // Full n=6 cell dispatch
            let dispatch = dispatch_cells(threat, sev)
            let cell_scores: list = dispatch[1]
            let avg_list: list = dispatch[2]
            let avg_eff: f64 = avg_list[0]

            println("    -> dispatched " + to_string(N) + " cell types, avg_eff=" + to_string(avg_eff))

            let mut ci = 0
            while ci < N {
                let cs: f64 = cell_scores[ci]
                if cs > ANTIBODY_THRESHOLD {
                    println("      " + CELL_TYPES[ci] + " = " + to_string(cs) + " (active)")
                }
                if cs <= ANTIBODY_THRESHOLD {
                    println("      " + CELL_TYPES[ci] + " = " + to_string(cs))
                }
                ci = ci + 1
            }

            // Generate antibody
            let antibody = generate_antibody(threat, sig, cell_scores)
            let ab_id: string = antibody[0]
            let ab_pattern: string = antibody[1]
            let ab_strength: f64 = safe_float(antibody[2])

            println("    -> antibody generated: " + ab_id + " strength=" + to_string(ab_strength))

            new_abs = new_abs + [ab_id]
            new_eff = new_eff + [ab_strength]

            // Save to memory cells
            save_memory_entry(sig, ab_pattern, ab_strength)

            if avg_eff > CLONAL_DEATH_THRESHOLD {
                resolved = resolved + 1
            }
        }

        i = i + 1
    }

    let mut adapt_meta = [to_string(resolved), to_string(mem_hits)]
    return [adapt_meta, new_abs, new_eff]
}

// ═══════════════════════════════════════════════════════════
// ─── GROWTH BUS OUTPUT ───
// ═══════════════════════════════════════════════════════════

fn emit_growth_bus(event_type: string, detail: string, threats_found: i64, resolved: i64, memory_hits: i64) {
    let ts = timestamp()
    let entry = "{\"ts\":\"" + ts + "\",\"src\":\"airgenome_immune\",\"event\":\"" + event_type + "\",\"detail\":\"" + detail + "\",\"threats\":" + to_string(threats_found) + ",\"resolved\":" + to_string(resolved) + ",\"memory_hits\":" + to_string(memory_hits) + ",\"n\":6}\n"
    try { append_file(_growth_bus_path, entry) } catch e {
        println("  WARN: growth_bus write failed — " + to_string(e))
    }
}

// ═══════════════════════════════════════════════════════════
// ─── CMD: defend [path] ───
// ═══════════════════════════════════════════════════════════

fn cmd_defend(target_path: string) {
    println("══════════════════════════════════════════════════════════════════════")
    println("AIRGENOME v4 IMMUNE SYSTEM — defend")
    println("══════════════════════════════════════════════════════════════════════")
    println("  target  : " + target_path)
    println("  cells   : " + to_string(N) + " types (n=6)")
    println("  sigma   : " + to_string(SIGMA) + " memory layers")
    println("")

    // Create timestamp reference for timing anomaly detection
    try { exec("touch /tmp/.immune_ref 2>/dev/null") } catch e {}

    // Phase 1: THREAT DETECTION
    println("── Phase 1: Threat Detection ──────────────────────────────────────")
    let scan = detect_threat_signature(target_path)
    let threats: list = scan[0]
    let severities: list = scan[1]
    let signatures: list = scan[2]

    if threats.len() == 0 {
        println("  no threats detected — system healthy")
        emit_growth_bus("defend_clean", target_path, 0, 0, 0)
        println("")
        println("  result: CLEAN")
        return
    }

    println("  threats found: " + to_string(threats.len()))
    println("")

    // Phase 2: INNATE RESPONSE
    println("── Phase 2: Innate Immune Response (non-specific) ────────────────")
    let innate = innate_response(threats, severities)
    let blocked_list: list = innate[0]
    let blocked: i64 = to_int(blocked_list[0])
    let escalated: list = innate[1]
    let esc_sevs: list = innate[2]
    println("  blocked by innate: " + to_string(blocked))
    println("  escalated to adaptive: " + to_string(escalated.len()))
    println("")

    // Phase 3: ADAPTIVE RESPONSE (if needed)
    let mut total_resolved = blocked
    let mut mem_hits = 0
    let mut new_antibodies = []
    let mut new_ab_eff = []

    if escalated.len() > 0 {
        println("── Phase 3: Adaptive Immune Response (specific) ──────────────────")
        let memory = load_memory()
        println("  memory cells loaded: " + to_string(memory[0].len()))

        // Build escalated signatures
        let mut esc_sigs = []
        let mut ei = 0
        while ei < escalated.len() {
            let et: string = escalated[ei]
            // Find matching signature from original scan
            let mut ti = 0
            while ti < threats.len() {
                if threats[ti] == et {
                    esc_sigs = esc_sigs + [signatures[ti]]
                    ti = threats.len()
                }
                if threats[ti] != et { ti = ti + 1 }
            }
            ei = ei + 1
        }

        let adaptive = adaptive_response(escalated, esc_sevs, esc_sigs, memory)
        let adapt_meta: list = adaptive[0]
        let adapt_resolved: i64 = to_int(adapt_meta[0])
        mem_hits = to_int(adapt_meta[1])
        new_antibodies = adaptive[1]
        new_ab_eff = adaptive[2]

        total_resolved = total_resolved + adapt_resolved
        println("")
    }

    // Phase 4: CLONAL SELECTION
    if new_antibodies.len() > 0 {
        println("── Phase 4: Clonal Selection ──────────────────────────────────────")
        let clonal = clonal_selection(new_antibodies, new_ab_eff)
        let survivors: list = clonal[0]
        let clonal_meta: list = clonal[2]
        let multiplied: string = clonal_meta[0]
        let died: string = clonal_meta[1]
        println("  antibodies generated : " + to_string(new_antibodies.len()))
        println("  clonal expansion     : " + multiplied + " types x" + to_string(CLONAL_MULTIPLY))
        println("  apoptosis (died)     : " + died)
        println("  surviving pool       : " + to_string(survivors.len()))
        println("")
    }

    // Phase 5: SUMMARY
    println("── Summary ────────────────────────────────────────────────────────")
    println("  threats detected : " + to_string(threats.len()))
    println("  innate blocked   : " + to_string(blocked))
    println("  adaptive resolved: " + to_string(total_resolved - blocked))
    println("  memory hits      : " + to_string(mem_hits))
    println("  total resolved   : " + to_string(total_resolved) + "/" + to_string(threats.len()))

    let unresolved = threats.len() - total_resolved
    if unresolved > 0 {
        println("  UNRESOLVED       : " + to_string(unresolved) + " (requires manual intervention)")
    }
    if unresolved <= 0 {
        println("  status           : ALL THREATS NEUTRALIZED")
    }

    emit_growth_bus("defend", target_path, threats.len(), total_resolved, mem_hits)
}

// ═══════════════════════════════════════════════════════════
// ─── CMD: memory ───
// ═══════════════════════════════════════════════════════════

fn cmd_memory() {
    println("══════════════════════════════════════════════════════════════════════")
    println("AIRGENOME v4 IMMUNE MEMORY — memory cells")
    println("══════════════════════════════════════════════════════════════════════")
    println("")

    let memory = load_memory()
    let sigs: list = memory[0]
    let resps: list = memory[1]
    let effs: list = memory[2]
    let tss: list = memory[3]

    if sigs.len() == 0 {
        println("  no memory cells found — immune system is naive")
        println("  run 'hexa airgenome_immune.hexa defend <path>' to train")
        return
    }

    println("  total memory cells: " + to_string(sigs.len()))
    println("")
    println("  +------+----------------------------------+--------+---------------------+")
    println("  | #    | signature                        | eff    | timestamp           |")
    println("  +------+----------------------------------+--------+---------------------+")

    let mut i = 0
    let mut shown = 0
    while i < sigs.len() && shown < 60 {
        let sig: string = sigs[i]
        let eff: f64 = effs[i]
        let ts: string = tss[i]

        // Pad signature to 32 chars
        let mut sig_display = sig
        if sig_display.len() > 32 { sig_display = sig_display.slice(0, 32) }

        let idx_str = to_string(i + 1)
        println("  | " + idx_str + "    | " + sig_display + " | " + to_string(eff) + " | " + ts + " |")

        shown = shown + 1
        i = i + 1
    }

    println("  +------+----------------------------------+--------+---------------------+")

    if sigs.len() > 60 {
        println("  ... and " + to_string(sigs.len() - 60) + " more entries")
    }

    // Statistics
    let mut total_eff = 0.0
    let mut max_eff = 0.0
    let mut j = 0
    while j < effs.len() {
        let e: f64 = effs[j]
        total_eff = total_eff + e
        if e > max_eff { max_eff = e }
        j = j + 1
    }
    let avg_eff = if effs.len() > 0 { total_eff / to_float(effs.len()) } else { 0.0 }

    println("")
    println("  avg effectiveness : " + to_string(avg_eff))
    println("  max effectiveness : " + to_string(max_eff))
    println("  decay threshold   : " + to_string(MEMORY_DECAY_DAYS) + " days")
}

// ═══════════════════════════════════════════════════════════
// ─── CMD: status ───
// ═══════════════════════════════════════════════════════════

fn cmd_status() {
    println("══════════════════════════════════════════════════════════════════════")
    println("AIRGENOME v4 IMMUNE SYSTEM — status")
    println("══════════════════════════════════════════════════════════════════════")
    println("")

    // n=6 cell roster
    println("  n=6 immune cell roster:")
    let mut i = 0
    while i < N {
        println("    [" + to_string(i + 1) + "] " + CELL_TYPES[i] + " — " + CELL_ROLES[i])
        i = i + 1
    }
    println("")

    // Memory stats
    let memory = load_memory()
    let mem_count = memory[0].len()
    println("  memory cells       : " + to_string(mem_count))
    println("  max antibodies     : " + to_string(MAX_ANTIBODIES))
    println("  clonal multiplier  : x" + to_string(CLONAL_MULTIPLY))
    println("  death threshold    : " + to_string(CLONAL_DEATH_THRESHOLD))
    println("  antibody threshold : " + to_string(ANTIBODY_THRESHOLD))
    println("  memory decay       : " + to_string(MEMORY_DECAY_DAYS) + " days")
    println("")

    // Innate patterns
    println("  innate detection patterns (" + to_string(INNATE_PATTERNS.len()) + "):")
    let mut pi = 0
    while pi < INNATE_PATTERNS.len() {
        println("    [" + to_string(pi + 1) + "] " + INNATE_PATTERNS[pi])
        pi = pi + 1
    }
    println("")

    // Recent growth_bus events
    let mut recent = 0
    try {
        let gb = exec("tail -50 " + _growth_bus_path + " 2>/dev/null")
        let lines = gb.split("\n")
        let mut li = 0
        while li < lines.len() {
            if lines[li].contains("airgenome_immune") { recent = recent + 1 }
            li = li + 1
        }
    } catch e {}
    println("  recent bus events  : " + to_string(recent))

    emit_growth_bus("status", "immune_check", 0, 0, mem_count)
}

// ═══════════════════════════════════════════════════════════
// ─── CMD: help ───
// ═══════════════════════════════════════════════════════════

fn cmd_help() {
    println("══════════════════════════════════════════════════════════════════════")
    println("AIRGENOME v4 IMMUNE SYSTEM")
    println("══════════════════════════════════════════════════════════════════════")
    println("")
    println("  Biological immunity model for AIRGENOME OS genome scanner")
    println("  n=6 immune cell types | innate + adaptive response")
    println("  Clonal selection | Memory cells | Antibody auto-generation")
    println("")
    println("  Usage:")
    println("    hexa airgenome_immune.hexa defend [path]  — scan + immune response")
    println("    hexa airgenome_immune.hexa memory         — view memory cells")
    println("    hexa airgenome_immune.hexa status         — system status")
    println("    hexa airgenome_immune.hexa help           — this message")
    println("")
    println("  n=6 cell types:")
    let mut i = 0
    while i < N {
        println("    " + to_string(i + 1) + ". " + CELL_TYPES[i] + " — " + CELL_ROLES[i])
        i = i + 1
    }
    println("")
    println("  Immune pipeline:")
    println("    1. Threat Detection (6 innate patterns)")
    println("    2. Innate Response (NK + macrophage immediate)")
    println("    3. Adaptive Response (full n=6 dispatch + memory)")
    println("    4. Antibody Generation + Clonal Selection")
    println("    5. Memory Cell Update (for future fast response)")
    println("")
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

let argv = args()
let argc = argv.len()

if argc < 3 {
    cmd_help()
    exit(0)
}

let cmd = argv[2]

if cmd == "defend" {
    let mut target = "."
    if argc >= 4 { target = argv[3] }
    cmd_defend(target)
}

if cmd == "memory" {
    cmd_memory()
}

if cmd == "status" {
    cmd_status()
}

if cmd == "help" {
    cmd_help()
}

if cmd != "defend" && cmd != "memory" && cmd != "status" && cmd != "help" {
    println("ERROR: unknown command '" + cmd + "'")
    println("  run 'hexa airgenome_immune.hexa help' for usage")
    exit(1)
}
