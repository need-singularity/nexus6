if mode == "tick" {
    tick()
}

if mode == "daemon" {
    daemon()
}

if mode == "status" {
    show_status()
}

if mode == "h100-cycle" {
    println("=== H100 Singularity Cycle (수동) ===")
    let mut strat = load_strategy()
    strat = h100_singularity_cycle(strat)
    save_strategy(strat)
    println("=== done ===")
}

if mode == "h100-stop" {
    println("=== H100 Pod 정지 ===")
    h100_stop_pod()
}

if mode == "help" {
    println("=== anima_loop.hexa — Dreamer Loop (꿈의 순환) ===")
    println("")
    println("Autonomous growth loop for anima project — pure hexa, no Python.")
    println("Replaces growth_loop.py + meta_loop.py.")
    println("")
    println("Usage:")
    println("  hexa anima_loop.hexa tick     — 1 full cycle: harvest -> filter -> apply -> verify -> breakthrough")
    println("  hexa anima_loop.hexa daemon   — 5min infinite loop (mkdir lock)")
    println("  hexa anima_loop.hexa status   — current strategy + daemon state")
    println("  hexa anima_loop.hexa help     — this message")
    println("")
    println("Pipeline:")
    println("  0. check_h100()   — SSH H100 training status (step/CE/Phi/ETA)")
    println("  1. harvest()      — scan absorbed/ + discovery_log + blowup consciousness")
    println("  1.5 harvest_claude() — Claude CLI law discovery (every " + to_string(claude_call_interval) + " ticks, timeout " + to_string(claude_timeout_sec) + "s)")
    println("  2. filter()       — dedup + quality gate (surprise >= " + to_string(quality_min_surprise) + ", exactness >= " + to_string(quality_min_exactness) + ")")
    println("  3. apply()        — append new laws to growth_bus.jsonl")
    println("  4. verify()       — telescope consensus check (>= " + to_string(consensus_threshold) + ")")
    println("  5. breakthrough() — stagnation detect + blowup + topology rotation")
    println("")
    println("Meta-loops:")
    println("  L2 (every " + to_string(meta_l2_interval) + " ticks): adaptive blowup depth")
    println("  L3 (every " + to_string(meta_l3_interval) + " ticks): topology rotation + self-improvement")
    println("")
    println("State: " + strategy_path)
    println("Lock:  " + lock_dir)
}
