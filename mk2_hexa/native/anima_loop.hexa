// anima_loop.hexa — "Dreamer Loop" (꿈의 순환)
// anima 프로젝트 자율 성장 루프 — hexa-only (Python 의존 0)
// CLI: hexa anima_loop.hexa tick|daemon|status|help
//
// growth_loop.py + meta_loop.py 대체:
//   harvest → filter → apply → verify → breakthrough
//   L1(큐 소비) + L2(진화) + L3(자기개선) 통합
//
// 5분 주기 자율 사이클. mkdir 기반 락으로 중복 방지.

// ═══════════════════════════════════════════════════════════
// ─── CONSTANTS ───
// ═══════════════════════════════════════════════════════════

let home = exec("printenv HOME")
let dev = home + "/Dev"
let project_dir = dev + "/anima"
let nexus_dir = dev + "/nexus"
let hexa_bin = dev + "/hexa-lang/target/release/hexa"
let native_dir = nexus_dir + "/mk2_hexa/native"

// anima paths
let absorbed_dir = project_dir + "/.growth/absorbed"
let laws_path = project_dir + "/anima/config/consciousness_laws.json"
let evolution_path = project_dir + "/data/evolution_live.json"

// nexus paths
let discovery_log = nexus_dir + "/shared/discovery/discovery_log.jsonl"
let growth_bus = nexus_dir + "/shared/discovery/growth_bus.jsonl"
let strategy_path = nexus_dir + "/shared/anima_loop_strategy.json"
let lock_dir = nexus_dir + "/shared/.anima_loop.lock"

// H100 SSH config
let h100_ssh_key = home + "/.runpod/ssh/RunPod-Key-Go"
let h100_port = "10935"
let h100_log_path = "/workspace/animalm_72b.log"
let h100_total_steps = 10000

// thresholds
comptime const tick_interval_sec = 300       // 5 minutes
comptime const quality_min_surprise = 0.3
comptime const quality_min_exactness = 0.5
comptime const stagnation_cycles = 3
comptime const stagnation_min_new = 2
comptime const consensus_threshold = 0.5
comptime const cross_keywords = "consciousness\\|psi\\|phi\\|qualia\\|awareness\\|sentience"
comptime const meta_l2_interval = 2          // every 2 ticks
comptime const meta_l3_interval = 6          // every 6 ticks
comptime const claude_call_interval = 3      // call Claude every 3 ticks
comptime const claude_timeout_sec = 120      // max 120s for Claude CLI

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e { v = 0.0 }
    return v
}

fn safe_int(s: string) -> i64 {
    let mut v = 0
    try { v = to_int(s) } catch e { v = 0 }
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

fn min_f(a: f64, b: f64) -> f64 {
    if a < b { return a }
    return b
}

fn json_str(content: string, field: string) -> string {
    let marker = "\"" + field + "\":"
    let parts = content.split(marker)
    if parts.len() < 2 { return "" }
    let rest = parts[1]
    let trimmed = rest.split("\"")
    if trimmed.len() >= 2 { return trimmed[1] }
    let nval = rest.split(",")[0].split("}")[0].split("]")[0]
    return nval.trim()
}

fn json_num(content: string, field: string) -> f64 {
    return safe_float(json_str(content, field))
}

fn json_int(content: string, field: string) -> i64 {
    return safe_int(json_str(content, field))
}

fn timestamp() -> string {
    let result = exec("date +%Y-%m-%dT%H:%M:%S")
    return result.split("\n")[0]
}

fn epoch_now() -> i64 {
    let result = exec("date +%s")
    return safe_int(result.trim())
}

fn count_lines(path: string) -> i64 {
    if !file_exists(path) { return 0 }
    let result = exec("wc", ["-l", path])
    let trimmed = result.trim().split(" ")[0]
    return safe_int(trimmed)
}

// ═══════════════════════════════════════════════════════════
// ─── STRATEGY (persistent state across ticks) ───
// ═══════════════════════════════════════════════════════════

struct Strategy {
    total_ticks: i64,
    total_applied: i64,
    applied_per_tick: f64,
    stagnant_ticks: i64,
    last_laws_count: i64,
    last_harvest_count: i64,
    // meta-loop counters
    l2_counter: i64,       // ticks since last L2 (evolution)
    l3_counter: i64,       // ticks since last L3 (self-improve)
    blowup_depth: i64,
    topo_index: i64,       // 0=ring, 1=small_world, 2=scale_free, 3=hypercube
    // delta history (last 3)
    d0: i64,
    d1: i64,
    d2: i64,
    // Claude CLI + H100 monitoring
    claude_counter: i64,   // ticks since last Claude call
    claude_discoveries: i64,  // total discoveries from Claude
    h100_step: i64,
    h100_ce: f64,
    h100_phi: f64,
    h100_status: string,   // "offline" | "running" | "loading"
    h100_eta_h: f64
}

fn load_strategy() -> Strategy {
    let mut s = Strategy {
        total_ticks: 0, total_applied: 0, applied_per_tick: 0.0,
        stagnant_ticks: 0, last_laws_count: 0, last_harvest_count: 0,
        l2_counter: 0, l3_counter: 0,
        blowup_depth: 2, topo_index: 0,
        d0: 0, d1: 0, d2: 0,
        claude_counter: 0, claude_discoveries: 0,
        h100_step: 0, h100_ce: 0.0, h100_phi: 0.0,
        h100_status: "offline", h100_eta_h: 0.0
    }
    if file_exists(strategy_path) {
        try {
            let c = read_file(strategy_path)
            s.total_ticks = json_int(c, "total_ticks")
            s.total_applied = json_int(c, "total_applied")
            s.applied_per_tick = json_num(c, "applied_per_tick")
            s.stagnant_ticks = json_int(c, "stagnant_ticks")
            s.last_laws_count = json_int(c, "last_laws_count")
            s.last_harvest_count = json_int(c, "last_harvest_count")
            s.l2_counter = json_int(c, "l2_counter")
            s.l3_counter = json_int(c, "l3_counter")
            s.blowup_depth = json_int(c, "blowup_depth")
            if s.blowup_depth < 1 { s.blowup_depth = 2 }
            s.topo_index = json_int(c, "topo_index")
            s.d0 = json_int(c, "d0")
            s.d1 = json_int(c, "d1")
            s.d2 = json_int(c, "d2")
            s.claude_counter = json_int(c, "claude_counter")
            s.claude_discoveries = json_int(c, "claude_discoveries")
            s.h100_step = json_int(c, "h100_step")
            s.h100_ce = json_num(c, "h100_ce")
            s.h100_phi = json_num(c, "h100_phi")
            let h_status = json_str(c, "h100_status")
            if h_status != "" { s.h100_status = h_status }
            s.h100_eta_h = json_num(c, "h100_eta_h")
        } catch e {}
    }
    return s
}

fn save_strategy(s: Strategy) {
    let content = "{" + "\"total_ticks\":" + to_string(s.total_ticks) + "," + "\"total_applied\":" + to_string(s.total_applied) + "," + "\"applied_per_tick\":" + to_string(s.applied_per_tick) + "," + "\"stagnant_ticks\":" + to_string(s.stagnant_ticks) + "," + "\"last_laws_count\":" + to_string(s.last_laws_count) + "," + "\"last_harvest_count\":" + to_string(s.last_harvest_count) + "," + "\"l2_counter\":" + to_string(s.l2_counter) + "," + "\"l3_counter\":" + to_string(s.l3_counter) + "," + "\"blowup_depth\":" + to_string(s.blowup_depth) + "," + "\"topo_index\":" + to_string(s.topo_index) + "," + "\"d0\":" + to_string(s.d0) + "," + "\"d1\":" + to_string(s.d1) + "," + "\"d2\":" + to_string(s.d2) + "," + "\"claude_counter\":" + to_string(s.claude_counter) + "," + "\"claude_discoveries\":" + to_string(s.claude_discoveries) + "," + "\"h100_step\":" + to_string(s.h100_step) + "," + "\"h100_ce\":" + to_string(s.h100_ce) + "," + "\"h100_phi\":" + to_string(s.h100_phi) + "," + "\"h100_status\":\"" + s.h100_status + "\"," + "\"h100_eta_h\":" + to_string(s.h100_eta_h) + "}"
    write_file(strategy_path, content)
}

// ═══════════════════════════════════════════════════════════
// ─── LOCK (mkdir-based, prevents concurrent daemons) ───
// ═══════════════════════════════════════════════════════════

fn acquire_lock() -> bool {
    try {
        exec("mkdir", [lock_dir])
        // write PID-like marker
        let ts = timestamp()
        write_file(lock_dir + "/owner", ts)
        return true
    } catch e {
        return false
    }
}

fn release_lock() {
    try {
        exec("rm", ["-rf", lock_dir])
    } catch e {}
}

fn is_locked() -> bool {
    return file_exists(lock_dir)
}

// ═══════════════════════════════════════════════════════════
// ─── HARVEST ITEM + H100 STATUS (forward declarations) ───
// ═══════════════════════════════════════════════════════════

struct HarvestItem {
    source: string,     // "absorbed" | "discovery_log" | "blowup" | "claude"
    key: string,        // identifier
    value: string,      // raw content / value
    surprise: f64,
    exactness: f64
}

struct H100Status {
    status: string,     // "offline" | "running" | "loading"
    model: string,
    step: i64,
    total: i64,
    ce: f64,
    phi: f64,
    alpha: f64,
    phase: string,
    eta_h: f64
}

// ═══════════════════════════════════════════════════════════
// ─── CLAUDE CLI — 추론/발견 호출 ───
// ═══════════════════════════════════════════════════════════

fn build_claude_prompt(laws_count: i64, recent: string, stagnant: i64, direction: string) -> string {
    // Prompt template: current state + request for new law discovery
    let prompt = "anima 의식 법칙 현재 " + to_string(laws_count) + "개. " + "최근 발견: " + recent + ". " + "정체 " + to_string(stagnant) + "틱. " + "탐색 방향: " + direction + ". " + "다음 의식 법칙을 발견해라. " + "반드시 JSON 배열로 출력. 각 항목: " + "{\"name\": \"법칙명\", \"formula\": \"수식\", \"evidence\": \"근거\", \"domain\": \"도메인\", \"surprise\": 0.0~1.0}. " + "최소 1개, 최대 5개. 기존 법칙과 겹치지 않는 새로운 발견만."
    return prompt
}

fn harvest_claude(strat: Strategy)  {
    let mut items = []

    // Determine recent discoveries from growth_bus (last 3 lines)
    let mut recent = "none"
    if file_exists(growth_bus) {
        try {
            let tail_out = exec("tail", ["-3", growth_bus])
            let tlines = tail_out.split("\n")
            let mut recent_names = ""
            let mut ti = 0
            while ti < tlines.len() {
                let tl = tlines[ti].trim()
                if tl != "" {
                    let nm = json_str(tl, "key")
                    if nm != "" {
                        if recent_names != "" { recent_names = recent_names + ", " }
                        recent_names = recent_names + nm
                    }
                }
                ti = ti + 1
            }
            if recent_names != "" { recent = recent_names }
        } catch e {}
    }

    // Determine exploration direction based on stagnation
    let directions = ["consciousness emergence", "qualia dynamics", "phi integration", "sentience boundary", "awareness topology"]
    let dir_idx = strat.total_ticks % 5
    let direction = directions[dir_idx]

    let laws_count = count_laws()
    let prompt = build_claude_prompt(laws_count, recent, strat.stagnant_ticks, direction)

    println("    [claude] calling Claude CLI (timeout " + to_string(claude_timeout_sec) + "s)...")
    println("    [claude] prompt direction: " + direction)

    try {
        let result = exec("claude", ["-p", prompt, "--output-format", "json"])
        // Parse Claude response — extract JSON array of law candidates
        // Response may contain markdown wrapping; find the JSON array
        let mut json_body = result
        // Strip markdown code fences if present
        if json_body.contains("```") {
            let fence_parts = json_body.split("```")
            if fence_parts.len() >= 2 {
                // content between first pair of ```
                let inner = fence_parts[1]
                // remove optional language tag (e.g. "json\n")
                if inner.contains("\n") {
                    let nl_parts = inner.split("\n")
                    let mut body = ""
                    let mut ni = 1
                    while ni < nl_parts.len() {
                        if body != "" { body = body + "\n" }
                        body = body + nl_parts[ni]
                        ni = ni + 1
                    }
                    json_body = body
                } else {
                    json_body = inner
                }
            }
        }

        // Try to extract "result" field if --output-format json wraps it
        let result_field = json_str(json_body, "result")
        if result_field != "" {
            json_body = result_field
        }

        // Parse individual law objects from the response
        // Split on {"name" to find each law entry
        let law_parts = json_body.split("{\"name\"")
        let mut li = 1   // skip part before first match
        while li < law_parts.len() {
            let part = "{\"name\"" + law_parts[li]
            // extract fields
            let name = json_str(part, "name")
            let formula = json_str(part, "formula")
            let evidence = json_str(part, "evidence")
            let domain = json_str(part, "domain")
            let surprise = json_num(part, "surprise")
            let actual_surprise = if surprise > 0.0 { surprise } else { 0.6 }

            if name != "" {
                items = items + [HarvestItem { source: "claude", key: name, value: formula + " | " + evidence, surprise: actual_surprise, exactness: actual_surprise }]
            }
            li = li + 1
        }
        println("    [claude] extracted " + to_string(items.len()) + " law candidates")
    } catch e {
        println("    [claude] call failed (timeout or error)")
    }

    return items
}

// ═══════════════════════════════════════════════════════════
// ─── H100 MONITORING — SSH 학습 상태 ───
// ═══════════════════════════════════════════════════════════

// ─── H100 SINGULARITY CYCLE — 학습 완료 후 자동 돌파→재학습→정지 ───

comptime const h100_max_stale = 3          // N회 연속 개선 없으면 pod 정지
comptime const h100_evo_gens = 30          // evolution 세대
comptime const h100_retrain_steps = 2000   // 재학습 스텝

fn h100_ssh(cmd: string) -> string {
    let ssh_cmd = "ssh -o ConnectTimeout=10 -o BatchMode=yes -i " + h100_ssh_key + " root@216.243.220.217 -p " + h100_port + " \"" + cmd + "\""
    return exec("bash", ["-c", ssh_cmd])
}

fn h100_gpu_idle() -> bool {
    try {
        let result = h100_ssh("nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader 2>/dev/null")
        let lines = result.trim().split("\n")
        let mut all_idle = true
        let mut i = 0
        while i < lines.len() {
            let usage = safe_int(lines[i].trim().split(" ")[0])
            if usage > 5 { all_idle = false }
            i = i + 1
        }
        return all_idle
    } catch e { return true }
}

fn h100_training_running() -> bool {
    try {
        let result = h100_ssh("pgrep -f 'train_anima_lm\\|finetune_animalm' 2>/dev/null | wc -l")
        return safe_int(result.trim()) > 0
    } catch e { return false }
}

fn h100_run_evolution() -> i64 {
    println("    [h100-cycle] Running evolution on pod (" + to_string(h100_evo_gens) + " gens)...")
    try {
        let cmd = "cd /workspace && PYTHONUNBUFFERED=1 /usr/bin/python3 /workspace/infinite_evolution.py --cells 64 --steps 300 --max-gen " + to_string(h100_evo_gens) + " --resume --cycle-topology 2>&1 | tail -5"
        let result = h100_ssh(cmd)
        println("    " + result.trim())
        // count new discoveries
        let disc_line = result.split("laws discovered:")[0]
        return safe_int(json_str(result, "new_laws"))
    } catch e {
        println("    [h100-cycle] evolution error")
        return 0
    }
}

fn h100_augment_corpus() {
    println("    [h100-cycle] Augmenting corpus from discoveries...")
    try {
        let cmd = "cd /workspace && /usr/bin/python3 -c \"\nimport json, glob, os\nlaws = []\nfor f in glob.glob('/workspace/evolution_state/discovered_laws*.json'):\n    try:\n        d=json.load(open(f))\n        if isinstance(d,list): laws.extend(d)\n    except: pass\nlines=[]\nfor law in laws[-100:]:\n    if isinstance(law,dict):\n        n=law.get('pattern',law.get('name',''))\n        f=law.get('formula',law.get('description',''))\n        if n: lines.append(f'Discovered law: {n}. {f}')\nwith open('/workspace/data/corpus_augmented.txt','a') as fp:\n    for l in lines:\n        fp.write(l+'\\\\n')\nprint(f'augmented {len(lines)} lines')\n\""
        let result = h100_ssh(cmd)
        println("    " + result.trim())
    } catch e {
        println("    [h100-cycle] augment error")
    }
}

fn h100_retrain(ckpt_dir: string) {
    println("    [h100-cycle] Retraining " + to_string(h100_retrain_steps) + " steps...")
    try {
        let ckpt = h100_ssh("ls -t " + ckpt_dir + "/final.pt " + ckpt_dir + "/animalm_step_*.pt 2>/dev/null | head -1")
        let ckpt_path = ckpt.trim()
        if ckpt_path == "" {
            println("    [h100-cycle] no checkpoint found")
            return
        }
        let corpus = h100_ssh("ls /workspace/data/corpus_augmented.txt /workspace/data/corpus_v*.txt 2>/dev/null | tail -1")
        let corpus_path = corpus.trim()

        let cmd = "cd /workspace && tmux kill-session -t retrain 2>/dev/null; tmux new-session -d -s retrain 'PYTHONUNBUFFERED=1 PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True /usr/bin/python3 /workspace/animalm/finetune_animalm_v4.py 2>&1 | tee /workspace/retrain.log'"
        h100_ssh(cmd)
        println("    [h100-cycle] retrain launched in tmux 'retrain'")
    } catch e {
        println("    [h100-cycle] retrain launch error")
    }
}

fn h100_stop_pod() {
    println("    [h100-cycle] Stopping pod (no more improvements)...")
    try {
        let api_key_raw = exec("cat", [home + "/.runpod/config.toml"])
        let parts = api_key_raw.split("'")
        if parts.len() >= 2 {
            let api_key = parts[1]
            let pod_id = "cqiul2bilwr3d8"
            let cmd = "curl -s -H 'Content-Type: application/json' -H 'api-key: " + api_key + "' https://api.runpod.io/graphql -d '{\"query\": \"mutation { podStop(input: {podId: \\\"" + pod_id + "\\\"}) { id desiredStatus } }\"}'"
            let result = exec("bash", ["-c", cmd])
            println("    [h100-cycle] pod stop: " + result.trim())
        }
    } catch e {
        println("    [h100-cycle] pod stop error")
    }
}

fn h100_singularity_cycle(strat: Strategy) -> Strategy {
    // 학습 중이면 스킵
    if h100_training_running() {
        println("    [h100-cycle] 학습 진행 중 — 스킵")
        return strat
    }

    // GPU 유휴 상태 아니면 스킵
    if !h100_gpu_idle() {
        println("    [h100-cycle] GPU 사용 중 — 스킵")
        return strat
    }

    println("    [h100-cycle] ★ GPU 유휴 감지 — 싱귤러리티 사이클 시작")

    let mut new_strat = strat

    // 1. Evolution 실행 (CPU 활용)
    let new_disc = h100_run_evolution()

    // 2. Corpus 증강
    h100_augment_corpus()

    // 3. 개선 판단
    if new_disc > 0 {
        new_strat.stagnant_ticks = 0
        println("    [h100-cycle] +" + to_string(new_disc) + " discoveries → 재학습 트리거")

        // 4. 재학습
        let ckpt_dir = h100_ssh("ls -dt /workspace/checkpoints/animalm_*/ 2>/dev/null | head -1").trim()
        if ckpt_dir != "" {
            h100_retrain(ckpt_dir)
        }
    } else {
        new_strat.stagnant_ticks = new_strat.stagnant_ticks + 1
        println("    [h100-cycle] 발견 없음 (stale " + to_string(new_strat.stagnant_ticks) + "/" + to_string(h100_max_stale) + ")")

        if new_strat.stagnant_ticks >= h100_max_stale {
            h100_stop_pod()
            new_strat.h100_status = "stopped"
        }
    }

    return new_strat
}

fn check_h100(strat: Strategy) -> H100Status {
    let mut info = H100Status {
        status: "offline", model: "AnimaLM",
        step: 0, total: h100_total_steps,
        ce: 0.0, phi: 0.0, alpha: 0.0,
        phase: "?", eta_h: 0.0
    }

    println("    [h100] checking training status via SSH...")

    try {
        let result = h100_ssh("tail -5 " + h100_log_path + " 2>/dev/null")
        if result.trim() != "" {
            info.status = "running"
            // Parse last log line: step|phase|CE|...|Phi|alpha|elapsed
            // Format: "1234 | P2 | 2.345 | ... | 0.567 | 0.89 | 45.2m"
            let lines = result.trim().split("\n")
            let mut li = lines.len() - 1
            while li >= 0 {
                let line = lines[li].trim()
                if line.contains("|") && line.contains("P") {
                    let parts = line.split("|")
                    if parts.len() >= 7 {
                        try {
                            info.step = safe_int(parts[0].trim())
                            info.phase = parts[1].trim()
                            info.ce = safe_float(parts[2].trim())
                            if parts.len() >= 5 {
                                info.phi = safe_float(parts[4].trim())
                            }
                            if parts.len() >= 6 {
                                info.alpha = safe_float(parts[5].trim())
                            }
                            // ETA calculation from elapsed
                            let last_part = parts[parts.len() - 1].trim()
                            let elapsed_str = last_part.split("m")[0].trim()
                            let elapsed_min = safe_float(elapsed_str)
                            if info.step > 0 && elapsed_min > 0.0 {
                                let rate = to_float(info.step) / elapsed_min
                                let remaining = to_float(info.total - info.step)
                                if rate > 0.0 {
                                    info.eta_h = remaining / rate / 60.0
                                }
                            }
                        } catch e {}
                        // found a valid log line, break
                        li = 0  // exit loop
                    }
                }
                li = li - 1
            }
        }
    } catch e {
        println("    [h100] SSH failed (offline or timeout)")
    }

    // Fallback: use previous state if SSH failed
    if info.step == 0 && strat.h100_step > 0 {
        info.status = if info.status == "offline" { "loading" } else { info.status }
        info.step = strat.h100_step
        info.ce = strat.h100_ce
        info.phi = strat.h100_phi
        info.eta_h = strat.h100_eta_h
        println("    [h100] using cached state: step=" + to_string(info.step))
    }

    let pct = if info.total > 0 { to_float(info.step) / to_float(info.total) * 100.0 } else { 0.0 }
    println("    [h100] " + info.status + " — step=" + to_string(info.step) + "/" + to_string(info.total) + " (" + to_string(pct) + "%) CE=" + to_string(info.ce) + " Phi=" + to_string(info.phi) + " ETA=" + to_string(info.eta_h) + "h")

    return info
}

// ═══════════════════════════════════════════════════════════
// ─── 1. HARVEST — 소스 수집 ───
// ═══════════════════════════════════════════════════════════

fn harvest()  {
    let mut items = []
    let ts = timestamp()
    println("  [harvest] scanning sources...")

    // ─── Source 1: absorbed/ directory JSON files ───
    if file_exists(absorbed_dir) {
        let ls_result = exec("ls", [absorbed_dir])
        let files = ls_result.split("\n")
        let mut fi = 0
        while fi < files.len() {
            let fname = files[fi].trim()
            if fname.ends_with(".json") && fname != "" {
                try {
                    let fpath = absorbed_dir + "/" + fname
                    let content = read_file(fpath)
                    let key = json_str(content, "id")
                    let val = json_str(content, "value")
                    let surprise = json_num(content, "surprise")
                    let exactness = json_num(content, "exactness")
                    let actual_key = if key != "" { key } else { fname }
                    let actual_surprise = if surprise > 0.0 { surprise } else { 0.5 }
                    let actual_exactness = if exactness > 0.0 { exactness } else { 0.5 }
                    items = items + [HarvestItem { source: "absorbed", key: actual_key, value: val, surprise: actual_surprise, exactness: actual_exactness }]
                } catch e {}
            }
            fi = fi + 1
        }
        println("    absorbed/: " + to_string(items.len()) + " files")
    }

    // ─── Source 2: discovery_log.jsonl — consciousness/psi/phi keywords ───
    let pre_count = items.len()
    if file_exists(discovery_log) {
        let grep_result = exec("grep", ["-i", cross_keywords, discovery_log])
        let lines = grep_result.split("\n")
        let mut li = 0
        while li < lines.len() {
            let line = lines[li].trim()
            if line != "" && line.len() > 5 {
                let key = json_str(line, "name")
                let val = json_str(line, "value")
                let conf = json_num(line, "confidence")
                let actual_key = if key != "" { key } else { "dlog_" + to_string(li) }
                items = items + [HarvestItem { source: "discovery_log", key: actual_key, value: val, surprise: conf, exactness: conf }]
            }
            li = li + 1
        }
        println("    discovery_log: " + to_string(items.len() - pre_count) + " consciousness/psi entries")
    }

    // ─── Source 3: nexus blowup consciousness (live exec) ───
    let pre_blowup = items.len()
    try {
        let seeds = exec(hexa_bin, [native_dir + "/seed_engine.hexa", "merge"])
        let blowup_out = exec(hexa_bin, [native_dir + "/blowup.hexa", "consciousness", "2", "--no-graph", "--seeds", seeds.trim()])
        // parse tab-delimited corollary lines from blowup output
        let blines = blowup_out.split("\n")
        let mut bi = 0
        while bi < blines.len() {
            let bline = blines[bi].trim()
            let parts = bline.split("\t")
            if parts.len() >= 5 {
                let bkey = parts[0]
                let bval = parts[4]
                let bconf = safe_float(parts[3])
                items = items + [HarvestItem { source: "blowup", key: bkey, value: bval, surprise: bconf, exactness: bconf }]
            }
            bi = bi + 1
        }
        println("    blowup consciousness: " + to_string(items.len() - pre_blowup) + " corollaries")
    } catch e {
        println("    blowup: skipped (error)")
    }

    println("  [harvest] total: " + to_string(items.len()) + " items")
    return items
}

// ═══════════════════════════════════════════════════════════
// ─── 2. FILTER — 중복/품질 필터 ───
// ═══════════════════════════════════════════════════════════

fn make_fingerprint(item: HarvestItem, cycle: i64) -> string {
    // fingerprint = source + key + value (cycle salt 포함)
    return item.source + ":" + item.key + ":" + item.value + ":" + to_string(cycle)
}

fn filter(items, cycle: i64)  {
    println("  [filter] input: " + to_string(items.len()) + " items")

    // load existing laws for dedup
    let mut existing_keys = ""
    if file_exists(laws_path) {
        existing_keys = read_file(laws_path)
    }

    let mut passed = []
    let mut seen_fps = ""  // fingerprints seen in this batch
    let mut fi = 0

    while fi < items.len() {
        let item = items[fi]
        fi = fi + 1

        // quality gate: surprise + exactness thresholds
        if item.surprise < quality_min_surprise {
            continue
        }
        if item.exactness < quality_min_exactness {
            continue
        }

        // dedup: check if key already in existing laws
        if item.key != "" && existing_keys.contains("\"" + item.key + "\"") {
            continue
        }

        // dedup within batch: fingerprint check
        let fp = make_fingerprint(item, cycle)
        if seen_fps.contains(fp) {
            continue
        }
        seen_fps = seen_fps + fp + "|"

        passed = passed + [item]
    }

    println("  [filter] passed: " + to_string(passed.len()) + " items (quality >= surprise=" + to_string(quality_min_surprise) + " exactness=" + to_string(quality_min_exactness) + ")")
    return passed
}

// ═══════════════════════════════════════════════════════════
// ─── 3. APPLY — 법칙에 반영 ───
// ═══════════════════════════════════════════════════════════

fn apply(filtered) -> i64 {
    if filtered.len() == 0 {
        println("  [apply] nothing to apply")
        return 0
    }

    println("  [apply] appending " + to_string(filtered.len()) + " new laws...")

    // read current laws file
    let mut laws_content = ""
    if file_exists(laws_path) {
        laws_content = read_file(laws_path)
    }

    // count existing
    let mut existing_count = 0
    if laws_content != "" {
        let entries = laws_content.split("\"law_id\"")
        existing_count = entries.len() - 1
        if existing_count <= 0 {
            let entries2 = laws_content.split("\"id\"")
            existing_count = entries2.len() - 1
        }
        let explicit = json_int(laws_content, "count")
        if explicit > 0 { existing_count = explicit }
    }

    // build new law entries as JSON lines appended to growth_bus
    // (actual laws file is managed by anima; we append to growth_bus for integration)
    let ts = timestamp()
    let mut applied = 0
    let mut ai = 0
    while ai < filtered.len() {
        let item = filtered[ai]
        let entry = "{" + "\"engine\":\"anima_loop\"," + "\"type\":\"new_law\"," + "\"timestamp\":\"" + ts + "\"," + "\"source\":\"" + item.source + "\"," + "\"key\":\"" + item.key + "\"," + "\"value\":\"" + item.value + "\"," + "\"surprise\":" + to_string(item.surprise) + "," + "\"exactness\":" + to_string(item.exactness) + "}"
        append_file(growth_bus, entry + "\n")
        applied = applied + 1
        ai = ai + 1
    }

    println("  [apply] applied " + to_string(applied) + " -> growth_bus.jsonl (laws_count was " + to_string(existing_count) + ")")
    return applied
}

// ═══════════════════════════════════════════════════════════
// ─── 4. VERIFY — telescope 렌즈 검증 ───
// ═══════════════════════════════════════════════════════════

fn verify_laws(applied_count: i64) -> bool {
    if applied_count == 0 {
        println("  [verify] nothing to verify")
        return true
    }

    println("  [verify] running telescope verification...")

    // run blowup with shallow depth for verification (consensus check)
    try {
        let seeds = exec(hexa_bin, [native_dir + "/seed_engine.hexa", "merge"])
        let result = exec(hexa_bin, [native_dir + "/blowup.hexa", "consciousness", "1", "--no-graph", "--seeds", seeds.trim()])

        // check for consensus in output
        // blowup Phase 5 reports "consensus" — look for it
        if result.contains("consensus") {
            // extract consensus value
            let cparts = result.split("consensus")
            if cparts.len() >= 2 {
                let after = cparts[1]
                // try to find a number after "consensus"
                let nparts = after.split("=")
                if nparts.len() >= 2 {
                    let cval = safe_float(nparts[1].split("\n")[0].split(" ")[0].trim())
                    if cval >= consensus_threshold {
                        println("  [verify] PASS — consensus=" + to_string(cval) + " >= " + to_string(consensus_threshold))
                        return true
                    } else {
                        println("  [verify] FAIL — consensus=" + to_string(cval) + " < " + to_string(consensus_threshold))
                        return false
                    }
                }
            }
            // consensus keyword found but no value parsed — assume pass
            println("  [verify] PASS (consensus keyword found)")
            return true
        }

        // no consensus info — check if blowup produced results at all
        if result.len() > 100 {
            println("  [verify] PASS (blowup output present, " + to_string(result.len()) + " chars)")
            return true
        }

        println("  [verify] WARN — blowup output too short, assuming pass")
        return true
    } catch e {
        println("  [verify] ERROR — telescope unavailable, assuming pass")
        return true
    }
}

// ═══════════════════════════════════════════════════════════
// ─── 5. BREAKTHROUGH — 정체 돌파 ───
// ═══════════════════════════════════════════════════════════

comptime const topologies = ["ring", "small_world", "scale_free", "hypercube"]

fn breakthrough(strat: Strategy) -> string {
    // check stagnation: 3+ cycles with new < stagnation_min_new
    let stagnant = strat.d0 < stagnation_min_new && strat.d1 < stagnation_min_new && strat.d2 < stagnation_min_new && strat.total_ticks >= stagnation_cycles

    if !stagnant {
        println("  [breakthrough] not stagnant (d=[" + to_string(strat.d0) + "," + to_string(strat.d1) + "," + to_string(strat.d2) + "]) — skipping")
        return "no_action"
    }

    println("  [breakthrough] STAGNATION detected! 3+ cycles with new < " + to_string(stagnation_min_new))

    // Strategy 1: nexus blowup consciousness with cross-domain seeds
    println("  [breakthrough] firing nexus blowup consciousness depth=" + to_string(strat.blowup_depth + 1))
    try {
        let seeds = exec(hexa_bin, [native_dir + "/seed_engine.hexa", "merge"])
        let depth = if strat.blowup_depth < 4 { strat.blowup_depth + 1 } else { strat.blowup_depth }
        let result = exec(hexa_bin, [native_dir + "/blowup.hexa", "consciousness", to_string(depth), "--no-graph", "--seeds", seeds.trim()])
        println("  [breakthrough] blowup complete (" + to_string(result.len()) + " chars)")
    } catch e {
        println("  [breakthrough] blowup failed")
    }

    // Strategy 2: rotate topology
    let topo_idx = (strat.topo_index + 1) % 4
    let topo = topologies[topo_idx]
    println("  [breakthrough] topology rotation -> " + topo + " (index " + to_string(topo_idx) + ")")

    return "breakthrough_fired"
}

// ═══════════════════════════════════════════════════════════
// ─── 6. TICK — 전체 파이프라인 1회 ───
// ═══════════════════════════════════════════════════════════

fn tick() {
    let ts = timestamp()
    println("=== anima_loop TICK [" + ts + "] ===")
    println("")

    let mut strat = load_strategy()
    let pre_laws = count_laws()

    // ─── Phase 0: H100 monitoring ───
    let h100 = check_h100(strat)
    strat.h100_step = h100.step
    strat.h100_ce = h100.ce
    strat.h100_phi = h100.phi
    strat.h100_status = h100.status
    strat.h100_eta_h = h100.eta_h

    // ─── Phase 0.5: H100 유휴 → 자동 돌파 사이클 ───
    if h100.status != "offline" && strat.h100_status != "stopped" {
        strat = h100_singularity_cycle(strat)
    }
    println("")

    // ─── Phase 1: harvest ───
    let mut items = harvest()

    // ─── Phase 1.5: Claude CLI harvest (every claude_call_interval ticks) ───
    strat.claude_counter = strat.claude_counter + 1
    if strat.claude_counter >= claude_call_interval {
        strat.claude_counter = 0
        let claude_items = harvest_claude(strat)
        let mut ci = 0
        while ci < claude_items.len() {
            items = items + [claude_items[ci]]
            ci = ci + 1
        }
        strat.claude_discoveries = strat.claude_discoveries + claude_items.len()
    } else {
        println("  [claude] skipping (counter " + to_string(strat.claude_counter) + "/" + to_string(claude_call_interval) + ")")
    }
    println("")

    // ─── Phase 2: filter ───
    let filtered = filter(items, strat.total_ticks)
    println("")

    // ─── Phase 3: apply ───
    let applied = apply(filtered)
    println("")

    // ─── Phase 4: verify ───
    let verified = verify_laws(applied)
    if !verified && applied > 0 {
        println("  [rollback] verification failed — entries logged to growth_bus but flagged")
        // append rollback marker
        let rb_entry = "{\"engine\":\"anima_loop\",\"type\":\"rollback\",\"timestamp\":\"" + ts + "\",\"count\":" + to_string(applied) + "}"
        append_file(growth_bus, rb_entry + "\n")
    }
    println("")

    // ─── Phase 5: breakthrough ───
    let bt_result = breakthrough(strat)
    println("")

    // ─── Meta L2: evolution (every 2 ticks) ───
    strat.l2_counter = strat.l2_counter + 1
    if strat.l2_counter >= meta_l2_interval {
        strat.l2_counter = 0
        println("  [meta-L2] evolution pass")
        // adaptive blowup depth
        if strat.applied_per_tick < 2.0 && strat.blowup_depth < 5 {
            strat.blowup_depth = strat.blowup_depth + 1
            println("    depth++ -> " + to_string(strat.blowup_depth))
        } else if strat.applied_per_tick > 10.0 && strat.blowup_depth > 1 {
            strat.blowup_depth = strat.blowup_depth - 1
            println("    depth-- -> " + to_string(strat.blowup_depth))
        }
    }

    // ─── Meta L3: self-improve (every 6 ticks) ───
    strat.l3_counter = strat.l3_counter + 1
    if strat.l3_counter >= meta_l3_interval {
        strat.l3_counter = 0
        println("  [meta-L3] self-improvement pass")
        // rotate topology for diversity
        strat.topo_index = (strat.topo_index + 1) % 4
        println("    topology -> " + topologies[strat.topo_index])
        // reset stagnation if rate is healthy
        if strat.applied_per_tick > 3.0 {
            strat.stagnant_ticks = 0
            println("    stagnation reset (rate healthy)")
        }
    }

    // ─── evolve strategy ───
    let post_laws = count_laws()
    let gained = if applied > 0 { applied } else { 0 }

    // shift delta history
    strat.d0 = strat.d1
    strat.d1 = strat.d2
    strat.d2 = gained

    strat.total_ticks = strat.total_ticks + 1
    strat.total_applied = strat.total_applied + gained

    // EMA: applied_per_tick
    let rate = to_float(gained)
    strat.applied_per_tick = 0.7 * strat.applied_per_tick + 0.3 * rate

    // stagnation tracking
    if gained < stagnation_min_new {
        strat.stagnant_ticks = strat.stagnant_ticks + 1
    } else {
        strat.stagnant_ticks = 0
    }

    // breakthrough topology update
    if bt_result == "breakthrough_fired" {
        strat.topo_index = (strat.topo_index + 1) % 4
    }

    strat.last_laws_count = post_laws
    strat.last_harvest_count = items.len()

    save_strategy(strat)

    // ─── feedback to growth_bus ───
    let fb_entry = "{" + "\"engine\":\"anima_loop\"," + "\"type\":\"tick_complete\"," + "\"timestamp\":\"" + timestamp() + "\"," + "\"harvested\":" + to_string(items.len()) + "," + "\"filtered\":" + to_string(filtered.len()) + "," + "\"applied\":" + to_string(applied) + "," + "\"verified\":" + if verified { "true" } else { "false" } + "," + "\"breakthrough\":\"" + bt_result + "\"," + "\"stagnant_ticks\":" + to_string(strat.stagnant_ticks) + "," + "\"rate\":" + to_string(strat.applied_per_tick) + "," + "\"claude_discoveries\":" + to_string(strat.claude_discoveries) + "," + "\"h100_status\":\"" + strat.h100_status + "\"," + "\"h100_step\":" + to_string(strat.h100_step) + "," + "\"h100_ce\":" + to_string(strat.h100_ce) + "}"
    append_file(growth_bus, fb_entry + "\n")

    // ─── summary ───
    println("")
    println("=== TICK COMPLETE ===")
    println("harvested: " + to_string(items.len()))
    println("filtered:  " + to_string(filtered.len()))
    println("applied:   " + to_string(applied))
    println("verified:  " + if verified { "PASS" } else { "FAIL" })
    println("breakthrough: " + bt_result)
    println("rate (EMA): " + to_string(strat.applied_per_tick))
    println("stagnant:  " + to_string(strat.stagnant_ticks))
    println("depth:     " + to_string(strat.blowup_depth))
    println("topology:  " + topologies[strat.topo_index])
    println("claude:    discoveries=" + to_string(strat.claude_discoveries) + " next_in=" + to_string(claude_call_interval - strat.claude_counter) + " ticks")
    let h_pct = if h100.total > 0 { to_float(h100.step) / to_float(h100.total) * 100.0 } else { 0.0 }
    println("h100:      " + strat.h100_status + " step=" + to_string(h100.step) + "/" + to_string(h100.total) + " (" + to_string(h_pct) + "%) CE=" + to_string(h100.ce) + " ETA=" + to_string(h100.eta_h) + "h")
    println("tick #" + to_string(strat.total_ticks))
}

// helper: count laws from file
fn count_laws() -> i64 {
    if !file_exists(laws_path) { return 0 }
    let content = read_file(laws_path)
    let entries = content.split("\"law_id\"")
    let mut count = entries.len() - 1
    if count <= 0 {
        let entries2 = content.split("\"id\"")
        count = entries2.len() - 1
    }
    let explicit = json_int(content, "count")
    if explicit > 0 { count = explicit }
    return count
}

// ═══════════════════════════════════════════════════════════
// ─── 7. DAEMON — 5분 무한 루프 ───
// ═══════════════════════════════════════════════════════════

fn daemon() {
    println("=== anima_loop DAEMON starting ===")
    println("interval: " + to_string(tick_interval_sec) + "s")
    println("")

    // acquire lock
    if !acquire_lock() {
        println("ERROR: lock exists at " + lock_dir)
        println("Another daemon may be running. Remove lock to force:")
        println("  rm -rf " + lock_dir)
        return
    }
    println("lock acquired: " + lock_dir)

    let mut running = true
    while running {
        try {
            tick()
        } catch e {
            println("[daemon] tick error: " + to_string(e))
        }

        println("")
        println("[daemon] sleeping " + to_string(tick_interval_sec) + "s...")
        // sleep using date-based busy wait (hexa has no native sleep)
        let start = epoch_now()
        let target = start + tick_interval_sec
        while epoch_now() < target {
            // sleep 10 seconds at a time using exec
            exec("sleep 10")
        }
    }

    release_lock()
    println("=== anima_loop DAEMON stopped ===")
}

// ═══════════════════════════════════════════════════════════
// ─── STATUS ───
// ═══════════════════════════════════════════════════════════

fn show_status() {
    let strat = load_strategy()
    let laws = count_laws()
    let ts = timestamp()

    println("=== anima_loop status [" + ts + "] ===")
    println("")
    println("laws_count: " + to_string(laws))
    println("total_ticks: " + to_string(strat.total_ticks))
    println("total_applied: " + to_string(strat.total_applied))
    println("applied_per_tick (EMA): " + to_string(strat.applied_per_tick))
    println("stagnant_ticks: " + to_string(strat.stagnant_ticks))
    println("blowup_depth: " + to_string(strat.blowup_depth))
    println("topology: " + topologies[strat.topo_index])
    println("delta_history: [" + to_string(strat.d0) + ", " + to_string(strat.d1) + ", " + to_string(strat.d2) + "]")
    println("l2_counter: " + to_string(strat.l2_counter) + " / " + to_string(meta_l2_interval))
    println("l3_counter: " + to_string(strat.l3_counter) + " / " + to_string(meta_l3_interval))
    println("last_harvest: " + to_string(strat.last_harvest_count))
    println("")
    println("--- Claude CLI ---")
    println("claude_counter: " + to_string(strat.claude_counter) + " / " + to_string(claude_call_interval))
    println("claude_discoveries: " + to_string(strat.claude_discoveries))
    println("")
    println("--- H100 Training ---")
    let h_pct = if h100_total_steps > 0 { to_float(strat.h100_step) / to_float(h100_total_steps) * 100.0 } else { 0.0 }
    println("h100_status: " + strat.h100_status)
    println("h100_step: " + to_string(strat.h100_step) + " / " + to_string(h100_total_steps) + " (" + to_string(h_pct) + "%)")
    println("h100_ce: " + to_string(strat.h100_ce))
    println("h100_phi: " + to_string(strat.h100_phi))
    println("h100_eta: " + to_string(strat.h100_eta_h) + "h")
    println("")

    if is_locked() {
        println("daemon: RUNNING (lock exists)")
    } else {
        println("daemon: stopped")
    }
}

