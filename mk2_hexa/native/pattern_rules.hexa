// mk2_hexa/native/pattern_rules.hexa — 패턴→규칙 변환기
// discovery_log.jsonl 반복 패턴 감지 → CLAUDE.md 규칙 후보 생성
// 사용: hexa pattern_rules.hexa scan     — 패턴 분석 실행
//       hexa pattern_rules.hexa rules    — 기존 규칙 출력

comptime const version = "1.0.0"
comptime const max_entries = 500
comptime const freq_threshold = 3

let home = exec("printenv HOME")
let shared_dir = home + "/Dev/nexus6/shared"
let log_path = shared_dir + "/discovery_log.jsonl"
let rules_path = shared_dir + "/pattern_rules.jsonl"

fn timestamp() -> string {
    exec("date +%Y-%m-%dT%H:%M:%S").trim()
}

// ─── JSONL 필드 추출 유틸 ───

fn extract_field(line: string, field: string) -> string {
    let key = "\"" + field + "\":\""
    if !line.contains(key) { return "" }
    let parts = line.split(key)
    if parts.len() < 2 { return "" }
    let val = parts[1].split("\"")[0]
    val
}

// ─── discovery_log.jsonl 최근 max_entries 건 로드 ───

fn load_recent_entries() -> list {
    let raw = ""
    try {
        // tail 로 최근 500건만 읽기
        raw = exec("bash", ["-c", "tail -n " + to_string(max_entries) + " " + log_path])
    } catch e {
        return []
    }
    if raw.trim() == "" { return [] }
    let lines = raw.split("\n")
    let mut entries = []
    for line in lines {
        if line.trim() != "" && line.contains("\"constant\"") {
            entries = entries + [line.trim()]
        }
    }
    entries
}

// ─── 패턴 1: 고빈도 상수 (같은 constant 3+회 등장) ───

fn detect_high_freq_constants(entries: list) -> list {
    // constant → count 맵 (리스트 기반)
    let mut names = []
    let mut counts = []

    for entry in entries {
        let c = extract_field(entry, "constant")
        if c == "" { continue }

        let mut found = false
        let mut i = 0
        while i < names.len() {
            if names[i] == c {
                counts[i] = counts[i] + 1
                found = true
                break
            }
            i = i + 1
        }
        if !found {
            names = names + [c]
            counts = counts + [1]
        }
    }

    // freq_threshold 이상만 추출
    let mut results = []
    let mut i = 0
    while i < names.len() {
        if counts[i] >= freq_threshold {
            let conf = if counts[i] >= 20 { 0.95 } else if counts[i] >= 10 { 0.8 } else { 0.6 }
            let entry = "{\"rule_id\":\"HF-" + names[i] + "\"" + ",\"type\":\"high_freq_constant\"" + ",\"constant\":\"" + names[i] + "\"" + ",\"count\":" + to_string(counts[i]) + ",\"description\":\"constant '" + names[i] + "' appears " + to_string(counts[i]) + " times in recent " + to_string(max_entries) + " entries — candidate for n6_check promotion\"" + ",\"confidence\":" + to_string(conf) + ",\"ts\":\"" + timestamp() + "\"}"
            results = results + [entry]
        }
        i = i + 1
    }
    results
}

// ─── 패턴 2: 소스 집중 (같은 source에서 집중 발견) ───

fn detect_source_concentration(entries: list) -> list {
    let mut sources = []
    let mut src_counts = []

    for entry in entries {
        let s = extract_field(entry, "source")
        if s == "" { continue }

        let mut found = false
        let mut i = 0
        while i < sources.len() {
            if sources[i] == s {
                src_counts[i] = src_counts[i] + 1
                found = true
                break
            }
            i = i + 1
        }
        if !found {
            sources = sources + [s]
            src_counts = src_counts + [1]
        }
    }

    let total = entries.len()
    let mut results = []
    let mut i = 0
    while i < sources.len() {
        if src_counts[i] >= freq_threshold {
            let ratio = to_float(src_counts[i]) / to_float(total)
            let conf = if ratio > 0.5 { 0.9 } else if ratio > 0.2 { 0.7 } else { 0.5 }
            // 집중률 20%+ 이상만 규칙 후보
            if ratio >= 0.1 {
                let pct = to_int(ratio * 100.0)
                let entry = "{\"rule_id\":\"SC-" + sources[i].replace(":", "_") + "\"" + ",\"type\":\"source_concentration\"" + ",\"source\":\"" + sources[i] + "\"" + ",\"count\":" + to_string(src_counts[i]) + ",\"ratio\":" + to_string(ratio) + ",\"description\":\"source '" + sources[i] + "' accounts for " + to_string(pct) + "% of discoveries (" + to_string(src_counts[i]) + "/" + to_string(total) + ") — prioritize or diversify\"" + ",\"confidence\":" + to_string(conf) + ",\"ts\":\"" + timestamp() + "\"}"
                results = results + [entry]
            }
        }
        i = i + 1
    }
    results
}

// ─── scan: 분석 실행 + 결과 출력 + shared/pattern_rules.jsonl 저장 ───

fn cmd_scan() {
    println("[pattern_rules] scanning discovery_log.jsonl (last " + to_string(max_entries) + " entries)...")

    let entries = load_recent_entries()
    if entries.len() == 0 {
        println("[pattern_rules] no entries found in discovery_log.jsonl")
        return
    }
    println("[pattern_rules] loaded " + to_string(entries.len()) + " entries")

    // 패턴 감지
    let hf_rules = detect_high_freq_constants(entries)
    let sc_rules = detect_source_concentration(entries)

    let all_rules = hf_rules + sc_rules

    println("")
    println("=== Pattern Rules Report ===")
    println("  high_freq_constant: " + to_string(hf_rules.len()) + " rules")
    println("  source_concentration: " + to_string(sc_rules.len()) + " rules")
    println("  total: " + to_string(all_rules.len()) + " rules")
    println("")

    // 상세 출력
    for rule in all_rules {
        println("  " + rule)
    }

    // shared/pattern_rules.jsonl 저장 (덮어쓰기)
    if all_rules.len() > 0 {
        let mut output = ""
        for rule in all_rules {
            output = output + rule + "\n"
        }
        write_file(rules_path, output)
        println("")
        println("[pattern_rules] saved " + to_string(all_rules.len()) + " rules -> " + rules_path)
    }
}

// ─── rules: 기존 규칙 출력 ───

fn cmd_rules() {
    let raw = ""
    try {
        raw = read_file(rules_path)
    } catch e {
        println("[pattern_rules] no rules file found. run 'scan' first.")
        return
    }
    if raw.trim() == "" {
        println("[pattern_rules] rules file is empty. run 'scan' first.")
        return
    }

    println("=== Existing Pattern Rules ===")
    println("  file: " + rules_path)
    println("")

    let lines = raw.split("\n")
    let mut count = 0
    for line in lines {
        if line.trim() != "" {
            println("  " + line)
            count = count + 1
        }
    }
    println("")
    println("  total: " + to_string(count) + " rules")
}

// ─── CLI 진입점 ───

let a = args()
let mode = if a.len() >= 3 { a[2] } else { "scan" }

if mode == "scan" {
    cmd_scan()
} else if mode == "rules" {
    cmd_rules()
} else {
    println("[pattern_rules v" + version + "] usage:")
    println("  hexa pattern_rules.hexa scan   — analyze discovery_log, detect patterns, generate rules")
    println("  hexa pattern_rules.hexa rules  — display existing rules from pattern_rules.jsonl")
}
