// mk2_hexa/native/gauge_filter.hexa — Gauge Invariance Filter
// Concept: A law is "gauge invariant" if it holds EXACT across 3+ domains.
//          If only 1 domain → gauge variant (artifact). EXACT in some but MISS
//          in others → gauge anomaly (investigation target).
//
// Usage:
//   hexa gauge_filter.hexa scan              # full gauge analysis
//   hexa gauge_filter.hexa invariant         # list gauge-invariant laws only
//   hexa gauge_filter.hexa anomaly           # list gauge anomalies
//   hexa gauge_filter.hexa report            # full report with statistics

// ═══════════════════════════════════════════════════════════════
// ─── MATH UTILITIES ───
// ═══════════════════════════════════════════════════════════════

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

fn round2(x: f64) -> string {
    let i = to_int(x * 100.0 + 0.5)
    let whole = i / 100
    let frac = i - whole * 100
    let mut fs = to_string(frac)
    if frac < 10 { fs = "0" + fs }
    return to_string(whole) + "." + fs
}

fn round4(x: f64) -> string {
    let i = to_int(x * 10000.0 + 0.5)
    let whole = i / 10000
    let frac = i - whole * 10000
    let mut fs = to_string(frac)
    if frac < 1000 { fs = "0" + fs }
    if frac < 100 { fs = "0" + fs }
    if frac < 10 { fs = "0" + fs }
    return to_string(whole) + "." + fs
}

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {}
    return v
}

// ═══════════════════════════════════════════════════════════════
// ─── n=6 CONSTANTS REGISTRY ───
// ═══════════════════════════════════════════════════════════════

comptime const N6_COUNT = 10

fn n6_const_name(idx: i64) -> string {
    if idx == 0 { return "n" }
    if idx == 1 { return "sigma" }
    if idx == 2 { return "phi" }
    if idx == 3 { return "tau" }
    if idx == 4 { return "sopfr" }
    if idx == 5 { return "J2" }
    if idx == 6 { return "M3" }
    if idx == 7 { return "alpha_inv" }
    if idx == 8 { return "Omega_m" }
    if idx == 9 { return "Omega_L" }
    return ""
}

fn n6_const_val(idx: i64) -> f64 {
    if idx == 0 { return 6.0 }
    if idx == 1 { return 12.0 }
    if idx == 2 { return 2.0 }
    if idx == 3 { return 4.0 }
    if idx == 4 { return 5.0 }
    if idx == 5 { return 24.0 }
    if idx == 6 { return 7.0 }
    if idx == 7 { return 137.036 }
    if idx == 8 { return 0.3153 }
    if idx == 9 { return 0.6847 }
    return 0.0
}

// ═══════════════════════════════════════════════════════════════
// ─── KNOWN DOMAIN SET ───
// ═══════════════════════════════════════════════════════════════

comptime const DOMAIN_COUNT = 10

fn known_domain(idx: i64) -> string {
    if idx == 0 { return "math" }
    if idx == 1 { return "physics" }
    if idx == 2 { return "topology" }
    if idx == 3 { return "cosmology" }
    if idx == 4 { return "semiconductor" }
    if idx == 5 { return "bio" }
    if idx == 6 { return "chemistry" }
    if idx == 7 { return "number_theory" }
    if idx == 8 { return "graph_theory" }
    if idx == 9 { return "quantum" }
    return ""
}

fn domain_index(name: string) -> i64 {
    let mut i: i64 = 0
    while i < DOMAIN_COUNT {
        if known_domain(i) == name { return i }
        i = i + 1
    }
    return -1
}

// Normalize domain aliases to canonical names
fn normalize_domain(raw: string) -> string {
    if raw == "math" || raw == "mathematics" || raw == "pure_math" { return "math" }
    if raw == "physics" || raw == "particle_physics" || raw == "classical" { return "physics" }
    if raw == "topology" || raw == "algebraic_topology" { return "topology" }
    if raw == "cosmology" || raw == "astro" || raw == "astrophysics" { return "cosmology" }
    if raw == "semiconductor" || raw == "materials" || raw == "condensed_matter" { return "semiconductor" }
    if raw == "bio" || raw == "biology" || raw == "biophysics" { return "bio" }
    if raw == "chemistry" || raw == "chem" { return "chemistry" }
    if raw == "number_theory" || raw == "nt" || raw == "integers" { return "number_theory" }
    if raw == "graph_theory" || raw == "graph" || raw == "combinatorics" { return "graph_theory" }
    if raw == "quantum" || raw == "qm" || raw == "quantum_mechanics" { return "quantum" }
    return raw
}

// ═══════════════════════════════════════════════════════════════
// ─── MATCH TOLERANCE ───
// ═══════════════════════════════════════════════════════════════

comptime const EXACT_TOL = 0.001

pure fn is_exact_match(value: f64, constant: f64) -> bool {
    let denom = max_f(abs_f(constant), 1.0)
    let rel_err = abs_f(value - constant) / denom
    return rel_err < EXACT_TOL
}

// ═══════════════════════════════════════════════════════════════
// ─── DATA STRUCTURES ───
// ═══════════════════════════════════════════════════════════════

// Per-constant, per-domain hit tracker
// We use a flat array: gauge_hits[const_idx * DOMAIN_COUNT + domain_idx] = count
// gauge_exact[same index] = count of EXACT hits
// gauge_miss[same index] = count of non-EXACT (MISS) entries

struct GaugeState {
    hits_exact: list,        // flat [N6_COUNT * DOMAIN_COUNT]
    hits_miss: list,         // flat [N6_COUNT * DOMAIN_COUNT]
    total_entries: i64,
    matched_entries: i64,
    domains_seen: list       // unique domains encountered
}

fn new_gauge_state() -> GaugeState {
    let mut exact = []
    let mut miss = []
    let total = N6_COUNT * DOMAIN_COUNT
    let mut i: i64 = 0
    while i < total {
        exact.push(0)
        miss.push(0)
        i = i + 1
    }
    return GaugeState {
        hits_exact: exact,
        hits_miss: miss,
        total_entries: 0,
        matched_entries: 0,
        domains_seen: []
    }
}

fn flat_idx(const_idx: i64, domain_idx: i64) -> i64 {
    return const_idx * DOMAIN_COUNT + domain_idx
}

// ═══════════════════════════════════════════════════════════════
// ─── JSON FIELD EXTRACTION (minimal parser) ───
// ═══════════════════════════════════════════════════════════════

fn extract_json_str(line: string, key: string) -> string {
    let needle = "\"" + key + "\":"
    if !line.contains(needle) { return "" }
    let parts = line.split(needle)
    if len(parts) < 2 { return "" }
    let rest = parts[1].trim()
    // Check if string value (starts with ")
    if len(rest) < 2 { return "" }
    let chars = rest.split("")
    if chars[0] != "\"" {
        // Numeric or bare value — read until , or }
        let mut val = ""
        let mut j: i64 = 0
        while j < len(chars) {
            if chars[j] == "," || chars[j] == "}" { return val.trim() }
            val = val + chars[j]
            j = j + 1
        }
        return val.trim()
    }
    // String value — read between quotes
    let mut result = ""
    let mut j: i64 = 1
    while j < len(chars) {
        if chars[j] == "\"" { return result }
        result = result + chars[j]
        j = j + 1
    }
    return result
}

fn extract_json_num(line: string, key: string) -> f64 {
    let s = extract_json_str(line, key)
    if s == "" { return 0.0 }
    return safe_float(s)
}

// ═══════════════════════════════════════════════════════════════
// ─── GROWTH BUS LOADER ───
// ═══════════════════════════════════════════════════════════════

fn load_growth_bus(state: GaugeState) -> GaugeState {
    let mut st = state
    let bus_path = "shared/discovery/growth_bus.jsonl"

    if !file_exists(bus_path) {
        println("[gauge_filter] WARNING: " + bus_path + " not found")
        return st
    }

    // Read last 1000 lines for broader history
    let raw = exec("tail -1000 " + bus_path)
    let lines = raw.split("\n")
    println("[gauge_filter] Loading " + to_string(len(lines)) + " entries from growth_bus...")

    let mut i: i64 = 0
    while i < len(lines) {
        let line = lines[i].trim()
        if line != "" && line.contains("{") {
            st.total_entries = st.total_entries + 1

            // Extract fields
            let value = extract_json_num(line, "value")
            let grade = extract_json_str(line, "grade")
            let raw_domain = extract_json_str(line, "domain")
            let domain = normalize_domain(raw_domain)

            if domain != "" && value != 0.0 {
                // Track unique domains seen
                let mut domain_found = false
                let mut d: i64 = 0
                while d < len(st.domains_seen) {
                    if st.domains_seen[d] == domain { domain_found = true }
                    d = d + 1
                }
                if !domain_found {
                    st.domains_seen.push(domain)
                }

                let d_idx = domain_index(domain)
                if d_idx >= 0 {
                    // Check against each n6 constant
                    let mut c: i64 = 0
                    while c < N6_COUNT {
                        let cval = n6_const_val(c)
                        let fi = flat_idx(c, d_idx)

                        if is_exact_match(value, cval) {
                            st.hits_exact[fi] = st.hits_exact[fi] + 1
                            st.matched_entries = st.matched_entries + 1
                        } else {
                            // Only count as MISS if grade indicates it was tested/expected
                            if grade == "MISS" || grade == "NEAR" || grade == "WEAK" {
                                st.hits_miss[fi] = st.hits_miss[fi] + 1
                            }
                        }
                        c = c + 1
                    }
                }
            }
        }

        i = i + 1
    }

    return st
}

// ═══════════════════════════════════════════════════════════════
// ─── GAUGE CLASSIFICATION ───
// ═══════════════════════════════════════════════════════════════

struct GaugeResult {
    gtype: string,          // "gauge_invariant", "gauge_variant", "gauge_anomaly"
    constant: string,
    value: f64,
    exact_domains: list,
    miss_domains: list,
    domain_count: i64,
    confidence: f64,
    investigation: string
}

fn classify_constant(state: GaugeState, const_idx: i64) -> GaugeResult {
    let cname = n6_const_name(const_idx)
    let cval = n6_const_val(const_idx)

    let mut exact_doms = []
    let mut miss_doms = []

    let mut d: i64 = 0
    while d < DOMAIN_COUNT {
        let fi = flat_idx(const_idx, d)
        let dname = known_domain(d)

        if state.hits_exact[fi] > 0 {
            exact_doms.push(dname)
        } else if state.hits_miss[fi] > 0 {
            miss_doms.push(dname)
        }
        d = d + 1
    }

    let n_exact = len(exact_doms)
    let n_miss = len(miss_doms)
    let total_scanned = max_f(to_float(len(state.domains_seen)), 1.0)
    let conf = to_float(n_exact) / total_scanned

    // Classification logic
    if n_exact >= 3 {
        // Gauge invariant: EXACT in 3+ domains
        return GaugeResult {
            gtype: "gauge_invariant",
            constant: cname,
            value: cval,
            exact_domains: exact_doms,
            miss_domains: [],
            domain_count: to_int(n_exact),
            confidence: conf,
            investigation: ""
        }
    }

    if n_exact >= 1 && n_miss >= 1 {
        // Gauge anomaly: EXACT in some, MISS in others
        let inv_msg = cname + " EXACT in " + to_string(n_exact) + " domain(s) but MISS in " + to_string(n_miss) + " — investigate cross-domain validity"
        return GaugeResult {
            gtype: "gauge_anomaly",
            constant: cname,
            value: cval,
            exact_domains: exact_doms,
            miss_domains: miss_doms,
            domain_count: to_int(n_exact),
            confidence: conf,
            investigation: inv_msg
        }
    }

    if n_exact == 1 {
        // Gauge variant: EXACT in only 1 domain
        return GaugeResult {
            gtype: "gauge_variant",
            constant: cname,
            value: cval,
            exact_domains: exact_doms,
            miss_domains: [],
            domain_count: 1,
            confidence: conf,
            investigation: ""
        }
    }

    // No EXACT matches at all — unclassified / no data
    return GaugeResult {
        gtype: "gauge_variant",
        constant: cname,
        value: cval,
        exact_domains: [],
        miss_domains: [],
        domain_count: 0,
        confidence: 0.0,
        investigation: "no EXACT matches found in any domain"
    }
}

fn classify_all(state: GaugeState) -> [GaugeResult] {
    let mut results = []
    let mut c: i64 = 0
    while c < N6_COUNT {
        let r = classify_constant(state, c)
        results.push(r)
        c = c + 1
    }
    return results
}

// ═══════════════════════════════════════════════════════════════
// ─── JSONL SERIALIZER ───
// ═══════════════════════════════════════════════════════════════

fn domains_to_json_arr(doms: list) -> string {
    let mut s = "["
    let mut i: i64 = 0
    while i < len(doms) {
        if i > 0 { s = s + "," }
        s = s + "\"" + doms[i] + "\""
        i = i + 1
    }
    s = s + "]"
    return s
}

fn result_to_jsonl(r: GaugeResult) -> string {
    let mut line = "{\"type\":\"" + r.gtype + "\""
    line = line + ",\"constant\":\"" + r.constant + "\""
    line = line + ",\"value\":" + round4(r.value)

    if r.gtype == "gauge_anomaly" {
        line = line + ",\"exact_domains\":" + domains_to_json_arr(r.exact_domains)
        line = line + ",\"miss_domains\":" + domains_to_json_arr(r.miss_domains)
        line = line + ",\"investigation\":\"" + r.investigation + "\""
    } else {
        line = line + ",\"domains\":" + domains_to_json_arr(r.exact_domains)
    }

    line = line + ",\"domain_count\":" + to_string(r.domain_count)
    line = line + ",\"confidence\":" + round4(r.confidence)
    line = line + "}"
    return line
}

// ═══════════════════════════════════════════════════════════════
// ─── OUTPUT WRITER ───
// ═══════════════════════════════════════════════════════════════

fn write_results(results: list) -> i64 {
    let out_path = "shared/gauge_invariants.jsonl"
    let mut content = ""
    let mut count: i64 = 0

    let mut i: i64 = 0
    while i < len(results) {
        let r = results[i]
        // Skip entries with zero domain count (no data)
        if r.domain_count > 0 || r.investigation != "" {
            if count > 0 { content = content + "\n" }
            content = content + result_to_jsonl(r)
            count = count + 1
        }
        i = i + 1
    }

    write_file(out_path, content)
    println("[gauge_filter] Wrote " + to_string(count) + " entries to " + out_path)
    return count
}

// ═══════════════════════════════════════════════════════════════
// ─── DISPLAY FUNCTIONS ───
// ═══════════════════════════════════════════════════════════════

fn display_invariants(results: list) {
    println("")
    println("══════════════════════════════════════════════════")
    println("  GAUGE-INVARIANT LAWS (EXACT in 3+ domains)")
    println("══════════════════════════════════════════════════")

    let mut found: i64 = 0
    let mut i: i64 = 0
    while i < len(results) {
        let r = results[i]
        if r.gtype == "gauge_invariant" {
            found = found + 1
            println("  [" + to_string(found) + "] " + r.constant + " = " + round4(r.value))
            println("      domains (" + to_string(r.domain_count) + "): " + domains_to_json_arr(r.exact_domains))
            println("      confidence: " + round4(r.confidence))
            println("")
        }
        i = i + 1
    }

    if found == 0 {
        println("  (none found — need more cross-domain data)")
    }
    println("  Total gauge-invariant: " + to_string(found))
    println("══════════════════════════════════════════════════")
}

fn display_variants(results: list) {
    println("")
    println("══════════════════════════════════════════════════")
    println("  GAUGE-VARIANT (EXACT in 1 domain only)")
    println("══════════════════════════════════════════════════")

    let mut found: i64 = 0
    let mut i: i64 = 0
    while i < len(results) {
        let r = results[i]
        if r.gtype == "gauge_variant" && r.domain_count > 0 {
            found = found + 1
            println("  [" + to_string(found) + "] " + r.constant + " = " + round4(r.value))
            println("      domain: " + domains_to_json_arr(r.exact_domains))
            println("      confidence: " + round4(r.confidence) + " — needs verification")
            println("")
        }
        i = i + 1
    }

    if found == 0 {
        println("  (none found)")
    }
    println("  Total gauge-variant: " + to_string(found))
    println("══════════════════════════════════════════════════")
}

fn display_anomalies(results: list) {
    println("")
    println("══════════════════════════════════════════════════")
    println("  GAUGE ANOMALIES (EXACT + MISS across domains)")
    println("══════════════════════════════════════════════════")

    let mut found: i64 = 0
    let mut i: i64 = 0
    while i < len(results) {
        let r = results[i]
        if r.gtype == "gauge_anomaly" {
            found = found + 1
            println("  [" + to_string(found) + "] " + r.constant + " = " + round4(r.value))
            println("      EXACT in: " + domains_to_json_arr(r.exact_domains))
            println("      MISS  in: " + domains_to_json_arr(r.miss_domains))
            println("      >> " + r.investigation)
            println("")
        }
        i = i + 1
    }

    if found == 0 {
        println("  (none found — no cross-domain contradictions detected)")
    }
    println("  Total anomalies: " + to_string(found))
    println("══════════════════════════════════════════════════")
}

fn display_report(state: GaugeState, results: list) {
    println("")
    println("╔══════════════════════════════════════════════════╗")
    println("║      GAUGE INVARIANCE FILTER — FULL REPORT      ║")
    println("╠══════════════════════════════════════════════════╣")
    println("║  Total entries scanned: " + to_string(state.total_entries))
    println("║  Matched entries:       " + to_string(state.matched_entries))
    println("║  Domains seen:          " + to_string(len(state.domains_seen)))
    println("║  Constants checked:     " + to_string(N6_COUNT))
    println("╚══════════════════════════════════════════════════╝")

    // Count by type
    let mut n_inv: i64 = 0
    let mut n_var: i64 = 0
    let mut n_anom: i64 = 0
    let mut i: i64 = 0
    while i < len(results) {
        let r = results[i]
        if r.gtype == "gauge_invariant" { n_inv = n_inv + 1 }
        if r.gtype == "gauge_variant" { n_var = n_var + 1 }
        if r.gtype == "gauge_anomaly" { n_anom = n_anom + 1 }
        i = i + 1
    }

    println("")
    println("  Summary:")
    println("    Gauge-invariant (universal): " + to_string(n_inv))
    println("    Gauge-variant (1 domain):    " + to_string(n_var))
    println("    Gauge-anomaly (investigate): " + to_string(n_anom))

    display_invariants(results)
    display_anomalies(results)
    display_variants(results)

    // Domain coverage matrix
    println("")
    println("══════════════════════════════════════════════════")
    println("  DOMAIN × CONSTANT COVERAGE MATRIX")
    println("══════════════════════════════════════════════════")

    // Header
    let mut header = "            "
    let mut c: i64 = 0
    while c < N6_COUNT {
        let name = n6_const_name(c)
        // Pad to 10 chars
        let mut padded = name
        while len(padded) < 10 { padded = padded + " " }
        header = header + padded
        c = c + 1
    }
    println(header)

    // Rows
    let mut d: i64 = 0
    while d < DOMAIN_COUNT {
        let dname = known_domain(d)
        let mut row = dname
        while len(row) < 12 { row = row + " " }

        c = 0
        while c < N6_COUNT {
            let fi = flat_idx(c, d)
            let ex = state.hits_exact[fi]
            let mi = state.hits_miss[fi]

            let mut cell = ""
            if ex > 0 && mi > 0 {
                cell = "E" + to_string(ex) + "/M" + to_string(mi)
            } else if ex > 0 {
                cell = "E" + to_string(ex)
            } else if mi > 0 {
                cell = "M" + to_string(mi)
            } else {
                cell = "."
            }
            while len(cell) < 10 { cell = cell + " " }
            row = row + cell
            c = c + 1
        }
        println(row)
        d = d + 1
    }
    println("══════════════════════════════════════════════════")
    println("  E=EXACT hits, M=MISS hits, .=no data")
}

// ═══════════════════════════════════════════════════════════════
// ─── THEOREMS & PROOFS ───
// ═══════════════════════════════════════════════════════════════

theorem gauge_invariance_transitivity {
    // If constant C is EXACT in domains A, B, C then it is a candidate
    // universal law. The gauge invariance property is transitive:
    // if C holds in A∩B and B∩C, it should hold in A∩C.
    // forall c: string, d1..d3: string, exact(c,d1)&&exact(c,d2)&&exact(c,d3) => universal(c)
    forall c: string, exact_domain_count(c) >= 3 => universal(c)
}

proof gauge_transitivity {
    // A constant matching EXACT across 3+ independent domains
    // cannot be a domain-specific artifact. The probability of
    // coincidental match at tolerance < 0.1% across 3 independent
    // measurement systems is < 10^{-9}.
    //
    // Step 1: Each domain uses independent measurement methodology
    // Step 2: EXACT match = relative error < 0.001
    // Step 3: P(coincidence per domain pair) < 0.001
    // Step 4: P(coincidence across 3) < 0.001^3 = 10^{-9}
    // Therefore: gauge_invariant => universal with p < 10^{-9}
    invariant gauge_invariance_implies_universality()
}

theorem gauge_anomaly_detection {
    // If a constant is EXACT in domain A but MISS in domain B,
    // one of three things is true:
    // (1) The constant is domain-specific (gauge variant)
    // (2) Domain B measurement is flawed
    // (3) There is a deeper relationship we don't yet understand
    // forall c: string, d1: string, d2: string, exact(c,d1)&&miss(c,d2) => anomaly(c,d1,d2)
    forall c: string, has_exact_and_miss(c) => anomaly(c)
}

proof anomaly_completeness {
    // The anomaly detector is complete: any constant that is EXACT
    // in at least one domain and MISS in at least one other domain
    // will be classified as a gauge anomaly.
    invariant all_cross_domain_mismatches_detected()
}

// ═══════════════════════════════════════════════════════════════
// ─── ASSERTIONS ───
// ═══════════════════════════════════════════════════════════════

// Match tolerance verification
assert is_exact_match(12.0, 12.0) == true
assert is_exact_match(12.01, 12.0) == true
assert is_exact_match(12.1, 12.0) == false
assert is_exact_match(137.036, 137.036) == true
assert is_exact_match(137.2, 137.036) == false
assert is_exact_match(0.3153, 0.3153) == true

// Domain normalization
assert normalize_domain("math") == "math"
assert normalize_domain("mathematics") == "math"
assert normalize_domain("qm") == "quantum"
assert normalize_domain("astrophysics") == "cosmology"

// Flat index
assert flat_idx(0, 0) == 0
assert flat_idx(1, 0) == DOMAIN_COUNT
assert flat_idx(0, 1) == 1

println("=== gauge_filter assertions passed ===")

// ═══════════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════════

fn main() {
    let argv = args()
    let mut cmd = "scan"
    if len(argv) > 1 { cmd = argv[1] }

    println("[gauge_filter] Command: " + cmd)

    // Load and analyze
    let mut state = new_gauge_state()
    state = load_growth_bus(state)

    let results = classify_all(state)

    if cmd == "scan" {
        // Full scan: classify + write + summary
        let written = write_results(results)
        display_invariants(results)
        display_anomalies(results)
        display_variants(results)
        println("")
        println("[gauge_filter] Scan complete. " + to_string(written) + " results written.")
    } else if cmd == "invariant" {
        display_invariants(results)
    } else if cmd == "anomaly" {
        display_anomalies(results)
    } else if cmd == "report" {
        let written = write_results(results)
        display_report(state, results)
        println("")
        println("[gauge_filter] Report complete. " + to_string(written) + " results written.")
    } else {
        println("[gauge_filter] Unknown command: " + cmd)
        println("Usage: hexa gauge_filter.hexa [scan|invariant|anomaly|report]")
    }
}

main()
