// hexa_quantum_types.hexa — HEXA-LANG v2 양자 타입 시스템 시뮬레이터
// 사용: hexa hexa_quantum_types.hexa check <file>
//       hexa hexa_quantum_types.hexa simulate
//       hexa hexa_quantum_types.hexa help
//
// 원리:
//   1. Quantum<T> — 값이 측정 전까지 중첩 상태로 존재
//   2. 측정 연산자 — 중첩을 단일 값으로 붕괴
//   3. 얽힘 바인딩 — 두 양자값 연결 (하나 측정 → 다른 하나 결정)
//   4. n=6 양자 타입 시스템: 6 기본 타입 × 중첩 = 타입 격자
//   5. 양자 타입 검사기 — 중첩 상태 간 타입 안전성 검증

// ═══════════════════════════════════════════════════════════
// 설정 & n=6 상수
// ═══════════════════════════════════════════════════════════

let _home = exec("printenv HOME").trim()
let _nexus = _home + "/Dev/nexus"
let _bus_path = _nexus + "/shared/discovery/growth_bus.jsonl"

comptime const N6 = 6
comptime const N6_DOUBLE = 12
comptime const N6_PERFECT = 28
comptime const N6_FACTORIAL = 720
comptime const COLLAPSE_THRESHOLD = 0.15

comptime const QT_INT = 0
comptime const QT_FLOAT = 1
comptime const QT_BOOL = 2
comptime const QT_STRING = 3
comptime const QT_ARRAY = 4
comptime const QT_MAP = 5
comptime const QT_NAMES = ["Q<int>", "Q<float>", "Q<bool>", "Q<string>", "Q<array>", "Q<map>"]

// ═══════════════════════════════════════════════════════════
// 유틸리티
// ═══════════════════════════════════════════════════════════

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn sqrt_approx(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut guess = x / 2.0
    let mut i = 0
    while i < N6 { guess = (guess + x / guess) / 2.0; i = i + 1 }
    return guess
}

fn min_f(a: f64, b: f64) -> f64 { if a <= b { return a } return b }

fn timestamp_now() -> string {
    let mut t = ""
    try { t = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim() } catch e { t = "unknown" }
    return t
}

fn random_unit() -> f64 {
    let mut r = 0.0
    try { r = to_float(exec("/usr/bin/python3 -c \"import random; print(random.random())\"").trim()) } catch e {
        let c = clock()
        r = c - to_float(to_int(c))
    }
    return r
}

fn type_name(idx: i64) -> string {
    if idx >= 0 { if idx < N6 { return to_string(QT_NAMES[idx]) } }
    return "Q<unknown>"
}

// ═══════════════════════════════════════════════════════════
// 1. Quantum<T> 중첩 상태 시뮬레이션
// ═══════════════════════════════════════════════════════════
// |ψ⟩ = Σ αᵢ|Tᵢ⟩, Σ|αᵢ|² = 1

fn new_quantum_state(primary: i64) -> list {
    let mut amps = []
    let noise = sqrt_approx((1.0 - 0.85 * 0.85) / 5.0)
    let mut i = 0
    while i < N6 {
        if i == primary { amps = amps + [0.85] } else { amps = amps + [noise] }
        i = i + 1
    }
    return amps
}

fn new_uniform_quantum() -> list {
    let amp = 1.0 / sqrt_approx(to_float(N6))
    let mut amps = []
    let mut i = 0
    while i < N6 { amps = amps + [amp]; i = i + 1 }
    return amps
}

fn normalize_amps(amps: list) -> list {
    let mut sum_sq = 0.0
    let mut i = 0
    while i < amps.len() { let a = to_float(to_string(amps[i])); sum_sq = sum_sq + a * a; i = i + 1 }
    if sum_sq < 0.0001 { return new_uniform_quantum() }
    let norm = sqrt_approx(sum_sq)
    let mut result = []
    i = 0
    while i < amps.len() { result = result + [to_float(to_string(amps[i])) / norm]; i = i + 1 }
    return result
}

fn prob_at(amps: list, idx: i64) -> f64 {
    if idx < 0 { return 0.0 }
    if idx >= amps.len() { return 0.0 }
    let a = to_float(to_string(amps[idx]))
    return a * a
}

fn dominant_type(amps: list) -> i64 {
    let mut best = 0
    let mut bp = 0.0
    let mut i = 0
    while i < amps.len() { let p = prob_at(amps, i); if p > bp { bp = p; best = i }; i = i + 1 }
    return best
}

fn is_collapsed(amps: list) -> bool {
    let mut mx = 0.0
    let mut i = 0
    while i < amps.len() { let p = prob_at(amps, i); if p > mx { mx = p }; i = i + 1 }
    return mx > 0.99
}

fn superposition_entropy(amps: list) -> f64 {
    let mut h = 0.0
    let mut i = 0
    while i < amps.len() {
        let p = prob_at(amps, i)
        if p > 0.001 { h = h - p * (0.0 - (1.0 - p) / p) }
        i = i + 1
    }
    return h
}

// ═══════════════════════════════════════════════════════════
// 2. 측정 연산자 — 중첩 붕괴
// ═══════════════════════════════════════════════════════════

fn measure(amps: list) -> list {
    let r = random_unit()
    let mut cum = 0.0
    let mut col = 0
    let mut i = 0
    while i < amps.len() {
        cum = cum + prob_at(amps, i)
        if r <= cum { col = i; i = amps.len() } else { i = i + 1 }
    }
    let mut result = []
    let mut j = 0
    while j < N6 { if j == col { result = result + [1.0] } else { result = result + [0.0] }; j = j + 1 }
    return result
}

fn measure_det(amps: list) -> list {
    let idx = dominant_type(amps)
    let mut result = []
    let mut j = 0
    while j < N6 { if j == idx { result = result + [1.0] } else { result = result + [0.0] }; j = j + 1 }
    return result
}

// ═══════════════════════════════════════════════════════════
// 3. 얽힘 바인딩
// ═══════════════════════════════════════════════════════════

let mut _entangled_pairs = []
let mut _entangle_count = 0

fn create_entanglement(sa: list, sb: list, ctype: string) -> list {
    let mut corr = []
    let mut i = 0
    while i < N6 {
        let mut row = []
        let mut j = 0
        while j < N6 {
            let mut val = 0.0
            if ctype == "same" { if i == j { val = 1.0 } }
            if ctype == "complement" { if i + j == N6 - 1 { val = 1.0 } }
            if ctype == "shift" {
                let mut s = i + 1
                if s >= N6 { s = 0 }
                if j == s { val = 1.0 }
            }
            row = row + [val]
            j = j + 1
        }
        corr = corr + [row]
        i = i + 1
    }
    let pair = [sa, sb, corr]
    if _entangle_count < N6_DOUBLE { _entangled_pairs = _entangled_pairs + [pair]; _entangle_count = _entangle_count + 1 }
    return pair
}

fn propagate_entanglement(pair: list, m_idx: i64) -> list {
    let row = pair[2][m_idx]
    let mut nb = []
    let mut j = 0
    while j < N6 { nb = nb + [to_float(to_string(row[j]))]; j = j + 1 }
    return normalize_amps(nb)
}

fn measure_entangled(pair: list) -> list {
    let ma = measure(pair[0])
    let a_idx = dominant_type(ma)
    let nb = propagate_entanglement(pair, a_idx)
    return [ma, measure_det(nb)]
}

// ═══════════════════════════════════════════════════════════
// 4. n=6 타입 격자 (Type Lattice) — 28노드
// ═══════════════════════════════════════════════════════════

let mut _lattice = []
let mut _lattice_n = 0

fn build_type_lattice() -> i64 {
    _lattice = []
    _lattice_n = 0
    // L0: 순수 타입 6개
    let mut i = 0
    while i < N6 { _lattice = _lattice + [#{"primary": i, "level": 0, "types": [i]}]; _lattice_n = _lattice_n + 1; i = i + 1 }
    // L1: 2-타입 중첩 (6C2 = 15)
    i = 0
    while i < N6 {
        let mut j = i + 1
        while j < N6 {
            if _lattice_n < N6_PERFECT { _lattice = _lattice + [#{"primary": i, "level": 1, "types": [i, j]}]; _lattice_n = _lattice_n + 1 }
            j = j + 1
        }
        i = i + 1
    }
    // L2: 3-타입 중첩 (격자 한도까지)
    i = 0
    while i < N6 {
        let mut j = i + 1
        while j < N6 {
            let mut k = j + 1
            while k < N6 {
                if _lattice_n < N6_PERFECT { _lattice = _lattice + [#{"primary": i, "level": 2, "types": [i, j, k]}]; _lattice_n = _lattice_n + 1 }
                k = k + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    // 최상위: 전체 중첩
    if _lattice_n < N6_PERFECT { _lattice = _lattice + [#{"primary": 0, "level": 5, "types": [0,1,2,3,4,5]}]; _lattice_n = _lattice_n + 1 }
    return _lattice_n
}

fn lattice_node_name(node: map) -> string {
    let types = node["types"]
    if types.len() == 1 { return type_name(to_int(to_string(types[0]))) }
    let mut name = "Q<"
    let labels = ["int","float","bool","string","array","map"]
    let mut i = 0
    while i < types.len() {
        if i > 0 { name = name + "|" }
        let idx = to_int(to_string(types[i]))
        if idx >= 0 { if idx < N6 { name = name + to_string(labels[idx]) } }
        i = i + 1
    }
    return name + ">"
}

// ═══════════════════════════════════════════════════════════
// 5. 양자 타입 검사기
// ═══════════════════════════════════════════════════════════

fn check_type_compat(a: list, b: list) -> list {
    let mut overlap = 0.0
    let mut i = 0
    while i < N6 { overlap = overlap + min_f(prob_at(a, i), prob_at(b, i)); i = i + 1 }
    if overlap > 0.5 { return ["true", to_string(overlap), "호환 " + to_string(to_int(overlap * 100.0)) + "%"] }
    if overlap > COLLAPSE_THRESHOLD { return ["true", to_string(overlap), "약호환 " + to_string(to_int(overlap * 100.0)) + "%"] }
    return ["false", to_string(overlap), "비호환 " + to_string(to_int(overlap * 100.0)) + "%"]
}

fn check_access(amps: list, op: string) -> list {
    if is_collapsed(amps) { return ["true", "확정 — " + op + " 허용"] }
    if op == "field_access" { return ["false", "오류: 중첩에서 필드 접근 불가 — measure() 필요"] }
    if op == "index_access" {
        let p = prob_at(amps, QT_ARRAY) + prob_at(amps, QT_MAP)
        if p < 0.5 { return ["false", "오류: 배열/맵 확률 " + to_string(to_int(p * 100.0)) + "% 불충분"] }
    }
    if op == "arithmetic" {
        let p = prob_at(amps, QT_INT) + prob_at(amps, QT_FLOAT)
        if p < 0.5 { return ["false", "오류: 수치 타입 확률 " + to_string(to_int(p * 100.0)) + "% 불충분"] }
    }
    return ["true", "중첩 — " + op + " 조건부 허용"]
}

// ═══════════════════════════════════════════════════════════
// 6. 파일 기반 양자 타입 검사 (check <file>)
// ═══════════════════════════════════════════════════════════

fn scan_file(filepath: string) -> list {
    let mut results = []
    let mut raw = ""
    try { raw = read_file(filepath) } catch e { return ["오류: 파일 읽기 실패 — " + filepath] }
    let lines = raw.split("\n")
    let mut ln = 0
    let mut qvars = #{}
    let mut errs = 0
    let mut warns = 0
    for line in lines {
        ln = ln + 1
        let t = line.trim()
        if t == "" { ln = ln }
        if t.starts_with("//") { ln = ln }
        if t.contains("let ") {
            if t.contains("new_quantum_state") {
                let vn = t.split("=")[0].replace("let mut ","").replace("let ","").trim()
                qvars[vn] = "quantum"
                results = results + ["L" + to_string(ln) + ": " + vn + " → 양자 상태 생성"]
            }
            if t.contains("new_uniform_quantum") {
                let vn = t.split("=")[0].replace("let mut ","").replace("let ","").trim()
                qvars[vn] = "uniform"
                results = results + ["L" + to_string(ln) + ": " + vn + " → 균등 중첩"]
            }
        }
        if t.contains("measure(") { results = results + ["L" + to_string(ln) + ": 측정 (붕괴)"] }
        if t.contains("create_entanglement") { results = results + ["L" + to_string(ln) + ": 얽힘 생성"] }
        // 위험: 양자 변수에 인덱스 접근
        let k = keys(qvars)
        let mut ki = 0
        while ki < k.len() {
            if t.contains(to_string(k[ki]) + "[") { warns = warns + 1; results = results + ["L" + to_string(ln) + ": ⚠ " + to_string(k[ki]) + " 인덱스 접근 — 중첩 확인 필요"] }
            ki = ki + 1
        }
    }
    results = results + ["── " + to_string(lines.len()) + "줄, " + to_string(errs) + " 오류, " + to_string(warns) + " 경고"]
    return results
}

// ═══════════════════════════════════════════════════════════
// 7. 양자 타입 진화 시뮬레이션
// ═══════════════════════════════════════════════════════════

fn simulate() -> list {
    let mut log = []
    let steps = 120  // N6_FACTORIAL / 6
    // 6개 양자 변수 (각 기본 타입)
    let mut states = []
    let mut i = 0
    while i < N6 { states = states + [new_quantum_state(i)]; i = i + 1 }
    // 얽힘 3쌍
    let p05 = create_entanglement(states[0], states[5], "complement")
    let p14 = create_entanglement(states[1], states[4], "same")
    let p23 = create_entanglement(states[2], states[3], "shift")
    log = log + ["═══ 양자 타입 진화 시뮬레이션 ═══"]
    log = log + ["변수: " + to_string(N6) + ", 얽힘: 3쌍, 격자: " + to_string(build_type_lattice()) + "노드"]
    log = log + [""]
    let mut step = 0
    let mut total_meas = 0
    let mut total_trans = 0
    let mut transitions = []
    while step < steps {
        let r = random_unit()
        let ia = to_int(r * to_float(N6)) % N6
        let mut ib = (ia + 1 + to_int(r * 100.0) % (N6 - 1)) % N6
        if ib == ia { ib = (ia + 1) % N6 }
        // 약한 타입 상호작용
        let mut na = []
        let mut nb = []
        let mut j = 0
        while j < N6 {
            let aa = to_float(to_string(states[ia][j]))
            let bb = to_float(to_string(states[ib][j]))
            na = na + [aa * 0.95 + bb * 0.05]
            nb = nb + [bb * 0.95 + aa * 0.05]
            j = j + 1
        }
        states[ia] = normalize_amps(na)
        states[ib] = normalize_amps(nb)
        // 6단계마다 측정 기회
        if step % N6 == 0 {
            if step > 0 {
                let mr = random_unit()
                if mr > 0.6 {
                    let mi = to_int(mr * to_float(N6)) % N6
                    let old_t = dominant_type(states[mi])
                    states[mi] = measure(states[mi])
                    let new_t = dominant_type(states[mi])
                    total_meas = total_meas + 1
                    if old_t != new_t { total_trans = total_trans + 1; transitions = transitions + [type_name(old_t) + "→" + type_name(new_t)] }
                    states[mi] = new_quantum_state(new_t)
                }
            }
        }
        // 36단계(6×6)마다 스냅샷
        if step % (N6 * N6) == 0 {
            log = log + ["── Step " + to_string(step) + "/" + to_string(steps) + " ──"]
            let mut si = 0
            while si < N6 {
                let d = dominant_type(states[si])
                log = log + ["  V" + to_string(si) + ": " + type_name(d) + " (p=" + to_string(to_int(prob_at(states[si], d) * 100.0)) + "%)"]
                si = si + 1
            }
        }
        step = step + 1
    }
    // 최종 상태
    log = log + [""]
    log = log + ["═══ 최종 상태 ═══"]
    let mut si = 0
    while si < N6 {
        let d = dominant_type(states[si])
        let mut st = "중첩"
        if is_collapsed(states[si]) { st = "붕괴" }
        log = log + ["  V" + to_string(si) + ": " + type_name(d) + " [" + st + "] p=" + to_string(to_int(prob_at(states[si], d) * 100.0)) + "%"]
        si = si + 1
    }
    // 호환성 매트릭스
    log = log + [""]
    log = log + ["═══ 타입 호환성 (6x6) ═══"]
    let mut mi = 0
    while mi < N6 {
        let mut row = "  " + type_name(mi) + ": "
        let mut mj = 0
        while mj < N6 {
            let c = check_type_compat(states[mi], states[mj])
            if to_string(c[0]) == "true" { row = row + "O " } else { row = row + "X " }
            mj = mj + 1
        }
        log = log + [row]
        mi = mi + 1
    }
    // 얽힘 테스트
    log = log + [""]
    log = log + ["═══ 얽힘 측정 테스트 ═══"]
    let e05 = measure_entangled(p05)
    log = log + ["  complement: " + type_name(dominant_type(e05[0])) + " ↔ " + type_name(dominant_type(e05[1]))]
    let e14 = measure_entangled(p14)
    log = log + ["  same:       " + type_name(dominant_type(e14[0])) + " ↔ " + type_name(dominant_type(e14[1]))]
    let e23 = measure_entangled(p23)
    log = log + ["  shift:      " + type_name(dominant_type(e23[0])) + " ↔ " + type_name(dominant_type(e23[1]))]
    // 통계
    log = log + [""]
    log = log + ["═══ 통계 ═══"]
    log = log + ["  단계: " + to_string(steps) + ", 측정: " + to_string(total_meas) + ", 전이: " + to_string(total_trans) + ", 얽힘: " + to_string(_entangle_count) + "쌍"]
    if transitions.len() > 0 {
        log = log + ["  전이 이력:"]
        let mut ti = 0
        while ti < transitions.len() { log = log + ["    " + to_string(transitions[ti])]; ti = ti + 1 }
    }
    return log
}

// ═══════════════════════════════════════════════════════════
// 8. growth_bus.jsonl 출력
// ═══════════════════════════════════════════════════════════

fn emit_bus(etype: string, detail: string, score: f64) -> bool {
    let ts = timestamp_now()
    let entry = "{\"ts\":\"" + ts + "\",\"src\":\"hexa_quantum_types\",\"type\":\"" + etype + "\",\"detail\":\"" + detail + "\",\"score\":" + to_string(score) + ",\"n6\":6}"
    try { append_file(_bus_path, entry + "\n"); return true } catch e { return false }
}

// ═══════════════════════════════════════════════════════════
// CLI
// ═══════════════════════════════════════════════════════════

fn print_help() {
    println("╔══════════════════════════════════════════════════════════╗")
    println("║  hexa_quantum_types.hexa — 양자 타입 시스템 시뮬레이터  ║")
    println("╠══════════════════════════════════════════════════════════╣")
    println("║  check <file>  — .hexa 파일의 양자 타입 일관성 검사     ║")
    println("║  simulate      — 양자 타입 진화 시뮬레이션              ║")
    println("║  help          — 이 도움말                              ║")
    println("╠══════════════════════════════════════════════════════════╣")
    println("║  6 기본 타입: int, float, bool, string, array, map      ║")
    println("║  중첩: Quantum<T>, 얽힘: same/complement/shift          ║")
    println("║  격자: 28노드, 상수: 6, 12, 28, 720                     ║")
    println("╚══════════════════════════════════════════════════════════╝")
}

fn main() {
    let argv = args()
    if argv.len() < 3 { print_help(); return }
    let cmd = to_string(argv[2])
    if cmd == "help" { print_help(); return }
    if cmd == "check" {
        if argv.len() < 3 { println("오류: check <file> 필요"); return }
        let fp = to_string(argv[2])
        println("═══ 양자 타입 검사: " + fp + " ═══")
        let lc = build_type_lattice()
        println("격자: " + to_string(lc) + "노드")
        println("")
        let results = scan_file(fp)
        let mut errs = 0
        let mut warns = 0
        let mut ri = 0
        while ri < results.len() {
            let r = to_string(results[ri])
            println(r)
            if r.contains("오류:") { errs = errs + 1 }
            if r.contains("⚠") { warns = warns + 1 }
            ri = ri + 1
        }
        let score = 1.0 - to_float(errs) * 0.1 - to_float(warns) * 0.02
        emit_bus("type_check", "check:" + fp + ":E" + to_string(errs) + "/W" + to_string(warns), score)
        println("\ngrowth_bus 기록 완료")
        return
    }
    if cmd == "simulate" {
        let log = simulate()
        let mut li = 0
        while li < log.len() { println(to_string(log[li])); li = li + 1 }
        emit_bus("simulation", "quantum_type_evolution:steps=120", 1.0)
        println("\ngrowth_bus 기록 완료")
        return
    }
    println("알 수 없는 명령: " + cmd + " — help 참조")
}

main()
