    if st.laws_delta_history.len() >= 3 {
        println("laws_delta_history: [" + to_string(st.laws_delta_history[0]) + ", " + to_string(st.laws_delta_history[1]) + ", " + to_string(st.laws_delta_history[2]) + "]")
    }

    let strat = load_strategy()
