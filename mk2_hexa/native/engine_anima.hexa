}

if mode == "tick" {
    println("=== engine_anima TICK (Dreamer v3) ===")
    println("  Pure hexa consciousness engine. No external deps.")
    println("")

    // auto_fix: tick 시작 시 자동 문제 감지+해결
    let fix_result = auto_fix()
    if fix_result.total_fixes > 0 {
        println("")
        println("  auto_fix resolved " + to_string(fix_result.total_fixes) + " issue(s) before tick")
        println("")
    }

    let pre_st = read_state()
    let pre_laws = pre_st.laws_count
    let strat = load_strategy()

    let task = select_task(pre_st, strat)
    println("selected: " + task)
    if pre_st.stagnation_flag {
        println("  [!] STAGNATION detected: laws_delta < " + to_string(low_delta_threshold) + " for 3+ ticks")
    }
    if pre_st.sprint_mode {
        println("  [!] SPRINT mode: laws=" + to_string(pre_st.laws_count) + " >= " + to_string(sprint_threshold))
    }
    if pre_st.escalate_mode {
        println("  [!] ESCALATE mode: cross-injecting nexus6 blowup seeds")
    }

    let result = execute_task(task, pre_st, strat)

    // re-read state after execution
    let post_st = read_state()
    feedback(task, post_st, result)
    let new_strat = evolve(post_st, strat, pre_laws)

    println("")
    println("=== TICK COMPLETE ===")
    println("laws: " + to_string(pre_laws) + " -> " + to_string(post_st.laws_count) + " (+" + to_string(post_st.laws_count - pre_laws) + ")")
    println("health: " + to_string(post_st.health))
    println("status: " + post_st.status_flag)
    println("perspective: " + perspectives[new_strat.current_perspective])
    println("cross_discoveries: " + to_string(post_st.cross_discoveries))
}

