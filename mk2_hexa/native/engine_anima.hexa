    while ti < 5 {
        let marker = if ti == strat.current_perspective { " <-- active" } else { "" }
        println("| " + perspectives[ti] + " | " + perspective_seeds[ti] + " | " + to_string(strat.perspective_weights[ti]) + marker + " |")
