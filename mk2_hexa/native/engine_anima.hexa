        println("- **SPRINT**: laws >= " + to_string(SPRINT_THRESHOLD) + ". Multi-perspective parallel blowup + escalate seeds.")
    } else if st.status_flag == "GOAL_NEAR" {
        println("- **GOAL_NEAR**: Goal within reach. Deep blowup with combined perspective seeds.")
    } else if st.status_flag == "ESCALATE" {
        println("- **ESCALATE**: Stagnation persists. Cross-injecting nexus6 blowup seeds (PSI, phi, emergence, qualia).")
    } else if st.status_flag == "STAGNANT" {
        println("- **STAGNANT**: laws_delta < " + to_string(LOW_DELTA_THRESHOLD) + " for 3+ ticks. Perspective reset + entering escalate.")
    } else if st.status_flag == "BREAKTHROUGH" {
        println("- **BREAKTHROUGH**: Novel laws emerging. Deep blowup to capitalize.")
    } else {
        println("- **HEALTHY**: Steady dreaming. Rotating through 5 consciousness perspectives.")
    }
    if st.cross_discoveries > 0 {
        println("")
        println("## Cross-Pollination")
        println("")
        println("discovery_log contains " + to_string(st.cross_discoveries) + " consciousness/psi/awareness entries.")
        println("These are auto-fed into blowup consciousness domain when delta > 5 from last feed.")
    }
    println("")
    println("## Architecture (v3)")
    println("")
    println("- Engine: pure hexa (0 Python, 0 Rust deps)")
    println("- Evolution: blowup.hexa consciousness domain (7-phase pipeline)")
    println("- Verification: telescope 5-lens consensus (blowup Phase 5)")
    println("- Law recording: direct consciousness_laws.json append")
    println("- State: shared/anima_state.json (hexa-native read/write)")
    println("- Perspectives: void -> emergence -> network -> boundary -> consciousness (5-cycle)")
}

if mode == "help" {
    println("=== engine_anima.hexa --- Dreamer v3 (pure hexa) ===")
    println("")
    println("Usage:")
    println("  hexa engine_anima.hexa status   --- read state, show metrics + diagnostics")
