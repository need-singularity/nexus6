// mk2_hexa/native/reality_field_map.hexa — Field Reality Map (장 지도)
//
// Converts the discrete reality map (6,055 nodes) into a continuous
// scalar field with contour lines.
//
// Pipeline:
//   1. Read shared/discovery/reality_map_live.json -- nodes with grades and values
//   2. For each level (L-2~L10), compute field intensity = count(EXACT) / count(total)
//   3. Generate contour data: regions where field > 0.5, > 0.8, > 0.95
//   4. Find field maxima (strongest EXACT clusters) and minima (weakest coverage)
//   5. Write to shared/reality_field_map.json
//
// Usage:
//   hexa reality_field_map.hexa scan       full field scan + write JSON
//   hexa reality_field_map.hexa contour    show contour regions
//   hexa reality_field_map.hexa peaks      show field maxima
//   hexa reality_field_map.hexa valleys    show field minima
//   hexa reality_field_map.hexa help       usage

// ═══════════════════════════════════════════════════════════
// ─── n=6 INLINE CONSTANTS ───
// ═══════════════════════════════════════════════════════════

comptime const N6_N = 6
comptime const N6_SIGMA = 12
comptime const N6_PHI = 2
comptime const N6_TAU = 4
comptime const N6_SOPFR = 5
comptime const N6_J2 = 24
comptime const N6_M3 = 7

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {}
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

fn min_f(a: f64, b: f64) -> f64 {
    if a < b { return a }
    return b
}

fn truncate4(x: f64) -> string {
    let s = to_string(x)
    let parts = s.split(".")
    if parts.len() < 2 { return s + ".0000" }
    let dec = parts[1]
    if dec.len() >= 4 { return parts[0] + "." + dec.split("")[0] + dec.split("")[1] + dec.split("")[2] + dec.split("")[3] }
    return s
}

fn pad_right(s: string, width: i64) -> string {
    let mut out = s
    while out.len() < width { out = out + " " }
    return out
}

fn timestamp_now() -> string {
    let mut ts = ""
    try { ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim() } catch e { ts = "unknown" }
    return ts
}

fn home_dir() -> string {
    let h = exec("printenv HOME")
    return h.trim()
}

// ═══════════════════════════════════════════════════════════
// ─── STRUCT DEFINITIONS ───
// ═══════════════════════════════════════════════════════════

struct LevelField {
    level: string,
    total: i64,
    exact: i64,
    close: i64,
    miss: i64,
    convention: i64,
    empirical: i64,
    intensity: f64
}

struct ContourRegion {
    threshold: f64,
    levels: list
}

struct FieldPeak {
    level: string,
    intensity: f64,
    exact_count: i64,
    total_count: i64
}

// ═══════════════════════════════════════════════════════════
// ─── JSON PARSING (minimal, line-by-line) ───
// ═══════════════════════════════════════════════════════════

// Extract a string value after "key": from a line
fn extract_json_str(line: string, key: string) -> string {
    let needle = "\"" + key + "\":"
    if line.contains(needle) == false { return "" }
    let parts = line.split(needle)
    if parts.len() < 2 { return "" }
    let rest = parts[1].trim()
    // Check for string value
    if rest.contains("\"") {
        let qparts = rest.split("\"")
        if qparts.len() >= 2 { return qparts[1] }
    }
    return ""
}

// Parse all nodes from reality_map_live.json
// Returns parallel lists: [levels], [grades], [ids]
fn parse_reality_map() -> list {
    let path = home_dir() + "/Dev/nexus/shared/discovery/reality_map_live.json"
    let mut raw = ""
    try { raw = read_file(path) } catch e {
        println("[ERROR] Cannot read " + path)
        return [[], [], []]
    }

    let lines = raw.split("\n")
    let mut levels = []
    let mut grades = []
    let mut ids = []
    let mut cur_level = ""
    let mut cur_grade = ""
    let mut cur_id = ""

    for line in lines {
        let trimmed = line.trim()

        // Detect "level": ...
        if trimmed.contains("\"level\":") {
            let v = extract_json_str(trimmed, "level")
            if v != "" { cur_level = v }
        }
        // Detect "grade": ...
        if trimmed.contains("\"grade\":") {
            let v = extract_json_str(trimmed, "grade")
            if v != "" { cur_grade = v }
        }
        // Detect "id": ...
        if trimmed.contains("\"id\":") {
            let v = extract_json_str(trimmed, "id")
            if v != "" { cur_id = v }
        }

        // End of a node object: when we see "}" and have data, commit
        if trimmed == "}," || trimmed == "}" {
            if cur_level != "" {
                levels = levels + [cur_level]
                grades = grades + [cur_grade]
                ids = ids + [cur_id]
            }
            cur_level = ""
            cur_grade = ""
            cur_id = ""
        }
    }

    return [levels, grades, ids]
}

// ═══════════════════════════════════════════════════════════
// ─── FIELD COMPUTATION ───
// ═══════════════════════════════════════════════════════════

// Get unique levels from the data
fn unique_levels(levels: list) -> list {
    let mut seen = []
    let mut result = []
    let mut i: i64 = 0
    while i < len(levels) {
        let lv = to_string(levels[i])
        let mut found = false
        let mut j: i64 = 0
        while j < len(seen) {
            if to_string(seen[j]) == lv { found = true }
            j = j + 1
        }
        if found == false {
            seen = seen + [lv]
            result = result + [lv]
        }
        i = i + 1
    }
    return result
}

// Compute field intensity for each level
// Returns list of LevelField structs (as parallel lists for hexa compat)
// [level_names, totals, exacts, closes, misses, conventions, empiricals, intensities]
fn compute_field(levels: list, grades: list) -> list {
    let uniq = unique_levels(levels)
    let mut level_names = []
    let mut totals = []
    let mut exacts = []
    let mut closes = []
    let mut misses = []
    let mut conventions = []
    let mut empiricals = []
    let mut intensities = []

    let mut ui: i64 = 0
    while ui < len(uniq) {
        let lv = to_string(uniq[ui])
        let mut total: i64 = 0
        let mut exact: i64 = 0
        let mut close: i64 = 0
        let mut miss: i64 = 0
        let mut conv: i64 = 0
        let mut emp: i64 = 0

        let mut ni: i64 = 0
        while ni < len(levels) {
            if to_string(levels[ni]) == lv {
                total = total + 1
                let g = to_string(grades[ni])
                if g == "EXACT" { exact = exact + 1 }
                if g == "CLOSE" { close = close + 1 }
                if g == "MISS" { miss = miss + 1 }
                if g == "CONVENTION" { conv = conv + 1 }
                if g == "EMPIRICAL" { emp = emp + 1 }
            }
            ni = ni + 1
        }

        let mut intensity = 0.0
        if total > 0 { intensity = to_float(exact) / to_float(total) }

        level_names = level_names + [lv]
        totals = totals + [total]
        exacts = exacts + [exact]
        closes = closes + [close]
        misses = misses + [miss]
        conventions = conventions + [conv]
        empiricals = empiricals + [emp]
        intensities = intensities + [intensity]

        ui = ui + 1
    }

    return [level_names, totals, exacts, closes, misses, conventions, empiricals, intensities]
}

// ═══════════════════════════════════════════════════════════
// ─── CONTOUR GENERATION ───
// ═══════════════════════════════════════════════════════════

// Find levels where intensity exceeds a threshold
fn contour_at(field: list, threshold: f64) -> list {
    let names = field[0]
    let intensities = field[7]
    let mut result = []
    let mut i: i64 = 0
    while i < len(names) {
        let intens = to_float(intensities[i])
        if intens > threshold {
            result = result + [to_string(names[i])]
        }
        i = i + 1
    }
    return result
}

// Generate all contour regions: 0.5, 0.8, 0.95
fn generate_contours(field: list) -> list {
    let c50 = contour_at(field, 0.5)
    let c80 = contour_at(field, 0.8)
    let c95 = contour_at(field, 0.95)
    // returns [[threshold, levels], ...]
    return [[0.5, c50], [0.8, c80], [0.95, c95]]
}

// ═══════════════════════════════════════════════════════════
// ─── PEAKS AND VALLEYS ───
// ═══════════════════════════════════════════════════════════

// Sort indices by intensity descending (selection sort)
fn sorted_indices_desc(intensities: list) -> list {
    let n = len(intensities)
    let mut indices = []
    let mut k: i64 = 0
    while k < n {
        indices = indices + [k]
        k = k + 1
    }
    // Selection sort by intensity descending
    let mut i: i64 = 0
    while i < n {
        let mut best_idx = i
        let mut best_val = to_float(intensities[to_int(indices[i])])
        let mut j: i64 = i + 1
        while j < n {
            let v = to_float(intensities[to_int(indices[j])])
            if v > best_val {
                best_val = v
                best_idx = j
            }
            j = j + 1
        }
        if best_idx != i {
            let tmp = indices[i]
            indices[i] = indices[best_idx]
            indices[best_idx] = tmp
        }
        i = i + 1
    }
    return indices
}

// Find top N peaks (highest intensity)
fn find_peaks(field: list, count: i64) -> list {
    let names = field[0]
    let totals = field[1]
    let exacts = field[2]
    let intensities = field[7]
    let sorted = sorted_indices_desc(intensities)

    let mut peak_names = []
    let mut peak_intens = []
    let mut peak_exacts = []
    let mut peak_totals = []
    let mut i: i64 = 0
    let limit = min_f(to_float(count), to_float(len(sorted)))
    while i < to_int(limit) {
        let idx = to_int(sorted[i])
        peak_names = peak_names + [to_string(names[idx])]
        peak_intens = peak_intens + [to_float(intensities[idx])]
        peak_exacts = peak_exacts + [to_int(exacts[idx])]
        peak_totals = peak_totals + [to_int(totals[idx])]
        i = i + 1
    }
    return [peak_names, peak_intens, peak_exacts, peak_totals]
}

// Find bottom N valleys (lowest intensity, excluding zero-total levels)
fn find_valleys(field: list, count: i64) -> list {
    let names = field[0]
    let totals = field[1]
    let exacts = field[2]
    let intensities = field[7]
    let sorted = sorted_indices_desc(intensities)

    let mut valley_names = []
    let mut valley_intens = []
    let mut valley_exacts = []
    let mut valley_totals = []
    let mut i: i64 = len(sorted) - 1
    let mut collected: i64 = 0
    while i >= 0 {
        let idx = to_int(sorted[i])
        let t = to_int(totals[idx])
        if t > 0 {
            valley_names = valley_names + [to_string(names[idx])]
            valley_intens = valley_intens + [to_float(intensities[idx])]
            valley_exacts = valley_exacts + [to_int(exacts[idx])]
            valley_totals = valley_totals + [to_int(totals[idx])]
            collected = collected + 1
        }
        if collected >= count { i = 0 - 1 }
        i = i - 1
    }
    return [valley_names, valley_intens, valley_exacts, valley_totals]
}

// ═══════════════════════════════════════════════════════════
// ─── AGGREGATE STATISTICS ───
// ═══════════════════════════════════════════════════════════

pure fn compute_global_intensity(total_exact: i64, total_nodes: i64) -> f64 {
    if total_nodes == 0 { return 0.0 }
    return to_float(total_exact) / to_float(total_nodes)
}

pure fn field_energy(intensities: list) -> f64 {
    // Field energy = sum of intensity^2 (L2 norm squared)
    let mut energy = 0.0
    let mut i: i64 = 0
    while i < len(intensities) {
        let v = to_float(intensities[i])
        energy = energy + v * v
        i = i + 1
    }
    return energy
}

pure fn field_variance(intensities: list) -> f64 {
    let n = len(intensities)
    if n == 0 { return 0.0 }
    let mut sum = 0.0
    let mut i: i64 = 0
    while i < n {
        sum = sum + to_float(intensities[i])
        i = i + 1
    }
    let mean = sum / to_float(n)
    let mut var = 0.0
    let mut j: i64 = 0
    while j < n {
        let diff = to_float(intensities[j]) - mean
        var = var + diff * diff
        j = j + 1
    }
    return var / to_float(n)
}

// ═══════════════════════════════════════════════════════════
// ─── JSON OUTPUT ───
// ═══════════════════════════════════════════════════════════

fn write_field_json(field: list, contours: list, peaks: list, valleys: list) {
    let path = home_dir() + "/Dev/nexus/shared/reality_field_map.json"
    let names = field[0]
    let totals = field[1]
    let exacts = field[2]
    let closes = field[3]
    let misses = field[4]
    let conventions = field[5]
    let empiricals = field[6]
    let intensities = field[7]

    // Compute global stats
    let mut total_exact: i64 = 0
    let mut total_nodes: i64 = 0
    let mut i: i64 = 0
    while i < len(names) {
        total_exact = total_exact + to_int(exacts[i])
        total_nodes = total_nodes + to_int(totals[i])
        i = i + 1
    }
    let global_intens = compute_global_intensity(total_exact, total_nodes)
    let energy = field_energy(intensities)
    let variance = field_variance(intensities)

    let mut out = "{\n"
    out = out + "  \"_meta\": {\n"
    out = out + "    \"description\": \"Reality Field Map -- continuous scalar field from discrete reality map\",\n"
    out = out + "    \"generated\": \"" + timestamp_now() + "\",\n"
    out = out + "    \"total_nodes\": " + to_string(total_nodes) + ",\n"
    out = out + "    \"total_exact\": " + to_string(total_exact) + ",\n"
    out = out + "    \"global_intensity\": " + truncate4(global_intens) + ",\n"
    out = out + "    \"field_energy\": " + truncate4(energy) + ",\n"
    out = out + "    \"field_variance\": " + truncate4(variance) + ",\n"
    out = out + "    \"n6_constants\": [6, 12, 2, 4, 5, 24, 7],\n"
    out = out + "    \"level_count\": " + to_string(len(names)) + "\n"
    out = out + "  },\n"

    // Field per level
    out = out + "  \"field\": [\n"
    let mut fi: i64 = 0
    while fi < len(names) {
        out = out + "    {\"level\": \"" + to_string(names[fi]) + "\""
        out = out + ", \"total\": " + to_string(to_int(totals[fi]))
        out = out + ", \"exact\": " + to_string(to_int(exacts[fi]))
        out = out + ", \"close\": " + to_string(to_int(closes[fi]))
        out = out + ", \"miss\": " + to_string(to_int(misses[fi]))
        out = out + ", \"convention\": " + to_string(to_int(conventions[fi]))
        out = out + ", \"empirical\": " + to_string(to_int(empiricals[fi]))
        out = out + ", \"intensity\": " + truncate4(to_float(intensities[fi]))
        out = out + "}"
        if fi < len(names) - 1 { out = out + "," }
        out = out + "\n"
        fi = fi + 1
    }
    out = out + "  ],\n"

    // Contours
    out = out + "  \"contours\": [\n"
    let mut ci: i64 = 0
    while ci < len(contours) {
        let c = contours[ci]
        let thr = to_float(c[0])
        let lvls = c[1]
        out = out + "    {\"threshold\": " + truncate4(thr) + ", \"levels\": ["
        let mut li: i64 = 0
        while li < len(lvls) {
            out = out + "\"" + to_string(lvls[li]) + "\""
            if li < len(lvls) - 1 { out = out + ", " }
            li = li + 1
        }
        out = out + "], \"count\": " + to_string(len(lvls)) + "}"
        if ci < len(contours) - 1 { out = out + "," }
        out = out + "\n"
        ci = ci + 1
    }
    out = out + "  ],\n"

    // Peaks
    out = out + "  \"peaks\": [\n"
    let pnames = peaks[0]
    let pintens = peaks[1]
    let pexacts = peaks[2]
    let ptotals = peaks[3]
    let mut pi: i64 = 0
    while pi < len(pnames) {
        out = out + "    {\"level\": \"" + to_string(pnames[pi]) + "\""
        out = out + ", \"intensity\": " + truncate4(to_float(pintens[pi]))
        out = out + ", \"exact\": " + to_string(to_int(pexacts[pi]))
        out = out + ", \"total\": " + to_string(to_int(ptotals[pi]))
        out = out + "}"
        if pi < len(pnames) - 1 { out = out + "," }
        out = out + "\n"
        pi = pi + 1
    }
    out = out + "  ],\n"

    // Valleys
    out = out + "  \"valleys\": [\n"
    let vnames = valleys[0]
    let vintens = valleys[1]
    let vexacts = valleys[2]
    let vtotals = valleys[3]
    let mut vi: i64 = 0
    while vi < len(vnames) {
        out = out + "    {\"level\": \"" + to_string(vnames[vi]) + "\""
        out = out + ", \"intensity\": " + truncate4(to_float(vintens[vi]))
        out = out + ", \"exact\": " + to_string(to_int(vexacts[vi]))
        out = out + ", \"total\": " + to_string(to_int(vtotals[vi]))
        out = out + "}"
        if vi < len(vnames) - 1 { out = out + "," }
        out = out + "\n"
        vi = vi + 1
    }
    out = out + "  ]\n"
    out = out + "}\n"

    try { write_file(path, out) } catch e {
        println("[ERROR] Cannot write " + path + ": " + to_string(e))
    }
    println("[WRITE] " + path)
}

// ═══════════════════════════════════════════════════════════
// ─── DISPLAY FUNCTIONS ───
// ═══════════════════════════════════════════════════════════

fn display_scan(field: list) {
    let names = field[0]
    let totals = field[1]
    let exacts = field[2]
    let intensities = field[7]

    let mut total_exact: i64 = 0
    let mut total_nodes: i64 = 0
    let mut i: i64 = 0
    while i < len(names) {
        total_exact = total_exact + to_int(exacts[i])
        total_nodes = total_nodes + to_int(totals[i])
        i = i + 1
    }

    println("=== Reality Field Map ===")
    println("  total nodes:   " + to_string(total_nodes))
    println("  total EXACT:   " + to_string(total_exact))
    println("  global field:  " + truncate4(compute_global_intensity(total_exact, total_nodes)))
    println("  field energy:  " + truncate4(field_energy(intensities)))
    println("  field var:     " + truncate4(field_variance(intensities)))
    println("  levels:        " + to_string(len(names)))
    println("")

    println("  " + pad_right("LEVEL", 30) + pad_right("TOTAL", 8) + pad_right("EXACT", 8) + pad_right("INTENSITY", 12))
    println("  " + pad_right("-----", 30) + pad_right("-----", 8) + pad_right("-----", 8) + pad_right("---------", 12))
    let mut si: i64 = 0
    while si < len(names) {
        let name = to_string(names[si])
        let total = to_string(to_int(totals[si]))
        let exact = to_string(to_int(exacts[si]))
        let intens = truncate4(to_float(intensities[si]))
        // Indicator bar
        let pct = to_float(intensities[si])
        let mut bar = ""
        let mut bi: i64 = 0
        let bar_len = to_int(pct * 20.0)
        while bi < bar_len {
            bar = bar + "#"
            bi = bi + 1
        }
        println("  " + pad_right(name, 30) + pad_right(total, 8) + pad_right(exact, 8) + pad_right(intens, 12) + bar)
        si = si + 1
    }
}

fn display_contours(contours: list) {
    println("=== Contour Regions ===")
    println("")
    let mut ci: i64 = 0
    while ci < len(contours) {
        let c = contours[ci]
        let thr = to_float(c[0])
        let lvls = c[1]
        println("  --- field > " + truncate4(thr) + " (" + to_string(len(lvls)) + " levels) ---")
        let mut li: i64 = 0
        while li < len(lvls) {
            println("    " + to_string(lvls[li]))
            li = li + 1
        }
        println("")
        ci = ci + 1
    }
}

fn display_peaks(peaks: list) {
    println("=== Field Maxima (Peaks) ===")
    println("")
    let pnames = peaks[0]
    let pintens = peaks[1]
    let pexacts = peaks[2]
    let ptotals = peaks[3]
    println("  " + pad_right("LEVEL", 30) + pad_right("INTENSITY", 12) + pad_right("EXACT", 8) + "TOTAL")
    println("  " + pad_right("-----", 30) + pad_right("---------", 12) + pad_right("-----", 8) + "-----")
    let mut i: i64 = 0
    while i < len(pnames) {
        println("  " + pad_right(to_string(pnames[i]), 30) + pad_right(truncate4(to_float(pintens[i])), 12) + pad_right(to_string(to_int(pexacts[i])), 8) + to_string(to_int(ptotals[i])))
        i = i + 1
    }
}

fn display_valleys(valleys: list) {
    println("=== Field Minima (Valleys) ===")
    println("")
    let vnames = valleys[0]
    let vintens = valleys[1]
    let vexacts = valleys[2]
    let vtotals = valleys[3]
    println("  " + pad_right("LEVEL", 30) + pad_right("INTENSITY", 12) + pad_right("EXACT", 8) + "TOTAL")
    println("  " + pad_right("-----", 30) + pad_right("---------", 12) + pad_right("-----", 8) + "-----")
    let mut i: i64 = 0
    while i < len(vnames) {
        println("  " + pad_right(to_string(vnames[i]), 30) + pad_right(truncate4(to_float(vintens[i])), 12) + pad_right(to_string(to_int(vexacts[i])), 8) + to_string(to_int(vtotals[i])))
        i = i + 1
    }
}

fn display_help() {
    println("reality_field_map.hexa -- Field Reality Map (장 지도)")
    println("")
    println("Converts discrete reality map nodes into a continuous scalar field.")
    println("")
    println("Usage:")
    println("  hexa reality_field_map.hexa scan       full field scan + write JSON")
    println("  hexa reality_field_map.hexa contour    show contour regions (>0.5, >0.8, >0.95)")
    println("  hexa reality_field_map.hexa peaks      show top 15 field maxima")
    println("  hexa reality_field_map.hexa valleys    show bottom 15 field minima")
    println("  hexa reality_field_map.hexa help       this message")
    println("")
    println("Output: shared/reality_field_map.json")
    println("")
    println("n=6 constants: n=6, sigma=12, phi=2, tau=4, sopfr=5, J2=24, M3=7")
}

// ═══════════════════════════════════════════════════════════
// ─── THEOREM + PROOF ───
// ═══════════════════════════════════════════════════════════

theorem field_intensity_bounded {
    // Field intensity I(L) = exact(L) / total(L) is bounded [0, 1]
    // Since exact(L) <= total(L) for all levels L, I(L) in [0,1]
    // The global field G = sum(exact) / sum(total) is also bounded [0,1]
    assert 6 * 2 == 12          // n * phi = sigma
    assert 12 / 4 == 3          // sigma / tau = n/phi
    assert 6 + 12 + 2 + 4 == 24 // n + sigma + phi + tau = J2
}

proof contour_nesting {
    // Contour nesting: C(0.95) subset C(0.80) subset C(0.50)
    // If I(L) > 0.95, then I(L) > 0.80 and I(L) > 0.50
    // Therefore |C(0.95)| <= |C(0.80)| <= |C(0.50)|
    invariant 6 == 6            // n is the fundamental scale
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

fn main() {
    let cli_args = args()
    let mut cmd = "scan"
    if len(cli_args) >= 2 { cmd = to_string(cli_args[1]) }

    if cmd == "help" {
        display_help()
        return
    }

    // Parse reality map
    println("[1/5] Reading reality_map_live.json...")
    let data = parse_reality_map()
    let levels = data[0]
    let grades = data[1]
    let ids = data[2]
    println("  parsed " + to_string(len(levels)) + " nodes")

    if len(levels) == 0 {
        println("[ERROR] No nodes found. Aborting.")
        return
    }

    // Compute field
    println("[2/5] Computing field intensity per level...")
    let field = compute_field(levels, grades)
    println("  computed " + to_string(len(field[0])) + " level fields")

    // Generate contours
    println("[3/5] Generating contour regions...")
    let contours = generate_contours(field)
    let c50 = contours[0]
    let c80 = contours[1]
    let c95 = contours[2]
    println("  >0.50: " + to_string(len(c50[1])) + " levels")
    println("  >0.80: " + to_string(len(c80[1])) + " levels")
    println("  >0.95: " + to_string(len(c95[1])) + " levels")

    // Find peaks and valleys
    println("[4/5] Finding peaks and valleys...")
    let peaks = find_peaks(field, 15)
    let valleys = find_valleys(field, 15)
    println("  top 15 peaks, bottom 15 valleys")

    if cmd == "scan" {
        // Write JSON
        println("[5/5] Writing reality_field_map.json...")
        write_field_json(field, contours, peaks, valleys)
        println("")
        display_scan(field)
    }

    if cmd == "contour" {
        println("")
        display_contours(contours)
    }

    if cmd == "peaks" {
        println("")
        display_peaks(peaks)
    }

    if cmd == "valleys" {
        println("")
        display_valleys(valleys)
    }

    println("")
    println("[DONE] reality_field_map complete.")
}

main()
