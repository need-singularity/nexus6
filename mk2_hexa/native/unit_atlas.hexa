// ═══════════════════════════════════════════════════════════
// ─── SCAN ENGINE ───
// ═══════════════════════════════════════════════════════════

fn scan_domain(domain: string, count: i64) -> string {
    // Returns: resonance_count|total|domain_name
    let mut resonances: i64 = 0
    let mut total: i64 = 0
    let mut i: i64 = 0

    println("")
    println("  ┌─────────────────────────────────────────────────────────────────────────────────┐")
    println("  │ " + pad_right(domain, 79) + "│")
    println("  ├───────────────────────────────┬────────────┬──────────┬──────────┬──────────────┤")
    println("  │ Constant                      │ Value      │ n6 Expr  │ Dist %   │ Status       │")
    println("  ├───────────────────────────────┼────────────┼──────────┼──────────┼──────────────┤")

    while i < count {
        let mut name = ""
        let mut val = 0.0
        let mut note = ""

        if domain == "SEMICONDUCTOR" {
            name = semi_name(i)
            val = semi_val(i)
            note = semi_note(i)
        }
        if domain == "MATERIALS" {
            name = mat_name(i)
            val = mat_val(i)
            note = mat_note(i)
        }
        if domain == "AUTOMOTIVE" {
            name = auto_name(i)
            val = auto_val(i)
            note = auto_note(i)
        }
        if domain == "STRUCTURAL" {
            name = struct_name(i)
            val = struct_val(i)
            note = struct_note(i)
        }

        if name.len() > 0 {
            let match_str = best_n6_match(val)
            let parts = match_str.split("|")
            let expr_nm = parts[0]
            let dist_pct = safe_float(parts[1])
            let mut status = "  MISS"
            if dist_pct < 0.01 {
                status = "  EXACT"
                resonances = resonances + 1
            } else if dist_pct < 1.0 {
                status = "  RESONANCE"
                resonances = resonances + 1
            } else if dist_pct < 5.0 {
                status = "  NEAR"
            }

            let val_str = round4(val)
            println("  │ " + pad_right(name, 30) + "│ " + pad_right(val_str, 11) + "│ " + pad_right(expr_nm, 9) + "│ " + pad_right(round4(dist_pct) + "%", 9) + "│ " + pad_right(status, 13) + "│")
            total = total + 1
        }
        i = i + 1
    }

    println("  └───────────────────────────────┴────────────┴──────────┴──────────┴──────────────┘")
    println("  Resonances (<1%): " + to_string(resonances) + " / " + to_string(total) + "  (" + round2(to_float(resonances) * 100.0 / max_f(to_float(total), 1.0)) + "%)")

    return to_string(resonances) + "|" + to_string(total) + "|" + domain
}

// ═══════════════════════════════════════════════════════════
// ─── FRACTAL SCAN ───
// ═══════════════════════════════════════════════════════════

fn scan_fractal() -> string {
    println("")
    println("  ┌─────────────────────────────────────────────────────────────────────────────────┐")
    println("  │ FRACTAL DEPTH ANALYSIS — Structural Nesting Depth                               │")
    println("  ├──────────────────┬───────┬──────────────────────────────────────────────────────┤")
    println("  │ System           │ Depth │ Layers                                               │")
    println("  ├──────────────────┼───────┼──────────────────────────────────────────────────────┤")

    let mut depth6_count: i64 = 0
    let mut i: i64 = 0
    while i < fractal_count() {
        let name = fractal_name(i)
        let depth = fractal_depth(i)
        let layers = fractal_layers(i)
        let mut marker = ""
        if depth == 6 {
            marker = " = n!"
            depth6_count = depth6_count + 1
        }
        if depth == 5 {
            marker = " = sopfr"
        }
        println("  │ " + pad_right(name, 17) + "│   " + to_string(depth) + pad_right(marker, 3) + " │ " + pad_right(layers, 53) + "│")
        i = i + 1
    }

    println("  └──────────────────┴───────┴──────────────────────────────────────────────────────┘")
    println("  Systems with depth=6 (=n): " + to_string(depth6_count) + " / " + to_string(fractal_count()))
    println("  >>> Real-world hierarchies converge on depth=n=6 <<<")

    return to_string(depth6_count) + "|" + to_string(fractal_count())
}

// ═══════════════════════════════════════════════════════════
// ─── CROSS-DOMAIN REPORT ───
// ═══════════════════════════════════════════════════════════

fn cross_domain_report(results: string) -> string {
    // results format: "res1|tot1|dom1;res2|tot2|dom2;..."
    let entries = results.split("
    ")
    let mut total_res: i64 = 0
    let mut total_all: i64 = 0

    println("")
    println("  ═══════════════════════════════════════════════════")
    println("  ║       CROSS-DOMAIN RESONANCE SUMMARY            ║")
    println("  ═══════════════════════════════════════════════════")
    println("  ┌──────────────────┬────────────┬─────────────────┐")
    println("  │ Domain           │ Resonances │ Rate            │")
    println("  ├──────────────────┼────────────┼─────────────────┤")

    let mut i: i64 = 0
    while i < entries.len() {
        let entry = entries[i]
        if entry.len() > 2 {
            let parts = entry.split("|")
            if parts.len() >= 3 {
                let res = to_int(parts[0])
                let tot = to_int(parts[1])
                let dom = parts[2]
                total_res = total_res + res
                total_all = total_all + tot
                let rate = to_float(res) * 100.0 / max_f(to_float(tot), 1.0)
                println("  │ " + pad_right(dom, 17) + "│ " + pad_right(to_string(res) + "/" + to_string(tot), 11) + "│ " + pad_right(round2(rate) + "%", 16) + "│")
            }
        }
        i = i + 1
    }

    println("  ├──────────────────┼────────────┼─────────────────┤")
    let total_rate = to_float(total_res) * 100.0 / max_f(to_float(total_all), 1.0)
    println("  │ " + pad_right("TOTAL", 17) + "│ " + pad_right(to_string(total_res) + "/" + to_string(total_all), 11) + "│ " + pad_right(round2(total_rate) + "%", 16) + "│")
    println("  └──────────────────┴────────────┴─────────────────┘")

    // Meta fixed point check
    let rho = to_float(total_res) / max_f(to_float(total_all), 1.0)
    println("")
    println("  Meta Fixed Point check:")
    println("    rho (resonance rate) = " + round4(rho))
    println("    1/3 (meta FP)        = 0.3333")
    let fp_dist = abs_f(rho - 0.333333) / 0.333333 * 100.0
    println("    distance to 1/3      = " + round2(fp_dist) + "%")
    if fp_dist < 15.0 {
        println("    >>> CONVERGING toward meta fixed point 1/3 <<<")
    }

    return round4(rho)
}

// ═══════════════════════════════════════════════════════════
// ─── JSONL OUTPUT ───
// ═══════════════════════════════════════════════════════════

fn write_discovery(domain: string, name: string, val: f64, expr_nm: string, dist_pct: f64) -> bool {
    if dist_pct > 1.0 { return false }
    let line = "{\"source\":\"unit_atlas\",\"domain\":\"" + domain + "\",\"constant\":\"" + name + "\",\"value\":" + round4(val) + ",\"n6_expr\":\"" + expr_nm + "\",\"dist_pct\":" + round4(dist_pct) + ",\"grade\":\"RESONANCE\"}"
    let path = "shared/discovery/discovery_log.jsonl"
    let mut existing = ""
    try { existing = read_file(path) } catch e {}
    if existing.contains(name) { return false }
    write_file(path, existing + line + "\n")
    return true
}

fn log_resonances(domain: string, count_fn: i64) -> i64 {
    let mut logged: i64 = 0
    let mut i: i64 = 0
    while i < count_fn {
        let mut name = ""
        let mut val = 0.0
        if domain == "SEMICONDUCTOR" {
            name = semi_name(i)
            val = semi_val(i)
        }
        if domain == "MATERIALS" {
            name = mat_name(i)
            val = mat_val(i)
        }
        if domain == "AUTOMOTIVE" {
            name = auto_name(i)
            val = auto_val(i)
        }
        if domain == "STRUCTURAL" {
            name = struct_name(i)
            val = struct_val(i)
        }
        if name.len() > 0 {
            let match_str = best_n6_match(val)
            let parts = match_str.split("|")
            let dist_pct = safe_float(parts[1])
            if write_discovery(domain, name, val, parts[0], dist_pct) {
                logged = logged + 1
            }
        }
        i = i + 1
    }
    return logged
}

