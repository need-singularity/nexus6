fn fractal_name(idx: i64) -> string {
    if idx == 0 { return "Tire" }
    if idx == 1 { return "Chip" }
    if idx == 2 { return "Car" }
    if idx == 3 { return "Building" }
    if idx == 4 { return "Human body" }
    if idx == 5 { return "Atom" }
    if idx == 6 { return "Internet" }
    if idx == 7 { return "Galaxy" }
    return ""
}

fn fractal_depth(idx: i64) -> i64 {
    if idx == 0 { return 5 }   // rubber > compound > polymer > monomer > atoms
    if idx == 1 { return 6 }   // wafer > die > block > cell > transistor > gate
    if idx == 2 { return 6 }   // body > chassis > suspension > wheel > tire > compound
    if idx == 3 { return 6 }   // structure > floor > room > wall > brick > morite
    if idx == 4 { return 6 }   // organism > organ > tissue > cell > organelle > molecule
    if idx == 5 { return 6 }   // atom > nucleus > nucleon > quark > gluon > field
    if idx == 6 { return 6 }   // internet > AS > network > subnet > host > process
    if idx == 7 { return 6 }   // galaxy > arm > cluster > system > planet > surface
    return 0
}

fn fractal_layers(idx: i64) -> string {
    if idx == 0 { return "rubber > compound > polymer > monomer > atoms" }
    if idx == 1 { return "wafer > die > block > cell > transistor > gate" }
