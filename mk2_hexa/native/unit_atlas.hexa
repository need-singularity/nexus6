// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

fn main() {
    let argv = args()
    let mut cmd = "help"
    if argv.len() > 2 {
        cmd = argv[2]
    }

    if cmd == "help" || cmd == "--help" || cmd == "-h" {
        print_help()
        return
    }

    print_banner()

    let mut results = ""

    if cmd == "semi" || cmd == "scan" || cmd == "all" {
        let r = scan_domain("SEMICONDUCTOR", semi_count())
        if results.len() > 0 {
            results = results + "
            "
        }
        results = results + r
        let _logged = log_resonances("SEMICONDUCTOR", semi_count())
    }

    if cmd == "mat" || cmd == "scan" || cmd == "all" {
        let r = scan_domain("MATERIALS", mat_count())
        if results.len() > 0 {
            results = results + "
            "
        }
        results = results + r
        let _logged = log_resonances("MATERIALS", mat_count())
    }

    if cmd == "auto" || cmd == "tire" || cmd == "scan" || cmd == "all" {
        let r = scan_domain("AUTOMOTIVE", auto_count())
        if results.len() > 0 {
            results = results + "
            "
        }
        results = results + r
        let _logged = log_resonances("AUTOMOTIVE", auto_count())
    }

    if cmd == "struct" || cmd == "scan" || cmd == "all" {
        let r = scan_domain("STRUCTURAL", struct_count())
        if results.len() > 0 {
            results = results + "
            "
        }
        results = results + r
        let _logged = log_resonances("STRUCTURAL", struct_count())
    }

    if cmd == "fractal" || cmd == "all" {
        let _fr = scan_fractal()
    }

    if cmd == "scan" || cmd == "all" {
        let _rho = cross_domain_report(results)
    }

    println("")
}

main()
