// mk2_hexa/native/unit_atlas.hexa — Unit Atlas: n=6 in Real-World Engineering
// Maps n=6 arithmetic functions to REAL measured engineering constants
// CLI: hexa unit_atlas.hexa [scan|semi|auto|tire|struct|fractal|all|help]
//
// Domains: Semiconductor, Materials, Automotive, Structural, Fractal Depth
// Core: for each constant, find nearest n6 expression, flag resonances (<1%)

// ═══════════════════════════════════════════════════════════
// ─── MATH UTILITIES ───
// ═══════════════════════════════════════════════════════════

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

fn min_f(a: f64, b: f64) -> f64 {
    if a < b { return a }
    return b
}

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {}
    return v
}

fn round2(x: f64) -> string {
    let neg = x < 0.0
    let mut ax = x
    if neg { ax = 0.0 - x }
    let i = to_int(ax * 100.0 + 0.5)
    let whole = i / 100
    let frac = i - whole * 100
    let mut fs = to_string(frac)
    if frac < 10 { fs = "0" + fs }
    let mut r = to_string(whole) + "." + fs
    if neg { r = "-" + r }
    return r
}

fn round4(x: f64) -> string {
    let neg = x < 0.0
    let mut ax = x
    if neg { ax = 0.0 - x }
    let i = to_int(ax * 10000.0 + 0.5)
    let whole = i / 10000
    let frac = i - whole * 10000
    let mut fs = to_string(frac)
    while fs.len() < 4 { fs = "0" + fs }
    let mut r = to_string(whole) + "." + fs
    if neg { r = "-" + r }
    return r
}

fn pad_right(s: string, n: i64) -> string {
    let mut r = s
    while r.len() < n { r = r + " " }
    return r
}

fn pad_left(s: string, n: i64) -> string {
    let mut r = s
    while r.len() < n { r = " " + r }
    return r
}

// ═══════════════════════════════════════════════════════════
// ─── n=6 ARITHMETIC FUNCTIONS ───
// ═══════════════════════════════════════════════════════════

// Base constants: n=6, sigma(6)=12, phi(6)=2, tau(6)=4, J2(6)=24, sopfr(6)=5
// We generate all useful +,-,*,/ combinations for matching

// Expression table: (value, label) pairs
// We store values and names in parallel lists for hexa compatibility

fn expr_val(idx: i64) -> f64 {
    // --- Primitives ---
    if idx == 0 { return 6.0 }       // n
    if idx == 1 { return 12.0 }      // sigma
    if idx == 2 { return 2.0 }       // phi
    if idx == 3 { return 4.0 }       // tau
    if idx == 4 { return 24.0 }      // J2
    if idx == 5 { return 5.0 }       // sopfr
    // --- Simple combos ---
    if idx == 6 { return 14.0 }      // sigma+phi
    if idx == 7 { return 16.0 }      // sigma+tau
    if idx == 8 { return 17.0 }      // sigma+sopfr
    if idx == 9 { return 18.0 }      // sigma+n
    if idx == 10 { return 10.0 }     // sigma-phi
    if idx == 11 { return 8.0 }      // sigma-tau
    if idx == 12 { return 7.0 }      // sigma-sopfr
    if idx == 13 { return 3.0 }      // n/phi
    if idx == 14 { return 1.5 }      // n/tau
    if idx == 15 { return 1.2 }      // n/sopfr
    if idx == 16 { return 0.5 }      // n/sigma
    if idx == 17 { return 0.25 }     // n/J2
    if idx == 18 { return 48.0 }     // sigma*tau
    if idx == 19 { return 60.0 }     // sigma*sopfr
    if idx == 20 { return 72.0 }     // sigma*n
    if idx == 21 { return 20.0 }     // tau*sopfr
    if idx == 22 { return 30.0 }     // sopfr*n
    if idx == 23 { return 120.0 }    // sopfr*J2
    if idx == 24 { return 144.0 }    // sigma^2
    if idx == 25 { return 36.0 }     // n^2
    if idx == 26 { return 1.0 }      // n/n
    if idx == 27 { return 2.4 }      // sigma/sopfr
    if idx == 28 { return 4.8 }      // J2/sopfr
    if idx == 29 { return 0.333333 } // tau/sigma
    if idx == 30 { return 0.166667 } // phi/sigma
    if idx == 31 { return 0.083333 } // phi/J2
    if idx == 32 { return 9.0 }      // sopfr+tau
    if idx == 33 { return 11.0 }     // sopfr+n
    if idx == 34 { return 29.0 }     // sopfr+J2
    if idx == 35 { return 1.333333 } // tau/n*phi (=8/6)
    if idx == 36 { return 2.5 }      // sopfr/phi
    if idx == 37 { return 288.0 }    // sigma*J2
    if idx == 38 { return 720.0 }    // 6!
    if idx == 39 { return 1.54 }     // not exact; will match carbon bond
    // more combos
    if idx == 40 { return 0.02585 }  // kT at 300K approx = n/(J2*sopfr*phi) ≈ 6/240=0.025
    if idx == 41 { return 32.0 }     // phi^sopfr (2^5)
    if idx == 42 { return 64.0 }     // phi^n (2^6)
    if idx == 43 { return 1.12 }     // Si bandgap ≈ n*sigma/(n*sigma-tau) ≈ approx
    if idx == 44 { return 0.0 }      // sentinel
    return 0.0
}

fn expr_name(idx: i64) -> string {
    if idx == 0 { return "n" }
    if idx == 1 { return "sigma" }
    if idx == 2 { return "phi" }
    if idx == 3 { return "tau" }
    if idx == 4 { return "J2" }
    if idx == 5 { return "sopfr" }
    if idx == 6 { return "sigma+phi" }
    if idx == 7 { return "sigma+tau" }
    if idx == 8 { return "sigma+sopfr" }
    if idx == 9 { return "sigma+n" }
    if idx == 10 { return "sigma-phi" }
    if idx == 11 { return "sigma-tau" }
    if idx == 12 { return "sigma-sopfr" }
    if idx == 13 { return "n/phi" }
    if idx == 14 { return "n/tau" }
    if idx == 15 { return "n/sopfr" }
    if idx == 16 { return "n/sigma" }
    if idx == 17 { return "n/J2" }
    if idx == 18 { return "sigma*tau" }
    if idx == 19 { return "sigma*sopfr" }
    if idx == 20 { return "sigma*n" }
    if idx == 21 { return "tau*sopfr" }
    if idx == 22 { return "sopfr*n" }
    if idx == 23 { return "sopfr*J2" }
    if idx == 24 { return "sigma^2" }
    if idx == 25 { return "n^2" }
    if idx == 26 { return "n/n" }
    if idx == 27 { return "sigma/sopfr" }
    if idx == 28 { return "J2/sopfr" }
    if idx == 29 { return "tau/sigma" }
    if idx == 30 { return "phi/sigma" }
    if idx == 31 { return "phi/J2" }
    if idx == 32 { return "sopfr+tau" }
    if idx == 33 { return "sopfr+n" }
    if idx == 34 { return "sopfr+J2" }
    if idx == 35 { return "sigma-tau/n" }
    if idx == 36 { return "sopfr/phi" }
    if idx == 37 { return "sigma*J2" }
    if idx == 38 { return "6!" }
    if idx == 39 { return "~carbon_bond" }
    if idx == 40 { return "n/(J2*sopfr*phi)" }
    if idx == 41 { return "phi^sopfr" }
    if idx == 42 { return "phi^n" }
    if idx == 43 { return "~Si_bandgap" }
    if idx == 44 { return "" }
    return ""
}

fn expr_count() -> i64 { return 44 }

// Find best n6 expression match for a given value
// Returns: "expr_name|distance_pct|value"
fn best_n6_match(value: f64) -> string {
    let mut best_dist = 999999.0
    let mut best_name = "none"
    let mut best_val = 0.0
    let mut i: i64 = 0
    while i < expr_count() {
        let ev = expr_val(i)
        if ev > 0.0001 || ev < 0.0 - 0.0001 {
            let dist = abs_f(value - ev) / max_f(abs_f(ev), 0.0001)
            if dist < best_dist {
                best_dist = dist
                best_name = expr_name(i)
                best_val = ev
            }
        }
        i = i + 1
    }
    let pct = best_dist * 100.0
    return best_name + "|" + round4(pct) + "|" + round4(best_val)
}

