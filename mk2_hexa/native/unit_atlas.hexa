fn semi_name(idx: i64) -> string {
    if idx == 0 { return "Si lattice constant (A)" }
    if idx == 1 { return "Si bandgap (eV)" }
    if idx == 2 { return "Si atomic number" }
    if idx == 3 { return "Si density (g/cm3)" }
    if idx == 4 { return "Gate oxide thickness (nm)" }
    if idx == 5 { return "MOSFET threshold (V)" }
    if idx == 6 { return "kT at 300K (eV)" }
    if idx == 7 { return "Electron mobility Si (cm2/Vs)" }
    if idx == 8 { return "Transistor scaling factor" }
    if idx == 9 { return "Process node 7nm (nm)" }
    if idx == 10 { return "Process node 5nm (nm)" }
    if idx == 11 { return "Process node 3nm (nm)" }
    if idx == 12 { return "Process node 2nm (nm)" }
    if idx == 13 { return "Si electrons per shell [2,8,4]" }
    if idx == 14 { return "Ge atomic number" }
    if idx == 15 { return "GaAs bandgap (eV)" }
    return ""
}

fn semi_val(idx: i64) -> f64 {
    if idx == 0 { return 5.431 }      // Si lattice constant
    if idx == 1 { return 1.12 }       // Si bandgap
    if idx == 2 { return 14.0 }       // Si Z = sigma+phi
    if idx == 3 { return 2.329 }      // Si density
    if idx == 4 { return 1.2 }        // gate oxide
    if idx == 5 { return 0.5 }        // MOSFET Vt
    if idx == 6 { return 0.02585 }    // kT @ 300K
    if idx == 7 { return 1400.0 }     // e- mobility
    if idx == 8 { return 2.0 }        // transistor 2x scaling
    if idx == 9 { return 7.0 }        // 7nm node
    if idx == 10 { return 5.0 }       // 5nm node
    if idx == 11 { return 3.0 }       // 3nm node
    if idx == 12 { return 2.0 }       // 2nm node
    if idx == 13 { return 4.0 }       // Si outer shell electrons
    if idx == 14 { return 32.0 }      // Ge Z = phi^sopfr
    if idx == 15 { return 1.42 }      // GaAs bandgap
    return 0.0
}

fn semi_note(idx: i64) -> string {
    if idx == 0 { return "~sopfr(6)=5" }
    if idx == 1 { return "~n*sigma/(n*sigma-tau)" }
    if idx == 2 { return "=sigma+phi EXACT" }
    if idx == 3 { return "~sigma/sopfr=2.4" }
    if idx == 4 { return "=n/sopfr EXACT" }
    if idx == 5 { return "=n/sigma EXACT" }
    if idx == 6 { return "~n/(J2*sopfr*phi)" }
    if idx == 7 { return "nonresonant" }
    if idx == 8 { return "=phi EXACT" }
    if idx == 9 { return "=sigma-sopfr EXACT" }
    if idx == 10 { return "=sopfr EXACT" }
    if idx == 11 { return "=n/phi EXACT" }
    if idx == 12 { return "=phi EXACT" }
    if idx == 13 { return "=tau EXACT" }
    if idx == 14 { return "=phi^sopfr EXACT" }
    if idx == 15 { return "~sqrt(phi)" }
    return ""
}

fn semi_count() -> i64 { return 16 }

