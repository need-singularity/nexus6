// mk2_hexa/native/statistics.hexa — Statistical verification engine
// Rust 원본: src/statistics/ (significance.rs, effect_size.rs, reproducibility.rs)
// 실행: hexa statistics.hexa verify|ttest|effect_val|reproduce|fdr <values...>
//
// CLI:
//   hexa statistics.hexa verify <v1> <v2> ...                  — 종합 검증 (p-value, CI, reproducibility)
//   hexa statistics.hexa ttest <v1,v2,...> <v1,v2,...>          — Welch's t-test (두 그룹)
//   hexa statistics.hexa effect_val <v1,v2,...> <v1,v2,...>         — Cohen's d 효과 크기
//   hexa statistics.hexa reproduce <v1> <v2> ... [--threshold T] — 재현성 검증
//   hexa statistics.hexa fdr <p1> <p2> ... [--alpha A]         — Benjamini-Hochberg FDR

// ─── comptime 상수 ───
comptime const default_alpha = 0.05
comptime const default_cv_threshold = 0.10
comptime const n6_score_perfect = 1.0

// ─── n=6 constants loader (shared/n6_constants.jsonl) ───

fn load_n6_consts() -> list {
    let home = exec("printenv HOME")
    let path = home + "/Dev/nexus6/shared/n6_constants.jsonl"
    let raw = try { read_file(path) } catch e { return [[], []] }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let trimmed = line.trim()
        if trimmed == "" { continue }
        let mut name = ""
        let mut value = 0.0
        if trimmed.contains("\"name\":\"") {
            let p = trimmed.split("\"name\":\"")
            if p.len() >= 2 { name = p[1].split("\"")[0] }
        }
        if trimmed.contains("\"value\":") {
            let p = trimmed.split("\"value\":")
            if p.len() >= 2 {
                let num_str = p[1].split(",")[0].split("}")[0].trim()
                value = to_float(num_str)
            }
        }
        if name != "" {
            names = names + [name]
            values = values + [value]
        }
    }
    [names, values]
}

fn n6_values(consts: list) -> list {
    consts[1]
}

// ─── math helpers ───

fn abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    x
}

fn sqrt(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut guess = x / 2.0
    if guess < 0.001 { guess = 0.001 }
    let mut i = 0
    while i < 20 {
        guess = (guess + x / guess) / 2.0
        i = i + 1
    }
    guess
}

fn clamp(x: float, lo: float, hi: float) -> float {
    if x < lo { return lo }
    if x > hi { return hi }
    x
}

fn min_f(a: float, b: float) -> float {
    if a < b { a } else { b }
}

fn max_f(a: float, b: float) -> float {
    if a > b { a } else { b }
}

fn min_i(a: int, b: int) -> int {
    if a < b { a } else { b }
}

fn max_i(a: int, b: int) -> int {
    if a > b { a } else { b }
}

fn floor(x: float) -> float {
    to_float(to_int(x))
}

fn exp_approx(x: float) -> float {
    // e^x via Taylor series (|x| < 20 range)
    let mut v = x
    if v > 20.0 { return 485165195.0 }
    if v < -20.0 { return 0.0 }
    // use identity e^x = (e^(x/k))^k for large x
    let mut k = 1
    while abs(v) > 1.0 {
        v = v / 2.0
        k = k * 2
    }
    // Taylor for e^v where |v| <= 1
    let mut sum = 1.0
    let mut term = 1.0
    let mut n = 1
    while n <= 15 {
        term = term * v / to_float(n)
        sum = sum + term
        n = n + 1
    }
    // raise to power k
    let mut result = sum
    let mut p = 0
    while p < k / 2 {
        result = result * result
        p = p + 1
    }
    // adjust for odd k
    if k % 2 == 1 { result = result * sum }
    // simpler approach: just square log2(k) times
    result = sum
    let mut remaining = k
    while remaining > 1 {
        result = result * result
        remaining = remaining / 2
    }
    result
}

// ─── Core statistics ───

fn mean(data) -> float {
    let n = len(data)
    if n == 0 { return 0.0 }
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + data[i]
        i = i + 1
    }
    sum / to_float(n)
}

fn variance(data, mean_val: float) -> float {
    let n = len(data)
    if n < 2 { return 0.0 }
    let mut ss = 0.0
    let mut i = 0
    while i < n {
        let d = data[i] - mean_val
        ss = ss + d * d
        i = i + 1
    }
    ss / (to_float(n) - 1.0)
}

fn std_dev(data) -> float {
    let m = mean(data)
    sqrt(variance(data, m))
}

// ─── Standard normal CDF (Abramowitz & Stegun 7.1.26) ───

fn standard_normal_cdf(x: float) -> float {
    if x < -8.0 { return 0.0 }
    if x > 8.0 { return 1.0 }

    let t = 1.0 / (1.0 + 0.2316419 * abs(x))
    let d = 0.3989422804014327
    let p = d * exp_approx(0.0 - x * x / 2.0)
    let c = t * (0.319381530 + t * (0.0 - 0.356563782 + t * (1.781477937 + t * (0.0 - 1.821255978 + t * 1.330274429))))

    if x >= 0.0 {
        1.0 - p * c
    } else {
        p * c
    }
}

// ─── Significance testing (Welch's t-test) ───

struct SignificanceResult {
    p_value: float,
    corrected_p: float,
    significant: bool,
    method: string,
    t_stat: float
}

fn test_significance(observed, expected) -> SignificanceResult {
    if len(observed) == 0 {
        return SignificanceResult {
            p_value: 1.0,
            corrected_p: 1.0,
            significant: false,
            method: "t-test (insufficient data)",
            t_stat: 0.0
        }
    }
    if len(expected) == 0 {
        return SignificanceResult {
            p_value: 1.0,
            corrected_p: 1.0,
            significant: false,
            method: "t-test (insufficient data)",
            t_stat: 0.0
        }
    }

    let n1 = to_float(len(observed))
    let n2 = to_float(len(expected))
    let mean1 = mean(observed)
    let mean2 = mean(expected)
    let var1 = variance(observed, mean1)
    let var2 = variance(expected, mean2)

    let se = sqrt(var1 / n1 + var2 / n2)
    let t_stat = if se > 0.000000000000001 { (mean1 - mean2) / se } else { 0.0 }

    let p_value = 2.0 * standard_normal_cdf(0.0 - abs(t_stat))

    SignificanceResult {
        p_value: p_value,
        corrected_p: p_value,
        significant: p_value < 0.05,
        method: "Welch's t-test (normal approx)",
        t_stat: t_stat
    }
}

// ─── Bonferroni correction ───

fn bonferroni_correction(p_values) {
    let m = to_float(len(p_values))
    let mut result = []
    let mut i = 0
    while i < len(p_values) {
        let corrected = min_f(p_values[i] * m, 1.0)
        let result = result.push(corrected)
        i = i + 1
    }
    result
}

// ─── Benjamini-Hochberg FDR ───

fn false_discovery_rate(p_values, alpha: float) {
    let m = len(p_values)
    if m == 0 { return [] }

    // build indexed pairs and sort by p-value
    let mut indexed = []
    let mut i = 0
    while i < m {
        let indexed = indexed.push([to_float(i), p_values[i]])
        i = i + 1
    }
    // bubble sort by p-value ascending
    let mut pass = 0
    while pass < m {
        let mut q = 0
        while q < m - 1 {
            if indexed[q][1] > indexed[q + 1][1] {
                let tmp = indexed[q]
                let indexed = indexed.set(q, indexed[q + 1])
                let indexed = indexed.set(q + 1, tmp)
            }
            q = q + 1
        }
        pass = pass + 1
    }

    // find largest k where P_(k) <= k/m * alpha
    let mut max_k = 0
    let mut rank = 0
    while rank < m {
        let threshold = to_float(rank + 1) / to_float(m) * alpha
        if indexed[rank][1] <= threshold {
            max_k = rank + 1
        }
        rank = rank + 1
    }

    // build rejected mask
    let mut rejected = []
    let mut ri = 0
    while ri < m {
        let rejected = rejected.push(false)
        ri = ri + 1
    }
    let mut k = 0
    while k < max_k {
        let orig_idx = to_int(indexed[k][0])
        let rejected = rejected.set(orig_idx, true)
        k = k + 1
    }
    rejected
}

// ─── Cohen's d effect_val size ───

fn cohens_d(group1, group2) -> float {
    if len(group1) < 2 { return 0.0 }
    if len(group2) < 2 { return 0.0 }

    let mean1 = mean(group1)
    let mean2 = mean(group2)
    let var1 = variance(group1, mean1)
    let var2 = variance(group2, mean2)
    let n1 = to_float(len(group1))
    let n2 = to_float(len(group2))

    let pooled_var = ((n1 - 1.0) * var1 + (n2 - 1.0) * var2) / (n1 + n2 - 2.0)
    let pooled_std = sqrt(pooled_var)

    if pooled_std < 0.000000000000001 { return 0.0 }
    (mean1 - mean2) / pooled_std
}

fn classify_effect(d: float) -> string {
    let abs_d = abs(d)
    if abs_d < 0.2 { return "negligible" }
    if abs_d < 0.5 { return "small" }
    if abs_d < 0.8 { return "medium" }
    "large"
}

// ─── Error function (Abramowitz & Stegun 7.1.28) ───

fn erf_approx(x: float) -> float {
    let a1 = 0.254829592
    let a2 = 0.0 - 0.284496736
    let a3 = 1.421413741
    let a4 = 0.0 - 1.453152027
    let a5 = 1.061405429
    let p = 0.3275911

    let sign = if x < 0.0 { 0.0 - 1.0 } else { 1.0 }
    let ax = abs(x)
    let t = 1.0 / (1.0 + p * ax)
    let y = 1.0 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * exp_approx(0.0 - ax * ax)
    sign * y
}

fn common_language_effect(d: float) -> float {
    let z = d / 1.41421356  // sqrt(2)
    0.5 * (1.0 + erf_approx(z / 1.41421356))
}

// ─── Reproducibility assessment ───

struct ReproReport {
    n_results: int,
    mean: float,
    std: float,
    cv: float,
    is_reproducible: bool,
    consistency_score: float,
    outlier_count: int
}

fn detect_outliers_iqr(data) {
    // returns count of outliers using 1.5*IQR
    let n = len(data)
    if n < 4 { return 0 }

    let mut sorted = []
    let mut si = 0
    while si < n {
        let sorted = sorted.push(data[si])
        si = si + 1
    }
    // bubble sort
    let mut pass = 0
    while pass < n {
        let mut q = 0
        while q < n - 1 {
            if sorted[q] > sorted[q + 1] {
                let tmp = sorted[q]
                let sorted = sorted.set(q, sorted[q + 1])
                let sorted = sorted.set(q + 1, tmp)
            }
            q = q + 1
        }
        pass = pass + 1
    }

    let q1 = sorted[n / 4]
    let q3 = sorted[3 * n / 4]
    let iqr = q3 - q1
    let lower = q1 - 1.5 * iqr
    let upper = q3 + 1.5 * iqr

    let mut count = 0
    let mut i = 0
    while i < n {
        if data[i] < lower { count = count + 1 }
        if data[i] > upper { count = count + 1 }
        i = i + 1
    }
    count
}

fn assess_reproducibility(results, cv_threshold: float) -> ReproReport {
    let n = len(results)
    if n == 0 {
        return ReproReport {
            n_results: 0,
            mean: 0.0,
            std: 0.0,
            cv: 999999.0,
            is_reproducible: false,
            consistency_score: 0.0,
            outlier_count: 0
        }
    }

    let m = mean(results)
    let s = std_dev(results)
    let cv = if abs(m) > 0.000000000000001 { s / abs(m) } else { 999999.0 }

    let outlier_count = detect_outliers_iqr(results)
    let consistency_score = clamp(1.0 - cv / cv_threshold, 0.0, 1.0)

    let is_reproducible = if cv < cv_threshold {
        if outlier_count == 0 { true } else { false }
    } else {
        false
    }

    ReproReport {
        n_results: n,
        mean: m,
        std: s,
        cv: cv,
        is_reproducible: is_reproducible,
        consistency_score: consistency_score,
        outlier_count: outlier_count
    }
}

// ─── n=6 consistency check ───

fn n6_consistency(exact_ratios) -> float {
    if len(exact_ratios) == 0 { return 0.0 }
    let m = mean(exact_ratios)
    let s = std_dev(exact_ratios)
    let cv = if abs(m) > 0.000000000000001 { s / abs(m) } else { 1.0 }
    max_f(m * (1.0 - min_f(cv, 1.0)), 0.0)
}

// ─── Confidence interval ───

fn confidence_interval_95(data) {
    // returns [lower, upper] for 95% CI
    let n = len(data)
    if n < 2 { return [0.0, 0.0] }
    let m = mean(data)
    let s = std_dev(data)
    let se = s / sqrt(to_float(n))
    let z = 1.96  // 95% CI z-score
    [m - z * se, m + z * se]
}

// ─── Parse comma-separated values ───

fn parse_csv(s: string) {
    // parse "1.0,2.0,3.0" -> [1.0, 2.0, 3.0]
    let mut values = []
    let mut current = ""
    let mut i = 0
    while i < len(s) {
        let ch = char_at(s, i)
        if ch == 44 {  // comma
            try {
                let v = to_float(current)
                let values = values.push(v)
            } catch e {
                // skip invalid
            }
            current = ""
        } else {
            current = current + from_char(ch)
        }
        i = i + 1
    }
    // last element
    if len(current) > 0 {
        try {
            let v = to_float(current)
            let values = values.push(v)
        } catch e {
            // skip
        }
    }
    values
}

// ─── CLI ───

fn main() {
    let a = args()
    let argc = len(a)

    if argc < 2 {
        println("Usage:")
        println("  hexa statistics.hexa verify <v1> <v2> ...")
        println("  hexa statistics.hexa ttest <v1,v2,...> <v1,v2,...>")
        println("  hexa statistics.hexa effect_val <v1,v2,...> <v1,v2,...>")
        println("  hexa statistics.hexa reproduce <v1> <v2> ... [--threshold T]")
        println("  hexa statistics.hexa fdr <p1> <p2> ... [--alpha A]")
        return 0
    }

    let cmd = a[1]

    if cmd == "verify" {
        if argc < 3 {
            println("Usage: hexa statistics.hexa verify <v1> <v2> ...")
            return 1
        }

        // collect all numeric args
        let mut values = []
        let mut i = 2
        while i < argc {
            try {
                let v = to_float(a[i])
                let values = values.push(v)
            } catch e {
                // skip non-numeric
            }
            i = i + 1
        }

        let n = len(values)
        if n < 2 {
            println("ERROR: need at least 2 values")
            return 1
        }

        println("=== Statistical Verification (" + to_string(n) + " values) ===")
        println("")

        // Basic stats
        let m = mean(values)
        let s = std_dev(values)
        let ci = confidence_interval_95(values)
        println("[1] Descriptive Statistics")
        println("  N: " + to_string(n))
        println("  Mean: " + to_string(m))
        println("  Std: " + to_string(s))
        println("  95% CI: [" + to_string(ci[0]) + ", " + to_string(ci[1]) + "]")
        println("")

        // Significance: test against expected = n=6 constant nearest to mean
        let _n6_data = load_n6_consts()
        let n6_consts = n6_values(_n6_data)
        let mut nearest = 6.0
        let mut nearest_dist = 999999.0
        let mut ni = 0
        while ni < len(n6_consts) {
            let d = abs(m - n6_consts[ni])
            if d < nearest_dist {
                nearest_dist = d
                nearest = n6_consts[ni]
            }
            ni = ni + 1
        }

        let mut expected = []
        let mut ei = 0
        while ei < n {
            let expected = expected.push(nearest)
            ei = ei + 1
        }
        let sig = test_significance(values, expected)

        println("[2] Significance Test (vs n=6 constant " + to_string(nearest) + ")")
        println("  Method: " + sig.method)
        println("  t-statistic: " + to_string(sig.t_stat))
        println("  p-value: " + to_string(sig.p_value))
        println("  Significant (p<0.05): " + to_string(sig.significant))
        println("")

        // Reproducibility
        let repro = assess_reproducibility(values, 0.10)
        println("[3] Reproducibility")
        println("  CV: " + to_string(repro.cv))
        println("  Consistency score: " + to_string(repro.consistency_score))
        println("  Reproducible (CV<10%): " + to_string(repro.is_reproducible))
        println("  Outliers (IQR): " + to_string(repro.outlier_count))
        println("")

        // n6 alignment
        let n6_score = 1.0 / (1.0 + nearest_dist)
        println("[4] n=6 Alignment")
        println("  Nearest n=6 constant: " + to_string(nearest))
        println("  Distance: " + to_string(nearest_dist))
        println("  n6_score: " + to_string(n6_score))
        println("")

        // Verdict
        let verdict = if repro.is_reproducible {
            if n6_score > 0.8 { "STRONG n=6 alignment, reproducible" }
            else if n6_score > 0.5 { "Moderate n=6 alignment, reproducible" }
            else { "Weak n=6 alignment, but reproducible" }
        } else {
            "NOT reproducible (CV=" + to_string(repro.cv) + ")"
        }
        println("VERDICT: " + verdict)
        return 0
    }

    if cmd == "ttest" {
        if argc < 4 {
            println("Usage: hexa statistics.hexa ttest <v1,v2,...> <v1,v2,...>")
            return 1
        }
        let group1 = parse_csv(a[2])
        let group2 = parse_csv(a[3])

        if len(group1) == 0 {
            println("ERROR: group1 is empty")
            return 1
        }
        if len(group2) == 0 {
            println("ERROR: group2 is empty")
            return 1
        }

        let result = test_significance(group1, group2)
        println("=== Welch's t-test ===")
        println("  Group 1: n=" + to_string(len(group1)) + " mean=" + to_string(mean(group1)))
        println("  Group 2: n=" + to_string(len(group2)) + " mean=" + to_string(mean(group2)))
        println("  t-statistic: " + to_string(result.t_stat))
        println("  p-value: " + to_string(result.p_value))
        println("  Significant (p<0.05): " + to_string(result.significant))
        return 0
    }

    if cmd == "effect_val" {
        if argc < 4 {
            println("Usage: hexa statistics.hexa effect_val <v1,v2,...> <v1,v2,...>")
            return 1
        }
        let group1 = parse_csv(a[2])
        let group2 = parse_csv(a[3])

        let d = cohens_d(group1, group2)
        let classification = classify_effect(d)
        let cles = common_language_effect(d)

        println("=== Effect Size ===")
        println("  Cohen's d: " + to_string(d))
        println("  Classification: " + classification)
        println("  CLES (Common Language): " + to_string(cles))
        return 0
    }

    if cmd == "reproduce" {
        if argc < 3 {
            println("Usage: hexa statistics.hexa reproduce <v1> <v2> ... [--threshold T]")
            return 1
        }

        let mut values = []
        let mut threshold = 0.10
        let mut i = 2
        while i < argc {
            if a[i] == "--threshold" {
                if i + 1 < argc {
                    try { threshold = to_float(a[i + 1]) } catch e { }
                    i = i + 2
                } else {
                    i = i + 1
                }
            } else {
                try {
                    let v = to_float(a[i])
                    let values = values.push(v)
                } catch e { }
                i = i + 1
            }
        }

        if len(values) < 2 {
            println("ERROR: need at least 2 values")
            return 1
        }

        let report = assess_reproducibility(values, threshold)

        println("=== Reproducibility Assessment ===")
        println("  N: " + to_string(report.n_results))
        println("  Mean: " + to_string(report.mean))
        println("  Std: " + to_string(report.std))
        println("  CV: " + to_string(report.cv))
        println("  Threshold: " + to_string(threshold))
        println("  Consistency score: " + to_string(report.consistency_score))
        println("  Reproducible: " + to_string(report.is_reproducible))
        println("  Outliers (IQR): " + to_string(report.outlier_count))
        return 0
    }

    if cmd == "fdr" {
        if argc < 3 {
            println("Usage: hexa statistics.hexa fdr <p1> <p2> ... [--alpha A]")
            return 1
        }

        let mut p_values = []
        let mut alpha = 0.05
        let mut i = 2
        while i < argc {
            if a[i] == "--alpha" {
                if i + 1 < argc {
                    try { alpha = to_float(a[i + 1]) } catch e { }
                    i = i + 2
                } else {
                    i = i + 1
                }
            } else {
                try {
                    let v = to_float(a[i])
                    let p_values = p_values.push(v)
                } catch e { }
                i = i + 1
            }
        }

        if len(p_values) == 0 {
            println("ERROR: need at least 1 p-value")
            return 1
        }

        // Bonferroni
        let bonf = bonferroni_correction(p_values)

        // BH-FDR
        let rejected = false_discovery_rate(p_values, alpha)

        println("=== Multiple Testing Correction (alpha=" + to_string(alpha) + ") ===")
        println("")
        println("  Bonferroni correction:")
        let mut bi = 0
        while bi < len(p_values) {
            let sig = if bonf[bi] < alpha { " *" } else { "" }
            println("    p[" + to_string(bi) + "] = " + to_string(p_values[bi]) + " -> corrected = " + to_string(bonf[bi]) + sig)
            bi = bi + 1
        }
        println("")
        println("  Benjamini-Hochberg FDR:")
        let mut fi = 0
        let mut rejected_count = 0
        while fi < len(p_values) {
            let status = if rejected[fi] { "REJECTED" } else { "retained" }
            if rejected[fi] { rejected_count = rejected_count + 1 }
            println("    p[" + to_string(fi) + "] = " + to_string(p_values[fi]) + " -> " + status)
            fi = fi + 1
        }
        println("")
        println("  Rejected hypotheses: " + to_string(rejected_count) + " / " + to_string(len(p_values)))
        return 0
    }

    println("Unknown command: " + cmd)
    println("Commands: verify, ttest, effect_val, reproduce, fdr")
    1
}

main()
