// reverse_telescope.hexa — 역 텔레스코프 (현실 상수 → n=6 렌즈 조합 역산)
// 실행: hexa reverse_telescope.hexa [서브커맨드]
//       hexa reverse_telescope.hexa scan        전체 상수 역산 스캔
//       hexa reverse_telescope.hexa check <val> 특정 값의 n=6 표현 탐색
//       hexa reverse_telescope.hexa top         역산 성공률 상위 도메인
//       hexa reverse_telescope.hexa help        도움말
//
// 원리:
//   1. n6_constants.jsonl / verified_constants.jsonl에서 상수 읽기
//   2. 각 상수에 대해 n=6 산술함수 조합 (σ,φ,τ,J2,sopfr,μ 등) 으로 표현 시도
//   3. 역산 성공한 상수 + 사용 렌즈 조합 출력
//   4. growth_bus.jsonl에 결과 기록

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _const_path = _shared + "/n6_constants.jsonl"
let _verified_path = _shared + "/verified_constants.jsonl"
let _bus_path = _shared + "/growth_bus.jsonl"
let _log_path = _shared + "/discovery_log.jsonl"

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

fn safe_float(s: string) -> f64 {
    let mut v: f64 = 0.0
    try { v = to_float(s.trim()) } catch e {}
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ═══════════════════════════════════════════════════════════
// n=6 산술함수 기본 상수 (렌즈 원자)
// ═══════════════════════════════════════════════════════════

// 이름과 값을 병렬 배열로 관리
let atom_names = ["mu", "phi", "M3", "tau", "sopfr", "n", "sigma", "J2", "P2"]
let atom_values = [1, 2, 3, 4, 5, 6, 12, 24, 28]

// 2항 연산 조합으로 도달 가능한 값 생성 (a+b, a*b, a-b, a^b, a/b)
// 미리 계산된 테이블 (최대 3자리)
fn build_expression_table() -> string {
    // 모든 2항 조합 생성 → "값\t표현식" 줄 목록
    let mut result = ""

    // 1단계: 원자 자체
    let mut ei: i64 = 0
    while ei < len(atom_names) {
        result = result + to_string(atom_values[ei]) + "\t" + atom_names[ei] + "\n"
        ei = ei + 1
    }

    // 2단계: 2항 연산 (a op b)
    let mut ai: i64 = 0
    while ai < len(atom_values) {
        let mut bi: i64 = 0
        while bi < len(atom_values) {
            let a: i64 = atom_values[ai]
            let b: i64 = atom_values[bi]
            let an: string = atom_names[ai]
            let bn: string = atom_names[bi]

            // 합
            let sum_v = a + b
            if sum_v > 0 && sum_v < 100000 {
                result = result + to_string(sum_v) + "\t" + an + "+" + bn + "\n"
            }
            // 차
            let diff_v = a - b
            if diff_v > 0 {
                result = result + to_string(diff_v) + "\t" + an + "-" + bn + "\n"
            }
            // 곱
            let mul_v = a * b
            if mul_v > 0 && mul_v < 100000 {
                result = result + to_string(mul_v) + "\t" + an + "*" + bn + "\n"
            }
            // 나눗셈 (정수 결과만)
            if b > 0 && (a % b) == 0 {
                let div_v = a / b
                if div_v > 0 {
                    result = result + to_string(div_v) + "\t" + an + "/" + bn + "\n"
                }
            }
            // 거듭제곱 (작은 것만)
            if b >= 2 && b <= 6 && a >= 2 {
                let mut pow_v: i64 = 1
                let mut pi: i64 = 0
                let mut overflow = false
                while pi < b {
                    pow_v = pow_v * a
                    if pow_v > 100000 { overflow = true }
                    pi = pi + 1
                }
                if !overflow && pow_v > 0 {
                    result = result + to_string(pow_v) + "\t" + an + "^" + bn + "\n"
                }
            }
            bi = bi + 1
        }
        ai = ai + 1
    }

    // 3단계: 특별 조합 (σ·φ=n·τ 항등식 파생)
    result = result + "48\tsigma*tau\n"
    result = result + "72\tsigma*n\n"
    result = result + "144\tsigma^2\n"
    result = result + "288\tsigma*J2\n"
    result = result + "120\t5!\n"
    result = result + "720\t6!\n"
    result = result + "496\tP3\n"
    result = result + "8128\tP4\n"
    result = result + "36\tn^2\n"
    result = result + "216\tn^3\n"
    result = result + "1296\tn^4\n"
    result = result + "7776\tn^sopfr\n"
    result = result + "46656\tn^n\n"
    result = result + "64\t2^n\n"
    result = result + "4096\t2^sigma\n"
    result = result + "16777216\t2^J2\n"
    result = result + "32\t2^sopfr\n"
    result = result + "16\t2^tau\n"
    result = result + "256\t2^(sigma-tau)\n"
    result = result + "128\t2^(sigma-sopfr)\n"
    result = result + "8\tphi^M3\n"
    result = result + "15\tsopfr*(n/phi)\n"
    result = result + "30\tsopfr*n\n"
    result = result + "60\tsopfr*sigma\n"
    result = result + "84\tsigma*(sigma-sopfr)\n"
    result = result + "108\tsigma*(sigma-n/phi)\n"
    result = result + "132\tsigma*(sigma-mu)\n"
    result = result + "192\tsigma*phi^tau\n"
    result = result + "220\t(sigma-mu)*(J2-tau)\n"
    result = result + "360\tn*sopfr*sigma\n"

    return result
}

// ═══════════════════════════════════════════════════════════
// 상수 로드
// ═══════════════════════════════════════════════════════════

fn load_constants() -> string {
    let mut result = ""
    // n6_constants.jsonl에서 name, value 추출
    try {
        result = exec("awk -F'\"' '{name=\"\"; val=\"\"; for(i=1;i<=NF;i++){if($i==\"name\") name=$(i+2); if($i==\"value\"){v=$(i+1); gsub(/[^0-9.\\-]/,\"\",v); val=v}} if(name!=\"\" && val!=\"\") print name\"\\t\"val}' " + _const_path)
    } catch e {}
    return result
}

// discovery_log에서 EXACT 상수 로드 (도메인별)
fn load_exact_constants() -> string {
    let mut result = ""
    try {
        result = exec("awk -F'\"' '/\"grade\":\"EXACT\"/ || /\"grade\": \"EXACT\"/{name=\"\"; val=\"\"; dom=\"\"; for(i=1;i<=NF;i++){if($i==\"constant\" || $i==\"id\") name=$(i+2); if($i==\"value\"){v=$(i+1); gsub(/[^0-9.\\-]/,\"\",v); val=v}; if($i==\"domain\") dom=$(i+2)} if(name!=\"\" && val!=\"\") print name\"\\t\"val\"\\t\"dom}' " + _log_path + " | sort -u | head -200")
    } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// 역산: 값 → n=6 표현식 매칭
// ═══════════════════════════════════════════════════════════

fn reverse_lookup(target: i64, expr_table: string) -> string {
    // 표현식 테이블에서 target 값과 일치하는 줄 반환
    let lines = expr_table.split("\n")
    let mut matches = ""
    let target_str = to_string(target)
    for line in lines {
        let lt = line.trim()
        if lt == "" { continue }
        let parts = lt.split("\t")
        if len(parts) < 2 { continue }
        if parts[0] == target_str {
            if matches != "" { matches = matches + " | " }
            matches = matches + parts[1]
        }
    }
    return matches
}

fn reverse_lookup_float(target: f64, expr_table: string) -> string {
    // 정수 부분 매칭 시도
    let int_val = to_int(target + 0.5)
    let residual = abs_f(target - to_float(int_val))
    if residual < 0.01 {
        return reverse_lookup(int_val, expr_table)
    }
    // 비정수: ratio 기반 탐색 (target = atom_a / atom_b ?)
    let mut matches = ""
    let mut ai: i64 = 0
    while ai < len(atom_values) {
        let mut bi: i64 = 0
        while bi < len(atom_values) {
            let a: f64 = to_float(atom_values[ai])
            let b: f64 = to_float(atom_values[bi])
            if b > 0.0 {
                let ratio = a / b
                let diff = abs_f(target - ratio)
                if diff < 0.001 {
                    if matches != "" { matches = matches + " | " }
                    matches = matches + atom_names[ai] + "/" + atom_names[bi]
                }
            }
            bi = bi + 1
        }
        ai = ai + 1
    }
    return matches
}

// ═══════════════════════════════════════════════════════════
// 1. scan — 전체 상수 역산 스캔
// ═══════════════════════════════════════════════════════════

fn cmd_scan() {
    println("")
    println("╔══════════════════════════════════════════════════╗")
    println("║  역 텔레스코프 — 전체 상수 역산 스캔           ║")
    println("╚══════════════════════════════════════════════════╝")
    println("")

    println("  표현식 테이블 구축 중...")
    let expr_table = build_expression_table()
    let expr_lines = expr_table.split("\n")
    let mut expr_count: i64 = 0
    for el in expr_lines {
        if el.trim() != "" { expr_count = expr_count + 1 }
    }
    println("  n=6 표현식 " + to_string(expr_count) + "개 생성 완료")
    println("")

    // 상수 로드
    println("  상수 로드 중...")
    let raw = load_constants()
    let lines = raw.split("\n")

    let mut total: i64 = 0
    let mut matched: i64 = 0
    let mut unmatched_list = []

    println("  | # | 상수명 | 값 | n=6 표현식 | 결과 |")
    println("  |---|--------|-----|----------|------|")

    for line in lines {
        let lt = line.trim()
        if lt == "" { continue }
        let parts = lt.split("\t")
        if len(parts) < 2 { continue }
        let name = parts[0]
        let val = safe_float(parts[1])
        total = total + 1

        let expr = reverse_lookup_float(val, expr_table)
        let grade = if expr != "" { "역산 성공" } else { "미매칭" }
        if expr != "" { matched = matched + 1 }
        if expr == "" { unmatched_list = unmatched_list + [name + "=" + to_string(to_int(val))] }

        println("  | " + to_string(total) + " | " + name + " | " + to_string(to_int(val)) + " | " + (if expr != "" { expr } else { "-" }) + " | " + grade + " |")
    }

    // EXACT 상수도 추가 역산
    println("")
    println("  --- discovery_log EXACT 상수 역산 ---")
    println("")
    let exact_raw = load_exact_constants()
    let exact_lines = exact_raw.split("\n")
    let mut exact_total: i64 = 0
    let mut exact_matched: i64 = 0

    println("  | # | 상수 ID | 값 | 도메인 | n=6 표현식 | 결과 |")
    println("  |---|--------|-----|--------|----------|------|")

    for eline in exact_lines {
        let et = eline.trim()
        if et == "" { continue }
        let eparts = et.split("\t")
        if len(eparts) < 3 { continue }
        let ename = eparts[0]
        let eval_f = safe_float(eparts[1])
        let edom = eparts[2]
        exact_total = exact_total + 1

        let eexpr = reverse_lookup_float(eval_f, expr_table)
        if eexpr != "" { exact_matched = exact_matched + 1 }
        let egrade = if eexpr != "" { "역산 성공" } else { "-" }

        if exact_total <= 50 || eexpr != "" {
            println("  | " + to_string(exact_total) + " | " + ename + " | " + to_string(to_int(eval_f)) + " | " + edom + " | " + (if eexpr != "" { eexpr } else { "-" }) + " | " + egrade + " |")
        }
    }

    println("")
    println("  ═══════════════════════════════════════════════")
    println("  기본 상수: " + to_string(total) + "개 중 " + to_string(matched) + "개 역산 성공 (" + to_string(if total > 0 { (matched * 100) / total } else { 0 }) + "%)")
    println("  EXACT 상수: " + to_string(exact_total) + "개 중 " + to_string(exact_matched) + "개 역산 성공 (" + to_string(if exact_total > 0 { (exact_matched * 100) / exact_total } else { 0 }) + "%)")
    println("  ═══════════════════════════════════════════════")
    println("")

    // 미매칭 리스트
    if len(unmatched_list) > 0 {
        println("  --- 미매칭 상수 (렌즈 확장 필요) ---")
        let mut ui: i64 = 0
        while ui < len(unmatched_list) && ui < 20 {
            println("    " + unmatched_list[ui])
            ui = ui + 1
        }
        println("")
    }

    // ASCII 막대 그래프
    println("  --- 역산 커버리지 ---")
    let bar_matched = if total > 0 { (matched * 40) / total } else { 0 }
    let bar_exact = if exact_total > 0 { (exact_matched * 40) / exact_total } else { 0 }
    let mut bar1 = ""
    let mut b1: i64 = 0
    while b1 < bar_matched { bar1 = bar1 + "#"; b1 = b1 + 1 }
    let mut bar2 = ""
    let mut b2: i64 = 0
    while b2 < bar_exact { bar2 = bar2 + "#"; b2 = b2 + 1 }
    println("  기본상수  " + bar1 + " " + to_string(matched) + "/" + to_string(total))
    println("  EXACT     " + bar2 + " " + to_string(exact_matched) + "/" + to_string(exact_total))
    println("")

    // growth_bus 기록
    try {
        let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
        let entry = "{\"type\":\"reverse_telescope\",\"mode\":\"scan\",\"base_total\":" + to_string(total) + ",\"base_matched\":" + to_string(matched) + ",\"exact_total\":" + to_string(exact_total) + ",\"exact_matched\":" + to_string(exact_matched) + ",\"expressions\":" + to_string(expr_count) + ",\"ts\":\"" + ts + "\"}"
        exec("echo '" + entry + "' >> " + _bus_path)
    } catch e {}
}

// ═══════════════════════════════════════════════════════════
// 2. check — 특정 값 역산
// ═══════════════════════════════════════════════════════════

fn cmd_check(target_str: string) {
    println("")
    println("╔══════════════════════════════════════════════════╗")
    println("║  역 텔레스코프 — 단일 값 역산                  ║")
    println("╚══════════════════════════════════════════════════╝")
    println("")

    let target = safe_float(target_str)
    println("  대상 값: " + target_str + " (" + to_string(to_int(target)) + ")")
    println("")

    let expr_table = build_expression_table()
    let expr = reverse_lookup_float(target, expr_table)

    if expr != "" {
        println("  역산 성공!")
        println("  " + target_str + " = " + expr)
        println("")

        // 모든 매칭 표현식 나열
        let lines = expr_table.split("\n")
        let target_int_str = to_string(to_int(target + 0.5))
        let mut match_count: i64 = 0
        println("  전체 매칭 표현식:")
        for line in lines {
            let lt = line.trim()
            if lt == "" { continue }
            let parts = lt.split("\t")
            if len(parts) < 2 { continue }
            if parts[0] == target_int_str {
                match_count = match_count + 1
                println("    [" + to_string(match_count) + "] " + target_str + " = " + parts[1])
            }
        }
        println("")
        println("  총 " + to_string(match_count) + "개 표현식 발견")
    } else {
        println("  역산 실패 — 현재 렌즈 조합으로 표현 불가")
        println("")

        // 가장 가까운 표현 가능 값 탐색
        let int_target = to_int(target + 0.5)
        let mut nearest_val: i64 = 0
        let mut nearest_dist: i64 = 999999
        let mut nearest_expr = ""

        let lines = expr_table.split("\n")
        for line in lines {
            let lt = line.trim()
            if lt == "" { continue }
            let parts = lt.split("\t")
            if len(parts) < 2 { continue }
            let v = safe_int(parts[0])
            let dist = if v > int_target { v - int_target } else { int_target - v }
            if dist < nearest_dist && dist > 0 {
                nearest_dist = dist
                nearest_val = v
                nearest_expr = parts[1]
            }
        }

        if nearest_expr != "" {
            println("  가장 가까운 표현: " + to_string(nearest_val) + " = " + nearest_expr + " (차이: " + to_string(nearest_dist) + ")")
        }
    }
    println("")
}

// ═══════════════════════════════════════════════════════════
// 3. top — 역산 성공률 상위 도메인
// ═══════════════════════════════════════════════════════════

fn cmd_top() {
    println("")
    println("╔══════════════════════════════════════════════════╗")
    println("║  역 텔레스코프 — 도메인별 역산 성공률          ║")
    println("╚══════════════════════════════════════════════════╝")
    println("")

    let expr_table = build_expression_table()

    // EXACT 상수를 도메인별로 집계
    let exact_raw = load_exact_constants()
    let exact_lines = exact_raw.split("\n")

    let mut dom_names = []
    let mut dom_total = []
    let mut dom_matched = []

    for eline in exact_lines {
        let et = eline.trim()
        if et == "" { continue }
        let eparts = et.split("\t")
        if len(eparts) < 3 { continue }
        let eval_f = safe_float(eparts[1])
        let edom = eparts[2]
        if edom == "" { continue }

        // 도메인 인덱스 찾기
        let mut di: i64 = -1
        let mut fi: i64 = 0
        while fi < len(dom_names) {
            if dom_names[fi] == edom { di = fi }
            fi = fi + 1
        }
        if di == -1 {
            dom_names = dom_names + [edom]
            dom_total = dom_total + [0]
            dom_matched = dom_matched + [0]
            di = len(dom_names) - 1
        }

        dom_total[di] = dom_total[di] + 1
        let eexpr = reverse_lookup_float(eval_f, expr_table)
        if eexpr != "" {
            dom_matched[di] = dom_matched[di] + 1
        }
    }

    // 성공률 기준 정렬 (간단한 버블정렬)
    let mut si: i64 = 0
    while si < len(dom_names) {
        let mut sj: i64 = si + 1
        while sj < len(dom_names) {
            let rate_i = if dom_total[si] > 0 { (dom_matched[si] * 100) / dom_total[si] } else { 0 }
            let rate_j = if dom_total[sj] > 0 { (dom_matched[sj] * 100) / dom_total[sj] } else { 0 }
            if rate_j > rate_i || (rate_j == rate_i && dom_matched[sj] > dom_matched[si]) {
                // swap
                let tn = dom_names[si]; dom_names[si] = dom_names[sj]; dom_names[sj] = tn
                let tt = dom_total[si]; dom_total[si] = dom_total[sj]; dom_total[sj] = tt
                let tm = dom_matched[si]; dom_matched[si] = dom_matched[sj]; dom_matched[sj] = tm
            }
            sj = sj + 1
        }
        si = si + 1
    }

    println("  | # | 도메인 | 역산 성공 | 전체 | 성공률 | 등급 |")
    println("  |---|--------|---------|------|--------|------|")

    let mut di: i64 = 0
    while di < len(dom_names) && di < 30 {
        let rate = if dom_total[di] > 0 { (dom_matched[di] * 100) / dom_total[di] } else { 0 }
        let grade = if rate >= 80 { "완전 해독" } else if rate >= 50 { "부분 해독" } else if rate >= 20 { "탐색 중" } else { "미해독" }

        // 막대
        let bar_len = rate / 3
        let mut bar = ""
        let mut bi: i64 = 0
        while bi < bar_len { bar = bar + "#"; bi = bi + 1 }

        println("  | " + to_string(di + 1) + " | " + dom_names[di] + " | " + to_string(dom_matched[di]) + " | " + to_string(dom_total[di]) + " | " + bar + " " + to_string(rate) + "% | " + grade + " |")
        di = di + 1
    }

    println("")

    // growth_bus 기록
    try {
        let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
        let entry = "{\"type\":\"reverse_telescope\",\"mode\":\"top\",\"domains\":" + to_string(len(dom_names)) + ",\"ts\":\"" + ts + "\"}"
        exec("echo '" + entry + "' >> " + _bus_path)
    } catch e {}
}

// ═══════════════════════════════════════════════════════════
// help
// ═══════════════════════════════════════════════════════════

fn cmd_help() {
    println("╔══════════════════════════════════════════════════╗")
    println("║  역 텔레스코프 (Reverse Telescope)             ║")
    println("║  현실 상수를 n=6 렌즈 조합으로 역산             ║")
    println("╚══════════════════════════════════════════════════╝")
    println("")
    println("사용법:")
    println("  hexa reverse_telescope.hexa scan         전체 상수 역산 스캔")
    println("  hexa reverse_telescope.hexa check <값>   특정 값의 n=6 표현 탐색")
    println("  hexa reverse_telescope.hexa top          도메인별 역산 성공률 순위")
    println("  hexa reverse_telescope.hexa help         이 도움말")
    println("")
    println("원리:")
    println("  - n=6의 산술함수: mu=1, phi=2, M3=3, tau=4, sopfr=5, n=6, sigma=12, J2=24, P2=28")
    println("  - 2항 연산(+,-,*,/,^) 조합으로 표현식 테이블 구축")
    println("  - 특수 조합: sigma*tau=48, 5!=120, 6!=720, P3=496 등 포함")
    println("  - 각 상수에 대해 테이블 매칭 → 역산 성공/실패 판정")
    println("  - 결과는 growth_bus.jsonl에 자동 기록")
    println("")
}

// ═══════════════════════════════════════════════════════════
// MAIN
// ═══════════════════════════════════════════════════════════

let argv = args()
let mode = if len(argv) >= 3 { argv[2] } else { "scan" }
let arg3 = if len(argv) >= 4 { argv[3] } else { "" }

if mode == "scan" || mode == "스캔" {
    cmd_scan()
} else if mode == "check" || mode == "체크" {
    if arg3 != "" {
        cmd_check(arg3)
    } else {
        println("  오류: check 모드는 값을 인자로 필요합니다")
        println("  예: hexa reverse_telescope.hexa check 72")
    }
} else if mode == "top" || mode == "순위" {
    cmd_top()
} else if mode == "help" || mode == "도움말" {
    cmd_help()
} else {
    cmd_scan()
}

println("[verified] reverse_telescope.hexa 실행 완료")
println("")
