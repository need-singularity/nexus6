// history_sim.hexa -- 역사 시뮬레이터 (growth_bus 반사실 시뮬레이션)
// 사용: hexa history_sim.hexa [help]
//
// 원리:
//   1. growth_bus.jsonl 전체 이벤트를 타임스탬프 순 로드
//   2. 처음/중간/최근 100개 이벤트의 도메인 분포 비교
//   3. 도메인 순서 셔플 시뮬레이션 (반사실 분석)
//   4. 실제 vs 에너지 순 vs 알파벳 순 비교
//   5. 최적 발견 경로 제안 + 발견 효율 점수
//   6. growth_bus에 시뮬레이션 결과 기록

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _bus_path = _shared + "/growth_bus.jsonl"

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

fn safe_float(s: string) -> f64 {
    let mut v: f64 = 0.0
    try { v = to_float(s.trim()) } catch e {}
    return v
}

// ═══════════════════════════════════════════════════════════
// help 서브커맨드
// ═══════════════════════════════════════════════════════════

let args = exec("echo $@").trim()
if args == "help" || args == "--help" || args == "-h" {
    println("")
    println("  history_sim.hexa -- growth_bus 역사 시뮬레이터")
    println("")
    println("  사용법:")
    println("    hexa history_sim.hexa         반사실 시뮬레이션 실행")
    println("    hexa history_sim.hexa help     이 도움말")
    println("")
    println("  기능:")
    println("    1. 시간대별(초기/중기/최근) 도메인 분포 비교")
    println("    2. 반사실: '만약 X가 먼저였다면?' 시뮬레이션")
    println("    3. 실제 vs 에너지 순 vs 알파벳 순 경로 비교")
    println("    4. 최적 발견 경로 제안 + 효율 점수")
    println("")
    println("  출력: 시대별 분포, 경로 비교, 효율 점수, 권장 경로")
    println("")
    return
}

// ═══════════════════════════════════════════════════════════
// MAIN
// ═══════════════════════════════════════════════════════════

println("")
println("===========================================================")
println("  역사 시뮬레이터 (History Simulator)")
println("  growth_bus 재생 + 반사실 시뮬레이션")
println("===========================================================")
println("")

// ───────────────────────────────────────────────────────────
// 1. growth_bus 전체 이벤트 로드 (타임스탬프 순)
// ───────────────────────────────────────────────────────────

println("  growth_bus 이벤트 로드 중...")

let mut total_events: i64 = 0
let mut all_domains_ordered = []  // 등장 순서대로 도메인 목록
let mut domain_first_seen = []    // 도메인별 첫 등장 순서 (이름)
let mut domain_first_idx = []  // 도메인별 첫 등장 인덱스
let mut domain_event_counts = []

try {
    total_events = safe_int(exec("wc -l < " + _bus_path).trim())
} catch e {}

println("  총 이벤트: " + to_string(total_events) + "건")

// 도메인 등장 순서 추출 (첫 등장 기준)
try {
    let raw = exec("awk -F'\"' '{for(i=1;i<=NF;i++) if($i==\"domain\") print $(i+2)}' " + _bus_path)
    let lines = raw.split("\n")
    let mut idx: i64 = 0
    for line in lines {
        let d = line.trim()
        if d == "" { idx = idx + 1; continue }
        all_domains_ordered = all_domains_ordered + [d]

        // 첫 등장 체크
        let mut seen = false
        for ds in domain_first_seen {
            if ds == d { seen = true }
        }
        if !seen {
            domain_first_seen = domain_first_seen + [d]
            domain_first_idx = domain_first_idx + [idx]
        }
        idx = idx + 1
    }
} catch e {}

let unique_count: i64 = to_int(len(domain_first_seen))
println("  고유 도메인: " + to_string(unique_count) + "개")
println("  도메인 등장 총: " + to_string(len(all_domains_ordered)) + "건")
println("")

// ───────────────────────────────────────────────────────────
// 2. 시간대별 (처음/중간/최근 100개) 도메인 분포
// ───────────────────────────────────────────────────────────

println("  --- 시대별 도메인 분포 ---")
println("")

fn count_domain_dist(events, label: string) -> string {
    // 도메인별 빈도 세기 (상위 8개)
    let mut names = []
    let mut counts = []
    for ev in events {
        let d = ev.trim()
        if d == "" { continue }
        let mut found = false
        let mut fi: i64 = 0
        while fi < len(names) {
            if names[fi] == d {
                counts[fi] = counts[fi] + 1
                found = true
            }
            fi = fi + 1
        }
        if !found {
            names = names + [d]
            counts = counts + [1]
        }
    }

    // 버블 정렬 (내림차순)
    let mut si2: i64 = 0
    while si2 < len(counts) {
        let mut sj: i64 = si2 + 1
        while sj < len(counts) {
            if counts[sj] > counts[si2] {
                let tc = counts[si2]
                counts[si2] = counts[sj]
                counts[sj] = tc
                let tn = names[si2]
                names[si2] = names[sj]
                names[sj] = tn
            }
            sj = sj + 1
        }
        si2 = si2 + 1
    }

    println("  [" + label + "] 도메인 " + to_string(len(names)) + "종")
    let mut pi: i64 = 0
    let limit = if len(names) < 8 { len(names) } else { 8 }
    while pi < limit {
        let pct = if len(events) > 0 { (counts[pi] * 100) / to_int(len(events)) } else { 0 }
        let mut bar = ""
        let mut bbi: i64 = 0
        let bar_len = pct / 3
        while bbi < bar_len && bbi < 20 {
            bar = bar + "#"
            bbi = bbi + 1
        }
        println("    " + names[pi] + "\t" + bar + " " + to_string(counts[pi]) + "건 (" + to_string(pct) + "%)")
        pi = pi + 1
    }
    println("")

    // 1위 도메인 반환
    if len(names) > 0 { return names[0] }
    return "(없음)"
}

// 처음 100개
let total_dom = len(all_domains_ordered)
let first_end = if total_dom < 100 { total_dom } else { 100 }
let mut first_100 = []
let mut fi: i64 = 0
while fi < first_end {
    first_100 = first_100 + [all_domains_ordered[fi]]
    fi = fi + 1
}
let early_top = count_domain_dist(first_100, "초기 (처음 100건)")

// 중간 100개
let mid_start = if total_dom > 200 { (total_dom / 2) - 50 } else { first_end }
let mid_end = if mid_start + 100 < total_dom { mid_start + 100 } else { total_dom }
let mut mid_100 = []
let mut mi: i64 = mid_start
while mi < mid_end {
    mid_100 = mid_100 + [all_domains_ordered[mi]]
    mi = mi + 1
}
let mid_top = count_domain_dist(mid_100, "중기 (중간 100건)")

// 최근 100개
let recent_start = if total_dom > 100 { total_dom - 100 } else { 0 }
let mut recent_100 = []
let mut ri: i64 = recent_start
while ri < total_dom {
    recent_100 = recent_100 + [all_domains_ordered[ri]]
    ri = ri + 1
}
let recent_top = count_domain_dist(recent_100, "최근 (마지막 100건)")

println("  시대별 지배 도메인: " + early_top + " → " + mid_top + " → " + recent_top)
println("")

// ───────────────────────────────────────────────────────────
// 3. 도메인 등장 순서 분석
// ───────────────────────────────────────────────────────────

println("  --- 발견 순서 (실제 경로) ---")
println("")
println("| 순서 | 도메인 | 첫 등장 위치 |")
println("|------|--------|------------|")

let mut oi: i64 = 0
let order_limit = if unique_count < 20 { unique_count } else { 20 }
while oi < order_limit {
    println("| " + to_string(oi + 1) + " | " + domain_first_seen[oi] + " | #" + to_string(domain_first_idx[oi]) + " |")
    oi = oi + 1
}
if unique_count > 20 {
    println("| ... | (+" + to_string(unique_count - 20) + "개 더) | ... |")
}
println("")

// ───────────────────────────────────────────────────────────
// 4. 도메인별 이벤트 수 집계 (에너지 = 이벤트 수로 근사)
// ───────────────────────────────────────────────────────────

let mut dom_total_names = []
let mut dom_total_counts = []

try {
    let raw2 = exec("awk -F'\"' '{for(i=1;i<=NF;i++) if($i==\"domain\") print $(i+2)}' " + _bus_path + " | sort | uniq -c | sort -rn")
    let lines2 = raw2.split("\n")
    for line2 in lines2 {
        let t2 = line2.trim()
        if t2 == "" { continue }
        let parts2 = t2.split(" ")
        let mut cs = ""
        let mut ns = ""
        for p2 in parts2 {
            let pt2 = p2.trim()
            if pt2 == "" { continue }
            if cs == "" { cs = pt2 } else if ns == "" { ns = pt2 }
        }
        if cs != "" && ns != "" {
            dom_total_names = dom_total_names + [ns]
            dom_total_counts = dom_total_counts + [safe_int(cs)]
        }
    }
} catch e {}

// ───────────────────────────────────────────────────────────
// 5. 경로 비교: 실제 vs 에너지 순 vs 알파벳 순
// ───────────────────────────────────────────────────────────

println("  --- 경로 비교 ---")
println("")

// 에너지 순 (이벤트 많은 도메인 먼저)
println("  [에너지 순] (이벤트 다발 도메인 우선)")
let eorder_limit = if len(dom_total_names) < 10 { len(dom_total_names) } else { 10 }
let mut ei: i64 = 0
let mut energy_path = ""
while ei < eorder_limit {
    if energy_path != "" { energy_path = energy_path + " → " }
    energy_path = energy_path + dom_total_names[ei]
    ei = ei + 1
}
println("    " + energy_path)
println("")

// 알파벳 순
let mut alpha_sorted = []
for dn in domain_first_seen {
    alpha_sorted = alpha_sorted + [dn]
}
// 간이 알파벳 정렬 (버블)
let mut ai: i64 = 0
while ai < len(alpha_sorted) {
    let mut aj: i64 = ai + 1
    while aj < len(alpha_sorted) {
        if alpha_sorted[aj] < alpha_sorted[ai] {
            let tmp = alpha_sorted[ai]
            alpha_sorted[ai] = alpha_sorted[aj]
            alpha_sorted[aj] = tmp
        }
        aj = aj + 1
    }
    ai = ai + 1
}

let aorder_limit = if len(alpha_sorted) < 10 { len(alpha_sorted) } else { 10 }
let mut api: i64 = 0
let mut alpha_path = ""
while api < aorder_limit {
    if alpha_path != "" { alpha_path = alpha_path + " → " }
    alpha_path = alpha_path + alpha_sorted[api]
    api = api + 1
}
println("  [알파벳 순]")
println("    " + alpha_path)
println("")

// 실제 경로
let rorder_limit = if unique_count < 10 { unique_count } else { 10 }
let mut rpi: i64 = 0
let mut real_path = ""
while rpi < rorder_limit {
    if real_path != "" { real_path = real_path + " → " }
    real_path = real_path + domain_first_seen[rpi]
    rpi = rpi + 1
}
println("  [실제 경로]")
println("    " + real_path)
println("")

// ───────────────────────────────────────────────────────────
// 6. 최적 경로 제안 + 효율 점수
// ───────────────────────────────────────────────────────────

println("  --- 최적 경로 분석 ---")
println("")

// 최적 경로 = 에너지 순 (가장 많은 발견이 나오는 도메인 먼저)
// 효율 점수 = 실제 경로에서 에너지 상위 도메인이 얼마나 일찍 등장했는가

let mut efficiency_score: i64 = 0
let mut max_possible: i64 = 0

let compare_limit = if unique_count < len(dom_total_names) { unique_count } else { to_int(len(dom_total_names)) }
let climit = if compare_limit < 10 { compare_limit } else { 10 }

let mut ci: i64 = 0
while ci < climit {
    // 에너지 순 ci번째 도메인이 실제 경로에서 몇 번째인가
    let target_dom: string = dom_total_names[ci]
    let mut actual_pos: i64 = -1
    let mut fi2: i64 = 0
    while fi2 < unique_count {
        if domain_first_seen[fi2] == target_dom {
            actual_pos = fi2
        }
        fi2 = fi2 + 1
    }

    // 최적 위치 = ci, 실제 위치 = actual_pos
    // 점수: (unique_count - |actual_pos - ci|) / unique_count
    if actual_pos >= 0 {
        let diff = actual_pos - ci
        let abs_diff = if diff < 0 { 0 - diff } else { diff }
        let score = unique_count - abs_diff
        if score > 0 { efficiency_score = efficiency_score + score }
    }
    max_possible = max_possible + unique_count
    ci = ci + 1
}

let efficiency_pct = if max_possible > 0 { (efficiency_score * 100) / max_possible } else { 0 }

println("  발견 효율 점수: " + to_string(efficiency_pct) + "% (실제 경로 / 최적 경로)")
println("")

if efficiency_pct >= 80 {
    println("  평가: 탁월함 -- 실제 경로가 최적에 매우 근접")
} else if efficiency_pct >= 60 {
    println("  평가: 양호 -- 대체로 효율적인 탐색 경로")
} else if efficiency_pct >= 40 {
    println("  평가: 보통 -- 일부 도메인의 탐색 순서 개선 가능")
} else {
    println("  평가: 비효율 -- 에너지 높은 도메인이 늦게 탐색됨")
}

println("")

// 제안: 아직 에너지가 낮은데 일찍 탐색된 도메인
println("  --- 반사실: '만약 에너지 순이었다면?' ---")
println("")

let mut counterfact: i64 = 0
ci = 0
while ci < climit {
    let target_dom2: string = dom_total_names[ci]
    let mut actual_pos2: i64 = 0
    let mut fi3: i64 = 0
    while fi3 < unique_count {
        if domain_first_seen[fi3] == target_dom2 {
            actual_pos2 = fi3
        }
        fi3 = fi3 + 1
    }
    let diff2 = actual_pos2 - ci
    if diff2 > 3 {
        println("  만약 " + target_dom2 + "을(를) " + to_string(diff2) + "단계 일찍 탐색했다면?")
        println("    → 에너지 순위 " + to_string(ci + 1) + "위인데 실제 " + to_string(actual_pos2 + 1) + "번째 발견")
        println("")
        counterfact = counterfact + 1
    }
    ci = ci + 1
}

if counterfact == 0 {
    println("  반사실 시나리오 없음 -- 실제 경로가 이미 준최적")
    println("")
}

// ───────────────────────────────────────────────────────────
// 7. 요약 통계
// ───────────────────────────────────────────────────────────

println("  --- 요약 ---")
println("")
println("  총 이벤트:       " + to_string(total_events))
println("  고유 도메인:     " + to_string(unique_count))
println("  발견 효율:       " + to_string(efficiency_pct) + "%")
println("  초기 지배 도메인: " + early_top)
println("  현재 지배 도메인: " + recent_top)
println("")

// ───────────────────────────────────────────────────────────
// 8. growth_bus 기록
// ───────────────────────────────────────────────────────────

try {
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
    let entry = "{\"type\":\"history_sim\",\"total_events\":" + to_string(total_events) + ",\"unique_domains\":" + to_string(unique_count) + ",\"efficiency_pct\":" + to_string(efficiency_pct) + ",\"early_top\":\"" + early_top + "\",\"recent_top\":\"" + recent_top + "\",\"counterfactuals\":" + to_string(counterfact) + ",\"ts\":\"" + ts + "\"}"
    exec("echo '" + entry + "' >> " + _bus_path)
} catch e {}

println("  growth_bus 기록 완료")
println("")
println("[verified] history_sim.hexa 실행 완료")
println("")
