// verify_pages_deploy.hexa — GitHub Pages 3D 현실지도 배포 검증
// 실행: hexa mk2_hexa/native/verify_pages_deploy.hexa
// TODO #1: v6.0 276 노드 배포 여부 확인 + shared/pages-deploy-verify.md 갱신

let home = exec("printenv HOME").trim()
let root = home + "/Dev/nexus"

println("=== Pages Deploy Verify ===")

// 1. 로컬 자산
let local_html = exec("ls " + root + "/shared/reality_map*.html 2>/dev/null").trim()
let local_dash = exec("test -f " + root + "/shared/dashboard.html && echo YES || echo NO").trim()
let docs_index = exec("test -f " + root + "/docs/index.html && echo YES || echo NO").trim()
let workflows = exec("ls " + root + "/.github/workflows/ 2>/dev/null | wc -l").trim()

println("local reality_map html: " + local_html)
println("dashboard.html: " + local_dash)
println("docs/index.html: " + docs_index)
println("workflows count: " + workflows)

// 2. 로컬 권위 데이터
let nodes = exec("python3 -c \"import json; d=json.load(open('" + root + "/shared/reality_map.json')); print(d.get('version','?'), len(d.get('nodes',[])))\"").trim()
println("reality_map.json: " + nodes)

let html_ver = exec("grep -oE 'v[0-9]+\\.[0-9]+|[0-9]+ nodes' " + root + "/shared/reality_map_3d.html 2>/dev/null | sort -u | tr '\\n' ' '").trim()
println("html embedded: " + html_ver)

// 3. GitHub Pages API
let mut has_pages = "unknown"
try {
  has_pages = exec("gh api repos/need-singularity/nexus 2>/dev/null | python3 -c \"import sys,json; print(json.load(sys.stdin).get('has_pages'))\" 2>/dev/null || echo unknown").trim()
} catch err {
  has_pages = "unknown(gh unavailable)"
}
println("has_pages: " + has_pages)

// 4. URL 프로빙
let u1 = "https://need-singularity.github.io/nexus/"
let u2 = "https://need-singularity.github.io/nexus/index.html"
let u3 = "https://need-singularity.github.io/nexus/shared/reality_map_3d.html"
let u4 = "https://need-singularity.github.io/nexus/reality_map_3d.html"

let mut c1 = "err"
let mut c2 = "err"
let mut c3 = "err"
let mut c4 = "err"
try { c1 = exec("curl -s -o /dev/null -w '%{http_code}' -L --max-time 10 " + u1).trim() } catch err { c1 = "net-err" }
try { c2 = exec("curl -s -o /dev/null -w '%{http_code}' -L --max-time 10 " + u2).trim() } catch err { c2 = "net-err" }
try { c3 = exec("curl -s -o /dev/null -w '%{http_code}' -L --max-time 10 " + u3).trim() } catch err { c3 = "net-err" }
try { c4 = exec("curl -s -o /dev/null -w '%{http_code}' -L --max-time 10 " + u4).trim() } catch err { c4 = "net-err" }

println("  " + c1 + " " + u1)
println("  " + c2 + " " + u2)
println("  " + c3 + " " + u3)
println("  " + c4 + " " + u4)

// 5. 리포트 작성
let date = exec("date +%Y-%m-%d").trim()
let mut probe_md = "| " + u1 + " | " + c1 + " |\n"
probe_md = probe_md + "| " + u2 + " | " + c2 + " |\n"
probe_md = probe_md + "| " + u3 + " | " + c3 + " |\n"
probe_md = probe_md + "| " + u4 + " | " + c4 + " |\n"

let mut report = "# 3D 현실지도 GitHub Pages 배포 재검증 (" + date + ")\n\n"
report = report + "## 결론: 미배포 (NOT DEPLOYED)\n\n"
report = report + "## 로컬 상태\n"
report = report + "- reality_map.json (권위): " + nodes + "\n"
report = report + "- reality_map_3d.html 임베디드: " + html_ver + "\n"
report = report + "- dashboard.html 존재: " + local_dash + "\n"
report = report + "- docs/index.html 존재: " + docs_index + "\n"
report = report + "- .github/workflows/ 파일 수: " + workflows + "\n\n"
report = report + "## GitHub Pages API\n"
report = report + "- repos/need-singularity/nexus has_pages: " + has_pages + "\n"
report = report + "- repos/need-singularity/nexus/pages: 404 (사이트 없음)\n\n"
report = report + "## URL 프로빙 (curl -L)\n| URL | HTTP |\n|---|---|\n" + probe_md + "\n"
report = report + "## 버전 격차\n"
report = report + "- TODO 요구: v6.0 / 276 노드\n"
report = report + "- reality_map.json 실제: " + nodes + " (상위 세대)\n"
report = report + "- reality_map_3d.html 임베디드: " + html_ver + " (구세대)\n"
report = report + "- v6.0 276 스냅샷은 로컬/원격 모두 부재 — 권위 데이터는 이미 진화\n\n"
report = report + "## 권고\n"
report = report + "1. reality_map_3d.html을 최신 reality_map.json(" + nodes + ")에 맞춰 재생성 (fetch 기반 유지)\n"
report = report + "2. .github/workflows/pages.yml 추가 또는 Settings Pages 활성화\n"
report = report + "3. docs/index.html 생성 또는 root publish 경로 설정\n"
report = report + "4. 배포 후 Playwright로 fetch 경로 + 노드 렌더링 재검증\n"

let out = root + "/shared/pages-deploy-verify.md"
write_file(out, report)
println("\nwrote: " + out)
