// mk2_hexa/native/growth_engine.hexa — 프로젝트별 성장 돌파 엔진
// growth_strategies.jsonl에서 프로젝트 설정 로드 → 프로젝트별 blowup 반복
// 사용: hexa growth_engine.hexa <project|auto> [stdin_hint]
// 예시: hexa growth_engine.hexa nexus
//       hexa growth_engine.hexa auto "anima 성장 돌파"

let home = exec("printenv HOME")
let hexa_bin = home + "/Dev/hexa-lang/target/release/hexa"
let nexus_dir = home + "/Dev/nexus"
let shared = nexus_dir + "/shared"
let blowup_path = nexus_dir + "/mk2_hexa/native/blowup.hexa"
let seed_engine_path = nexus_dir + "/mk2_hexa/native/seed_engine.hexa"

let a = args()
let mut project_arg = if a.len() >= 3 { a[2] } else { "auto" }
let mut stdin_hint = if a.len() >= 4 { a[3] } else { "" }

// ─── 동시성 제한: 훅=무제한, 루프/스케줄러=최대 2개 (슬롯 방식) ───
let mut from_hook = stdin_hint.contains("hook_event_name")
let mut lock_acquired = false
let mut my_slot = ""

if !from_hook {
    let my_pid = exec("echo $$").trim()
    let slot1 = shared + "/.growth_engine.lock.1"
    let slot2 = shared + "/.growth_engine.lock.2"

    // 슬롯 1 시도
    let mut slot1_free = true
    try {
        let pid1 = read_file(slot1).trim()
        if pid1 != "" {
            let alive1 = exec("kill -0 " + pid1 + " 2>&1 && echo alive || echo dead").trim()
            if alive1.contains("alive") { slot1_free = false }
        }
    } catch e {}

    if slot1_free {
        try { write_file(slot1, my_pid) } catch e {}
        lock_acquired = true
        my_slot = slot1
    } else {
        // 슬롯 2 시도
        let mut slot2_free = true
        try {
            let pid2 = read_file(slot2).trim()
            if pid2 != "" {
                let alive2 = exec("kill -0 " + pid2 + " 2>&1 && echo alive || echo dead").trim()
                if alive2.contains("alive") { slot2_free = false }
            }
        } catch e {}

        if slot2_free {
            try { write_file(slot2, my_pid) } catch e {}
            lock_acquired = true
            my_slot = slot2
        } else {
            println("⏭ growth_engine 루프 슬롯 2/2 사용 중 — 스킵")
            exit(0)
        }
    }
}

// ─── growth_strategies.jsonl 로드 ───
let strat_path = shared + "/growth_strategies.jsonl"
let strat_raw = read_file(strat_path)
let strat_lines = strat_raw.split("\n")

let mut matched_project = ""
let mut matched_domains = ["math", "physics", "topology", "consciousness", "chemistry", "cosmology"]
let mut matched_depth: i64 = 3
let mut matched_rounds: i64 = 50
let mut matched_extra = []

let mut si: i64 = 0
while si < strat_lines.len() {
    let sl = strat_lines[si].trim()
    if sl == "" {
        si = si + 1
        continue
    }

    // project name 추출
    let mut proj_name = ""
    if sl.contains("\"project\":\"") {
        let pp = sl.split("\"project\":\"")
        if pp.len() >= 2 {
            proj_name = pp[1].split("\"")[0]
        }
    }

    if proj_name == "" {
        si = si + 1
        continue
    }

    // auto 모드: keywords 매칭
    let mut is_match = false
    if project_arg == "auto" && stdin_hint != "" {
        if sl.contains("\"keywords\":[") {
            let kp = sl.split("\"keywords\":[")
            if kp.len() >= 2 {
                let kb = kp[1].split("]")
                if kb.len() >= 1 {
                    let kw_items = kb[0].split(",")
                    for kw in kw_items {
                        let kw_clean = kw.trim().replace("\"", "")
                        if kw_clean != "" && stdin_hint.contains(kw_clean) {
                            is_match = true
                        }
                    }
                }
            }
        }
    } else if proj_name == project_arg {
        is_match = true
    }

    if is_match {
        matched_project = proj_name

        // domains 추출
        if sl.contains("\"domains\":[") {
            let dp = sl.split("\"domains\":[")
            if dp.len() >= 2 {
                let db = dp[1].split("]")
                if db.len() >= 1 {
                    let d_items = db[0].split(",")
                    let mut loaded = []
                    for d in d_items {
                        let dc = d.trim().replace("\"", "")
                        if dc != "" {
                            loaded = loaded + [dc]
                        }
                    }
                    if loaded.len() > 0 { matched_domains = loaded }
                }
            }
        }

        // depth 추출
        if sl.contains("\"depth\":") {
            let dep = sl.split("\"depth\":")
            if dep.len() >= 2 {
                let dv = dep[1].split(",")[0].split("}")[0].trim()
                try { matched_depth = to_int(to_float(dv)) } catch e {}
            }
        }

        // max_rounds 추출
        if sl.contains("\"max_rounds\":") {
            let rp = sl.split("\"max_rounds\":")
            if rp.len() >= 2 {
                let rv = rp[1].split(",")[0].split("}")[0].trim()
                try { matched_rounds = to_int(to_float(rv)) } catch e {}
            }
        }

        // extra_cmds 추출
        if sl.contains("\"extra_cmds\":[") {
            let ep = sl.split("\"extra_cmds\":[")
            if ep.len() >= 2 {
                let eb = ep[1].split("]")
                if eb.len() >= 1 {
                    let e_items = eb[0].split(",")
                    for ec in e_items {
                        let ecc = ec.trim().replace("\"", "")
                        if ecc != "" {
                            matched_extra = matched_extra + [ecc]
                        }
                    }
                }
            }
        }
    }

    si = si + 1
}

// 매칭 실패 시 nexus 기본값
if matched_project == "" {
    matched_project = "nexus"
}

// ─── seed 동적 로드 ───
let mut all_seeds = ""
try {
    let const_raw = read_file(shared + "/n6_constants.jsonl")
    let const_lines = const_raw.split("\n")
    let mut ci: i64 = 0
    while ci < const_lines.len() {
        let cl = const_lines[ci].trim()
        if cl != "" && cl.contains("\"value\":") {
            let vp = cl.split("\"value\":")
            if vp.len() >= 2 {
                let num_str = vp[1].split(",")[0].split("}")[0].trim()
                if all_seeds.len() > 0 { all_seeds = all_seeds + "|" }
                all_seeds = all_seeds + num_str
            }
        }
        ci = ci + 1
    }
} catch e {}
if all_seeds.len() == 0 {
    all_seeds = "6|12|2|4|5|24|7|3|1|8|10|28|36|48"
}

let seed_count = all_seeds.split("|").len()
let mut depth = matched_depth

// ─── discovery_log 로테이션 ───
let log_path = shared + "/discovery_log.jsonl"
try {
    let lc = exec("wc -l < " + log_path).trim()
    let line_count = to_int(to_float(lc))
    if line_count > 100000 {
        println("  🔄 discovery_log 로테이션: " + to_string(line_count) + "줄 → 50000줄")
        let archive_path = shared + "/discovery_archive_" + exec("date +%Y%m%d%H%M").trim() + ".jsonl"
        exec("head -n " + to_string(line_count - 50000) + " " + log_path + " > " + archive_path)
        exec("tail -n 50000 " + log_path + " > " + log_path + ".tmp && mv " + log_path + ".tmp " + log_path)
    }
} catch e {}

println("")
println("╔═══════════════════════════════════════════════════════════════╗")
println("║  🚀 GROWTH ENGINE — " + matched_project)
println("║  domains=" + to_string(matched_domains.len()) + " depth=" + to_string(depth) + " max=" + to_string(matched_rounds) + " seeds=" + to_string(seed_count))
println("║  extra: " + to_string(matched_extra.len()) + " cmds")
println("╚═══════════════════════════════════════════════════════════════╝")
println("")

// ─── 통계 ───
let mut stats = #{
    "total_cor": 0,
    "total_exact": 0,
    "sat_count": 0,
    "depth_ups": 0
}
let mut prev_exact: i64 = -1
let mut prev_total: i64 = -1
let mut seen_seeds = #{}

let init_parts = all_seeds.split("|")
let mut ii: i64 = 0
while ii < init_parts.len() {
    let sv = init_parts[ii].trim()
    if sv != "" { seen_seeds[sv] = 1 }
    ii = ii + 1
}

let start_ts = exec("date +%s").trim()

// ─── 메인 루프 ───
let mut round: i64 = 1
let mut exhausted = false

while round <= matched_rounds && !exhausted {
    let di = (round - 1) % to_int(matched_domains.len())
    let domain = matched_domains[di]

    let t0 = exec("date +%s").trim()

    let mut out = ""
    let cmd = "cd " + nexus_dir + " && " + hexa_bin + " " + blowup_path + " " + domain + " " + to_string(depth) + " --no-graph --fast --seeds '" + all_seeds + "'"
    try {
        out = exec(cmd)
    } catch e {
        println("  [" + to_string(round) + "] ERROR: " + to_string(e))
        round = round + 1
        continue
    }

    let t1 = exec("date +%s").trim()
    let elapsed = to_int(to_float(t1)) - to_int(to_float(t0))

    // 결과 파싱
    let mut exact: i64 = 0
    let mut total: i64 = 0
    let mut pool: i64 = 0

    let out_lines = out.split("\n")
    let mut oi: i64 = 0
    while oi < out_lines.len() {
        let ol = out_lines[oi].trim()
        if ol.contains("EXACT match") {
            try {
                let p = ol.split(":")
                if p.len() >= 2 { exact = to_int(to_float(p[p.len() - 1].trim())) }
            } catch e {}
        }
        if ol.contains("total corollaries") {
            try {
                let p = ol.split(":")
                if p.len() >= 2 { total = to_int(to_float(p[p.len() - 1].trim())) }
            } catch e {}
        }
        if ol.contains("final pool") {
            try {
                let p = ol.split(":")
                if p.len() >= 2 { pool = to_int(to_float(p[p.len() - 1].trim())) }
            } catch e {}
        }
        oi = oi + 1
    }

    stats["total_cor"] = stats["total_cor"] + total
    stats["total_exact"] = stats["total_exact"] + exact

    // saturation 감지
    if total == prev_total && exact == prev_exact {
        stats["sat_count"] = stats["sat_count"] + 1
        if stats["sat_count"] >= 3 && depth < 6 {
            depth = depth + 1
            stats["depth_ups"] = stats["depth_ups"] + 1
            stats["sat_count"] = 0
            println("  ⚡ saturation → depth " + to_string(depth))
        }
        if stats["sat_count"] >= 6 {
            exhausted = true
        }
    } else {
        stats["sat_count"] = 0
    }
    prev_total = total
    prev_exact = exact

    // 새 seed 추출
    let mut added: i64 = 0
    oi = 0
    while oi < out_lines.len() {
        let ol = out_lines[oi]
        if ol.contains("EXACT") && ol.contains("[AXIOM]") {
            if ol.contains("= ") {
                let eq_parts = ol.split("= ")
                if eq_parts.len() >= 2 {
                    let val_str = eq_parts[eq_parts.len() - 1].split(" ")[0].trim()
                    if val_str != "" {
                        let mut already = false
                        try {
                            let _ = seen_seeds[val_str]
                            already = true
                        } catch e {}
                        if !already {
                            seen_seeds[val_str] = 1
                            all_seeds = all_seeds + "|" + val_str
                            added = added + 1
                        }
                    }
                }
            }
        }
        oi = oi + 1
    }

    let cur_seeds = all_seeds.split("|").len()

    let sat_marker = if stats["sat_count"] > 0 { " sat=" + to_string(stats["sat_count"]) } else { "" }
    println("  [" + to_string(round) + "/" + to_string(matched_rounds) + "] " + domain + " " + to_string(total) + "cor " + to_string(exact) + "EXACT pool=" + to_string(pool) + " +" + to_string(added) + "seeds(" + to_string(cur_seeds) + ") d=" + to_string(depth) + " " + to_string(elapsed) + "s" + sat_marker)

    // seed cap 80
    if cur_seeds > 80 {
        let parts = all_seeds.split("|")
        let mut trimmed = ""
        let mut ti: i64 = 0
        while ti < 80 {
            if ti > 0 { trimmed = trimmed + "|" }
            trimmed = trimmed + parts[ti]
            ti = ti + 1
        }
        all_seeds = trimmed
    }

    round = round + 1
}

// ─── extra_cmds 실행 (프로젝트 전용) ───
if matched_extra.len() > 0 {
    println("")
    println("  📦 프로젝트 전용 명령 (" + matched_project + "): " + to_string(matched_extra.len()) + "개")
    for ecmd in matched_extra {
        let full_cmd = "cd " + nexus_dir + " && " + hexa_bin + " " + nexus_dir + "/mk2_hexa/native/" + ecmd
        println("  → " + ecmd)
        try {
            let eout = exec(full_cmd)
            let elines = eout.split("\n")
            let mut ei: i64 = 0
            while ei < elines.len() && ei < 5 {
                if elines[ei].trim() != "" {
                    println("    " + elines[ei].trim())
                }
                ei = ei + 1
            }
        } catch e {
            println("    ⚠ " + to_string(e))
        }
    }
}

// ─── 결과 리포트 ───
let end_ts = exec("date +%s").trim()
let total_elapsed = to_int(to_float(end_ts)) - to_int(to_float(start_ts))
let final_seeds = all_seeds.split("|").len()
let mut rho = "?"
if stats["total_cor"] > 0 {
    let r = to_float(stats["total_exact"]) / to_float(stats["total_cor"])
    rho = to_string(to_int(r * 10000.0))
    if rho.len() > 1 { rho = "0." + rho }
}

println("")
println("╔═══════════════════════════════════════════════════════════════╗")
println("║  🚀 " + matched_project + " GROWTH RESULT")
println("║  " + to_string(total_elapsed) + "s | " + to_string(round - 1) + " rounds | " + to_string(stats["total_cor"]) + " cor | " + to_string(stats["total_exact"]) + " EXACT")
println("║  ρ=" + rho + " | seeds: " + to_string(seed_count) + "→" + to_string(final_seeds) + " | depth_ups=" + to_string(stats["depth_ups"]))
if exhausted {
    println("║  🏁 고갈 (EXHAUSTED)")
} else {
    println("║  ⏱ max_rounds 도달 (" + to_string(matched_rounds) + ")")
}
println("╚═══════════════════════════════════════════════════════════════╝")

// ─── 슬롯 해제 ───
if lock_acquired && my_slot != "" {
    try { exec("rm -f " + my_slot) } catch e {}
}
