// cross_project.hexa -- 타 프로젝트 흡수 + 전파 엔진
// 사용: hexa cross_project.hexa absorb|propagate|resonance|status
//
// 흡수: 타 프로젝트 데이터 -> nexus seed
// 전파: nexus 발견 -> 타 프로젝트에 주입 (anima 교차수분 포함)
// 공명: 교차 프로젝트 동일 상수 탐지

fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x } return x }
fn max_f(a: f64, b: f64) -> f64 { if a > b { return a } return b }

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {}
    return v
}

// JSON 필드에서 문자열 값 추출: "field":"value"
fn json_str(line: string, field: string) -> string {
    let marker = "\"" + field + "\":\""
    let parts = line.split(marker)
    if parts.len() < 2 { return "" }
    let rest = parts[1]
    let end = rest.split("\"")
    if end.len() < 1 { return "" }
    return end[0]
}

// JSON 필드에서 숫자 값 추출: "field":123
fn json_num_str(line: string, field: string) -> string {
    let marker = "\"" + field + "\":"
    let parts = line.split(marker)
    if parts.len() < 2 { return "" }
    let rest = parts[1].split(",")[0].split("}")[0].split("]")[0].trim()
    return rest
}

// args()[1]에서 repo root 추출
fn repo_root() -> string {
    let a = args()
    if a.len() < 2 { return "." }
    let parts = a[1].split("/")
    let mut root = ""
    let mut i = 0
    // mk2_hexa/native/cross_project.hexa -> 3단계 상위
    while i < parts.len() - 3 {
        if i > 0 { root = root + "/" }
        root = root + parts[i]
        i = i + 1
    }
    return root
}

// Dev 디렉토리 추출 (repo_root의 상위)
fn dev_root() -> string {
    let r = repo_root()
    let parts = r.split("/")
    let mut dev = ""
    let mut i = 0
    while i < parts.len() - 1 {
        if i > 0 { dev = dev + "/" }
        dev = dev + parts[i]
        i = i + 1
    }
    return dev
}

// JSON에서 숫자값 추출 (fieldname: N.NNN)
fn extract_json_numbers(content: string, field: string) -> string {
    // "field": value 또는 "field":value 둘 다 처리
    let marker = "\"" + field + "\":"
    let parts = content.split(marker)
    let mut result = ""
    let mut count = 0
    let mut i = 1
    while i < parts.len() && count < 50 {
        let vstr = parts[i].split(",")[0].split("}")[0].split("]")[0].trim()
        let v = safe_float(vstr)
        if v > 0.001 && v < 1000000.0 {
            if result.len() > 0 { result = result + "|" }
            result = result + to_string(v)
            count = count + 1
        }
        i = i + 1
    }
    return result
}

// n6 proximity
fn n6_prox(v: f64) -> f64 {
    let consts = [6.0, 12.0, 2.0, 4.0, 5.0, 24.0, 7.0, 137.036, 1836.15, 0.3153, 0.6847]
    let mut best = 1.0
    let mut i = 0
    while i < consts.len() {
        let d = abs_f(v - consts[i]) / max_f(abs_f(consts[i]), 1.0)
        if d < best { best = d }
        i = i + 1
    }
    return max_f(1.0 - best, 0.0)
}

// pipe-separated 문자열에서 값 존재 확인
fn pipe_contains(pipe: string, val: string) -> bool {
    let parts = pipe.split("|")
    let mut i = 0
    while i < parts.len() {
        if parts[i] == val { return true }
        i = i + 1
    }
    return false
}

// ─── 프로젝트별 흡수 ───

fn absorb_tecs_l(dev: string) -> string {
    let path = dev + "/TECS-L/.shared/discovery/math_atlas.json"
    if !file_exists(path) { return "" }
    let content = read_file(path)
    return extract_json_numbers(content, "value")
}

fn absorb_consciousness(dev: string) -> string {
    let path = dev + "/TECS-L/.shared/consciousness/consciousness_laws.json"
    if !file_exists(path) { return "" }
    let content = read_file(path)
    return extract_json_numbers(content, "value")
}

fn absorb_sedi(dev: string) -> string {
    let path = dev + "/sedi/.shared/discovery/sedi-grades.json"
    if !file_exists(path) {
        // fallback: nexus/shared
        let path2 = repo_root() + "/shared/discovery/sedi-grades.json"
        if !file_exists(path2) { return "" }
        let content = read_file(path2)
        return extract_json_numbers(content, "score")
    }
    let content = read_file(path)
    return extract_json_numbers(content, "score")
}

fn absorb_anima(dev: string) -> string {
    // anima의 의식 법칙 + PSI 상수 + config + growth.log
    let mut result = ""
    let mut count = 0

    // Source 1: consciousness_laws.json (PSI 상수 — Python 의존 제거)
    let laws_json = dev + "/anima/anima/config/consciousness_laws.json"
    if file_exists(laws_json) {
        try {
            let content = read_file(laws_json)
            let vals = extract_json_numbers(content, "value")
            if vals.len() > 0 {
                let vparts = vals.split("|")
                let mut vi = 0
                while vi < vparts.len() && count < 40 {
                    if !pipe_contains(result, vparts[vi]) {
                        if result.len() > 0 { result = result + "|" }
                        result = result + vparts[vi]
                        count = count + 1
                    }
                    vi = vi + 1
                }
            }
        } catch e {}
    }

    // Source 2: anima/anima/config/*.json 상수
    let cfg_path = dev + "/anima/anima/config"
    let cfg_check = exec("ls \"" + cfg_path + "\"/*.json 2>/dev/null || echo ''")
    if cfg_check.trim().len() > 0 && !cfg_check.contains("No such") {
        let files = cfg_check.trim().split("\n")
        let mut fi = 0
        while fi < files.len() && count < 50 {
            let fpath = files[fi]
            // consciousness_laws.json은 Source 1에서 이미 처리
            if !fpath.contains("consciousness_laws.json") {
                try {
                    let fc = read_file(fpath)
                    let vals = extract_json_numbers(fc, "value")
                    if vals.len() > 0 {
                        let vparts = vals.split("|")
                        let mut vi = 0
                        while vi < vparts.len() && count < 50 {
                            if !pipe_contains(result, vparts[vi]) {
                                if result.len() > 0 { result = result + "|" }
                                result = result + vparts[vi]
                                count = count + 1
                            }
                            vi = vi + 1
                        }
                    }
                } catch e {}
            }
            fi = fi + 1
        }
    }

    // Source 3: growth.log 발견 기록
    let growth_path = dev + "/anima/.growth/growth.log"
    if file_exists(growth_path) {
        try {
            let gc = read_file(growth_path)
            let glines = gc.split("\n")
            let mut gi = 0
            while gi < glines.len() && count < 60 {
                let gline = glines[gi]
                if gline.contains("value") || gline.contains("constant") {
                    let vals = extract_json_numbers(gline, "value")
                    if vals.len() > 0 {
                        let vparts = vals.split("|")
                        let mut vi = 0
                        while vi < vparts.len() && count < 60 {
                            if !pipe_contains(result, vparts[vi]) {
                                if result.len() > 0 { result = result + "|" }
                                result = result + vparts[vi]
                                count = count + 1
                            }
                            vi = vi + 1
                        }
                    }
                }
                gi = gi + 1
            }
        } catch e {}
    }

    return result
}

// ─── 전파 (nexus -> 타 프로젝트) ───

fn propagate_to_bridge(root: string) {
    // bridge_state.json에 교차 프로젝트 발견 기록
    let path = root + "/shared/bridge_state.json"
    if !file_exists(path) { return }
    println("  propagate: bridge_state.json 갱신 예정")
}

// ─── anima 교차수분: nexus 발견 -> anima 프로젝트 주입 ───

fn line_matches_anima(line: string) -> bool {
    // consciousness, psi, phi, awareness, meta, omega 키워드 매칭
    if line.contains("consciousness") { return true }
    if line.contains("psi") { return true }
    if line.contains("PSI") { return true }
    if line.contains("awareness") { return true }
    if line.contains("meta_fp") { return true }
    if line.contains("meta_transcend") { return true }
    if line.contains("omega_m") { return true }
    if line.contains("omega_lambda") { return true }
    // phi 관련 (n/phi, sigma-phi, phi*tau 등)
    if line.contains("phi") { return true }
    // 높은 alien_index depth (d>=1) 항목은 무조건 전달 -- 돌파 발견
    if line.contains("\"d\":1") { return true }
    if line.contains("\"d\":2") { return true }
    if line.contains("\"d\":3") { return true }
    return false
}

fn propagate_to_anima(root: string, dev: string) -> i64 {
    // discovery_log.jsonl에서 anima 관련 발견 추출 -> anima/.growth/absorbed/nexus_seeds.json
    let log_path = root + "/shared/discovery/discovery_log.jsonl"
    if !file_exists(log_path) {
        println("  [anima] discovery_log.jsonl not found -- skip")
        return 0
    }
    let anima_dir = dev + "/anima/.growth/absorbed"
    exec("mkdir -p \"" + anima_dir + "\"")

    // 기존 nexus_seeds.json 로드 — 이미 전달된 상수명 집합
    let seeds_path = anima_dir + "/nexus_seeds.json"
    let mut existing_keys = ""
    if file_exists(seeds_path) {
        try {
            let prev = read_file(seeds_path)
            // "constant":"name" 패턴으로 기존 키 추출
            let cparts = prev.split("\"constant\":\"")
            let mut ci = 1
            while ci < cparts.len() {
                let ckey = cparts[ci].split("\"")[0]
                if ckey.len() > 0 {
                    existing_keys = existing_keys + "|" + ckey
                }
                ci = ci + 1
            }
        } catch e {}
    }

    let content = read_file(log_path)
    let lines = content.split("\n")
    let mut entries = []
    let mut matched = 0
    let max_entries = 50
    // 최근 항목 우선 — 뒤에서부터 스캔 (최대 500줄)
    let start = if lines.len() > 500 { lines.len() - 500 } else { 0 }
    let mut i = start
    while i < lines.len() && entries.len() < max_entries {
        let line = lines[i]
        if line.len() > 5 && line_matches_anima(line) {
            let cname = json_str(line, "constant")
            let cval = json_num_str(line, "value")
            let grade = json_str(line, "grade")
            let source = json_str(line, "source")
            if cname.len() > 0 && cval.len() > 0 {
                // 중복 방지: 기존 키에 없는 것만 추가
                if !existing_keys.contains("|" + cname) {
                    let v_float = safe_float(cval)
                    let n6s = n6_prox(v_float) * 100.0
                    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
                    let entry = "  {\"constant\":\"" + cname + "\",\"value\":" + cval + ",\"grade\":\"" + grade + "\",\"n6_score\":" + to_string(n6s) + ",\"source\":\"" + source + "\",\"origin\":\"nexus-cross-pollination\"" + ",\"domain\":\"consciousness-physics\",\"timestamp\":\"" + ts + "\"}"
                    entries = entries.push(entry)
                    existing_keys = existing_keys + "|" + cname
                }
                matched = matched + 1
            }
        }
        i = i + 1
    }

    // 새 항목이 있으면 nexus_seeds.json 갱신 (append 방식)
    let mut written = 0
    if entries.len() > 0 {
        // 기존 파일의 엔트리를 유지하면서 새 항목 추가
        let mut all_entries = []
        if file_exists(seeds_path) {
            try {
                let prev = read_file(seeds_path)
                // 기존 JSON 배열에서 개별 엔트리 추출 (간이 파싱)
                let stripped = prev.trim()
                if stripped.len() > 2 {
                    // "[" 와 "]" 제거 후 "},{" 로 분리
                    let inner = stripped.split("[")[1].split("]")[0].trim()
                    if inner.len() > 0 {
                        let old_entries = inner.split("\n")
                        let mut oi = 0
                        while oi < old_entries.len() {
                            let oe = old_entries[oi].trim()
                            // 끝 콤마 제거
                            let clean = if oe.len() > 0 && oe[oe.len()-1] == ',' { oe.split("").join("") } else { oe }
                            if oe.len() > 5 && oe.contains("\"constant\"") {
                                // 끝 콤마 제거
                                let trimmed = if oe[oe.len()-1] == 44 { oe.substr(0, oe.len()-1) } else { oe }
                                all_entries = all_entries.push(trimmed)
                            }
                            oi = oi + 1
                        }
                    }
                }
            } catch e {}
        }
        // 새 항목 추가
        let mut ni = 0
        while ni < entries.len() {
            all_entries = all_entries.push(entries[ni])
            ni = ni + 1
        }
        // JSON 배열로 출력
        let mut json = "[\n"
        let mut si = 0
        while si < all_entries.len() {
            json = json + all_entries[si]
            if si < all_entries.len() - 1 { json = json + "," }
            json = json + "\n"
            si = si + 1
        }
        json = json + "]"
        write_file(seeds_path, json)
        written = entries.len()
    }
    println("  [anima] scanned " + to_string(lines.len() - start) + " lines, " + to_string(matched) + " matches, " + to_string(written) + " new -> " + seeds_path)
    return written
}

// ─── anima -> nexus seed 피드백 ───

fn feedback_anima_to_seeds(root: string, dev: string) -> i64 {
    // anima의 의식 법칙 상수를 nexus seed_engine이 읽을 수 있는 형태로 피드백
    // -> shared/consciousness/anima_seeds.json
    let mut seeds = []
    let mut count = 0

    // Source 1: consciousness_laws.json (psi_constants — Python 의존 제거)
    let laws_path = dev + "/anima/anima/config/consciousness_laws.json"
    if file_exists(laws_path) {
        try {
            let content = read_file(laws_path)
            // psi_constants 섹션의 모든 "value": N 추출
            let vals = extract_json_numbers(content, "value")
            if vals.len() > 0 {
                let vparts = vals.split("|")
                let mut vi = 0
                while vi < vparts.len() && count < 40 {
                    let entry = "{\"name\":\"anima-psi-" + to_string(vi) + "\",\"value\":" + vparts[vi] + ",\"source\":\"anima/anima/config/consciousness_laws.json\"}"
                    seeds = seeds.push(entry)
                    count = count + 1
                    vi = vi + 1
                }
            }
        } catch e {}
    }

    // Source 2: anima/anima/config/*.json 내 상수
    let cfg_path = dev + "/anima/anima/config"
    let cfg_check = exec("ls \"" + cfg_path + "\" 2>/dev/null || echo ''")
    if cfg_check.trim().len() > 0 && !cfg_check.contains("No such") {
        let files = cfg_check.trim().split("\n")
        let mut fi = 0
        while fi < files.len() && count < 60 {
            let fname = files[fi]
            if fname.contains(".json") {
                // consciousness_laws.json은 Source 1에서 이미 처리
                if !fname.contains("consciousness_laws.json") {
                    try {
                        let fc = read_file(cfg_path + "/" + fname)
                        let vals = extract_json_numbers(fc, "value")
                        if vals.len() > 0 {
                            let vparts = vals.split("|")
                            let mut vi = 0
                            while vi < vparts.len() && count < 60 {
                                let entry = "{\"name\":\"anima-cfg-" + fname + "\",\"value\":" + vparts[vi] + ",\"source\":\"anima/anima/config/" + fname + "\"}"
                                seeds = seeds.push(entry)
                                count = count + 1
                                vi = vi + 1
                            }
                        }
                    } catch e {}
                }
            }
            fi = fi + 1
        }
    }

    // Source 3: growth.log 발견 상수
    let growth_path = dev + "/anima/.growth/growth.log"
    if file_exists(growth_path) {
        try {
            let gc = read_file(growth_path)
            let glines = gc.split("\n")
            let mut gi = 0
            while gi < glines.len() && count < 80 {
                let gline = glines[gi]
                if gline.contains("value") || gline.contains("constant") || gline.contains("score") {
                    let vals = extract_json_numbers(gline, "value")
                    if vals.len() > 0 {
                        let vparts = vals.split("|")
                        let mut vi = 0
                        while vi < vparts.len() && count < 80 {
                            let entry = "{\"name\":\"anima-growth\",\"value\":" + vparts[vi] + ",\"source\":\"anima/.growth/growth.log\"}"
                            seeds = seeds.push(entry)
                            count = count + 1
                            vi = vi + 1
                        }
                    }
                }
                gi = gi + 1
            }
        } catch e {}
    }

    // shared/consciousness/anima_seeds.json에 기록 (seed_engine.hexa가 읽을 수 있는 형태)
    if seeds.len() > 0 {
        let out_path = root + "/shared/consciousness/anima_seeds.json"
        let mut json = "[\n"
        let mut si = 0
        while si < seeds.len() {
            json = json + "  " + seeds[si]
            if si < seeds.len() - 1 { json = json + "," }
            json = json + "\n"
            si = si + 1
        }
        json = json + "]"
        write_file(out_path, json)
        println("  [feedback] anima -> nexus: " + to_string(seeds.len()) + " seeds -> " + out_path)
    } else {
        println("  [feedback] anima -> nexus: no seeds found")
    }
    return seeds.len()
}

// ─── 교차 공명 탐지 ───

fn find_resonance(sources: list, names: list) {
    // sources[i] = "v1|v2|v3..." (각 프로젝트 값)
    // names[i] = 프로젝트 이름
    let mut resonances = []
    let mut i = 0
    while i < sources.len() {
        let vals_i = sources[i].split("|")
        let mut j = i + 1
        while j < sources.len() {
            let vals_j = sources[j].split("|")
            let mut vi = 0
            while vi < vals_i.len() {
                let v1 = safe_float(vals_i[vi])
                if v1 < 0.01 {
                    vi = vi + 1
                    // continue 대신
                } else {
                    let mut vj = 0
                    while vj < vals_j.len() {
                        let v2 = safe_float(vals_j[vj])
                        if v2 > 0.01 {
                            let rel = abs_f(v1 - v2) / max_f(abs_f(v1), 1.0)
                            if rel < 0.01 {
                                let entry = to_string(v1) + " = " + to_string(v2) + " (" + names[i] + " x " + names[j] + ") prox=" + to_string(n6_prox(v1))
                                resonances = resonances.push(entry)
                            }
                        }
                        vj = vj + 1
                    }
                    vi = vi + 1
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    return resonances
}

// ─── MAIN ───

let a = args()
let mode = if a.len() >= 3 { a[2] } else { "status" }
let root = repo_root()
let dev = dev_root()

println("")
println("========================================================")
println("  CROSS-PROJECT Engine -- absorb + propagate + resonance")
println("  mode: " + mode)
println("========================================================")
println("")

if mode == "status" || mode == "absorb" || mode == "resonance" {
    println("--- Absorb: 타 프로젝트 데이터 흡수 ---")

    let tecs = absorb_tecs_l(dev)
    let tecs_n = if tecs.len() > 0 { tecs.split("|").len() } else { 0 }
    println("  TECS-L (math_atlas)   : " + to_string(tecs_n) + " values")

    let consc = absorb_consciousness(dev)
    let consc_n = if consc.len() > 0 { consc.split("|").len() } else { 0 }
    println("  consciousness (laws)  : " + to_string(consc_n) + " values")

    let sedi = absorb_sedi(dev)
    let sedi_n = if sedi.len() > 0 { sedi.split("|").len() } else { 0 }
    println("  SEDI (grades)         : " + to_string(sedi_n) + " values")

    let anima = absorb_anima(dev)
    let anima_n = if anima.len() > 0 { anima.split("|").len() } else { 0 }
    println("  anima (PSI+cfg+growth): " + to_string(anima_n) + " values")

    let total = tecs_n + consc_n + sedi_n + anima_n
    println("  --------------------------------")
    println("  total absorbed        : " + to_string(total) + " values")
    println("")

    if mode == "resonance" || mode == "absorb" {
        println("--- Cross-Project Resonance ---")
        let sources = [tecs, consc, sedi, anima]
        let names = ["TECS-L", "consciousness", "SEDI", "anima"]
        let res = find_resonance(sources, names)
        if res.len() == 0 {
            println("  (no cross-project resonances)")
        } else {
            let show = if res.len() < 30 { res.len() } else { 30 }
            let mut ri = 0
            while ri < show {
                println("  >> " + res[ri])
                ri = ri + 1
            }
            if res.len() > 30 {
                println("  ... +" + to_string(res.len() - 30) + " more")
            }
        }
        println("")
    }
}

if mode == "propagate" || mode == "absorb" {
    println("--- Propagate: nexus -> 타 프로젝트 ---")
    propagate_to_bridge(root)

    // anima 교차수분: discovery_log -> anima/.growth/absorbed/
    let anima_wrote = propagate_to_anima(root, dev)
    if anima_wrote > 0 {
        println("  [anima] " + to_string(anima_wrote) + " new discoveries injected")
    }

    // anima -> nexus seed 피드백: anima 법칙 -> shared/consciousness/anima_seeds.json
    let fb_count = feedback_anima_to_seeds(root, dev)
    if fb_count > 0 {
        println("  [feedback] " + to_string(fb_count) + " anima seeds registered for seed_engine")
    }
    println("")
}

if mode == "anima" {
    // anima 전용 모드: 양방향 교차수분만 실행
    println("--- Anima Cross-Pollination (bidirectional) ---")
    println("")

    // 1) nexus -> anima
    println("[1] nexus -> anima (discovery injection)")
    let anima_wrote = propagate_to_anima(root, dev)

    // 2) anima -> nexus
    println("[2] anima -> nexus (seed feedback)")
    let fb_count = feedback_anima_to_seeds(root, dev)

    // 3) 흡수 상태 보고
    println("[3] anima absorb status")
    let anima = absorb_anima(dev)
    let anima_n = if anima.len() > 0 { anima.split("|").len() } else { 0 }
    println("  anima values absorbed : " + to_string(anima_n))
    println("  discoveries injected  : " + to_string(anima_wrote) + " new files")
    println("  seeds fed back        : " + to_string(fb_count))
    println("")
}

println("done.")
