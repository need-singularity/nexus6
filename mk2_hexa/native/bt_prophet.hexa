// bt_prophet.hexa -- BT 예언기 (미발견 BT 예측)
// 사용: hexa bt_prophet.hexa [help]
//
// 원리:
//   1. breakthrough-theorems.md 파싱 → 도메인별 BT 수 집계
//   2. 도메인별 BT 밀도 계산
//   3. 밀도 낮은 도메인 = "BT 공백" → 예측 후보 영역
//   4. 최근 BT 트렌드 분석 (번호 순 도메인 패턴)
//   5. 인접 도메인 패턴 기반 6개 예측 생성
//   6. growth_bus.jsonl에 예측 기록

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _bus_path = _shared + "/growth_bus.jsonl"
let _bt_path = _dev + "/n6-architecture/docs/breakthrough-theorems.md"

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

// ═══════════════════════════════════════════════════════════
// help 서브커맨드
// ═══════════════════════════════════════════════════════════

let _args = args()
if len(_args) > 1 && _args[1] == "help" {
    println("")
    println("===========================================================")
    println("  bt_prophet.hexa -- BT 예언기")
    println("===========================================================")
    println("")
    println("  사용법: hexa bt_prophet.hexa")
    println("")
    println("  기능:")
    println("    - breakthrough-theorems.md에서 BT 계보 파싱")
    println("    - 도메인별 BT 밀도 계산")
    println("    - BT 공백(밀도 낮은 도메인) 탐지")
    println("    - 최근 BT 트렌드 분석")
    println("    - 6개 BT 후보 예측 생성")
    println("    - growth_bus.jsonl에 예측 기록")
    println("")
    println("  출력:")
    println("    - 도메인별 BT 분포표")
    println("    - BT 공백 지도")
    println("    - 예측 후보 6건")
    println("")
    println("[verified] bt_prophet.hexa help")
    println("")
    exit(0)
}

// ═══════════════════════════════════════════════════════════
// BT 헤더 파싱 — "## BT-NNN: <제목>" 라인 추출
// ═══════════════════════════════════════════════════════════

fn extract_bt_headers() -> string {
    let mut result = ""
    try {
        // BT 헤더에서 번호와 제목 추출
        result = exec("grep '^## BT-' '" + _bt_path + "' | sed 's/## BT-//' | sed 's/:.*//'")
    } catch e {}
    return result
}

fn extract_bt_domains() -> string {
    let mut result = ""
    try {
        // BT 헤더에서 제목(도메인 힌트) 추출
        result = exec("grep '^## BT-' '" + _bt_path + "' | sed 's/## BT-[0-9~]*//' | sed 's/^[^:]*: //' | sed 's/ — .*//' | sed 's/ -- .*//'")
    } catch e {}
    return result
}

fn extract_bt_numbers() -> string {
    let mut result = ""
    try {
        // BT 번호만 추출 (단일 번호만, 범위 제외)
        result = exec("grep '^## BT-' '" + _bt_path + "' | sed 's/## BT-//' | sed 's/[^0-9].*//' | grep -v '^$'")
    } catch e {}
    return result
}

fn extract_table_bt() -> string {
    let mut result = ""
    try {
        // 테이블 형식 BT (| **BT-NNN** |) 에서 도메인 추출
        result = exec("grep '^| \\*\\*BT-' '" + _bt_path + "' | sed 's/.*\\*\\*BT-[0-9]*\\*\\* | //' | sed 's/ |.*//'")
    } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// 도메인 키워드 분류기
// ═══════════════════════════════════════════════════════════

fn classify_domain(title: string) -> string {
    let t = title.trim()
    if t == "" { return "기타" }

    // 한글 도메인 키워드 매핑 (빈도순)
    let keywords = [
        "양자", "핵융합", "반도체", "암호", "네트워크", "소프트웨어",
        "에너지", "물리", "수학", "생물", "화학", "의학", "건축",
        "음악", "천문", "재료", "광학", "전기", "유전", "뇌",
        "기후", "해양", "토양", "화산", "지질", "생태", "항공",
        "로봇", "언어", "경제", "농업", "식품", "심리", "교육",
        "Carbon", "Quantum", "Fusion", "SC", "Crypto", "Network",
        "Chip", "Software", "Energy", "Solar", "Battery", "Magnet",
        "Particle", "Cosmol", "Genetic", "Neural", "Scaling", "GUT",
        "CKM", "Neutrino", "Gauge", "Inflation", "Koide", "Riemann",
        "Golay", "Egyptian", "Hamming", "Bott", "Landauer", "MHD"
    ]

    let domains = [
        "양자", "핵융합", "반도체", "암호", "네트워크", "소프트웨어",
        "에너지", "물리", "수학", "생물", "화학", "의학", "건축",
        "음악", "천문", "재료", "광학", "전기", "유전", "뇌과학",
        "기후", "해양", "토양", "화산", "지질", "생태", "항공",
        "로봇", "언어학", "경제", "농업", "식품", "심리", "교육",
        "탄소화학", "양자", "핵융합", "초전도", "암호", "네트워크",
        "반도체", "소프트웨어", "에너지", "태양광", "배터리", "자석",
        "입자물리", "우주론", "유전", "신경", "스케일링", "대통일",
        "쿼크", "중성미자", "게이지", "우주론", "입자물리", "수학",
        "부호이론", "수학", "부호이론", "위상수학", "열역학", "플라즈마"
    ]

    let mut i: i64 = 0
    while i < len(keywords) {
        let kw: string = keywords[i]
        try {
            // exec 기반 문자열 포함 검사
            let check = exec("echo '" + t + "' | grep -i '" + kw + "' | wc -l").trim()
            if safe_int(check) > 0 {
                return domains[i]
            }
        } catch e {}
        i = i + 1
    }
    return t
}

// ═══════════════════════════════════════════════════════════
// MAIN
// ═══════════════════════════════════════════════════════════

println("")
println("===========================================================")
println("  BT 예언기 (BT Prophet) -- 미발견 BT 예측")
println("  BT 계보 + 시간 패턴에서 공백 영역 탐지")
println("===========================================================")
println("")

// 1. BT 총 개수
let bt_num_raw = extract_bt_numbers()
let bt_num_lines = bt_num_raw.split("\n")
let mut total_bt: i64 = 0
let mut max_bt: i64 = 0
let mut bt_numbers = []

for line in bt_num_lines {
    let num = safe_int(line)
    if num > 0 {
        total_bt = total_bt + 1
        bt_numbers = bt_numbers + [num]
        if num > max_bt { max_bt = num }
    }
}

println("  BT 총 헤더 수: " + to_string(total_bt))
println("  최대 BT 번호: BT-" + to_string(max_bt))
println("")

// 2. 도메인별 BT 집계
let domain_raw = extract_bt_domains()
let domain_lines = domain_raw.split("\n")

let mut domain_names = []
let mut domain_counts = []

for dl in domain_lines {
    let dom = classify_domain(dl)
    if dom == "" { continue }

    // 기존 도메인 검색
    let mut found = false
    let mut di: i64 = 0
    while di < len(domain_names) {
        let dn: string = domain_names[di]
        if dn == dom {
            domain_counts[di] = domain_counts[di] + 1
            found = true
        }
        di = di + 1
    }
    if !found {
        domain_names = domain_names + [dom]
        domain_counts = domain_counts + [1]
    }
}

// 테이블 BT도 추가 집계
let table_raw = extract_table_bt()
let table_lines = table_raw.split("\n")
for tl in table_lines {
    let dom = classify_domain(tl)
    if dom == "" { continue }
    let mut found = false
    let mut di: i64 = 0
    while di < len(domain_names) {
        let dn: string = domain_names[di]
        if dn == dom {
            domain_counts[di] = domain_counts[di] + 1
            found = true
        }
        di = di + 1
    }
    if !found {
        domain_names = domain_names + [dom]
        domain_counts = domain_counts + [1]
    }
}

// 3. 도메인 밀도 정렬 (버블정렬 — 내림차순)
let mut si: i64 = 0
while si < len(domain_names) - 1 {
    let mut sj: i64 = si + 1
    while sj < len(domain_names) {
        let ci: i64 = domain_counts[si]
        let cj: i64 = domain_counts[sj]
        if cj > ci {
            // swap
            let tmp_n: string = domain_names[si]
            let tmp_c: i64 = domain_counts[si]
            domain_names[si] = domain_names[sj]
            domain_counts[si] = domain_counts[sj]
            domain_names[sj] = tmp_n
            domain_counts[sj] = tmp_c
        }
        sj = sj + 1
    }
    si = si + 1
}

// 4. 도메인별 BT 분포표 출력
println("  --- 도메인별 BT 밀도 (상위 30) ---")
println("")
println("| 순위 | 도메인 | BT 수 | 밀도 막대 |")
println("|------|--------|-------|----------|")

let mut di: i64 = 0
let max_count: i64 = if len(domain_counts) > 0 { domain_counts[0] } else { 1 }
while di < len(domain_names) && di < 30 {
    let dn: string = domain_names[di]
    let dc: i64 = domain_counts[di]

    // 막대 (최대 40자)
    let bar_len = (dc * 40) / (max_count + 1)
    let mut bar = ""
    let mut bi: i64 = 0
    while bi < bar_len && bi < 40 {
        bar = bar + "#"
        bi = bi + 1
    }
    if bar == "" { bar = "." }

    println("| " + to_string(di + 1) + " | " + dn + " | " + to_string(dc) + " | " + bar + " |")
    di = di + 1
}

println("")

// 5. BT 공백 탐지 (밀도 1~2인 도메인)
println("  --- BT 공백 지도 (밀도 <=2 도메인) ---")
println("")

let mut gap_domains = []
let mut gap_counts = []
let mut gap_count: i64 = 0

di = 0
while di < len(domain_names) {
    let dc: i64 = domain_counts[di]
    if dc <= 2 {
        let dn: string = domain_names[di]
        gap_domains = gap_domains + [dn]
        gap_counts = gap_counts + [dc]
        gap_count = gap_count + 1
        if gap_count <= 20 {
            println("  공백: " + dn + " (BT " + to_string(dc) + "건)")
        }
    }
    di = di + 1
}

if gap_count > 20 {
    println("  ... 외 " + to_string(gap_count - 20) + "개 공백 도메인")
}
println("")
println("  총 공백 도메인: " + to_string(gap_count) + "개")
println("")

// 6. 최근 BT 트렌드 (마지막 50개 BT의 도메인 패턴)
println("  --- 최근 BT 트렌드 (최신 50건) ---")
println("")

let mut recent_domains_raw = ""
try {
    recent_domains_raw = exec("grep '^## BT-' '" + _bt_path + "' | tail -50 | sed 's/## BT-[0-9~]*//' | sed 's/^[^:]*: //' | sed 's/ — .*//' | sed 's/ -- .*//'")
} catch e {}

let recent_lines = recent_domains_raw.split("\n")
let mut recent_domain_names = []
let mut recent_domain_counts = []

for rl in recent_lines {
    let dom = classify_domain(rl)
    if dom == "" { continue }
    let mut found = false
    let mut ri: i64 = 0
    while ri < len(recent_domain_names) {
        let rn: string = recent_domain_names[ri]
        if rn == dom {
            recent_domain_counts[ri] = recent_domain_counts[ri] + 1
            found = true
        }
        ri = ri + 1
    }
    if !found {
        recent_domain_names = recent_domain_names + [dom]
        recent_domain_counts = recent_domain_counts + [1]
    }
}

// 최근 트렌드 정렬 (내림차순)
si = 0
while si < len(recent_domain_names) - 1 {
    let mut sj2: i64 = si + 1
    while sj2 < len(recent_domain_names) {
        let ci2: i64 = recent_domain_counts[si]
        let cj2: i64 = recent_domain_counts[sj2]
        if cj2 > ci2 {
            let tmp_n2: string = recent_domain_names[si]
            let tmp_c2: i64 = recent_domain_counts[si]
            recent_domain_names[si] = recent_domain_names[sj2]
            recent_domain_counts[si] = recent_domain_counts[sj2]
            recent_domain_names[sj2] = tmp_n2
            recent_domain_counts[sj2] = tmp_c2
        }
        sj2 = sj2 + 1
    }
    si = si + 1
}

let mut ri: i64 = 0
while ri < len(recent_domain_names) && ri < 10 {
    let rn: string = recent_domain_names[ri]
    let rc: i64 = recent_domain_counts[ri]
    println("  최근 활성: " + rn + " (" + to_string(rc) + "건)")
    ri = ri + 1
}
println("")

// ═══════════════════════════════════════════════════════════
// 7. BT 예측 생성 — 6개 후보
// ═══════════════════════════════════════════════════════════

println("  ===========================================================")
println("  BT 예측 후보 (6건)")
println("  ===========================================================")
println("")

let next_bt = max_bt + 1

// 공백 도메인에서 예측 (최대 4건)
let mut predictions = []
let mut pred_domains = []
let mut pred_reasons = []
let mut pred_count: i64 = 0

di = 0
while di < len(gap_domains) && pred_count < 4 {
    let gd: string = gap_domains[di]
    let gc: i64 = gap_counts[di]

    // 인접 도메인에서 활발한 것 찾기
    let mut adjacent = "n=6 산술"
    let mut ri2: i64 = 0
    while ri2 < len(recent_domain_names) && ri2 < 3 {
        let rn2: string = recent_domain_names[ri2]
        if rn2 != gd {
            adjacent = rn2
            ri2 = len(recent_domain_names) // break
        }
        ri2 = ri2 + 1
    }

    let bt_id = next_bt + pred_count
    let reason = "BT 밀도 " + to_string(gc) + "건 (공백), 인접 " + adjacent + " 활성"

    println("  BT-" + to_string(bt_id) + " 후보: [" + gd + "] -- " + reason)

    predictions = predictions + [bt_id]
    pred_domains = pred_domains + [gd]
    pred_reasons = pred_reasons + [reason]
    pred_count = pred_count + 1
    di = di + 1
}

// 최근 트렌드 도메인에서 추가 예측 (2건 — 활발한 영역의 확장)
ri = 0
while ri < len(recent_domain_names) && pred_count < 6 {
    let rn3: string = recent_domain_names[ri]
    let rc3: i64 = recent_domain_counts[ri]

    // 이미 예측에 포함된 도메인 건너뛰기
    let mut already = false
    for pd in pred_domains {
        if pd == rn3 { already = true }
    }

    if !already && rc3 >= 2 {
        let bt_id = next_bt + pred_count
        let reason = "최근 " + to_string(rc3) + "건 활성 트렌드, 확장 여지"

        println("  BT-" + to_string(bt_id) + " 후보: [" + rn3 + "] -- " + reason)

        predictions = predictions + [bt_id]
        pred_domains = pred_domains + [rn3]
        pred_reasons = pred_reasons + [reason]
        pred_count = pred_count + 1
    }
    ri = ri + 1
}

// 부족하면 전체 밀도 중간 도메인에서 채우기
di = len(domain_names) / 2
while pred_count < 6 && di < len(domain_names) {
    let md: string = domain_names[di]
    let mc: i64 = domain_counts[di]

    let mut already = false
    for pd in pred_domains {
        if pd == md { already = true }
    }

    if !already {
        let bt_id = next_bt + pred_count
        let reason = "중간 밀도 " + to_string(mc) + "건, 추가 발견 가능"

        println("  BT-" + to_string(bt_id) + " 후보: [" + md + "] -- " + reason)

        predictions = predictions + [bt_id]
        pred_domains = pred_domains + [md]
        pred_reasons = pred_reasons + [reason]
        pred_count = pred_count + 1
    }
    di = di + 1
}

println("")

// ═══════════════════════════════════════════════════════════
// 8. growth_bus 기록
// ═══════════════════════════════════════════════════════════

try {
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
    let mut pred_list = ""
    let mut pi: i64 = 0
    while pi < len(pred_domains) {
        if pi > 0 { pred_list = pred_list + "," }
        let pd2: string = pred_domains[pi]
        pred_list = pred_list + "\"" + pd2 + "\""
        pi = pi + 1
    }

    let entry = "{\"type\":\"bt_prophet\",\"total_bt\":" + to_string(total_bt) + ",\"max_bt\":" + to_string(max_bt) + ",\"gap_domains\":" + to_string(gap_count) + ",\"predictions\":[" + pred_list + "],\"ts\":\"" + ts + "\"}"
    exec("echo '" + entry + "' >> " + _bus_path)
} catch e {}

println("  growth_bus 기록 완료")
println("")
println("  요약: BT " + to_string(total_bt) + "건 분석, 공백 " + to_string(gap_count) + "개, 예측 " + to_string(pred_count) + "건")
println("")
println("[verified] bt_prophet.hexa 실행 완료")
println("")
