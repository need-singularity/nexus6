fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }
fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0)) / 10000.0
    to_string(r)
}
fn fmt6(x: float) -> string {
    let r = to_float(to_int(x * 1000000.0)) / 1000000.0
    to_string(r)
}
fn fmt2(x: float) -> string {
    let r = to_float(to_int(x * 100.0)) / 100.0
    to_string(r)
}
fn fmt1(x: float) -> string {
    let r = to_float(to_int(x * 10.0)) / 10.0
    to_string(r)
}

fn divisors(k: int) -> [int] {
    let mut d = []
    let mut i = 1
    while i * i <= k {
        if k % i == 0 {
            d = d + [i]
            if i != k / i { d = d + [k / i] }
        }
        i = i + 1
    }
    d.sort()
}

fn sigma_fn(k: int) -> int {
    let ds = divisors(k)
    let mut s = 0
    let mut i = 0
    while i < len(ds) {
        s = s + ds[i]
        i = i + 1
    }
    s
}

fn tau_fn(k: int) -> int { len(divisors(k)) }

fn phi_fn(k: int) -> int {
    let mut r = k
    let mut t = k
    let mut p = 2
    while p * p <= t {
        if t % p == 0 {
            while t % p == 0 { t = t / p }
            r = r - r / p
        }
        p = p + 1
    }
    if t > 1 { r = r - r / t }
    r
}

fn sopfr_fn(k: int) -> int {
    let mut s = 0
    let mut t = k
    let mut p = 2
    while p * p <= t {
        while t % p == 0 {
            s = s + p
            t = t / p
        }
        p = p + 1
    }
    if t > 1 { s = s + t }
    s
}

fn R_val(k: int) -> float {
    let s = sigma_fn(k)
    let t = tau_fn(k)
    let p = phi_fn(k)
    if t == 0 { return 0.0 }
    to_float(s * p) / to_float(k * t)
}

fn is_prime(x: int) -> bool {
    if x < 2 { return false }
    let mut i = 2
    while i * i <= x {
        if x % i == 0 { return false }
        i = i + 1
    }
    true
}

fn sigma3(k: int) -> int {
    let ds = divisors(k)
    let mut s = 0
    let mut i = 0
    while i < len(ds) {
        let d = ds[i]
        s = s + d * d * d
        i = i + 1
    }
    s
}

fn factorial(k: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= k {
        r = r * i
        i = i + 1
    }
    r
}

fn comb(n: int, k: int) -> int {
    if k < 0 || k > n { return 0 }
    let mut r = 1
    let mut i = 0
    while i < k {
        r = r * (n - i) / (i + 1)
        i = i + 1
    }
    r
}

