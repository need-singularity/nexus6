// ⛔ CORE — L0 불변식 (자기조직 설계 엔진. 수정 전 유저 승인 필수)
// mk2_hexa/native/arch_selforg.hexa — N6-ARCHITECTURE v3 자기조직 설계 엔진
//
// Self-organization engine: emergent structure from local rules only
// 6 component types | 6 interaction rules | 6 layers | cellular automata
// Pipeline: S1 Init | S2 Automata | S3 Interact | S4 Criticality | S5 Emerge | S6 Report
//
// Usage:
//   hexa arch_selforg.hexa simulate [steps]   run self-organization simulation
//   hexa arch_selforg.hexa status             show current system state
//   hexa arch_selforg.hexa help

// ─── n=6 CONSTANTS LOADER ───

fn load_n6_consts() -> list {
    let home = exec("printenv HOME")
    let path = home + "/Dev/nexus/shared/n6_constants.jsonl"
    let mut raw = ""
    try { raw = read_file(path) } catch e { return [[], []] }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let t = line.trim()
        let mut _skip = false
        if t == "" { _skip = true }
        if t != "" {
            let mut name = ""
            let mut value = 0.0
            if t.contains("\"name\":\"") {
                let p = t.split("\"name\":\"")
                if p.len() >= 2 { name = p[1].split("\"")[0] }
            }
            if t.contains("\"value\":") {
                let p = t.split("\"value\":")
                if p.len() >= 2 { value = to_float(p[1].split(",")[0].split("}")[0].trim()) }
            }
            if name != "" { names = names + [name] ; values = values + [value] }
        }
    }
    [names, values]
}

let _n6 = load_n6_consts()
let _n6_names: list = _n6[0]
let _n6_vals: list = _n6[1]
let _n6_count: i64 = len(_n6_vals)

// ─── MATH UTILITIES ───

fn sf(s: string) -> f64 { let mut v = 0.0 ; try { v = to_float(s) } catch e {} ; return v }
fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x } ; return x }
fn max_f(a: f64, b: f64) -> f64 { if a > b { return a } ; return b }
fn min_f(a: f64, b: f64) -> f64 { if a < b { return a } ; return b }
fn clamp01(x: f64) -> f64 { if x < 0.0 { return 0.0 } ; if x > 1.0 { return 1.0 } ; return x }

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = if x > 2.0 { x / 2.0 } else { 1.0 }
    let mut i: i64 = 0
    while i < 15 { g = (g + x / g) / 2.0 ; i = i + 1 }
    return g
}

fn exp_f(x: f64) -> f64 {
    if x > 20.0 { return 999999999.0 }
    if x < 0.0 - 20.0 { return 0.0 }
    let mut s = 1.0
    let mut t = 1.0
    let mut k: i64 = 1
    while k <= 30 { t = t * x / to_float(k) ; s = s + t ; k = k + 1 }
    return s
}

fn ln_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 - 999999.0 }
    let mut y = (x - 1.0) / (x + 1.0)
    let mut s = y
    let mut t = y
    let mut k: i64 = 1
    while k <= 30 { t = t * y * y ; s = s + t / to_float(2 * k + 1) ; k = k + 1 }
    return 2.0 * s
}

fn trunc4(x: f64) -> string {
    let s = to_string(x)
    let p = s.split(".")
    if p.len() < 2 { return s + ".0000" }
    let d = p[1]
    if d.len() >= 4 { return p[0] + "." + d.split("")[0] + d.split("")[1] + d.split("")[2] + d.split("")[3] }
    return s
}

fn pad(s: string, w: i64) -> string {
    let mut o = s
    while o.len() < w { o = o + " " }
    return o
}

fn ts_now() -> string {
    let mut t = ""
    try { t = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim() } catch e { t = "unknown" }
    return t
}

// ─── n=6 SELF-ORGANIZATION CONSTANTS ───

let N: i64 = 6
let GRID_SIZE: i64 = 36
let CELL_COUNT: i64 = GRID_SIZE * GRID_SIZE

// 6 component types: substrate, catalyst, membrane, signal, storage, emergent
let COMP_NAMES = ["substrate", "catalyst", "membrane", "signal", "storage", "emergent"]

// 6 interaction rules (encoded as rule index)
// R0: substrate+catalyst -> membrane   (assembly)
// R1: membrane+signal -> storage       (encapsulation)
// R2: storage+emergent -> substrate    (recycling)
// R3: catalyst+membrane -> signal      (signaling)
// R4: signal+storage -> emergent       (emergence)
// R5: emergent+substrate -> catalyst   (autocatalysis)
let RULE_FROM_A = [0, 2, 4, 1, 3, 5]
let RULE_FROM_B = [1, 3, 5, 2, 4, 0]
let RULE_PRODUCE = [2, 4, 0, 3, 5, 1]
let RULE_NAMES = ["assembly", "encapsulation", "recycling", "signaling", "emergence", "autocatalysis"]

// 6 layers of self-organization
let LAYER_NAMES = ["micro", "meso", "macro", "meta", "hyper", "omega"]
let LAYER_THRESHOLDS = [0.1, 0.25, 0.45, 0.65, 0.8, 0.95]

// Criticality thresholds (sand pile)
let CRITICAL_HEIGHT: i64 = 6
let AVALANCHE_DECAY: f64 = 0.85

// ─── S1: GRID INITIALIZATION ───
// Cellular automata grid — each cell holds a state [0..5] = component type

fn init_grid() -> list {
    let mut grid = []
    let mut i: i64 = 0
    while i < CELL_COUNT {
        // Deterministic seeding: position-based assignment mod 6
        let row: i64 = i / GRID_SIZE
        let col: i64 = i - row * GRID_SIZE
        let state: i64 = (row * 3 + col * 7 + i * 11) - ((row * 3 + col * 7 + i * 11) / N) * N
        grid = grid + [state]
        i = i + 1
    }
    return grid
}

fn init_sand_pile() -> list {
    let mut pile = []
    let mut i: i64 = 0
    while i < CELL_COUNT {
        // Start with moderate heights — some cells near critical
        let row: i64 = i / GRID_SIZE
        let col: i64 = i - row * GRID_SIZE
        let h: i64 = (row + col * 2 + i * 5) - ((row + col * 2 + i * 5) / CRITICAL_HEIGHT) * CRITICAL_HEIGHT
        pile = pile + [h]
        i = i + 1
    }
    return pile
}

// ─── S2: CELLULAR AUTOMATA STEP ───
// Each cell looks at its 4 neighbors (von Neumann), applies local rules

fn get_neighbor_idx(idx: i64, dir: i64) -> i64 {
    let row: i64 = idx / GRID_SIZE
    let col: i64 = idx - row * GRID_SIZE
    let mut nr: i64 = row
    let mut nc: i64 = col
    if dir == 0 { nr = row - 1 }
    if dir == 1 { nr = row + 1 }
    if dir == 2 { nc = col - 1 }
    if dir == 3 { nc = col + 1 }
    // Wrap around (toroidal grid)
    if nr < 0 { nr = GRID_SIZE - 1 }
    if nr >= GRID_SIZE { nr = 0 }
    if nc < 0 { nc = GRID_SIZE - 1 }
    if nc >= GRID_SIZE { nc = 0 }
    return nr * GRID_SIZE + nc
}

fn automata_step(grid: list) -> list {
    let mut new_grid = []
    let mut i: i64 = 0
    while i < CELL_COUNT {
        let my_state: i64 = grid[i]
        // Count neighbor types
        let mut counts = [0, 0, 0, 0, 0, 0]
        let mut d: i64 = 0
        while d < 4 {
            let ni: i64 = get_neighbor_idx(i, d)
            let ns: i64 = grid[ni]
            counts[ns] = counts[ns] + 1
            d = d + 1
        }
        // Apply interaction rules: check if this cell + majority neighbor triggers a rule
        let mut majority: i64 = 0
        let mut max_count: i64 = 0
        let mut r: i64 = 0
        while r < N {
            if counts[r] > max_count { max_count = counts[r] ; majority = r }
            r = r + 1
        }
        let mut new_state: i64 = my_state
        // Check all 6 rules
        let mut rule: i64 = 0
        while rule < N {
            if my_state == RULE_FROM_A[rule] {
                if majority == RULE_FROM_B[rule] {
                    if max_count >= 2 { new_state = RULE_PRODUCE[rule] }
                }
            }
            rule = rule + 1
        }
        new_grid = new_grid + [new_state]
        i = i + 1
    }
    return new_grid
}

// ─── S3: INTERACTION STATISTICS ───

fn count_types(grid: list) -> list {
    let mut counts = [0, 0, 0, 0, 0, 0]
    let mut i: i64 = 0
    while i < CELL_COUNT {
        let s: i64 = grid[i]
        counts[s] = counts[s] + 1
        i = i + 1
    }
    return counts
}

fn compute_entropy(grid: list) -> f64 {
    let counts = count_types(grid)
    let total: f64 = to_float(CELL_COUNT)
    let mut entropy: f64 = 0.0
    let mut i: i64 = 0
    while i < N {
        let p: f64 = to_float(counts[i]) / total
        if p > 0.0001 {
            entropy = entropy - p * ln_f(p)
        }
        i = i + 1
    }
    return entropy
}

fn max_entropy() -> f64 {
    // Maximum entropy = ln(6) for uniform distribution
    return ln_f(to_float(N))
}

fn order_parameter(grid: list) -> f64 {
    // Order = 1 - (entropy / max_entropy)
    // 0 = maximum disorder, 1 = perfect order
    let ent = compute_entropy(grid)
    let max_ent = max_entropy()
    if max_ent < 0.001 { return 0.0 }
    return clamp01(1.0 - ent / max_ent)
}

// ─── S4: SELF-ORGANIZED CRITICALITY (Sand Pile) ───

fn sand_pile_step(pile: list) -> list {
    let mut new_pile = []
    let mut i: i64 = 0
    // Copy pile
    while i < CELL_COUNT {
        new_pile = new_pile + [pile[i]]
        i = i + 1
    }
    // Add grain at center
    let center: i64 = (GRID_SIZE / 2) * GRID_SIZE + GRID_SIZE / 2
    new_pile[center] = new_pile[center] + 1
    // Topple until stable
    let mut unstable = true
    let mut max_iter: i64 = 0
    while unstable {
        unstable = false
        max_iter = max_iter + 1
        if max_iter > 200 { unstable = false }
        if max_iter <= 200 {
            let mut j: i64 = 0
            while j < CELL_COUNT {
                if new_pile[j] >= CRITICAL_HEIGHT {
                    unstable = true
                    let topple: i64 = new_pile[j] / 4
                    new_pile[j] = new_pile[j] - topple * 4
                    let mut d: i64 = 0
                    while d < 4 {
                        let ni: i64 = get_neighbor_idx(j, d)
                        new_pile[ni] = new_pile[ni] + topple
                        d = d + 1
                    }
                }
                j = j + 1
            }
        }
    }
    return new_pile
}

fn avalanche_size(pile_before: list, pile_after: list) -> i64 {
    let mut changed: i64 = 0
    let mut i: i64 = 0
    while i < CELL_COUNT {
        if pile_before[i] != pile_after[i] { changed = changed + 1 }
        i = i + 1
    }
    return changed
}

fn criticality_score(pile: list) -> f64 {
    // Fraction of cells near critical threshold
    let mut near_crit: i64 = 0
    let mut i: i64 = 0
    while i < CELL_COUNT {
        if pile[i] >= CRITICAL_HEIGHT - 2 { near_crit = near_crit + 1 }
        i = i + 1
    }
    return to_float(near_crit) / to_float(CELL_COUNT)
}

// ─── S5: PATTERN EMERGENCE DETECTION ───

fn detect_layer(order: f64) -> i64 {
    // Determine which self-organization layer we have reached
    let mut layer: i64 = 0
    let mut i: i64 = 0
    while i < N {
        if order >= LAYER_THRESHOLDS[i] { layer = i }
        i = i + 1
    }
    return layer
}

fn cluster_count(grid: list) -> i64 {
    // Simple cluster detection: count distinct connected regions of same type
    // (Approximation: count cells whose left neighbor differs)
    let mut boundaries: i64 = 0
    let mut i: i64 = 0
    while i < CELL_COUNT {
        let row: i64 = i / GRID_SIZE
        let col: i64 = i - row * GRID_SIZE
        if col > 0 {
            if grid[i] != grid[i - 1] { boundaries = boundaries + 1 }
        }
        if row > 0 {
            if grid[i] != grid[i - GRID_SIZE] { boundaries = boundaries + 1 }
        }
        i = i + 1
    }
    // Fewer boundaries = more clustering = fewer clusters
    let max_b: i64 = 2 * CELL_COUNT
    let cluster_est: i64 = boundaries / 6 + 1
    return cluster_est
}

fn emergence_score(order: f64, crit: f64, clusters: i64) -> f64 {
    // Combine order parameter, criticality, and cluster structure
    // High order + high criticality + low cluster count = strong emergence
    let cluster_norm: f64 = 1.0 - clamp01(to_float(clusters) / to_float(CELL_COUNT / 6))
    let score: f64 = 0.4 * order + 0.3 * crit + 0.3 * cluster_norm
    return clamp01(score)
}

fn grade_emergence(score: f64) -> string {
    if score >= 0.95 { return "EXACT" }
    if score >= 0.80 { return "STRONG" }
    if score >= 0.60 { return "CLOSE" }
    if score >= 0.40 { return "WEAK" }
    if score >= 0.20 { return "NASCENT" }
    return "NONE"
}

// ─── S6: REPORT & GROWTH BUS ───

fn emit_growth_bus(score: f64, grade: string, layer: i64, step: i64) -> bool {
    let home = exec("printenv HOME").trim()
    let bus = home + "/Dev/nexus/shared/growth_bus.jsonl"
    let ts = ts_now()
    let line = "{\"ts\":\"" + ts + "\",\"source\":\"arch_selforg\",\"event\":\"self_organization\",\"type\":\"architecture\",\"phase\":\"S5\",\"id\":\"so_emerge_" + to_string(step) + "\",\"value\":" + trunc4(score) + ",\"grade\":\"" + grade + "\",\"layer\":\"" + LAYER_NAMES[layer] + "\",\"step\":" + to_string(step) + ",\"timestamp\":\"" + ts + "\"}"
    try { exec("echo '" + line + "' >> " + bus) ; return true } catch e { return false }
}

fn print_grid_summary(grid: list, pile: list, step: i64) {
    let counts = count_types(grid)
    let ent = compute_entropy(grid)
    let ord = order_parameter(grid)
    let crit = criticality_score(pile)
    let clusters = cluster_count(grid)
    let emer = emergence_score(ord, crit, clusters)
    let grade = grade_emergence(emer)
    let layer = detect_layer(ord)

    println("")
    println("╔══════════════════════════════════════════════╗")
    println("║   N6-ARCHITECTURE v3 — Self-Organization    ║")
    println("╚══════════════════════════════════════════════╝")
    println("")
    println("  Step:         " + to_string(step))
    println("  Grid:         " + to_string(GRID_SIZE) + "x" + to_string(GRID_SIZE) + " (" + to_string(CELL_COUNT) + " cells)")
    println("")
    println("  ── Component Census ──")
    let mut c: i64 = 0
    while c < N {
        let pct: f64 = to_float(counts[c]) * 100.0 / to_float(CELL_COUNT)
        println("  [" + to_string(c) + "] " + pad(COMP_NAMES[c], 12) + to_string(counts[c]) + " (" + trunc4(pct) + "%)")
        c = c + 1
    }
    println("")
    println("  ── Dynamics ──")
    println("  Entropy:      " + trunc4(ent) + " / " + trunc4(max_entropy()))
    println("  Order:        " + trunc4(ord))
    println("  Criticality:  " + trunc4(crit))
    println("  Clusters:     ~" + to_string(clusters))
    println("  Emergence:    " + trunc4(emer) + " [" + grade + "]")
    println("  Layer:        L" + to_string(layer) + " (" + LAYER_NAMES[layer] + ")")
    println("")

    // Emit to growth_bus
    let bus_ok = emit_growth_bus(emer, grade, layer, step)
    if bus_ok { println("  [BUS] growth_bus.jsonl <- self_organization/step_" + to_string(step)) }
    if !bus_ok { println("  [BUS] WARN: failed to write growth_bus.jsonl") }
}

// ─── SIMULATE COMMAND ───

fn run_simulate(steps: i64) {
    println("")
    println("  ═══ Self-Organization Simulation ═══")
    println("  Steps: " + to_string(steps))
    println("  Grid:  " + to_string(GRID_SIZE) + "x" + to_string(GRID_SIZE))
    println("  Rules: " + to_string(N) + " interaction rules")
    println("  Layers:" + to_string(N) + " emergence layers")
    println("")

    let mut grid = init_grid()
    let mut pile = init_sand_pile()

    let mut prev_entropy = compute_entropy(grid)
    let mut entropy_decreases: i64 = 0

    let mut step: i64 = 0
    while step < steps {
        // S2: Cellular automata evolution
        grid = automata_step(grid)

        // S4: Sand pile dynamics
        let pile_before = pile
        pile = sand_pile_step(pile)
        let aval = avalanche_size(pile_before, pile)

        // S5: Track entropy changes
        let ent = compute_entropy(grid)
        let delta_ent = ent - prev_entropy
        if delta_ent < 0.0 { entropy_decreases = entropy_decreases + 1 }
        prev_entropy = ent

        let ord = order_parameter(grid)
        let layer = detect_layer(ord)

        // Progress every 6 steps (n=6 cadence)
        let report_mod: i64 = step - (step / N) * N
        if report_mod == 0 {
            println("  step " + pad(to_string(step), 6) + " entropy=" + trunc4(ent) + "  order=" + trunc4(ord) + "  avalanche=" + pad(to_string(aval), 6) + " L" + to_string(layer))
        }

        step = step + 1
    }

    println("")
    println("  ── Entropy decreased in " + to_string(entropy_decreases) + "/" + to_string(steps) + " steps (emergence signal)")
    println("")

    // Final report
    print_grid_summary(grid, pile, steps)
}

// ─── STATUS COMMAND ───

fn run_status() {
    let grid = init_grid()
    let pile = init_sand_pile()
    print_grid_summary(grid, pile, 0)

    println("")
    println("  ── Interaction Rules ──")
    let mut r: i64 = 0
    while r < N {
        println("  R" + to_string(r) + ": " + COMP_NAMES[RULE_FROM_A[r]] + " + " + COMP_NAMES[RULE_FROM_B[r]] + " -> " + COMP_NAMES[RULE_PRODUCE[r]] + "  (" + RULE_NAMES[r] + ")")
        r = r + 1
    }

    println("")
    println("  ── Emergence Layers ──")
    let mut l: i64 = 0
    while l < N {
        println("  L" + to_string(l) + ": " + pad(LAYER_NAMES[l], 8) + " (threshold >= " + trunc4(LAYER_THRESHOLDS[l]) + ")")
        l = l + 1
    }
}

// ─── HELP ───

fn run_help() {
    println("")
    println("╔══════════════════════════════════════════════╗")
    println("║   arch_selforg.hexa — Self-Organization v3  ║")
    println("╚══════════════════════════════════════════════╝")
    println("")
    println("  USAGE:")
    println("    hexa arch_selforg.hexa simulate [steps]")
    println("    hexa arch_selforg.hexa status")
    println("    hexa arch_selforg.hexa help")
    println("")
    println("  PIPELINE:")
    println("    S1 Init         36x36 grid, 6-state cells")
    println("    S2 Automata     von Neumann neighborhood rules")
    println("    S3 Interact     6 component interaction rules")
    println("    S4 Criticality  sand pile -> self-organized criticality")
    println("    S5 Emerge       entropy tracking + pattern detection")
    println("    S6 Report       summary + growth_bus.jsonl")
    println("")
    println("  COMPONENTS (n=6):")
    let mut i: i64 = 0
    while i < N {
        println("    [" + to_string(i) + "] " + COMP_NAMES[i])
        i = i + 1
    }
    println("")
    println("  RULES (n=6):")
    let mut r: i64 = 0
    while r < N {
        println("    R" + to_string(r) + ": " + COMP_NAMES[RULE_FROM_A[r]] + " + " + COMP_NAMES[RULE_FROM_B[r]] + " -> " + COMP_NAMES[RULE_PRODUCE[r]])
        r = r + 1
    }
    println("")
    println("  LAYERS (n=6):")
    let mut l: i64 = 0
    while l < N {
        println("    L" + to_string(l) + ": " + LAYER_NAMES[l] + " (>= " + trunc4(LAYER_THRESHOLDS[l]) + ")")
        l = l + 1
    }
    println("")
}

// ─── MAIN DISPATCH ───

let argv = args()
let mut cmd = "help"
if argv.len() >= 3 { cmd = argv[2] }

if cmd == "simulate" {
    let mut steps: i64 = 36
    if argv.len() >= 4 {
        try { steps = to_int(argv[3]) } catch e { steps = 36 }
    }
    if steps < 1 { steps = 1 }
    if steps > 10000 { steps = 10000 }
    run_simulate(steps)
} else if cmd == "status" {
    run_status()
} else if cmd == "help" {
    run_help()
} else {
    println("  [ERR] Unknown command: " + cmd)
    println("  Run: hexa arch_selforg.hexa help")
}
