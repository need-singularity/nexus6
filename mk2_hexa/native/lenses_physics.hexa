fn register_physics_lenses(data: list[float]) -> list[ScanEntry] {
    let mut entries = []

    entries = entries + [ScanEntry { lens_name: "light", lens_category: "physics", result: scan_light(data) }]
    entries = entries + [ScanEntry { lens_name: "light_wave", lens_category: "physics", result: scan_light_wave(data) }]
