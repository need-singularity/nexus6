println("")
println("Seq J: {n : n | lcm(sigma(n), phi(n))}")
println("  First terms: " + to_string(j_disp))
println("  Total up to " + to_string(N) + ": " + to_string(len(seq_J_ns)))

println("")
println("Seq K: Dirichlet convolution collapse")
println("  Terms: " + to_string(seq_K))

println("")
println("R(n) numerators (1..40):   " + to_string(nums))
println("R(n) denominators (1..40): " + to_string(dens))

