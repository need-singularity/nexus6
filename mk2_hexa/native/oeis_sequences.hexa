// 포팅 원본: tecs-l/math/oeis_sequences.py (376 LOC)
// OEIS-worthy sequences from R(n), D(n), arithmetic derivative, etc.
// AI-native: hexa sigma/phi/tau builtins, ranges reduced for interpreter speed

let N = 1000
let N_BIG = 5000

// ═══ helpers ═══

fn gcd_int(a: int, b: int) -> int {
    let mut x = if a < 0 { 0 - a } else { a }
    let mut y = if b < 0 { 0 - b } else { b }
    while y != 0 {
        let t = x % y
        x = y
        y = t
    }
    x
}

fn lcm_int(a: int, b: int) -> int {
    if a == 0 || b == 0 { return 0 }
    let g = gcd_int(a, b)
    (a / g) * b
}

fn is_prime(n: int) -> bool {
    if n < 2 { return false }
    if n == 2 { return true }
    if n % 2 == 0 { return false }
    let mut i = 3
    while i * i <= n {
        if n % i == 0 { return false }
        i = i + 2
    }
    true
}

fn abs_int(x: int) -> int {
    if x < 0 { 0 - x } else { x }
}

// mu(n) — Mobius function
fn mu(n: int) -> int {
    if n == 1 { return 1 }
    let mut m = n
    let mut p = 2
    let mut count = 0
    while p * p <= m {
        if m % p == 0 {
            m = m / p
            count = count + 1
            if m % p == 0 { return 0 }
        }
        p = p + 1
    }
    if m > 1 { count = count + 1 }
    if count % 2 == 0 { 1 } else { 0 - 1 }
}

// arithmetic derivative n'
fn arith_deriv(n: int) -> int {
    if n <= 1 { return 0 }
    let mut m = n
    let mut result = 0
    let mut p = 2
    while p * p <= m {
        let mut e = 0
        while m % p == 0 {
            m = m / p
            e = e + 1
        }
        if e > 0 {
            result = result + (n * e) / p
        }
        p = p + 1
    }
    if m > 1 {
        result = result + n / m
    }
    result
}

// R(n) = sigma(n)*phi(n) / (n*tau(n)) — return [num, den] reduced
fn R_frac(n: int) -> [int] {
    let num = sigma(n) * phi(n)
    let den = n * tau(n)
    let g = gcd_int(num, den)
    [num / g, den / g]
}

// D(n) = (sigma(n)*phi(n) - n^2) / tau(n) — return [num, den] reduced
fn D_frac(n: int) -> [int] {
    let s = sigma(n)
    let p = phi(n)
    let t = tau(n)
    let num = s * p - n * n
    let g = gcd_int(abs_int(num), t)
    [num / g, t / g]
}

// L(n) = lcm(sigma(n), phi(n))
fn L_val(n: int) -> int {
    lcm_int(sigma(n), phi(n))
}

// lcm of prime factors of n
fn lcm_prime_factors(n: int) -> int {
    if n <= 1 { return 1 }
    let mut m = n
    let mut result = 1
    let mut p = 2
    while p * p <= m {
        if m % p == 0 {
            result = lcm_int(result, p)
            while m % p == 0 { m = m / p }
        }
        p = p + 1
    }
    if m > 1 { result = lcm_int(result, m) }
    result
}

println("======================================================================")
println("OEIS SEQUENCE GENERATOR — R(n) and related number-theoretic functions")
println("======================================================================")
println("  Range: n = 1.." + to_string(N) + " (big sequences: 1.." + to_string(N_BIG) + ")")

// ═══ Sequence A: {n : R(n) is integer} ═══
println("")
println("======================================================================")
println("SEQUENCE A: {n : R(n) = sigma(n)*phi(n)/(n*tau(n)) is an integer}")
println("======================================================================")

let mut seq_A = []
let mut n = 1
while n <= N {
    let r = R_frac(n)
    if r[1] == 1 { seq_A = seq_A + [n] }
    n = n + 1
}

println("Count: " + to_string(len(seq_A)) + " terms for n <= " + to_string(N))
let mut disp_A = []
let mut i = 0
while i < len(seq_A) && i < 60 {
    disp_A = disp_A + [seq_A[i]]
    i = i + 1
}
println("Terms: " + to_string(disp_A))

// Show R(n) values for first 30 hits
println("")
println("First 30 with R(n) values:")
i = 0
while i < len(seq_A) && i < 30 {
    let nn = seq_A[i]
    let r = R_frac(nn)
    let line = "  n=" + to_string(nn) + "  R(n)=" + to_string(r[0]) + "  sigma=" + to_string(sigma(nn)) + "  phi=" + to_string(phi(nn)) + "  tau=" + to_string(tau(nn))
    println(line)
    i = i + 1
}

// ═══ Sequence B: {n : |D(n)| <= k} ═══
println("")
println("======================================================================")
println("SEQUENCE B: a(k) = |{n <= " + to_string(N) + " : |D(n)| <= k}|")
println("Also: {n : D(n) = 0}")
println("======================================================================")

// Compute D values
let mut D_nums = []
let mut D_dens = []
n = 0
while n <= N {
    if n == 0 {
        D_nums = D_nums + [0]
        D_dens = D_dens + [1]
    } else {
        let d = D_frac(n)
        D_nums = D_nums + [d[0]]
        D_dens = D_dens + [d[1]]
    }
    n = n + 1
}

// D(n) = 0
let mut d_zero = []
n = 1
while n <= N {
    if D_nums[n] == 0 { d_zero = d_zero + [n] }
    n = n + 1
}
println("D(n) = 0: " + to_string(d_zero))

// Count for small k
println("")
println("|{n<=" + to_string(N) + " : |D(n)| <= k}|:")
let mut k = 0
while k <= 10 {
    let mut count = 0
    let mut members = []
    n = 1
    while n <= N {
        if D_dens[n] == 1 && abs_int(D_nums[n]) <= k {
            count = count + 1
            if len(members) < 15 { members = members + [n] }
        }
        n = n + 1
    }
    let line = "  k=" + to_string(k) + ": count=" + to_string(count) + "  first: " + to_string(members)
    println(line)
    k = k + 1
}

// ═══ Sequence C: R(n) for n=1..50 ═══
println("")
println("======================================================================")
println("SEQUENCE C: R(n) = sigma(n)*phi(n)/(n*tau(n)) for n=1..50")
println("======================================================================")

n = 1
while n <= 50 {
    let r = R_frac(n)
    let s = sigma(n)
    let p = phi(n)
    let t = tau(n)
    let frac_str = to_string(r[0]) + "/" + to_string(r[1])
    let line = "  n=" + to_string(n) + "  sigma=" + to_string(s) + "  phi=" + to_string(p) + "  tau=" + to_string(t) + "  R(n)=" + frac_str
    println(line)
    n = n + 1
}

// ═══ Sequence D: {n : tau(sigma(n)) = n} ═══
println("")
println("======================================================================")
println("SEQUENCE D: {n : tau(sigma(n)) = n}")
println("======================================================================")

let mut seq_D = []
n = 1
while n <= N {
    if tau(sigma(n)) == n { seq_D = seq_D + [n] }
    n = n + 1
}

println("Terms up to " + to_string(N) + ": " + to_string(seq_D))
i = 0
while i < len(seq_D) {
    let nn = seq_D[i]
    let s = sigma(nn)
    let line = "  n=" + to_string(nn) + ": sigma(" + to_string(nn) + ")=" + to_string(s) + ", tau(" + to_string(s) + ")=" + to_string(tau(s))
    println(line)
    i = i + 1
}

// First 40 values of tau(sigma(n))
println("")
println("First 40 values of tau(sigma(n)):")
let mut ts_vals = []
n = 1
while n <= 40 {
    ts_vals = ts_vals + [tau(sigma(n))]
    n = n + 1
}
println("  " + to_string(ts_vals))

// ═══ Sequence E: {n : mu(n)*sigma(n) = 2n} ═══
println("")
println("======================================================================")
println("SEQUENCE E: {n : mu(n)*sigma(n) = 2n}")
println("======================================================================")

let mut seq_E = []
n = 1
while n <= N {
    let m = mu(n)
    let s = sigma(n)
    if m * s == 2 * n {
        seq_E = seq_E + [n]
        let line = "  n=" + to_string(n) + ": mu=" + to_string(m) + ", sigma=" + to_string(s) + ", 2n=" + to_string(2 * n)
        println(line)
    }
    n = n + 1
}
println("Terms up to " + to_string(N) + ": " + to_string(seq_E))

// ═══ Sequence F: {n : phi(n)^2 = tau(n)} ═══
println("")
println("======================================================================")
println("SEQUENCE F: {n : phi(n)^2 = tau(n)}")
println("======================================================================")

let mut seq_F = []
n = 1
while n <= N_BIG {
    let p = phi(n)
    let t = tau(n)
    if p * p == t { seq_F = seq_F + [n] }
    n = n + 1
}
println("Terms up to " + to_string(N_BIG) + ": " + to_string(seq_F))
i = 0
while i < len(seq_F) {
    let nn = seq_F[i]
    let line = "  n=" + to_string(nn) + ": phi=" + to_string(phi(nn)) + ", tau=" + to_string(tau(nn)) + ", phi^2=" + to_string(phi(nn) * phi(nn))
    println(line)
    i = i + 1
}

// ═══ Sequence G: D-spectrum ═══
println("")
println("======================================================================")
println("SEQUENCE G: D-spectrum — sorted distinct integer D(n) for n=1.." + to_string(N))
println("======================================================================")

let mut d_int_set = #{}
n = 1
while n <= N {
    if D_dens[n] == 1 {
        let key = to_string(D_nums[n])
        d_int_set[key] = D_nums[n]
    }
    n = n + 1
}

let mut d_vals_list = values(d_int_set)
d_vals_list = d_vals_list.sort()
println("Number of distinct integer D(n) values: " + to_string(len(d_vals_list)))

let mut non_neg = []
let mut neg_vals = []
i = 0
while i < len(d_vals_list) {
    let v = d_vals_list[i]
    if v >= 0 && len(non_neg) < 50 { non_neg = non_neg + [v] }
    if v < 0 && len(neg_vals) < 30 { neg_vals = neg_vals + [v] }
    i = i + 1
}
println("First 50 non-negative: " + to_string(non_neg))
println("First 30 negative: " + to_string(neg_vals))

// Non-integer D(n) for n<=100
let mut non_int_count = 0
n = 1
while n <= 100 {
    if D_dens[n] != 1 {
        non_int_count = non_int_count + 1
        if non_int_count <= 20 {
            let line = "  D(" + to_string(n) + ") = " + to_string(D_nums[n]) + "/" + to_string(D_dens[n])
            println(line)
        }
    }
    n = n + 1
}
println("Non-integer D(n) for n<=100: " + to_string(non_int_count) + " cases")

// ═══ Sequence H: {n : sigma(n) = 2*lcm(prime factors)} ═══
println("")
println("======================================================================")
println("SEQUENCE H: {n : sigma(n) = 2*lcm(prime factors of n)}")
println("======================================================================")

let mut seq_H = []
n = 1
while n <= N {
    let lp = lcm_prime_factors(n)
    if sigma(n) == 2 * lp {
        seq_H = seq_H + [n]
        println("  n=" + to_string(n) + ": sigma=" + to_string(sigma(n)) + ", lcm_pf=" + to_string(lp))
    }
    n = n + 1
}
println("Terms up to " + to_string(N) + ": " + to_string(seq_H))

// ═══ Sequence I: {n : n' = n-1} (arithmetic derivative) ═══
println("")
println("======================================================================")
println("SEQUENCE I: {n : n' = n-1} (arithmetic derivative)")
println("Known: A054377 — primary pseudoperfect numbers")
println("======================================================================")

let mut seq_I = []
n = 1
while n <= N_BIG {
    if arith_deriv(n) == n - 1 { seq_I = seq_I + [n] }
    n = n + 1
}
println("Terms up to " + to_string(N_BIG) + ": " + to_string(seq_I))
println("Known A054377: 2, 6, 42, 1806, 47058, ...")

// ═══ Sequence J: {n : n | lcm(sigma(n), phi(n))} ═══
println("")
println("======================================================================")
println("SEQUENCE J: {n : lcm(sigma(n), phi(n)) / n is a positive integer}")
println("======================================================================")

let mut seq_J = []
let mut seq_J_ns = []
n = 1
while n <= N {
    let ln = L_val(n)
    if ln % n == 0 {
        let kv = ln / n
        seq_J = seq_J + [[n, kv]]
        seq_J_ns = seq_J_ns + [n]
    }
    n = n + 1
}

println("Count up to " + to_string(N) + ": " + to_string(len(seq_J)))
println("Terms (n, L(n)/n):")
i = 0
while i < len(seq_J) && i < 40 {
    let pair = seq_J[i]
    let nn = pair[0]
    let kv = pair[1]
    let line = "  n=" + to_string(nn) + "  L(n)/n=" + to_string(kv) + "  sigma=" + to_string(sigma(nn)) + "  phi=" + to_string(phi(nn)) + "  L(n)=" + to_string(L_val(nn))
    println(line)
    i = i + 1
}

let mut disp_J = []
i = 0
while i < len(seq_J_ns) && i < 40 {
    disp_J = disp_J + [seq_J_ns[i]]
    i = i + 1
}
println("")
println("Just the n values (first 40): " + to_string(disp_J))

// ═══ Sequence K: Dirichlet convolution collapse ═══
println("")
println("======================================================================")
println("SEQUENCE K: Dirichlet convolution (sigma * phi)(n) vs sigma(n)*phi(n)")
println("======================================================================")

fn dirichlet_conv_sp(n: int) -> int {
    let mut total = 0
    let mut d = 1
    while d <= n {
        if n % d == 0 {
            total = total + sigma(d) * phi(n / d)
        }
        d = d + 1
    }
    total
}

let mut seq_K = []
let N_K = 100
n = 1
while n <= N_K {
    let conv = dirichlet_conv_sp(n)
    let prod = sigma(n) * phi(n)
    let eq = conv == prod
    if n <= 30 || eq {
        let eq_str = if eq { "YES" } else { "" }
        let line = "  n=" + to_string(n) + "  conv=" + to_string(conv) + "  prod=" + to_string(prod) + "  " + eq_str
        println(line)
    }
    if eq { seq_K = seq_K + [n] }
    n = n + 1
}

println("Convolution collapse points up to " + to_string(N_K) + ": " + to_string(seq_K))

// ═══ BONUS SEQUENCES ═══
println("")
println("======================================================================")
println("BONUS SEQUENCES")
println("======================================================================")

// B1: {n : sigma(n)*phi(n) mod n^2 = 0, not prime}
println("")
println("--- B1: {n : sigma(n)*phi(n) mod n^2 = 0, not prime} ---")
let mut seq_B1 = []
n = 1
while n <= N {
    let sp = sigma(n) * phi(n)
    if sp % (n * n) == 0 && !is_prime(n) {
        seq_B1 = seq_B1 + [n]
    }
    n = n + 1
}
let mut disp_B1 = []
i = 0
while i < len(seq_B1) && i < 40 {
    disp_B1 = disp_B1 + [seq_B1[i]]
    i = i + 1
}
println("Terms: " + to_string(disp_B1))

// B2: R(n) numerators and denominators
println("")
println("--- B2: Numerator/Denominator of R(n) for n=1..40 ---")
let mut nums = []
let mut dens = []
n = 1
while n <= 40 {
    let r = R_frac(n)
    nums = nums + [r[0]]
    dens = dens + [r[1]]
    n = n + 1
}
println("Numerators:   " + to_string(nums))
println("Denominators: " + to_string(dens))

// B3: {n : R(n) = R(n+1)}
println("")
println("--- B3: {n : R(n) = R(n+1)} ---")
let mut seq_B3 = []
n = 1
while n < N {
    let r1 = R_frac(n)
    let r2 = R_frac(n + 1)
    if r1[0] == r2[0] && r1[1] == r2[1] {
        seq_B3 = seq_B3 + [n]
        let line = "  R(" + to_string(n) + ") = R(" + to_string(n + 1) + ") = " + to_string(r1[0]) + "/" + to_string(r1[1])
        println(line)
    }
    n = n + 1
}
println("Terms: " + to_string(seq_B3))

// B4: Record values of R(n) — track as fraction (num, den)
println("")
println("--- B4: Record values of R(n) (new maximum) ---")
let mut max_num = 0
let mut max_den = 1
let mut records = []
n = 1
while n <= N {
    let r = R_frac(n)
    // compare r.0/r.1 > max_num/max_den  =>  r.0*max_den > max_num*r.1
    if r[0] * max_den > max_num * r[1] {
        max_num = r[0]
        max_den = r[1]
        records = records + [[n, r[0], r[1]]]
    }
    n = n + 1
}

println("First 20 records:")
i = 0
while i < len(records) && i < 20 {
    let rec = records[i]
    let line = "  n=" + to_string(rec[0]) + "  R(n)=" + to_string(rec[1]) + "/" + to_string(rec[2])
    println(line)
    i = i + 1
}

