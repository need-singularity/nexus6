                note = "R=1, p=1/6 <- SELF"
            }
            if k == 2 {
                note = "p=R/2=" + fmt4(rval / 2.0)
            }
            if k == 28 {
                note = "p=R/28=" + fmt4(rval / 28.0)
            }
            let rstr = frac_str(rn, rd)
            println("  " + to_string(k) + "\t" + rstr + "\t" + fmt6(p_val) + "\t" + fmt4(fisher) + "\t" + note)
        }
    }
    fki = fki + 1
}

