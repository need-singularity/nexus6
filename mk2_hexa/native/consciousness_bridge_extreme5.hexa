// Matrix-vector multiply for 4x4
fn mat_vec(m: any, v: any) -> any {
    let r0 = m[0]*v[0] + m[1]*v[1] + m[2]*v[2] + m[3]*v[3]
    let r1 = m[4]*v[0] + m[5]*v[1] + m[6]*v[2] + m[7]*v[3]
    let r2 = m[8]*v[0] + m[9]*v[1] + m[10]*v[2] + m[11]*v[3]
    let r3 = m[12]*v[0] + m[13]*v[1] + m[14]*v[2] + m[15]*v[3]
    [r0, r1, r2, r3]
}

// Build step matrix: S = I - 0.01*L
let step_mat = [
    1.0 - 0.01*3.0,  0.0 + 0.01*1.0,  0.0 + 0.01*1.0,  0.0 + 0.01*1.0,
    0.0 + 0.01*1.0,  1.0 - 0.01*2.0,  0.0 - 0.01*0.0,  0.0 + 0.01*1.0,
    0.0 + 0.01*1.0,  0.0 - 0.01*0.0,  1.0 - 0.01*2.0,  0.0 + 0.01*1.0,
    0.0 + 0.01*1.0,  0.0 + 0.01*1.0,  0.0 + 0.01*1.0,  1.0 - 0.01*3.0
]

let time_steps = [10, 50, 100, 200]
