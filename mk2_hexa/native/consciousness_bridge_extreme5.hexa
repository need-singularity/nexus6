// ─── 헬퍼 함수 ───
fn abs_f(x: float) -> float {
    if x < 0.0 { 0.0 - x } else { x }
}

fn divisors(k: int) -> [int] {
    let mut d = []
    let mut i = 1
    while i * i <= k {
        if k % i == 0 {
            d = d.push(i)
            if i != k / i {
                d = d.push(k / i)
            }
        }
        i = i + 1
    }
    d.sort()
}

fn sigma_fn(k: int) -> int {
    let ds = divisors(k)
    let mut s = 0
    let mut i = 0
    while i < len(ds) {
        s = s + ds[i]
        i = i + 1
    }
    s
}

fn tau_fn(k: int) -> int {
    len(divisors(k))
}

fn phi_fn(k: int) -> int {
    let mut r = k
    let mut t = k
    let mut p = 2
    while p * p <= t {
        if t % p == 0 {
            while t % p == 0 {
                t = t / p
            }
            r = r - r / p
        }
        p = p + 1
    }
    if t > 1 {
        r = r - r / t
    }
    r
}

fn sopfr_fn(k: int) -> int {
    let mut s = 0
    let mut t = k
    let mut p = 2
    while p * p <= t {
        while t % p == 0 {
            s = s + p
            t = t / p
        }
        p = p + 1
    }
    if t > 1 {
        s = s + t
    }
    s
}

fn R_num(k: int) -> int {
    sigma_fn(k) * phi_fn(k)
}

fn R_den(k: int) -> int {
    k * tau_fn(k)
}

fn R_float(k: int) -> float {
    to_float(R_num(k)) / to_float(R_den(k))
}

fn frac_str(num: int, den: int) -> string {
    let g = gcd(num, den)
    to_string(num / g) + "/" + to_string(den / g)
}

fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0)) / 10000.0
    to_string(r)
}

fn fmt3(x: float) -> string {
    let r = to_float(to_int(x * 1000.0)) / 1000.0
    to_string(r)
}

fn fmt6(x: float) -> string {
    let r = to_float(to_int(x * 1000000.0)) / 1000000.0
    to_string(r)
}

fn fmt1(x: float) -> string {
    let r = to_float(to_int(x * 10.0)) / 10.0
    to_string(r)
}

fn fmt2(x: float) -> string {
    let r = to_float(to_int(x * 100.0)) / 100.0
    to_string(r)
}

fn repeat_str(s: string, n: int) -> string {
    let mut out = ""
    let mut i = 0
    while i < n {
        out = out + s
        i = i + 1
    }
    out
}

fn fib(k: int) -> int {
    let mut a = 0
    let mut b = 1
    let mut i = 0
    while i < k {
        let tmp = b
        b = a + b
        a = tmp
        i = i + 1
    }
    a
}

