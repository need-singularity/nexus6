let mut ti = 0
while ti < len(time_steps) {
    let steps = time_steps[ti]
    let mut p = [0.25, 0.25, 0.25, 0.25]
    let mut si = 0
    while si < steps {
        p = mat_vec(step_mat, p)
        si = si + 1
    }
    // normalize
    let psum = p[0] + p[1] + p[2] + p[3]
    let p0n = p[0] / psum
    let p1n = p[1] / psum
    let p2n = p[2] / psum
    let p3n = p[3] / psum
    println("  t=" + time_labels[ti] + ": [" + fmt3(p0n) + ", " + fmt3(p1n) + ", " + fmt3(p2n) + ", " + fmt3(p3n) + "]")
    ti = ti + 1
}

