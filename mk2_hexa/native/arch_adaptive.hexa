// mk2_hexa/native/arch_adaptive.hexa — N6-ARCHITECTURE v4 진화적 설계 엔진
// Adaptive self-modifying system: architecture responds to environment changes
// Fitness landscape with 6 dimensions, architecture evolves to maximize
// CLI: hexa arch_adaptive.hexa adapt [env] | status | help

// ═══════════════════════════════════════════════════════════
// ─── n=6 CONSTANTS & PATHS ───
// ═══════════════════════════════════════════════════════════

let _home = exec("printenv HOME").trim()
let _shared = _home + "/Dev/nexus/shared"
let _bus_path = _shared + "/growth_bus.jsonl"
let _arch_state_path = _shared + "/arch_adaptive_state.json"
let _n6_path = _shared + "/n6_constants.jsonl"

comptime const N = 6
comptime const TOLERANCE = 0.001
comptime const MAX_GENERATIONS = 6
comptime const MUTATION_RATE = 0.15
comptime const ELITE_RATIO = 0.33
comptime const CONVERGENCE_TH = 0.95

// ─── 6 Adaptation Strategies ─────────────────────────────
// 0: structural — reshape module boundaries
// 1: parametric — tune internal weights
// 2: topological — rewire connections
// 3: evolutionary — generational selection
// 4: reactive — immediate response to pressure
// 5: anticipatory — predictive pre-adaptation

let STRATEGY_NAMES = ["structural", "parametric", "topological", "evolutionary", "reactive", "anticipatory"]

// ─── 6 Fitness Metrics ───────────────────────────────────
// 0: coherence — internal consistency
// 1: coverage — domain breadth
// 2: depth — analytical depth
// 3: resilience — robustness under perturbation
// 4: efficiency — resource utilization
// 5: novelty — discovery of new patterns

let FITNESS_NAMES = ["coherence", "coverage", "depth", "resilience", "efficiency", "novelty"]

// ─── 6 Environment Types ─────────────────────────────────
// 0: stable — low change rate
// 1: volatile — rapid fluctuations
// 2: adversarial — hostile conditions
// 3: cooperative — synergistic context
// 4: sparse — limited data/signal
// 5: saturated — information overload

let ENV_NAMES = ["stable", "volatile", "adversarial", "cooperative", "sparse", "saturated"]

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════

pure fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }
pure fn max_f(a: float, b: float) -> float { if a > b { a } else { b } }
pure fn min_f(a: float, b: float) -> float { if a < b { a } else { b } }
fn safe_float(s: string) -> float { let mut v = 0.0; try { v = to_float(s) } catch e {}; v }
fn now_ts() -> string { exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim() }

fn pseudo_rand(seed: int, bound: int) -> int {
    let mut h = seed * 2654435761
    if h < 0 { h = 0 - h }
    h % bound
}

fn pseudo_rand_f(seed: int) -> float {
    let mut h = seed * 2654435761
    if h < 0 { h = 0 - h }
    let r = h % 10000
    to_float(r) / 10000.0
}

// ─── JSON field extractor ────────────────────────────────

pure fn xf(line: string, field: string) -> string {
    let needle = "\"" + field + "\":"
    if !line.contains(needle) { return "" }
    let after = line.split(needle)
    if after.len() < 2 { return "" }
    let rest = after[1].trim()
    if rest.starts_with("\"") {
        let parts = rest.split("\"")
        if parts.len() >= 2 { return parts[1] }
    }
    let mut result = ""
    let mut i = 0
    while i < rest.len() {
        let ch = rest[i]
        if ch == "," || ch == "}" || ch == " " || ch == "]" { return result }
        result = result + ch
        i = i + 1
    }
    result
}

// ─── n=6 Constants loader ────────────────────────────────

fn load_n6() -> list {
    let mut raw = ""
    try { raw = read_file(_n6_path) } catch e { return [[], []] }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let t = line.trim()
        if t == "" { break }
        let mut name = ""
        let mut value = 0.0
        if t.contains("\"name\":\"") {
            let p = t.split("\"name\":\"")
            if p.len() >= 2 { name = p[1].split("\"")[0] }
        }
        if t.contains("\"value\":") {
            let p = t.split("\"value\":")
            if p.len() >= 2 { value = to_float(p[1].split(",")[0].split("}")[0].trim()) }
        }
        if name != "" { names = names + [name]; values = values + [value] }
    }
    [names, values]
}

let _n6 = load_n6()
let _n6_names: list = _n6[0]
let _n6_vals: list = _n6[1]
let _n6_count = len(_n6_vals)

fn n6_distance(value: float) -> float {
    let mut d = 1.0
    let mut i = 0
    while i < _n6_count {
        let cv = to_float(_n6_vals[i])
        let dd = abs_f(value - cv) / max_f(abs_f(cv), 1.0)
        d = min_f(d, dd)
        i = i + 1
    }
    min_f(d, 1.0)
}

fn n6_grade(value: float) -> string {
    let d = n6_distance(value)
    if d < 0.0001 { return "EXACT" }
    if d < 0.01 { return "NEAR" }
    if d < 0.05 { return "CLOSE" }
    "MISS"
}

// ═══════════════════════════════════════════════════════════
// ─── FITNESS LANDSCAPE ───
// ═══════════════════════════════════════════════════════════

struct FitnessVector {
    coherence: float,
    coverage: float,
    depth: float,
    resilience: float,
    efficiency: float,
    novelty: float
}

fn make_fitness(c: float, cov: float, d: float, r: float, e: float, n: float) -> FitnessVector {
    FitnessVector {
        coherence: min_f(1.0, max_f(0.0, c)),
        coverage: min_f(1.0, max_f(0.0, cov)),
        depth: min_f(1.0, max_f(0.0, d)),
        resilience: min_f(1.0, max_f(0.0, r)),
        efficiency: min_f(1.0, max_f(0.0, e)),
        novelty: min_f(1.0, max_f(0.0, n))
    }
}

fn fitness_total(f: FitnessVector) -> float {
    (f.coherence + f.coverage + f.depth + f.resilience + f.efficiency + f.novelty) / 6.0
}

fn fitness_to_str(f: FitnessVector) -> string {
    "coh=" + to_string(f.coherence) + " cov=" + to_string(f.coverage) + " dep=" + to_string(f.depth) + " res=" + to_string(f.resilience) + " eff=" + to_string(f.efficiency) + " nov=" + to_string(f.novelty)
}

fn fitness_dim(f: FitnessVector, idx: int) -> float {
    if idx == 0 { return f.coherence }
    if idx == 1 { return f.coverage }
    if idx == 2 { return f.depth }
    if idx == 3 { return f.resilience }
    if idx == 4 { return f.efficiency }
    f.novelty
}

fn fitness_weakest(f: FitnessVector) -> int {
    let mut worst_idx = 0
    let mut worst_val = f.coherence
    let mut i = 1
    while i < N {
        let v = fitness_dim(f, i)
        if v < worst_val { worst_val = v; worst_idx = i }
        i = i + 1
    }
    worst_idx
}

// ═══════════════════════════════════════════════════════════
// ─── ENVIRONMENT SENSING ───
// ═══════════════════════════════════════════════════════════

struct Environment {
    env_type: string,
    pressure: float,
    change_rate: float,
    signal_density: float,
    hostility: float,
    opportunity: float
}

fn detect_environment(env_name: string) -> Environment {
    let ts_hash = safe_float(exec("date +%S").trim())
    let mut pressure = 0.5
    let mut change_rate = 0.3
    let mut signal_density = 0.5
    let mut hostility = 0.1
    let mut opportunity = 0.5

    if env_name == "stable" {
        pressure = 0.2; change_rate = 0.1; signal_density = 0.6; hostility = 0.05; opportunity = 0.4
    }
    if env_name == "volatile" {
        pressure = 0.8; change_rate = 0.9; signal_density = 0.7; hostility = 0.3; opportunity = 0.7
    }
    if env_name == "adversarial" {
        pressure = 0.9; change_rate = 0.5; signal_density = 0.4; hostility = 0.9; opportunity = 0.2
    }
    if env_name == "cooperative" {
        pressure = 0.3; change_rate = 0.4; signal_density = 0.8; hostility = 0.05; opportunity = 0.9
    }
    if env_name == "sparse" {
        pressure = 0.6; change_rate = 0.2; signal_density = 0.1; hostility = 0.2; opportunity = 0.3
    }
    if env_name == "saturated" {
        pressure = 0.7; change_rate = 0.6; signal_density = 1.0; hostility = 0.15; opportunity = 0.6
    }

    // small stochastic perturbation
    let jitter = (ts_hash % 10.0) / 100.0
    pressure = min_f(1.0, pressure + jitter)

    Environment {
        env_type: env_name, pressure: pressure,
        change_rate: change_rate, signal_density: signal_density,
        hostility: hostility, opportunity: opportunity
    }
}

fn env_to_str(e: Environment) -> string {
    "type=" + e.env_type + " press=" + to_string(e.pressure) + " chg=" + to_string(e.change_rate) + " sig=" + to_string(e.signal_density) + " host=" + to_string(e.hostility) + " opp=" + to_string(e.opportunity)
}

// ═══════════════════════════════════════════════════════════
// ─── ADAPTATION STRATEGIES ───
// ═══════════════════════════════════════════════════════════

fn select_strategy(env: Environment, current_fitness: FitnessVector) -> int {
    // Strategy selection based on environment + fitness weaknesses
    let weak = fitness_weakest(current_fitness)

    if env.hostility > 0.7 { return 4 }       // reactive for adversarial
    if env.change_rate > 0.7 { return 5 }      // anticipatory for volatile
    if env.signal_density < 0.2 { return 1 }   // parametric for sparse
    if env.opportunity > 0.8 { return 2 }       // topological for cooperative

    // fallback: evolutionary for depth, structural for coherence
    if weak == 2 { return 3 }
    if weak == 0 { return 0 }

    // default: evolutionary
    3
}

fn apply_strategy(strat_idx: int, fitness: FitnessVector, env: Environment, gen: int) -> FitnessVector {
    let seed = gen * 17 + strat_idx * 31
    let delta = MUTATION_RATE * (1.0 + env.pressure)
    let jitter = pseudo_rand_f(seed) * delta

    if strat_idx == 0 {
        // structural: boost coherence + resilience
        return make_fitness(fitness.coherence + jitter * 0.6, fitness.coverage + jitter * 0.1, fitness.depth + jitter * 0.1, fitness.resilience + jitter * 0.5, fitness.efficiency + jitter * 0.2, fitness.novelty - jitter * 0.1)
    }
    if strat_idx == 1 {
        // parametric: boost efficiency + depth
        return make_fitness(fitness.coherence + jitter * 0.1, fitness.coverage + jitter * 0.2, fitness.depth + jitter * 0.5, fitness.resilience + jitter * 0.1, fitness.efficiency + jitter * 0.6, fitness.novelty + jitter * 0.1)
    }
    if strat_idx == 2 {
        return make_fitness(fitness.coherence - jitter * 0.1, fitness.coverage + jitter * 0.6, fitness.depth + jitter * 0.2, fitness.resilience + jitter * 0.1, fitness.efficiency + jitter * 0.1, fitness.novelty + jitter * 0.5)
    }
    if strat_idx == 3 {
        return make_fitness(fitness.coherence + jitter * 0.3, fitness.coverage + jitter * 0.3, fitness.depth + jitter * 0.3, fitness.resilience + jitter * 0.3, fitness.efficiency + jitter * 0.3, fitness.novelty + jitter * 0.3)
    }
    if strat_idx == 4 {
        return make_fitness(fitness.coherence + jitter * 0.5, fitness.coverage + jitter * 0.1, fitness.depth + jitter * 0.1, fitness.resilience + jitter * 0.7, fitness.efficiency + jitter * 0.3, fitness.novelty - jitter * 0.2)
    }
    // 5: anticipatory: boost novelty + coverage, preemptive
    make_fitness(fitness.coherence + jitter * 0.2, fitness.coverage + jitter * 0.5, fitness.depth + jitter * 0.3, fitness.resilience + jitter * 0.2, fitness.efficiency + jitter * 0.1, fitness.novelty + jitter * 0.6)
}

// ═══════════════════════════════════════════════════════════
// ─── GROWTH BUS OUTPUT ───
// ═══════════════════════════════════════════════════════════

fn emit_bus(event: string, domain: string, value: float, phase: string, id: string) -> bool {
    let ts = now_ts()
    let grade = n6_grade(value)
    let line = "{\"ts\":\"" + ts + "\",\"source\":\"arch_adaptive\"" + ",\"event\":\"" + event + "\",\"domain\":\"" + domain + "\",\"type\":\"adaptation\"" + ",\"phase\":\"" + phase + "\",\"id\":\"" + id + "\",\"value\":" + to_string(value) + ",\"grade\":\"" + grade + "\"}"
    let mut ok = false
    try { exec("echo '" + line + "' >> " + _bus_path); ok = true } catch e {
        println("[WARN] bus write failed: " + to_string(e))
    }
    ok
}

// ═══════════════════════════════════════════════════════════
// ─── ADAPTATION ENGINE (6-generation loop) ───
// ═══════════════════════════════════════════════════════════

fn run_adaptation(env_name: string) -> bool {
    println("=== N6-ARCHITECTURE v4 :: Adaptive Engine ===")
    println("")

    // Detect environment
    let env = detect_environment(env_name)
    println("[ENV] " + env_to_str(env))
    println("")

    // Initialize fitness from bus history or defaults
    let mut fitness = make_fitness(0.5, 0.4, 0.45, 0.5, 0.55, 0.3)

    // Try to load last state
    let mut loaded_state = false
    try {
        let state_raw = read_file(_arch_state_path)
        if state_raw.contains("\"coherence\":") {
            fitness = make_fitness(safe_float(xf(state_raw, "coherence")), safe_float(xf(state_raw, "coverage")), safe_float(xf(state_raw, "depth")), safe_float(xf(state_raw, "resilience")), safe_float(xf(state_raw, "efficiency")), safe_float(xf(state_raw, "novelty")))
            loaded_state = true
        }
    } catch e {}
    if loaded_state { println("[STATE] loaded previous fitness") }

    println("[INIT] fitness total=" + to_string(fitness_total(fitness)))
    println("[INIT] " + fitness_to_str(fitness))
    println("")

    // 6-generation adaptation loop
    let mut gen = 0
    let mut best_total = fitness_total(fitness)
    let mut strat_counts = [0, 0, 0, 0, 0, 0]

    while gen < MAX_GENERATIONS {
        println("--- Generation " + to_string(gen + 1) + "/" + to_string(MAX_GENERATIONS) + " ---")

        // Select strategy
        let strat = select_strategy(env, fitness)
        strat_counts[strat] = strat_counts[strat] + 1
        println("  strategy: " + STRATEGY_NAMES[strat])

        // Apply strategy
        let new_fitness = apply_strategy(strat, fitness, env, gen)
        let new_total = fitness_total(new_fitness)

        // Selection: keep if improved
        if new_total >= best_total {
            fitness = new_fitness
            best_total = new_total
            println("  fitness: " + to_string(new_total) + " [improved]")
        } else {
            // partial acceptance: keep if within elite ratio threshold
            let delta = best_total - new_total
            if delta < ELITE_RATIO * MUTATION_RATE {
                fitness = new_fitness
                best_total = new_total
                println("  fitness: " + to_string(new_total) + " [accepted-drift]")
            } else {
                println("  fitness: " + to_string(new_total) + " [rejected, kept " + to_string(best_total) + "]")
            }
        }

        // Emit to growth bus
        let gen_id = "arch_g" + to_string(gen + 1) + "_" + env_name
        emit_bus("adapt_gen_" + to_string(gen + 1), env_name, best_total * N, "gen" + to_string(gen + 1), gen_id)

        // Check convergence
        if best_total >= CONVERGENCE_TH {
            println("  [CONVERGED] fitness >= " + to_string(CONVERGENCE_TH))
            gen = MAX_GENERATIONS
        }

        gen = gen + 1
    }

    println("")
    println("=== Adaptation Results ===")
    println("[FINAL] " + fitness_to_str(fitness))
    println("[FINAL] total=" + to_string(best_total))
    println("[ENV]   " + env_name)

    // n=6 resonance check: does total*6 approach n6 constant?
    let scaled = best_total * 6.0
    let grade = n6_grade(scaled)
    println("[N6]    scaled=" + to_string(scaled) + " grade=" + grade)
    println("")

    // Strategy usage summary
    println("[STRATEGIES]")
    let mut si = 0
    while si < N {
        if strat_counts[si] > 0 {
            println("  " + STRATEGY_NAMES[si] + ": " + to_string(strat_counts[si]) + "x")
        }
        si = si + 1
    }

    // Weakest dimension report
    let weak = fitness_weakest(fitness)
    println("")
    println("[RECOMMEND] strengthen: " + FITNESS_NAMES[weak] + " (=" + to_string(fitness_dim(fitness, weak)) + ")")

    // Save state
    let state_json = "{\"coherence\":" + to_string(fitness.coherence) + ",\"coverage\":" + to_string(fitness.coverage) + ",\"depth\":" + to_string(fitness.depth) + ",\"resilience\":" + to_string(fitness.resilience) + ",\"efficiency\":" + to_string(fitness.efficiency) + ",\"novelty\":" + to_string(fitness.novelty) + ",\"env\":\"" + env_name + "\",\"total\":" + to_string(best_total) + ",\"ts\":\"" + now_ts() + "\"}"
    try { write_file(_arch_state_path, state_json) } catch e {
        println("[WARN] state save failed")
    }

    // Final bus emit: summary
    emit_bus("adapt_complete", env_name, scaled, "final", "arch_final_" + env_name)
    true
}

// ═══════════════════════════════════════════════════════════
// ─── STATUS COMMAND ───
// ═══════════════════════════════════════════════════════════

fn run_status() -> bool {
    println("=== N6-ARCHITECTURE v4 :: Status ===")
    println("")

    // Load saved state
    let mut loaded = false
    try {
        let state_raw = read_file(_arch_state_path)
        if state_raw.contains("\"coherence\":") {
            let fitness = make_fitness(safe_float(xf(state_raw, "coherence")), safe_float(xf(state_raw, "coverage")), safe_float(xf(state_raw, "depth")), safe_float(xf(state_raw, "resilience")), safe_float(xf(state_raw, "efficiency")), safe_float(xf(state_raw, "novelty")))
            let total = fitness_total(fitness)
            let env = xf(state_raw, "env")
            let ts = xf(state_raw, "ts")

            println("[STATE] last adapted: " + ts)
            println("[ENV]   " + env)
            println("[FIT]   " + fitness_to_str(fitness))
            println("[FIT]   total=" + to_string(total))

            let scaled = total * 6.0
            println("[N6]    scaled=" + to_string(scaled) + " grade=" + n6_grade(scaled))

            let weak = fitness_weakest(fitness)
            println("[WEAK]  " + FITNESS_NAMES[weak] + " (=" + to_string(fitness_dim(fitness, weak)) + ")")
            loaded = true
        }
    } catch e {}

    if !loaded {
        println("[INFO] no saved state found. run 'adapt' first.")
    }

    // Scan bus for recent arch_adaptive entries
    println("")
    println("[BUS] recent arch_adaptive events:")
    let mut bus_count = 0
    try {
        let tail = exec("tail -100 " + _bus_path)
        let lines = tail.split("\n")
        let mut i = 0
        while i < lines.len() {
            let line = lines[i].trim()
            if line.contains("arch_adaptive") {
                let event = xf(line, "event")
                let value = xf(line, "value")
                let grade = xf(line, "grade")
                println("  " + event + " val=" + value + " grade=" + grade)
                bus_count = bus_count + 1
            }
            i = i + 1
        }
    } catch e {}
    if bus_count == 0 { println("  (none)") }

    // Architecture health: 6 dimension radar
    println("")
    println("[RADAR] 6-dimensional fitness landscape:")
    let mut di = 0
    while di < N {
        println("  " + FITNESS_NAMES[di] + ": " + to_string(di) + "/6 dimension")
        di = di + 1
    }

    println("")
    println("[ENV TYPES] " + to_string(N) + " recognized environments:")
    let mut ei = 0
    while ei < N {
        println("  " + ENV_NAMES[ei])
        ei = ei + 1
    }

    true
}

// ═══════════════════════════════════════════════════════════
// ─── HELP ───
// ═══════════════════════════════════════════════════════════

fn show_help() -> bool {
    println("=== N6-ARCHITECTURE v4 :: Adaptive Engine ===")
    println("")
    println("Usage:")
    println("  hexa arch_adaptive.hexa adapt [env]  — run 6-gen adaptation cycle")
    println("  hexa arch_adaptive.hexa status       — show current architecture fitness")
    println("  hexa arch_adaptive.hexa help          — this help")
    println("")
    println("Environment types (n=6):")
    let mut i = 0
    while i < N {
        println("  " + ENV_NAMES[i])
        i = i + 1
    }
    println("")
    println("Fitness dimensions (n=6):")
    i = 0
    while i < N {
        println("  " + FITNESS_NAMES[i])
        i = i + 1
    }
    println("")
    println("Adaptation strategies (n=6):")
    i = 0
    while i < N {
        println("  " + STRATEGY_NAMES[i])
        i = i + 1
    }
    println("")
    println("Output: growth_bus.jsonl (grade: EXACT/NEAR/CLOSE/MISS)")
    println("State:  arch_adaptive_state.json (persistent fitness vector)")
    true
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN CLI DISPATCH ───
// ═══════════════════════════════════════════════════════════

let mut _cmd = "help"
try { _cmd = args()[2] } catch e {}

let mut _env_arg = "stable"
try { _env_arg = args()[3] } catch e {}

// Validate env arg
fn valid_env(name: string) -> bool {
    let mut i = 0
    while i < N {
        if ENV_NAMES[i] == name { return true }
        i = i + 1
    }
    false
}

if _cmd == "adapt" {
    if !valid_env(_env_arg) {
        println("[WARN] unknown env '" + _env_arg + "', defaulting to 'stable'")
        _env_arg = "stable"
    }
    run_adaptation(_env_arg)
} else if _cmd == "status" {
    run_status()
} else {
    show_help()
}
