// wave_contact.hexa -- 접촉 파동 확산 (발견의 전파 경로 시뮬레이션)
// 사용: hexa wave_contact.hexa
//       hexa wave_contact.hexa --help
//       hexa wave_contact.hexa --optimal   최적 경로만
//
// 원리:
//   1. 전파 노드 5종: 유튜브(6), 논문(12), 이메일(4), SNS(2), 강연(24)
//   2. 각 노드에서 6명에게 전파, 감쇠율 1/phi(6)=1/2
//   3. 3단계 전파 시뮬레이션: 총 도달 인원, 총 에너지
//   4. 최적 전파 경로: 어떤 채널 조합이 최대 도달?
//   5. 현재 유튜브 2.4만 기준 시뮬레이션
//   6. growth_bus.jsonl 기록

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _bus_path = _shared + "/growth_bus.jsonl"

let args = exec("echo $@").trim().split(" ")

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

fn safe_float(s: string) -> f64 {
    let mut v: f64 = 0.0
    try { v = to_float(s.trim()) } catch e {}
    return v
}

// ═══════════════════════════════════════════════════════════
// 도움말
// ═══════════════════════════════════════════════════════════

let mut show_help = false
let mut optimal_only = false
for a in args {
    if a == "--help" || a == "-h" { show_help = true }
    if a == "--optimal" { optimal_only = true }
}

if show_help {
    println("")
    println("  wave_contact.hexa -- 접촉 파동 확산")
    println("")
    println("  사용법:")
    println("    hexa wave_contact.hexa              전체 시뮬레이션")
    println("    hexa wave_contact.hexa --optimal     최적 경로만")
    println("    hexa wave_contact.hexa --help        이 도움말")
    println("")
    println("  전파 노드: 유튜브(6), 논문(12), 이메일(4), SNS(2), 강연(24)")
    println("  전파 규칙: 각 노드에서 6명에게 전파, 감쇠율 1/phi(6) = 1/2")
    println("  시뮬레이션: 3단계 전파, 유튜브 2.4만 구독자 기준")
    println("")
}

if show_help {  } else {

// ═══════════════════════════════════════════════════════════
// 전파 채널 정의
// ═══════════════════════════════════════════════════════════

let channel_names = ["유튜브", "논문", "이메일", "SNS", "강연"]
let channel_energy = [6, 12, 4, 2, 24]
// 초기 도달 인원 (유튜브=24000, 논문=500, 이메일=50, SNS=10000, 강연=200)
let channel_initial_reach = [24000, 500, 50, 10000, 200]

let spread_factor: i64 = 6          // 각 노드에서 6명에게 전파
let decay_numer: i64 = 1            // 감쇠율 분자 (1/phi(6) = 1/2)
let decay_denom: i64 = 2            // 감쇠율 분모
let max_steps: i64 = 3              // 3단계 전파

println("")
println("===========================================================")
println("  접촉 파동 확산 -- 발견의 전파 경로 시뮬레이션")
println("  전파 인자: 6명/노드, 감쇠: 1/phi(6)=1/2, 3단계")
println("===========================================================")
println("")

// ═══════════════════════════════════════════════════════════
// 3단계 전파 시뮬레이션 (채널별)
// ═══════════════════════════════════════════════════════════

if !optimal_only {
    println("  --- 채널별 전파 시뮬레이션 ---")
    println("")
    println("| 채널 | 에너지 | 초기도달 | 1단계 | 2단계 | 3단계 | 총도달 | 총에너지 |")
    println("|------|--------|---------|-------|-------|-------|--------|---------|")
}

let mut ch_total_reach = []
let mut ch_total_energy = []

let mut ci: i64 = 0
while ci < len(channel_names) {
    let cname: string = channel_names[ci]
    let cenergy: i64 = channel_energy[ci]
    let cinitial: i64 = channel_initial_reach[ci]

    // 단계별 전파 계산
    // 0단계: 초기 도달
    // k단계: 이전단계 인원 * spread_factor * (decay_numer/decay_denom)^k
    // 감쇠 적용: 분자^k / 분모^k

    let mut step_reach = [cinitial]
    let mut total_reach: i64 = cinitial
    let mut total_e: i64 = cinitial * cenergy

    let mut step: i64 = 1
    while step <= max_steps {
        // 이전 단계 도달 인원
        let prev: i64 = step_reach[step - 1]
        // 새 도달 = prev * 6 * (1/2)^step
        // = prev * 6 / 2^step
        let mut denom_power: i64 = 1
        let mut sp: i64 = 0
        while sp < step {
            denom_power = denom_power * decay_denom
            sp = sp + 1
        }
        let new_reach: i64 = (prev * spread_factor) / denom_power
        step_reach = step_reach + [new_reach]
        total_reach = total_reach + new_reach
        // 에너지도 감쇠
        let step_energy: i64 = (new_reach * cenergy) / denom_power
        total_e = total_e + step_energy
        step = step + 1
    }

    ch_total_reach = ch_total_reach + [total_reach]
    ch_total_energy = ch_total_energy + [total_e]

    if !optimal_only {
        println("| " + cname + " | " + to_string(cenergy) + " | " + to_string(cinitial) + " | " + to_string(step_reach[1]) + " | " + to_string(step_reach[2]) + " | " + to_string(step_reach[3]) + " | " + to_string(total_reach) + " | " + to_string(total_e) + " |")
    }

    ci = ci + 1
}

if !optimal_only {
    println("")
}

// ═══════════════════════════════════════════════════════════
// 최적 전파 경로: 모든 채널 조합 평가
// 2^5 = 32 조합 (공집합 제외 = 31)
// ═══════════════════════════════════════════════════════════

println("  --- 최적 전파 경로 (상위 6개) ---")
println("")
println("| 순위 | 채널 조합 | 총 도달 | 총 에너지 | 효율 |")
println("|------|----------|--------|----------|------|")

// 조합 생성: 비트마스크 1~31
let mut combo_names = []
let mut combo_reach = []
let mut combo_energy = []

let mut mask: i64 = 1
while mask < 32 {
    let mut name = ""
    let mut reach: i64 = 0
    let mut energy: i64 = 0
    let mut bit: i64 = 0
    while bit < 5 {
        let mut test: i64 = 1
        let mut shift: i64 = 0
        while shift < bit {
            test = test * 2
            shift = shift + 1
        }
        if (mask / test) % 2 == 1 {
            if name != "" { name = name + "+" }
            name = name + channel_names[bit]
            reach = reach + ch_total_reach[bit]
            energy = energy + ch_total_energy[bit]
        }
        bit = bit + 1
    }
    combo_names = combo_names + [name]
    combo_reach = combo_reach + [reach]
    combo_energy = combo_energy + [energy]
    mask = mask + 1
}

// 에너지 기준 정렬 (버블 소트, 상위 6개만 필요)
let mut si: i64 = 0
while si < 6 {
    let mut sj: i64 = si + 1
    while sj < len(combo_names) {
        if combo_energy[sj] > combo_energy[si] {
            // swap
            let tn = combo_names[si]
            let tr = combo_reach[si]
            let te = combo_energy[si]
            combo_names[si] = combo_names[sj]
            combo_reach[si] = combo_reach[sj]
            combo_energy[si] = combo_energy[sj]
            combo_names[sj] = tn
            combo_reach[sj] = tr
            combo_energy[sj] = te
        }
        sj = sj + 1
    }
    si = si + 1
}

// 상위 6개 출력
let mut ri: i64 = 0
while ri < 6 && ri < len(combo_names) {
    let eff = if combo_reach[ri] > 0 { combo_energy[ri] / (combo_reach[ri] / 1000 + 1) } else { 0 }
    println("| " + to_string(ri + 1) + " | " + combo_names[ri] + " | " + to_string(combo_reach[ri]) + " | " + to_string(combo_energy[ri]) + " | " + to_string(eff) + " |")
    ri = ri + 1
}

println("")

// ═══════════════════════════════════════════════════════════
// 유튜브 2.4만 기준 시뮬레이션 상세
// ═══════════════════════════════════════════════════════════

if !optimal_only {
    println("  --- 유튜브 2.4만 기준 전파 상세 ---")
    println("")

    let yt_base: i64 = 24000
    let mut yt_step = [yt_base]
    let mut yt_total: i64 = yt_base
    let mut yt_energy_total: i64 = yt_base * 6

    let mut k: i64 = 1
    while k <= max_steps {
        let prev_yt: i64 = yt_step[k - 1]
        let mut dp: i64 = 1
        let mut sp2: i64 = 0
        while sp2 < k {
            dp = dp * 2
            sp2 = sp2 + 1
        }
        let new_yt: i64 = (prev_yt * 6) / dp
        yt_step = yt_step + [new_yt]
        yt_total = yt_total + new_yt
        yt_energy_total = yt_energy_total + (new_yt * 6) / dp
        k = k + 1
    }

    println("  0단계 (초기 구독자):  " + to_string(yt_step[0]) + "명")
    println("  1단계 (6명 전파, 1/2 감쇠): " + to_string(yt_step[1]) + "명")
    println("  2단계 (6명 전파, 1/4 감쇠): " + to_string(yt_step[2]) + "명")
    println("  3단계 (6명 전파, 1/8 감쇠): " + to_string(yt_step[3]) + "명")
    println("  ────────────────────────────────")
    println("  총 도달:  " + to_string(yt_total) + "명")
    println("  총 에너지: " + to_string(yt_energy_total))
    println("")
}

// ═══════════════════════════════════════════════════════════
// ASCII 전파 그래프
// ═══════════════════════════════════════════════════════════

if !optimal_only {
    println("  --- 채널별 도달 비교 ---")
    println("")

    let mut max_reach: i64 = 1
    let mut mi: i64 = 0
    while mi < len(ch_total_reach) {
        if ch_total_reach[mi] > max_reach { max_reach = ch_total_reach[mi] }
        mi = mi + 1
    }

    mi = 0
    while mi < len(channel_names) {
        let cname2: string = channel_names[mi]
        let cr: i64 = ch_total_reach[mi]
        let bar_len: i64 = (cr * 40) / (max_reach + 1)
        let mut bar = ""
        let mut bi: i64 = 0
        while bi < bar_len && bi < 40 {
            bar = bar + "#"
            bi = bi + 1
        }
        println("  " + cname2 + "\t" + bar + " " + to_string(cr))
        mi = mi + 1
    }

    println("")
}

// ═══════════════════════════════════════════════════════════
// growth_bus 기록
// ═══════════════════════════════════════════════════════════

try {
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
    let best_combo: string = combo_names[0]
    let best_reach: i64 = combo_reach[0]
    let best_energy: i64 = combo_energy[0]
    let entry = "{\"type\":\"wave_contact\",\"channels\":5,\"best_combo\":\"" + best_combo + "\",\"best_reach\":" + to_string(best_reach) + ",\"best_energy\":" + to_string(best_energy) + ",\"yt_base\":24000,\"spread\":6,\"decay\":\"1/2\",\"steps\":3,\"ts\":\"" + ts + "\"}"
    exec("echo '" + entry + "' >> " + _bus_path)
} catch e {}

println("  growth_bus 기록 완료")
println("")
println("[verified] wave_contact.hexa 실행 완료")
println("")

}
