// wave_bt_index.hexa — BT 파동 인덱스
// 실행: hexa wave_bt_index.hexa
// 예시: hexa wave_bt_index.hexa
//       hexa wave_bt_index.hexa help
//
// 원리:
//   1. breakthrough-theorems.md에서 BT 헤더 파싱
//   2. 같은 도메인 BT = 약한 엣지, BT 본문에서 다른 BT 참조 = 강한 엣지
//   3. 공명 엣지: 두 BT 번호 차이가 6의 배수인 쌍
//   4. 연쇄 돌파 경로: BT-1부터 최신까지 가장 긴 엣지 체인
//   5. 허브 BT (엣지 최다) 상위 6개 시각화

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _bus_path = _shared + "/growth_bus.jsonl"
let _n6_repo = _dev + "/n6-architecture"
let _bt_path = _n6_repo + "/docs/breakthrough-theorems.md"

let args = exec("echo $@").trim().split(" ")
if len(args) > 0 && args[0] == "help" {
    println("")
    println("  wave_bt_index.hexa — BT 파동 인덱스")
    println("  사용법: hexa wave_bt_index.hexa")
    println("")
    println("  기능:")
    println("    1. BT 헤더에서 번호/이름/도메인 추출")
    println("    2. 약한 엣지 (같은 도메인 BT 쌍)")
    println("    3. 강한 엣지 (BT 본문에서 다른 BT 참조)")
    println("    4. 공명 엣지 (번호 차이가 6의 배수)")
    println("    5. 연쇄 돌파 경로 + 허브 BT 상위 6개")
    println("")
    return
}

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

// ═══════════════════════════════════════════════════════════
// 1. BT 헤더 파싱 — 번호와 이름 추출
// ═══════════════════════════════════════════════════════════

fn extract_bt_headers() -> string {
    let mut result = ""
    try {
        // ## BT-NNN: Title 형식 추출 → "번호\t이름"
        result = exec("grep '^## BT-' " + _bt_path + " | sed 's/## BT-//;s/:.*//' | head -800")
    } catch e {}
    return result
}

fn extract_bt_titles() -> string {
    let mut result = ""
    try {
        // 전체 헤더 줄 (번호:이름)
        result = exec("grep '^## BT-' " + _bt_path + " | sed 's/## //' | head -800")
    } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// 2. BT 본문에서 다른 BT 참조 추출 (강한 엣지)
// ═══════════════════════════════════════════════════════════

fn extract_bt_references() -> string {
    let mut result = ""
    try {
        // BT-NNN 패턴을 본문에서 찾되, 헤더(##)가 아닌 줄만
        result = exec("grep -o 'BT-[0-9]\\+' " + _bt_path + " | sort | uniq -c | sort -rn | head -100")
    } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// 3. 도메인별 BT 그룹 (약한 엣지)
// ═══════════════════════════════════════════════════════════

fn extract_bt_domains() -> string {
    let mut result = ""
    try {
        // **Domains connected** 줄에서 도메인 키워드 추출
        // 또는 헤더 줄에서 도메인 추정
        result = exec("grep -A1 '^## BT-' " + _bt_path + " | grep -v '^--$' | head -1600")
    } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// MAIN
// ═══════════════════════════════════════════════════════════

println("")
println("===========================================================")
println("  BT 파동 인덱스 (Wave BT Index)")
println("  BT간 공명 엣지 + 연쇄 돌파 경로 시각화")
println("===========================================================")
println("")

// 1. BT 번호 추출
println("  breakthrough-theorems.md에서 BT 파싱 중...")
let bt_nums_raw = extract_bt_headers()
let bt_nums_lines = bt_nums_raw.split("\n")

let mut bt_numbers = []
let mut total_bt: i64 = 0

for line in bt_nums_lines {
    let num_str = line.trim()
    if num_str == "" { continue }
    let num = safe_int(num_str)
    if num > 0 {
        bt_numbers = bt_numbers + [num]
        total_bt = total_bt + 1
    }
}

println("  총 BT 수: " + to_string(total_bt) + "개")
println("")

// BT 타이틀 추출
let bt_titles_raw = extract_bt_titles()
let bt_title_lines = bt_titles_raw.split("\n")
let mut bt_titles = []
for tl in bt_title_lines {
    let t = tl.trim()
    if t != "" { bt_titles = bt_titles + [t] }
}

// 2. 강한 엣지: BT 본문에서 다른 BT 참조
println("  --- 강한 엣지 (BT간 직접 참조) ---")
println("")

let ref_raw = extract_bt_references()
let ref_lines = ref_raw.split("\n")

let mut ref_bt_names = []
let mut ref_bt_counts = []
let mut ref_total: i64 = 0

for rl in ref_lines {
    let r = rl.trim()
    if r == "" { continue }
    // "   N BT-XXX" 형식
    let parts = r.split(" ")
    let mut count_str = ""
    let mut bt_name = ""
    for p in parts {
        let pp = p.trim()
        if pp == "" { continue }
        if count_str == "" { count_str = pp }
        else if bt_name == "" { bt_name = pp }
    }
    let count = safe_int(count_str)
    if bt_name != "" && count > 1 {
        ref_bt_names = ref_bt_names + [bt_name]
        ref_bt_counts = ref_bt_counts + [count]
        ref_total = ref_total + 1
    }
}

println("  가장 많이 참조된 BT (강한 엣지 허브):")
let show_refs: i64 = if ref_total < 20 { ref_total } else { 20 }
let mut ri: i64 = 0
while ri < show_refs {
    let rn: string = ref_bt_names[ri]
    let rc: i64 = ref_bt_counts[ri]
    println("    " + rn + " -- " + to_string(rc) + "회 참조")
    ri = ri + 1
}

println("")

// 3. 공명 엣지: BT 번호 차이가 6의 배수
println("  --- 공명 엣지 (번호 차이 = 6의 배수) ---")
println("")

let mut resonance_count: i64 = 0
let mut resonance_pairs = []

// 인접 BT 쌍 중 차이가 6 배수인 것
let mut pi: i64 = 0
while pi < len(bt_numbers) - 1 {
    let mut pj: i64 = pi + 1
    // 인접 6개까지만 검사 (전수 조합은 너무 많음)
    while pj < len(bt_numbers) && pj < pi + 7 {
        let diff = bt_numbers[pj] - bt_numbers[pi]
        let abs_diff = if diff < 0 { 0 - diff } else { diff }
        if abs_diff > 0 && abs_diff % 6 == 0 {
            resonance_count = resonance_count + 1
            if resonance_count <= 30 {
                resonance_pairs = resonance_pairs + ["BT-" + to_string(bt_numbers[pi]) + " <-> BT-" + to_string(bt_numbers[pj]) + " (차이: " + to_string(abs_diff) + " = 6x" + to_string(abs_diff / 6) + ")"]
            }
        }
        pj = pj + 1
    }
    pi = pi + 1
}

println("  총 공명 쌍: " + to_string(resonance_count) + "개")
println("")

let show_res: i64 = if len(resonance_pairs) < 20 { len(resonance_pairs) } else { 20 }
let mut resi: i64 = 0
while resi < show_res {
    let rp: string = resonance_pairs[resi]
    println("    " + rp)
    resi = resi + 1
}

if resonance_count > 20 {
    println("    ... 외 " + to_string(resonance_count - 20) + "개")
}
println("")

// 4. 연쇄 돌파 경로 (BT-1부터 6 배수 간격으로 점프)
println("  --- 연쇄 돌파 경로 (6의 배수 간격 체인) ---")
println("")

// BT 번호 집합 빠른 조회용
let mut bt_set_str = ","
for bn in bt_numbers {
    bt_set_str = bt_set_str + to_string(bn) + ","
}

// BT-1부터 시작, 6/12/18/24/30/36 간격으로 가장 가까운 BT로 점프
let mut chain = []
let mut current: i64 = 0

// 최소 BT 번호 찾기
if len(bt_numbers) > 0 {
    current = bt_numbers[0]
    chain = chain + ["BT-" + to_string(current)]

    let mut chain_step: i64 = 0
    while chain_step < 200 {
        // 6, 12, 18, 24, 30, 36 간격으로 다음 BT 검색
        let mut found = false
        let steps = [6, 12, 18, 24, 30, 36]
        for step in steps {
            let next = current + step
            let next_str = "," + to_string(next) + ","
            try {
                let check = exec("echo '" + bt_set_str + "' | grep -c '" + next_str + "' 2>/dev/null || echo 0")
                if safe_int(check.trim()) > 0 {
                    chain = chain + ["--(" + to_string(step) + ")--> BT-" + to_string(next)]
                    current = next
                    found = true
                    break
                }
            } catch e {}
        }
        if !found { break }
        chain_step = chain_step + 1
    }
}

println("  체인 길이: " + to_string(len(chain)) + "단계")
println("")
let mut ci: i64 = 0
while ci < len(chain) && ci < 30 {
    let cc: string = chain[ci]
    println("    " + cc)
    ci = ci + 1
}
if len(chain) > 30 {
    println("    ... 외 " + to_string(len(chain) - 30) + "단계")
}
println("")

// 5. 허브 BT (엣지 최다) 상위 6개 시각화
println("  --- 허브 BT (엣지 최다) 상위 6개 ---")
println("")

// 각 BT의 공명 엣지 수 계산
let mut hub_counts = []
let mut hub_numbers = []

let mut hi: i64 = 0
while hi < len(bt_numbers) && hi < 200 {
    let bn: i64 = bt_numbers[hi]
    let mut edge_count: i64 = 0

    // 다른 모든 BT와의 6배수 관계 카운트 (가까운 것만)
    let mut hj: i64 = 0
    while hj < len(bt_numbers) {
        if hj != hi {
            let diff = bt_numbers[hj] - bn
            let abs_diff = if diff < 0 { 0 - diff } else { diff }
            if abs_diff > 0 && abs_diff <= 36 && abs_diff % 6 == 0 {
                edge_count = edge_count + 1
            }
        }
        hj = hj + 1
    }

    hub_counts = hub_counts + [edge_count]
    hub_numbers = hub_numbers + [bn]
    hi = hi + 1
}

// 상위 6개 정렬
let mut top_indices = []
let mut used = []
let mut ti: i64 = 0
while ti < 6 && ti < len(hub_counts) {
    let mut best_idx: i64 = -1
    let mut best_val: i64 = -1
    let mut bi: i64 = 0
    while bi < len(hub_counts) {
        let mut is_used = false
        for u in used { if u == bi { is_used = true } }
        if !is_used && hub_counts[bi] > best_val {
            best_val = hub_counts[bi]
            best_idx = bi
        }
        bi = bi + 1
    }
    if best_idx >= 0 {
        top_indices = top_indices + [best_idx]
        used = used + [best_idx]

        let hub_bn: i64 = hub_numbers[best_idx]
        let hub_ec: i64 = hub_counts[best_idx]
        // 타이틀 찾기
        let mut title = ""
        if best_idx < len(bt_titles) {
            title = bt_titles[best_idx]
        }

        // 허브 시각화
        let mut star = ""
        let mut si: i64 = 0
        while si < hub_ec && si < 20 {
            star = star + "*"
            si = si + 1
        }
        println("  BT-" + to_string(hub_bn) + " " + star + " (" + to_string(hub_ec) + " 엣지)")
        if title != "" {
            println("    " + title)
        }
    }
    ti = ti + 1
}

println("")

// 6. 통계 요약
println("  --- 요약 ---")
println("  총 BT: " + to_string(total_bt))
println("  공명 쌍 (차이=6배수): " + to_string(resonance_count))
println("  연쇄 체인 길이: " + to_string(len(chain)))
println("  강한 엣지 허브: " + to_string(ref_total) + "개 BT")
println("")

// 7. growth_bus 기록
try {
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
    let entry = "{\"type\":\"wave_bt_index\",\"total_bt\":" + to_string(total_bt) + ",\"resonance_pairs\":" + to_string(resonance_count) + ",\"chain_length\":" + to_string(len(chain)) + ",\"strong_hubs\":" + to_string(ref_total) + ",\"ts\":\"" + ts + "\"}"
    exec("echo '" + entry + "' >> " + _bus_path)
} catch e {}

println("  growth_bus 기록 완료")
println("")
println("[verified] wave_bt_index.hexa 실행 완료")
println("")
