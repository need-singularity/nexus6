// energy_landscape.hexa -- 에너지 지형도 (DSE 도메인 에너지 풍경)
// 사용: hexa energy_landscape.hexa [help]
//
// 원리:
//   1. growth_bus.jsonl에서 도메인별 총 에너지(이벤트 수) 집계
//   2. 에너지 순으로 정렬
//   3. ASCII 가로 바 차트 시각화 (최대 60자 폭)
//   4. 봉우리(최대) / 골짜기(에너지 0) 식별
//   5. 에너지 분포 통계: 평균, 중앙값, 표준편차
//   6. n=6 에너지 대역별 도메인 수 분류
//   7. growth_bus에 지형도 요약 기록

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _bus_path = _shared + "/growth_bus.jsonl"

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

fn safe_float(s: string) -> f64 {
    let mut v: f64 = 0.0
    try { v = to_float(s.trim()) } catch e {}
    return v
}

// ═══════════════════════════════════════════════════════════
// help 서브커맨드
// ═══════════════════════════════════════════════════════════

let _args = args()
if len(_args) > 1 && _args[1] == "help" {
    println("")
    println("===========================================================")
    println("  energy_landscape.hexa -- 에너지 지형도")
    println("===========================================================")
    println("")
    println("  사용법: hexa energy_landscape.hexa")
    println("")
    println("  기능:")
    println("    - growth_bus.jsonl에서 도메인별 에너지(이벤트) 집계")
    println("    - ASCII 가로 바 차트 시각화 (60자 폭)")
    println("    - 봉우리(최대 에너지) / 골짜기(에너지 0) 식별")
    println("    - 분포 통계: 평균, 중앙값, 표준편차")
    println("    - n=6 에너지 대역(6,12,24,36,48,72) 구간별 분류")
    println("    - growth_bus.jsonl에 지형도 요약 기록")
    println("")
    println("  출력:")
    println("    - 에너지 지형 바 차트 (상위 40)")
    println("    - 봉우리/골짜기 목록")
    println("    - 분포 통계")
    println("    - n=6 대역 분류표")
    println("")
    println("[verified] energy_landscape.hexa help")
    println("")
    exit(0)
}

// ═══════════════════════════════════════════════════════════
// growth_bus.jsonl에서 도메인별 에너지 집계
// ═══════════════════════════════════════════════════════════

fn extract_domain_energy() -> string {
    let mut result = ""
    try {
        // domain/source 필드에서 도메인명 추출 + 이벤트 수 카운트
        // type, source, domain 등 다양한 키에서 도메인 정보 추출
        result = exec("cat '" + _bus_path + "' | awk -F'\"' '{for(i=1;i<=NF;i++){if($i==\"domain\" || $i==\"source\") {d=$(i+2); if(d!=\"\" && d!=\":\") print d}}}' | sort | uniq -c | sort -rn")
    } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// MAIN
// ═══════════════════════════════════════════════════════════

println("")
println("===========================================================")
println("  에너지 지형도 (Energy Landscape)")
println("  DSE 도메인 에너지 풍경 ASCII 시각화")
println("===========================================================")
println("")

// 1. 도메인별 에너지 추출
println("  growth_bus.jsonl 분석 중...")
let energy_raw = extract_domain_energy()
let energy_lines = energy_raw.split("\n")

let mut domain_names = []
let mut domain_energies = []
let mut total_energy: i64 = 0
let mut max_energy: i64 = 0
let mut peak_domain = ""

for el in energy_lines {
    let et = el.trim()
    if et == "" { continue }

    // "  123 domain_name" 형식 파싱
    let parts = et.split(" ")
    let mut count_str = ""
    let mut name_str = ""
    let mut found_count = false

    for p in parts {
        let pt = p.trim()
        if pt == "" { continue }
        if !found_count {
            count_str = pt
            found_count = true
        } else {
            if name_str != "" { name_str = name_str + "_" }
            name_str = name_str + pt
        }
    }

    let energy = safe_int(count_str)
    if energy <= 0 || name_str == "" { continue }

    domain_names = domain_names + [name_str]
    domain_energies = domain_energies + [energy]
    total_energy = total_energy + energy

    if energy > max_energy {
        max_energy = energy
        peak_domain = name_str
    }
}

let domain_count: i64 = to_int(len(domain_names))

println("  총 도메인: " + to_string(domain_count) + "개")
println("  총 에너지: " + to_string(total_energy))
println("  봉우리: " + peak_domain + " (" + to_string(max_energy) + ")")
println("")

// ═══════════════════════════════════════════════════════════
// 2. ASCII 가로 바 차트 (상위 40, 최대 60자 폭)
// ═══════════════════════════════════════════════════════════

println("  --- 에너지 지형 바 차트 (상위 40) ---")
println("")

let bar_max: i64 = 60
let mut di: i64 = 0
while di < len(domain_names) && di < 40 {
    let dn: string = domain_names[di]
    let de: i64 = domain_energies[di]

    // 막대 길이 계산
    let bar_len = if max_energy > 0 { (de * bar_max) / max_energy } else { 0 }
    let mut bar = ""
    let mut bi: i64 = 0
    while bi < bar_len {
        bar = bar + "#"
        bi = bi + 1
    }
    if bar == "" { bar = "." }

    // 도메인명 패딩 (20자)
    let mut label = dn
    try {
        let label_len = safe_int(exec("echo -n '" + dn + "' | wc -c").trim())
        if label_len < 20 {
            let mut pi: i64 = label_len
            while pi < 20 {
                label = label + " "
                pi = pi + 1
            }
        } else if label_len > 20 {
            label = exec("echo '" + dn + "' | cut -c1-20").trim()
        }
    } catch e {}

    // 봉우리/골짜기 표시
    let marker = if de == max_energy { " <봉우리>" } else if de <= 2 { " <골짜기>" } else { "" }

    println("  " + label + " |" + bar + " " + to_string(de) + marker)
    di = di + 1
}

println("")

// ═══════════════════════════════════════════════════════════
// 3. 봉우리 / 골짜기 목록
// ═══════════════════════════════════════════════════════════

println("  --- 봉우리 (에너지 상위 6) ---")
println("")

di = 0
while di < len(domain_names) && di < 6 {
    let dn2: string = domain_names[di]
    let de2: i64 = domain_energies[di]
    println("  " + to_string(di + 1) + ". " + dn2 + " = " + to_string(de2))
    di = di + 1
}
println("")

println("  --- 골짜기 (에너지 <=2) ---")
println("")

let mut valley_count: i64 = 0
di = 0
while di < len(domain_names) {
    let de3: i64 = domain_energies[di]
    if de3 <= 2 {
        let dn3: string = domain_names[di]
        valley_count = valley_count + 1
        if valley_count <= 10 {
            println("  골짜기: " + dn3 + " = " + to_string(de3))
        }
    }
    di = di + 1
}

if valley_count > 10 {
    println("  ... 외 " + to_string(valley_count - 10) + "개 골짜기")
}
println("  총 골짜기: " + to_string(valley_count) + "개")
println("")

// ═══════════════════════════════════════════════════════════
// 4. 분포 통계: 평균, 중앙값, 표준편차
// ═══════════════════════════════════════════════════════════

println("  --- 에너지 분포 통계 ---")
println("")

let avg_energy = if domain_count > 0 { total_energy / domain_count } else { 0 }

// 중앙값 (이미 정렬됨 — 내림차순이므로 중간 인덱스)
let median_idx = domain_count / 2
let median_energy: i64 = if domain_count > 0 { domain_energies[median_idx] } else { 0 }

// 표준편차 (정수 근사)
let mut variance_sum: i64 = 0
di = 0
while di < len(domain_energies) {
    let de4: i64 = domain_energies[di]
    let diff = de4 - avg_energy
    variance_sum = variance_sum + (diff * diff)
    di = di + 1
}
let variance = if domain_count > 0 { variance_sum / domain_count } else { 0 }

// 정수 제곱근 근사
let mut stddev: i64 = 0
let mut s: i64 = 1
while s * s <= variance {
    stddev = s
    s = s + 1
}

println("  평균 에너지:   " + to_string(avg_energy))
println("  중앙값:        " + to_string(median_energy))
println("  분산:          " + to_string(variance))
println("  표준편차(근사): " + to_string(stddev))
println("  최대:          " + to_string(max_energy) + " (" + peak_domain + ")")
println("  최소:          " + to_string(if len(domain_energies) > 0 { domain_energies[len(domain_energies) - 1] } else { 0 }))
println("")

// ═══════════════════════════════════════════════════════════
// 5. n=6 에너지 대역별 도메인 수
// ═══════════════════════════════════════════════════════════

println("  --- n=6 에너지 대역별 분류 ---")
println("")

// 대역 경계: 0, 6, 12, 24, 36, 48, 72, 120, 720, ∞
let band_limits = [6, 12, 24, 36, 48, 72, 120, 720]
let band_labels = ["0~5", "6~11", "12~23", "24~35", "36~47", "48~71", "72~119", "120~719", "720+"]
let mut band_counts = [0, 0, 0, 0, 0, 0, 0, 0, 0]

di = 0
while di < len(domain_energies) {
    let de5: i64 = domain_energies[di]

    let mut assigned = false
    let mut bi2: i64 = 0
    while bi2 < len(band_limits) {
        let lim: i64 = band_limits[bi2]
        if de5 < lim && !assigned {
            band_counts[bi2] = band_counts[bi2] + 1
            assigned = true
        }
        bi2 = bi2 + 1
    }
    if !assigned {
        // 720 이상
        band_counts[len(band_limits)] = band_counts[len(band_limits)] + 1
    }
    di = di + 1
}

println("| 대역 (n=6 배수) | 도메인 수 | 비율 | 히스토그램 |")
println("|-----------------|----------|------|-----------|")

let mut bi3: i64 = 0
while bi3 < len(band_labels) {
    let bl: string = band_labels[bi3]
    let bc: i64 = band_counts[bi3]
    let pct = if domain_count > 0 { (bc * 100) / domain_count } else { 0 }

    // 히스토그램 바 (최대 30자)
    let hist_len = if domain_count > 0 { (bc * 30) / (domain_count + 1) } else { 0 }
    let mut hist = ""
    let mut hi: i64 = 0
    while hi < hist_len + 1 && hi < 30 {
        hist = hist + "="
        hi = hi + 1
    }
    if hist == "" { hist = "." }

    println("| " + bl + " | " + to_string(bc) + " | " + to_string(pct) + "% | " + hist + " |")
    bi3 = bi3 + 1
}

println("")

// ═══════════════════════════════════════════════════════════
// 6. ASCII 등고선 요약 (6단 에너지 레벨)
// ═══════════════════════════════════════════════════════════

println("  --- 에너지 등고선 (6단) ---")
println("")

let level_thresholds = [max_energy, max_energy * 5 / 6, max_energy * 4 / 6, max_energy * 3 / 6, max_energy * 2 / 6, max_energy * 1 / 6]
let level_labels = ["정상 (6/6)", "고원 (5/6)", "산허리 (4/6)", "중턱 (3/6)", "구릉 (2/6)", "평야 (1/6)"]

let mut li: i64 = 0
while li < 6 {
    let thresh: i64 = level_thresholds[li]
    let ll: string = level_labels[li]
    let mut count_at: i64 = 0

    di = 0
    while di < len(domain_energies) {
        let de6: i64 = domain_energies[di]
        if li == 0 {
            if de6 >= thresh { count_at = count_at + 1 }
        } else {
            let prev_thresh: i64 = level_thresholds[li - 1]
            if de6 < prev_thresh && de6 >= thresh { count_at = count_at + 1 }
        }
        di = di + 1
    }

    println("  " + ll + " (>=" + to_string(thresh) + "): " + to_string(count_at) + "개 도메인")
    li = li + 1
}

// 바닥 (threshold 미만)
let mut floor_count: i64 = 0
let floor_thresh: i64 = level_thresholds[5]
di = 0
while di < len(domain_energies) {
    let de7: i64 = domain_energies[di]
    if de7 < floor_thresh { floor_count = floor_count + 1 }
    di = di + 1
}
println("  바닥 (<" + to_string(floor_thresh) + "): " + to_string(floor_count) + "개 도메인")
println("")

// ═══════════════════════════════════════════════════════════
// 7. growth_bus 기록
// ═══════════════════════════════════════════════════════════

try {
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
    let entry = "{\"type\":\"energy_landscape\",\"domains\":" + to_string(domain_count) + ",\"total_energy\":" + to_string(total_energy) + ",\"max_energy\":" + to_string(max_energy) + ",\"peak\":\"" + peak_domain + "\",\"valleys\":" + to_string(valley_count) + ",\"avg\":" + to_string(avg_energy) + ",\"median\":" + to_string(median_energy) + ",\"stddev\":" + to_string(stddev) + ",\"ts\":\"" + ts + "\"}"
    exec("echo '" + entry + "' >> " + _bus_path)
} catch e {}

println("  growth_bus 기록 완료")
println("")
println("  요약: " + to_string(domain_count) + "개 도메인, 총 에너지 " + to_string(total_energy) + ", 봉우리 " + peak_domain + "(" + to_string(max_energy) + "), 골짜기 " + to_string(valley_count) + "개")
println("")
println("[verified] energy_landscape.hexa 실행 완료")
println("")
