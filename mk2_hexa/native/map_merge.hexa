// map_merge.hexa — nexus SSOT + n6-arch 고유 콘텐츠 병합 + 전계층 크로스링크
// 사용: hexa map_merge.hexa
//
// 1) nexus/docs/n6-map-data.json (SSOT) 로드
// 2) n6-architecture/docs/n6-map-data.json 에서 rm_* 제외 고유 노드 추가
// 3) 전계층 도메인+키워드 크로스링크 생성
// 4) n6-architecture/docs/n6-map-data.json 에 병합 결과 출력

let home = exec("printenv HOME").trim()
let dev = home + "/Dev"
let nexus_map = dev + "/nexus/docs/n6-map-data.json"
let n6arch_map = dev + "/n6-architecture/docs/n6-map-data.json"
let out_path = n6arch_map

// ─── 도메인 키워드 사전 ───

comptime const DOMAINS = [
    "fusion", "chip", "energy", "ai", "physics", "chemistry",
    "materials", "biology", "astronomy", "math", "robotics",
    "software", "display", "audio", "aerospace", "environment",
    "economics", "geology", "music", "linguistics", "meteorology"
]

comptime const DOMAIN_KW = [
    "fusion,plasma,tokamak,tritium,deuterium,magnetic,confinement,iter,stellarator",
    "chip,semiconductor,transistor,silicon,dram,memory,nand,cpu,gpu,fpga,lithograph,wafer",
    "energy,solar,battery,grid,power,wind,turbine,thermal,hydrogen,fuel,supercapacitor",
    "neural,attention,transformer,scaling,inference,training,llm,dropout,embedding,gradient,diffusion",
    "particle,quantum,neutrino,cosmology,relativity,gravity,string,higgs,boson,quark,lepton,gluon,gauge",
    "chemistry,synthesis,element,compound,reaction,catalyst,enzyme,molecular,bond,orbital,valence",
    "material,crystal,alloy,polymer,ceramic,graphene,superconductor,composite,diamond,topological,piezo",
    "biology,cell,gene,protein,dna,rna,amino,photosynthesis,metabolism,mitosis",
    "star,planet,galaxy,orbit,cosmic,pulsar,neutron,supernova,nebula,celestial",
    "theorem,prime,modular,zeta,ramanujan,euler,bernoulli,riemann,algebraic,topology,manifold",
    "robot,actuator,servo,locomotion,manipulator,humanoid,autonomous,sensor,lidar",
    "compiler,operating,programming,algorithm,database,kernel,runtime,protocol",
    "display,oled,lcd,pixel,refresh,hdr,panel",
    "audio,speaker,acoustic,noise,codec,frequency,resonance,harmonic",
    "aerospace,rocket,satellite,propulsion,space,launch,reentry",
    "environment,carbon,water,recycling,desalination,pollution,climate,ocean",
    "economics,market,currency,trade,inflation,supply,demand",
    "geology,tectonic,mineral,volcanic,sediment,mantle,crust",
    "music,harmony,consonance,octave,tuning,scale,rhythm,chord",
    "linguistics,phoneme,syntax,morpheme,grammar,vowel,consonant",
    "weather,atmosphere,pressure,tornado,hurricane,precipitation,cloud"
]

// ─── 유틸 ───

fn to_lower_safe(s: string) -> string {
    try { return s.to_lower() } catch e { return s }
}

fn extract_keywords(text: string) {
    let low = to_lower_safe(text)
    let parts = low.split(" ")
    let mut result = []
    let mut i = 0
    while i < parts.len() {
        let w = parts[i].trim()
        if w.len() >= 3 {
            result = result.push(w)
        }
        i = i + 1
    }
    result
}

fn node_text(n) -> string {
    let mut t = ""
    try { t = t + " " + to_string(n["label"]) } catch e {}
    try { t = t + " " + to_string(n["description"]) } catch e {}
    try { t = t + " " + to_string(n["note"]) } catch e {}
    try { t = t + " " + to_string(n["title"]) } catch e {}
    try { t = t + " " + to_string(n["domain"]) } catch e {}
    try { t = t + " " + to_string(n["level"]) } catch e {}
    t
}

fn classify_domains(text: string) {
    let low = to_lower_safe(text)
    let mut result = []
    let mut di = 0
    while di < DOMAINS.len() {
        let kws = DOMAIN_KW[di].split(",")
        let mut ki = 0
        let mut matched = false
        while ki < kws.len() {
            if low.contains(kws[ki]) {
                matched = true
                break
            }
            ki = ki + 1
        }
        if matched {
            result = result.push(DOMAINS[di])
        }
        di = di + 1
    }
    result
}

fn has_common(a, b) -> bool {
    let mut ai = 0
    while ai < a.len() {
        let mut bi = 0
        while bi < b.len() {
            if a[ai] == b[bi] { return true }
            bi = bi + 1
        }
        ai = ai + 1
    }
    false
}

fn count_common_kw(a, b) -> int {
    let mut count = 0
    let mut ai = 0
    while ai < a.len() {
        let mut bi = 0
        while bi < b.len() {
            if a[ai] == b[bi] {
                count = count + 1
                break
            }
            bi = bi + 1
        }
        ai = ai + 1
    }
    count
}

// ─── JSON 배열 직렬화 헬퍼 ───

fn node_to_json(n) -> string {
    let mut s = "{"
    s = s + "\"id\":" + json_stringify(to_string(n["id"]))
    try { s = s + ",\"label\":" + json_stringify(to_string(n["label"])) } catch e {}
    try { s = s + ",\"layer\":" + to_string(n["layer"]) } catch e {}
    try { s = s + ",\"type\":" + json_stringify(to_string(n["type"])) } catch e {}
    try { s = s + ",\"description\":" + json_stringify(to_string(n["description"])) } catch e {}
    try { s = s + ",\"grade\":" + json_stringify(to_string(n["grade"])) } catch e {}
    try { s = s + ",\"origin\":" + json_stringify(to_string(n["origin"])) } catch e {}
    try { s = s + ",\"level\":" + json_stringify(to_string(n["level"])) } catch e {}
    try { s = s + ",\"note\":" + json_stringify(to_string(n["note"])) } catch e {}
    try { s = s + ",\"title\":" + json_stringify(to_string(n["title"])) } catch e {}
    try { s = s + ",\"domain\":" + json_stringify(to_string(n["domain"])) } catch e {}
    try { s = s + ",\"bt_num\":" + to_string(n["bt_num"]) } catch e {}
    try { s = s + ",\"combos\":" + to_string(n["combos"]) } catch e {}
    try { s = s + ",\"alien_level\":" + to_string(n["alien_level"]) } catch e {}
    try { s = s + ",\"n6_max\":" + to_string(n["n6_max"]) } catch e {}
    try { s = s + ",\"ufo\":" + to_string(n["ufo"]) } catch e {}
    try { s = s + ",\"section\":" + json_stringify(to_string(n["section"])) } catch e {}
    try { s = s + ",\"closure_grade\":" + to_string(n["closure_grade"]) } catch e {}
    try { s = s + ",\"bt_count\":" + to_string(n["bt_count"]) } catch e {}
    s = s + "}"
    s
}

fn edge_to_json(src: string, tgt: string, etype: string) -> string {
    "{\"source\":" + json_stringify(src) + ",\"target\":" + json_stringify(tgt) + ",\"type\":" + json_stringify(etype) + "}"
}

// ─── 메인 ───

fn main() {
    println("=== map_merge.hexa — nexus SSOT + n6-arch 병합 ===")

    // 1. nexus SSOT 로드
    println("[1/4] Loading nexus SSOT...")
    let nx_raw = read_file(nexus_map)
    let nx_data = json_parse(nx_raw)
    let nx_nodes = nx_data["nodes"]
    let nx_edges = nx_data["edges"]
    println("  nexus: " + to_string(nx_nodes.len()) + " nodes, " + to_string(nx_edges.len()) + " edges")

    // nexus 노드 ID 셋 (HashMap으로 O(1) 조회)
    let mut nx_id_set = #{}
    let mut i = 0
    while i < nx_nodes.len() {
        nx_id_set[to_string(nx_nodes[i]["id"])] = 1
        i = i + 1
    }

    // 2. n6-arch 고유 콘텐츠 로드
    println("[2/4] Loading n6-arch unique nodes...")
    let n6_raw = read_file(n6arch_map)
    let n6_data = json_parse(n6_raw)
    let n6_nodes = n6_data["nodes"]
    let n6_edges = n6_data["edges"]

    let mut unique_nodes = []
    let mut unique_count = 0
    i = 0
    while i < n6_nodes.len() {
        let nid = to_string(n6_nodes[i]["id"])
        // rm_* reality 노드 스킵 (nexus에 이미 있음)
        if !nid.starts_with("rm_") && !nx_id_set.contains_key(nid) {
            unique_nodes = unique_nodes.push(n6_nodes[i])
            unique_count = unique_count + 1
        }
        i = i + 1
    }
    println("  n6-arch unique: " + to_string(unique_count) + " nodes (rm_* skipped)")

    // 병합 노드 = nexus + unique
    let mut all_nodes = []
    let mut all_id_set = #{}
    i = 0
    while i < nx_nodes.len() {
        all_nodes = all_nodes.push(nx_nodes[i])
        all_id_set[to_string(nx_nodes[i]["id"])] = i
        i = i + 1
    }
    let nx_count = i
    i = 0
    while i < unique_nodes.len() {
        all_nodes = all_nodes.push(unique_nodes[i])
        all_id_set[to_string(unique_nodes[i]["id"])] = nx_count + i
        i = i + 1
    }
    println("  merged: " + to_string(all_nodes.len()) + " nodes")

    // 기존 엣지 병합 (from/to → source/target 변환, dangling 제거)
    let mut edge_set = #{}
    let mut merged_edges = []

    // nexus edges
    i = 0
    while i < nx_edges.len() {
        let mut src = ""
        let mut tgt = ""
        try { src = to_string(nx_edges[i]["source"]) } catch e {}
        try { tgt = to_string(nx_edges[i]["target"]) } catch e {}
        if src == "" {
            try { src = to_string(nx_edges[i]["from"]) } catch e {}
        }
        if tgt == "" {
            try { tgt = to_string(nx_edges[i]["to"]) } catch e {}
        }
        let mut etype = "nexus_link"
        try { etype = to_string(nx_edges[i]["type"]) } catch e {}

        if src != "" && tgt != "" && all_id_set.contains_key(src) && all_id_set.contains_key(tgt) {
            let key = src + "|" + tgt + "|" + etype
            let rev = tgt + "|" + src + "|" + etype
            if !edge_set.contains_key(key) && !edge_set.contains_key(rev) {
                edge_set[key] = 1
                merged_edges = append(merged_edges, [src, tgt, etype])
            }
        }
        i = i + 1
    }

    // n6-arch edges (rm_* 관련 스킵)
    i = 0
    while i < n6_edges.len() {
        let src = to_string(n6_edges[i]["source"])
        let tgt = to_string(n6_edges[i]["target"])
        if src.starts_with("rm_") || tgt.starts_with("rm_") {
            i = i + 1
            continue
        }
        let mut etype = "n6arch_link"
        try { etype = to_string(n6_edges[i]["type"]) } catch e {}

        if all_id_set.contains_key(src) && all_id_set.contains_key(tgt) {
            let key = src + "|" + tgt + "|" + etype
            let rev = tgt + "|" + src + "|" + etype
            if !edge_set.contains_key(key) && !edge_set.contains_key(rev) {
                edge_set[key] = 1
                merged_edges = append(merged_edges, [src, tgt, etype])
            }
        }
        i = i + 1
    }
    println("  base edges: " + to_string(merged_edges.len()))

    // 3. 전계층 크로스링크
    println("[3/4] Building full cross-layer links...")

    // 노드별 도메인 + 키워드 캐시
    let mut node_doms = #{}
    let mut node_kws = #{}
    let mut node_layers = #{}
    i = 0
    while i < all_nodes.len() {
        let nid = to_string(all_nodes[i]["id"])
        let text = node_text(all_nodes[i])
        node_doms[nid] = classify_domains(text)
        node_kws[nid] = extract_keywords(text)
        let mut layer = 0
        try { layer = to_int(to_string(all_nodes[i]["layer"])) } catch e {}
        node_layers[nid] = layer
        i = i + 1
    }

    // 도메인별 노드 그룹핑
    let mut by_domain = #{}
    i = 0
    while i < all_nodes.len() {
        let nid = to_string(all_nodes[i]["id"])
        let doms = node_doms[nid]
        let mut di = 0
        while di < doms.len() {
            let dom = doms[di]
            if !by_domain.contains_key(dom) {
                by_domain[dom] = []
            }
            by_domain[dom] = append(by_domain[dom], nid)
            di = di + 1
        }
        i = i + 1
    }

    let mut cross_count = 0

    // 3a. 도메인 매칭 (다른 계층 간)
    let mut di = 0
    while di < DOMAINS.len() {
        let dom = DOMAINS[di]
        if !by_domain.contains_key(dom) {
            di = di + 1
            continue
        }
        let nids = by_domain[dom]
        let mut ai = 0
        while ai < nids.len() {
            let a = nids[ai]
            let la = node_layers[a]
            let mut bi = ai + 1
            while bi < nids.len() {
                let b = nids[bi]
                let lb = node_layers[b]
                if la != lb {
                    let key = a + "|" + b + "|domain_" + dom
                    let rev = b + "|" + a + "|domain_" + dom
                    if !edge_set.contains_key(key) && !edge_set.contains_key(rev) {
                        edge_set[key] = 1
                        merged_edges = append(merged_edges, [a, b, "domain_" + dom])
                        cross_count = cross_count + 1
                    }
                }
                bi = bi + 1
            }
            ai = ai + 1
        }
        di = di + 1
    }
    println("  domain links: " + to_string(cross_count))

    // 3b. 인접 계층 키워드 브릿지 (2+ 공통)
    let mut kw_count = 0
    let mut layer_a = 0
    while layer_a < 4 {
        let layer_b = layer_a + 1
        // 계층별 노드 수집
        let mut la_nodes = []
        let mut lb_nodes = []
        i = 0
        while i < all_nodes.len() {
            let nid = to_string(all_nodes[i]["id"])
            let l = node_layers[nid]
            if l == layer_a { la_nodes = append(la_nodes, nid) }
            if l == layer_b { lb_nodes = append(lb_nodes, nid) }
            i = i + 1
        }

        let mut ai = 0
        while ai < la_nodes.len() {
            let a = la_nodes[ai]
            let kw_a = node_kws[a]
            if kw_a.len() >= 2 {
                let mut bi = 0
                while bi < lb_nodes.len() {
                    let b = lb_nodes[bi]
                    let overlap = count_common_kw(kw_a, node_kws[b])
                    if overlap >= 2 {
                        let key = a + "|" + b + "|keyword_bridge"
                        let rev = b + "|" + a + "|keyword_bridge"
                        if !edge_set.contains_key(key) && !edge_set.contains_key(rev) {
                            edge_set[key] = 1
                            merged_edges = append(merged_edges, [a, b, "keyword_bridge"])
                            kw_count = kw_count + 1
                        }
                    }
                    bi = bi + 1
                }
            }
            ai = ai + 1
        }
        layer_a = layer_a + 1
    }
    println("  keyword bridges: " + to_string(kw_count))

    // 3c. BT/DSE/product → nexus 노드 (도메인 공명)
    let mut resonance_count = 0
    i = 0
    while i < all_nodes.len() {
        let nid = to_string(all_nodes[i]["id"])
        let mut ntype = ""
        try { ntype = to_string(all_nodes[i]["type"]) } catch e {}

        let is_arch = ntype == "breakthrough" || ntype == "dse_domain" || ntype == "product"
        if !is_arch {
            i = i + 1
            continue
        }

        let n_doms = node_doms[nid]
        if n_doms.len() == 0 {
            i = i + 1
            continue
        }

        let etype = if ntype == "breakthrough" { "bt_resonance" } else if ntype == "dse_domain" { "dse_resonance" } else { "product_link" }

        // nexus 노드와 매칭
        let mut j = 0
        while j < nx_count {
            let nx_nid = to_string(all_nodes[j]["id"])
            if has_common(n_doms, node_doms[nx_nid]) {
                let key = nid + "|" + nx_nid + "|" + etype
                let rev = nx_nid + "|" + nid + "|" + etype
                if !edge_set.contains_key(key) && !edge_set.contains_key(rev) {
                    edge_set[key] = 1
                    merged_edges = append(merged_edges, [nid, nx_nid, etype])
                    resonance_count = resonance_count + 1
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    println("  resonance links: " + to_string(resonance_count))
    println("  total cross-links: " + to_string(cross_count + kw_count + resonance_count))

    // 4. 출력
    println("[4/4] Writing merged map...")

    // 계층별 통계
    let mut lc = #{0: 0, 1: 0, 2: 0, 3: 0, 4: 0}
    i = 0
    while i < all_nodes.len() {
        let l = node_layers[to_string(all_nodes[i]["id"])]
        lc[l] = lc[l] + 1
        i = i + 1
    }

    // JSON 직렬화
    let mut nodes_json = ""
    i = 0
    while i < all_nodes.len() {
        if i > 0 { nodes_json = nodes_json + ",\n" }
        nodes_json = nodes_json + node_to_json(all_nodes[i])
        i = i + 1
    }

    let mut edges_json = ""
    i = 0
    while i < merged_edges.len() {
        if i > 0 { edges_json = edges_json + ",\n" }
        edges_json = edges_json + edge_to_json(merged_edges[i][0], merged_edges[i][1], merged_edges[i][2])
        i = i + 1
    }

    let ts = exec("date -u +%Y-%m-%dT%H:%M:%S").trim()
    let mut output = "{\n  \"meta\": {\n"
    output = output + "    \"title\": \"n=6 Architecture — Unified Map\",\n"
    output = output + "    \"version\": \"3.0-merged\",\n"
    output = output + "    \"source\": \"nexus SSOT + n6-arch (BT/DSE/products)\",\n"
    output = output + "    \"date\": \"" + ts + "\",\n"
    output = output + "    \"layers\": {\"0\":\"Constants & Elements\",\"1\":\"Materials & Chemistry\",\"2\":\"Applications & Combinations\",\"3\":\"Technology & Techniques\",\"4\":\"Products\"},\n"
    output = output + "    \"node_count\": " + to_string(all_nodes.len()) + ",\n"
    output = output + "    \"edge_count\": " + to_string(merged_edges.len()) + ",\n"
    output = output + "    \"layer_counts\": {\"0\":" + to_string(lc[0]) + ",\"1\":" + to_string(lc[1]) + ",\"2\":" + to_string(lc[2]) + ",\"3\":" + to_string(lc[3]) + ",\"4\":" + to_string(lc[4]) + "}\n"
    output = output + "  },\n"
    output = output + "  \"nodes\": [\n" + nodes_json + "\n  ],\n"
    output = output + "  \"edges\": [\n" + edges_json + "\n  ]\n"
    output = output + "}\n"

    write_file(out_path, output)

    println("\n✅ " + out_path)
    println("   Nodes: " + to_string(all_nodes.len()) + " (L0=" + to_string(lc[0]) + " L1=" + to_string(lc[1]) + " L2=" + to_string(lc[2]) + " L3=" + to_string(lc[3]) + " L4=" + to_string(lc[4]) + ")")
    println("   Edges: " + to_string(merged_edges.len()))
    println("   Cross: domain=" + to_string(cross_count) + " keyword=" + to_string(kw_count) + " resonance=" + to_string(resonance_count))
}

main()
