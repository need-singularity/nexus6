// map_merge.hexa — nexus SSOT + n6-arch 병합 + 전계층 크로스링크
// 사용: hexa map_merge.hexa
//
// nexus/docs/n6-map-data.json (SSOT) + n6-architecture 고유 콘텐츠 병합
// rm_* reality 노드 제외, 전계층 도메인+키워드 크로스링크 생성
// 출력: n6-architecture/docs/n6-map-data.json

let home = exec("printenv HOME").trim()
let dev = home + "/Dev"
let nexus_map = dev + "/nexus/docs/n6-map-data.json"
let n6arch_map = dev + "/n6-architecture/docs/n6-map-data.json"

fn main() {
    println("=== map_merge.hexa — nexus SSOT + n6-arch 병합 ===")

    // hexa는 오케스트레이터, 무거운 JSON 처리는 /usr/bin/python3 위임
    // 스크립트를 파일로 저장 후 실행 (exec 단일 문자열 제한 우회)
    let script_path = dev + "/nexus/.tmp_map_merge.py"
    let py_code = "import json,re,sys\nfrom collections import Counter\nfrom datetime import datetime,timezone\n\nDOMAIN_KW={\n"
    let py2 = "  'fusion':{'fusion','plasma','tokamak','tritium','deuterium','magnetic','confinement','iter','stellarator'},\n"
    let py3 = "  'chip':{'chip','semiconductor','transistor','silicon','dram','memory','nand','cpu','gpu','fpga','lithograph','wafer'},\n"
    let py4 = "  'energy':{'energy','solar','battery','grid','power','wind','turbine','thermal','hydrogen','fuel','supercapacitor'},\n"
    let py5 = "  'ai':{'neural','attention','transformer','scaling','inference','training','llm','dropout','embedding','gradient','diffusion'},\n"
    let py6 = "  'physics':{'particle','quantum','neutrino','cosmology','relativity','gravity','string','higgs','boson','quark','lepton','gluon','gauge'},\n"
    let py7 = "  'chemistry':{'chemistry','synthesis','element','compound','reaction','catalyst','enzyme','molecular','bond','orbital','valence'},\n"
    let py8 = "  'materials':{'material','crystal','alloy','polymer','ceramic','graphene','superconductor','composite','diamond','topological','piezo'},\n"
    let py9 = "  'biology':{'biology','cell','gene','protein','dna','rna','amino','photosynthesis','metabolism','mitosis'},\n"
    let py10 = "  'astronomy':{'star','planet','galaxy','orbit','cosmic','pulsar','neutron','supernova','nebula','celestial'},\n"
    let py11 = "  'math':{'theorem','prime','modular','zeta','ramanujan','euler','bernoulli','riemann','algebraic','topology','manifold'},\n"
    let py12 = "  'robotics':{'robot','actuator','servo','locomotion','manipulator','humanoid','autonomous','sensor','lidar'},\n"
    let py13 = "  'software':{'compiler','operating','programming','algorithm','database','kernel','runtime','protocol'},\n"
    let py14 = "  'display':{'display','oled','lcd','pixel','refresh','hdr','panel'},\n"
    let py15 = "  'audio':{'audio','speaker','acoustic','noise','codec','frequency','resonance','harmonic'},\n"
    let py16 = "  'aerospace':{'aerospace','rocket','satellite','propulsion','space','launch','reentry'},\n"
    let py17 = "  'environment':{'environment','carbon','water','recycling','desalination','pollution','climate','ocean'},\n"
    let py18 = "  'economics':{'economics','market','currency','trade','inflation','supply','demand'},\n"
    let py19 = "  'geology':{'geology','tectonic','mineral','volcanic','sediment','mantle','crust'},\n"
    let py20 = "  'music':{'music','harmony','consonance','octave','tuning','scale','rhythm','chord'},\n"
    let py21 = "  'linguistics':{'linguistics','phoneme','syntax','morpheme','grammar','vowel','consonant'},\n"
    let py22 = "  'meteorology':{'weather','atmosphere','pressure','tornado','hurricane','precipitation','cloud'},\n}\n\n"

    let py_stop = "STOP={'the','and','for','with','from','that','this','are','was','were','has','have','had',\n  'not','but','can','all','one','two','its','also','been','into','more','new','than',\n  'each','most','some','such','very','just','like','over','only','same','when','will',\n  'used','based','using','high','low','level','type','layer','node','none','true','false'}\n\n"
    let py_gen = "GEN_TYPES={'keyword_bridge','bt_resonance','dse_resonance','product_link'}\nGEN_PFX=['domain_']\ndef is_gen(t):\n  if t in GEN_TYPES: return True\n  return any(t.startswith(p) for p in GEN_PFX)\n\n"
    let py_funcs = "def kw(t):\n  return {w for w in re.split(r'[\\\\s,/_\\\\-()]+',t.lower()) if len(w)>=4 and w not in STOP}\n\ndef doms(t):\n  kws={w for w in re.split(r'[\\\\s,/_\\\\-()]+',t.lower()) if len(w)>=3}\n  return {d for d,dk in DOMAIN_KW.items() if kws&dk}\n\ndef ntxt(n):\n  return ' '.join(str(n.get(k,'')) for k in ['label','description','note','title','domain','level'])\n\n"

    let py_main = "nx=json.load(open('" + nexus_map + "'))\nn6=json.load(open('" + n6arch_map + "'))\n"
    let py_main2 = "nx_ids={n['id'] for n in nx['nodes']}\nnx_nodes=nx['nodes']\n"
    let py_main3 = "uniq=[n for n in n6['nodes'] if not n['id'].startswith('rm_') and n['id'] not in nx_ids]\n"
    let py_main4 = "all_n=nx_nodes+uniq\nall_ids={n['id'] for n in all_n}\nprint(f'nexus:{len(nx_nodes)} uniq:{len(uniq)} merged:{len(all_n)}',file=sys.stderr)\n\n"

    let py_edges = "edges=[]\nedge_set=set()\ndef add_e(s,t,tp):\n  if s==t or (s,t,tp) in edge_set or (t,s,tp) in edge_set: return\n  edge_set.add((s,t,tp))\n  edges.append({'source':s,'target':t,'type':tp})\n\n"
    let py_edges2 = "for e in nx['edges']:\n  s=e.get('source',e.get('from',''))\n  t=e.get('target',e.get('to',''))\n  tp=e.get('type','nexus_link')\n  if s in all_ids and t in all_ids: add_e(s,t,tp)\n\n"
    let py_edges3 = "for e in n6['edges']:\n  s,t=e.get('source',''),e.get('target','')\n  tp=e.get('type','n6arch_link')\n  if s.startswith('rm_') or t.startswith('rm_'): continue\n  if is_gen(tp): continue\n  if s in all_ids and t in all_ids: add_e(s,t,tp)\nprint(f'base_edges:{len(edges)}',file=sys.stderr)\n\n"

    let py_cross = "# domain cache\nnd={n['id']:doms(ntxt(n)) for n in all_n}\nnk={n['id']:kw(ntxt(n)) for n in all_n}\nnl={n['id']:n.get('layer',0) for n in all_n}\n\n"
    let py_cross2 = "# domain crosslinks (same domain + different layer, cap per domain pair)\nby_dom={}\nfor n in all_n:\n  for d in nd[n['id']]: by_dom.setdefault(d,[]).append(n['id'])\ndc=0\nfor dom,nids in by_dom.items():\n  # group by layer, link only adjacent layers\n  bl={}\n  for nid in nids: bl.setdefault(nl[nid],[]).append(nid)\n  layers=sorted(bl.keys())\n  for li in range(len(layers)-1):\n    la,lb=layers[li],layers[li+1]\n    if abs(la-lb)>1: continue\n    for a in bl[la]:\n      for b in bl[lb]:\n        add_e(a,b,f'domain_{dom}'); dc+=1\nprint(f'domain_links:{dc}',file=sys.stderr)\n\n"
    let py_cross3 = "# keyword bridges (adjacent layers, 7+ common keywords, 4+ chars, no stop words)\nkc=0\nby_layer={i:[n['id'] for n in all_n if n.get('layer',0)==i] for i in range(5)}\nfor la in range(4):\n  lb=la+1\n  for a in by_layer[la]:\n    ka=nk[a]\n    if len(ka)<7: continue\n    for b in by_layer[lb]:\n      if len(ka&nk[b])>=7: add_e(a,b,'keyword_bridge'); kc+=1\nprint(f'kw_bridges:{kc}',file=sys.stderr)\n\n"
    let py_cross4 = "# BT/DSE/product resonance (2+ domain overlap)\nrc=0\nnx_set={n['id'] for n in nx_nodes}\nfor n in all_n:\n  tp=n.get('type','')\n  if tp not in ('breakthrough','dse_domain','product'): continue\n  n_d=nd[n['id']]\n  if len(n_d)<2: continue\n  et={'breakthrough':'bt_resonance','dse_domain':'dse_resonance','product':'product_link'}[tp]\n  for nx_id in nx_set:\n    if len(n_d&nd.get(nx_id,set()))>=2: add_e(n['id'],nx_id,et); rc+=1\nprint(f'resonance:{rc} total_edges:{len(edges)}',file=sys.stderr)\n\n"

    let py_out = "lc=Counter(n.get('layer',0) for n in all_n)\nout={'meta':{'title':'n=6 Architecture - Unified Map','version':'3.0-merged','source':'nexus SSOT + n6-arch (BT/DSE/products)','date':datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%S'),'layers':{'0':'Constants & Elements','1':'Materials & Chemistry','2':'Applications & Combinations','3':'Technology & Techniques','4':'Products'},'node_count':len(all_n),'edge_count':len(edges),'layer_counts':dict(sorted(lc.items()))},'nodes':all_n,'edges':edges}\n"
    let py_out2 = "json.dump(out,open('" + n6arch_map + "','w'),ensure_ascii=False,indent=2)\nprint(f'DONE nodes:{len(all_n)} edges:{len(edges)} L0:{lc[0]} L1:{lc[1]} L2:{lc[2]} L3:{lc[3]} L4:{lc[4]}',file=sys.stderr)\n"

    let full_script = py_code + py2 + py3 + py4 + py5 + py6 + py7 + py8 + py9 + py10 + py11 + py12 + py13 + py14 + py15 + py16 + py17 + py18 + py19 + py20 + py21 + py22 + py_stop + py_gen + py_funcs + py_main + py_main2 + py_main3 + py_main4 + py_edges + py_edges2 + py_edges3 + py_cross + py_cross2 + py_cross3 + py_cross4 + py_out + py_out2

    write_file(script_path, full_script)
    println("[exec] Running merge engine...")
    let result = to_string(exec("/usr/bin/python3 " + script_path + " 2>&1"))
    println(result)

    // 임시 스크립트 정리
    exec("rm -f " + script_path)
    println("✅ 병합 완료 → " + n6arch_map)
}

main()
