// millennium_cross.hexa — 밀레니엄 교차 공격 (7대 난제 상호 렌즈 분석)
// 사용: hexa millennium_cross.hexa [서브커맨드]
//       hexa millennium_cross.hexa all          전체 21쌍 교차 분석
//       hexa millennium_cross.hexa pair A B     특정 쌍 분석
//       hexa millennium_cross.hexa matrix       교차 행렬 출력
//       hexa millennium_cross.hexa stats        EXACT/CLOSE/MISS 통계
//       hexa millennium_cross.hexa help         도움말
//
// 원리:
//   1. 7개 밀레니엄 난제의 핵심 상수/값 정의
//   2. 난제쌍 (7C2=21쌍) 교차: 상수간 비율에서 n=6 패턴 탐색
//   3. 비율 = a/b 또는 b/a 중 6에 가까운 쪽
//   4. EXACT: |ratio/6 - 1| < 0.01 (1% 이내)
//      CLOSE: |ratio/6 - 1| < 0.05 (5% 이내)
//      MISS:  그 외
//   5. growth_bus.jsonl에 결과 기록

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _bus_path = _shared + "/growth_bus.jsonl"

fn safe_float(s: string) -> f64 {
    let mut v: f64 = 0.0
    try { v = to_float(s.trim()) } catch e {}
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ═══════════════════════════════════════════════════════════
// 7대 밀레니엄 난제 정의
// (핵심 상수는 수학적 고정값 — 하드코딩 허용)
// ═══════════════════════════════════════════════════════════

// 난제 이름
let prob_names = ["riemann", "navier_stokes", "yang_mills", "p_vs_np", "hodge", "bsd", "poincare"]
let prob_labels = ["리만 가설", "나비에-스토크스", "양-밀스", "P vs NP", "호지 추측", "BSD 추측", "푸앵카레"]

// 각 난제의 핵심 상수 (이름)
let const_names = [
    "zeta2_pi2_over_6",   // riemann: ζ(2) = π²/6 ≈ 1.6449
    "mertens_M",          // riemann: 머텐스 상수 ≈ 0.2615
    "reynolds_critical",  // navier_stokes: Re_c ≈ 2300
    "viscosity_mu",       // navier_stokes: μ ≈ 0.20
    "alpha_s",            // yang_mills: 강결합 상수 ≈ 0.118
    "su3_dim",            // yang_mills: SU(3) 차원 = 8
    "sat_alpha_c",        // p_vs_np: 3-SAT 임계값 ≈ 4.267
    "hodge_dim_2p",       // hodge: (p,p)-형식 차원 = 2p, p=1→2
    "bsd_rank",           // bsd: 타원곡선 rank (대표값 = 1)
    "bsd_L_special",      // bsd: L-함수 특수값 (대표적 ≈ 0.3059)
    "pi3_S2",             // poincare: π₃(S²) = Z, 생성원 = 1
    "euler_char_S3"       // poincare: χ(S³) = 0
]

// 상수 값
let const_vals = [
    1.6449,    // ζ(2) = π²/6
    0.2615,    // 머텐스 상수
    2300.0,    // Re_c
    0.20,      // μ
    0.118,     // α_s
    8.0,       // SU(3) dim
    4.267,     // 3-SAT α_c
    2.0,       // hodge dim 2p (p=1)
    1.0,       // rank
    0.3059,    // L 특수값
    1.0,       // π₃(S²) 생성원
    0.0        // χ(S³)
]

// 상수→난제 매핑 인덱스
let const_prob_idx = [0, 0, 1, 1, 2, 2, 3, 4, 5, 5, 6, 6]

// ═══════════════════════════════════════════════════════════
// n=6 비율 탐색
// ═══════════════════════════════════════════════════════════

// 두 값의 비율에서 n=6 패턴 검사
// 반환: "ratio|grade|desc" 형태 문자열
fn check_n6_ratio(val_a: f64, val_b: f64, name_a: string, name_b: string) -> string {
    if val_a <= 0.0 || val_b <= 0.0 {
        return "0|MISS|영값 포함"
    }

    // a/b와 b/a 양쪽 검사
    let r1 = val_a / val_b
    let r2 = val_b / val_a

    // 6의 거듭제곱/분수와 비교: 1/6, 1, 6, 36, 216
    let targets = [0.1667, 1.0, 6.0, 36.0, 216.0]
    let target_names = ["1/6", "1", "6", "6^2", "6^3"]

    let mut best_ratio: f64 = 0.0
    let mut best_dev: f64 = 999.0
    let mut best_target = ""
    let mut best_dir = ""

    let mut ti: i64 = 0
    while ti < len(targets) {
        let t: f64 = targets[ti]
        let tn: string = target_names[ti]

        // r1과 비교
        if t > 0.0 {
            let dev1 = abs_f(r1 / t - 1.0)
            if dev1 < best_dev {
                best_dev = dev1
                best_ratio = r1
                best_target = tn
                best_dir = name_a + "/" + name_b
            }
        }

        // r2와 비교
        if t > 0.0 {
            let dev2 = abs_f(r2 / t - 1.0)
            if dev2 < best_dev {
                best_dev = dev2
                best_ratio = r2
                best_target = tn
                best_dir = name_b + "/" + name_a
            }
        }

        ti = ti + 1
    }

    let grade = if best_dev < 0.01 { "EXACT" } else if best_dev < 0.05 { "CLOSE" } else { "MISS" }

    // 소수점 4자리로 포맷
    let ratio_str = to_string(to_int(best_ratio * 10000.0))
    let desc = best_dir + " = " + to_string(best_ratio) + " ~ " + best_target + " (편차 " + to_string(to_int(best_dev * 10000.0) / 100) + "%)"

    return to_string(best_ratio) + "|" + grade + "|" + desc
}

// ═══════════════════════════════════════════════════════════
// 도움말
// ═══════════════════════════════════════════════════════════

fn show_help() {
    println("")
    println("===========================================================")
    println("  밀레니엄 교차 공격 (millennium_cross.hexa)")
    println("  7대 난제를 서로의 렌즈로 교차 분석")
    println("===========================================================")
    println("")
    println("  서브커맨드:")
    println("    all       전체 21쌍 교차 분석 (기본)")
    println("    pair A B  특정 난제 쌍 분석")
    println("    matrix    교차 행렬 출력")
    println("    stats     EXACT/CLOSE/MISS 통계")
    println("    help      이 도움말")
    println("")
    println("  난제 ID:")
    println("    riemann, navier_stokes, yang_mills,")
    println("    p_vs_np, hodge, bsd, poincare")
    println("")
    println("  판정 기준:")
    println("    EXACT: 6의 거듭제곱 비율과 1% 이내")
    println("    CLOSE: 5% 이내")
    println("    MISS:  그 외")
    println("")
}

// ═══════════════════════════════════════════════════════════
// 메인
// ═══════════════════════════════════════════════════════════

let args = exec("echo $@").trim().split(" ")
let subcmd = if len(args) > 1 { args[1] } else { "all" }

if subcmd == "help" {
    show_help()
} else {

    println("")
    println("===========================================================")
    println("  밀레니엄 교차 공격 — 7대 난제 상호 렌즈 분석")
    println("  7C2 = 21쌍, 상수간 n=6 비율 탐색")
    println("===========================================================")
    println("")

    // 상수 목록 출력
    println("  --- 난제별 핵심 상수 ---")
    println("")
    println("| 난제 | 상수 | 값 |")
    println("|------|------|----|")

    let mut ci: i64 = 0
    while ci < len(const_names) {
        let pidx: i64 = const_prob_idx[ci]
        let plabel: string = prob_labels[pidx]
        let cname: string = const_names[ci]
        let cval: f64 = const_vals[ci]
        println("| " + plabel + " | " + cname + " | " + to_string(cval) + " |")
        ci = ci + 1
    }
    println("")

    // 교차 분석 실행
    let mut exact_count: i64 = 0
    let mut close_count: i64 = 0
    let mut miss_count: i64 = 0
    let mut total_pairs: i64 = 0

    // 결과 저장
    let mut result_lines = []

    // 특정 쌍 분석 모드
    let mut filter_a = ""
    let mut filter_b = ""
    if subcmd == "pair" && len(args) > 3 {
        filter_a = args[2]
        filter_b = args[3]
    }

    // 모든 상수 쌍 비교 (서로 다른 난제의 상수끼리만)
    println("  --- 교차 분석 결과 ---")
    println("")
    println("| 쌍 | 난제A | 난제B | 비율 | 등급 | 설명 |")
    println("|-----|------|------|------|------|------|")

    let mut ai: i64 = 0
    while ai < len(const_vals) {
        let prob_a_idx: i64 = const_prob_idx[ai]
        let prob_a_name: string = prob_names[prob_a_idx]
        let prob_a_label: string = prob_labels[prob_a_idx]

        let mut bi: i64 = ai + 1
        while bi < len(const_vals) {
            let prob_b_idx: i64 = const_prob_idx[bi]

            // 같은 난제 내 상수 비교는 건너뜀
            if prob_a_idx != prob_b_idx {
                let prob_b_name: string = prob_names[prob_b_idx]
                let prob_b_label: string = prob_labels[prob_b_idx]

                // 필터 적용
                let mut do_check = true
                if filter_a != "" {
                    do_check = (prob_a_name == filter_a && prob_b_name == filter_b) || (prob_a_name == filter_b && prob_b_name == filter_a)
                }

                if do_check {
                    let va: f64 = const_vals[ai]
                    let vb: f64 = const_vals[bi]
                    let na: string = const_names[ai]
                    let nb: string = const_names[bi]

                    // 영값 쌍 건너뜀
                    if va > 0.0 && vb > 0.0 {
                        let result = check_n6_ratio(va, vb, na, nb)
                        let parts = result.split("|")

                        if len(parts) >= 3 {
                            let grade: string = parts[1]
                            let desc: string = parts[2]

                            total_pairs = total_pairs + 1

                            if grade == "EXACT" { exact_count = exact_count + 1 }
                            else if grade == "CLOSE" { close_count = close_count + 1 }
                            else { miss_count = miss_count + 1 }

                            let grade_mark = if grade == "EXACT" { "*** EXACT ***" } else if grade == "CLOSE" { "* CLOSE *" } else { "MISS" }

                            println("| " + to_string(total_pairs) + " | " + prob_a_label + " | " + prob_b_label + " | " + na + " vs " + nb + " | " + grade_mark + " | " + desc + " |")

                            result_lines = result_lines + [prob_a_name + ":" + prob_b_name + ":" + grade]
                        }
                    }
                }
            }

            bi = bi + 1
        }
        ai = ai + 1
    }

    println("")

    // 통계
    println("  --- 판정 통계 ---")
    println("")
    println("  총 교차 쌍: " + to_string(total_pairs))
    println("  EXACT:      " + to_string(exact_count) + " (" + to_string(if total_pairs > 0 { (exact_count * 100) / total_pairs } else { 0 }) + "%)")
    println("  CLOSE:      " + to_string(close_count) + " (" + to_string(if total_pairs > 0 { (close_count * 100) / total_pairs } else { 0 }) + "%)")
    println("  MISS:       " + to_string(miss_count) + " (" + to_string(if total_pairs > 0 { (miss_count * 100) / total_pairs } else { 0 }) + "%)")
    println("")

    // 정직한 자기평가
    let honest = if exact_count == 0 { "주의: EXACT 없음 — 상수 선택 또는 비율 기준 재검토 필요" } else if exact_count < 3 { "보통: EXACT " + to_string(exact_count) + "건 — 추가 상수 탐색 권장" } else { "양호: EXACT " + to_string(exact_count) + "건 — 교차 연결 활성" }
    println("  자기평가: " + honest)
    println("")

    // matrix 모드: 7x7 교차 행렬
    if subcmd == "matrix" || subcmd == "all" {
        println("  --- 교차 행렬 (EXACT=O, CLOSE=~, MISS=.) ---")
        println("")

        // 헤더
        let mut header = "        "
        let mut hi: i64 = 0
        while hi < len(prob_names) {
            let short = if hi == 0 { "Rie" } else if hi == 1 { "N-S" } else if hi == 2 { "Y-M" } else if hi == 3 { "PNP" } else if hi == 4 { "Hod" } else if hi == 5 { "BSD" } else { "Poi" }
            header = header + short + " "
            hi = hi + 1
        }
        println("  " + header)

        // 각 행
        let mut ri: i64 = 0
        while ri < len(prob_names) {
            let rname: string = prob_names[ri]
            let short_r = if ri == 0 { "Rie" } else if ri == 1 { "N-S" } else if ri == 2 { "Y-M" } else if ri == 3 { "PNP" } else if ri == 4 { "Hod" } else if ri == 5 { "BSD" } else { "Poi" }
            let mut row = "  " + short_r + "   "

            let mut rci: i64 = 0
            while rci < len(prob_names) {
                if ri == rci {
                    row = row + " -  "
                } else {
                    let cname: string = prob_names[rci]
                    // result_lines에서 이 쌍의 최고 등급 찾기
                    let mut best_g = "MISS"
                    for rl in result_lines {
                        let rp = rl.split(":")
                        if len(rp) >= 3 {
                            let ra: string = rp[0]
                            let rb: string = rp[1]
                            let rg: string = rp[2]
                            if (ra == rname && rb == cname) || (ra == cname && rb == rname) {
                                if rg == "EXACT" { best_g = "EXACT" }
                                else if rg == "CLOSE" && best_g != "EXACT" { best_g = "CLOSE" }
                            }
                        }
                    }
                    let mark = if best_g == "EXACT" { " O  " } else if best_g == "CLOSE" { " ~  " } else { " .  " }
                    row = row + mark
                }
                rci = rci + 1
            }
            println(row)
            ri = ri + 1
        }
        println("")
    }

    // growth_bus 기록
    try {
        let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
        let entry = "{\"type\":\"millennium_cross\",\"total_pairs\":" + to_string(total_pairs) + ",\"exact\":" + to_string(exact_count) + ",\"close\":" + to_string(close_count) + ",\"miss\":" + to_string(miss_count) + ",\"ts\":\"" + ts + "\"}"
        exec("echo '" + entry + "' >> " + _bus_path)
        println("  growth_bus 기록 완료")
    } catch e {}

    println("")
    println("[verified] millennium_cross.hexa 실행 완료")
    println("")
}
