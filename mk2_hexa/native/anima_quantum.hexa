// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

fn main() {
    let cli = args()
    let argc = len(cli)

    // Parse command
    let mut cmd = "scan"
    let mut domain = "consciousness"

    if argc >= 3 { cmd = cli[2] }
    if argc >= 4 { domain = cli[3] }

    if cmd == "help" || cmd == "--help" || cmd == "-h" {
        show_help()
        return
    }

    if cmd == "scan" {
        run_scan(domain)
        return
    }

    if cmd == "collapse" {
        run_collapse(domain)
        return
    }

    // Unknown command
    println("[!] Unknown command: " + cmd)
    println("    Use 'help' for usage info.")
}

main()
