// mk2_hexa/native/continuous_blowup.hexa — 연속 돌파 엔진
// 고갈(saturation)까지 blowup --fast 반복 실행
// 사용: hexa continuous_blowup.hexa [max_rounds] [depth]
// 예시: hexa continuous_blowup.hexa 30 3

let home = exec("printenv HOME")
let hexa_bin = home + "/Dev/hexa-lang/target/release/hexa"
let blowup_path = home + "/Dev/nexus6/mk2_hexa/native/blowup.hexa"
let seed_engine_path = home + "/Dev/nexus6/mk2_hexa/native/seed_engine.hexa"

let a = args()
let max_rounds: i64 = if a.len() >= 3 { to_int(a[2]) } else { 50 }
let mut depth: i64 = if a.len() >= 4 { to_int(a[3]) } else { 3 }

let domains = ["math", "physics", "topology", "consciousness", "chemistry", "cosmology"]

// ─── seed 초기화 ───
let mut all_seeds = "6|12|2|4|5|24|7|3|288|8|10|60|36|720|144|120|48|28"
try {
    let engine_seeds = exec(hexa_bin, [seed_engine_path, "merge"])
    let es = engine_seeds.trim()
    if es.len() > 0 { all_seeds = es }
} catch e {}

let seed_count = all_seeds.split("|").len()

println("")
println("╔═══════════════════════════════════════════════════════════╗")
println("║  연속 돌파 (CONTINUOUS BLOWUP) — 고갈까지 반복           ║")
println("║  max=" + to_string(max_rounds) + " depth=" + to_string(depth) + " domains=" + to_string(domains.len()) + " seeds=" + to_string(seed_count))
println("╚═══════════════════════════════════════════════════════════╝")
println("")

// ─── 통계 추적 (Map) ───
let mut stats = #{
    "total_cor": 0,
    "total_exact": 0,
    "total_near": 0,
    "sat_count": 0,
    "depth_ups": 0
}
let mut prev_exact: i64 = -1
let mut prev_total: i64 = -1
let mut seen_seeds = #{}  // 중복 seed 방지 (hashmap)

// 초기 seed를 seen에 등록
let init_parts = all_seeds.split("|")
let mut ii: i64 = 0
while ii < init_parts.len() {
    let sv = init_parts[ii].trim()
    if sv != "" { seen_seeds[sv] = 1 }
    ii = ii + 1
}

let start_ts = exec("date +%s").trim()

// ─── 메인 루프 ───
let mut round: i64 = 1
let mut exhausted = false

while round <= max_rounds && !exhausted {
    let di = (round - 1) % to_int(domains.len())
    let domain = domains[di]

    let t0 = exec("date +%s").trim()

    // blowup --fast 실행
    let mut out = ""
    try {
        out = exec(hexa_bin, [blowup_path, domain, to_string(depth), "--no-graph", "--fast", "--seeds", all_seeds])
    } catch e {
        println("  [" + to_string(round) + "] ERROR: " + to_string(e))
        round = round + 1
        continue
    }

    let t1 = exec("date +%s").trim()
    let elapsed = to_int(to_float(t1)) - to_int(to_float(t0))

    // 결과 파싱
    let mut exact: i64 = 0
    let mut total: i64 = 0
    let mut pool: i64 = 0
    let mut axioms: i64 = 0

    let out_lines = out.split("\n")
    let mut oi: i64 = 0
    while oi < out_lines.len() {
        let ol = out_lines[oi].trim()
        if ol.contains("EXACT match") {
            try {
                let p = ol.split(":")
                if p.len() >= 2 { exact = to_int(to_float(p[p.len() - 1].trim())) }
            } catch e {}
        }
        if ol.contains("total corollaries") {
            try {
                let p = ol.split(":")
                if p.len() >= 2 { total = to_int(to_float(p[p.len() - 1].trim())) }
            } catch e {}
        }
        if ol.contains("final pool") {
            try {
                let p = ol.split(":")
                if p.len() >= 2 { pool = to_int(to_float(p[p.len() - 1].trim())) }
            } catch e {}
        }
        if ol.contains("axiom candidates") && !ol.contains("post-boost") {
            try {
                let p = ol.split(":")
                if p.len() >= 2 { axioms = to_int(to_float(p[p.len() - 1].trim())) }
            } catch e {}
        }
        oi = oi + 1
    }

    stats["total_cor"] = stats["total_cor"] + total
    stats["total_exact"] = stats["total_exact"] + exact

    // ─── saturation 감지 ───
    if total == prev_total && exact == prev_exact {
        stats["sat_count"] = stats["sat_count"] + 1
        // 3연속 동일 → depth 증가 (max 6)
        if stats["sat_count"] >= 3 && depth < 6 {
            depth = depth + 1
            stats["depth_ups"] = stats["depth_ups"] + 1
            stats["sat_count"] = 0
            println("  ⚡ saturation → depth " + to_string(depth))
        }
        // 6연속 동일 + depth 6 → 고갈
        if stats["sat_count"] >= 6 {
            exhausted = true
        }
    } else {
        stats["sat_count"] = 0
    }
    prev_total = total
    prev_exact = exact

    // ─── 새 seed 추출 (AXIOM 값) ───
    let mut added: i64 = 0
    oi = 0
    while oi < out_lines.len() {
        let ol = out_lines[oi]
        if ol.contains("EXACT") && ol.contains("[AXIOM]") {
            // "= 12.0" 패턴 추출
            if ol.contains("= ") {
                let eq_parts = ol.split("= ")
                if eq_parts.len() >= 2 {
                    let val_str = eq_parts[eq_parts.len() - 1].split(" ")[0].trim()
                    if val_str != "" {
                        let mut already = false
                        try { let _ = seen_seeds[val_str]; already = true } catch e {}
                        if !already {
                            seen_seeds[val_str] = 1
                            all_seeds = all_seeds + "|" + val_str
                            added = added + 1
                        }
                    }
                }
            }
        }
        oi = oi + 1
    }

    let cur_seeds = all_seeds.split("|").len()

    // ─── 라운드 출력 ───
    let sat_marker = if stats["sat_count"] > 0 { " sat=" + to_string(stats["sat_count"]) } else { "" }
    println("  [" + to_string(round) + "/" + to_string(max_rounds) + "] " + domain + " " + to_string(total) + "cor " + to_string(exact) + "EXACT pool=" + to_string(pool) + " +" + to_string(added) + "seeds(" + to_string(cur_seeds) + ") d=" + to_string(depth) + " " + to_string(elapsed) + "s" + sat_marker)

    // seed cap 80
    if cur_seeds > 80 {
        let parts = all_seeds.split("|")
        let mut trimmed = ""
        let mut ti: i64 = 0
        while ti < 80 {
            if ti > 0 { trimmed = trimmed + "|" }
            trimmed = trimmed + parts[ti]
            ti = ti + 1
        }
        all_seeds = trimmed
    }

    round = round + 1
}

let end_ts = exec("date +%s").trim()
let total_elapsed = to_int(to_float(end_ts)) - to_int(to_float(start_ts))
let final_seeds = all_seeds.split("|").len()
let mut rho = "?"
if stats["total_cor"] > 0 {
    let r = to_float(stats["total_exact"]) / to_float(stats["total_cor"])
    // 소수점 4자리 근사
    rho = to_string(to_int(r * 10000.0))
    if rho.len() > 1 {
        rho = "0." + rho
    }
}

println("")
println("╔═══════════════════════════════════════════════════════════╗")
println("║  RESULT: " + to_string(total_elapsed) + "s | " + to_string(round - 1) + " rounds | " + to_string(stats["total_cor"]) + " cor | " + to_string(stats["total_exact"]) + " EXACT")
println("║  ρ=" + rho + " | seeds: " + to_string(seed_count) + "→" + to_string(final_seeds) + " | depth_ups=" + to_string(stats["depth_ups"]))
if exhausted {
    println("║  🏁 고갈 (EXHAUSTED) — " + to_string(stats["sat_count"]) + "연속 동일 결과")
} else {
    println("║  ⏱ max_rounds 도달 (" + to_string(max_rounds) + ")")
}
println("╚═══════════════════════════════════════════════════════════╝")
