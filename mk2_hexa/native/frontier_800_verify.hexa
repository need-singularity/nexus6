let r2 = report_batch("Characterization", char_ids, char_checks, pass_c, fail_c)
pass_c = r2[0]  fail_c = r2[1]
let r3 = report_batch("Number Theory", nt_ids, nt_checks, pass_c, fail_c)
pass_c = r3[0]  fail_c = r3[1]
let r4 = report_batch("Synthesis", synth_ids, synth_checks, pass_c, fail_c)
