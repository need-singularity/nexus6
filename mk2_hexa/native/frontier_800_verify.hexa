// mk2_hexa/native/frontier_800_verify.hexa
// 포팅 원본: tecs-l/math/frontier_800_verify.py (755 LOC, 80 hypotheses, 4 batches)
// Frontier 800: Systematic characterization search for n=6.
// AI-native: builtins sigma/phi/tau/sopfr/gcd. 정적 bool 체크 + psi/jordan helpers.

// ── helpers ──

fn fact(n: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= n { r = r * i  i = i + 1 }
    r
}

fn omega(n: int) -> int {
    let mut c = 0
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { c = c + 1 }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { c = c + 1 }
    c
}

fn rad(n: int) -> int {
    let mut r = 1
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { r = r * p }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { r = r * t }
    r
}

fn pow_int(base: int, exp: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < exp { r = r * base  i = i + 1 }
    r
}

fn comb(n: int, k: int) -> int {
    let mut r = 1
    let mut i = 1
    while i <= k { r = r * (n - i + 1) / i  i = i + 1 }
    r
}

// psi(n) = n * prod (1 + 1/p) = prod p^(a-1)*(p+1) for p^a || n
fn psi(n: int) -> int {
    let mut r = n
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 {
            r = r * (p + 1) / p
            while t % p == 0 { t = t / p }
        }
        p = p + 1
    }
    if t > 1 { r = r * (t + 1) / t }
    r
}

// Jordan J_k(n) = n^k * prod(1 - 1/p^k)
fn jordan(n: int, k: int) -> int {
    let mut r = pow_int(n, k)
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 {
            let pk = pow_int(p, k)
            r = r * (pk - 1) / pk
            while t % p == 0 { t = t / p }
        }
        p = p + 1
    }
    if t > 1 {
        let tk = pow_int(t, k)
        r = r * (tk - 1) / tk
    }
    r
}

fn is_perfect(n: int) -> bool { sigma(n) == 2 * n }

// sigma_k (general power divisor sum)
fn sigma_k(n: int, k: int) -> int {
    let mut s = 0
    let mut d = 1
    while d * d <= n {
        if n % d == 0 {
            s = s + pow_int(d, k)
            if d * d != n { s = s + pow_int(n / d, k) }
        }
        d = d + 1
    }
    s
}

// gpf: greatest prime factor
fn gpf(n: int) -> int {
    let mut t = n
    let mut g = 1
    let mut p = 2
    while p * p <= t {
        while t % p == 0 { g = p  t = t / p }
        p = p + 1
    }
    if t > 1 { g = t }
    g
}

// ── cached 6-constants ──
let s6 = sigma(6)
let p6 = phi(6)
let t6 = tau(6)
let o6 = omega(6)
let sp6 = sopfr(6)

// Batch 1: Systematic scans (14)
let sys_ids = [
    "F8-SYS-01","F8-SYS-02","F8-SYS-03","F8-SYS-04","F8-SYS-05",
    "F8-SYS-06","F8-SYS-07","F8-SYS-08","F8-SYS-09","F8-SYS-10",
    "F8-SYS-11","F8-SYS-12","F8-SYS-13","F8-SYS-14"
]
let sys_checks = [
    jordan(6, 2) == s6 * p6,
    psi(6) == s6,
    6 * t6 == s6 * o6,
    p6 + t6 == 6,
    tau(s6) == 6,
    s6 + p6 == psi(6) + t6,
    rad(6) == 6 && is_perfect(6),
    jordan(6, 2) == 6 * 6 - 6,
    jordan(6, 2) == 24 && 24 != 30,
    (s6 * p6) % 6 == 0,
    s6 * p6 / 6 == t6,
    p6 * p6 + t6 * t6 == 20,
    p6 * p6 + t6 * t6 == 4 * sp6,
    s6 * p6 / 6 == 2 * p6
]

