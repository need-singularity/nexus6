    fact(gpf(6)) == 6,
    is_perfect(6) && !is_perfect(24) && !is_perfect(120),
    6 == fact(3) && 6 == 3 * 4 / 2 && 120 == fact(5) && 120 == 15 * 16 / 2,
    is_perfect(6) && 6 == fact(3) && 6 == 3 * 4 / 2,
    s6 == sp6 + 6 + 1,
    s6 == sp6 + 6 + 1 && sp6 == 5,
    tau(fact(6)) == 30 && 30 == sp6 * 6,
    s6 == 2 * rad(6),
    phi(s6) == 6 - o6,
    phi(s6) == 6 - o6,
    p6 * sp6 == s6 - o6,
    p6 * sp6 == s6 - o6,
    s6 == p6 * sp6 + o6
]

// Batch 3: Number Theory gems (20)
