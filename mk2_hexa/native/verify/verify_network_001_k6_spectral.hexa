// Ported from tecs-l/verify/verify_network_001_K6_spectral.py — 2026-04-10
// H-NETWORK-001: K6 Spectral Properties and Consciousness
// Verify spectral properties of the complete graph K6 via trace method.
// Adjacency eigenvalues: (n-1) x1, (-1) x(n-1) → for K6: 5 x1, -1 x5.
// Laplacian eigenvalues: 0 x1, n x(n-1) → for K6: 0 x1, 6 x5.

let n = 6

// Adjacency trace identities (integer)
// tr(A)   = sum(eigs)    = (n-1) + (n-1)*(-1) = 0
// tr(A^2) = sum(eigs^2)  = (n-1)^2 + (n-1) = n*(n-1) = 30
// tr(A^3) = sum(eigs^3)  = (n-1)^3 - (n-1) = (n-1)*((n-1)^2-1) = 120
let tr_a = 0
let tr_a2 = n * (n - 1)           // 30
let tr_a3 = (n - 1) * ((n - 1) * (n - 1) - 1)  // 120

// Triangles in K6 = tr(A^3)/6 = C(6,3) = 20
let triangles = tr_a3 / 6         // 20
let c63 = 20                      // binomial(6,3)

// Spectral radius of K6 adjacency = n-1 = 5 = sopfr(6)
let spec_radius = n - 1           // 5
let sp6 = sopfr(n)                // 5

// Spectral gap = (n-1) - (-1) = n = 6
let spec_gap = n                  // 6

// Laplacian trace identities
// tr(L)   = 0 + (n-1)*n = n*(n-1)    = 30
// tr(L^2) = 0 + (n-1)*n^2 = n^2*(n-1) = 180
let tr_l = n * (n - 1)            // 30
let tr_l2 = n * n * (n - 1)       // 180

// Max Laplacian eigenvalue = n = 6 = sigma(6)/2 = 2*phi(6)+2
let max_l = n                     // 6
let s6 = sigma(n)                 // 12

// Number of spanning trees (Matrix-Tree) for K_n = n^(n-2) = 6^4 = 1296
let mut spanning = 1
let mut ki = 0
while ki < n - 2 {
    spanning = spanning * n
    ki = ki + 1
}
let expected_spanning = 1296

let ids = [
    "NET-01","NET-02","NET-03","NET-04","NET-05",
    "NET-06","NET-07","NET-08","NET-09","NET-10","NET-11"
]
let checks = [
    tr_a == 0,
    tr_a2 == 30,
    tr_a3 == 120,
    triangles == c63,
    spec_radius == sp6,          // rho(K6) = sopfr(6) = 5
    spec_gap == n,               // gap = n
    tr_l == 30,
    tr_l2 == 180,
    max_l == n,
    spanning == expected_spanning,
    s6 == 2 * n                  // sigma(6)=12=2*6 (perfect number)
]

println("======================================================================")
println("H-NETWORK-001: K6 SPECTRAL PROPERTIES")
println("======================================================================")
println("tr(A)=" + to_string(tr_a) + " tr(A^2)=" + to_string(tr_a2) + " tr(A^3)=" + to_string(tr_a3))
println("triangles=" + to_string(triangles) + " (C(6,3)=" + to_string(c63) + ")")
println("rho(A)=" + to_string(spec_radius) + "=sopfr(6)=" + to_string(sp6))
println("spec_gap=" + to_string(spec_gap) + " max_L=" + to_string(max_l))
println("spanning_trees(K6)=" + to_string(spanning))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
