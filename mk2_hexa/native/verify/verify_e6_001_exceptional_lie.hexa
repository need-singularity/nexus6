// Ported from tecs-l/verify/verify_e6_001_exceptional_lie.py — 2026-04-10
// E6-001: E6 Lie algebra encodes n=6 (rank=6, dim=78, roots=72, |W|=51840).

let s6 = sigma(6)
let t6 = tau(6)
let p6 = phi(6)

let e6_rank = 6
let e6_dim = 78                  // 6*13
let e6_roots = 72                // = 6 * 12 = 6 * sigma(6)
let e6_pos_roots = 36            // half of 72
let e6_weyl = 51840              // 72 * 720
let e6_fund = 27                 // 27 = 3^3

// Cross-series dims
let g2_dim = 14
let f4_dim = 52
let e7_dim = 133
let e8_dim = 248

let ids = [
    "E6-01","E6-02","E6-03","E6-04","E6-05",
    "E6-06","E6-07","E6-08","E6-09"
]
let checks = [
    e6_rank == 6,
    e6_dim == 6 * 13,
    e6_dim == 78,
    e6_roots == 6 * s6,           // 72 = 6 * 12
    e6_roots == 72,
    e6_pos_roots * 2 == e6_roots,
    e6_weyl == 72 * 720,
    e6_weyl == 51840,
    e6_dim + 1 == 79              // anchor
]

println("======================================================================")
println("E6-001: Exceptional Lie algebra")
println("======================================================================")
println("rank=" + to_string(e6_rank) + " dim=" + to_string(e6_dim) + " roots=" + to_string(e6_roots) + " |W|=" + to_string(e6_weyl))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
