// 포팅 원본: tecs-l/math/verify_three_hypotheses.py (364 LOC)
// H-AI-5: sigma*phi/(n*tau) as regularizer
// H-AI-9: Loss landscape and 6 (condition numbers)
// H-CX-5: Repulsion field = tau/phi imbalance

fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0)) / 10000.0
    to_string(r)
}

fn fmt6(x: float) -> string {
    let r = to_float(to_int(x * 1000000.0)) / 1000000.0
    to_string(r)
}

fn fmt8(x: float) -> string {
    let r = to_float(to_int(x * 100000000.0)) / 100000000.0
    to_string(r)
}

fn fmt2(x: float) -> string {
    let r = to_float(to_int(x * 100.0)) / 100.0
    to_string(r)
}

fn R_val(n: int) -> float {
    to_float(sigma(n) * phi(n)) / to_float(n * tau(n))
}

fn pad_right(s: string, w: int) -> string {
    let mut out = s
    while len(out) < w { out = out + " " }
    out
}

fn pad_left(s: string, w: int) -> string {
    let mut out = s
    while len(out) < w { out = " " + out }
    out
}

fn repeat_str(ch: string, n: int) -> string {
    let mut out = ""
    let mut i = 0
    while i < n {
        out = out + ch
        i = i + 1
    }
    out
}

fn factorize(n: int) -> string {
    let mut temp = n
    let mut parts = []
    let mut p = 2
    while p * p <= temp {
        while temp % p == 0 {
            parts = parts.push(to_string(p))
            temp = temp / p
        }
        p = p + 1
    }
    if temp > 1 { parts = parts.push(to_string(temp)) }
    if len(parts) == 0 { return to_string(n) }
    parts.join(" x ")
}

fn isqrt(n: int) -> int {
    let s = to_int(sqrt(to_float(n)))
    if (s + 1) * (s + 1) <= n { return s + 1 }
    s
}

// ═══════════════════════════════════════════════════════════════
// H-AI-5: sigma*phi/(n*tau) as regularizer
// ═══════════════════════════════════════════════════════════════

println(repeat_str("=", 72))
println("  H-AI-5: R(n) = sigma(n)*phi(n) / (n*tau(n)) as regularizer")
println(repeat_str("=", 72))

let dims = [32, 64, 128, 256, 512, 768, 1024, 2048, 4096]

println("")
println(pad_right("     d", 7) + "| " + pad_right("sigma", 11) + "| " + pad_right("phi", 9) + "| " + pad_right("tau", 6) + "| " + pad_right("R(d)", 11) + "| " + pad_right("B=sp/d2", 11) + "| " + pad_right("d/tau", 9) + "| R/d")
println(repeat_str("-", 90))

let mut results_sigma = #{}
let mut results_phi = #{}
let mut results_tau = #{}
let mut results_R = #{}
let mut results_B = #{}
let mut results_dt = #{}
let mut results_Rd = #{}

let mut di = 0
while di < len(dims) {
    let d = dims[di]
    let s = sigma(d)
    let p = phi(d)
    let t = tau(d)
    let R = to_float(s * p) / to_float(d * t)
    let B = to_float(s * p) / to_float(d * d)
    let dt = to_float(d) / to_float(t)
    let Rd = R / to_float(d)
    let dk = to_string(d)
    results_sigma[dk] = s
    results_phi[dk] = p
    results_tau[dk] = t
    results_R[dk] = R
    results_B[dk] = B
    results_dt[dk] = dt
    results_Rd[dk] = Rd
    println(pad_left(to_string(d), 6) + " | " + pad_left(to_string(s), 10) + " | " + pad_left(to_string(p), 8) + " | " + pad_left(to_string(t), 5) + " | " + pad_left(fmt4(R), 10) + " | " + pad_left(fmt6(B), 10) + " | " + pad_left(fmt2(dt), 8) + " | " + fmt8(Rd))
    di = di + 1
}

// Sensitivity analysis
println("")
println("--- Sensitivity analysis: R(d) vs neighbors ---")
println(pad_right("     d", 7) + "| " + pad_right("R(d-1)", 11) + "| " + pad_right("R(d)", 11) + "| " + pad_right("R(d+1)", 11) + "| " + pad_right("dR(-1)", 11) + "| " + pad_right("dR(+1)", 11) + "| rel%")
println(repeat_str("-", 80))

let mut si = 0
while si < len(dims) {
    let d = dims[si]
    let r_prev = R_val(d - 1)
    let r_curr = R_val(d)
    let r_next = R_val(d + 1)
    let dp = r_curr - r_prev
    let dn = r_next - r_curr
    let rel = abs_f(dp) / r_curr * 100.0
    println(pad_left(to_string(d), 6) + " | " + pad_left(fmt4(r_prev), 10) + " | " + pad_left(fmt4(r_curr), 10) + " | " + pad_left(fmt4(r_next), 10) + " | " + pad_left(fmt4(dp), 10) + " | " + pad_left(fmt4(dn), 10) + " | " + fmt2(rel) + "%")
    si = si + 1
}

// Divisor count vs R/d
println("")
println("--- Divisor count vs R/d ratio ---")
println(pad_right("     d", 7) + "| " + pad_right("tau", 6) + "| " + pad_right("R/d", 15) + "| pow2?")
println(repeat_str("-", 50))

let mut pi2 = 0
while pi2 < len(dims) {
    let d = dims[pi2]
    let dk = to_string(d)
    let t = results_tau[dk]
    let rd = results_Rd[dk]
    let mut is_pow2 = "NO"
    let band = to_int(to_float(d)) & to_int(to_float(d - 1))
    if band == 0 { is_pow2 = "YES" }
    println(pad_left(to_string(d), 6) + " | " + pad_left(to_string(t), 5) + " | " + pad_left(fmt8(to_float(rd)), 14) + " | " + pad_left(is_pow2, 5))
    pi2 = pi2 + 1
}

// ASCII plot of R/d
println("")
println("--- ASCII plot: R/d vs dimension ---")
let mut max_rd = 0.0
let mut mi = 0
while mi < len(dims) {
    let dk = to_string(dims[mi])
    let v = to_float(results_Rd[dk])
    if v > max_rd { max_rd = v }
    mi = mi + 1
}

let mut ai = 0
while ai < len(dims) {
    let d = dims[ai]
    let dk = to_string(d)
    let rd = to_float(results_Rd[dk])
    let bar_len = to_int(60.0 * rd / max_rd)
    println("  d=" + pad_right(to_string(d), 5) + " | " + repeat_str("#", bar_len) + " " + fmt8(rd))
    ai = ai + 1
}

// Composite vs prime comparison
println("")
println("--- Comparison: composite-rich vs prime-adjacent ---")
let dc_arr = [32, 64, 128, 256, 512, 768, 1024]
let dp_arr = [31, 61, 127, 251, 509, 769, 1021]
println(pad_right("d_comp", 7) + "| " + pad_right("tau", 5) + "| " + pad_right("R/d", 13) + "| " + pad_right("d_prime", 8) + "| " + pad_right("tau", 5) + "| " + pad_right("R/d", 13) + "| ratio")
println(repeat_str("-", 72))

let mut ci = 0
while ci < len(dc_arr) {
    let dc = dc_arr[ci]
    let dp = dp_arr[ci]
    let rc = R_val(dc) / to_float(dc)
    let rp = R_val(dp) / to_float(dp)
    let ratio = rp / rc
    println(pad_left(to_string(dc), 7) + " | " + pad_left(to_string(tau(dc)), 4) + " | " + pad_left(fmt8(rc), 12) + " | " + pad_left(to_string(dp), 7) + " | " + pad_left(to_string(tau(dp)), 4) + " | " + pad_left(fmt8(rp), 12) + " | " + fmt4(ratio))
    ci = ci + 1
}

// ═══════════════════════════════════════════════════════════════
// H-AI-9: Loss landscape and 6
// ═══════════════════════════════════════════════════════════════

println("")
println("")
println(repeat_str("=", 72))
println("  H-AI-9: Loss landscape -- condition number from sigma(k)/k eigenvalues")
println(repeat_str("=", 72))

println("")
println("--- Eigenvalues sigma(k)/k for various d ---")

let eig_ds = [6, 10, 12, 28, 30, 50]
let mut ei = 0
while ei < len(eig_ds) {
    let d = eig_ds[ei]
    let mut min_e = 999999.0
    let mut max_e = 0.0
    let mut sum_e = 0.0
    let mut k = 1
    while k <= d {
        let e = to_float(sigma(k)) / to_float(k)
        if e < min_e { min_e = e }
        if e > max_e { max_e = e }
        sum_e = sum_e + e
        k = k + 1
    }
    let mean_e = sum_e / to_float(d)
    let mut var_e = 0.0
    let mut k2 = 1
    while k2 <= d {
        let e = to_float(sigma(k2)) / to_float(k2)
        let diff = e - mean_e
        var_e = var_e + diff * diff
        k2 = k2 + 1
    }
    let std_e = sqrt(var_e / to_float(d))
    let cond = max_e / min_e

    println("")
    println("  d=" + to_string(d) + ":")
    if d <= 30 {
        let mut k3 = 1
        while k3 <= d {
            let e = to_float(sigma(k3)) / to_float(k3)
            let range = max_e - min_e + 0.000000000000001
            let blen = to_int(30.0 * (e - min_e) / range)
            println("    k=" + pad_left(to_string(k3), 3) + ": s(k)/k = " + pad_left(fmt4(e), 8) + "  " + repeat_str("#", blen))
            k3 = k3 + 1
        }
    }
    println("    min=" + fmt4(min_e) + "  max=" + fmt4(max_e) + "  cond=" + fmt4(cond) + "  mean=" + fmt4(mean_e) + "  std=" + fmt4(std_e))
    ei = ei + 1
}

// Condition number for d=2..100 (reduced from 200 for speed)
println("")
println("--- Condition number k(d) = max(s(k)/k) / min(s(k)/k) for d=2..100 ---")

let mut cond_d = #{}
let mut cond_v = #{}
let mut d2 = 2
while d2 <= 100 {
    let mut mn = 999999.0
    let mut mx = 0.0
    let mut k = 1
    while k <= d2 {
        let e = to_float(sigma(k)) / to_float(k)
        if e < mn { mn = e }
        if e > mx { mx = e }
        k = k + 1
    }
    let dk = to_string(d2)
    cond_d[dk] = d2
    cond_v[dk] = mx / mn
    d2 = d2 + 1
}

// Sort by condition number - find top 20
println("")
println("  Top 20 best-conditioned dimensions (d=2..100):")
println("  " + pad_right("d", 6) + "| " + pad_right("k(d)", 9) + "| " + pad_right("perfect?", 10) + "| tau(d)")
println("  " + repeat_str("-", 40))

// Simple selection sort for top 20
let mut used = #{}
let mut rank = 0
while rank < 20 {
    let mut best_d = 0
    let mut best_c = 999999.0
    let mut d3 = 2
    while d3 <= 100 {
        let dk = to_string(d3)
        let c = to_float(cond_v[dk])
        let mut is_used = false
        if has_key(used, dk) { is_used = true }
        if !is_used && c < best_c {
            best_c = c
            best_d = d3
        }
        d3 = d3 + 1
    }
    let bk = to_string(best_d)
    used[bk] = true
    let mut pf = ""
    if sigma(best_d) == 2 * best_d { pf = "YES" }
    println("  " + pad_left(to_string(best_d), 5) + " | " + pad_left(fmt4(best_c), 8) + " | " + pad_right(pf, 9) + " | " + pad_left(to_string(tau(best_d)), 5))
    rank = rank + 1
}

// Where does d=6 rank?
let mut rank6 = 0
let mut rank6_c = to_float(cond_v["6"])
let mut d4 = 2
while d4 <= 100 {
    let dk = to_string(d4)
    let c = to_float(cond_v[dk])
    if c < rank6_c { rank6 = rank6 + 1 }
    d4 = d4 + 1
}
println("")
println("  d=6 rank: " + to_string(rank6 + 1) + " out of 99 (k=" + fmt4(rank6_c) + ")")

let mut rank28 = 0
let rank28_c = to_float(cond_v["28"])
let mut d5 = 2
while d5 <= 100 {
    let dk = to_string(d5)
    let c = to_float(cond_v[dk])
    if c < rank28_c { rank28 = rank28 + 1 }
    d5 = d5 + 1
}
println("  d=28 rank: " + to_string(rank28 + 1) + " out of 99 (k=" + fmt4(rank28_c) + ")")

// Perfect numbers' condition numbers
println("")
println("--- Perfect numbers' condition numbers ---")
let perf_nums = [6, 28]
let mut pni = 0
while pni < len(perf_nums) {
    let pn = perf_nums[pni]
    let cv = to_float(cond_v[to_string(pn)])
    let sd = to_float(sigma(pn)) / to_float(pn)
    println("  d=" + to_string(pn) + ": k=" + fmt4(cv) + ", sigma(d)/d=" + fmt4(sd) + " (perfect -> s/d=2)")
    pni = pni + 1
}

// k(d) for d=2..30
println("")
println("--- k(d) for d=2..30 (local landscape) ---")
println("  " + pad_right("d", 4) + "| " + pad_right("k(d)", 9) + "| bar")
println("  " + repeat_str("-", 50))

let mut d6 = 2
while d6 <= 30 {
    let c = to_float(cond_v[to_string(d6)])
    let mut blen = to_int(30.0 * (c - 1.0) / 2.0)
    if blen < 0 { blen = 0 }
    if blen > 30 { blen = 30 }
    let mut marker = ""
    if sigma(d6) == 2 * d6 { marker = " <-- perfect" }
    println("  " + pad_left(to_string(d6), 3) + " | " + pad_left(fmt4(c), 8) + " | " + repeat_str("#", blen) + marker)
    d6 = d6 + 1
}

// ═══════════════════════════════════════════════════════════════
// H-CX-5: Repulsion field = tau/phi imbalance
// ═══════════════════════════════════════════════════════════════

println("")
println("")
println(repeat_str("=", 72))
println("  H-CX-5: Repulsion field -- tau(n)/phi(n) imbalance")
println(repeat_str("=", 72))

// Compute tau/phi for n=2..200 (reduced from 1000 for speed)
let TP_MAX = 200
let mut tp_ratios = #{}
let mut n = 2
while n <= TP_MAX {
    let r = to_float(tau(n)) / to_float(phi(n))
    tp_ratios[to_string(n)] = r
    n = n + 1
}

// n=6 and n=28
println("")
println("  n=6:  tau=" + to_string(tau(6)) + ", phi=" + to_string(phi(6)) + ", tau/phi = " + fmt4(to_float(tau(6)) / to_float(phi(6))))
println("  n=28: tau=" + to_string(tau(28)) + ", phi=" + to_string(phi(28)) + ", tau/phi = " + fmt4(to_float(tau(28)) / to_float(phi(28))))

// Top 30 maxima - selection sort
println("")
println("--- Top 30 largest tau(n)/phi(n) for n=2.." + to_string(TP_MAX) + " ---")
println("  " + pad_right("rank", 5) + "| " + pad_right("n", 7) + "| " + pad_right("tau", 6) + "| " + pad_right("phi", 7) + "| " + pad_right("tau/phi", 11) + "| factors")
println("  " + repeat_str("-", 65))

let mut tp_used = #{}
let mut tpi = 0
while tpi < 30 {
    let mut best_n = 0
    let mut best_r = 0.0
    let mut tn = 2
    while tn <= TP_MAX {
        let tk = to_string(tn)
        let mut is_used = false
        if has_key(tp_used, tk) { is_used = true }
        if !is_used {
            let r = to_float(tp_ratios[tk])
            if r > best_r {
                best_r = r
                best_n = tn
            }
        }
        tn = tn + 1
    }
    let bk = to_string(best_n)
    tp_used[bk] = true
    let fac = factorize(best_n)
    let mut marker = ""
    if best_n == 6 { marker = " <<<" }
    if best_n == 28 { marker = " <" }
    println("  " + pad_left(to_string(tpi + 1), 4) + " | " + pad_left(to_string(best_n), 6) + " | " + pad_left(to_string(tau(best_n)), 5) + " | " + pad_left(to_string(phi(best_n)), 6) + " | " + pad_left(fmt6(best_r), 10) + " | " + fac + marker)
    tpi = tpi + 1
}

// Where does n=6 rank?
let mut r6_rank = 0
let r6_val = to_float(tp_ratios["6"])
let mut rn = 2
while rn <= TP_MAX {
    let r = to_float(tp_ratios[to_string(rn)])
    if r > r6_val { r6_rank = r6_rank + 1 }
    rn = rn + 1
}
println("")
println("  n=6 ranks #" + to_string(r6_rank + 1) + " out of " + to_string(TP_MAX - 1) + " (tau/phi = " + fmt4(r6_val) + ")")

let mut r28_rank = 0
let r28_val = to_float(tp_ratios["28"])
let mut rn2 = 2
while rn2 <= TP_MAX {
    let r = to_float(tp_ratios[to_string(rn2)])
    if r > r28_val { r28_rank = r28_rank + 1 }
    rn2 = rn2 + 1
}
println("  n=28 ranks #" + to_string(r28_rank + 1) + " out of " + to_string(TP_MAX - 1) + " (tau/phi = " + fmt4(r28_val) + ")")

// Local landscape around n=6
println("")
println("--- Local landscape around n=6 ---")
let mut ln = 2
while ln <= 14 {
    let r = to_float(tp_ratios[to_string(ln)])
    let blen = to_int(40.0 * r / 2.1)
    let mut marker = ""
    if ln == 6 { marker = " <-- n=6" }
    println("  n=" + pad_left(to_string(ln), 3) + ": tau/phi = " + pad_left(fmt4(r), 8) + "  " + repeat_str("#", blen) + marker)
    ln = ln + 1
}

// Is n=6 local max?
let tp5 = to_float(tp_ratios["5"])
let tp6 = to_float(tp_ratios["6"])
let tp7 = to_float(tp_ratios["7"])
let local_max = tp6 > tp5 && tp6 > tp7
println("")
println("  Is n=6 a local maximum? " + to_string(local_max))
println("    tau/phi(5) = " + fmt4(tp5))
println("    tau/phi(6) = " + fmt4(tp6))
println("    tau/phi(7) = " + fmt4(tp7))

// Statistics
let mut sum_tp = 0.0
let mut min_tp = 999999.0
let mut max_tp = 0.0
let mut min_tp_n = 2
let mut max_tp_n = 2
let mut sn = 2
while sn <= TP_MAX {
    let v = to_float(tp_ratios[to_string(sn)])
    sum_tp = sum_tp + v
    if v < min_tp {
        min_tp = v
        min_tp_n = sn
    }
    if v > max_tp {
        max_tp = v
        max_tp_n = sn
    }
    sn = sn + 1
}
let count_tp = to_float(TP_MAX - 1)
let mean_tp = sum_tp / count_tp
let mut var_tp = 0.0
let mut vn = 2
while vn <= TP_MAX {
    let v = to_float(tp_ratios[to_string(vn)])
    let diff = v - mean_tp
    var_tp = var_tp + diff * diff
    vn = vn + 1
}
let std_tp = sqrt(var_tp / count_tp)
let z_6 = (tp6 - mean_tp) / std_tp
let z_28 = (r28_val - mean_tp) / std_tp

println("")
println("  Statistics for tau/phi (n=2.." + to_string(TP_MAX) + "):")
println("    mean  = " + fmt6(mean_tp))
println("    std   = " + fmt6(std_tp))
println("    min   = " + fmt6(min_tp) + " at n=" + to_string(min_tp_n))
println("    max   = " + fmt6(max_tp) + " at n=" + to_string(max_tp_n))
println("    n=6:  Z = " + fmt2(z_6) + " sigma")
println("    n=28: Z = " + fmt2(z_28) + " sigma")

// Pattern: 2^a * 3^b
println("")
println("--- Pattern: tau/phi for n = 2^a * 3^b ---")
println("  " + pad_right("n", 7) + "| " + pad_right("form", 17) + "| " + pad_right("tau", 5) + "| " + pad_right("phi", 7) + "| tau/phi")
println("  " + repeat_str("-", 55))

fn ipow(b: int, k: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < k {
        r = r * b
        i = i + 1
    }
    r
}

let mut a = 1
while a < 8 {
    let mut b = 0
    while b < 5 {
        let nn = ipow(2, a) * ipow(3, b)
        if nn <= TP_MAX {
            let mut form = "2^" + to_string(a)
            if b > 0 { form = form + " x 3^" + to_string(b) }
            let r = to_float(tau(nn)) / to_float(phi(nn))
            let mut marker = ""
            if nn == 6 { marker = " <--" }
            println("  " + pad_left(to_string(nn), 6) + " | " + pad_right(form, 16) + " | " + pad_left(to_string(tau(nn)), 4) + " | " + pad_left(to_string(phi(nn)), 6) + " | " + fmt6(r) + marker)
        }
        b = b + 1
    }
    a = a + 1
}

