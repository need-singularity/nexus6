// mk2_hexa/native/verify_h_cs_6.hexa
// 포팅 원본: tecs-l/math/verify_h_cs_6.py (217 LOC)
// H-CS-6: Hash collision probability와 6의 관계 — 검증

let LN2 = log(2.0)
let PI = 3.141592653589793

// @pure
fn log2(x: float) -> float { log(x) / LN2 }

fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0)) / 10000.0
    to_string(r)
}
fn fmt6(x: float) -> string {
    let r = to_float(to_int(x * 1000000.0)) / 1000000.0
    to_string(r)
}

println("══════════════════════════════════════════════════════════════════════")
println("H-CS-6: Hash Collision Probability and 6  (hexa port)")
println("══════════════════════════════════════════════════════════════════════")

// ─── Test 1: Birthday Paradox ───
println("")
println("### Test 1: Birthday Paradox Formula")
let birthday_const = sqrt(2.0 * LN2)
println("  birthday_const = sqrt(2·ln 2) = " + fmt6(birthday_const))
println("  6 appears? NO — constant involves only 2 and ln 2.")
println("")
let bits_arr = [128, 256, 512]
let mut i = 0
while i < len(bits_arr) {
    let bits = bits_arr[i]
    // k = birthday_const · 2^(bits/2), log2(k) = bits/2 + log2(const)
    let k_bits = to_float(bits) / 2.0 + log2(birthday_const)
    println("  N=2^" + to_string(bits) + ": k ≈ 2^" + fmt4(k_bits))
    i = i + 1
}

// ─── Test 2: Hash function rounds survey ───
println("")
println("══════════════════════════════════════════════════════════════════════")
println("### Test 2: Hash Function Rounds Survey")
println("══════════════════════════════════════════════════════════════════════")
let hash_name   = ["MD5", "SHA-1", "SHA-256", "SHA-512", "SHA-3/224", "SHA-3/256", "SHA-3/384", "SHA-3/512", "BLAKE2b", "BLAKE3", "Whirlpool"]
let hash_rounds = [64,    80,      64,        80,        24,          24,          24,          24,          12,        7,        10]

println("  Algorithm    | Rounds")
println("  -------------+--------")
let mut j = 0
while j < len(hash_name) {
    println("  " + hash_name[j] + "\t| " + to_string(hash_rounds[j]))
    j = j + 1
}

// Multiples of d in [2..8]
println("")
println("  Multiples of small d:")
let total = len(hash_rounds)
let mut d = 2
while d <= 8 {
    let mut cnt = 0
    let mut k = 0
    while k < total {
        if hash_rounds[k] % d == 0 { cnt = cnt + 1 }
        k = k + 1
    }
    println("    d=" + to_string(d) + ": " + to_string(cnt) + "/" + to_string(total) + " = " + fmt4(to_float(cnt) / to_float(total)))
    d = d + 1
}
println("")
println("  → 6의 배수는 특별히 두드러지지 않음 (control d=3,4에 밀림).")

// ─── Test 3: Keccak formula ───
println("")
println("══════════════════════════════════════════════════════════════════════")
println("### Test 3: Keccak/SHA-3 round count formula")
println("══════════════════════════════════════════════════════════════════════")
println("  nr = 12 + 2·l,  l = log2(w),  w = lane width")
let ws = [1, 2, 4, 8, 16, 32, 64]
let mut wi = 0
while wi < len(ws) {
    let w = ws[wi]
    let l = to_int(log2(to_float(w)))
    let nr = 12 + 2 * l
    println("  w=" + to_string(w) + "\tl=" + to_string(l) + "\tnr=" + to_string(nr))
    wi = wi + 1
}
println("")
println("  Standard Keccak w=64 → l=6, nr=24. l=6은 64-bit CPU 아키텍처의 artifact.")

// ─── Test 4: σφ/(nτ) for perfect numbers ───
println("")
println("══════════════════════════════════════════════════════════════════════")
println("### Test 4: σφ/(nτ) for perfect numbers")
println("══════════════════════════════════════════════════════════════════════")
let perfects = [6, 28, 496]
let mut p = 0
while p < len(perfects) {
    let n = perfects[p]
    let s = sigma(n)
    let ph = phi(n)
    let t = tau(n)
    let ratio = to_float(s * ph) / to_float(n * t)
    println("  n=" + to_string(n) + ": σ=" + to_string(s) + ", φ=" + to_string(ph) + ", τ=" + to_string(t) + ", σφ/(nτ) = " + fmt4(ratio))
    p = p + 1
}
println("")
println("  Note: σφ/(nτ) = 1 for n=6 BUT not for n=28,496 (4, 48 resp.)")
println("  Actually only n=6 (and n=1) among perfects has σφ/(nτ) = 1.")

// σ/n = 2 for perfect, τ/φ check
println("")
println("  Check τ/φ = σ/n for each perfect:")
let mut q = 0
while q < len(perfects) {
    let n = perfects[q]
    let sn = to_float(sigma(n)) / to_float(n)
    let tp = to_float(tau(n)) / to_float(phi(n))
    println("    n=" + to_string(n) + ": σ/n = " + fmt4(sn) + ", τ/φ = " + fmt4(tp) + (if sn == tp { "  MATCH" } else { "" }))
    q = q + 1
}

// ─── Final verdict ───
println("")
println("══════════════════════════════════════════════════════════════════════")
println("### FINAL VERDICT")
println("══════════════════════════════════════════════════════════════════════")
println("  1. Birthday paradox: NO relation to 6 (sqrt(N), ln 2)")
println("  2. Hash rounds: 6의 배수 패턴 없음")
println("  3. Keccak l=6: 64-bit CPU artifact")
println("  4. σφ/(nτ)=1: n=6 (유일) — master identity, 단 hash 성능과 인과 없음")
println("")
println("  GRADE: ⚪  (White circle — coincidence, no deep structure)")
