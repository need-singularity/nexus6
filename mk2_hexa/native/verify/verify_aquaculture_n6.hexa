// mk2_hexa/native/verify_aquaculture_n6.hexa
// A16: aquaculture n=6 검증 (R18 미니멀 / R19 에러 명시)
// 해수 n=6 주요이온, sopfr=5 대양, pH sigma-tau=8, 양식수온 J2=24°C

let n = 6
let major_ions = ["Na+", "Cl-", "Mg2+", "SO4^2-", "Ca2+", "K+"]

println("══════════════════════════════════════════════════════════════════════")
println("A16 aquaculture n=6: seawater ion verification")
println("══════════════════════════════════════════════════════════════════════")

if len(major_ions) != n {
    println("ERROR[A16]: ion count mismatch expected=" + to_string(n) + " got=" + to_string(len(major_ions)))
    assert false
}

let mut i = 0
while i < len(major_ions) {
    println("  [" + to_string(i + 1) + "] " + major_ions[i])
    i = i + 1
}

// 5 oceans = sopfr(6) = 5
let oceans = 5
let sopfr = 5
assert oceans == sopfr
println("  oceans = sopfr = " + to_string(oceans))

// seawater pH = sigma - tau = 8
let sigma = 12
let tau = 4
let ph = sigma - tau
assert ph == 8
println("  seawater pH = sigma-tau = " + to_string(ph))

// optimal aquaculture temp = J2 = 24 deg C
let j2 = 24
println("  optimal temp = J2 = " + to_string(j2) + " C")

// salinity 35 psu = sopfr * (sigma - sopfr) = 5 * 7 = 35
let salinity = sopfr * (sigma - sopfr)
assert salinity == 35
println("  salinity = sopfr*(sigma-sopfr) = " + to_string(salinity) + " psu")

// Beaufort scale max = sigma = 12
assert sigma == 12
println("  Beaufort scale = sigma = " + to_string(sigma) + " grades")

println("  ✓ aquaculture n=6 OK (6 ions, pH=8, 35psu, J2=24C)")
