// mk2_hexa/native/verify_aerospace_transport_n6.hexa
// A12: aerospace-transport n=6 검증 (R18 미니멀 / R19 에러 명시)
// SE(3) 강체운동 6-DOF: 3 translation + 3 rotation, eVTOL n=6 rotor

let n = 6
let dof_trans = 3
let dof_rot = 3
let dof_total = dof_trans + dof_rot

println("══════════════════════════════════════════════════════════════════════")
println("A12 aerospace-transport n=6: SE(3) 6-DOF verification")
println("══════════════════════════════════════════════════════════════════════")
println("  trans DOF = " + to_string(dof_trans))
println("  rot   DOF = " + to_string(dof_rot))
println("  total DOF = " + to_string(dof_total))

if dof_total != n {
    println("ERROR[A12]: DOF mismatch expected=" + to_string(n) + " got=" + to_string(dof_total))
    assert false
}

// eVTOL rotor count = n = 6
let rotors = 6
assert rotors == n
println("  eVTOL rotors = " + to_string(rotors))

// cargo module = n=6 faces (modular cargo unit)
let cargo_faces = 6
assert cargo_faces == n
println("  cargo unit faces = " + to_string(cargo_faces))

println("  ✓ aerospace-transport n=6 OK (SE(3) 6-DOF, 6-rotor eVTOL)")
