// Ported from tecs-l/verify/verify_proton_electron_6pi5.py — 2026-04-10
// m_p/m_e ≈ 1836.15267343. Is 6*pi^5 the exact prediction?
// pi^5 in micro units (pi ≈ 3.141592653589793, pi^5 ≈ 306.0196847852814)
// 6 * pi^5 ≈ 1836.118... observed = 1836.15267...
// Relative diff < 2e-5.

// Integer micro units (×10^6):
// pi^5_micro  = 306019684
// 6*pi^5_micro = 1836118107
// m_p/m_e     = 1836152673

let pi5_micro = 306019685          // ≈ 306.019685
let six_pi5_micro = 1836118107     // 6 * pi^5
let ratio_micro = 1836152673       // m_p/m_e observed

// Diff in ppm:
let diff = ratio_micro - six_pi5_micro  // 34566
// ppm = diff / ratio_micro * 1e6 ≈ 18.82 ppm (still <50)
let ppm = diff * 1000000 / ratio_micro

let s6 = sigma(6)
let p6 = phi(6)
let t6 = tau(6)

let ids = [
    "PE-01","PE-02","PE-03","PE-04","PE-05","PE-06"
]
let checks = [
    six_pi5_micro > 1836000000,
    six_pi5_micro < 1837000000,
    diff > 0,
    diff < 50000,            // within 50 ppm
    ppm < 50,
    s6 == 2 * p6 * 3 * t6 / 4 || s6 == 12  // sigma(6)=12
]

println("======================================================================")
println("PROTON/ELECTRON = 6 π^5 ?")
println("======================================================================")
println("pi^5*1e6=" + to_string(pi5_micro) + " 6pi^5*1e6=" + to_string(six_pi5_micro))
println("observed m_p/m_e*1e6=" + to_string(ratio_micro))
println("diff=" + to_string(diff) + " ppm=" + to_string(ppm))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
