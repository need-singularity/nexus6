// Ported from tecs-l/verify/verify_perfect_number_chain.py — 2026-04-10
// Explore the perfect number chain: 6 → 28 → 496 → 8128.

fn is_perfect(n: int) -> bool { sigma(n) == 2 * n }

let p1 = 6
let p2 = 28
let p3 = 496
let p4 = 8128

// Each P_k = 2^(k-1) * (2^k - 1) for k = {2, 3, 5, 7} (Mersenne exponents)
// But we test by sigma.
let s1 = sigma(p1)
let s2 = sigma(p2)
let s3 = sigma(p3)
let s4 = sigma(p4)

// Successive ratios: 28/6 ≈ 4.67, 496/28 ≈ 17.71, 8128/496 ≈ 16.39
// Integer test: 28 = 4*6 + 4. 496 = 17*28 + 20. 8128 = 16*496 + 192.
let r12 = p2 - 4 * p1
let r23 = p3 - 17 * p2
let r34 = p4 - 16 * p3

// sigma-functions of perfect numbers: sigma(28)=56, sigma(496)=992.
// sopfr(6)=5, sopfr(28)=11, sopfr(496)=? 496 = 2^4*31 → sopfr=8+31=39.
let sp1 = sopfr(p1)
let sp2 = sopfr(p2)
let sp3 = sopfr(p3)

let ids = [
    "PN-01","PN-02","PN-03","PN-04","PN-05","PN-06","PN-07","PN-08","PN-09"
]
let checks = [
    is_perfect(p1),
    is_perfect(p2),
    is_perfect(p3),
    is_perfect(p4),
    s1 == 2 * p1,
    s2 == 2 * p2,
    sp1 == 5,
    sp2 == 11,
    sp3 == 39
]

println("======================================================================")
println("PERFECT NUMBER CHAIN: 6 → 28 → 496 → 8128")
println("======================================================================")
println("sigma: " + to_string(s1) + " " + to_string(s2) + " " + to_string(s3) + " " + to_string(s4))
println("sopfr: " + to_string(sp1) + " " + to_string(sp2) + " " + to_string(sp3))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
