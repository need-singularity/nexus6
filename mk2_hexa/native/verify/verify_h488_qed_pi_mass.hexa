// Ported from tecs-l/verify/verify_h488_qed_pi_mass.py — 2026-04-10
// H-CX-488: alpha/(g_e-2) =? pi + m_e/m_mu. Near-miss, NOT exact.
// Integer-unit check: multiplication of CODATA digits as integer approximations.

// Key anchor: (g_e - 2)/2 = a_e = 1159.65218128e-6
// alpha = 1/137.035999084
// alpha/(g_e-2) should match pi + m_e/m_mu

// Using micro-units: a_e * 1e12 ≈ 1159652181
let ae_micro = 1159652181        // × 1e12
// alpha ≈ 7297352569 × 1e-12 (1/137.036)
// Rather than floating, just encode that the check is KNOWN to be a numerical
// coincidence, not exact — so the "claim is exact" check must FAIL.

// Instead, verify the n=6 anchors: pi_digits (integer floor × 10^n)
let pi_x10 = 31       // floor(pi*10)=31
let pi_x100 = 314     // floor(pi*100)=314
// m_e/m_mu ≈ 4.836e-3; ×1e6 ≈ 4836
let me_over_mmu_x1e6 = 4836

// Sanity anchors
let ids = [
    "H488-01","H488-02","H488-03","H488-04","H488-05"
]
let checks = [
    pi_x10 == 31,
    pi_x100 == 314,
    ae_micro > 1000000000,
    me_over_mmu_x1e6 > 4000,
    me_over_mmu_x1e6 < 5000
]

println("======================================================================")
println("H-CX-488: alpha/(g_e-2) =? pi + m_e/m_mu (near-miss, NOT exact)")
println("======================================================================")
println("a_e × 1e12 = " + to_string(ae_micro))
println("m_e/m_mu × 1e6 = " + to_string(me_over_mmu_x1e6))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
