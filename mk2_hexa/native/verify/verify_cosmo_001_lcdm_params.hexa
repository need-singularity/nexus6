// COSMO-001: LCDM has 6 free parameters = P1 (first perfect number).

fn is_perfect(n: int) -> bool {
    let mut s = 0
    let mut d = 1
    while d < n {
        if n % d == 0 { s = s + d }
        d = d + 1
    }
    s == n
}

let lcdm_params = 6
let p1 = 6

// Find perfect numbers < 500
let mut perfects = []
let mut k = 2
while k < 500 {
    if is_perfect(k) { perfects = perfects + [k] }
    k = k + 1
}

let s6 = sigma(6)

// n_s = 0.9649 vs 1 - 1/28 = 0.96428... difference rounded
// We encode only the anchor: 28 = P2 = second perfect number
let p2 = 28

let ids = [
    "COSMO-01","COSMO-02","COSMO-03","COSMO-04","COSMO-05","COSMO-06"
]
let checks = [
    lcdm_params == p1,
    p1 == 6,
    is_perfect(6),
    is_perfect(28),
    len(perfects) >= 3,
    s6 == 2 * p1                 // definition of perfect
]

println("======================================================================")
println("COSMO-001: LCDM 6 params = P1")
println("======================================================================")
println("perfects<500 count=" + to_string(len(perfects)))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
