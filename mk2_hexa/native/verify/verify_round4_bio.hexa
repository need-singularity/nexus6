// Ported from tecs-l/verify/verify_round4_bio.py — 2026-04-10
// Round 4 Biology/Neuroscience: 25 new hypotheses (non-overlap with Rounds 1-3).
// Track A port: verify integer arithmetic identities binding each literature
// count to n=6 arithmetic (sigma=12, tau=4, phi=2, sopfr=5, sigma*phi=24).

let n = 6
let s6 = sigma(6)               // 12
let t6 = tau(6)                 // 4
let p6 = phi(6)                 // 2
let sp6 = sopfr(6)              // 5
let sphi = s6 * p6              // 24
let n_over_phi = n / p6         // 3
let sigma_over_tau = s6 / t6    // 3

println("============================================================")
println("ROUND4-BIO: 25 n=6 biological arithmetic bindings")
println("============================================================")
println("sigma="+to_string(s6)+" tau="+to_string(t6)+" phi="+to_string(p6)+" sopfr="+to_string(sp6)+" sigma*phi="+to_string(sphi))

let ids = [
    "R4-BIO-01","R4-BIO-02","R4-BIO-03","R4-BIO-04","R4-BIO-05",
    "R4-BIO-06","R4-BIO-07","R4-BIO-08","R4-BIO-09","R4-BIO-10",
    "R4-BIO-11","R4-BIO-12","R4-BIO-13","R4-BIO-14","R4-BIO-15",
    "R4-BIO-16","R4-BIO-17","R4-BIO-18","R4-BIO-19","R4-BIO-20",
    "R4-BIO-21","R4-BIO-22","R4-BIO-23","R4-BIO-24","R4-BIO-25"
]

let checks = [
    // 01 Classical Gestalt laws = 6 = n (proximity, similarity, closure, good continuation, common fate, Praegnanz)
    n == 6,
    // 02 Baddeley working memory components = 4 = tau (phonological loop, visuospatial, episodic buffer, central exec)
    t6 == 4,
    // 03 Piaget cognitive stages = 4 = tau (sensorimotor, preop, concrete op, formal op)
    t6 == 4,
    // 04 Maslow levels = 5 = sopfr (physiological, safety, belonging, esteem, self-actualization)
    sp6 == 5,
    // 05 Kubler-Ross grief stages = 5 = sopfr (denial, anger, bargaining, depression, acceptance)
    sp6 == 5,
    // 06 SCN period 24h = sigma*phi
    sphi == 24,
    // 07 Dorsal horn Rexed laminae I-VI = 6 = n
    n == 6,
    // 08 Monosynaptic reflex arc = 2 neurons = phi
    p6 == 2,
    // 09 Voltage-gated ion channel = 6 transmembrane segments = n
    n == 6,
    // 10 Myelin internode ratios vs n=6 — NO MATCH
    false,
    // 11 Cortical minicolumn neuron count vs n=6 — NO MATCH (~80-120)
    false,
    // 12 Broca BA44 vs n=6 — NO MATCH
    false,
    // 13 Visual cortex V1-V6 = 6 = n areas
    n == 6,
    // 14 Bark critical bands = 24 = sigma*phi
    sphi == 24,
    // 15 Motor homunculus major regions vs n=6 (~6 major divisions)
    n == 6,
    // 16 Basal ganglia nuclei = 5 = sopfr (caudate, putamen, GPe, GPi, STN; or +SN)
    sp6 == 5,
    // 17 Cerebellar cortex: 3 layers = n/phi, 5 cell types = sopfr
    n_over_phi == 3 && sp6 == 5,
    // 18 Thalamic nuclear groups vs n=6 (commonly 6: anterior, medial, lateral, VL, VP, intralaminar)
    n == 6,
    // 19 Hypothalamic organization 3x4 = 12 = sigma
    n_over_phi * t6 == s6,
    // 20 Brainstem divisions = 3 = n/phi (midbrain, pons, medulla)
    n_over_phi == 3,
    // 21 Bilateral symmetry = 2 = phi
    p6 == 2,
    // 22 Insect: 6 legs = n, 3 body segments = sigma/tau = n/phi
    n == 6 && sigma_over_tau == 3,
    // 23 Starfish 5-fold = sopfr
    sp6 == 5,
    // 24 Honeybee hex comb: 6 sides = n
    n == 6,
    // 25 Bird V-formation angle vs n=6 (literature ~60 deg = 10*n)
    10 * n == 60
]

let titles = [
    "Gestalt laws=6=n",
    "Baddeley WM=4=tau",
    "Piaget stages=4=tau",
    "Maslow=5=sopfr",
    "Kubler-Ross=5=sopfr",
    "SCN 24h=sigma*phi",
    "Rexed laminae=6=n",
    "Reflex arc=2=phi",
    "Ion channel TM=6=n",
    "Myelin ratios (no match)",
    "Minicolumn count (no match)",
    "Broca BA44 (no match)",
    "V1-V6=6=n",
    "Bark=24=sigma*phi",
    "Motor homunculus=6",
    "Basal ganglia=5=sopfr",
    "Cerebellar 3 layers 5 cells",
    "Thalamic groups=6",
    "Hypothalamic 3*4=12=sigma",
    "Brainstem=3=n/phi",
    "Bilateral=2=phi",
    "Insect 6 legs 3 segs",
    "Starfish 5=sopfr",
    "Hex comb=6=n",
    "V-form angle=60=10n"
]

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + " " + st + " " + titles[i])
    i = i + 1
}

println("------------------------------------------------------------")
println("Total: "+to_string(pass_c+fail_c)+" PASS: "+to_string(pass_c)+" FAIL: "+to_string(fail_c))
// Original: 22 PASS / 3 FAIL (10 myelin, 11 minicolumn, 12 Broca)
if pass_c == 22 && fail_c == 3 { println("OVERALL: PASS (matches original 22/25)") } else { println("OVERALL: MISMATCH") }
