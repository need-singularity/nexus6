// Ported from tecs-l/verify/verify_qcomp_003_hamming_mds_bridge.py — 2026-04-10
// QCOMP-003: Hamming bound vs Singleton bound bridge via [[6,4,2]].
// Integer checks on code parameters and perfect-number identities.

fn singleton(n: int, d: int) -> int { n - 2 * (d - 1) }

// Hamming (classical) bound for (n, k, d): k <= n - ceil(log2(sum_{i=0}^{t}(n choose i)))
// with t = floor((d-1)/2). For [[n,k,d]] quantum, we just check [[6,4,2]] satisfies both
// as integer claims.
fn c(n: int, k: int) -> int {
    let mut r = 1
    let mut i = 1
    while i <= k { r = r * (n - i + 1) / i  i = i + 1 }
    r
}

// [[6,4,2]]: t=(d-1)/2=0 → sum = C(6,0) = 1, Hamming: k <= 6 - log2(1) = 6. k=4 ≤ 6. OK.
// MDS singleton: 4 = 6 - 2*1 = 4. OK.
let hb_sum = c(6, 0)  // = 1
let sb = singleton(6, 2)
let s6 = sigma(6)

let ids = [
    "QC3-01","QC3-02","QC3-03","QC3-04","QC3-05","QC3-06","QC3-07"
]
let checks = [
    hb_sum == 1,
    sb == 4,
    4 <= 6,            // Hamming OK
    4 == sb,           // MDS
    c(6, 2) == 15,     // binomial
    c(6, 3) == 20,     // central
    s6 == 12
]

println("======================================================================")
println("QCOMP-003: Hamming / Singleton Bridge for [[6,4,2]]")
println("======================================================================")
println("C(6,0)=" + to_string(c(6,0)) + " C(6,2)=" + to_string(c(6,2)) + " C(6,3)=" + to_string(c(6,3)))
println("singleton=" + to_string(sb) + " sigma(6)=" + to_string(s6))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
