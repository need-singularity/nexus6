// mk2_hexa/native/verify_antimatter_factory_n6.hexa
// A15: antimatter-factory n=6 검증 (R18 미니멀 / R19 에러 명시)
// 반물질 공장: n=6 코어, sigma=12 공장, J2=24개월 저장, C(Z=6) 감속기

let n = 6
let sigma = 12
let j2 = 24
let tau = 4

println("══════════════════════════════════════════════════════════════════════")
println("A15 antimatter-factory n=6: core parameter verification")
println("══════════════════════════════════════════════════════════════════════")

// factory count = sigma = 12
assert sigma == 12
println("  factory modules = sigma = " + to_string(sigma))

// storage lifetime = J2 = 24 months
assert j2 == 24
println("  Penning trap storage = J2 = " + to_string(j2) + " months")

// graphite moderator: C Z=6 = n
let carbon_z = 6
assert carbon_z == n
println("  graphite moderator C Z=" + to_string(carbon_z) + " = n")

// graphite thickness = J2 = 24cm
let graphite_cm = 24
assert graphite_cm == j2
println("  graphite thickness = J2 = " + to_string(graphite_cm) + "cm")

// tau = 4 cold-chain stages
assert tau == 4
println("  cold-chain stages = tau = " + to_string(tau))

println("  ✓ antimatter-factory n=6 OK (sigma=12 factories, J2=24mo storage)")
