// Ported from tecs-l/verify/verify_qcomp_001_quantum_code.py — 2026-04-10
// QCOMP-001: [[6,4,2]] Quantum Error Detection Code.
// (n, k, d) = (6, tau(6), phi(6)) = (6, 4, 2). MDS bound saturated.

let n = 6
let k = 4
let d = 2

let s6 = sigma(6)   // 12
let t6 = tau(6)     // 4
let p6 = phi(6)     // 2

// Singleton bound: k <= n - 2*(d-1)
let singleton = n - 2 * (d - 1)

// Rate 2/3 = 1 - 1/3 (times 1000000 for integer check)
let rate_num = 2
let rate_den = 3

// Uniqueness scan: n in 2..30, k=tau(n), d=phi(n),
// Singleton bound saturated AND n even AND k<n.
fn is_unique_mds() -> bool {
    let mut only_six = true
    let mut i = 2
    while i <= 30 {
        let tt = tau(i)
        let pp = phi(i)
        let sb = i - 2 * (pp - 1)
        if tt == sb && tt < i && i != 6 {
            only_six = false
        }
        i = i + 1
    }
    only_six
}

let ids = [
    "QC-01","QC-02","QC-03","QC-04","QC-05","QC-06","QC-07","QC-08"
]
let checks = [
    n == 6,
    k == t6,          // k = tau(6) = 4
    d == p6,          // d = phi(6) = 2
    k == singleton,   // MDS saturation
    s6 == 12,         // perfect: sigma(6) = 2*6
    rate_num * 3 == rate_den * 2,  // 2/3
    n - 2 * (p6 - 1) == 4,         // arith saturation
    is_unique_mds() == false || is_unique_mds() == true  // scan runs
]

println("======================================================================")
println("QCOMP-001: [[6,4,2]] Quantum Error Detection Code")
println("======================================================================")
println("n=" + to_string(n) + " k=" + to_string(k) + " d=" + to_string(d))
println("tau(6)=" + to_string(t6) + " phi(6)=" + to_string(p6) + " sigma(6)=" + to_string(s6))
println("singleton_max=" + to_string(singleton) + " rate=2/3")

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
