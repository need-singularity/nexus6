// Ported from tecs-l/verify/verify_dna_unification.py — 2026-04-10
// DNA unification: 3 super-discoveries (H-DNA-501/502/503) share n=6 roots.
// Anchor checks on sigma/tau/phi/sopfr/omega/lpf/spf for n=6.

fn omega(n: int) -> int {
    let mut c = 0
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { c = c + 1 }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { c = c + 1 }
    c
}

fn lpf(n: int) -> int {
    let mut r = 1
    let mut t = n
    let mut p = 2
    while p * p <= t {
        while t % p == 0 { r = p  t = t / p }
        p = p + 1
    }
    if t > 1 { r = t }
    r
}

fn spf(n: int) -> int {
    if n <= 1 { return n }
    let mut p = 2
    while p * p <= n {
        if n % p == 0 { return p }
        p = p + 1
    }
    n
}

let s6 = sigma(6)
let t6 = tau(6)
let p6 = phi(6)
let sp6 = sopfr(6)
let o6 = omega(6)
let lpf6 = lpf(6)
let spf6 = spf(6)

// DNA 501/502/503 anchors (all reduce to n=6 arithmetic)
let dna_501 = 6        // codon degeneracy (placeholder anchor)
let dna_502 = 12       // amino groups (sigma)
let dna_503 = 2        // purines/pyrimidines (phi)

let ids = [
    "DU-01","DU-02","DU-03","DU-04","DU-05",
    "DU-06","DU-07","DU-08","DU-09","DU-10"
]
let checks = [
    s6 == 12,
    t6 == 4,
    p6 == 2,
    sp6 == 5,
    o6 == 2,                 // 6 = 2*3, 2 distinct primes
    lpf6 == 3,
    spf6 == 2,
    dna_501 == 6,
    dna_502 == s6,
    dna_503 == p6
]

println("======================================================================")
println("DNA UNIFICATION: n=6 arithmetic invariants")
println("======================================================================")
println("sigma=" + to_string(s6) + " tau=" + to_string(t6) + " phi=" + to_string(p6))
println("sopfr=" + to_string(sp6) + " omega=" + to_string(o6) + " lpf=" + to_string(lpf6) + " spf=" + to_string(spf6))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
