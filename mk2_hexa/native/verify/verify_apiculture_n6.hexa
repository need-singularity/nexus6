// mk2_hexa/native/verify_apiculture_n6.hexa
// A17: apiculture n=6 검증 (R1 HEXA-FIRST / R18 미니멀 / R19 에러 명시)
// 벌집 육각형 셀 변 수 = 6 (최밀충전 기하)

let n = 6
let cell_sides = 6          // 벌집 셀 육각형 변
let comb_neighbors = 6      // 한 셀의 인접 셀 수
let caste_count = 3         // queen + worker + drone
let dance_axes = 2          // waggle 방향 + 거리
let life_phases = 1         // egg→larva→pupa→adult 성체 단계 대표
let domain_dim = caste_count + dance_axes + life_phases  // 3+2+1=6

println("══════════════════════════════════════════════════════════════════════")
println("A17 apiculture n=6: honeycomb hexagon + colony dimension")
println("══════════════════════════════════════════════════════════════════════")
println("  cell sides       = " + to_string(cell_sides))
println("  comb neighbors   = " + to_string(comb_neighbors))
println("  caste count      = " + to_string(caste_count))
println("  dance axes       = " + to_string(dance_axes))
println("  life phases      = " + to_string(life_phases))
println("  domain dim       = " + to_string(domain_dim))

if cell_sides != n {
    println("ERROR[A17]: cell sides mismatch expected=" + to_string(n) + " got=" + to_string(cell_sides))
    assert false
}
if comb_neighbors != n {
    println("ERROR[A17]: comb neighbor mismatch expected=" + to_string(n) + " got=" + to_string(comb_neighbors))
    assert false
}
if domain_dim != n {
    println("ERROR[A17]: domain dim mismatch expected=" + to_string(n) + " got=" + to_string(domain_dim))
    assert false
}

// 화분 수집 효율: 일벌 1마리 일일 ~ 6회 foraging trip (경험적 상한)
let forage_trips = 6
assert forage_trips == n
println("  ✓ apiculture n=6 OK (hexagon + 6-dim colony + 6 trips/day)")
