// Ported from tecs-l/verify/verify_harmonic_001_ramanujan_sum.py — 2026-04-10
// HARMONIC-001: Ramanujan sum c_6(n) depends only on gcd(n,6), value set {±1,±phi(6)}.
// c_6(n) = sum of e^(2pi*i*k/6) over k in (Z/6Z)*.
// Known closed form: c_6(n) = mu(6/d) * phi(6)/phi(6/d) where d = gcd(n,6).

fn my_gcd(a: int, b: int) -> int {
    let mut x = a
    let mut y = b
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    x
}

fn moebius(nn: int) -> int {
    if nn == 1 { return 1 }
    let mut cnt = 0
    let mut t = nn
    let mut d = 2
    while d * d <= t {
        if t % d == 0 {
            cnt = cnt + 1
            t = t / d
            if t % d == 0 { return 0 }
        }
        d = d + 1
    }
    if t > 1 { cnt = cnt + 1 }
    if cnt % 2 == 0 { 1 } else { 0 - 1 }
}

// c_6(n) closed form: for gcd(n,6)=d, c_6(n) = mu(6/d)*phi(6)/phi(6/d)
fn c6_at(n: int) -> int {
    let d = my_gcd(n, 6)
    let k = 6 / d
    let mu = moebius(k)
    let ph_k = phi(k)
    let ph_6 = phi(6)
    mu * ph_6 / ph_k
}

// Compute c_6(1..6) and compare to known values: [1,-1,-2,2,1,-1]... wait let's derive
// c_6(n) for n=1..6: [1,1,-2,-2,1,1]? Standard: c_q(n) is periodic in n mod q.
// Using formula: d=gcd(n,6), k=6/d, c_6(n) = mu(k)*phi(6)/phi(k) = mu(k)*2/phi(k)
//  n=1: d=1, k=6, mu(6)=1, phi(6)=2 → 1*2/2 = 1
//  n=2: d=2, k=3, mu(3)=-1, phi(3)=2 → -1*2/2 = -1
//  n=3: d=3, k=2, mu(2)=-1, phi(2)=1 → -1*2/1 = -2
//  n=4: d=2, k=3 → -1
//  n=5: d=1, k=6 → 1
//  n=6: d=6, k=1, mu(1)=1, phi(1)=1 → 1*2/1 = 2
// Sum over residues 1..6: 1-1-2-1+1+2 = 0 ✓
let v1 = c6_at(1)
let v2 = c6_at(2)
let v3 = c6_at(3)
let v4 = c6_at(4)
let v5 = c6_at(5)
let v6 = c6_at(6)
let tot = v1 + v2 + v3 + v4 + v5 + v6

let ph6 = phi(6)    // 2

let ids = [
    "HAR-01","HAR-02","HAR-03","HAR-04","HAR-05",
    "HAR-06","HAR-07","HAR-08"
]
let checks = [
    v1 == 1,
    v2 == 0 - 1,
    v3 == 0 - 2,
    v4 == 0 - 1,
    v5 == 1,
    v6 == 2,
    tot == 0,
    ph6 == 2
]

println("======================================================================")
println("HARMONIC-001: Ramanujan sum c_6(n)")
println("======================================================================")
println("c_6(1..6) = " + to_string(v1) + "," + to_string(v2) + "," + to_string(v3) + "," + to_string(v4) + "," + to_string(v5) + "," + to_string(v6))
println("Sum over residues = " + to_string(tot))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
