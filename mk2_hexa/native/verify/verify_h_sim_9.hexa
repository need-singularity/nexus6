// Ported from tecs-l/verify/verify_h_sim_9.py — 2026-04-10
// H-SIM-9: E(n) = sigma(n)*phi(n)/(n*tau(n)). Find all n with E(n)=1.
// Known theorem: E(n) = 1 iff n = 6. Search over 1..1000.

let s6 = sigma(6)
let t6 = tau(6)
let p6 = phi(6)

// For n=6: E(6) = 12*2 / (6*4) = 24/24 = 1
let e6_num = s6 * p6    // 24
let e6_den = 6 * t6     // 24

// Search 1..1000 for n where sigma(n)*phi(n) = n*tau(n)
let mut n = 1
let mut matches = 0
while n <= 1000 {
    if sigma(n) * phi(n) == n * tau(n) { matches = matches + 1 }
    n = n + 1
}

let ids = [
    "SIM9-01","SIM9-02","SIM9-03","SIM9-04","SIM9-05"
]
let checks = [
    e6_num == e6_den,
    e6_num == 24,
    matches == 2,                // n=1 (trivial) and n=6 in [1,1000]
    s6 * p6 == 6 * t6,
    s6 == 2 * 6                   // definition of perfect
]

println("======================================================================")
println("H-SIM-9: E(n) = sigma(n)*phi(n)/(n*tau(n)) = 1 iff n = 6")
println("======================================================================")
println("E(6) num/den = " + to_string(e6_num) + "/" + to_string(e6_den))
println("n in [1,1000] with E(n)=1: " + to_string(matches))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
