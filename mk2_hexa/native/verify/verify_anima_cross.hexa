// Ported from tecs-l/verify/verify_anima_cross.py — 2026-04-10
// Anima × TECS-L cross-domain checks.
// Core: R(n) = sigma(n)*phi(n)/(n*tau(n)) = 1 uniquely at n=6 (nontrivial).
// Integer form: sigma(n)*phi(n) == n*tau(n).

fn R_num(n: int) -> int { sigma(n) * phi(n) }
fn R_den(n: int) -> int { n * tau(n) }
fn R_is_one(n: int) -> bool { R_num(n) == R_den(n) }

// --- H-AX-1: growth stages [1,2,3,6,12] trace R-spectrum ---
// R(1)=1*1/(1*1)=1, R(2)=3*1/(2*2)=3/4, R(3)=4*2/(3*2)=8/6=4/3,
// R(6)=12*2/(6*4)=24/24=1, R(12)=28*4/(12*6)=112/72=14/9.
// Check: R(1)=1, R(6)=1, and no other n in [2,100] except n=1 satisfies R(n)=1.
fn count_R_eq_one(limit: int) -> int {
    let mut c = 0
    let mut n = 1
    while n <= limit {
        if R_is_one(n) { c = c + 1 }
        n = n + 1
    }
    c
}
let r_one_count_100 = count_R_eq_one(100)

// R(2) is 3/4: sigma(2)*phi(2)=3*1=3, 2*tau(2)=2*2=4 → 3 < 4 (deficient)
let r2_def = R_num(2) < R_den(2)
// R(3) is 4/3: sigma(3)*phi(3)=4*2=8, 3*tau(3)=3*2=6 → 8 > 6 (abundant)
let r3_abn = R_num(3) > R_den(3)
// R(6) = 1
let r6_one = R_is_one(6)

// --- Divisors of 6 = {1,2,3,6}, sum = 12 = sigma(6) ---
let s6 = sigma(6)
let t6 = tau(6)
let p6 = phi(6)

// --- H-AX-4: ConsciousLM 4M PPL ≈ σφ = 24 (integer check: target=24) ---
let target_ppl = s6 * p6  // 24

// --- Breath/Drift period amplitude ratio = 12/3 = 4 = tau(6) EXACT ---
let amp_b = 12
let amp_d = 3
let amp_ratio = amp_b / amp_d   // 4

// --- H-AX-5: sopfr(6)=5, n=6 semiprime structure ---
let sp6 = sopfr(6)  // 5

// --- R(n) product across stages: R(1)*R(2)*R(3)*R(6)*R(12) integer check ---
// Multiply numerators and denominators; check product of numerators == product of dens
let num_prod = R_num(1) * R_num(2) * R_num(3) * R_num(6) * R_num(12)
let den_prod = R_den(1) * R_den(2) * R_den(3) * R_den(6) * R_den(12)
// R(1)=1, R(6)=1 are identities; product = R(2)*R(3)*R(12) = (3/4)*(4/3)*(14/9) = 14/9
// So num_prod/den_prod should reduce to 14/9.
let prod_14_9 = num_prod * 9 == den_prod * 14

let ids = [
    "AX-01","AX-02","AX-03","AX-04","AX-05","AX-06","AX-07","AX-08","AX-09"
]
let checks = [
    r6_one,                       // R(6) = 1
    r2_def,                       // R(2) < 1 deficient
    r3_abn,                       // R(3) > 1 abundant
    r_one_count_100 == 2,         // Only n=1 and n=6 satisfy R(n)=1 in [1,100]
    s6 == 12 && t6 == 4 && p6 == 2,
    target_ppl == 24,             // sigma*phi = 24
    amp_ratio == t6,              // 12/3 = 4 = tau(6)
    sp6 == 5,                     // sopfr(6) = 2+3
    prod_14_9                     // Stage product = 14/9
]

println("======================================================================")
println("ANIMA x TECS-L Cross-Domain Verification")
println("======================================================================")
println("R(6) = sigma*phi/(n*tau) = " + to_string(R_num(6)) + "/" + to_string(R_den(6)))
println("R(n)=1 solutions in [1,100]: " + to_string(r_one_count_100))
println("sigma(6)*phi(6) = " + to_string(target_ppl) + " (ConsciousLM target)")
println("amp ratio 12/3 = " + to_string(amp_ratio) + " = tau(6)")

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
