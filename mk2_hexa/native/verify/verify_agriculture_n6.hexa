// mk2_hexa/native/verify_agriculture_n6.hexa
// A14: agriculture n=6 검증 (R18 미니멀 / R19 에러 명시)
// 6-요소 작물 필수 대량원소: N, P, K, Ca, Mg, S

let n = 6
let macros = ["N", "P", "K", "Ca", "Mg", "S"]

println("══════════════════════════════════════════════════════════════════════")
println("A14 agriculture n=6: macronutrient verification")
println("══════════════════════════════════════════════════════════════════════")

if len(macros) != n {
    println("ERROR[A14]: macro count mismatch expected=" + to_string(n) + " got=" + to_string(len(macros)))
    assert false
}

let mut i = 0
while i < len(macros) {
    println("  [" + to_string(i + 1) + "] " + macros[i])
    i = i + 1
}
assert len(macros) == n
println("  ✓ agriculture n=6 OK (NPK+CaMgS)")
