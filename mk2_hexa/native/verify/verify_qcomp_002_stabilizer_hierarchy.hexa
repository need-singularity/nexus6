// Ported from tecs-l/verify/verify_qcomp_002_stabilizer_hierarchy.py — 2026-04-10
// QCOMP-002: Stabilizer hierarchy — [[6,4,2]] detection / [[5,1,3]] Perfect / [[7,1,3]] Steane.
// Core integer claims: code parameters + Singleton bounds.

fn singleton(n: int, d: int) -> int { n - 2 * (d - 1) }

// [[6,4,2]] detection code (MDS)
let c642_n = 6
let c642_k = 4
let c642_d = 2

// [[5,1,3]] perfect 1-error correcting code (Laflamme) — MDS
let c513_n = 5
let c513_k = 1
let c513_d = 3

// [[7,1,3]] Steane code — not MDS (k=1, bound=3)
let c713_n = 7
let c713_k = 1
let c713_d = 3

let s6 = sigma(6)
let t6 = tau(6)
let p6 = phi(6)

let ids = [
    "QC2-01","QC2-02","QC2-03","QC2-04","QC2-05","QC2-06","QC2-07","QC2-08","QC2-09"
]
let checks = [
    c642_k == singleton(c642_n, c642_d),  // [[6,4,2]] MDS
    c513_k == singleton(c513_n, c513_d),  // [[5,1,3]] MDS
    c713_k <  singleton(c713_n, c713_d),  // Steane NOT MDS
    c642_k == t6,    // k = tau(6)
    c642_d == p6,    // d = phi(6)
    c642_n == 6,
    s6 == 12,
    c642_n + c642_k + c642_d == 12,  // 6+4+2 = sigma(6)
    c642_n * c642_d == s6            // 6*2 = 12
]

println("======================================================================")
println("QCOMP-002: Stabilizer Hierarchy — [[6,4,2]] / [[5,1,3]] / [[7,1,3]]")
println("======================================================================")
println("[[6,4,2]] singleton=" + to_string(singleton(c642_n, c642_d)) + " k=" + to_string(c642_k))
println("[[5,1,3]] singleton=" + to_string(singleton(c513_n, c513_d)) + " k=" + to_string(c513_k))
println("[[7,1,3]] singleton=" + to_string(singleton(c713_n, c713_d)) + " k=" + to_string(c713_k))
println("n+k+d = " + to_string(c642_n + c642_k + c642_d) + " = sigma(6)=" + to_string(s6))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
