// mk2_hexa/native/verify_hcx71_r_fractal.hexa
// 포팅 원본: tecs-l/math/verify_hcx71_r_fractal.py (224 LOC)
// H-CX-71: R-spectrum box-counting dimension → 1/(2π) 수렴 가설
//
// AI-native: @pure 전역, numpy 제거
// 범위: N=1000 (Python 50000 → 인터프리터 속도)

let PI = 3.141592653589793
let TARGET = 1.0 / (2.0 * PI)
let N_max = 1000

fn fmt6(x: float) -> string {
    let r = to_float(to_int(x * 1000000.0)) / 1000000.0
    to_string(r)
}
fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0)) / 10000.0
    to_string(r)
}
fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

// @pure
fn R_val(n: int) -> float {
    to_float(sigma(n) * phi(n)) / to_float(n * tau(n))
}

println("══════════════════════════════════════════════════════════════════════")
println("H-CX-71: R-spectrum fractal dim convergence to 1/(2π)  (hexa port)")
println("══════════════════════════════════════════════════════════════════════")
println("")
println("  TARGET = 1/(2π) = " + fmt6(TARGET))

// ─── R 값 계산 (1..N_max), [0, 5] 필터링 ───
println("")
println("  Precomputing R(n) for n=1.." + to_string(N_max) + "...")
let mut R_arr = []
let mut i = 1
while i <= N_max {
    let r = R_val(i)
    R_arr = R_arr + [r]
    i = i + 1
}

// ─── Box-counting dim: simple linear regression on (log(1/ε), log(count)) ───
// 고유값 정렬 (selection sort) — 범위 작으므로 허용
fn sort_asc(arr: list) -> list {
    let mut a = arr
    let n = len(a)
    let mut i = 0
    while i < n - 1 {
        let mut mn = i
        let mut j = i + 1
        while j < n {
            if a[j] < a[mn] { mn = j }
            j = j + 1
        }
        if mn != i {
            let t = a[i]
            a[i] = a[mn]
            a[mn] = t
        }
        i = i + 1
    }
    a
}

fn unique_sorted(arr: list) -> list {
    if len(arr) == 0 { return [] }
    let s = sort_asc(arr)
    let mut out = [s[0]]
    let mut i = 1
    while i < len(s) {
        if s[i] != s[i - 1] { out = out + [s[i]] }
        i = i + 1
    }
    out
}

// Count distinct boxes of size eps
fn count_boxes(sorted_data: list, data_min: float, eps: float) -> int {
    if eps <= 0.0 { return 0 }
    let mut last = 0 - 1
    let mut count = 0
    let mut i = 0
    while i < len(sorted_data) {
        let b = to_int((sorted_data[i] - data_min) / eps)
        if b != last {
            count = count + 1
            last = b
        }
        i = i + 1
    }
    count
}

// Linear regression: returns slope
fn linreg_slope(xs: list, ys: list) -> float {
    let n = len(xs)
    let nf = to_float(n)
    let mut sx = 0.0
    let mut sy = 0.0
    let mut sxy = 0.0
    let mut sxx = 0.0
    let mut i = 0
    while i < n {
        sx = sx + xs[i]
        sy = sy + ys[i]
        sxy = sxy + xs[i] * ys[i]
        sxx = sxx + xs[i] * xs[i]
        i = i + 1
    }
    (nf * sxy - sx * sy) / (nf * sxx - sx * sx)
}

// R² computation
fn r_squared(xs: list, ys: list, slope: float, intercept: float) -> float {
    let mut y_mean = 0.0
    let mut i = 0
    while i < len(ys) {
        y_mean = y_mean + ys[i]
        i = i + 1
    }
    y_mean = y_mean / to_float(len(ys))
    let mut ss_res = 0.0
    let mut ss_tot = 0.0
    let mut j = 0
    while j < len(xs) {
        let pred = slope * xs[j] + intercept
        ss_res = ss_res + (ys[j] - pred) * (ys[j] - pred)
        ss_tot = ss_tot + (ys[j] - y_mean) * (ys[j] - y_mean)
        j = j + 1
    }
    if ss_tot == 0.0 { return 1.0 }
    1.0 - ss_res / ss_tot
}

fn box_counting_dim(data: list) -> list {
    let sorted_u = unique_sorted(data)
    if len(sorted_u) < 2 { return [0.0, 1.0, 0] }
    let data_min = sorted_u[0]
    let data_max = sorted_u[len(sorted_u) - 1]
    let data_range = data_max - data_min
    if data_range <= 0.0 { return [0.0, 1.0, 0] }

    // ε 값: 20개 log-spaced in [0.001, 1] * range
    let mut epsilons = []
    let mut k = 0
    while k < 20 {
        // logspace(-3, 0, 20): exponent = -3 + k*3/19
        let expv = 0.0 - 3.0 + to_float(k) * 3.0 / 19.0
        let ev = pow(10.0, expv) * data_range
        epsilons = epsilons + [ev]
        k = k + 1
    }

    let mut xs = []
    let mut ys = []
    let mut e = 0
    while e < len(epsilons) {
        let eps = epsilons[e]
        if eps > 0.0 {
            let nb = count_boxes(sorted_u, data_min, eps)
            if nb > 1 {
                xs = xs + [log(1.0 / eps)]
                ys = ys + [log(to_float(nb))]
            }
        }
        e = e + 1
    }

    if len(xs) < 5 { return [0.0, 0.0, len(sorted_u)] }

    let slope = linreg_slope(xs, ys)
    // intercept = mean(y) - slope * mean(x)
    let mut mx = 0.0
    let mut my = 0.0
    let mut i = 0
    while i < len(xs) {
        mx = mx + xs[i]
        my = my + ys[i]
        i = i + 1
    }
    mx = mx / to_float(len(xs))
    my = my / to_float(len(ys))
    let intercept = my - slope * mx
    let r2 = r_squared(xs, ys, slope, intercept)
    [slope, r2, len(sorted_u)]
}

// ─── N values to test ───
let N_list = [100, 250, 500, 1000]

println("")
println("         N | unique |  d_box   |    R²    | |d−1/(2π)| | ratio")
println("  ---------+--------+----------+----------+------------+------")

let mut ni = 0
while ni < len(N_list) {
    let N = N_list[ni]
    // R[0..N] subset in [0, 5]
    let mut data = []
    let mut k = 0
    while k < N {
        let v = R_arr[k]
        if v >= 0.0 && v <= 5.0 { data = data + [v] }
        k = k + 1
    }
    let res = box_counting_dim(data)
    let d_box = res[0]
    let r2 = res[1]
    let n_uniq = res[2]
    let diff = abs_f(d_box - TARGET)
    let ratio = if TARGET > 0.0 { d_box / TARGET } else { 0.0 }
    println("  " + to_string(N) + "\t| " + to_string(n_uniq) + "\t| " + fmt6(d_box) + " | " + fmt4(r2) + " | " + fmt6(diff) + " | " + fmt4(ratio))
    ni = ni + 1
}

println("")
println("  Target:  1/(2π) = " + fmt6(TARGET))
println("")
println("  Interpretation: d_box가 1/(2π) ≈ " + fmt4(TARGET) + "로 수렴하는지 관찰")
println("  (원본 Python N=50000 vs hexa N=1000 — 수렴 추세만 확인 가능)")
