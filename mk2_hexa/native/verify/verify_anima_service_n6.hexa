// mk2_hexa/native/verify_anima_service_n6.hexa
// A16: anima-service n=6 검증 (R18 미니멀 / R19 에러 명시)
// anima 서비스 6-state: init, sense, reflect, decide, act, absorb

let n = 6
let states = ["init", "sense", "reflect", "decide", "act", "absorb"]

println("══════════════════════════════════════════════════════════════════════")
println("A16 anima-service n=6: state machine verification")
println("══════════════════════════════════════════════════════════════════════")

if len(states) != n {
    println("ERROR[A16]: state count mismatch expected=" + to_string(n) + " got=" + to_string(len(states)))
    assert false
}

// 순환 닫힘: absorb → init (6→1) 확인
let head = states[0]
let tail = states[len(states) - 1]
if head != "init" {
    println("ERROR[A16]: head must be init got=" + head)
    assert false
}
if tail != "absorb" {
    println("ERROR[A16]: tail must be absorb got=" + tail)
    assert false
}

let mut i = 0
while i < len(states) {
    println("  [" + to_string(i + 1) + "] " + states[i])
    i = i + 1
}
println("  ✓ anima-service n=6 OK (cyclic: absorb→init)")
