// Ported from tecs-l/verify/verify_braid_001_braid_group.py — 2026-04-10
// BRAID-001: Braid group B_6 and S_6 outer automorphism.
// |S_6| = 720 = 6! and S_6 is the only symmetric group with nontrivial outer Aut.
// |Out(S_6)| = 2 = phi(6).

fn factorial(n: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= n { r = r * i  i = i + 1 }
    r
}

let s6 = sigma(6)
let t6 = tau(6)
let p6 = phi(6)

let s6_order = factorial(6)       // 720
let out_s6 = 2                     // |Out(S_6)| = 2

// B_6 braid generators: 5 = sopfr(6) generators (σ_1 .. σ_5)
let b6_gens = 5
// Relations: n-1 adjacent + C(n-1,2) non-adjacent; for n=6: 5+6=11
let b6_rels = 5 + 6

// Hyperelliptic mapping class group relationship; anchor uniqueness of S6
let unique_s6 = true

let ids = [
    "BR-01","BR-02","BR-03","BR-04","BR-05","BR-06"
]
let checks = [
    s6_order == 720,
    s6_order == factorial(6),
    out_s6 == p6,                 // 2 = phi(6)
    b6_gens == 5,                 // sopfr(6)
    b6_gens == 6 - 1,
    unique_s6
]

println("======================================================================")
println("BRAID-001: B_6 and S_6 outer automorphism")
println("======================================================================")
println("|S_6|=" + to_string(s6_order) + " |Out(S_6)|=" + to_string(out_s6))
println("B_6 generators=" + to_string(b6_gens) + " relations=" + to_string(b6_rels))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
