// 포팅 원본: tecs-l/math/verify_hcx71_r_fractal_v2.py (277 LOC)
// H-CX-71: R-spectrum fractal dimension convergence to 1/(2*pi)
// R(n) = sigma(n)*phi(n)/(n*tau(n))
// Variants: full, log, composite-only, restricted [0.75,5]

fn R(n: int) -> float {
    to_float(sigma(n) * phi(n)) / to_float(n * tau(n))
}

fn fmt6(x: float) -> string {
    let r = to_float(to_int(x * 1000000.0)) / 1000000.0
    to_string(r)
}

fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0)) / 10000.0
    to_string(r)
}

fn fmt1(x: float) -> string {
    let r = to_float(to_int(x * 10.0)) / 10.0
    to_string(r)
}

fn abs_val(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    x
}

fn ln(x: float) -> float {
    log(x)
}

fn is_prime(n: int) -> bool {
    if n < 2 { return false }
    if n < 4 { return true }
    if n % 2 == 0 { return false }
    if n % 3 == 0 { return false }
    let mut i = 5
    while i * i <= n {
        if n % i == 0 { return false }
        if n % (i + 2) == 0 { return false }
        i = i + 6
    }
    true
}

// Box-counting dimension for 1D set
// Returns [d_box, r2]
fn box_counting_dim(data) {
    // Deduplicate and sort
    let sorted = data.sort()
    let mut unique = [sorted[0]]
    let mut k = 1
    while k < len(sorted) {
        if sorted[k] != sorted[k - 1] {
            unique = unique.push(sorted[k])
        }
        k = k + 1
    }
    if len(unique) < 2 { return [0.0, 0.0] }

    let d_min = unique[0]
    let d_max = unique[len(unique) - 1]
    let d_range = d_max - d_min
    if d_range == 0.0 { return [0.0, 1.0] }

    // Log-spaced epsilons: 30 points from 10^-3.5 to 10^0 * d_range
    let n_eps = 30
    let mut log_eps_inv = []
    let mut log_counts = []

    let mut ei = 0
    while ei < n_eps {
        let t = -3.5 + to_float(ei) * 3.5 / to_float(n_eps - 1)
        let eps = pow(10.0, t) * d_range
        if eps <= 0.0 {
            ei = ei + 1
            continue
        }
        // Count occupied boxes
        let mut boxes = #{}
        let mut j = 0
        while j < len(unique) {
            let box_id = to_int(floor((unique[j] - d_min) / eps))
            let box_key = to_string(box_id)
            boxes[box_key] = 1
            j = j + 1
        }
        let n_boxes = len(keys(boxes))
        if n_boxes > 1 {
            log_eps_inv = log_eps_inv.push(ln(1.0 / eps))
            log_counts = log_counts.push(ln(to_float(n_boxes)))
        }
        ei = ei + 1
    }

    if len(log_counts) < 5 { return [0.0, 0.0] }

    // Linear regression: slope = d_box
    let n_pts = len(log_eps_inv)
    let mut sum_x = 0.0
    let mut sum_y = 0.0
    let mut sum_xy = 0.0
    let mut sum_xx = 0.0
    let mut ri = 0
    while ri < n_pts {
        sum_x = sum_x + log_eps_inv[ri]
        sum_y = sum_y + log_counts[ri]
        sum_xy = sum_xy + log_eps_inv[ri] * log_counts[ri]
        sum_xx = sum_xx + log_eps_inv[ri] * log_eps_inv[ri]
        ri = ri + 1
    }
    let nf = to_float(n_pts)
    let denom = nf * sum_xx - sum_x * sum_x
    if abs_val(denom) < 0.000000000000001 { return [0.0, 0.0] }
    let slope = (nf * sum_xy - sum_x * sum_y) / denom
    let intercept = (sum_y - slope * sum_x) / nf

    // R^2
    let mean_y = sum_y / nf
    let mut ss_tot = 0.0
    let mut ss_res = 0.0
    let mut qi = 0
    while qi < n_pts {
        let pred = slope * log_eps_inv[qi] + intercept
        let diff_r = log_counts[qi] - pred
        let diff_m = log_counts[qi] - mean_y
        ss_res = ss_res + diff_r * diff_r
        ss_tot = ss_tot + diff_m * diff_m
        qi = qi + 1
    }
    let r2 = if ss_tot > 0.0 { 1.0 - ss_res / ss_tot } else { 1.0 }

    [slope, r2]
}

// ─── MAIN ───
let PI = 3.14159265358979323846
let TARGET = 1.0 / (2.0 * PI)

println("Target: 1/(2*pi) = " + fmt6(TARGET))
println("======================================================================")
println("H-CX-71 v2: R-spectrum fractal dimension (corrected range)")
println("======================================================================")

// Compute R(n) for n=1..N_max (reduced for hexa)
let N_max = 2500
println("\nComputing R(n) for n=1.." + to_string(N_max) + "...")

let mut R_arr = []
let mut R_min = 999999.0
let mut R_max = 0.0
let mut R_sum = 0.0
let mut R_min_idx = 1
let mut R_max_idx = 1
let mut count_le5 = 0
let mut count_le1 = 0

let mut n = 1
while n <= N_max {
    let r = R(n)
    R_arr = R_arr.push(r)
    R_sum = R_sum + r
    if r < R_min {
        R_min = r
        R_min_idx = n
    }
    if r > R_max {
        R_max = r
        R_max_idx = n
    }
    if r <= 5.0 { count_le5 = count_le5 + 1 }
    if r <= 1.0 { count_le1 = count_le1 + 1 }
    n = n + 1
}
println("Done.")

let R_mean = R_sum / to_float(N_max)
println("\nR(n) statistics for n=1.." + to_string(N_max) + ":")
println("  Min:      " + fmt6(R_min) + "  (at n=" + to_string(R_min_idx) + ")")
println("  Max:      " + fmt6(R_max) + "  (at n=" + to_string(R_max_idx) + ")")
println("  Mean:     " + fmt6(R_mean))
let pct5 = fmt1(100.0 * to_float(count_le5) / to_float(N_max))
let pct1 = fmt1(100.0 * to_float(count_le1) / to_float(N_max))
println("  In [0,5]: " + to_string(count_le5) + " (" + pct5 + "%)")
println("  In [0,1]: " + to_string(count_le1) + " (" + pct1 + "%)")

// N-list for convergence (reduced)
let N_list = [50, 100, 250, 500, 1000, 1500, 2000, 2500]

// ─── VARIANT 1: Full R(n) ───
println("\n======================================================================")
println("VARIANT 1: Full R(n) set (no range restriction)")
println("======================================================================")
println("")

let mut v1_d = []
let mut v1_N = []

let mut ni = 0
while ni < len(N_list) {
    let Nval = N_list[ni]
    let mut data = []
    let mut di = 0
    while di < Nval {
        data = data.push(R_arr[di])
        di = di + 1
    }
    let result = box_counting_dim(data)
    let d_box = result[0]
    let r2 = result[1]
    let diff = abs_val(d_box - TARGET)
    let ratio = d_box / TARGET
    v1_d = v1_d.push(d_box)
    v1_N = v1_N.push(Nval)
    println("N=" + to_string(Nval) + " | d_box=" + fmt6(d_box) + " | R2=" + fmt4(r2) + " | |d-1/2pi|=" + fmt6(diff) + " | ratio=" + fmt4(ratio))
    ni = ni + 1
}

// ─── VARIANT 2: log(R(n)) ───
println("\n======================================================================")
println("VARIANT 2: log(R(n)) set")
println("======================================================================")
println("")

let mut v2_d = []

let mut ni2 = 0
while ni2 < len(N_list) {
    let Nval = N_list[ni2]
    let mut data = []
    let mut di = 0
    while di < Nval {
        let val = ln(R_arr[di])
        data = data.push(val)
        di = di + 1
    }
    let result = box_counting_dim(data)
    let d_box = result[0]
    let r2 = result[1]
    let diff = abs_val(d_box - TARGET)
    let ratio = d_box / TARGET
    v2_d = v2_d.push(d_box)
    println("N=" + to_string(Nval) + " | d_box=" + fmt6(d_box) + " | R2=" + fmt4(r2) + " | |d-1/2pi|=" + fmt6(diff) + " | ratio=" + fmt4(ratio))
    ni2 = ni2 + 1
}

// ─── VARIANT 3: Composite only ───
println("\n======================================================================")
println("VARIANT 3: R(n) restricted to composite n (no primes)")
println("======================================================================")
println("")

let mut v3_d = []

let mut ni3 = 0
while ni3 < len(N_list) {
    let Nval = N_list[ni3]
    let mut data = []
    let mut di = 0
    while di < Nval {
        let nn = di + 1
        if !is_prime(nn) {
            data = data.push(R_arr[di])
        }
        di = di + 1
    }
    if len(data) < 10 {
        println("N=" + to_string(Nval) + " | too few composites")
        v3_d = v3_d.push(0.0)
        ni3 = ni3 + 1
        continue
    }
    let result = box_counting_dim(data)
    let d_box = result[0]
    let r2 = result[1]
    let diff = abs_val(d_box - TARGET)
    v3_d = v3_d.push(d_box)
    let nc = len(data)
    println("N=" + to_string(Nval) + " | composites=" + to_string(nc) + " | d_box=" + fmt6(d_box) + " | R2=" + fmt4(r2) + " | |d-1/2pi|=" + fmt6(diff))
    ni3 = ni3 + 1
}

// ─── VARIANT 4: R(n) in [0.75, 5] ───
println("\n======================================================================")
println("VARIANT 4: R(n) in [0.75, 5] (original hypothesis range)")
println("======================================================================")
println("")

let mut ni4 = 0
while ni4 < len(N_list) {
    let Nval = N_list[ni4]
    let mut data = []
    let mut di = 0
    while di < Nval {
        let val = R_arr[di]
        if val >= 0.75 && val <= 5.0 {
            data = data.push(val)
        }
        di = di + 1
    }
    let nf = len(data)
    if nf < 5 {
        println("N=" + to_string(Nval) + " | in_range=" + to_string(nf) + " | N/A")
        ni4 = ni4 + 1
        continue
    }
    let result = box_counting_dim(data)
    let d_box = result[0]
    let r2 = result[1]
    let diff = abs_val(d_box - TARGET)
    println("N=" + to_string(Nval) + " | in_range=" + to_string(nf) + " | d_box=" + fmt6(d_box) + " | R2=" + fmt4(r2) + " | |d-1/2pi|=" + fmt6(diff))
    ni4 = ni4 + 1
}

// ─── CONVERGENCE ANALYSIS ───
println("\n======================================================================")
println("CONVERGENCE ANALYSIS")
println("======================================================================")

// Linear regression: d_box vs log(N) for V1
if len(v1_d) >= 3 {
    let mut sx = 0.0
    let mut sy = 0.0
    let mut sxy = 0.0
    let mut sxx = 0.0
    let nv = len(v1_d)
    let mut ci = 0
    while ci < nv {
        let lnN = ln(to_float(v1_N[ci]))
        let d = v1_d[ci]
        sx = sx + lnN
        sy = sy + d
        sxy = sxy + lnN * d
        sxx = sxx + lnN * lnN
        ci = ci + 1
    }
    let nvf = to_float(nv)
    let den = nvf * sxx - sx * sx
    let slope = (nvf * sxy - sx * sy) / den
    let intercept = (sy - slope * sx) / nvf
    let final_d = v1_d[nv - 1]
    let final_N = v1_N[nv - 1]
    println("\nV1 Full R(n):")
    println("  Slope (d_box vs log N): " + fmt6(slope))
    println("  d_box(N=" + to_string(final_N) + ") = " + fmt6(final_d))
    println("  Target 1/(2*pi) = " + fmt6(TARGET))
    println("  Ratio d/target = " + fmt4(final_d / TARGET))
    if abs_val(slope) < 0.000001 {
        println("  Status: FLAT (no convergence toward target)")
    } else {
        if (slope > 0.0 && final_d < TARGET) || (slope < 0.0 && final_d > TARGET) {
            println("  Status: Trending TOWARD target")
        } else {
            println("  Status: Trending AWAY from target")
        }
    }
}

// V2
if len(v2_d) >= 3 {
    let mut sx = 0.0
    let mut sy = 0.0
    let mut sxy = 0.0
    let mut sxx = 0.0
    let nv = len(v2_d)
    let mut ci = 0
    while ci < nv {
        let lnN = ln(to_float(N_list[ci]))
        let d = v2_d[ci]
        sx = sx + lnN
        sy = sy + d
        sxy = sxy + lnN * d
        sxx = sxx + lnN * lnN
        ci = ci + 1
    }
    let nvf = to_float(nv)
    let den = nvf * sxx - sx * sx
    let slope = (nvf * sxy - sx * sy) / den
    let final_d = v2_d[nv - 1]
    println("\nV2 log(R(n)):")
    println("  Slope (d_box vs log N): " + fmt6(slope))
    println("  d_box(N=" + to_string(N_list[nv - 1]) + ") = " + fmt6(final_d))
    println("  Ratio d/target = " + fmt4(final_d / TARGET))
}

// V3
if len(v3_d) >= 3 {
    let mut sx = 0.0
    let mut sy = 0.0
    let mut sxy = 0.0
    let mut sxx = 0.0
    let nv = len(v3_d)
    let mut ci = 0
    while ci < nv {
        let lnN = ln(to_float(N_list[ci]))
        let d = v3_d[ci]
        sx = sx + lnN
        sy = sy + d
        sxy = sxy + lnN * d
        sxx = sxx + lnN * lnN
        ci = ci + 1
    }
    let nvf = to_float(nv)
    let den = nvf * sxx - sx * sx
    let slope = (nvf * sxy - sx * sy) / den
    let final_d = v3_d[nv - 1]
    println("\nV3 Composites:")
    println("  Slope (d_box vs log N): " + fmt6(slope))
    println("  d_box(N=" + to_string(N_list[nv - 1]) + ") = " + fmt6(final_d))
    println("  Ratio d/target = " + fmt4(final_d / TARGET))
}

// ─── FINAL VERDICT ───
println("\n======================================================================")
println("FINAL VERDICT")
println("======================================================================")
println("\nTarget hypothesis: d_box -> 1/(2*pi) = " + fmt6(TARGET))
println("")

// Check each variant's final value
if len(v1_d) > 0 {
    let fd = v1_d[len(v1_d) - 1]
    let ratio = fd / TARGET
    let w10 = abs_val(fd - TARGET) < 0.1 * TARGET
    let w5 = abs_val(fd - TARGET) < 0.05 * TARGET
    let w1 = abs_val(fd - TARGET) < 0.01 * TARGET
    println("V1 Full: d=" + fmt6(fd) + ", ratio=" + fmt4(ratio) + "x target")
    println("  Within 10%: " + to_string(w10) + ", Within 5%: " + to_string(w5) + ", Within 1%: " + to_string(w1))
}
if len(v2_d) > 0 {
    let fd = v2_d[len(v2_d) - 1]
    let ratio = fd / TARGET
    let w10 = abs_val(fd - TARGET) < 0.1 * TARGET
    let w5 = abs_val(fd - TARGET) < 0.05 * TARGET
    let w1 = abs_val(fd - TARGET) < 0.01 * TARGET
    println("V2 log: d=" + fmt6(fd) + ", ratio=" + fmt4(ratio) + "x target")
    println("  Within 10%: " + to_string(w10) + ", Within 5%: " + to_string(w5) + ", Within 1%: " + to_string(w1))
}
if len(v3_d) > 0 {
    let fd = v3_d[len(v3_d) - 1]
    let ratio = fd / TARGET
    let w10 = abs_val(fd - TARGET) < 0.1 * TARGET
    let w5 = abs_val(fd - TARGET) < 0.05 * TARGET
    let w1 = abs_val(fd - TARGET) < 0.01 * TARGET
    println("V3 Comp: d=" + fmt6(fd) + ", ratio=" + fmt4(ratio) + "x target")
    println("  Within 10%: " + to_string(w10) + ", Within 5%: " + to_string(w5) + ", Within 1%: " + to_string(w1))
}

println("\nDone.")
