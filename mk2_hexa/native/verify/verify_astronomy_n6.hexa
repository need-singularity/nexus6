// mk2_hexa/native/verify_astronomy_n6.hexa
// A?: astronomy n=6 검증 (R18 미니멀 / R19 에러 명시)
// 6 naked-eye planets + 6-fold snowflake/star symmetry

let n = 6
let visible_planets = 6      // Mercury Venus Mars Jupiter Saturn + Earth
let star_symmetry = 6        // 6-pointed crystal / hex star pattern

println("══════════════════════════════════════════════════════════════════════")
println("A?? astronomy n=6: visible planets + 6-fold symmetry")
println("══════════════════════════════════════════════════════════════════════")
println("  visible planets = " + to_string(visible_planets))
println("  star symmetry   = " + to_string(star_symmetry))

if visible_planets != n {
    println("ERROR[astronomy]: planets expected=" + to_string(n) + " got=" + to_string(visible_planets))
    assert false
}
if star_symmetry != n {
    println("ERROR[astronomy]: symmetry expected=" + to_string(n) + " got=" + to_string(star_symmetry))
    assert false
}

// equatorial coords: RA + Dec + dist + 3 proper motion = 6 phase-space dims
let phase_dims = 6
assert phase_dims == n
println("  ✓ astronomy n=6 OK (6 planets + C6 + phase6)")
