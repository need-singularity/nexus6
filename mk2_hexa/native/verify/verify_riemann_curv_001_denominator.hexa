// Ported from tecs-l/verify/verify_riemann_curv_001_denominator.py — 2026-04-10
// RIEMANN-CURV-001: Riemann tensor indep comps = n^2(n^2-1)/12, denom = sigma(6).

fn riemann_comps(d: int) -> int { d * d * (d * d - 1) / 12 }
fn ricci_comps(d: int) -> int { d * (d + 1) / 2 }
fn weyl_comps(d: int) -> int {
    if d < 3 { return 0 }
    (d + 2) * (d + 1) * d * (d - 3) / 12
}

let s6 = sigma(6)

// N(3) = 9*8/12 = 6 = P1
let r3 = riemann_comps(3)
// N(4) = 16*15/12 = 20
let r4 = riemann_comps(4)
// N(6) = 36*35/12 = 105
let r6 = riemann_comps(6)
// Weyl in dim 6: (8*7*6*3)/12 = 84 = sigma(6)*7
let w6 = weyl_comps(6)
// Ricci sym(3) = 6
let ri3 = ricci_comps(3)

let ids = [
    "RM-01","RM-02","RM-03","RM-04","RM-05","RM-06","RM-07"
]
let checks = [
    r3 == 6,
    r3 == 6,                        // N(3)=P1=6
    r4 == 20,
    r6 == 105,
    w6 == 84,
    w6 == s6 * 7,
    ri3 == 6
]

println("======================================================================")
println("RIEMANN-CURV-001: N(n)=n^2(n^2-1)/sigma(6)")
println("======================================================================")
println("N(3)=" + to_string(r3) + " N(4)=" + to_string(r4) + " N(6)=" + to_string(r6))
println("Weyl(6)=" + to_string(w6) + " sigma(6)*7=" + to_string(s6 * 7))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
