// Ported from tecs-l/verify/verify_n_pi_sopfr_universal.py — 2026-04-10
// Universal formula: n · π^sopfr(n) at n=6 gives 6*pi^5 (proton/electron prediction).
// Test sopfr at perfect numbers: sopfr(6)=5, sopfr(28)=11, sopfr(496)=39.

let sp6 = sopfr(6)       // 2+3 = 5
let sp28 = sopfr(28)     // 2+2+7 = 11
let sp496 = sopfr(496)   // 2*4 + 31 = 39

// sigma(sigma(n)) chain
let s6 = sigma(6)
let ss6 = sigma(s6)      // sigma(12) = 28
let sss6 = sigma(ss6)    // sigma(28) = 56

// n + sopfr(n) for perfect numbers
let t1 = 6 + sp6     // 11 (prime)
let t2 = 28 + sp28   // 39 = 3*13
let t3 = 496 + sp496 // 535 = 5*107

// 6*5 = 30 = 2*3*5 = smallest 3-almost prime
let n_sp = 6 * sp6   // 30

let ids = [
    "NP-01","NP-02","NP-03","NP-04","NP-05","NP-06","NP-07","NP-08"
]
let checks = [
    sp6 == 5,
    sp28 == 11,
    sp496 == 39,
    s6 == 12,
    ss6 == 28,         // second perfect number
    sss6 == 56,        // 2 * 28
    n_sp == 30,
    t1 == 11           // 6+5 = 11 prime
]

println("======================================================================")
println("UNIVERSAL n · π^sopfr(n) FORMULA CHECK")
println("======================================================================")
println("sopfr(6)=" + to_string(sp6) + " sopfr(28)=" + to_string(sp28) + " sopfr(496)=" + to_string(sp496))
println("sigma^2(6)=" + to_string(ss6) + " sigma^3(6)=" + to_string(sss6))
println("6*sopfr(6)=" + to_string(n_sp))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
