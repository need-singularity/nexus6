// 포팅 원본: tecs-l/math/verify_tree_1_3.py (409 LOC)
// H-TREE-1: Dynamical Systems (R-chain dynamics, cycles, basins)
// H-TREE-3: Probability (R(n) distribution, R(n)/n scaling)
// R(n) = sigma(n)*phi(n) / (n*tau(n))
//
// hexa builtins: sigma(n), phi(n), tau(n), gcd(a,b)
// 범위: N 축소 (Python 100k → hexa 500~2000, 인터프리터 속도)

// ─── Helper functions ───

fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0)) / 10000.0
    to_string(r)
}

fn fmt6(x: float) -> string {
    let r = to_float(to_int(x * 1000000.0)) / 1000000.0
    to_string(r)
}

fn R_float(n: int) -> float {
    let num = sigma(n) * phi(n)
    let den = n * tau(n)
    to_float(num) / to_float(den)
}

fn R_floor(n: int) -> int {
    let num = sigma(n) * phi(n)
    let den = n * tau(n)
    num / den
}

fn R_is_integer(n: int) -> bool {
    let num = sigma(n) * phi(n)
    let den = n * tau(n)
    num % den == 0
}

fn repeat_char(ch: string, count: int) -> string {
    let mut s = ""
    let mut i = 0
    while i < count {
        s = s + ch
        i = i + 1
    }
    s
}

fn min_f(a: float, b: float) -> float { if a < b { a } else { b } }
fn max_f(a: float, b: float) -> float { if a > b { a } else { b } }
fn min_i(a: int, b: int) -> int { if a < b { a } else { b } }
fn max_i(a: int, b: int) -> int { if a > b { a } else { b } }

fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

// ─── Limits (reduced for interpreter speed) ───
let N_CHAIN = 2000
let N_FIXED = 2000
let N_BASIN = 2000
let N_PROB  = 2000

// ═══════════════════════════════════════════════════════════════
// Sanity check
// ═══════════════════════════════════════════════════════════════
let r6 = R_float(6)
println("Sanity check: R(6) = sigma(6)*phi(6)/(6*tau(6)) = " + to_string(sigma(6)) + "*" + to_string(phi(6)) + "/(6*" + to_string(tau(6)) + ") = " + fmt6(r6))
if abs_f(r6 - 1.0) < 0.0001 {
    println("R(6) = 1 OK")
} else {
    println("ERROR: R(6) != 1, got " + fmt6(r6))
}
println("")

// ═══════════════════════════════════════════════════════════════
// H-TREE-1: DYNAMICAL SYSTEMS BRANCH
// ═══════════════════════════════════════════════════════════════
println("======================================================================")
println("H-TREE-1: DYNAMICAL SYSTEMS BRANCH")
println("R-chain: n -> floor(R(n)) -> floor(R(floor(R(n)))) -> ... -> 1 or cycle")
println("======================================================================")

// --- 1. R-chain orbits for n=2..N_CHAIN ---
println("")
println("## 1. R-chain orbits for n=2.." + to_string(N_CHAIN))

// chain_lengths[n] = steps to reach 1 (or -1 if cycle/overflow)
let mut chain_lengths = []
let mut cl_init = 0
while cl_init <= N_CHAIN {
    chain_lengths = chain_lengths + [0]
    cl_init = cl_init + 1
}

let mut chains_through_6 = 0
let mut longest_chain_len = 0
let mut longest_chain_start = 0
let mut longest_chain_path = []
let mut cycle_count = 0

let mut n = 2
while n <= N_CHAIN {
    let mut path = [n]
    let mut current = n
    let mut steps = 0
    let mut is_cycle = false
    let max_steps = 200

    while current > 1 && steps < max_steps {
        if current > 100000 {
            steps = 0 - 1
            break
        }
        let fl = R_floor(current)
        if fl == 0 {
            break
        }
        // Simple cycle check: if fl == current (fixed point other than 1)
        if fl == current && fl != 1 {
            is_cycle = true
            cycle_count = cycle_count + 1
            break
        }
        path = path + [fl]
        current = fl
        steps = steps + 1
    }

    if is_cycle {
        chain_lengths[n] = 0 - 1
    } else if steps < 0 {
        chain_lengths[n] = 0 - 1
    } else {
        let clen = len(path) - 1
        chain_lengths[n] = clen
    }

    // Check if 6 is in the path
    let mut pi = 0
    while pi < len(path) {
        if path[pi] == 6 {
            chains_through_6 = chains_through_6 + 1
            pi = len(path)
        }
        pi = pi + 1
    }

    // Track longest
    let plen = len(path)
    if plen > longest_chain_len && chain_lengths[n] >= 0 {
        longest_chain_len = plen
        longest_chain_start = n
        longest_chain_path = path
    }

    n = n + 1
}

// Chain length distribution
let mut length_counts = #{}
let mut valid_count = 0
let mut length_sum = 0
let mut max_len = 0
let mut ci = 2
while ci <= N_CHAIN {
    let cl = chain_lengths[ci]
    if cl >= 0 {
        valid_count = valid_count + 1
        length_sum = length_sum + cl
        if cl > max_len { max_len = cl }
        let key = to_string(cl)
        if has_key(length_counts, key) {
            length_counts[key] = length_counts[key] + 1
        } else {
            length_counts[key] = 1
        }
    }
    ci = ci + 1
}

println("")
println("### Chain length distribution (n=2.." + to_string(N_CHAIN) + ")")
println("| Length | Count | Fraction |")
println("|--------|-------|----------|")
let mut li = 0
while li <= max_len {
    let key = to_string(li)
    if has_key(length_counts, key) {
        let cnt = length_counts[key]
        let frac = to_float(cnt) / to_float(valid_count)
        println("| " + to_string(li) + " | " + to_string(cnt) + " | " + fmt6(frac) + " |")
    }
    li = li + 1
}

// --- 2. Fixed points ---
println("")
println("## 2. Fixed points: floor(R(n)) = n for n=2.." + to_string(N_FIXED))
let mut fixed_points = []
let mut fi = 2
while fi <= N_FIXED {
    let fl = R_floor(fi)
    if fl == fi { fixed_points = fixed_points + [fi] }
    fi = fi + 1
}

if len(fixed_points) > 0 {
    let mut show_fp = fixed_points
    if len(fixed_points) > 30 {
        let mut h = []
        let mut k = 0
        while k < 30 {
            h = h + [fixed_points[k]]
            k = k + 1
        }
        show_fp = h
    }
    println("  Fixed points found: " + to_string(show_fp))
} else {
    println("  No fixed points found (other than trivial n=1).")
}

// floor(R(n)) = 1
let mut maps_to_1 = []
let mut mi = 2
while mi <= N_CHAIN {
    let fl = R_floor(mi)
    if fl == 1 { maps_to_1 = maps_to_1 + [mi] }
    mi = mi + 1
}
println("")
println("  Numbers with floor(R(n))=1 (n=2.." + to_string(N_CHAIN) + "): " + to_string(len(maps_to_1)))
if len(maps_to_1) <= 50 {
    println("  Values: " + to_string(maps_to_1))
} else {
    let mut h50 = []
    let mut k = 0
    while k < 50 {
        h50 = h50 + [maps_to_1[k]]
        k = k + 1
    }
    println("  First 50: " + to_string(h50))
}

println("")
println("  Cycles detected: " + to_string(cycle_count))

// --- 3. Basin of attraction of n=6 ---
println("")
println("## 3. Basin of attraction of n=6")
println("  Chains passing through 6 (n=2.." + to_string(N_CHAIN) + "): " + to_string(chains_through_6))
let frac6 = to_float(chains_through_6) / to_float(N_CHAIN - 1)
println("  Fraction: " + fmt6(frac6))

// Direct preimages: floor(R(m)) = 6
let mut preimage_6 = []
let mut pm = 2
while pm <= N_BASIN {
    if R_floor(pm) == 6 { preimage_6 = preimage_6 + [pm] }
    pm = pm + 1
}
println("  Direct preimages (floor(R(m))=6, m<=" + to_string(N_BASIN) + "): " + to_string(len(preimage_6)))
if len(preimage_6) <= 30 {
    println("  Values: " + to_string(preimage_6))
} else {
    let mut h30 = []
    let mut k = 0
    while k < 30 {
        h30 = h30 + [preimage_6[k]]
        k = k + 1
    }
    println("  First 30: " + to_string(h30))
}

// --- 4. Longest chain ---
println("")
println("## 4. Longest chain (n<=" + to_string(N_CHAIN) + ")")
println("  Start: n=" + to_string(longest_chain_start))
let lc_steps = longest_chain_len - 1
println("  Length: " + to_string(lc_steps) + " steps (" + to_string(longest_chain_len) + " nodes)")
let mut path_str = ""
let mut ps = 0
while ps < len(longest_chain_path) {
    if ps > 0 { path_str = path_str + " -> " }
    path_str = path_str + to_string(longest_chain_path[ps])
    ps = ps + 1
}
println("  Path: " + path_str)

// Top 20 longest chains — collect (n, length) pairs
println("")
println("### Top 20 longest chains:")
println("| Rank | Start n | Length |")
println("|------|---------|--------|")
// Simple selection: find top 20 by scanning max repeatedly
let mut used = #{}
let mut rank = 1
while rank <= 20 {
    let mut best_n = 0 - 1
    let mut best_l = 0 - 1
    let mut si = 2
    while si <= N_CHAIN {
        let key = to_string(si)
        let cl = chain_lengths[si]
        if cl > best_l && !has_key(used, key) {
            best_l = cl
            best_n = si
        }
        si = si + 1
    }
    if best_n < 0 { break }
    let ukey = to_string(best_n)
    used[ukey] = 1
    println("| " + to_string(rank) + " | " + to_string(best_n) + " | " + to_string(best_l) + " |")
    rank = rank + 1
}

// --- 5. Summary statistics ---
if valid_count > 0 {
    let mean_len = to_float(length_sum) / to_float(valid_count)
    println("")
    println("### Summary statistics (chain lengths)")
    println("| Statistic | Value |")
    println("|-----------|-------|")
    println("| Mean      | " + fmt4(mean_len) + " |")
    println("| Max       | " + to_string(max_len) + " |")
    println("| Total chains | " + to_string(valid_count) + " |")
}

// ═══════════════════════════════════════════════════════════════
// H-TREE-3: PROBABILITY BRANCH
// ═══════════════════════════════════════════════════════════════
println("")
println("======================================================================")
println("H-TREE-3: PROBABILITY BRANCH")
println("Distribution of R(n) = sigma(n)*phi(n) / (n*tau(n))")
println("======================================================================")

// --- 1. Compute R(n) for n=2..N_PROB ---
println("")
println("## 1. R(n) for n=2.." + to_string(N_PROB))

// R(n)/n statistics
let mut ratio_sum = 0.0
let mut ratio_min = 999999.0
let mut ratio_max = 0.0
let mut ratio_min_n = 2
let mut ratio_max_n = 2
let mut r_values_sum = 0.0

let mut ri = 2
while ri <= N_PROB {
    let rv = R_float(ri)
    let ratio = rv / to_float(ri)
    ratio_sum = ratio_sum + ratio
    r_values_sum = r_values_sum + rv
    if ratio < ratio_min {
        ratio_min = ratio
        ratio_min_n = ri
    }
    if ratio > ratio_max {
        ratio_max = ratio
        ratio_max_n = ri
    }
    ri = ri + 1
}

let total_prob = N_PROB - 1
let mean_ratio = ratio_sum / to_float(total_prob)

// Variance pass
let mut var_sum = 0.0
let mut vi = 2
while vi <= N_PROB {
    let rv = R_float(vi)
    let ratio = rv / to_float(vi)
    let diff = ratio - mean_ratio
    var_sum = var_sum + diff * diff
    vi = vi + 1
}
let std_ratio = sqrt(var_sum / to_float(total_prob))

println("")
println("## 2. R(n)/n statistics (n=2.." + to_string(N_PROB) + ")")
println("| Statistic | Value |")
println("|-----------|-------|")
println("| Mean(R(n)/n) | " + fmt6(mean_ratio) + " |")
println("| Std(R(n)/n) | " + fmt6(std_ratio) + " |")
println("| Min(R(n)/n) | " + fmt6(ratio_min) + " (n=" + to_string(ratio_min_n) + ") |")
println("| Max(R(n)/n) | " + fmt6(ratio_max) + " (n=" + to_string(ratio_max_n) + ") |")

// --- 4. Scaling: E[R(n)] in windows [N, 2N] ---
println("")
println("## 4. Scaling of E[R(n)] in windows [N, 2N]")
println("| N | E[R(n)] in [N,2N] | E[R(n)]/N | Samples |")
println("|---|--------------------|-----------|---------|")

let win_ns = [100, 500, 1000]
let mut wi = 0
while wi < len(win_ns) {
    let nw = win_ns[wi]
    let hi = min_i(2 * nw, N_PROB)
    if nw < N_PROB {
        let mut wsum = 0.0
        let mut wcount = 0
        let mut wn = nw
        while wn <= hi {
            wsum = wsum + R_float(wn)
            wcount = wcount + 1
            wn = wn + 1
        }
        let wmean = wsum / to_float(wcount)
        println("| " + to_string(nw) + " | " + fmt4(wmean) + " | " + fmt6(wmean / to_float(nw)) + " | " + to_string(wcount) + " |")
    }
    wi = wi + 1
}

// --- 5. Fraction thresholds ---
println("")
println("## 5. Fraction of n with R(n) > n/2, > n/3, < n/10")
let mut gt_half = 0
let mut gt_third = 0
let mut lt_tenth = 0
let mut ti = 2
while ti <= N_PROB {
    let rv = R_float(ti)
    let nf = to_float(ti)
    if rv > nf / 2.0 { gt_half = gt_half + 1 }
    if rv > nf / 3.0 { gt_third = gt_third + 1 }
    if rv < nf / 10.0 { lt_tenth = lt_tenth + 1 }
    ti = ti + 1
}

println("| Condition | Count | Fraction |")
println("|-----------|-------|----------|")
let fh = to_float(gt_half) / to_float(total_prob)
let ft = to_float(gt_third) / to_float(total_prob)
let fl = to_float(lt_tenth) / to_float(total_prob)
println("| R(n) > n/2 | " + to_string(gt_half) + " | " + fmt6(fh) + " |")
println("| R(n) > n/3 | " + to_string(gt_third) + " | " + fmt6(ft) + " |")
println("| R(n) < n/10 | " + to_string(lt_tenth) + " | " + fmt6(fl) + " |")

// --- 6. R(n)/n concentration as n grows ---
println("")
println("## 6. R(n)/n concentration as n grows")
println("  (Mean R(n)/n in windows of size 500)")
println("| Window | Mean(R/n) | Std(R/n) |")
println("|--------|-----------|----------|")

let wsize = 500
let mut wstart = 2
while wstart + wsize - 1 <= N_PROB {
    let wend = wstart + wsize - 1
    let mut wmean = 0.0
    let mut wj = wstart
    while wj <= wend {
        wmean = wmean + R_float(wj) / to_float(wj)
        wj = wj + 1
    }
    wmean = wmean / to_float(wsize)
    // Std pass
    let mut wvar = 0.0
    let mut wk = wstart
    while wk <= wend {
        let d = R_float(wk) / to_float(wk) - wmean
        wvar = wvar + d * d
        wk = wk + 1
    }
    let wstd = sqrt(wvar / to_float(wsize))
    println("| [" + to_string(wstart) + "," + to_string(wend) + "] | " + fmt6(wmean) + " | " + fmt6(wstd) + " |")
    wstart = wstart + wsize
}

// --- 7. Integer R(n) statistics ---
println("")
println("## 7. Integer R(n) (exact divisibility)")
let mut int_count = 0
let mut int_vals = #{}
let mut ii = 2
while ii <= N_PROB {
    if R_is_integer(ii) {
        int_count = int_count + 1
        let rv = R_floor(ii)
        let key = to_string(rv)
        if has_key(int_vals, key) {
            int_vals[key] = int_vals[key] + 1
        } else {
            int_vals[key] = 1
        }
    }
    ii = ii + 1
}
let int_frac = to_float(int_count) / to_float(total_prob)
println("  Count of n with integer R(n): " + to_string(int_count) + " / " + to_string(total_prob) + " = " + fmt6(int_frac))

println("")
println("  Distribution of integer R(n) values:")
println("  | R(n) | Count |")
println("  |------|-------|")
let int_keys = keys(int_vals)
let mut ik = 0
while ik < len(int_keys) && ik < 30 {
    let k = int_keys[ik]
    println("  | " + k + " | " + to_string(int_vals[k]) + " |")
    ik = ik + 1
}

println("")
println("======================================================================")
println("VERIFICATION COMPLETE")
println("======================================================================")
