// Ported from tecs-l/verify/verify_round2_bio.py — 2026-04-10
// Round 2 Biology/Neuroscience: 20 hypotheses claiming integer counts
// match n=6 arithmetic (sigma=12, tau=4, phi=2, sopfr=5, n=6, sigma*phi=24).
// Track A port: verify the INTEGER arithmetic identities the original
// docstrings assert. Each PASS = the arithmetic claim holds. The biology
// citation itself (e.g. "6 olfactory receptor families") is recorded as
// a literature claim; we only verify the math binding the claim to n=6.

let n = 6
let s6 = sigma(6)                  // 12
let t6 = tau(6)                    // 4
let p6 = phi(6)                    // 2
let sp6 = sopfr(6)                 // 5
let sphi = s6 * p6                 // 24
let n_over_phi = n / p6            // 3
let two_pow_3 = 8                  // 2^(n/phi)
let two_pow_sopfr = 32             // 2^5

println("============================================================")
println("ROUND2-BIO: 20 n=6 biological arithmetic bindings")
println("============================================================")
println("sigma(6)="+to_string(s6)+" tau(6)="+to_string(t6)+" phi(6)="+to_string(p6)+" sopfr(6)="+to_string(sp6))
println("sigma*phi="+to_string(sphi)+" n/phi="+to_string(n_over_phi)+" 2^3="+to_string(two_pow_3)+" 2^5="+to_string(two_pow_sopfr))

// Each claim = (id, title, arithmetic holds?)
// match_ok comes from original literature assertion; we re-verify the n=6 side.
let ids = [
    "R2-BIO-01","R2-BIO-02","R2-BIO-03","R2-BIO-04","R2-BIO-05",
    "R2-BIO-06","R2-BIO-07","R2-BIO-08","R2-BIO-09","R2-BIO-10",
    "R2-BIO-11","R2-BIO-12","R2-BIO-13","R2-BIO-14","R2-BIO-15",
    "R2-BIO-16","R2-BIO-17","R2-BIO-18","R2-BIO-19","R2-BIO-20"
]

let checks = [
    // 01 Major white matter tracts ~12 = sigma(6)
    s6 == 12,
    // 02 Classical NTs = 9 (no match) -> literature negative, recorded FAIL
    false,
    // 03 Grid cells C6 symmetry = n
    n == 6,
    // 04 Core language regions = 6 = n
    n == 6,
    // 05 Retinal cell types = 6 = n
    n == 6,
    // 06 Bark bands = 24 = sigma*phi = n*tau
    sphi == 24 && n * t6 == 24,
    // 07 Olfactory families = 6 = n
    n == 6,
    // 08 Spinal: T=12=sigma, L=S=5=sopfr, C=8=2^3, regions=4=tau
    s6 == 12 && sp6 == 5 && two_pow_3 == 8 && t6 == 4,
    // 09 Cranial nerves = 12 = sigma(6)
    s6 == 12,
    // 10 Heart chambers = valves = 4 = tau(6)
    t6 == 4,
    // 11 Ig classes=5=sopfr, IgG=4=tau, IgA=2=phi
    sp6 == 5 && t6 == 4 && p6 == 2,
    // 12 HP axes = 5 = sopfr; endocrine glands = 8 = 2^3
    sp6 == 5 && two_pow_3 == 8,
    // 13 ABO=4=tau, alleles=3=n/phi, ABO*Rh=8=2^3
    t6 == 4 && n_over_phi == 3 && two_pow_3 == 8,
    // 14 Acrocentric chromosomes = 5 = sopfr
    sp6 == 5,
    // 15 Turing morphogens=2=phi; hex patterns C6=n; 3 pattern types=n/phi
    p6 == 2 && n == 6 && n_over_phi == 3,
    // 16 Germ layers=3=n/phi; diploblast=2=phi; tissues=4=tau
    n_over_phi == 3 && p6 == 2 && t6 == 4,
    // 17 Classical senses=5=sopfr
    sp6 == 5,
    // 18 Stem potency=5=sopfr; Yamanaka=4=tau
    sp6 == 5 && t6 == 4,
    // 19 Caspases total=12=sigma, init=4=tau, exec=3=n/phi, infl=5=sopfr, paths=2=phi
    s6 == 12 && t6 == 4 && n_over_phi == 3 && sp6 == 5 && p6 == 2,
    // 20 Gut dominant phyla = 6 = n; core = 4 = tau
    n == 6 && t6 == 4
]

let titles = [
    "WM tracts=12=sigma",
    "Classical NTs=9 (no n=6 match)",
    "Grid cells C6=n",
    "Language regions=6=n",
    "Retinal cell types=6=n",
    "Bark bands=24=sigma*phi",
    "Olfactory families=6=n",
    "Spinal T=sigma L=S=sopfr C=8",
    "Cranial nerves=12=sigma",
    "Heart chambers/valves=4=tau",
    "Ig classes=5=sopfr",
    "HP axes=5=sopfr glands=8",
    "ABO=tau alleles=n/phi",
    "Acrocentric=5=sopfr",
    "Turing morphogens=phi hex=n",
    "Germ layers=n/phi",
    "5 senses=sopfr",
    "Stem potency=sopfr Yamanaka=tau",
    "Caspases 5-fold n=6 match",
    "Gut phyla=6=n core=tau"
]

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + " " + st + " " + titles[i])
    i = i + 1
}

println("------------------------------------------------------------")
println("Total: "+to_string(pass_c+fail_c)+" PASS: "+to_string(pass_c)+" FAIL: "+to_string(fail_c))
// Original had 19 PASS / 1 honest literature non-match (R2-BIO-02 = 9 != any n=6 fn).
if pass_c == 19 && fail_c == 1 { println("OVERALL: PASS (matches original 19/20)") } else { println("OVERALL: MISMATCH") }
