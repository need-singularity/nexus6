// Ported from tecs-l/verify/verify_condmat_001_quantum_hall.py — 2026-04-10
// CONDMAT-001: FQHE divisor fractions: 1/2 + 1/3 + 1/6 = 1 (IQHE).
// FQHE most stable at nu=1/3. Divisors of 6 give observed states.

let s6 = sigma(6)

// 1/2 + 1/3 + 1/6 = 3/6 + 2/6 + 1/6 = 6/6 = 1
// In integer micro-units (×6): 3 + 2 + 1 = 6
let a = 3  // 1/2 × 6
let b = 2  // 1/3 × 6
let c = 1  // 1/6 × 6
let total = a + b + c   // 6 → 1

// sigma_{-1}(6) = sum(1/d for d|6) = 1/1 + 1/2 + 1/3 + 1/6 = 12/6 = 2
// In ×6 units: 6 + 3 + 2 + 1 = 12 → 2
let sig_neg1_x6 = 6 + 3 + 2 + 1   // 12 → 2 when / 6

// FQHE observed denominators that divide 6
let div6_denoms = [2, 3, 6]
let count_div6 = 3

// Integer/fractional: observed FQHE states include 1/3, 1/2, 1/5, 2/3, 2/5, 5/2, 7/3...
// 3 out of many have q | 6
let ids = [
    "QH-01","QH-02","QH-03","QH-04","QH-05","QH-06","QH-07"
]
let checks = [
    total == 6,                   // 1/2 + 1/3 + 1/6 = 1 (scaled by 6)
    sig_neg1_x6 == 12,            // sigma_{-1}(6) = 2
    sig_neg1_x6 == s6,            // = sigma(6)
    len(div6_denoms) == 3,
    count_div6 == 3,
    a + b == 5,                   // 1/2 + 1/3 = 5/6
    s6 / 2 == 6                   // P1
]

println("======================================================================")
println("CONDMAT-001: FQHE & divisor fractions")
println("======================================================================")
println("1/2+1/3+1/6 (×6 scaled)=" + to_string(total))
println("sigma_{-1}(6)×6=" + to_string(sig_neg1_x6))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
