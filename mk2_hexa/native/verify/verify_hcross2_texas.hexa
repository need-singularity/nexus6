// H-CROSS-2: Texas Sharpshooter test for n=6 → 28 discoveries
//
// AI-native: @pure, hexa σ/φ/τ 빌트인

// @pure — σ_k(n) = Σ_{d|n} d^k
fn sigma_k(n: int, k: int) -> int {
    let mut s = 0
    let mut i = 1
    while i * i <= n {
        if n % i == 0 {
            let mut pw1 = 1
            let mut e = 0
            while e < k {
                pw1 = pw1 * i
                e = e + 1
            }
            s = s + pw1
            let other = n / i
            if other != i {
                let mut pw2 = 1
                let mut e2 = 0
                while e2 < k {
                    pw2 = pw2 * other
                    e2 = e2 + 1
                }
                s = s + pw2
            }
        }
        i = i + 1
    }
    s
}

// @pure — C(n,2)
fn binom2(n: int) -> int { n * (n - 1) / 2 }

// @pure — factorial
fn fact(k: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= k {
        r = r * i
        i = i + 1
    }
    r
}

let n_val = 6
let s6 = sigma(6)   // 12
let p6 = phi(6)     // 2
let t6 = tau(6)     // 4
let P1 = 6
let P2 = 28
let P3 = 496

println("══════════════════════════════════════════════════════════════")
println("Texas Sharpshooter: H-CROSS-2 Key New Discoveries  (hexa port)")
println("══════════════════════════════════════════════════════════════")

// ─── Discovery A: Chang srg(28, 12, 6, 4) feasibility ───
println("")
println("## A. Chang graphs srg(28, σ(6), n, τ(6)) = srg(28, 12, 6, 4)")
let v = 28
let k = 12
let lam = 6
let mu = 4
let lhs = k * (k - lam - 1)
let rhs = (v - k - 1) * mu
println("   Feasibility: k(k−λ−1) = " + to_string(lhs))
println("                (v−k−1)·μ = " + to_string(rhs))
println("   " + (if lhs == rhs { "✓ FEASIBLE" } else { "✗ NOT FEASIBLE" }))
assert lhs == rhs

let disc = (lam - mu) * (lam - mu) + 4 * (k - mu)
println("   Discriminant = (λ−μ)² + 4(k−μ) = " + to_string(disc))
// For disc = 36 (4+32), sqrt = 6. But let me compute: (6-4)² + 4*(12-4) = 4 + 32 = 36.
assert disc == 36
println("   √disc = 6")
println("   Eigenvalues r = (λ−μ + √disc)/2 = (2+6)/2 = 4")
println("                s = (λ−μ − √disc)/2 = (2−6)/2 = −2")

// ─── Discovery B: Plücker bitangents ───
println("")
println("## B. Plücker bitangent formula with d = τ(6) = 4")
let d = t6
let bt_num = d * (d - 2) * (d * d - 9)
let bt = bt_num / 2
println("   bitangents(d) = d(d−2)(d²−9)/2")
println("   d=4: 4·2·(16−9)/2 = 4·2·7/2 = " + to_string(bt))
println("   = 28 = P2  " + (if bt == 28 { "✓" } else { "✗" }))
assert bt == 28
println("   Simplified: τ(6)·(τ(6)−2)·(n+1) = 4·2·7 = 56, /2 = 28")

// Texas scan: d=3..11
println("")
println("   Texas scan for random degrees d=3..11:")
let mut dd = 3
while dd <= 11 {
    let bn = dd * (dd - 2) * (dd * dd - 9)
    if bn > 0 && bn % 2 == 0 {
        let b_val = bn / 2
        let mark = if b_val == 28 { " ← 28=P2 ✓" } else { "" }
        println("     d=" + to_string(dd) + ": " + to_string(b_val) + mark)
    } else {
        println("     d=" + to_string(dd) + ": " + to_string(bn) + "/2 (negative/odd)")
    }
    dd = dd + 1
}

// ─── Discovery C: τ(n)·(n+1) = P_next? ───
println("")
println("## C. τ(n)·(n+1) = next perfect?")
println("   n=6:  τ(6)·7 = " + to_string(t6 * 7) + " = P2 " + (if t6 * 7 == 28 { "✓" } else { "✗" }))
assert t6 * 7 == 28
let tau28 = tau(28)
println("   n=28: τ(28)·29 = " + to_string(tau28 * 29) + "  vs P3=496  " + (if tau28 * 29 == 496 { "✓" } else { "✗ (pattern breaks)" }))

// Euler perfect generalization
println("")
println("   Euler perfects P_p = 2^(p-1)·(2^p−1):")
let ps = [2, 3, 5, 7]
let mut pi = 0
while pi < len(ps) {
    let p = ps[pi]
    let mut pw_p = 1
    let mut e = 0
    while e < p - 1 {
        pw_p = pw_p * 2
        e = e + 1
    }
    let mut pw_2p = 1
    let mut e2 = 0
    while e2 < p {
        pw_2p = pw_2p * 2
        e2 = e2 + 1
    }
    let Pk = pw_p * (pw_2p - 1)
    let tk = tau(Pk)
    println("     p=" + to_string(p) + ": P=" + to_string(Pk) + ", τ(P)=" + to_string(tk) + ", τ·(P+1)=" + to_string(tk * (Pk + 1)))
    pi = pi + 1
}

// ─── Discovery D: σ_k(6) mod 28 period ───
println("")
println("## D. σ_k(6) mod 28 pattern (period = n = 6?)")
let mut zeros = []
let mut kk = 1
while kk <= 24 {
    let v_k = sigma_k(6, kk)
    let modv = v_k % 28
    if modv == 0 {
        zeros = zeros + [kk]
        println("   σ_" + to_string(kk) + "(6) = " + to_string(v_k) + " ≡ 0 (mod 28)  ✓")
    }
    kk = kk + 1
}
println("   Zero positions: " + to_string(zeros))
if len(zeros) >= 2 {
    let diff1 = zeros[1] - zeros[0]
    println("   First difference: " + to_string(diff1))
    let mut all_same = true
    let mut di = 1
    while di < len(zeros) - 1 {
        if zeros[di + 1] - zeros[di] != diff1 { all_same = false }
        di = di + 1
    }
    if all_same && diff1 == 6 {
        println("   → Period = 6 = n  ★  σ_k(6) ≡ 0 (mod 28) ⟺ k ≡ 3 (mod 6)")
    }
}

// ─── Discovery E: n² − (σ−τ) = 28 ───
println("")
println("## E. n² − (σ−τ) = 28")
let val_e = n_val * n_val - (s6 - t6)
println("   6² − (12−4) = " + to_string(n_val * n_val) + " − " + to_string(s6 - t6) + " = " + to_string(val_e))
assert val_e == 28
println("   ✓ = 28 = P2")

// ─── Discovery F: σ·(σ+2) = P1·P2 ───
println("")
println("## F. σ·(σ+2) = P1·P2  (Mersenne twin structure)")
let val_f = s6 * (s6 + 2)
println("   σ(6)·(σ(6)+2) = 12·14 = " + to_string(val_f))
println("   P1·P2 = 6·28 = " + to_string(6 * 28))
assert val_f == 6 * 28
println("   ✓ MATCH")
println("   Note: σ+2 = 14 = 7·2 = (n+1)·φ(6)")
let val_check = (n_val + 1) * p6
println("   (n+1)·φ(6) = 7·2 = " + to_string(val_check) + "  " + (if val_check == s6 + 2 { "✓" } else { "✗" }))
assert val_check == s6 + 2

// ─── Additional: Triangular numbers ───
println("")
println("## Additional: T(n+1) = 28")
let T7 = 7 * 8 / 2
println("   T(7) = 7·8/2 = " + to_string(T7) + " = 28  " + (if T7 == 28 { "✓" } else { "✗" }))
assert T7 == 28

