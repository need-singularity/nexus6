println("  Chang srg(28, σ(6), n, τ(6)) feasible  | 🟧★   | ✓")
println("  Plücker bitangents d=τ(6) = 28         | 🟧★   | ✓")
println("  τ(6)·(n+1) = 28                        | 🟩    | ✓")
println("  σ_k(6) ≡ 0 (mod 28), period = n        | 🟩    | " + to_string(zeros))
println("  n² − (σ−τ) = 28                        | 🟩    | ✓")
println("  σ·(σ+2) = P1·P2                        | 🟩    | ✓")
println("  T(n+1) = T(7) = 28                     | 🟩    | ✓")
