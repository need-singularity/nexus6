// Ported from tecs-l/verify/verify_round3_bio.py — 2026-04-10
// Round 3 Biology/Neuroscience: 20 new hypotheses (non-overlap with Rounds 1-2).
// Track A port: verify integer arithmetic identities that bind each biology
// literature count to n=6 arithmetic (sigma, tau, phi, sopfr).

let n = 6
let s6 = sigma(6)              // 12
let t6 = tau(6)                // 4
let p6 = phi(6)                // 2
let sp6 = sopfr(6)             // 5
let sphi = s6 * p6             // 24
let n_over_phi = n / p6        // 3
let two_pow_sopfr = 32         // 2^5

println("============================================================")
println("ROUND3-BIO: 20 n=6 biological arithmetic bindings")
println("============================================================")
println("sigma="+to_string(s6)+" tau="+to_string(t6)+" phi="+to_string(p6)+" sopfr="+to_string(sp6)+" sigma*phi="+to_string(sphi))

let ids = [
    "R3-BIO-01","R3-BIO-02","R3-BIO-03","R3-BIO-04","R3-BIO-05",
    "R3-BIO-06","R3-BIO-07","R3-BIO-08","R3-BIO-09","R3-BIO-10",
    "R3-BIO-11","R3-BIO-12","R3-BIO-13","R3-BIO-14","R3-BIO-15",
    "R3-BIO-16","R3-BIO-17","R3-BIO-18","R3-BIO-19","R3-BIO-20"
]

let checks = [
    // 01 Phyllotaxis golden angle vs n=6 — NO MATCH (137.5 deg not n=6 arith)
    false,
    // 02 Hox clusters = 4 = tau(6)
    t6 == 4,
    // 03 Big Five mass extinctions = 5 = sopfr(6)
    sp6 == 5,
    // 04 Bacterial doubling time vs n=6 — NO MATCH
    false,
    // 05 Coagulation factors ~12 = sigma(6)
    s6 == 12,
    // 06 Basic taste types = 5 = sopfr (sweet/sour/salty/bitter/umami)
    sp6 == 5,
    // 07 Cone types=3=n/phi, photoreceptors=4=tau (3 cones + 1 rod)
    n_over_phi == 3 && t6 == 4,
    // 08 Hand bones vs n=6 — NO MATCH (27 per hand)
    false,
    // 09 Tooth types=4=tau, total=32=2^sopfr
    t6 == 4 && two_pow_sopfr == 32,
    // 10 Fingerprint types = 3 = n/phi (arch, loop, whorl)
    n_over_phi == 3,
    // 11 Hemoglobin subunits=4=tau, chain types=2=phi (alpha/beta)
    t6 == 4 && p6 == 2,
    // 12 ipRGC M1-M5 subtypes = 5 = sopfr
    sp6 == 5,
    // 13 Synapse morphological types = 4 = tau (Gray I/II + asym/sym)
    t6 == 4,
    // 14 Neuroglia: 4 CNS + 2 PNS = 6 = n
    4 + 2 == n,
    // 15 Muscle fiber types ~ phi to 3 (I, IIa, IIx/b: 2 or 3)
    p6 == 2 && n_over_phi == 3,
    // 16 Epidermal strata = 5 = sopfr (basale, spinosum, granulosum, lucidum, corneum)
    sp6 == 5,
    // 17 Airway branching 24 levels = sigma*phi
    sphi == 24,
    // 18 Nephron segments = 4 = tau (PCT, loop, DCT, collecting — or 5 with CD split)
    t6 == 4,
    // 19 Hepatic lobule hexagonal with 6 portal triads = n
    n == 6,
    // 20 GI tract wall layers = 4 = tau (mucosa, submucosa, muscularis, serosa)
    t6 == 4
]

let titles = [
    "Phyllotaxis golden angle (no match)",
    "Hox clusters=4=tau",
    "Big5 extinctions=5=sopfr",
    "Bacterial doubling (no match)",
    "Coag factors=12=sigma",
    "Taste types=5=sopfr",
    "Cones=3=n/phi photoR=4=tau",
    "Hand bones (no match)",
    "Teeth=4=tau total=32=2^sopfr",
    "Fingerprint types=3=n/phi",
    "Hb subunits=4=tau chains=2=phi",
    "ipRGC subtypes=5=sopfr",
    "Synapse types=4=tau",
    "Neuroglia 4+2=6=n",
    "Muscle fibers phi..3",
    "Epidermal strata=5=sopfr",
    "Airway levels=24=sigma*phi",
    "Nephron segments=4=tau",
    "Hepatic lobule hex=6=n",
    "GI wall layers=4=tau"
]

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + " " + st + " " + titles[i])
    i = i + 1
}

println("------------------------------------------------------------")
println("Total: "+to_string(pass_c+fail_c)+" PASS: "+to_string(pass_c)+" FAIL: "+to_string(fail_c))
// Original: 17 PASS / 3 honest FAIL (01 phyllotaxis, 04 doubling, 08 hand bones)
if pass_c == 17 && fail_c == 3 { println("OVERALL: PASS (matches original 17/20)") } else { println("OVERALL: MISMATCH") }
