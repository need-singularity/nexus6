// Ported from tecs-l/verify/verify_p4_8128.py — 2026-04-10
// P4 = 8128 = 2^6 * 127 = 4th perfect number.
// Checks: dim(SO(128)) = 8128, T(127) = 8128, tau chain = 2*Mersenne exps.

let s6 = sigma(6)

// P4 decomposition
let p4 = 8128
let two_six = 64
let mersenne7 = 127
let p4_decomp = two_six * mersenne7

// dim(SO(128)) = 128*127/2
let dim_so128 = 128 * 127 / 2
// T(127) = 127*128/2
let t127 = 127 * 128 / 2

// tau chain check: tau(P_k) = 2*p_k where P_k = 2^(p_k-1)*(2^p_k - 1)
// Perfect numbers: P1=6 (p=2), P2=28 (p=3), P3=496 (p=5), P4=8128 (p=7), P5=33550336 (p=13)
// tau(6)=4=2*2, tau(28)=6=2*3, tau(496)=10=2*5, tau(8128)=14=2*7
let tau_6 = tau(6)
let tau_28 = tau(28)
let tau_496 = tau(496)

// Higher-order checks
let dim_so32 = 32 * 31 / 2    // 496 = P3
let sigma_32 = 63              // sigma(32) = 1+2+4+8+16+32 = 63

let ids = [
    "P4-01","P4-02","P4-03","P4-04","P4-05",
    "P4-06","P4-07","P4-08","P4-09"
]
let checks = [
    p4 == 8128,
    p4_decomp == 8128,
    dim_so128 == 8128,
    t127 == 8128,
    tau_6 == 2 * 2,
    tau_28 == 2 * 3,
    tau_496 == 2 * 5,
    dim_so32 == 496,
    s6 == 12
]

println("======================================================================")
println("P4 = 8128 verification (4th perfect number)")
println("======================================================================")
println("P4 = 2^6 * 127 = " + to_string(p4_decomp))
println("dim(SO(128)) = " + to_string(dim_so128))
println("T(127) = " + to_string(t127))
println("tau(6)=" + to_string(tau_6) + " tau(28)=" + to_string(tau_28) + " tau(496)=" + to_string(tau_496))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
