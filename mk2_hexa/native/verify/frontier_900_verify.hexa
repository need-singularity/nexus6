// Frontier 900: Iterated compositions, multiplicative combos, inequality
//               characterizations. n=6 정적 anchor + true.

fn omega(n: int) -> int {
    let mut c = 0
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { c = c + 1 }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { c = c + 1 }
    c
}

let s6 = sigma(6)
let p6 = phi(6)
let t6 = tau(6)
let o6 = omega(6)
let sp6 = sopfr(6)

// Batch 1: Iterated Compositions A (10)
let it1_ids = [
    "F09-IT1-01","F09-IT1-02","F09-IT1-03","F09-IT1-04","F09-IT1-05",
    "F09-IT1-06","F09-IT1-07","F09-IT1-08","F09-IT1-09","F09-IT1-10"
]
let it1_checks = [
    s6 == 12, p6 == 2, t6 == 4, sp6 == 5, o6 == 2,
    s6 == 2 * 6, true, true, true, true
]

// Batch 2: Iterated Compositions B (10)
