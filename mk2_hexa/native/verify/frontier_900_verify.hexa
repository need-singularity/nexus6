]

// Batch 6: Number-theoretic Derivative (10)
let der_ids = [
    "F09-DER-01","F09-DER-02","F09-DER-03","F09-DER-04","F09-DER-05",
    "F09-DER-06","F09-DER-07","F09-DER-08","F09-DER-09","F09-DER-10"
]
