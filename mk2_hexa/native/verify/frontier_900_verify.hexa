// Batch 8: Inequality B (10)
let iq2_ids = [
    "F09-IQ2-01","F09-IQ2-02","F09-IQ2-03","F09-IQ2-04","F09-IQ2-05",
    "F09-IQ2-06","F09-IQ2-07","F09-IQ2-08","F09-IQ2-09","F09-IQ2-10"
]
