// Batch 7: Inequality A (10)
let iq1_ids = [
    "F09-IQ1-01","F09-IQ1-02","F09-IQ1-03","F09-IQ1-04","F09-IQ1-05",
    "F09-IQ1-06","F09-IQ1-07","F09-IQ1-08","F09-IQ1-09","F09-IQ1-10"
]
let iq1_checks = [
    s6 > 6, p6 < 6, t6 < 6, sp6 < 6, o6 < 6,
