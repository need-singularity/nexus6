// Ported from tecs-l/verify/verify_dna_hypotheses.py — 2026-04-10
// DNA/RNA hypotheses H-DNA-001..030 — integer claims only.
// Float groove widths / bp/turn skipped.

let t6 = tau(6)       // 4
let s6 = sigma(6)     // 12
let p6 = phi(6)       // 2
let sp6 = sopfr(6)    // 5

// H-DNA-001 (integer form): sigma(6)-phi(6) = 10 bp/turn (rounded)
let sigma_minus_phi = s6 - p6     // 10
let bp_per_turn_int = 10

// H-DNA-002: Minor groove 12 A = sigma(6)
let minor_groove_angstrom = 12

// H-DNA-004: 4 DNA bases = tau(6), 2 purines + 2 pyrimidines = 2*phi(6)
let n_bases = 4
let n_purines = 2
let n_pyrimidines = 2

// H-DNA-005: Chargaff's rules → 2 independent ratios = phi(6)
let chargaff_indep = 2

// H-DNA-007: 64 codons = 4^3 = 2^6
let n_codons = 64
let four_cubed = 4 * 4 * 4
let two_to_six = 2 * 2 * 2 * 2 * 2 * 2

// H-DNA-008: 3 stop codons, 3 | 6
let n_stop = 3

// H-DNA-009: 61 sense codons = 64 - 3
let n_sense = 61

// H-DNA-010: 20 standard amino acids = sigma(6) + 2*tau(6)
let std_aa = 20
let aa_formula = s6 + 2 * t6      // 12 + 8 = 20

// H-DNA-011: Codon length = 3 = divisor of 6
let codon_len = 3

// H-DNA-012: Reading frames = 6 = n (3 forward + 3 reverse)
let reading_frames = 6

// H-DNA-015: Codon families = 16 = tau(6)^2 = 4^2
let codon_families = 16
let tau_sq = t6 * t6

// H-DNA-017: Watson-Crick H-bonds: GC=3, AT=2, sum=5=sopfr(6)
let gc_bonds = 3
let at_bonds = 2
let hbond_sum = gc_bonds + at_bonds    // 5

let ids = [
    "DN-01","DN-02","DN-03","DN-04","DN-05","DN-06","DN-07","DN-08",
    "DN-09","DN-10","DN-11","DN-12","DN-13","DN-14","DN-15","DN-16",
    "DN-17","DN-18"
]
let checks = [
    sigma_minus_phi == bp_per_turn_int,
    minor_groove_angstrom == s6,
    n_bases == t6,
    n_purines == p6,
    n_pyrimidines == p6,
    chargaff_indep == p6,
    n_codons == four_cubed,
    n_codons == two_to_six,
    n_stop == 3,
    n_sense == n_codons - n_stop,
    std_aa == aa_formula,
    codon_len == 3,
    reading_frames == 6,
    codon_families == tau_sq,
    gc_bonds == 3,
    at_bonds == p6,
    hbond_sum == sp6,
    std_aa == 20
]

println("======================================================================")
println("H-DNA: DNA/RNA HYPOTHESES (integer claims)")
println("======================================================================")
println("bases=" + to_string(n_bases) + "=tau(6), codons=" + to_string(n_codons) + "=2^6")
println("aa=20=sigma+2*tau, frames=6=n, H-bonds 3+2=5=sopfr(6)")

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
