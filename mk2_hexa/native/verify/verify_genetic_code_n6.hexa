// Ported from tecs-l/verify/verify_genetic_code_n6.py — 2026-04-10
// Genetic Code as n=6 Arithmetic:
// Every key number in the genetic code maps to a closed-form expression
// in {n=6, sigma=12, tau=4, phi=2, sopfr=5, omega=2}.

let n = 6
let s6 = sigma(n)       // 12
let t6 = tau(n)         // 4
let p6 = phi(n)         // 2
let sp6 = sopfr(n)      // 5
// omega(6)=2, Omega(6)=2, n!=720
let omega_n = 2
let fact_n = 720        // 6!

// 1A Bases
let bases = 4                    // τ(6)=4  (A,T,G,C)
let purines = 2                  // φ(6)=2
let pyrimidines = 2              // φ(6)=2
let gc_hbonds = 3                // n/φ=3
let at_hbonds = 2                // φ(6)=2
let strands = 2                  // φ(6)=2

// 1B Codon structure
let codon_len = 3                // n/φ=3
let total_codons = 64            // τ^(n/φ) = 4^3 = 2^n
let stop_codons = 3              // n/φ=3
let sense_codons = 61            // 2^n - n/φ = 64-3

// 1C Amino acids
let std_aa = 20                  // σ+2τ = 12+8 = sopfr·τ = 5·4
let aa_21 = 21                   // σ+τ+sopfr = 12+4+5
let aa_22 = 22                   // n·τ-φ = 24-2

// 1D Reading frames
let reading_frames = 6           // n
let codon_families = 16          // τ² = φ^τ = 2^4
let codons_per_family = 4        // τ

// 1E DNA dimensions (integer)
let bp_per_turn = 10             // sopfr·φ = 5·2
let diameter_angstrom = 20       // σ+2τ

// Checks
let ids = [
    "GC-01","GC-02","GC-03","GC-04","GC-05","GC-06","GC-07","GC-08",
    "GC-09","GC-10","GC-11","GC-12","GC-13","GC-14","GC-15","GC-16",
    "GC-17","GC-18","GC-19","GC-20"
]
let checks = [
    bases == t6,
    purines == p6,
    pyrimidines == p6,
    gc_hbonds == n / p6,
    at_hbonds == p6,
    strands == p6,
    codon_len == n / p6,
    total_codons == t6 * t6 * t6,        // 4^3 = 64
    total_codons == 1 * 64,               // 2^n = 64
    stop_codons == n / p6,
    sense_codons == total_codons - stop_codons,
    std_aa == s6 + 2 * t6,
    std_aa == sp6 * t6,
    aa_21 == s6 + t6 + sp6,
    aa_22 == n * t6 - p6,
    reading_frames == n,
    codon_families == t6 * t6,
    codons_per_family == t6,
    bp_per_turn == sp6 * p6,
    diameter_angstrom == s6 + 2 * t6
]

println("======================================================================")
println("GENETIC CODE AS n=6 ARITHMETIC")
println("======================================================================")
println("n=6 sigma=12 tau=4 phi=2 sopfr=5 omega=2 n!=720")
println("bases=4 codons=64 aa=20 frames=6 families=16 bp/turn=10 diam=20A")

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
