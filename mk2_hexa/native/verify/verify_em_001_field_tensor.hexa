// Ported from tecs-l/verify/verify_em_001_field_tensor.py — 2026-04-10
// EM-001: F_muv antisymmetric 4x4 → C(4,2) = 6 = P1. Self-ref C(tau(6),phi(6))=6.

fn comb(nn: int, k: int) -> int {
    if k < 0 || k > nn { return 0 }
    let mut r = 1
    let mut i = 0
    while i < k {
        r = r * (nn - i) / (i + 1)
        i = i + 1
    }
    r
}

let s6 = sigma(6)
let t6 = tau(6)
let p6 = phi(6)
let sp6 = sopfr(6)

// C(4,2) = 6 independent components of F_mu_nu
let c42 = comb(4, 2)
// Self-referential: C(tau(6), phi(6)) = C(4,2) = 6
let self_ref = comb(t6, p6)
// 4x4 antisymmetric: total = 16, diagonal = 0, off-diag pairs = 12, indep = 6
let antisym_4x4 = 16 - 4
let indep = antisym_4x4 / 2
// Electric + magnetic: 3+3 = 6
let e_plus_b = 3 + 3

let ids = [
    "EM-01","EM-02","EM-03","EM-04","EM-05","EM-06"
]
let checks = [
    c42 == 6,
    self_ref == 6,
    self_ref == c42,
    indep == 6,
    e_plus_b == 6,
    c42 == sigma(6) / phi(6)      // 12/2 = 6
]

println("======================================================================")
println("EM-001: F_muv = C(4,2) = 6")
println("======================================================================")
println("C(4,2)=" + to_string(c42) + " C(tau(6),phi(6))=" + to_string(self_ref))
println("antisym indep = " + to_string(indep) + " E+B = " + to_string(e_plus_b))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
