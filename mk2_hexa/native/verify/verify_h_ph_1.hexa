// mk2_hexa/native/verify_h_ph_1.hexa
// 포팅 원본: tecs-l/math/verify_h_ph_1.py (305 LOC, core 220)
// H-PH-1: σ(6)² − 7 = 137 (fine structure constant connection)
//
// AI-native: @pure 전역, hexa sigma 빌트인, sympy 제거

// @pure — trial division primality
fn is_prime(n: int) -> bool {
    if n < 2 { return false }
    if n == 2 { return true }
    if n % 2 == 0 { return false }
    let mut i = 3
    while i * i <= n {
        if n % i == 0 { return false }
        i = i + 2
    }
    true
}

// @pure — 소인수 분해 문자열
fn factor_str(n: int) -> string {
    let mut m = n
    let mut s = ""
    let mut p = 2
    while p * p <= m {
        if m % p == 0 {
            let mut e = 0
            while m % p == 0 {
                m = m / p
                e = e + 1
            }
            if s != "" { s = s + " × " }
            if e == 1 { s = s + to_string(p) } else { s = s + to_string(p) + "^" + to_string(e) }
        }
        p = p + 1
    }
    if m > 1 {
        if s != "" { s = s + " × " }
        s = s + to_string(m)
    }
    if s == "" { s = to_string(n) }
    s
}

fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0)) / 10000.0
    to_string(r)
}

// @pure — n in base b → digit list (MSB first)
fn to_base(n: int, b: int) -> list {
    if n == 0 { return [0] }
    let mut digits = []
    let mut m = n
    while m > 0 {
        digits = [m % b] + digits
        m = m / b
    }
    digits
}

// @pure — popcount
fn popcount(n: int) -> int {
    let mut m = n
    let mut c = 0
    while m > 0 {
        if m % 2 == 1 { c = c + 1 }
        m = m / 2
    }
    c
}

// @pure — primerange [a, b)
fn primes_in(a: int, b: int) -> list {
    let mut out = []
    let mut k = a
    while k < b {
        if is_prime(k) { out = out + [k] }
        k = k + 1
    }
    out
}

let sigma_6 = sigma(6)       // 12
let sigma_sq = sigma_6 * sigma_6  // 144

println("══════════════════════════════════════════════════════════════════════")
println("H-PH-1: σ(6)² − 7 = 137 (fine structure)  (hexa port)")
println("══════════════════════════════════════════════════════════════════════")
println("")
println("  σ(6) = " + to_string(sigma_6) + ",  σ² = " + to_string(sigma_sq))

// ─── Part 1: primes near 144 ───
println("")
println("── PART 1: primes near σ² = 144 ──")
println("     k | σ²−k | prime? | factorization")
println("  -----+------+--------+---------------")
let mut primes_found = []
let mut k = 1
while k < 20 {
    let v = sigma_sq - k
    if v >= 2 {
        let ip = is_prime(v)
        if ip { primes_found = primes_found + [v] }
        let fs = if ip { to_string(v) + " (PRIME)" } else { factor_str(v) }
        let mark = if v == 137 { " ◄" } else { "" }
        println("  " + to_string(k) + "\t| " + to_string(v) + "\t| " + (if ip { "YES" } else { "no" }) + "\t| " + fs + mark)
    }
    k = k + 1
}
println("")
println("  Primes found: " + to_string(primes_found))
assert is_prime(137)
assert sigma_sq - 7 == 137

// ─── Part 2: other perfect numbers ───
println("")
println("── PART 2: σ(n)² − 7 for other perfect numbers ──")
let perfs = [6, 28, 496, 8128]
let mut pi_idx = 0
while pi_idx < len(perfs) {
    let p = perfs[pi_idx]
    let sn = 2 * p
    let sq = sn * sn
    let v = sq - 7
    let ip = is_prime(v)
    println("")
    println("  n=" + to_string(p) + ": σ=" + to_string(sn) + ", σ²=" + to_string(sq) + ", σ²−7=" + to_string(v) + "  " + (if ip { "PRIME" } else { "composite" }))
    println("    factorization: " + factor_str(v))
    pi_idx = pi_idx + 1
}
println("")
println("  → 137 pattern is UNIQUE to n=6 (not generalizable)")

// ─── Part 3: Texas Sharpshooter ───
println("")
println("── PART 3: Texas Sharpshooter ──")
let pr_100_200 = primes_in(100, 200)
println("  Primes in [100, 200]: " + to_string(len(pr_100_200)))
println("  " + to_string(pr_100_200))

// Probability bounds
let odd_ks = [1, 3, 5, 7, 9, 11]
let mut prob_none = 1.0
let mut kk = 0
while kk < len(odd_ks) {
    let v = sigma_sq - odd_ks[kk]
    let pp = 1.0 / log(to_float(v))
    prob_none = prob_none * (1.0 - pp)
    kk = kk + 1
}
let prob_any = 1.0 - prob_none
println("")
println("  P(at least one prime among σ²−k, k odd in 1..11) ≈ " + fmt4(prob_any))
println("  → Finding SOME prime near 144 is NOT surprising")

// Bonferroni 대충 추정
let n_func = 8
let n_off = 20
let n_targets = 4
let one_try = 1.0 - 1.0 / 200.0
let mut ph = 1.0
let mut e = 0
while e < n_func * n_off {
    ph = ph * one_try
    e = e + 1
}
let p_adj = (1.0 - ph) * to_float(n_targets)
let p_cap = if p_adj > 1.0 { 1.0 } else { p_adj }
println("  Bonferroni adjusted p ≈ " + fmt4(p_cap) + " → NOT significant")

// ─── Part 4: 137 in base 6 ───
println("")
println("── PART 4: 137 in base 6 ──")
let d137 = to_base(137, 6)
let mut ds = 0
let mut di = 0
while di < len(d137) {
    ds = ds + d137[di]
    di = di + 1
}
let mut digit_str = ""
let mut dj = 0
while dj < len(d137) {
    digit_str = digit_str + to_string(d137[dj])
    dj = dj + 1
}
println("  137₁₀ = " + digit_str + "₆")
println("  Digits: " + to_string(d137))
println("  Digit sum = " + to_string(ds) + "  " + (if ds == sigma_6 { "= σ(6) ★" } else { "≠ σ(6)" }))
assert ds == sigma_6

// Distribution check
let mut count12 = 0
let mut matches = []
let mut pr_i = 0
while pr_i < len(pr_100_200) {
    let pp = pr_100_200[pr_i]
    let dd = to_base(pp, 6)
    let mut ss = 0
    let mut k2 = 0
    while k2 < len(dd) {
        ss = ss + dd[k2]
        k2 = k2 + 1
    }
    if ss == 12 {
        count12 = count12 + 1
        matches = matches + [pp]
    }
    pr_i = pr_i + 1
}
println("")
println("  Primes in [100,200] with digit_sum₆ = 12: " + to_string(count12) + "/" + to_string(len(pr_100_200)))
println("  Matches: " + to_string(matches))

// ─── Part 5: Binary structure of 137 ───
println("")
println("── PART 5: Binary structure of 137 ──")
let pc = popcount(137)
let tau_6 = tau(6)
println("  137 = 128 + 8 + 1 = 2⁷ + 2³ + 2⁰")
println("  Binary: 10001001")
println("  Hamming weight = " + to_string(pc))
println("  τ(6) = " + to_string(tau_6) + "  " + (if pc == tau_6 - 1 { " (= τ(6)−1)" } else { "" }))
println("  σ/τ = " + to_string(sigma_6 / tau_6))
// 137 = 2^7 + 2^3 + 2^0: exponents {7,3,0}, sum = 10; 7+3+0=10 = σ(6)−τ(6)+(...)?

// ─── Verdict ───
println("")
println("══════════════════════════════════════════════════════════════════════")
println("VERDICT: H-PH-1")
println("══════════════════════════════════════════════════════════════════════")
println("  σ(6)² − 7 = 137 exact arithmetic ✓")
println("  137₆ = 345₆, digit sum = 12 = σ(6) ★ (non-trivial)")
println("  137 HW=3, 137=2^7+2^3+2^0")
println("  But: Bonferroni-corrected p ≈ " + fmt4(p_cap) + " → post-hoc search not significant")
println("  Grade: 🟡 (arithmetic true, but Texas-shoot with many degrees of freedom)")
