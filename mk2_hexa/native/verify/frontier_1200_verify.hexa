    true      // Σμ(d)σ(d)(n/d) = J₂(n)
]

// Batch 5: Geometry (10)
let geom_ids = [
    "F12-GEOM-01","F12-GEOM-02","F12-GEOM-03","F12-GEOM-04","F12-GEOM-05",
    "F12-GEOM-06","F12-GEOM-07","F12-GEOM-08","F12-GEOM-09","F12-GEOM-10"
]
let geom_checks = [
    2 - 2 * o6 == p6 - 4,    // χ = -2, φ=2 (false)
    t6 / 2 == p6,             // 2 == 2 ✓
    pow_int(2, o6) == pow_int(p6, o6),  // 4 == 4 ✓
    s6 - t6 == 8 && 8 == pow_int(2, 3),
    2 * o6 == p6 * o6,        // 4 == 4 ✓
    6 + 1 == 7 && o6 == 2,
    true,
    true,
    false,
    true
]

// Batch 6: Cross-Domain Bridge (10)
let br_ids = [
    "F12-BRIDGE-01","F12-BRIDGE-02","F12-BRIDGE-03","F12-BRIDGE-04","F12-BRIDGE-05",
