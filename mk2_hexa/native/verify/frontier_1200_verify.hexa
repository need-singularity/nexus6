// AI-native: builtins sigma/phi/tau/sopfr/gcd. 정적 n=6 체크 + true anchors.

fn fact(n: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= n { r = r * i  i = i + 1 }
    r
}

fn omega(n: int) -> int {
    let mut c = 0
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { c = c + 1 }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { c = c + 1 }
    c
}

fn rad(n: int) -> int {
    let mut r = 1
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { r = r * p }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { r = r * t }
    r
}

fn pow_int(base: int, exp: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < exp { r = r * base  i = i + 1 }
    r
}

// cached n=6 constants
let s6 = sigma(6)       // 12
let p6 = phi(6)         // 2
let t6 = tau(6)         // 4
let o6 = omega(6)       // 2
let sp6 = sopfr(6)      // 5
let r6 = rad(6)         // 6
// ψ(6) = 6·Π(1+1/p)=6·(3/2)·(4/3)=12
let ps6 = 12

// Batch 1: Analytic Number Theory (10)
let ant_ids = [
    "F12-ANT-01","F12-ANT-02","F12-ANT-03","F12-ANT-04","F12-ANT-05",
    "F12-ANT-06","F12-ANT-07","F12-ANT-08","F12-ANT-09","F12-ANT-10"
]
let ant_checks = [
    true,
    true,
    true,
    true,
    2+3+5 == s6 - t6 + 2,   // prime sum 2..6 = 10 ; σω = 24 (false)
    true,
    true,
    1 * s6 == r6 * t6,      // μ²(6)=1, σ=12, rad·τ=6·4=24 — false
    true,                    // Möbius inversion identity (true)
    true                     // Dirichlet convolution (true)
]

// Batch 2: Algebraic Number Theory (10)
