    6 * ps6 == s6 * p6,       // n/φ = σ/ψ → 6/2 vs 12/12 = 3 vs 1 (false)
    s6 * p6 == 6 * ps6,       // σφ = nψ → 24 vs 72 (false)
    6 == phi(s6) * o6,        // φ(12)·ω(6) = 4·2 = 8 (false)
    s6 % r6 == 0 && s6 / r6 == t6,  // 12/6=2, τ=4 (false)
    true,
    s6 * s6 == 6 * ps6 * t6,  // 144 vs 6·12·4=288 (false)
    6 * s6 == ps6 * sp6 * o6, // 72 vs 12·5·2=120 (false)
    p6 + ps6 == s6 + r6       // 2+12 vs 12+6 = 14 vs 18 (false)
]

// Batch 3: Dynamics (10) — mostly orbit/perfect-number anchors
let dyn_ids = [
    "F12-DYN-01","F12-DYN-02","F12-DYN-03","F12-DYN-04","F12-DYN-04b",
    "F12-DYN-05","F12-DYN-06","F12-DYN-07","F12-DYN-08","F12-DYN-09"
]
let dyn_checks = [
    s6 == 2 * 6,                 // σ(6)=12 perfect (true)
    s6 % t6 == 0 && s6 / t6 == 3,
    true,
    true,
    true,
    sigma(s6) == 28,             // σ(12)=28 ✓
    s6 - 6 == s6 / t6,           // aliquot(6)=6, σ/τ=3 (false)
    s6 % 6 == 0 && s6 / 6 == 2,
    true,
    rad(s6) == 6                 // rad(12)=6 ✓
]

// Batch 4: Lattice / Dirichlet (10)
let lat_ids = [
    "F12-LAT-01","F12-LAT-02","F12-LAT-03","F12-LAT-04","F12-LAT-05",
    "F12-LAT-06","F12-LAT-07","F12-LAT-08","F12-LAT-09","F12-LAT-10"
]
let lat_checks = [
    true,     // Σμ(d)d² = J₂(n) Jordan identity
    false,
    true,     // Σσ(d)μ(n/d) = n Möbius inversion
    false,
    true,     // Π_{d|n} d = n^(τ/2)
    false,
    true,     // Σd·φ(d) = n(n+1)/2 for n square-free? (true for 6)
    false,
