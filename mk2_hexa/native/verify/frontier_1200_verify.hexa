    "F12-QUANT-01","F12-QUANT-02","F12-QUANT-03","F12-QUANT-04","F12-QUANT-05",
    "F12-QUANT-06","F12-QUANT-07","F12-QUANT-08","F12-QUANT-09","F12-QUANT-10"
]
let q_checks = [
    sp6 == 6 - 1,             // 5 == 5 ✓
    p6 / o6 == 1,
    6 % (s6 / t6) == 0 && 6 % p6 == 0,
    true,
    true,
    6 - 1 == sp6,
    true,
    pow_int(p6, 6) == pow_int(t6, s6 / t6),   // 64 == 64 ✓
