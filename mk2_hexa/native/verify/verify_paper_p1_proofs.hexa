// Ported from tecs-l/verify/verify_paper_p1_proofs.py — 2026-04-10
// P1 Paper: "The Unique Prime Pair" — core theorems + sample Appendix A equations.
// Theorem 1: (p-1)(q-1) = 2 has unique prime-pair solution (p,q) = (2,3).
// This is the arithmetic basis for why 6 = 2*3 is the first perfect number.

// Theorem 1 verification: scan primes and find solutions to (p-1)(q-1)=2
// Primes up to 50 via trial division
fn is_prime(n: int) -> bool {
    if n < 2 { return false }
    if n < 4 { return true }
    if n % 2 == 0 { return false }
    let mut d = 3
    while d * d <= n {
        if n % d == 0 { return false }
        d = d + 2
    }
    return true
}

let mut unique_k2_count = 0      // solutions with (p-1)(q-1) = 2
let mut k4_count = 0             // solutions with (p-1)(q-1) = 4
let mut p1 = 0
let mut q1 = 0
let mut p = 2
while p <= 50 {
    if is_prime(p) {
        let mut q = p
        while q <= 50 {
            if is_prime(q) {
                let prod = (p - 1) * (q - 1)
                if prod == 2 {
                    unique_k2_count = unique_k2_count + 1
                    p1 = p
                    q1 = q
                }
                if prod == 4 {
                    k4_count = k4_count + 1
                }
            }
            q = q + 1
        }
    }
    p = p + 1
}

// Arithmetic profile of n=6 (Thm 4/5 anchors)
let s6 = sigma(6)        // 12
let t6 = tau(6)          // 4
let p6 = phi(6)          // 2

// Sample Appendix A equations — count solutions up to 1000 for n=6 specifically
// Eq 4: 2*sigma = n*tau → for n=6: 24 = 24 ✓
let eq4_n6 = 2 * s6 == 6 * t6
// Eq 5: sigma = n*phi → 12 = 6*2 ✓
let eq5_n6 = s6 == 6 * p6
// Eq 6: n - 2 = tau → 6-2 = 4 = tau(6) ✓
let eq6_n6 = 6 - 2 == t6
// Eq 8: sigma + phi = 2*tau + n → 12+2 = 8+6 = 14 ✓
let eq8_n6 = s6 + p6 == 2 * t6 + 6
// Eq 11: aliquot s(n) = 3*phi → s(6)=6, 3*phi=6 ✓
let al6 = s6 - 6                // aliquot sum = 6 for perfect
let eq11_n6 = al6 == 3 * p6
// Eq 13: n = 3*(tau - phi) → 6 = 3*(4-2) = 6 ✓
let eq13_n6 = 6 == 3 * (t6 - p6)
// Eq 19: phi^2 = tau → 4 = 4 ✓
let eq19_n6 = p6 * p6 == t6

let ids = [
    "P1-01","P1-02","P1-03","P1-04","P1-05","P1-06","P1-07","P1-08",
    "P1-09","P1-10","P1-11","P1-12","P1-13","P1-14"
]
let checks = [
    unique_k2_count == 1,           // only (2,3) gives (p-1)(q-1)=2
    p1 == 2,
    q1 == 3,
    k4_count == 2,                  // (2,5) and (3,3)
    s6 == 12,
    t6 == 4,
    p6 == 2,
    eq4_n6,
    eq5_n6,
    eq6_n6,
    eq8_n6,
    eq11_n6,
    eq13_n6,
    eq19_n6
]

println("======================================================================")
println("P1: THE UNIQUE PRIME PAIR — Theorem 1 + Appendix A samples")
println("======================================================================")
println("(p-1)(q-1)=2 solutions: " + to_string(unique_k2_count) + " → (" + to_string(p1) + "," + to_string(q1) + ")")
println("(p-1)(q-1)=4 solutions: " + to_string(k4_count) + " (expect 2: (2,5),(3,3))")
println("n=6: sigma=" + to_string(s6) + " tau=" + to_string(t6) + " phi=" + to_string(p6))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
