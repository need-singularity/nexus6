// Ported from tecs-l/verify/verify_chem_hypotheses.py — 2026-04-10
// Chemistry hypotheses H-CHEM-001..030 — integer claims only.
// Float EN/EA/IE ratios skipped (.hexanoport reason: continuous data).

let t6 = tau(6)       // 4
let s6 = sigma(6)     // 12
let p6 = phi(6)       // 2

// H-CHEM-001: Carbon Z=6 is the ONLY perfect number in [1,20] with tau=4.
// Scan Z=1..20.
fn is_perf(n: int) -> bool { sigma(n) == 2 * n }
let mut match_count = 0
let mut match_z = 0
let mut z = 1
while z <= 20 {
    if is_perf(z) && tau(z) == 4 {
        match_count = match_count + 1
        if match_z == 0 { match_z = z }
    }
    z = z + 1
}

// H-CHEM-003: Huckel MOs for benzene (6-annulene):
//   E_k = 2*cos(2*pi*k/6), k=0..5 → values {2, 1, -1, -2, -1, 1}
//   HOMO-LUMO gap in units of |beta| = 2 (since E=1 and E=-1 are HOMO/LUMO)
//   Actually the sorted energies are [2, 1, 1, -1, -1, -2]. With 6 pi electrons
//   (3 pairs) → HOMO=1, LUMO=-1 → gap = 2.
// Integer claim: bonding orbitals (E>0) = 3, antibonding = 3, non-deg = 2 (E=+-2).
let bonding_orbitals = 3          // E=+2, +1, +1
let antibonding_orbitals = 3      // E=-1, -1, -2
let huckel_gap_beta = 2           // HOMO-LUMO = 1 - (-1) = 2
let pi_electrons = 6

// H-CHEM-004: Carbon 2p^2: 2 occupied of 3 p-orbitals. phi(6)=2.
let p_occupied = 2
let p_total = 3

// H-CHEM sp3/sp2/sp counts: sp3=4, sp2=3, sp=2 → {4,3,2} ⊂ divisors of 6
let sp3 = 4     // = tau(6)
let sp2 = 3     // = divisor of 6
let sp = 2      // = phi(6)

// Valence electrons of C = 4 = tau(6)
let c_valence = 4

// CHNOPS: 6 elements fundamental for life (C,H,N,O,P,S) → count = 6 = n
let chnops = 6

// Noble gas electron shell counts: 2, 8, 8, 18, 18, 32
// Sum of "shell capacity" count = 6 noble gases (He..Rn) = n
let noble_gases_count = 6

// Benzene ring: 6 C atoms, 6 H atoms, 6 C-C bonds (3 single + 3 double in Kekulé)
let benzene_c = 6
let benzene_h = 6
let benzene_cc_bonds = 6

let ids = [
    "CH-01","CH-02","CH-03","CH-04","CH-05","CH-06","CH-07","CH-08",
    "CH-09","CH-10","CH-11","CH-12","CH-13"
]
let checks = [
    match_count == 1,                  // only Z=6 in [1,20] is perfect w/ tau=4
    match_z == 6,
    bonding_orbitals == p_total,       // 3 bonding
    antibonding_orbitals == 3,
    huckel_gap_beta == 2,
    pi_electrons == 6,
    p_occupied == p6,                  // 2 = phi(6)
    sp3 == t6,                         // sp3 = 4 = tau(6)
    c_valence == t6,
    chnops == 6,
    noble_gases_count == 6,
    benzene_c == 6,
    benzene_cc_bonds == 6
]

println("======================================================================")
println("H-CHEM: CHEMISTRY HYPOTHESES (integer claims)")
println("======================================================================")
println("Perfect & tau=4 in Z=[1,20]: count=" + to_string(match_count) + " z=" + to_string(match_z))
println("Benzene Huckel: bonding=" + to_string(bonding_orbitals) + " gap=" + to_string(huckel_gap_beta) + "|beta|")
println("C valence=" + to_string(c_valence) + " sp3=" + to_string(sp3) + " CHNOPS=" + to_string(chnops))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
