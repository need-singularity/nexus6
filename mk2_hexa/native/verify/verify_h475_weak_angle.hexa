// Ported from tecs-l/verify/verify_h475_weak_angle.py — 2026-04-10
// H-CX-475: sin^2(theta_W) * N_gen ~ ln(2). Encoded as rounded integer checks.
// PDG MS-bar: sin^2(theta_W) = 0.23122, N_gen = 3.
// Anchor check: product ~ 0.6937, ln(2) ~ 0.6931, ratio in [0.999, 1.001].

// Work in integer micro-units: sin2_micro = 231220 (×1e6 = 0.23122*1e6)
let sin2_micro = 231220
let n_gen = 3
let product_micro = sin2_micro * n_gen   // 693660
// ln(2)*1e6 ≈ 693147 (Mercator constant, anchor)
let ln2_micro = 693147
let diff_micro = product_micro - ln2_micro   // 513
// Relative error in ppm = 513 * 1e6 / 693147 ≈ 740 ppm ≈ 0.074%
let abs_diff = if diff_micro < 0 { 0 - diff_micro } else { diff_micro }
let within_tenth_pct = abs_diff * 1000 <= ln2_micro   // diff ≤ 0.1% of ln2

// Sigma test: uncertainty 0.00003 = 30 ppm → diff ~ 170 ppm / 30 ppm ≈ 5.7 sigma → EXCLUDED
let excluded_as_exact = abs_diff * 17 > ln2_micro / 1000   // heuristic: > 5sigma

let ids = [
    "HW-01","HW-02","HW-03","HW-04","HW-05","HW-06"
]
let checks = [
    n_gen == 3,
    product_micro > 690000,
    product_micro < 700000,
    ln2_micro > 693000,
    within_tenth_pct,              // match within 0.1%
    excluded_as_exact              // >5sigma from exact
]

println("======================================================================")
println("H-CX-475: sin^2(theta_W) * N_gen vs ln(2)")
println("======================================================================")
println("product*1e6=" + to_string(product_micro) + " ln2*1e6=" + to_string(ln2_micro))
println("abs_diff*1e6=" + to_string(abs_diff))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
