// Ported from tecs-l/verify/verify_qcomp_008_depolarizing.py — 2026-04-10
// QCOMP-008: Depolarizing channel threshold for [[6,4,2]].
// Error rate p → fidelity F = 1 - 3p/4; detection requires F > p_detect.
// We verify integer Pauli-group counts: 6-qubit Pauli group has 4^6 = 4096 elements.

fn pow4(k: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < k { r = r * 4  i = i + 1 }
    r
}
fn pow2(k: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < k { r = r * 2  i = i + 1 }
    r
}

let n = 6
let pauli_n = pow4(n)   // 4^6 = 4096
let hilbert = pow2(n)   // 64

// Weight-0 errors: 1 (identity). Weight-1 errors: 3n = 18. Weight-2 errors: C(n,2)*9 = 135.
let w0 = 1
let w1 = 3 * n
fn c2(n: int) -> int { n * (n - 1) / 2 }
let w2 = c2(n) * 9   // 135

// For [[6,4,2]] d=2: detects all weight-1 errors (18).
// Total Pauli = 4^6 = 4096. Stabilizer has 2^(n-k) = 2^2 = 4 generators.
let stab_gen = n - 4   // 2
let stab_size = pow2(stab_gen)  // 4

let ids = [
    "QC8-01","QC8-02","QC8-03","QC8-04","QC8-05","QC8-06","QC8-07"
]
let checks = [
    pauli_n == 4096,
    hilbert == 64,
    w1 == 18,
    w2 == 135,
    stab_gen == 2,
    stab_size == 4,
    pauli_n / hilbert == 64   // 4096/64 = 64
]

println("======================================================================")
println("QCOMP-008: Depolarizing Channel — Pauli Group Counts for [[6,4,2]]")
println("======================================================================")
println("4^6=" + to_string(pauli_n) + " 2^6=" + to_string(hilbert))
println("weight-1 errors=" + to_string(w1) + " weight-2=" + to_string(w2))
println("stabilizer generators=" + to_string(stab_gen) + " size=" + to_string(stab_size))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
