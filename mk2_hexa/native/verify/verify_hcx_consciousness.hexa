// mk2_hexa/native/verify_hcx_consciousness.hexa
// 포팅 원본: tecs-l/math/verify_hcx_consciousness.py (317 LOC)
// H-CX-1 / H-CX-3 / H-CX-4: R(n) tension, balance score, diversity

let N_MAX = 1000

fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0)) / 10000.0
    to_string(r)
}
fn fmt6(x: float) -> string {
    let r = to_float(to_int(x * 1000000.0)) / 1000000.0
    to_string(r)
}
fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

fn R_val(n: int) -> float {
    to_float(sigma(n) * phi(n)) / to_float(n * tau(n))
}

// @pure — is n perfect?
fn is_perfect(n: int) -> bool { sigma(n) == 2 * n }

println("══════════════════════════════════════════════════════════════════════")
println("H-CX-1 / H-CX-3 / H-CX-4: Consciousness R(n) analysis  (hexa port)")
println("══════════════════════════════════════════════════════════════════════")

// ─── H-CX-1: T(n) = |R(n) − 1| analysis ───
println("")
println("══ H-CX-1: T(n) = |R(n) − 1|  tension analysis ══")

// Distribution of T by threshold
println("")
println("  Threshold | count with T < th")
println("  ----------+-------------------")
let thresholds = [1000, 100, 50, 10, 1]  // *1000 → threshold 0.001, 0.01, 0.05, 0.1, 0.5  (wait, 1→0.001, 1000→1.0)
// Actually use float thresholds properly:
let th_vals = [0.001, 0.01, 0.05, 0.1, 0.2, 0.5]
let mut ti = 0
while ti < len(th_vals) {
    let th = th_vals[ti]
    let mut cnt = 0
    let mut n = 2
    while n <= N_MAX {
        let t = abs_f(R_val(n) - 1.0)
        if t < th { cnt = cnt + 1 }
        n = n + 1
    }
    println("   T < " + fmt4(th) + "   | " + to_string(cnt))
    ti = ti + 1
}

// Exact zeros: R(n) = 1 in [2, N_MAX]
let mut exact_zeros = []
let mut m = 2
while m <= N_MAX {
    if sigma(m) * phi(m) == m * tau(m) { exact_zeros = exact_zeros + [m] }
    m = m + 1
}
println("")
println("  Exact zeros T=0 (R=1): " + to_string(exact_zeros))
assert len(exact_zeros) == 1
assert exact_zeros[0] == 6
println("  ✓ n=6 UNIQUE with R=1 in [2, " + to_string(N_MAX) + "]")

// ─── Top 10 smallest tensions ───
println("")
println("  Top 10 smallest T(n) (excluding n=6):")
println("    rank | n      | R(n)      | T(n)")
println("    -----+--------+-----------+--------")
// Simple O(N·10) top-k
let K = 10
let mut top_n = []
let mut top_t = []
let mut tk = 0
while tk < K {
    top_n = top_n + [0]
    top_t = top_t + [1.0e99]
    tk = tk + 1
}
let mut m2 = 2
while m2 <= N_MAX {
    if m2 != 6 {
        let t = abs_f(R_val(m2) - 1.0)
        // insert if smaller than any current top
        let mut worst_i = 0
        let mut wi = 1
        while wi < K {
            if top_t[wi] > top_t[worst_i] { worst_i = wi }
            wi = wi + 1
        }
        if t < top_t[worst_i] {
            top_n[worst_i] = m2
            top_t[worst_i] = t
        }
    }
    m2 = m2 + 1
}
// Print sorted (selection)
let mut rank = 1
while rank <= K {
    let mut min_i = 0
    let mut mi2 = 1
    while mi2 < K {
        if top_t[mi2] < top_t[min_i] { min_i = mi2 }
        mi2 = mi2 + 1
    }
    if top_n[min_i] > 0 {
        let nn = top_n[min_i]
        println("    " + to_string(rank) + "    | " + to_string(nn) + "\t| " + fmt6(R_val(nn)) + "  | " + fmt6(top_t[min_i]))
    }
    top_t[min_i] = 1.0e99  // remove
    rank = rank + 1
}

// ─── H-CX-3: Balance score B(n) = 1/T(n) ───
println("")
println("══ H-CX-3: Balance score B(n) = 1/T(n) ══")
println("")
println("  B(6) = ∞ (T=0, unique global balance point)")
println("")
println("  Divisor partition pairs for small n:")
println("    n  | pairs (d, n/d) with d ≤ n/d")
println("    ---+------------------------------")
let ns = [4, 5, 6, 7, 8, 9, 10, 12, 20, 24, 28]
let mut ni = 0
while ni < len(ns) {
    let nn = ns[ni]
    let mut pair_count = 0
    let mut d = 1
    while d * d <= nn {
        if nn % d == 0 { pair_count = pair_count + 1 }
        d = d + 1
    }
    let perf_tag = if is_perfect(nn) { " [PERFECT]" } else { "" }
    println("   " + to_string(nn) + "\t| " + to_string(pair_count) + " pairs" + perf_tag)
    ni = ni + 1
}

// Perfect numbers with R analysis
println("")
println("  Perfect numbers in [2, " + to_string(N_MAX) + "]:")
let mut perfects = []
let mut pn = 2
while pn <= N_MAX {
    if is_perfect(pn) { perfects = perfects + [pn] }
    pn = pn + 1
}
println("    " + to_string(perfects))
let mut pi = 0
while pi < len(perfects) {
    let p = perfects[pi]
    let rv = R_val(p)
    println("    n=" + to_string(p) + ": R=" + fmt6(rv) + ", σ=" + to_string(sigma(p)) + ", φ=" + to_string(phi(p)) + ", τ=" + to_string(tau(p)))
    pi = pi + 1
}
println("  → Only n=6 among perfects has R=1")

// ─── H-CX-4: Diversity D(d) = d·ln(d)·R(d) ───
println("")
println("══ H-CX-4: Diversity D(d) = d · ln(d) · R(d) ══")
println("")
println("     d |   R(d)     | d·ln(d)  | D(d)         | note")
println("  -----+------------+----------+--------------+-------")
let dims = [2, 3, 4, 5, 6, 8, 12, 16, 24, 28, 64, 128, 256, 512, 768, 1024]
let mut di = 0
while di < len(dims) {
    let d = dims[di]
    let r = R_val(d)
    let info = to_float(d) * log(to_float(d))
    let D = info * r
    let mut note = ""
    if is_perfect(d) { note = "PERFECT" }
    if d == 6 { note = note + " R=1★" }
    if abs_f(r - 1.0) < 0.05 && d != 6 { note = note + " R≈1" }
    println("  " + to_string(d) + "\t| " + fmt6(r) + "\t| " + fmt4(info) + "\t| " + fmt4(D) + "\t| " + note)
    di = di + 1
}

// ─── ML embedding dimensions ───
println("")
println("  Common ML embedding dimensions — R(d) comparison:")
let ml_dims = [64, 128, 256, 384, 512, 768, 1024]
let mut mli = 0
while mli < len(ml_dims) {
    let d = ml_dims[mli]
    let r = R_val(d)
    let multiple_24 = if d % 24 == 0 { " ← σφ multiple" } else { "" }
    println("    d=" + to_string(d) + ": R=" + fmt6(r) + multiple_24)
    mli = mli + 1
}

// ─── Proof that R(6) = 1 ───
println("")
println("══════════════════════════════════════════════════════════════════════")
println("PROOF: R(6) = 1")
println("══════════════════════════════════════════════════════════════════════")
println("  σ(6) = 1+2+3+6 = " + to_string(sigma(6)))
println("  φ(6) = |{1, 5}| = " + to_string(phi(6)))
println("  τ(6) = |{1,2,3,6}| = " + to_string(tau(6)))
println("  σ·φ = " + to_string(sigma(6) * phi(6)))
println("  n·τ = 6·" + to_string(tau(6)) + " = " + to_string(6 * tau(6)))
assert sigma(6) * phi(6) == 6 * tau(6)
println("  R(6) = σφ/(nτ) = 24/24 = 1  ✓")

// Extended uniqueness
println("")
println("  Extended uniqueness check [2, " + to_string(N_MAX) + "]:")
println("  n with σ·φ = n·τ (R=1): " + to_string(exact_zeros))
println("  → n=6 UNIQUE (also n=1 trivially, excluded)")

// ─── FINAL SUMMARY ───
println("")
println("══════════════════════════════════════════════════════════════════════")
println("FINAL SUMMARY")
println("══════════════════════════════════════════════════════════════════════")
println("  H-CX-1: R(6)=1 UNIQUE global minimum of T(n) in [2, 1000]   ✓")
println("  H-CX-3: B(6)=∞ uniquely balanced; n=6 is ONLY perfect with R=1  ✓")
println("  H-CX-4: Diversity D(d) = d·ln(d)·R(d), d=6 has R=1 optimal efficiency")
println("")
println("  All assertions PASS.")
