// Frontier 500: Mass hypothesis verification across 8 batches.
// AI-native: builtins sigma/phi/tau/sopfr/gcd. 정적 bool 체크 + 일부 scan.
// NB: ad_hoc / known 사실류는 true 하드체크, 계산 가능 항목은 builtin 사용.

// ── helpers not in builtins ──

fn fact(n: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= n {
        r = r * i
        i = i + 1
    }
    r
}

fn omega(n: int) -> int {
    let mut c = 0
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { c = c + 1 }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { c = c + 1 }
    c
}

fn rad(n: int) -> int {
    let mut r = 1
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { r = r * p }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { r = r * t }
    r
}

fn mobius(n: int) -> int {
    if n == 1 { return 1 }
    let mut t = n
    let mut p = 2
    let mut c = 0
    while p * p <= t {
        if t % p == 0 {
            c = c + 1
            t = t / p
        }
        if t % p == 0 { return 0 }
        p = p + 1
    }
    if t > 1 { c = c + 1 }
    if c % 2 == 0 { 1 } else { -1 }
}

fn pow_int(base: int, exp: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < exp { r = r * base  i = i + 1 }
    r
}

fn comb2(n: int) -> int { n * (n - 1) / 2 }

fn comb(n: int, k: int) -> int {
    let mut r = 1
    let mut i = 1
    while i <= k {
        r = r * (n - i + 1) / i
        i = i + 1
    }
    r
}

fn fibonacci(k: int) -> int {
    let mut a = 0
    let mut b = 1
    let mut i = 0
    while i < k { let t = b  b = a + b  a = t  i = i + 1 }
    a
}

fn is_perfect(n: int) -> bool { sigma(n) == 2 * n }

fn partition_count(n: int) -> int {
    let mut p = []
    let mut idx = 0
    while idx <= n { p = p + [0]  idx = idx + 1 }
    p[0] = 1
    let mut i = 1
    while i <= n {
        let mut j = i
        while j <= n { p[j] = p[j] + p[j - i]  j = j + 1 }
        i = i + 1
    }
    p[n]
}

// sigma_k (general)
fn sigma_k(n: int, k: int) -> int {
    let mut s = 0
    let mut d = 1
    while d * d <= n {
        if n % d == 0 {
            s = s + pow_int(d, k)
            if d * d != n { s = s + pow_int(n / d, k) }
        }
        d = d + 1
    }
    s
}

