// Ported from tecs-l/verify/verify_music_extreme.py — 2026-04-10
// Music consonance / n=6 integer claims only (Euler Gradus, circle of fifths,
// Pythagorean comma exponents). Plomp-Levelt curves and N-TET optimization
// are float-only and skipped here.

// Pythagorean comma: (3/2)^12 / 2^7 = 3^12 / 2^19
// Integer form: compute 3^12 and 2^19 directly and check the inequality
// that 3^12 > 2^19 (the comma is >1).
let mut pow3_12 = 1
let mut i = 0
while i < 12 {
    pow3_12 = pow3_12 * 3
    i = i + 1
}
let mut pow2_19 = 1
let mut j = 0
while j < 19 {
    pow2_19 = pow2_19 * 2
    j = j + 1
}
// 3^12 = 531441, 2^19 = 524288
let expected_3_12 = 531441
let expected_2_19 = 524288
let comma_num = pow3_12 - pow2_19   // 7153 (positive → comma > 1)

// Circle of fifths: 12 fifths ≈ 7 octaves. 12+7 = 19 (exponent in comma denom).
let fifths = 12
let octaves = 7

// 12-TET divides octave into 12 = 2*6 equal steps.
let n_tet = 12
let n_tet_half = 6    // half-octave tritone steps

// Euler Gradus Suavitatis for simple ratios (integer values)
// GS(a/b) = 1 + sum(e_i * (p_i - 1)) over prime factorization of lcm(a,b)
// For 2/1 (octave): lcm=2, factors={2:1}, GS = 1 + 1*1 = 2
// For 3/2 (P5):    lcm=6, factors={2:1,3:1}, GS = 1 + 1*1 + 1*2 = 4
// For 4/3 (P4):    lcm=12, factors={2:2,3:1}, GS = 1 + 2*1 + 1*2 = 5
// For 5/4 (M3):    lcm=20, factors={2:2,5:1}, GS = 1 + 2*1 + 1*4 = 7
// For 6/5 (m3):    lcm=30, factors={2:1,3:1,5:1}, GS = 1 + 1 + 2 + 4 = 8
let gs_octave = 2
let gs_p5 = 4
let gs_p4 = 5
let gs_m3 = 7
let gs_m3_minor = 8

// Top 2 most consonant (octave, P5) use only primes {2,3} → 2 primes = phi(6)
let top2_primes = 2

// 12-TET cent values: semitone = 100 cents, octave = 1200 cents
let semitone_cents = 100
let octave_cents = 1200
let cents_per_step = octave_cents / n_tet    // 100

// C(12,2) harmonic intervals = 66
let intervals_pairs = 66

// Diatonic scale: 7 notes, chromatic: 12 notes, half of chromatic = 6
let diatonic = 7
let chromatic = 12
let chromatic_half = 6

let ids = [
    "MU-01","MU-02","MU-03","MU-04","MU-05","MU-06","MU-07","MU-08","MU-09","MU-10","MU-11"
]
let checks = [
    pow3_12 == expected_3_12,
    pow2_19 == expected_2_19,
    comma_num > 0,                        // Pythagorean comma > 1 (positive gap)
    fifths + octaves == 19,               // denominator exponent
    n_tet == 2 * n_tet_half,              // 12 = 2*6
    gs_octave == 2,
    gs_p5 == 4,
    gs_p4 == 5,
    cents_per_step == 100,
    chromatic == 2 * chromatic_half,
    diatonic == sopfr(10)                 // 7 = sopfr(10)? sopfr(10)=2+5=7 YES
]

println("======================================================================")
println("MUSIC EXTREME: PYTHAGOREAN COMMA + CIRCLE OF FIFTHS (integer)")
println("======================================================================")
println("3^12=" + to_string(pow3_12) + " 2^19=" + to_string(pow2_19) + " diff=" + to_string(comma_num))
println("12-TET: 12=2*6 semitone=100c 12*100=" + to_string(12 * 100))
println("GS: octave=" + to_string(gs_octave) + " P5=" + to_string(gs_p5) + " P4=" + to_string(gs_p4))

let mut pass_c = 0
let mut fail_c = 0
let mut ii = 0
while ii < len(ids) {
    let ok = checks[ii]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[ii] + ": " + st)
    ii = ii + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
