println("  2 = phi(6), 3 = sigma(6)/tau(6)")

// Seifert matrix
println("")
println("## Seifert Matrix")
println("  For trefoil (genus 1), Seifert matrix is 2x2:")
println("  V = [[-1, 1], [0, -1]]")
let v00 = -1
let v01 = 1
let v10 = 0
let v11 = -1
let det_v = v00 * v11 - v01 * v10
println("  det(V) = " + to_string(det_v))
println("  V + V^T:")
let s00 = v00 + v00
let s01 = v01 + v10
let s10 = v10 + v01
let s11 = v11 + v11
let vvt = "  V + V^T = [[" + to_string(s00) + ", " + to_string(s01) + "], [" + to_string(s10) + ", " + to_string(s11) + "]]"
println(vvt)
// Eigenvalues: x^2 + 4x + 3 = 0 => x = -1, -3
let disc = 16.0 - 12.0
let ev1 = (-4.0 + sqrt(disc)) / 2.0
let ev2 = (-4.0 - sqrt(disc)) / 2.0
println("  Eigenvalues: " + fmt4(ev1) + ", " + fmt4(ev2))
let mut sig = 0
if ev1 > 0.0 { sig = sig + 1 } else { if ev1 < 0.0 { sig = sig - 1 } }
if ev2 > 0.0 { sig = sig + 1 } else { if ev2 < 0.0 { sig = sig - 1 } }
println("  Signature = " + to_string(sig) + " (both negative)")

