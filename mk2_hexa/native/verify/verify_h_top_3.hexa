// Torus knots table (reduced set for speed)
println("")
println("### Torus knots T(p,q) and their p*q products")
println("")
println("| Knot | (p,q) | p*q | Perfect? | sigma(p*q) | Crossing # |")
println("|---|---|---|---|---|---|")

let tk_p = [2, 2, 2, 3, 3, 4]
let tk_q = [3, 5, 7, 4, 5, 5]

let mut ti2 = 0
while ti2 < len(tk_p) {
    let p = tk_p[ti2]
    let q = tk_q[ti2]
    let pq = p * q
    let is_perf = if pq == 6 || pq == 28 || pq == 496 { "YES" } else { "no" }
    let sig_pq = sigma_of(pq)
    let c1 = p * (q - 1)
    let c2 = q * (p - 1)
    let crossing = min_i(c1, c2)
    let name = "T(" + to_string(p) + "," + to_string(q) + ")"
    let line = "| " + name + " | (" + to_string(p) + "," + to_string(q) + ") | " + to_string(pq) + " | " + is_perf + " | " + to_string(sig_pq) + " | " + to_string(crossing) + " |"
    println(line)
    ti2 = ti2 + 1
}

println("")
println("  T(2,3) is the ONLY small torus knot with p*q = perfect number")

// Check torus knots with p*q = perfect
println("")
println("### Torus knots with p*q = perfect number (gcd(p,q)=1)")
let perfects = [6, 28]
let mut pi = 0
while pi < len(perfects) {
    let P = perfects[pi]
    println("")
    println("  p*q = " + to_string(P) + ":")
    let mut p = 2
    while p < P {
        let q = P / p
        if p * q == P && p < q && gcd(p, q) == 1 {
            let c1 = p * (q - 1)
            let c2 = q * (p - 1)
            let crossing = min_i(c1, c2)
            let genus = (p - 1) * (q - 1) / 2
            let line = "    T(" + to_string(p) + "," + to_string(q) + "): crossing=" + to_string(crossing) + ", genus=" + to_string(genus)
            println(line)
        }
        p = p + 1
    }
    pi = pi + 1
}

