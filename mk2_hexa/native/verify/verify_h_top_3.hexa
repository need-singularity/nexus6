// H-TOP-3: Trefoil knot T(2,3) connections to sigma(6), tau(6), phi(6)

fn abs_i(x: int) -> int {
    if x < 0 { return -x }
    x
}

fn min_i(a: int, b: int) -> int {
    if a < b { return a }
    b
}

fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0)) / 10000.0
    to_string(r)
}

fn sigma_of(n: int) -> int {
    let mut s = 0
    let mut d = 1
    while d <= n {
        if n % d == 0 { s = s + d }
        d = d + 1
    }
    s
}

