// Alexander polynomial
println("")
println("## Alexander Polynomial")
println("  Delta(t) = t - 1 + t^{-1}")
println("  Verification:")
let t_vals = [1.0, -1.0, 2.0, 0.5]
let mut ti = 0
while ti < len(t_vals) {
    let t = t_vals[ti]
    if t != 0.0 {
        let inv_t = 1.0 / t
        let delta = t - 1.0 + inv_t
        let line = "    Delta(" + fmt4(t) + ") = " + fmt4(t) + " - 1 + " + fmt4(inv_t) + " = " + fmt4(delta)
        println(line)
    }
    ti = ti + 1
}

println("")
println("  Delta(1) = 1  (always 1 for any knot)")
println("  Delta(-1) = -1 - 1 + (-1) = -3  (= +/-determinant)")
let det_from_alex = abs_i(-3)
println("  |Delta(-1)| = " + to_string(det_from_alex) + " = determinant OK")

// Jones polynomial
println("")
println("## Jones Polynomial")
println("  V(t) = -t^{-4} + t^{-3} + t^{-1}  (right-handed trefoil)")
println("  V(-1) = -1 + (-1) + (-1) = -3")
println("  V(1) = -1 + 1 + 1 = 1")
println("")
println("  |V(-1)| = 3 = sigma(6)/tau(6) OK")

// HOMFLY polynomial
println("")
println("## HOMFLY-PT Polynomial")
println("  P(a,z) = -a^4 + a^2*z^2 + 2*a^2  (right-handed trefoil)")
println("  Span in 'a' variable = 2 (from a^2 to a^4)")

