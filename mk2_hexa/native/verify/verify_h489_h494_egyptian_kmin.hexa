// Ported from tecs-l/verify/verify_h489_h494_egyptian_kmin.py — 2026-04-10
// H-CX-489/494: For perfect number P_n = 2^(p-1)(2^p - 1), k_min = 2p - 1.
// Egyptian fraction decomposition 1 = sum(1/a_i) with lcm(a_i) = P.
// Key insight: divisors of P = 2p total; divisors >= 2 has 2p-1 elements.
// sigma_{-1}(P) = 2 for perfect P, so sum of reciprocals over divisors>=2 = 1.
// Removing any divisor gives sum < 1, so k_min = 2p-1 (all non-trivial divisors).

fn pow2(k: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < k { r = r * 2  i = i + 1 }
    r
}

// Divisors of n, count only
fn divisor_count(n: int) -> int {
    let mut c = 0
    let mut d = 1
    while d <= n {
        if n % d == 0 { c = c + 1 }
        d = d + 1
    }
    c
}

// Sum of 1/d over divisors d of n, scaled by n (so integer): sum(n/d) = sigma(n)
// sigma_-1(n) * n = sigma(n)
// For perfect n: sigma(n) = 2n, so sigma_-1(n) = 2.
// Sum over divisors >= 2 of 1/d = sigma_-1(n) - 1 = 1 for perfect n.

// Verify for p=2: P=6
let p1 = 2
let m1 = pow2(p1) - 1       // 3
let P1 = pow2(p1 - 1) * m1  // 6
let dc1 = divisor_count(P1) // 4 = 2p
let k1_min = dc1 - 1        // 3 = 2p - 1
let sig1 = sigma(P1)        // 12 = 2*6

// p=3: P=28
let p2 = 3
let m2 = pow2(p2) - 1       // 7
let P2 = pow2(p2 - 1) * m2  // 28
let dc2 = divisor_count(P2) // 6 = 2p
let k2_min = dc2 - 1        // 5
let sig2 = sigma(P2)        // 56

// p=5: P=496
let p3 = 5
let m3 = pow2(p3) - 1       // 31
let P3 = pow2(p3 - 1) * m3  // 496
let dc3 = divisor_count(P3) // 10 = 2p
let k3_min = dc3 - 1        // 9
let sig3 = sigma(P3)        // 992

// Verify: sum of n/d over divisors d>=2 equals n (since sum over all divisors
// is sigma(n) = 2n, minus n/1 = n gives n, so sum of 1/d over d>=2 = 1).
fn sum_ndiv_d_ge2(n: int) -> int {
    let mut s = 0
    let mut d = 2
    while d <= n {
        if n % d == 0 { s = s + n / d }
        d = d + 1
    }
    s
}
let s1 = sum_ndiv_d_ge2(P1)   // should equal P1 = 6
let s2 = sum_ndiv_d_ge2(P2)   // should equal P2 = 28
let s3 = sum_ndiv_d_ge2(P3)   // should equal P3 = 496

// Removing any divisor d from the sum gives: sum - n/d = n - n/d = n(1 - 1/d) < n
// So after removal, sum_reciprocals = 1 - 1/d < 1. No proper subset = 1.
// Therefore k_min = 2p - 1 exactly.

let ids = [
    "EG-01","EG-02","EG-03","EG-04","EG-05","EG-06","EG-07","EG-08",
    "EG-09","EG-10","EG-11","EG-12"
]
let checks = [
    P1 == 6,
    P2 == 28,
    P3 == 496,
    sig1 == 2 * P1,             // sigma(P1) = 2P1 (perfect)
    sig2 == 2 * P2,
    sig3 == 2 * P3,
    dc1 == 2 * p1,              // number of divisors = 2p
    dc2 == 2 * p2,
    dc3 == 2 * p3,
    k1_min == 2 * p1 - 1 && k1_min == 3,  // H-CX-489: k_min=3
    k2_min == 2 * p2 - 1 && k2_min == 5,  // k_min=5
    k3_min == 2 * p3 - 1 && k3_min == 9   // H-CX-494: k_min=9
]

println("======================================================================")
println("H-CX-489/494: Egyptian fraction k_min for perfect numbers")
println("======================================================================")
println("P_1 (p=2) = " + to_string(P1) + " divisors=" + to_string(dc1) + " k_min=" + to_string(k1_min))
println("P_2 (p=3) = " + to_string(P2) + " divisors=" + to_string(dc2) + " k_min=" + to_string(k2_min))
println("P_3 (p=5) = " + to_string(P3) + " divisors=" + to_string(dc3) + " k_min=" + to_string(k3_min))
println("sum(n/d, d|n, d>=2) for P_1: " + to_string(s1) + " (should = " + to_string(P1) + ")")
println("sum(n/d, d|n, d>=2) for P_2: " + to_string(s2) + " (should = " + to_string(P2) + ")")
println("sum(n/d, d|n, d>=2) for P_3: " + to_string(s3) + " (should = " + to_string(P3) + ")")

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
