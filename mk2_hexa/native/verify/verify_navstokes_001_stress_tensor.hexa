// Ported from tecs-l/verify/verify_navstokes_001_stress_tensor.py — 2026-04-10
// NAVSTOKES-001: 3D symmetric stress tensor has P1=6 independent components.

fn sym_components(d: int) -> int { d * (d + 1) / 2 }
fn triangular(k: int) -> int { k * (k + 1) / 2 }

let n = 6
let s6 = sigma(6)   // 12
let t6 = tau(6)     // 4
let p6 = phi(6)     // 2
let sp6 = sopfr(6)  // 5
let p1 = 6
let p2 = 28

let components_3d = sym_components(3)              // 6 = P1
let components_4d = sym_components(4)              // 10
let normal = 3
let shear = 3
let antisym_3d = 3                                  // 3 rotational dof
let full_3d = components_3d + antisym_3d           // 9 = 3x3 matrix
let cross_prod = 3                                  // curl in 3D

let ids = [
    "NAV-01","NAV-02","NAV-03","NAV-04","NAV-05",
    "NAV-06","NAV-07","NAV-08"
]
let checks = [
    components_3d == p1,
    components_3d == n,
    normal + shear == components_3d,
    full_3d == 9,
    triangular(3) == 6,
    triangular(3) == p1,
    components_4d == 10,
    cross_prod == 3
]

println("======================================================================")
println("NAVSTOKES-001: stress tensor = P1 = 6 components")
println("======================================================================")
println("sym(3)=" + to_string(components_3d) + " sym(4)=" + to_string(components_4d))
println("T(3)=" + to_string(triangular(3)) + " sigma(6)=" + to_string(s6))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
