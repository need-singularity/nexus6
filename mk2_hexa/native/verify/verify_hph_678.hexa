fn f_chain(start: int) -> [string] {
    let mut chain = [to_string(start)]
    let mut nn = start
    let mut step = 0
    let mut seen = #{}
    seen[to_string(start)] = 1
    while step < 15 {
        if nn > 50000 {
            chain = chain.push("(too large)")
            break
        }
        let s_n = sigma(nn)
        let t_n = tau(nn)
        let p_n = phi(nn)
        let val = s_n * p_n
        if val % t_n != 0 {
            let fv = to_float(val) / to_float(t_n)
            chain = chain.push("non-int(" + fmt2(fv) + ")")
            break
        }
        let new_n = val / t_n
        if new_n == nn {
            chain = chain.push(to_string(new_n) + "(fixed)")
            break
        }
        if has_key(seen, to_string(new_n)) {
            chain = chain.push(to_string(new_n) + "(cycle)")
            break
        }
        if new_n > 50000 {
            chain = chain.push(to_string(new_n) + "(large)")
            break
        }
        chain = chain.push(to_string(new_n))
        seen[to_string(new_n)] = 1
        nn = new_n
        step = step + 1
    }
    chain
}

