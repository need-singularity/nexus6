let mut n = 1
while n <= 100 {
    let s = sigma(n)
    let t = tau(n)
    let p = phi(n)
    let r = R(n)
    let mut is_one = ""
    if abs_f(r - 1.0) < 1e-12 {
        is_one = "YES"
        r_equals_1 = r_equals_1.push(n)
    }
    if n <= 30 || abs_f(r - 1.0) < 1e-12 {
        println("| " + to_string(n) + " | " + to_string(s) + " | " + to_string(t) + " | " + to_string(p) + " | " + fmt6(r) + " | " + is_one + " |")
    }
    n = n + 1
}

