let mut two_prime = []
n = 6
while n <= 200 {
    let factors = factorize(n)
    let ks = keys(factors)
    if len(ks) == 2 {
        let mut all_one = true
        let mut ki = 0
        while ki < len(ks) {
            if factors[ks[ki]] != 1 { all_one = false }
            ki = ki + 1
        }
        if all_one {
            two_prime = two_prime.push([n, arithmetic_entropy(n)])
        }
    }
    n = n + 1
}
// simple sort by entropy descending (bubble)
let mut si = 0
while si < len(two_prime) {
    let mut sj = si + 1
    while sj < len(two_prime) {
        if two_prime[sj][1] > two_prime[si][1] {
            let tmp = two_prime[si]
            two_prime[si] = two_prime[sj]
            two_prime[sj] = tmp
        }
        sj = sj + 1
    }
    si = si + 1
}
