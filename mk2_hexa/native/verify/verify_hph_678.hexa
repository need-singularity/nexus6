println("")
println(repeat_str("=", 80))
println("PART 5: THERMODYNAMIC PARTITION FUNCTION (H-PH-8)")
println(repeat_str("=", 80))
println("")

fn Z_n(n: int, beta: float) -> float {
    let divs = divisors(n)
    let mut z = 0.0
    let mut i = 0
    while i < len(divs) {
        z = z + exp_f(0.0 - beta * to_float(divs[i]))
        i = i + 1
    }
    z
}

fn U_n(n: int, beta: float) -> float {
    let divs = divisors(n)
    let mut z = 0.0
    let mut u = 0.0
    let mut i = 0
    while i < len(divs) {
        let eb = exp_f(0.0 - beta * to_float(divs[i]))
        z = z + eb
        u = u + to_float(divs[i]) * eb
        i = i + 1
    }
    u / z
}

fn S_n(n: int, beta: float) -> float {
    beta * U_n(n, beta) + log(Z_n(n, beta))
}

fn Cv_n(n: int, beta: float) -> float {
    if beta < 1e-10 { return 0.0 }
    let db = 1e-5
    let du = U_n(n, beta + db) - U_n(n, beta - db)
    0.0 - beta * beta * du / (2.0 * db)
}

let betas = [0.01, 0.05, 0.10, 0.20, 0.30, 0.50, 0.70, 1.00, 1.50, 2.00, 3.00, 5.00]

