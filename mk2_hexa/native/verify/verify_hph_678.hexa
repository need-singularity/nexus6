    while bi <= 500 {
        let b = to_float(bi) * 0.006
        let cv = Cv_n(nn, b)
        if cv > max_cv {
            max_cv = cv
            best_b = b
        }
        bi = bi + 1
    }
    println("n=" + to_string(nn) + ": peak at beta=" + fmt4(best_b) + ", C_v_max=" + fmt6(max_cv))
    idx = idx + 1
}

