println("")
println(repeat_str("=", 80))
println("PART 2: S(n) SEARCH FOR n=1..2000")
println("S(n) = [sigma*phi - n*tau]^2 + [sigma*(n+phi) - n*tau^2]^2")
println(repeat_str("=", 80))
println("")

let mut s_zero = []
n = 1
while n <= 2000 {
    let s_n = sigma(n)
    let t_n = tau(n)
    let p_n = phi(n)
    let term1 = s_n * p_n - n * t_n
    let term2_ntau2 = n * t_n * t_n
    let term2_sig = s_n * (n + p_n)
    let term2 = term2_sig - term2_ntau2
    if term1 == 0 && term2 == 0 {
        s_zero = s_zero.push(n)
    }
    n = n + 1
}

println("All n with S(n)=0 in [1,2000]: " + to_string(s_zero))
println("Count: " + to_string(len(s_zero)))
println("")
println("| n | sigma | tau | phi | term1 | term2 | Perfect? |")
println("|---:|---:|---:|---:|---:|---:|:---:|")
idx = 0
while idx < len(s_zero) {
    let nn = s_zero[idx]
    let s_n = sigma(nn)
    let t_n = tau(nn)
    let p_n = phi(nn)
    let t1 = s_n * p_n - nn * t_n
    let t2 = s_n * (nn + p_n) - nn * t_n * t_n
    let mut perf = ""
    if sigma(nn) == 2 * nn { perf = "YES" }
    println("| " + to_string(nn) + " | " + to_string(s_n) + " | " + to_string(t_n) + " | " + to_string(p_n) + " | " + to_string(t1) + " | " + to_string(t2) + " | " + perf + " |")
    idx = idx + 1
}

