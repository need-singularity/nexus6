println("PART 4: ARITHMETIC ENTROPY (H-PH-7)")
println(repeat_str("=", 80))
println("")

fn f_factor(p: int, a: int) -> float {
    let pa = ipow(p, a)
    let sig_num = ipow(p, a + 1) - 1
    let sig_den = p - 1
    let sig_pa = sig_num / sig_den
    let phi_pa = pa - pa / p
    let tau_pa = a + 1
    to_float(sig_pa * phi_pa) / to_float(pa * tau_pa)
}

fn arithmetic_entropy(n: int) -> float {
    if n == 1 { return 0.0 }
    let factors = factorize(n)
    let ks = keys(factors)
    if len(ks) < 2 { return 0.0 }
    let mut f_vals = []
    let mut f_sum = 0.0
    let mut ki = 0
    while ki < len(ks) {
        let p = to_int(ks[ki])
        let a = factors[ks[ki]]
        let fv = f_factor(p, a)
        f_vals = f_vals.push(fv)
        f_sum = f_sum + fv
        ki = ki + 1
    }
    if f_sum == 0.0 { return 0.0 }
    let mut h = 0.0
    let mut wi = 0
    while wi < len(f_vals) {
        let w = f_vals[wi] / f_sum
        if w > 0.0 {
            h = h - w * log(w)
        }
        wi = wi + 1
    }
    h
}

println("### Arithmetic Entropy H_R(n) for select n")
println("")
println("| n | factors | H_R | H_max | H_R/H_max |")
println("|---:|:---|---:|---:|---:|")
let ent_ns = [6, 10, 12, 15, 28, 30, 42, 60, 66, 70, 78, 90, 105, 210, 496]
idx = 0
while idx < len(ent_ns) {
    let nn = ent_ns[idx]
    let factors = factorize(nn)
    let ks = keys(factors)
    let k = len(ks)
    if k >= 2 {
        let H = arithmetic_entropy(nn)
        let H_max = log(to_float(k))
        let mut ratio = 0.0
        if H_max > 0.0 { ratio = H / H_max }
        let mut fac_str = ""
        let mut fi = 0
        while fi < len(ks) {
            if fi > 0 { fac_str = fac_str + " x " }
            fac_str = fac_str + ks[fi] + "^" + to_string(factors[ks[fi]])
            fi = fi + 1
        }
        println("| " + to_string(nn) + " | " + fac_str + " | " + fmt4(H) + " | " + fmt4(H_max) + " | " + fmt4(ratio) + " |")
    }
    idx = idx + 1
}

