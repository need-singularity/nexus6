// 포팅 원본: tecs-l/math/verify_hph_678.py (413 LOC)
// H-PH-6, H-PH-7, H-PH-8: R-chain decay, Arithmetic entropy, Thermodynamic partition

let LN2 = log(2.0)
fn log2(x: float) -> float { log(x) / LN2 }

fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }
fn abs_i(x: int) -> int { if x < 0 { 0 - x } else { x } }

fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0 + 0.5)) / 10000.0
    to_string(r)
}
fn fmt6(x: float) -> string {
    let r = to_float(to_int(x * 500000.0 + 0.5)) / 500000.0
    to_string(r)
}
fn fmt2(x: float) -> string {
    let r = to_float(to_int(x * 100.0 + 0.5)) / 100.0
    to_string(r)
}
fn fmt1(x: float) -> string {
    let r = to_float(to_int(x * 10.0 + 0.5)) / 10.0
    to_string(r)
}

fn R(n: int) -> float {
    let s = sigma(n)
    let t = tau(n)
    let p = phi(n)
    to_float(s * p) / to_float(n * t)
}

fn divisors(n: int) -> [int] {
    let mut divs = []
    let mut i = 1
    while i * i <= n {
        if n % i == 0 {
            divs = divs.push(i)
            if i != n / i {
                divs = divs.push(n / i)
            }
        }
        i = i + 1
    }
    divs.sort()
}

fn factorize(n: int) -> map {
    let mut factors = #{}
    let mut d = 2
    let mut nn = n
    while d * d <= nn {
        while nn % d == 0 {
            if has_key(factors, to_string(d)) {
                factors[to_string(d)] = factors[to_string(d)] + 1
            } else {
                factors[to_string(d)] = 1
            }
            nn = nn / d
        }
        d = d + 1
    }
    if nn > 1 {
        if has_key(factors, to_string(nn)) {
            factors[to_string(nn)] = factors[to_string(nn)] + 1
        } else {
            factors[to_string(nn)] = 1
        }
    }
    factors
}

fn ipow(b: int, k: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < k {
        r = r * b
        i = i + 1
    }
    r
}

fn exp_f(x: float) -> float {
    pow(2.718281828459045, x)
}

fn repeat_str(s: string, n: int) -> string {
    let mut r = ""
    let mut i = 0
    while i < n {
        r = r + s
        i = i + 1
    }
    r
}

