let chain_starts = [120, 60, 28, 496]
idx = 0
while idx < len(chain_starts) {
    let st = chain_starts[idx]
    let chain = f_chain(st)
    // parse integer chain values
    let mut int_chain = []
    let mut ci = 0
    while ci < len(chain) {
        let cs = chain[ci]
        if !cs.contains("(") && !cs.contains("non") {
            let v = to_int(cs)
            if v > 0 || cs == "0" {
                int_chain = int_chain.push(v)
            }
        }
        ci = ci + 1
    }
    if len(int_chain) > 1 {
        let mut r_strs = []
        let mut mono = true
        let mut ri = 0
        let mut prev_r = 999.0
        while ri < len(int_chain) {
            let rv = R(int_chain[ri])
            r_strs = r_strs.push(fmt4(rv))
            if rv > prev_r { mono = false }
            prev_r = rv
            ri = ri + 1
        }
        let mut chain_strs = []
        let mut ci2 = 0
        while ci2 < len(int_chain) {
            chain_strs = chain_strs.push(to_string(int_chain[ci2]))
            ci2 = ci2 + 1
        }
        println("Start=" + to_string(st) + ":")
        println("  Chain: " + chain_strs.join(" -> "))
        println("  R:     " + r_strs.join(" -> "))
        let decay_label = if mono { "monotonic decrease" } else { "non-monotonic" }
        println("  Decay: " + decay_label)
        println("")
    }
    idx = idx + 1
}

