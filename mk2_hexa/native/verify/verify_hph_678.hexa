// beta* where U=phi
println("")
println("### beta* where U_n = phi(n)")
let bstar_ns = [6, 28]
idx = 0
while idx < len(bstar_ns) {
    let nn = bstar_ns[idx]
    let target = to_float(phi(nn))
    let mut lo = 0.001
    let mut hi = 20.0
    let mut iter = 0
    while iter < 100 {
        let mid = (lo + hi) / 2.0
        if U_n(nn, mid) > target { lo = mid } else { hi = mid }
        iter = iter + 1
    }
    let bs = (lo + hi) / 2.0
    println("n=" + to_string(nn) + ": beta*=" + fmt6(bs) + ", U=" + fmt6(U_n(nn, bs)) + "=phi(" + to_string(nn) + ")=" + to_string(phi(nn)))
    println("  Z=" + fmt6(Z_n(nn, bs)) + ", S=" + fmt6(S_n(nn, bs)) + ", C_v=" + fmt6(Cv_n(nn, bs)))
    let inv_e = 1.0 / 2.718281828459045
    println("  Compare: ln(4/3)=" + fmt6(log(4.0 / 3.0)) + ", 1/e=" + fmt6(inv_e))
    idx = idx + 1
}

