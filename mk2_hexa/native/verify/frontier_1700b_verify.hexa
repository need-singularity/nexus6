fn report_batch(name: string, ids: list, checks: list, pass_c: int, fail_c: int) -> list {
    println("")
    println("--- " + name + " (" + to_string(len(ids)) + ") ---")
    let mut p = pass_c
    let mut f = fail_c
    let mut i = 0
    while i < len(ids) {
        let ok = checks[i]
        let em = if ok { "🟧" } else { "⬛" }
        let st = if ok { "PASS" } else { "FAIL" }
        if ok { p = p + 1 } else { f = f + 1 }
        println("  " + em + " " + ids[i] + ": " + st)
        i = i + 1
    }
    [p, f]
}

println("======================================================================")
println("FRONTIER 1700b: 100 Pure Math Hypotheses")
