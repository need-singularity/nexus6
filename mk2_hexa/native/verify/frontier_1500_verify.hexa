fn fact(n: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= n { r = r * i  i = i + 1 }
    r
}

fn omega(n: int) -> int {
    let mut c = 0
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { c = c + 1 }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { c = c + 1 }
    c
}

fn pow_int(base: int, exp: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < exp { r = r * base  i = i + 1 }
    r
}

