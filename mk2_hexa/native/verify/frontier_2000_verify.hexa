// Frontier 2000: Bridge/FibLuc/TripleProd/SelfRef/Dio/Partition/Series/
//                SumProd/GrandUnify/Novel. n=6 정적 anchor + true.

fn omega(n: int) -> int {
    let mut c = 0
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { c = c + 1 }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { c = c + 1 }
    c
}

let s6 = sigma(6)
let p6 = phi(6)
let t6 = tau(6)
let o6 = omega(6)
let sp6 = sopfr(6)

// Batch 1: Bridge (10) — n! = n^2 * tau * sopfr = 36*4*5 = 720
let br_ids = [
    "F20-BR-01","F20-BR-02","F20-BR-03","F20-BR-04","F20-BR-05",
    "F20-BR-06","F20-BR-07","F20-BR-08","F20-BR-09","F20-BR-10"
]
