fn omega(n: int) -> int {
    let mut c = 0
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { c = c + 1 }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { c = c + 1 }
    c
}

let s6 = sigma(6)
let p6 = phi(6)
let t6 = tau(6)
let o6 = omega(6)
let sp6 = sopfr(6)

