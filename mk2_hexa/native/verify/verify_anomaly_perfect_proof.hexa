// Ported from tecs-l/verify/verify_anomaly_perfect_proof.py — 2026-04-10
// Anomaly cancellation requires dim(G)=496=P3 (3rd perfect number).
// E8xE8 and SO(32) both have dim 496.

fn is_perfect(n: int) -> bool {
    let mut s = 0
    let mut d = 1
    while d < n {
        if n % d == 0 { s = s + d }
        d = d + 1
    }
    s == n
}

// dim(SO(n)) = n(n-1)/2; for n=32 → 32*31/2 = 496
let dim_so32 = 32 * 31 / 2
// dim(E8) = 248; E8 x E8 = 496
let dim_e8 = 248
let dim_e8e8 = 2 * 248

// P3 = 496 = 2^4 * (2^5 - 1) = 16 * 31
let p3 = 16 * 31

// Green-Schwarz: n_V - n_H = 244, with n_H = 252
let gs_check = 244 + 252

let ids = [
    "ANOM-01","ANOM-02","ANOM-03","ANOM-04","ANOM-05","ANOM-06","ANOM-07"
]
let checks = [
    dim_so32 == 496,
    dim_e8e8 == 496,
    dim_so32 == dim_e8e8,
    p3 == 496,
    gs_check == 496,
    is_perfect(496),
    is_perfect(6)
]

println("======================================================================")
println("ANOMALY PROOF: dim(G)=496=P3")
println("======================================================================")
println("dim(SO(32))=" + to_string(dim_so32) + " dim(E8xE8)=" + to_string(dim_e8e8))
println("P3 = 2^4*(2^5-1) = " + to_string(p3))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
