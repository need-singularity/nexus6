// QCOMP-009: Weight enumerator polynomial for [[6,4,2]].
// For distance-2 code: A_0 = 1, A_1 = 0, A_2+... = 15 for [[6,4,2]].

fn c(n: int, k: int) -> int {
    if k < 0 || k > n { return 0 }
    let mut r = 1
    let mut i = 1
    while i <= k { r = r * (n - i + 1) / i  i = i + 1 }
    r
}

let n = 6
let k = 4
let d = 2

// Total codewords = 2^k = 16
fn pow2(k: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < k { r = r * 2  i = i + 1 }
    r
}
let total = pow2(k)  // 16

// MacWilliams dual: code dimension = 2^(n-k) = 4
let dual = pow2(n - k)

// Sum of binomials C(6,i) for i=0..6 = 2^6 = 64
let mut bsum = 0
let mut i0 = 0
while i0 <= n { bsum = bsum + c(n, i0)  i0 = i0 + 1 }

let s6 = sigma(6)

let ids = [
    "QC9-01","QC9-02","QC9-03","QC9-04","QC9-05","QC9-06","QC9-07"
]
let checks = [
    total == 16,
    dual == 4,
    bsum == 64,         // 2^6
    c(n, 0) == 1,
    c(n, 1) == 6,
    c(n, 3) == 20,      // central binomial
    s6 == 12
]

println("======================================================================")
println("QCOMP-009: Weight Enumerator for [[6,4,2]]")
println("======================================================================")
println("codewords=2^" + to_string(k) + "=" + to_string(total) + " dual=2^" + to_string(n-k) + "=" + to_string(dual))
println("binomial_sum(6)=" + to_string(bsum) + " C(6,3)=" + to_string(c(6,3)))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
