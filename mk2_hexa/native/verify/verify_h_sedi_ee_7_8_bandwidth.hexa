// Ported from tecs-l/verify/verify_h_sedi_ee_7_8_bandwidth.py — 2026-04-10
// H-SEDI-EE-8: Takens dim=6 by divisor richness.
// R(n) = sigma(n)*phi(n) / (n*tau(n))  — only n=6 has R(n)=1 in [2,100].
// (H-SEDI-EE-7 ln(4/3) bandwidth skipped — continuous only.)

// Compute R(n) as integer equation: sigma(n)*phi(n) == n*tau(n)
fn R_eq_one(n: int) -> bool {
    return sigma(n) * phi(n) == n * tau(n)
}

// Scan n = 2..100
let mut r_one_count = 0
let mut r_one_first = 0
let mut n = 2
while n <= 100 {
    if R_eq_one(n) {
        r_one_count = r_one_count + 1
        if r_one_first == 0 { r_one_first = n }
    }
    n = n + 1
}

// Takens range [4,8]: rank by tau(n)*10000/n (integer ratio scaled)
// n=4: tau=3, 3/4=0.75 → 7500
// n=5: tau=2, 2/5=0.40 → 4000
// n=6: tau=4, 4/6≈0.667 → 6666
// n=7: tau=2, 2/7≈0.286 → 2857
// n=8: tau=4, 4/8=0.50 → 5000
// Best in [4,8] by tau/n: n=4 (0.75), then n=6 (0.67), then n=8 (0.50)
// Note: n=4 wins, n=6 second. But n=6 uniquely has R(n)=1.
let t4 = tau(4)      // 3
let t5 = tau(5)      // 2
let t6 = tau(6)      // 4
let t7 = tau(7)      // 2
let t8 = tau(8)      // 4

// R(n) values (exact integer form sigma*phi vs n*tau)
// n=2: sigma=3,phi=1,tau=2 → 3*1 vs 2*2 = 3 vs 4 (no)
// n=6: sigma=12,phi=2,tau=4 → 12*2=24 vs 6*4=24 (yes, R=1)
let sp6 = sigma(6) * phi(6)          // 24
let nt6 = 6 * tau(6)                  // 24

// SEDI bandwidth connection: S(n)=ln(n!) integer factorials
// 3! = 6, 4! = 24, 6!/3! = 120, 4!/3! = 4
let f3 = 6       // 3!
let f4 = 24      // 4!
let f6 = 720     // 6!
let ratio_43 = f4 / f3    // 4  (24/6)

let ids = [
    "SE-01","SE-02","SE-03","SE-04","SE-05","SE-06","SE-07","SE-08","SE-09"
]
let checks = [
    r_one_count == 1,              // only one n in [2,100] with R(n)=1
    r_one_first == 6,              // and it is n=6
    sp6 == nt6,                    // explicit: sigma(6)*phi(6) = 6*tau(6)
    sp6 == 24,
    t6 == 4,
    t4 == 3,                       // tau(4)
    f3 == 6,                       // 3! = 6 (first perfect number!)
    f4 == 24,
    ratio_43 == 4                  // 4!/3! = 4 = tau(6)
]

println("======================================================================")
println("H-SEDI-EE-8: TAKENS dim=6 BY DIVISOR RICHNESS")
println("======================================================================")
println("R(n)=1 in [2,100]: count=" + to_string(r_one_count) + " first=" + to_string(r_one_first))
println("sigma(6)*phi(6)=" + to_string(sp6) + " = 6*tau(6)=" + to_string(nt6))
println("3!=6 4!=24 4!/3!=" + to_string(ratio_43))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
