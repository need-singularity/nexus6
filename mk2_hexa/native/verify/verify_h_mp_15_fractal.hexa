// mk2_hexa/native/verify_h_mp_15_fractal.hexa
// 포팅 원본: tecs-l/math/verify_h_mp_15_fractal.py (332 LOC)
// H-MP-15: R(n) spectrum Cantor-like structure
// Distribution + box-counting dim
//
// 범위: N=1500 (Python 50000 → 인터프리터 속도)

let N_MAX = 1500

fn fmt2(x: float) -> string {
    let r = to_float(to_int(x * 100.0)) / 100.0
    to_string(r)
}
fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0)) / 10000.0
    to_string(r)
}
fn fmt6(x: float) -> string {
    let r = to_float(to_int(x * 1000000.0)) / 1000000.0
    to_string(r)
}

fn R_val(n: int) -> float {
    to_float(sigma(n) * phi(n)) / to_float(n * tau(n))
}

println("══════════════════════════════════════════════════════════════════════")
println("H-MP-15: R(n) spectrum Cantor-like structure  (hexa port)")
println("  R(n) = σ(n)·φ(n) / (n·τ(n))")
println("══════════════════════════════════════════════════════════════════════")
println("")
println("  Computing R(n) for n=2.." + to_string(N_MAX) + "...")

// ─── Step 1: Compute all R(n), basic stats ───
let mut r_arr = []
let mut sum_r = 0.0
let mut sum_r2 = 0.0
let mut min_r = 1.0e99
let mut max_r = 0.0
let mut n = 2
while n <= N_MAX {
    let r = R_val(n)
    r_arr = r_arr + [r]
    sum_r = sum_r + r
    sum_r2 = sum_r2 + r * r
    if r < min_r { min_r = r }
    if r > max_r { max_r = r }
    n = n + 1
}
let count_n = N_MAX - 1
let mean_r = sum_r / to_float(count_n)
let var_r = sum_r2 / to_float(count_n) - mean_r * mean_r
let std_r = sqrt(if var_r < 0.0 { 0.0 } else { var_r })

println("")
println("  Total R values: " + to_string(count_n))
println("  Min:    " + fmt6(min_r))
println("  Max:    " + fmt2(max_r))
println("  Mean:   " + fmt4(mean_r))
println("  Std:    " + fmt4(std_r))

// ─── Step 2: Distribution by interval ───
println("")
println("══════════════════════════════════════════════════════════════════════")
println("DISTRIBUTION BY INTERVAL")
println("══════════════════════════════════════════════════════════════════════")
println("")
println("  Interval        |  count  | percentage")
println("  ----------------+---------+-----------")

let bounds_lo = [0.0, 0.5, 1.0, 1.5, 2.0, 3.0, 5.0, 10.0, 20.0, 50.0]
let bounds_hi = [0.5, 1.0, 1.5, 2.0, 3.0, 5.0, 10.0, 20.0, 50.0, 1000.0]
let mut bi = 0
while bi < len(bounds_lo) {
    let lo = bounds_lo[bi]
    let hi = bounds_hi[bi]
    let mut cnt = 0
    let mut i = 0
    while i < count_n {
        let r = r_arr[i]
        if r >= lo && r < hi { cnt = cnt + 1 }
        i = i + 1
    }
    let pct = 100.0 * to_float(cnt) / to_float(count_n)
    println("  [" + fmt2(lo) + ", " + fmt2(hi) + ")\t| " + to_string(cnt) + "\t  | " + fmt2(pct) + "%")
    bi = bi + 1
}

// ─── Step 3: Box-counting dimension in [0, 10] ───
println("")
println("══════════════════════════════════════════════════════════════════════")
println("BOX-COUNTING DIMENSION in [0, 10]")
println("══════════════════════════════════════════════════════════════════════")

// 추출: R values in [0, 10]
let mut vals_010 = []
let mut p = 0
while p < count_n {
    let r = r_arr[p]
    if r >= 0.0 && r <= 10.0 { vals_010 = vals_010 + [r] }
    p = p + 1
}
println("")
println("  R values in [0, 10]: " + to_string(len(vals_010)))

println("")
println("  ε       | N(ε) | log(1/ε) | log(N)")
println("  --------+------+----------+--------")
let epsilons = [0.5, 0.2, 0.1, 0.05, 0.02, 0.01]
let mut log_eps_inv = []
let mut log_N = []
let mut ei = 0
while ei < len(epsilons) {
    let eps = epsilons[ei]
    let n_boxes_max = to_int(10.0 / eps) + 1
    let mut occ = []
    let mut q = 0
    while q < n_boxes_max {
        occ = occ + [0]
        q = q + 1
    }
    let mut vi = 0
    while vi < len(vals_010) {
        let bi2 = to_int(vals_010[vi] / eps)
        if bi2 < n_boxes_max { occ[bi2] = 1 }
        vi = vi + 1
    }
    let mut N_eps = 0
    let mut oi = 0
    while oi < n_boxes_max {
        if occ[oi] == 1 { N_eps = N_eps + 1 }
        oi = oi + 1
    }
    let lie = log(1.0 / eps)
    let lN = log(to_float(N_eps))
    log_eps_inv = log_eps_inv + [lie]
    log_N = log_N + [lN]
    println("  " + fmt4(eps) + "  | " + to_string(N_eps) + "\t| " + fmt4(lie) + "    | " + fmt4(lN))
    ei = ei + 1
}

// Linear regression: log(N) = d · log(1/ε) + c
let nP = len(log_eps_inv)
let nF = to_float(nP)
let mut sx = 0.0
let mut sy = 0.0
let mut sxy = 0.0
let mut sxx = 0.0
let mut z = 0
while z < nP {
    sx = sx + log_eps_inv[z]
    sy = sy + log_N[z]
    sxy = sxy + log_eps_inv[z] * log_N[z]
    sxx = sxx + log_eps_inv[z] * log_eps_inv[z]
    z = z + 1
}
let d_box = (nF * sxy - sx * sy) / (nF * sxx - sx * sx)
let c_box = (sy - d_box * sx) / nF

println("")
println("  Linear fit: log(N) = " + fmt4(d_box) + " · log(1/ε) + " + fmt4(c_box))
println("  Box-counting dimension: d = " + fmt4(d_box))

if d_box < 1.0 {
    println("  → d < 1: CANTOR-LIKE fractal spectrum")
} else if d_box < 1.05 {
    println("  → d ≈ 1: borderline / dense")
} else {
    println("  → d > 1: densely fills interval")
}

// ─── Special: R(6) = 1 ───
println("")
println("══════════════════════════════════════════════════════════════════════")
println("SPECIAL POINT: R(6) = 1")
println("══════════════════════════════════════════════════════════════════════")
let r6 = R_val(6)
assert r6 == 1.0
println("  R(6) = " + to_string(r6) + " ✓ (master identity σφ = nτ)")
println("  → Anchored at exactly 1.0 within fractal R-spectrum")
