// Ported from tecs-l/verify/verify_dna_massive_mining.py — 2026-04-10
// Massive identity mining: equation templates unique to n=6 in [2, 1000].
// Canonical template: sigma(n)*phi(n) = n*tau(n) iff n=6.

fn omega_fn(n: int) -> int {
    let mut c = 0
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { c = c + 1 }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { c = c + 1 }
    c
}

// Template T1: sigma(n)*phi(n) == n*tau(n) → unique at 6
// Template T2: sigma(n) == 2*n (perfect numbers)
// Template T3: tau(n) + phi(n) == n → small solutions
// Scan 1..1000

let mut n = 1
let mut t1_matches = 0
let mut t2_matches = 0
let mut t3_matches = 0
while n <= 1000 {
    let sn = sigma(n)
    let pn = phi(n)
    let tn = tau(n)
    if sn * pn == n * tn { t1_matches = t1_matches + 1 }
    if sn == 2 * n { t2_matches = t2_matches + 1 }
    if tn + pn == n { t3_matches = t3_matches + 1 }
    n = n + 1
}

let ids = [
    "MM-01","MM-02","MM-03","MM-04","MM-05"
]
let checks = [
    t1_matches == 2,                      // n=1 (trivial) and n=6
    t2_matches >= 2,                      // 6, 28, 496 in [1,1000]
    t2_matches <= 3,
    t3_matches >= 1,                      // 6 (plus possibly 1)
    omega_fn(6) == 2
]

println("======================================================================")
println("DNA MASSIVE MINING: templates unique to n=6")
println("======================================================================")
println("T1 (sigma*phi=n*tau) matches: " + to_string(t1_matches))
println("T2 (perfect) matches: " + to_string(t2_matches))
println("T3 (tau+phi=n) matches: " + to_string(t3_matches))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
