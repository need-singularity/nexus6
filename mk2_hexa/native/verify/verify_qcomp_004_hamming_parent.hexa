// Ported from tecs-l/verify/verify_qcomp_004_hamming_parent.py — 2026-04-10
// QCOMP-004: [[6,4,2]] as child of classical Hamming family via dimension (6,4,2).

fn c(n: int, k: int) -> int {
    let mut r = 1
    let mut i = 1
    while i <= k { r = r * (n - i + 1) / i  i = i + 1 }
    r
}

// Classical Hamming [7,4,3]: perfect single-error code
let h_n = 7
let h_k = 4
let h_d = 3
// [[6,4,2]] and [7,4,3] share k=4. Ratio of n: 7/6. Redundancy: 7-4=3, 6-4=2.

let s6 = sigma(6)
let t6 = tau(6)

// Volume of Hamming ball radius 1 in F_2^7: 1 + 7 = 8 = 2^3 ⇒ perfect
let vol = 1 + h_n
let twok = 1
let mut i2 = 0
while i2 < 3 { twok = twok * 2  i2 = i2 + 1 }  // 8

let ids = [
    "QC4-01","QC4-02","QC4-03","QC4-04","QC4-05","QC4-06"
]
let checks = [
    h_n == 7,
    h_k == 4,
    h_k == t6,           // k = tau(6) = 4
    vol == twok,         // Hamming perfect
    h_n - h_k == 3,      // redundancy bits
    s6 == 12
]

println("======================================================================")
println("QCOMP-004: [7,4,3] Hamming parent vs [[6,4,2]] child")
println("======================================================================")
println("Hamming [7,4,3] ball_vol=" + to_string(vol) + " 2^3=" + to_string(twok))
println("Shared k=tau(6)=" + to_string(t6) + " sigma(6)=" + to_string(s6))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
