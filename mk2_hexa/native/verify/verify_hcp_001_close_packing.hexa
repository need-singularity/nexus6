// Ported from tecs-l/verify/verify_hcp_001_close_packing.py — 2026-04-10
// HCP-001: Close-Packed Structures — Coordination number 12 = sigma(6).
// HCP and FCC both have coordination 12 (kissing number in 3D).

let coord = 12
let s6 = sigma(6)       // 12
let kissing_3d = 12     // Newton-Gregory
let kissing_2d = 6      // Hexagonal (n=6)
let kissing_1d = 2      // 2 neighbors
let kissing_4d = 24     // D4 lattice, 24 = 2*12

// Packing density: pi / sqrt(18) ≈ 0.7405
// In micro units: 740480
let density_micro = 740480

// Integer tests on kissing numbers
let sum_k = kissing_1d + kissing_2d + kissing_3d  // 20

// 12 divisors/neighbors pattern: 6 + 6 triangle top/bottom + 6 mid
let upper = 6
let lower = 6
let middle = 6
let total_neighbors = upper + lower  // 12 for stacked hexagonal

let ids = [
    "HCP-01","HCP-02","HCP-03","HCP-04","HCP-05","HCP-06","HCP-07"
]
let checks = [
    coord == s6,
    coord == 12,
    kissing_2d == 6,     // phi/n=6 in 2D
    kissing_3d == 12,
    kissing_4d == 2 * coord,  // 24 = 2*12
    total_neighbors == coord,
    density_micro > 700000 && density_micro < 800000
]

println("======================================================================")
println("HCP-001: Close-Packed Coordination 12 = sigma(6)")
println("======================================================================")
println("coord=" + to_string(coord) + " sigma(6)=" + to_string(s6))
println("kissing: 1D=" + to_string(kissing_1d) + " 2D=" + to_string(kissing_2d) + " 3D=" + to_string(kissing_3d) + " 4D=" + to_string(kissing_4d))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
