// mk2_hexa/native/verify_h_nt_2.hexa
// 포팅 원본: tecs-l/math/verify_h_nt_2.py (160 LOC)
// H-NT-2: sopfr(n) = n-1  iff  n=6
//
// AI-native: @pure @memoize + @parallel 전수조사
// 이점: hexa sopfr() 빌트인 — sympy.factorint 완전 제거

// @pure — 표시용: 소인수분해 문자열 (trial division)
fn factor_str(n: int) -> string {
    let mut m = n
    let mut s = ""
    let mut p = 2
    while p * p <= m {
        if m % p == 0 {
            let mut e = 0
            while m % p == 0 {
                m = m / p
                e = e + 1
            }
            if s != "" { s = s + "*" }
            if e == 1 { s = s + to_string(p) } else { s = s + to_string(p) + "^" + to_string(e) }
        }
        p = p + 1
    }
    if m > 1 {
        if s != "" { s = s + "*" }
        s = s + to_string(m)
    }
    if s == "" { s = to_string(n) }
    s
}

// @pure — Omega(n) = total prime factors with multiplicity (trial division)
fn big_omega(n: int) -> int {
    let mut m = n
    let mut total = 0
    let mut p = 2
    while p * p <= m {
        while m % p == 0 {
            m = m / p
            total = total + 1
        }
        p = p + 1
    }
    if m > 1 { total = total + 1 }
    total
}

println("══════════════════════════════════════════════════════════════════════")
println("H-NT-2 Verification: sopfr(n) = n-1  iff  n=6  (hexa port)")
println("══════════════════════════════════════════════════════════════════════")

println("")
println("--- Detailed check n=2..50 ---")
println("    n |     factorization | sopfr |  n-1 | Match?")
println("  ----+--------------------+-------+------+-------")
let mut n = 2
while n <= 50 {
    let s = sopfr(n)
    let eq = s == n - 1
    let mark = if eq { " ***" } else { "" }
    println("  " + to_string(n) + "\t| " + factor_str(n) + "\t| " + to_string(s) + "\t| " + to_string(n - 1) + "\t| " + (if eq { "YES" } else { "no" }) + mark)
    n = n + 1
}

// ─── 전수 스캔 (@parallel counter loop) ───
println("")
println("--- Exhaustive scan n=2..10000 ---")
let mut solutions = []
let mut k = 2
while k <= 10000 {
    if sopfr(k) == k - 1 {
        solutions = solutions + [k]
    }
    k = k + 1
}
println("Total solutions in [2, 10000]: " + to_string(len(solutions)))
println("Solutions: " + to_string(solutions))

// ─── Omega >= 3 bound 검증 ───
println("")
println("--- n - sopfr(n) >= 2 for Omega(n) >= 3 (verification) ---")
let mut min_diff = 999999999
let mut min_n = 0
let mut m = 2
while m <= 10000 {
    if big_omega(m) >= 3 {
        let diff = m - sopfr(m)
        if diff < min_diff {
            min_diff = diff
            min_n = m
        }
    }
    m = m + 1
}
println("  Minimum (n - sopfr(n)) for Omega>=3 in [2, 10000]: " + to_string(min_diff) + " at n=" + to_string(min_n))
if min_diff >= 2 {
    println("  ✓ Confirms: n - sopfr(n) >= 2 for Omega(n) >= 3")
} else {
    println("  ✗ Counterexample found")
}

// ─── 증명 요약 ───
println("")
println("--- Proof summary ---")
println("  CASE 1 (prime p):        sopfr(p) = p ≠ p-1")
println("  CASE 2 (p^k, k≥2):       kp = p^k - 1 → no solutions")
println("  CASE 3 (pq, p<q primes): (p-1)(q-1)=2 → p=2, q=3 → n=6 ★")
println("  CASE 4 (Omega ≥ 3):      n - sopfr(n) ≥ 2 → no solution")
println("")
println("  ∴ n=6 is the UNIQUE solution. QED.")
