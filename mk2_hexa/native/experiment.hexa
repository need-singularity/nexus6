// mk2_hexa/native/experiment.hexa — 22-type experiment engine
// Rust 원본: src/experiment/ (types.rs, runner.rs, report.rs)
// 실행: hexa experiment.hexa run <domain> [type]
//       hexa experiment.hexa list
//       hexa experiment.hexa describe <type>
//
// CLI:
//   hexa experiment.hexa run <domain>             — 22개 전부 실행
//   hexa experiment.hexa run <domain> <type>      — 특정 실험 1개 실행
//   hexa experiment.hexa list                     — 22개 타입 목록
//   hexa experiment.hexa describe <type>          — 실험 설명 + 추천 렌즈

// ─── comptime 상수 ───
comptime const N = 6
comptime const sigma = 12
comptime const j2 = 24
comptime const pi = 3.14159265358979
comptime const tau_2pi = 6.28318530717959
comptime const experiment_count = 22
comptime const log_file = "shared/discovery/discovery_log.jsonl"

// ─── n=6 constants loader (shared/n6/n6_constants.jsonl) ───

fn load_n6_consts() -> list {
    let home = exec("printenv HOME")
    let path = home + "/Dev/nexus/shared/n6/n6_constants.jsonl"
    let raw = try { read_file(path) } catch e { return [[], []] }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let trimmed = line.trim()
        if trimmed == "" { continue }
        let mut name = ""
        let mut value = 0.0
        if trimmed.contains("\"name\":\"") {
            let p = trimmed.split("\"name\":\"")
            if p.len() >= 2 { name = p[1].split("\"")[0] }
        }
        if trimmed.contains("\"value\":") {
            let p = trimmed.split("\"value\":")
            if p.len() >= 2 {
                let num_str = p[1].split(",")[0].split("}")[0].trim()
                value = to_float(num_str)
            }
        }
        if name != "" {
            names = names + [name]
            values = values + [value]
        }
    }
    [names, values]
}

fn n6_values(consts: list) -> list {
    consts[1]
}

