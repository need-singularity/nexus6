fn type_description(t: string) -> string {
    if t == "Acceleration" { return "Accelerate data scale to observe speed/efficiency changes" }
    if t == "Collision" { return "Merge two systems and observe emergent properties" }
    if t == "Separation" { return "Split a system in two and compare halves" }
    if t == "Fusion" { return "Fuse multiple subsets into one unified structure" }
    if t == "Reversal" { return "Reverse the data ordering and observe invariance" }
    if t == "Destruction" { return "Inject noise to destroy structure, measure resilience" }
    if t == "Amplification" { return "Scale up weak signals to reveal hidden patterns" }
    if t == "Suppression" { return "Dampen strong signals to expose underlying structure" }
    if t == "Mutation" { return "Apply random perturbations and observe stability" }
    if t == "Crossover" { return "Swap segments between two datasets" }
    if t == "Isolation" { return "Isolate a subset and measure independent behavior" }
    if t == "Overload" { return "Duplicate/expand data beyond normal capacity" }
    if t == "Starvation" { return "Reduce data to minimum and observe core behavior" }
    if t == "TimeWarp" { return "Resample along time axis at different rates" }
    if t == "DimensionShift" { return "Add or remove data dimensions" }
    if t == "SymmetryBreak" { return "Remove symmetric components intentionally" }
    if t == "Resonance" { return "Find and amplify resonant frequencies" }
    if t == "Tension" { return "Gradually increase stress until breakpoint" }
    if t == "Compression" { return "Compress data to extract essential structure (PCA/SVD-like)" }
    if t == "Vibration" { return "Inject perturbations at varying frequencies" }
    if t == "Elasticity" { return "Deform then release, measure recovery fidelity" }
    if t == "Friction" { return "Simulate interface resistance between subsystems" }
    "Unknown experiment type"
}

