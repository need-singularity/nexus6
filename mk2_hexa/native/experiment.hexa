// ─── Metrics struct ───
struct Metrics {
    phi: float,
    entropy: float,
    connectivity: float,
    stability: float,
    complexity: float,
    n6_score: float
}

fn metrics_zero() -> Metrics {
    Metrics { phi: 0.0, entropy: 0.0, connectivity: 0.0, stability: 0.0, complexity: 0.0, n6_score: 0.0 }
}

fn metrics_delta(after: Metrics, before: Metrics) -> Metrics {
    Metrics {
        phi: after.phi - before.phi,
        entropy: after.entropy - before.entropy,
        connectivity: after.connectivity - before.connectivity,
        stability: after.stability - before.stability,
        complexity: after.complexity - before.complexity,
        n6_score: after.n6_score - before.n6_score
    }
}

