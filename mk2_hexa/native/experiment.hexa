fn domain_variability(target: string) -> float {
    if target == "physics" { return 0.05 }
    if target == "biology" { return 0.15 }
    if target == "chip" { return 0.02 }
    if target == "energy" { return 0.08 }
    if target == "battery" { return 0.1 }
    if target == "fusion" { return 0.12 }
    if target == "consciousness" { return 0.2 }
    if target == "quantum" { return 0.03 }
    if target == "math" { return 0.18 }
    if target == "ai" { return 0.08 }
    if target == "network" { return 0.06 }
    if target == "robot" { return 0.1 }
    if target == "material" { return 0.09 }
    if target == "software" { return 0.04 }
    0.1
}

// simple hash from string bytes
fn str_hash(s: string) -> float {
    let mut h = 0.0
    let mut i = 0
    while i < len(s) {
        h = h * 31.0 + to_float(char_at(s, i))
        i = i + 1
    }
    h
}

fn generate_probe_data(target: string) {
    let base = domain_base_values(target)
    let variability = domain_variability(target)
    let seed = str_hash(target)
    let profile_len = len(base)
    let data_len = 24
    let mut data = []
    let mut i = 0
    while i < data_len {
        let b = base[i % profile_len]
        // deterministic noise from seed+index
        let hash_val = seed * 6364136223.0 + to_float(i) * 1442695040.0
        // wrap to get fractional noise
        let noise_raw = hash_val - floor(hash_val / 10000.0) * 10000.0
        let noise_frac = (noise_raw / 10000.0 - 0.5) * 2.0 * variability
        let data = data.push(b * (1.0 + noise_frac))
        i = i + 1
    }
    data
}

// ─── Metrics measurement ───

fn abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    x
}

fn sqrt(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    // Newton's method 20 iterations
    let mut guess = x / 2.0
    if guess < 0.001 { guess = 0.001 }
    let mut i = 0
    while i < 20 {
        guess = (guess + x / guess) / 2.0
        i = i + 1
    }
    guess
}

fn ln_approx(x: float) -> float {
    // natural log approximation for x > 0
    if x <= 0.0 { return 0.0 }
    // use series: ln(1+u) for |u|<1, scale x to range
    let mut val = x
    let mut scale = 0.0
    while val > 2.0 {
        val = val / 2.718281828
        scale = scale + 1.0
    }
    while val < 0.5 {
        val = val * 2.718281828
        scale = scale - 1.0
    }
    // now val is near 1; ln(val) via series
    let u = val - 1.0
    let result = u - u*u/2.0 + u*u*u/3.0 - u*u*u*u/4.0
    result + scale
}

fn sin_approx(x: float) -> float {
    // reduce x to [-pi, pi]
    let mut v = x
    while v > 3.14159265 { v = v - 6.28318530 }
    while v < -3.14159265 { v = v + 6.28318530 }
    // Taylor series 7 terms
    let v3 = v * v * v
    let v5 = v3 * v * v
    let v7 = v5 * v * v
    v - v3 / 6.0 + v5 / 120.0 - v7 / 5040.0
}

fn cos_approx(x: float) -> float {
    sin_approx(x + 1.5707963)
}

fn clamp(x: float, lo: float, hi: float) -> float {
    if x < lo { return lo }
    if x > hi { return hi }
    x
}

fn max_f(a: float, b: float) -> float {
    if a > b { a } else { b }
}

fn min_f(a: float, b: float) -> float {
    if a < b { a } else { b }
}

fn max_i(a: int, b: int) -> int {
    if a > b { a } else { b }
}

fn min_i(a: int, b: int) -> int {
    if a < b { a } else { b }
}

fn measure_metrics(data) -> Metrics {
    let n = len(data)
    if n == 0 { return metrics_zero() }
    let nf = to_float(n)

    // mean
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + data[i]
        i = i + 1
    }
    let mean = sum / nf

    // variance -> phi
    let mut var_sum = 0.0
    let mut j = 0
    while j < n {
        let d = data[j] - mean
        var_sum = var_sum + d * d
        j = j + 1
    }
    let variance = var_sum / nf
    let phi = sqrt(variance)

    // entropy (Shannon-like)
    let mut sum_abs = 0.0
    let mut k = 0
    while k < n {
        sum_abs = sum_abs + abs(data[k])
        k = k + 1
    }
    let mut entropy = 0.0
    if sum_abs > 0.0 {
        let mut m = 0
        while m < n {
            let p = abs(data[m]) / sum_abs
            if p > 0.000000000000001 {
                entropy = entropy - p * ln_approx(p)
            }
            m = m + 1
        }
    }

    // connectivity (autocorrelation lag 1)
    let mut connectivity = 0.0
    if n > 1 {
        let mut pairs = 0.0
        let mut c = 0
        while c < n - 1 {
            pairs = pairs + (data[c] - mean) * (data[c + 1] - mean)
            c = c + 1
        }
        let denom = variance * (nf - 1.0)
        if denom > 0.000000000000001 {
            connectivity = abs(pairs / denom)
        }
    }

    // stability (1 - CoV)
    let mut stability = 0.0
    if abs(mean) > 0.000000000000001 {
        stability = clamp(1.0 - phi / abs(mean), 0.0, 1.0)
    }

    // complexity (distinct levels / n)
    // simplified: count number of distinct value buckets
    let mut levels = 1
    // sort data via simple selection sort on copy
    let mut sorted = []
    let mut si = 0
    while si < n {
        let sorted = sorted.push(data[si])
        si = si + 1
    }
    // bubble sort (small n=24 is fine)
    let mut pass = 0
    while pass < n {
        let mut q = 0
        while q < n - 1 {
            if sorted[q] > sorted[q + 1] {
                let tmp = sorted[q]
                let sorted = sorted.set(q, sorted[q + 1])
                let sorted = sorted.set(q + 1, tmp)
            }
            q = q + 1
        }
        pass = pass + 1
    }
    let mut li = 0
    while li < n - 1 {
        if abs(sorted[li + 1] - sorted[li]) > 0.01 {
            levels = levels + 1
        }
        li = li + 1
    }
    let complexity = to_float(levels) / nf

    // n6_score
    let _n6_data = load_n6_consts()
    let n6_consts = n6_values(_n6_data)
    let mut min_dist = 999999999.0
    let mut ni = 0
    while ni < len(n6_consts) {
        let d = abs(mean - n6_consts[ni])
        if d < min_dist { min_dist = d }
        ni = ni + 1
    }
    let n6_score = 1.0 / (1.0 + min_dist)

    Metrics {
        phi: phi,
        entropy: entropy,
        connectivity: connectivity,
        stability: stability,
        complexity: complexity,
        n6_score: n6_score
    }
}

// ─── Experiment config (domain-aware intensity/duration) ───

fn domain_params(target: string) {
    // returns [intensity, duration]
    if target == "physics" { return [0.50, 6.0] }
    if target == "biology" { return [0.60, 8.0] }
    if target == "chip" { return [0.40, 4.0] }
    if target == "energy" { return [0.55, 6.0] }
    if target == "battery" { return [0.65, 8.0] }
    if target == "fusion" { return [0.70, 10.0] }
    if target == "consciousness" { return [0.45, 12.0] }
    if target == "quantum" { return [0.35, 5.0] }
    if target == "math" { return [0.50, 6.0] }
    if target == "ai" { return [0.55, 8.0] }
    if target == "network" { return [0.45, 7.0] }
    if target == "robot" { return [0.50, 6.0] }
    if target == "material" { return [0.55, 6.0] }
    if target == "software" { return [0.40, 5.0] }
    [0.50, 6.0]
}

// ─── Experiment manipulations ───

fn apply_acceleration(data, intensity: float) {
    let factor = 1.0 + intensity * 6.0
    let mut result = []
    let mut i = 0
    while i < len(data) {
        let result = result.push(data[i] * factor)
        i = i + 1
    }
    result
}

fn apply_collision(data, intensity: float) {
    let n = len(data)
    let shift = to_int(to_float(n) * intensity) + 1
    let mut result = []
    let mut i = 0
    while i < n {
        let partner = data[(i + shift) % n]
        let val = (data[i] + partner * intensity) / (1.0 + intensity)
        let result = result.push(val)
        i = i + 1
    }
    result
}

fn apply_separation(data, intensity: float) {
    let n = len(data)
    let keep = to_int((1.0 - intensity) * to_float(n)) + 1
    let mut result = []
    let mut i = 0
    while i < n {
        if i < keep {
            let result = result.push(data[i])
        } else {
            let result = result.push(0.0)
        }
        i = i + 1
    }
    result
}

fn apply_fusion(data, intensity: float) {
    let n = len(data)
    let window = to_int(intensity * 5.0) + 1
    let mut result = []
    let mut i = 0
    while i < n {
        let start = max_i(0, i - window / 2)
        let end = min_i(n, i + window / 2 + 1)
        let mut s = 0.0
        let mut j = start
        while j < end {
            s = s + data[j]
            j = j + 1
        }
        let result = result.push(s / to_float(end - start))
        i = i + 1
    }
    result
}

fn apply_reversal(data) {
    let n = len(data)
    let mut result = []
    let mut i = n - 1
    while i >= 0 {
        let result = result.push(data[i])
        i = i - 1
    }
    result
}

fn apply_destruction(data, intensity: float) {
    let mut result = []
    let mut i = 0
    while i < len(data) {
        let noise = sin_approx(to_float(i) * 7.3 + 13.7) * intensity * abs(data[i])
        let result = result.push(data[i] + noise)
        i = i + 1
    }
    result
}

fn apply_amplification(data, intensity: float) {
    let n = len(data)
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + data[i]
        i = i + 1
    }
    let mean = sum / to_float(n)
    let factor = 1.0 + intensity * 12.0
    let mut result = []
    let mut j = 0
    while j < n {
        let result = result.push(mean + (data[j] - mean) * factor)
        j = j + 1
    }
    result
}

fn apply_suppression(data, intensity: float) {
    let n = len(data)
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + data[i]
        i = i + 1
    }
    let mean = sum / to_float(n)
    let factor = 1.0 - intensity * 0.9
    let mut result = []
    let mut j = 0
    while j < n {
        let result = result.push(mean + (data[j] - mean) * factor)
        j = j + 1
    }
    result
}

fn apply_mutation(data, intensity: float) {
    let mut result = []
    let mut i = 0
    while i < len(data) {
        let perturbation = cos_approx(to_float(i) * 3.7 + 2.1) * intensity * 6.0
        let result = result.push(data[i] + perturbation)
        i = i + 1
    }
    result
}

fn apply_crossover(data, intensity: float) {
    let n = len(data)
    let mid = n / 2
    let mut result = []
    let mut i = 0
    while i < n {
        let result = result.push(data[i])
        i = i + 1
    }
    let mut k = 0
    let swap_len = min_i(mid, n - mid)
    while k < swap_len {
        let a = data[k]
        let b = data[mid + k]
        let result = result.set(k, a * (1.0 - intensity) + b * intensity)
        let result = result.set(mid + k, b * (1.0 - intensity) + a * intensity)
        k = k + 1
    }
    result
}

fn apply_isolation(data, intensity: float) {
    let n = len(data)
    let keep = to_int((1.0 - intensity) * to_float(n)) + 1
    let start = (n - keep) / 2
    let end = start + keep
    let mut result = []
    let mut i = 0
    while i < n {
        if i >= start {
            if i < end {
                let result = result.push(data[i])
            } else {
                let result = result.push(0.0)
            }
        } else {
            let result = result.push(0.0)
        }
        i = i + 1
    }
    result
}

fn apply_overload(data, duration: int) {
    let mut result = []
    let mut rep = 0
    while rep < duration {
        let mut i = 0
        while i < len(data) {
            let result = result.push(data[i])
            i = i + 1
        }
        rep = rep + 1
    }
    result
}

fn apply_starvation(data, intensity: float) {
    let n = len(data)
    let keep = max_i(1, to_int((1.0 - intensity * 0.9) * to_float(n)) + 1)
    let mut result = []
    let mut i = 0
    while i < keep {
        let result = result.push(data[i])
        i = i + 1
    }
    result
}

fn apply_time_warp(data, intensity: float) {
    let n = len(data)
    let rate = 1.0 + intensity * 2.0
    let new_len = to_int(to_float(n) * rate) + 1
    let mut result = []
    let mut i = 0
    while i < new_len {
        let src = min_f(to_float(i) / rate, to_float(n - 1))
        let lo = to_int(src)
        let hi = min_i(lo + 1, n - 1)
        let frac = src - to_float(lo)
        let val = data[lo] * (1.0 - frac) + data[hi] * frac
        let result = result.push(val)
        i = i + 1
    }
    result
}

fn apply_dimension_shift(data, intensity: float) {
    let n = len(data)
    let extra = to_int(intensity * to_float(n)) + 1
    let mut result = []
    let mut i = 0
    while i < n {
        let result = result.push(data[i])
        i = i + 1
    }
    let mut j = 0
    while j < min_i(extra, n) {
        let result = result.push(data[j] * data[j] / 6.0)
        j = j + 1
    }
    result
}

fn apply_symmetry_breaking(data, intensity: float) {
    let n = len(data)
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + data[i]
        i = i + 1
    }
    let mean = sum / to_float(n)
    let mut result = []
    let mut j = 0
    while j < n {
        let result = result.push(data[j] - mean * intensity)
        j = j + 1
    }
    result
}

fn apply_resonance(data, intensity: float) {
    let n = len(data)
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + data[i]
        i = i + 1
    }
    let mean = sum / to_float(n)

    // find dominant lag via autocorrelation
    let mut best_lag = 1
    let mut best_corr = -999999999.0
    let mut lag = 1
    while lag < n / 2 {
        let mut corr = 0.0
        let mut c = 0
        while c < n - lag {
            corr = corr + (data[c] - mean) * (data[(c + lag) % n] - mean)
            c = c + 1
        }
        if corr > best_corr {
            best_corr = corr
            best_lag = lag
        }
        lag = lag + 1
    }

    let mut result = []
    let mut j = 0
    while j < n {
        let resonant = sin_approx(to_float(j) / to_float(best_lag) * 6.28318530)
        let result = result.push(data[j] + resonant * intensity * 6.0)
        j = j + 1
    }
    result
}

fn apply_tension(data, intensity: float, duration: int) {
    // returns [breakpoint, modified_data...]
    let n = len(data)
    let orig_metrics = measure_metrics(data)
    let base_stab = orig_metrics.stability
    let threshold = base_stab * 0.5
    let steps = max_i(1, duration)

    let mut breakpoint = 1.0
    let mut result = []
    let mut ri = 0
    while ri < n {
        let result = result.push(data[ri])
        ri = ri + 1
    }

    let mut step = 1
    let mut found = false
    while step <= steps {
        if found == false {
            let stress = intensity * (to_float(step) / to_float(steps))
            let mut stressed = []
            let mut si = 0
            while si < n {
                let strain = sin_approx(to_float(si) * 5.3 + to_float(step)) * stress * abs(data[si])
                let stressed = stressed.push(data[si] + strain)
                si = si + 1
            }
            let m = measure_metrics(stressed)
            breakpoint = stress
            result = stressed
            if m.stability < threshold {
                found = true
            }
        }
        step = step + 1
    }

    // encode breakpoint as first element
    let mut out = []
    let out = out.push(breakpoint)
    let mut oi = 0
    while oi < len(result) {
        let out = out.push(result[oi])
        oi = oi + 1
    }
    out
}

fn apply_compression(data, intensity: float) {
    let n = len(data)
    let keep = max_i(1, to_int((1.0 - intensity * 0.8) * to_float(n)) + 1)

    // build indexed array, sort by magnitude desc, keep top-k
    let mut indexed = []
    let mut i = 0
    while i < n {
        let indexed = indexed.push([to_float(i), abs(data[i])])
        i = i + 1
    }
    // bubble sort by magnitude desc
    let mut pass = 0
    while pass < n {
        let mut q = 0
        while q < n - 1 {
            if indexed[q][1] < indexed[q + 1][1] {
                let tmp = indexed[q]
                let indexed = indexed.set(q, indexed[q + 1])
                let indexed = indexed.set(q + 1, tmp)
            }
            q = q + 1
        }
        pass = pass + 1
    }

    let mut result = []
    let mut ri = 0
    while ri < n {
        let result = result.push(0.0)
        ri = ri + 1
    }
    let mut k = 0
    while k < keep {
        if k < n {
            let idx = to_int(indexed[k][0])
            let result = result.set(idx, data[idx])
        }
        k = k + 1
    }
    result
}

fn apply_vibration(data, intensity: float) {
    let mut result = []
    let mut i = 0
    while i < len(data) {
        let fi = to_float(i)
        let v1 = sin_approx(fi * 1.0) * intensity
        let v2 = sin_approx(fi * 2.5) * intensity * 0.5
        let v3 = sin_approx(fi * 6.0) * intensity * 0.25
        let result = result.push(data[i] + v1 + v2 + v3)
        i = i + 1
    }
    result
}

fn apply_elasticity(data, intensity: float) {
    let n = len(data)
    let recovery = 1.0 - intensity * 0.3
    let mut result = []
    let mut i = 0
    while i < n {
        let deformation = sin_approx(to_float(i) * 4.1) * intensity * abs(data[i])
        let deformed = data[i] + deformation
        let val = data[i] * recovery + deformed * (1.0 - recovery)
        let result = result.push(val)
        i = i + 1
    }
    result
}

fn apply_friction(data, intensity: float) {
    let n = len(data)
    let passes = to_int(intensity * 6.0) + 1
    let mut result = []
    let mut i = 0
    while i < n {
        let result = result.push(data[i])
        i = i + 1
    }
    let mut p = 0
    while p < passes {
        let mut prev = []
        let mut ci = 0
        while ci < n {
            let prev = prev.push(result[ci])
            ci = ci + 1
        }
        let mut j = 1
        while j < n - 1 {
            let val = prev[j] * (1.0 - intensity * 0.5) + (prev[j - 1] + prev[j + 1]) * intensity * 0.25
            let result = result.set(j, val)
            j = j + 1
        }
        p = p + 1
    }
    result
}

// ─── Apply experiment dispatcher ───

fn apply_experiment(exp_type: string, data, intensity: float, duration: int) {
    // returns [breakpoint_or_neg1, modified_data...]
    if exp_type == "Tension" {
        return apply_tension(data, intensity, duration)
    }
    let mut modified = []
    if exp_type == "Acceleration" { modified = apply_acceleration(data, intensity) }
    if exp_type == "Collision" { modified = apply_collision(data, intensity) }
    if exp_type == "Separation" { modified = apply_separation(data, intensity) }
    if exp_type == "Fusion" { modified = apply_fusion(data, intensity) }
    if exp_type == "Reversal" { modified = apply_reversal(data) }
    if exp_type == "Destruction" { modified = apply_destruction(data, intensity) }
    if exp_type == "Amplification" { modified = apply_amplification(data, intensity) }
    if exp_type == "Suppression" { modified = apply_suppression(data, intensity) }
    if exp_type == "Mutation" { modified = apply_mutation(data, intensity) }
    if exp_type == "Crossover" { modified = apply_crossover(data, intensity) }
    if exp_type == "Isolation" { modified = apply_isolation(data, intensity) }
    if exp_type == "Overload" { modified = apply_overload(data, duration) }
    if exp_type == "Starvation" { modified = apply_starvation(data, intensity) }
    if exp_type == "TimeWarp" { modified = apply_time_warp(data, intensity) }
    if exp_type == "DimensionShift" { modified = apply_dimension_shift(data, intensity) }
    if exp_type == "SymmetryBreak" { modified = apply_symmetry_breaking(data, intensity) }
    if exp_type == "Resonance" { modified = apply_resonance(data, intensity) }
    if exp_type == "Compression" { modified = apply_compression(data, intensity) }
    if exp_type == "Vibration" { modified = apply_vibration(data, intensity) }
    if exp_type == "Elasticity" { modified = apply_elasticity(data, intensity) }
    if exp_type == "Friction" { modified = apply_friction(data, intensity) }
    if len(modified) == 0 { modified = data }
    // prepend -1.0 (no breakpoint)
    let mut out = []
    let out = out.push(-1.0)
    let mut oi = 0
    while oi < len(modified) {
        let out = out.push(modified[oi])
        oi = oi + 1
    }
    out
}

// ─── Discovery detection ───

fn detect_discoveries(exp_type: string, before: Metrics, after: Metrics, breakpoint: float) {
    let mut discoveries = []

    // n6_score improvement
    let n6_delta = after.n6_score - before.n6_score
    if n6_delta > 0.05 {
        let discoveries = discoveries.push(exp_type + ": n6_score improved by " + to_string(n6_delta))
    }

    // complexity emergence
    let complexity_delta = after.complexity - before.complexity
    if complexity_delta > 0.1 {
        let discoveries = discoveries.push(exp_type + ": complexity emerged (+" + to_string(complexity_delta) + ")")
    }

    // stability anomaly
    let stab_delta = abs(after.stability - before.stability)
    if stab_delta > 0.3 {
        let discoveries = discoveries.push(exp_type + ": stability anomaly (delta=" + to_string(stab_delta) + ")")
    }

    // breakpoint near n=6 fractions
    if breakpoint >= 0.0 {
        let n6_fracs = [0.166667, 0.333333, 0.5, 0.666667, 0.833333, 1.0]
        let mut fi = 0
        while fi < 6 {
            if abs(breakpoint - n6_fracs[fi]) < 0.05 {
                let discoveries = discoveries.push(exp_type + ": breakpoint " + to_string(breakpoint) + " near n=6 fraction " + to_string(n6_fracs[fi]))
            }
            fi = fi + 1
        }
    }

    discoveries
}

// ─── Run single experiment ───

struct ExperimentResult {
    exp_type: string,
    before: Metrics,
    after: Metrics,
    delta: Metrics,
    breakpoint: float,
    discoveries: str
}

fn run_experiment(exp_type: string, target: string) -> ExperimentResult {
    let data = generate_probe_data(target)
    let before = measure_metrics(data)

    let params = domain_params(target)
    let intensity = clamp(params[0], 0.01, 1.0)
    let duration = max_i(1, to_int(params[1]))

    let raw = apply_experiment(exp_type, data, intensity, duration)
    let breakpoint = raw[0]
    let mut modified = []
    let mut i = 1
    while i < len(raw) {
        let modified = modified.push(raw[i])
        i = i + 1
    }

    let after = measure_metrics(modified)
    let delta = metrics_delta(after, before)
    let discoveries = detect_discoveries(exp_type, before, after, breakpoint)

    ExperimentResult {
        exp_type: exp_type,
        before: before,
        after: after,
        delta: delta,
        breakpoint: breakpoint,
        discoveries: discoveries
    }
}

// ─── Report formatting ───

fn pad_right(s: string, width: int) -> string {
    let mut out = s
    while len(out) < width {
        out = out + " "
    }
    out
}

fn fmt_float(x: float, prec: int) -> string {
    // simple: just use to_string
    to_string(x)
}

fn format_report(results) {
    println("+-----------------+----------+----------+----------+----------+----------+----------+")
    println("| Experiment      |  Phi D   | Entropy  | Connect. | Stable   | N6 Score | Breakpt  |")
    println("+-----------------+----------+----------+----------+----------+----------+----------+")

    let mut total_disc = 0
    let mut sum_n6 = 0.0
    let mut bp_count = 0
    let mut all_disc = []

    let mut i = 0
    while i < len(results) {
        let r = results[i]
        let bp_str = if r.breakpoint >= 0.0 { to_string(r.breakpoint) } else { "-" }
        println("| " + pad_right(r.exp_type, 15) + " | " + pad_right(to_string(r.delta.phi), 8) + " | " + pad_right(to_string(r.delta.entropy), 8) + " | " + pad_right(to_string(r.delta.connectivity), 8) + " | " + pad_right(to_string(r.delta.stability), 8) + " | " + pad_right(to_string(r.after.n6_score), 8) + " | " + pad_right(bp_str, 8) + " |")

        sum_n6 = sum_n6 + r.after.n6_score
        if r.breakpoint >= 0.0 { bp_count = bp_count + 1 }
        let mut di = 0
        while di < len(r.discoveries) {
            total_disc = total_disc + 1
            let all_disc = all_disc.push(r.discoveries[di])
            di = di + 1
        }
        i = i + 1
    }

    println("+-----------------+----------+----------+----------+----------+----------+----------+")

    let n = len(results)
    let avg_n6 = if n > 0 { sum_n6 / to_float(n) } else { 0.0 }
    println("")
    println("  Experiments: " + to_string(n) + "  |  Breakpoints: " + to_string(bp_count) + "  |  Discoveries: " + to_string(total_disc) + "  |  Avg N6: " + to_string(avg_n6))

    if total_disc > 0 {
        println("")
        println("  Discoveries:")
        let mut di = 0
        while di < len(all_disc) {
            println("    * " + all_disc[di])
            di = di + 1
        }
    }
}

// ─── CLI ───

fn main() {
    let a = args()
    let argc = len(a)

    if argc < 2 {
        println("Usage:")
        println("  hexa experiment.hexa run <domain> [type]")
        println("  hexa experiment.hexa list")
        println("  hexa experiment.hexa describe <type>")
        return 0
    }

    let cmd = a[1]

    if cmd == "list" {
        let names = all_type_names()
        println("=== 22 Experiment Types ===")
        let mut i = 0
        while i < len(names) {
            println("  " + to_string(i + 1) + ". " + names[i])
            i = i + 1
        }
        return 0
    }

    if cmd == "describe" {
        if argc < 3 {
            println("Usage: hexa experiment.hexa describe <type>")
            return 1
        }
        let t = normalize_type(a[2])
        if t == "" {
            println("ERROR: unknown experiment type: " + a[2])
            return 1
        }
        println("=== " + t + " ===")
        println("Description: " + type_description(t))
        println("Recommended lenses: " + recommended_lenses(t))
        return 0
    }

    if cmd == "run" {
        if argc < 3 {
            println("Usage: hexa experiment.hexa run <domain> [type]")
            return 1
        }
        let domain = a[2]

        if argc >= 4 {
            // single experiment
            let t = normalize_type(a[3])
            if t == "" {
                println("ERROR: unknown experiment type: " + a[3])
                return 1
            }
            println("=== Running " + t + " on " + domain + " ===")
            let result = run_experiment(t, domain)
            println("[" + result.exp_type + "] phi=" + to_string(result.delta.phi) + " entropy=" + to_string(result.delta.entropy) + " n6=" + to_string(result.after.n6_score) + " bp=" + to_string(result.breakpoint) + " discoveries=" + to_string(len(result.discoveries)))
            let mut di = 0
            while di < len(result.discoveries) {
                println("  * " + result.discoveries[di])
                di = di + 1
            }
            return 0
        }

        // run all 22
        println("=== Running all 22 experiments on " + domain + " ===")
        let names = all_type_names()
        let mut results = []
        let mut i = 0
        while i < len(names) {
            let r = run_experiment(names[i], domain)
            let results = results.push(r)
            i = i + 1
        }
        format_report(results)
        return 0
    }

    println("Unknown command: " + cmd)
    println("Commands: run, list, describe")
    1
}

main()
