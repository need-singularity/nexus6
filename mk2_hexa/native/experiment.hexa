    if target == "consciousness" { return [0.3, 0.8, 1.5, 3.0, 2.718, 1.618, 0.618, 6.0, 12.0, 3.14159, 0.5, 1.0] }
    if target == "quantum" { return [1000.0, 0.999, 0.9999, 100.0, 0.001, 17.0, 7.0, 3.0, 72.0, 53.0, 127.0, 433.0] }
    if target == "math" { return [3.14159, 2.71828, 1.61803, 1.41421, 0.57722, 0.91597, 1.20206, 6.0, 28.0, 496.0, 12.0, 24.0] }
    if target == "ai" { return [0.001, 8192.0, 12.0, 96.0, 4096.0, 0.1, 2000.0, 0.9, 0.95, 128.0, 32000.0, 0.288] }
