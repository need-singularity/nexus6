// mk2_hexa/native/real_breakthrough.hexa — Real-Data Breakthrough Engine
// 실행: hexa mk2_hexa/native/real_breakthrough.hexa scan|histogram|clusters|surprise|live
//
// 3 data sources: discovery_log.jsonl + math_atlas.json + live macOS metrics (exec)
// Core: filter "already known" -> histogram -> clusters -> cross-source resonance -> surprise
// Only reports genuinely NEW findings, not recombinations of hardcoded n=6 constants.

// ═══════════════════════════════════════════════════════════
// ─── MATH UTILITIES ───
// ═══════════════════════════════════════════════════════════

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

fn min_f(a: f64, b: f64) -> f64 {
    if a < b { return a }
    return b
}

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {}
    return v
}

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 15 {
        g = (g + x / g) / 2.0
        i = i + 1
    }
    return g
}

fn ln_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut sum = 0.0
    let mut term = (x - 1.0) / (x + 1.0)
    let t2 = term * term
    let mut k: i64 = 1
    while k <= 15 {
        sum = sum + term / to_float(k)
        term = term * t2
        k = k + 2
    }
    return 2.0 * sum
}

fn round2(x: f64) -> string {
    let i = to_int(x * 100.0 + 0.5)
    let whole = i / 100
    let frac = i - whole * 100
    let mut fs = to_string(frac)
    if frac < 10 { fs = "0" + fs }
    return to_string(whole) + "." + fs
}

fn round4f(x: f64) -> f64 {
    return to_float(to_int(x * 10000.0 + 0.5)) / 10000.0
}

// ═══════════════════════════════════════════════════════════
// ─── KNOWN n=6 CONSTANTS (filter: NOT a discovery) ───
// ═══════════════════════════════════════════════════════════

// Every value already in the n6 constant table. We skip these.
fn known_n6_val(idx: i64) -> f64 {
    if idx == 0 { return 6.0 }
    if idx == 1 { return 12.0 }
    if idx == 2 { return 2.0 }
    if idx == 3 { return 4.0 }
    if idx == 4 { return 5.0 }
    if idx == 5 { return 24.0 }
    if idx == 6 { return 7.0 }
    if idx == 7 { return 10.0 }
    if idx == 8 { return 8.0 }
    if idx == 9 { return 3.0 }
    if idx == 10 { return 1.0 }
    if idx == 11 { return 36.0 }
    if idx == 12 { return 48.0 }
    if idx == 13 { return 60.0 }
    if idx == 14 { return 120.0 }
    if idx == 15 { return 30.0 }
    if idx == 16 { return 144.0 }
    if idx == 17 { return 288.0 }
    if idx == 18 { return 28.0 }
    if idx == 19 { return 496.0 }
    if idx == 20 { return 720.0 }
    if idx == 21 { return 8128.0 }
    if idx == 22 { return 0.333333 }
    if idx == 23 { return 0.166667 }
    if idx == 24 { return 0.083333 }
    if idx == 25 { return 1.618034 }
    if idx == 26 { return 0.287682 }
    return 0.0
}

fn known_n6_name(idx: i64) -> string {
    if idx == 0 { return "n" }
    if idx == 1 { return "sigma" }
    if idx == 2 { return "phi" }
    if idx == 3 { return "tau" }
    if idx == 4 { return "sopfr" }
    if idx == 5 { return "J2" }
    if idx == 6 { return "M3" }
    if idx == 7 { return "sigma-phi" }
    if idx == 8 { return "phi*tau" }
    if idx == 9 { return "n/phi" }
    if idx == 10 { return "mu" }
    if idx == 11 { return "n^2" }
    if idx == 12 { return "sigma*tau" }
    if idx == 13 { return "sigma*sopfr" }
    if idx == 14 { return "sigma*(s-p)" }
    if idx == 15 { return "sopfr*n" }
    if idx == 16 { return "sigma^2" }
    if idx == 17 { return "sigma*J2" }
    if idx == 18 { return "P2" }
    if idx == 19 { return "P3" }
    if idx == 20 { return "6!" }
    if idx == 21 { return "P4" }
    if idx == 22 { return "1/3" }
    if idx == 23 { return "1/6" }
    if idx == 24 { return "1/12" }
    if idx == 25 { return "golden" }
    if idx == 26 { return "Omega_J" }
    return ""
}

comptime const N6_COUNT = 27

fn physics_val(idx: i64) -> f64 {
    if idx == 0 { return 137.036 }
    if idx == 1 { return 1836.15 }
    if idx == 2 { return 0.3153 }
    if idx == 3 { return 0.6847 }
    if idx == 4 { return 0.0729 }
    if idx == 5 { return 3.14159 }
    if idx == 6 { return 2.71828 }
    if idx == 7 { return 0.69315 }
    if idx == 8 { return 1.41421 }
    if idx == 9 { return 1.73205 }
    return 0.0
}

fn physics_name(idx: i64) -> string {
    if idx == 0 { return "alpha_inv" }
    if idx == 1 { return "mp/me" }
    if idx == 2 { return "Omega_m" }
    if idx == 3 { return "Omega_L" }
    if idx == 4 { return "alpha" }
    if idx == 5 { return "pi" }
    if idx == 6 { return "e" }
    if idx == 7 { return "ln2" }
    if idx == 8 { return "sqrt2" }
    if idx == 9 { return "sqrt3" }
    return ""
}

comptime const PHYS_COUNT = 10

fn is_known_n6(v: f64) -> bool {
    let mut i: i64 = 0
    while i < N6_COUNT {
        let c = known_n6_val(i)
        if c > 0.001 {
            if abs_f(v - c) / max_f(abs_f(c), 0.001) < 0.001 { return true }
        } else {
            if abs_f(v - c) < 0.0005 { return true }
        }
        i = i + 1
    }
    return false
}

// Closest n6 constant name + distance %
fn nearest_n6(v: f64) -> string {
    let mut best_d = 999999.0
    let mut best_name = "?"
    let mut i: i64 = 0
    while i < N6_COUNT {
        let c = known_n6_val(i)
        if c != 0.0 {
            let d = abs_f(v - c) / max_f(abs_f(c), 0.001)
            if d < best_d { best_d = d; best_name = known_n6_name(i) }
        }
        i = i + 1
    }
    // Also check n6 ratios/products (first 7 core constants)
    i = 0
    while i < 7 {
        let mut j: i64 = 0
        while j < 7 {
            if i != j {
                let va = known_n6_val(i)
                let vb = known_n6_val(j)
                if vb != 0.0 {
                    let ratio = va / vb
                    let d_r = abs_f(v - ratio) / max_f(abs_f(ratio), 0.001)
                    if d_r < best_d { best_d = d_r; best_name = known_n6_name(i) + "/" + known_n6_name(j) }
                    let prod = va * vb
                    if prod < 10000.0 {
                        let d_p = abs_f(v - prod) / max_f(abs_f(prod), 0.001)
                        if d_p < best_d { best_d = d_p; best_name = known_n6_name(i) + "*" + known_n6_name(j) }
                    }
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    return best_name + "(" + round2(best_d * 100.0) + "%)"
}

fn nearest_physics(v: f64) -> string {
    let mut best_d = 999999.0
    let mut best_name = "?"
    let mut i: i64 = 0
    while i < PHYS_COUNT {
        let c = physics_val(i)
        if c != 0.0 {
            let d = abs_f(v - c) / max_f(abs_f(c), 0.001)
            if d < best_d { best_d = d; best_name = physics_name(i) }
        }
        i = i + 1
    }
    return best_name + "(" + round2(best_d * 100.0) + "%)"
}

// ═══════════════════════════════════════════════════════════
// ─── TAGGED VALUE: value + source label ───
// ═══════════════════════════════════════════════════════════

// Using parallel lists instead of struct list (safer for hexa list ops)
// tv_vals[i], tv_srcs[i], tv_labels[i] are synchronized

fn tv_add(vals: list, srcs: list, labels: list, v: f64, src: string, lbl: string) -> list {
    return [vals + [v], srcs + [src], labels + [lbl]]
}

// ═══════════════════════════════════════════════════════════
// ─── SOURCE 1: discovery_log.jsonl ───
// ═══════════════════════════════════════════════════════════

fn load_discovery_log() -> list {
    let path = env("HOME") + "/Dev/nexus6/shared/discovery_log.jsonl"
    let raw = read_file(path)
    if raw == "" {
        println("  [discovery_log] WARN: empty or not found")
        return [[], [], []]
    }
    let lines = raw.split("\n")
    let mut vals: list = []
    let mut srcs: list = []
    let mut labels: list = []
    let max_lines = if lines.len() < 50000 { lines.len() } else { 50000 }
    let mut i: i64 = 0
    while i < max_lines {
        let line = lines[i]
        if line.len() > 10 && line.contains("\"value\"") {
            // Extract value — handles both "value":"8" and "value":8
            let parts = line.split("\"value\"")
            if parts.len() >= 2 {
                let after = parts[1].trim()
                let mut val_str = ""
                if after.contains(":") {
                    let ac = after.split(":")[1].trim()
                    let mut clean = ac
                    if clean.starts_with("\"") {
                        let inner = clean.split("\"")
                        if inner.len() >= 2 { val_str = inner[1] }
                    } else {
                        if clean.contains(",") { clean = clean.split(",")[0] }
                        if clean.contains("}") { clean = clean.split("}")[0] }
                        val_str = clean.trim()
                    }
                }
                let v = safe_float(val_str)
                if v > 0.001 || val_str == "0" {
                    // Extract source
                    let mut src = "dlog"
                    if line.contains("\"source\"") {
                        let sp = line.split("\"source\"")
                        if sp.len() >= 2 {
                            let sq = sp[1].split("\"")
                            if sq.len() >= 3 { src = "dlog:" + sq[2] }
                        }
                    }
                    // Extract constant name
                    let mut lbl = ""
                    if line.contains("\"constant\"") {
                        let cp = line.split("\"constant\"")
                        if cp.len() >= 2 {
                            let cq = cp[1].split("\"")
                            if cq.len() >= 3 { lbl = cq[2] }
                        }
                    }
                    vals = vals + [v]
                    srcs = srcs + [src]
                    labels = labels + [lbl]
                }
            }
        }
        i = i + 1
    }
    println("  [discovery_log] " + to_string(vals.len()) + " values from " + to_string(lines.len()) + " lines")
    return [vals, srcs, labels]
}

// ═══════════════════════════════════════════════════════════
// ─── SOURCE 2: math_atlas.json ───
// ═══════════════════════════════════════════════════════════

fn load_math_atlas() -> list {
    let path = env("HOME") + "/Dev/nexus6/shared/math_atlas.json"
    let raw = read_file(path)
    if raw == "" {
        println("  [math_atlas] WARN: empty or not found")
        return [[], [], []]
    }
    let mut vals: list = []
    let mut srcs: list = []
    let mut labels: list = []

    // Split by "title":" to find hypothesis titles
    let parts = raw.split("\"title\":")
    let mut i: i64 = 1
    let max_parts = if parts.len() < 1000 { parts.len() } else { 1000 }
    while i < max_parts {
        let chunk = parts[i].trim()
        // Get the title string
        if chunk.starts_with("\"") {
            let inner = chunk.split("\"")
            if inner.len() >= 2 {
                let title = inner[1]
                // Tokenize and extract numbers
                let tokens = title.split(" ")
                let mut ti: i64 = 0
                while ti < tokens.len() {
                    let tok = tokens[ti].trim()
                    // Clean punctuation
                    let mut clean = tok
                    if clean.ends_with(",") { clean = clean.slice(0, clean.len() - 1) }
                    if clean.ends_with(")") { clean = clean.slice(0, clean.len() - 1) }
                    if clean.starts_with("(") { clean = clean.slice(1, clean.len()) }
                    if clean.ends_with("}") { clean = clean.slice(0, clean.len() - 1) }
                    if clean.starts_with("{") { clean = clean.slice(1, clean.len()) }

                    let v = safe_float(clean)
                    if abs_f(v) > 0.001 {
                        vals = vals + [v]
                        srcs = srcs + ["atlas"]
                        labels = labels + [title]
                    }

                    // Fraction parsing: a/b
                    if clean.contains("/") && v == 0.0 {
                        let fp = clean.split("/")
                        if fp.len() == 2 {
                            let num = safe_float(fp[0])
                            let den = safe_float(fp[1])
                            if den != 0.0 && abs_f(num) > 0.0 {
                                vals = vals + [num / den]
                                srcs = srcs + ["atlas:frac"]
                                labels = labels + [title + " [" + clean + "]"]
                            }
                        }
                    }
                    ti = ti + 1
                }
            }
        }
        i = i + 1
    }

    // Also extract from "grade" fields
    let gparts = raw.split("\"grade\":")
    let mut gi: i64 = 1
    while gi < gparts.len() {
        let gc = gparts[gi].trim()
        if gc.starts_with("\"") {
            let gq = gc.split("\"")
            if gq.len() >= 2 {
                let gv = safe_float(gq[1])
                if gv > 0.0 {
                    vals = vals + [gv]
                    srcs = srcs + ["atlas:grade"]
                    labels = labels + ["grade=" + gq[1]]
                }
            }
        }
        gi = gi + 1
    }

    println("  [math_atlas] " + to_string(vals.len()) + " values from " + to_string(max_parts - 1) + " hypotheses")
    return [vals, srcs, labels]
}

// ═══════════════════════════════════════════════════════════
// ─── SOURCE 3: Live macOS System Metrics (via exec) ───
// ═══════════════════════════════════════════════════════════

fn load_live_metrics() -> list {
    let mut vals: list = []
    let mut srcs: list = []
    let mut labels: list = []

    // (1) Load averages
    let uptime_out = exec("uptime 2>/dev/null")
    if uptime_out.contains("load average") {
        let lp = uptime_out.split("load average")
        if lp.len() >= 2 {
            let rest = lp[1]
            let mut after = rest
            if after.contains(":") { after = after.split(":")[1].trim() }
            // macOS uses "s:" not ":"
            if after.starts_with("s:") { after = after.slice(2, after.len()).trim() }
            let toks = after.split(",")
            let mut ti: i64 = 0
            while ti < toks.len() && ti < 3 {
                let v = safe_float(toks[ti].trim())
                if v > 0.0 {
                    let tag = if ti == 0 { "load_1m" } else { if ti == 1 { "load_5m" } else { "load_15m" } }
                    vals = vals + [v]
                    srcs = srcs + ["live:load"]
                    labels = labels + [tag]
                }
                ti = ti + 1
            }
        }
    }

    // (2) Process count
    let ps_out = exec("ps aux 2>/dev/null | wc -l")
    let ps_count = safe_float(ps_out.trim())
    if ps_count > 0.0 {
        vals = vals + [ps_count]
        srcs = srcs + ["live:ps"]
        labels = labels + ["process_count"]
    }

    // (3) Disk usage %
    let df_out = exec("df -h / 2>/dev/null | tail -1")
    if df_out != "" {
        let dtoks = df_out.split(" ")
        let mut di: i64 = 0
        while di < dtoks.len() {
            let dt = dtoks[di].trim()
            if dt.ends_with("%") {
                let pct_str = dt.slice(0, dt.len() - 1)
                let pct = safe_float(pct_str)
                if pct > 0.0 {
                    vals = vals + [pct]
                    srcs = srcs + ["live:disk"]
                    labels = labels + ["disk_pct"]
                    vals = vals + [pct / 100.0]
                    srcs = srcs + ["live:disk"]
                    labels = labels + ["disk_frac"]
                }
            }
            di = di + 1
        }
    }

    // (4) vm_stat memory
    let vm_out = exec("vm_stat 2>/dev/null")
    if vm_out != "" {
        let vm_lines = vm_out.split("\n")
        let mut page_size = 16384.0
        if vm_lines.len() > 0 && vm_lines[0].contains("page size of") {
            let psp = vm_lines[0].split("page size of")
            if psp.len() >= 2 {
                let psv = safe_float(psp[1].trim().split(" ")[0])
                if psv > 0.0 { page_size = psv }
            }
        }
        let mut free_p = 0.0
        let mut active_p = 0.0
        let mut inactive_p = 0.0
        let mut wired_p = 0.0
        let mut vi: i64 = 1
        while vi < vm_lines.len() {
            let vl = vm_lines[vi].trim()
            if vl.contains(":") {
                let vparts = vl.split(":")
                let vkey = vparts[0].trim()
                let mut vval_s = vparts[1].trim()
                if vval_s.ends_with(".") { vval_s = vval_s.slice(0, vval_s.len() - 1) }
                let vval = safe_float(vval_s.trim())
                if vkey.contains("Pages free") { free_p = vval }
                if vkey.contains("Pages active") { active_p = vval }
                if vkey.contains("Pages inactive") { inactive_p = vval }
                if vkey.contains("Pages wired") { wired_p = vval }
            }
            vi = vi + 1
        }
        let total_p = free_p + active_p + inactive_p + wired_p
        if total_p > 0.0 {
            let used_pct = (active_p + wired_p) / total_p * 100.0
            let free_pct = free_p / total_p * 100.0
            let active_ratio = active_p / total_p
            let wired_ratio = wired_p / total_p
            let total_gb = total_p * page_size / 1073741824.0

            vals = vals + [round4f(used_pct)]
            srcs = srcs + ["live:mem"]
            labels = labels + ["mem_used_pct"]

            vals = vals + [round4f(free_pct)]
            srcs = srcs + ["live:mem"]
            labels = labels + ["mem_free_pct"]

            vals = vals + [round4f(active_ratio)]
            srcs = srcs + ["live:mem"]
            labels = labels + ["mem_active_ratio"]

            vals = vals + [round4f(wired_ratio)]
            srcs = srcs + ["live:mem"]
            labels = labels + ["mem_wired_ratio"]

            vals = vals + [round4f(total_gb)]
            srcs = srcs + ["live:mem"]
            labels = labels + ["mem_total_gb"]
        }
    }

    // (5) CPU cores
    let cpu_out = exec("sysctl -n hw.ncpu 2>/dev/null")
    let ncpu = safe_float(cpu_out.trim())
    if ncpu > 0.0 {
        vals = vals + [ncpu]
        srcs = srcs + ["live:cpu"]
        labels = labels + ["cpu_cores"]
    }

    // (6) Uptime hours
    let boot_out = exec("sysctl -n kern.boottime 2>/dev/null")
    if boot_out.contains("sec =") {
        let bp = boot_out.split("sec =")
        if bp.len() >= 2 {
            let mut bs = bp[1].trim()
            if bs.contains(",") { bs = bs.split(",")[0] }
            let boot_sec = safe_float(bs.trim())
            let now_out = exec("date +%s 2>/dev/null")
            let now_sec = safe_float(now_out.trim())
            if boot_sec > 0.0 && now_sec > boot_sec {
                let up_hours = (now_sec - boot_sec) / 3600.0
                vals = vals + [round4f(up_hours)]
                srcs = srcs + ["live:uptime"]
                labels = labels + ["uptime_hours"]
            }
        }
    }

    // (7) Thermal (fan speed if available)
    let thermal_out = exec("sudo -n powermetrics --samplers smc -n 1 -i 1 2>/dev/null | grep -i 'die temp' | head -1")
    if thermal_out != "" {
        // Try to extract number
        let ttoks = thermal_out.split(" ")
        let mut tti: i64 = 0
        while tti < ttoks.len() {
            let tv = safe_float(ttoks[tti].trim())
            if tv > 20.0 && tv < 120.0 {
                vals = vals + [tv]
                srcs = srcs + ["live:thermal"]
                labels = labels + ["die_temp_C"]
            }
            tti = tti + 1
        }
    }

    println("  [live_metrics] " + to_string(vals.len()) + " values")
    return [vals, srcs, labels]
}

// ═══════════════════════════════════════════════════════════
// ─── ANALYSIS: HISTOGRAM ───
// ═══════════════════════════════════════════════════════════

fn build_histogram(all_vals: list, bin_size: f64) -> list {
    // Returns [bin_centers, bin_counts, bin_source_lists]
    let mut centers: list = []
    let mut counts: list = []
    let mut src_sets: list = []   // comma-separated source strings per bin

    let mut i: i64 = 0
    while i < all_vals.len() {
        let v: f64 = all_vals[i]
        let bin_idx = to_int(v / bin_size)
        let bin_center = to_float(bin_idx) * bin_size + bin_size / 2.0
        // Find existing bin
        let mut found = false
        let mut bi: i64 = 0
        while bi < centers.len() {
            let bc: f64 = centers[bi]
            if to_int(bc / bin_size) == bin_idx {
                let c: i64 = counts[bi]
                counts[bi] = c + 1
                found = true
            }
            bi = bi + 1
        }
        if !found {
            centers = centers + [bin_center]
            counts = counts + [1]
        }
        i = i + 1
    }
    return [centers, counts]
}

fn print_histogram(hist: list, bin_size: f64, top_n: i64) {
    let centers: list = hist[0]
    let counts: list = hist[1]

    // Sort indices by count descending (selection sort)
    let mut indices: list = []
    let mut ii: i64 = 0
    while ii < centers.len() {
        indices = indices + [ii]
        ii = ii + 1
    }

    let mut si: i64 = 0
    while si < indices.len() {
        let mut best = si
        let mut sj = si + 1
        while sj < indices.len() {
            let ci: i64 = indices[sj]
            let cb: i64 = indices[best]
            let cnt_j: i64 = counts[ci]
            let cnt_b: i64 = counts[cb]
            if cnt_j > cnt_b { best = sj }
            sj = sj + 1
        }
        if best != si {
            let tmp: i64 = indices[si]
            indices[si] = indices[best]
            indices[best] = tmp
        }
        si = si + 1
    }

    let show = if top_n < indices.len() { top_n } else { indices.len() }
    let mut pi: i64 = 0
    while pi < show {
        let idx: i64 = indices[pi]
        let center: f64 = centers[idx]
        let cnt: i64 = counts[idx]
        let lo = center - bin_size / 2.0
        let hi = center + bin_size / 2.0
        let bar_max = if cnt > 50 { 50 } else { cnt }
        let mut bar = ""
        let mut bi: i64 = 0
        while bi < bar_max {
            bar = bar + "#"
            bi = bi + 1
        }
        let known_tag = if is_known_n6(center) { " [KNOWN]" } else { "" }
        println("  [" + round2(lo) + " - " + round2(hi) + ") " + to_string(cnt) + " " + bar + known_tag)
        pi = pi + 1
    }
}

// ═══════════════════════════════════════════════════════════
// ─── ANALYSIS: CLUSTER DETECTION (1% tolerance, 3+) ───
// ═══════════════════════════════════════════════════════════

fn detect_clusters(all_vals: list, all_srcs: list, tolerance: f64) -> list {
    // Returns list of "centroid|count|n_sources|src_summary|known" strings
    let n = if all_vals.len() < 3000 { all_vals.len() } else { 3000 }

    // Sort values (with index tracking)
    let mut sorted_vals: list = []
    let mut sorted_idxs: list = []
    let mut si: i64 = 0
    while si < n {
        sorted_vals = sorted_vals + [all_vals[si]]
        sorted_idxs = sorted_idxs + [si]
        si = si + 1
    }
    // Selection sort
    si = 0
    while si < sorted_vals.len() {
        let mut best = si
        let mut sj = si + 1
        while sj < sorted_vals.len() {
            let va: f64 = sorted_vals[sj]
            let vb: f64 = sorted_vals[best]
            if va < vb { best = sj }
            sj = sj + 1
        }
        if best != si {
            let tv: f64 = sorted_vals[si]
            sorted_vals[si] = sorted_vals[best]
            sorted_vals[best] = tv
            let ti: i64 = sorted_idxs[si]
            sorted_idxs[si] = sorted_idxs[best]
            sorted_idxs[best] = ti
        }
        si = si + 1
    }

    // Sweep through sorted values, group within tolerance
    let mut clusters: list = []
    let mut ci: i64 = 0
    while ci < sorted_vals.len() {
        let anchor: f64 = sorted_vals[ci]
        if abs_f(anchor) < 0.0001 { ci = ci + 1 } else {
            let mut members: list = [ci]
            let mut sum = anchor
            let mut cj = ci + 1
            while cj < sorted_vals.len() {
                let vj: f64 = sorted_vals[cj]
                let rel = abs_f(vj - anchor) / max_f(abs_f(anchor), 0.001)
                if rel < tolerance {
                    members = members + [cj]
                    sum = sum + vj
                    cj = cj + 1
                } else {
                    cj = sorted_vals.len()
                }
            }
            if members.len() >= 3 {
                let centroid = sum / to_float(members.len())
                // Count distinct sources
                let mut src_unique: list = []
                let mut mi: i64 = 0
                while mi < members.len() {
                    let midx: i64 = members[mi]
                    let orig_idx: i64 = sorted_idxs[midx]
                    if orig_idx < all_srcs.len() {
                        let src: string = all_srcs[orig_idx]
                        // Check uniqueness (by prefix)
                        let src_prefix = src.split(":")[0]
                        let mut dup = false
                        let mut ui: i64 = 0
                        while ui < src_unique.len() {
                            let existing: string = src_unique[ui]
                            if existing == src_prefix { dup = true }
                            ui = ui + 1
                        }
                        if !dup { src_unique = src_unique + [src_prefix] }
                    }
                    mi = mi + 1
                }
                let mut src_str = ""
                let mut ui: i64 = 0
                while ui < src_unique.len() {
                    if src_str != "" { src_str = src_str + "+" }
                    let s: string = src_unique[ui]
                    src_str = src_str + s
                    ui = ui + 1
                }
                let known_tag = if is_known_n6(centroid) { "KNOWN" } else { "NEW" }
                let entry = to_string(round4f(centroid)) + "|" + to_string(members.len()) + "|" + to_string(src_unique.len()) + "|" + src_str + "|" + known_tag
                clusters = clusters + [entry]
            }
            ci = ci + members.len()
        }
    }
    return clusters
}

// ═══════════════════════════════════════════════════════════
// ─── ANALYSIS: CROSS-SOURCE RESONANCE ───
// ═══════════════════════════════════════════════════════════

fn find_resonances(all_vals: list, all_srcs: list, all_labels: list) -> list {
    // Find values appearing in 2+ distinct source categories
    let mut results: list = []
    let mut checked: list = []
    let mut i: i64 = 0
    let n = if all_vals.len() < 2000 { all_vals.len() } else { 2000 }

    while i < n {
        let v0: f64 = all_vals[i]
        if abs_f(v0) < 0.01 { i = i + 1 } else {
            // Skip already checked
            let mut already = false
            let mut ci: i64 = 0
            while ci < checked.len() {
                let cv: f64 = checked[ci]
                if abs_f(cv - v0) / max_f(abs_f(v0), 0.001) < 0.005 { already = true }
                ci = ci + 1
            }
            if !already {
                checked = checked + [v0]
                // Collect distinct source categories
                let mut cat_list: list = []
                let mut lbl_list: list = []
                let mut j: i64 = 0
                while j < all_vals.len() {
                    let vj: f64 = all_vals[j]
                    let rel = abs_f(vj - v0) / max_f(abs_f(v0), 0.001)
                    if rel < 0.01 {
                        let src: string = all_srcs[j]
                        let cat = src.split(":")[0]
                        let mut dup = false
                        let mut ki: i64 = 0
                        while ki < cat_list.len() {
                            let ec: string = cat_list[ki]
                            if ec == cat { dup = true }
                            ki = ki + 1
                        }
                        if !dup {
                            cat_list = cat_list + [cat]
                            let lbl: string = all_labels[j]
                            lbl_list = lbl_list + [lbl]
                        }
                    }
                    j = j + 1
                }
                if cat_list.len() >= 2 {
                    let mut cat_str = ""
                    let mut k: i64 = 0
                    while k < cat_list.len() {
                        if cat_str != "" { cat_str = cat_str + " + " }
                        let c: string = cat_list[k]
                        cat_str = cat_str + c
                        k = k + 1
                    }
                    let mut lbl_str = ""
                    k = 0
                    while k < lbl_list.len() {
                        if lbl_str != "" { lbl_str = lbl_str + " | " }
                        let l: string = lbl_list[k]
                        if l.len() < 60 { lbl_str = lbl_str + l }
                        k = k + 1
                    }
                    let known_tag = if is_known_n6(v0) { "KNOWN" } else { "***NEW***" }
                    let entry = to_string(round4f(v0)) + "|" + to_string(cat_list.len()) + "|" + cat_str + "|" + lbl_str + "|" + known_tag
                    results = results + [entry]
                }
            }
            i = i + 1
        }
    }
    return results
}

// ═══════════════════════════════════════════════════════════
// ─── ANALYSIS: SURPRISE METRIC ───
// ═══════════════════════════════════════════════════════════

fn compute_surprises(all_vals: list, all_srcs: list, all_labels: list) -> list {
    // Values CLOSE to n6/physics constants but NOT already in the known table
    let mut results: list = []
    let mut seen: list = []
    let mut i: i64 = 0
    let n = if all_vals.len() < 3000 { all_vals.len() } else { 3000 }

    while i < n {
        let v: f64 = all_vals[i]
        if abs_f(v) < 0.01 || is_known_n6(v) { i = i + 1 } else {
            // Dedup by rounded value
            let rv = to_int(v * 100.0)
            let mut dup = false
            let mut di: i64 = 0
            while di < seen.len() {
                let sv: i64 = seen[di]
                if sv == rv { dup = true }
                di = di + 1
            }
            if !dup {
                seen = seen + [rv]

                // Compute minimum distance to any n6 constant
                let mut best_n6_d = 999999.0
                let mut best_n6_name = ""
                let mut ni: i64 = 0
                while ni < N6_COUNT {
                    let c = known_n6_val(ni)
                    if c != 0.0 {
                        let d = abs_f(v - c) / max_f(abs_f(c), 0.001)
                        if d < best_n6_d { best_n6_d = d; best_n6_name = known_n6_name(ni) }
                    }
                    ni = ni + 1
                }

                // Also check n6 ratio/product combos
                ni = 0
                while ni < 7 {
                    let mut nj: i64 = 0
                    while nj < 7 {
                        if ni != nj {
                            let va = known_n6_val(ni)
                            let vb = known_n6_val(nj)
                            if vb != 0.0 {
                                let ratio = va / vb
                                let d_r = abs_f(v - ratio) / max_f(abs_f(ratio), 0.001)
                                if d_r < best_n6_d { best_n6_d = d_r; best_n6_name = known_n6_name(ni) + "/" + known_n6_name(nj) }
                                let prod = va * vb
                                if prod < 10000.0 {
                                    let d_p = abs_f(v - prod) / max_f(abs_f(prod), 0.001)
                                    if d_p < best_n6_d { best_n6_d = d_p; best_n6_name = known_n6_name(ni) + "*" + known_n6_name(nj) }
                                }
                            }
                        }
                        nj = nj + 1
                    }
                    ni = ni + 1
                }

                // Compute distance to physics constants
                let mut best_phys_d = 999999.0
                let mut best_phys_name = ""
                let mut pi: i64 = 0
                while pi < PHYS_COUNT {
                    let c = physics_val(pi)
                    if c != 0.0 {
                        let d = abs_f(v - c) / max_f(abs_f(c), 0.001)
                        if d < best_phys_d { best_phys_d = d; best_phys_name = physics_name(pi) }
                    }
                    pi = pi + 1
                }

                // Surprise score: closer to known structure = more surprising (if not exact)
                let n6_prox = if best_n6_d < 0.05 { 1.0 - best_n6_d * 20.0 } else { 0.0 }
                let phys_prox = if best_phys_d < 0.05 { 1.0 - best_phys_d * 20.0 } else { 0.0 }
                let score = max_f(n6_prox, phys_prox)

                if score > 0.1 {
                    let src: string = all_srcs[i]
                    let lbl: string = all_labels[i]
                    let stars = if score > 0.8 { "***" } else { if score > 0.5 { "**" } else { "*" } }
                    let entry = stars + "|" + to_string(round4f(v)) + "|" + round2(score) + "|" + best_n6_name + "(" + round2(best_n6_d * 100.0) + "%)|" + best_phys_name + "(" + round2(best_phys_d * 100.0) + "%)|" + src + "|" + lbl
                    results = results + [entry]
                }
            }
            i = i + 1
        }
    }
    return results
}

// ═══════════════════════════════════════════════════════════
// ─── REPORT OUTPUT ───
// ═══════════════════════════════════════════════════════════

fn print_header() {
    println("")
    println("================================================================")
    println("  REAL BREAKTHROUGH ENGINE")
    println("  Genuine pattern discovery from real data")
    println("  (NOT recombinations of hardcoded n=6 constants)")
    println("================================================================")
    println("")
}

fn print_clusters_report(clusters: list) {
    println("--- CLUSTER DETECTION (1% tolerance, 3+ members) ---")
    println("")
    if clusters.len() == 0 {
        println("  (no clusters found)")
        println("")
        return
    }
    let mut new_count: i64 = 0
    let mut cross_count: i64 = 0
    let mut i: i64 = 0
    while i < clusters.len() {
        let entry: string = clusters[i]
        let parts = entry.split("|")
        let centroid = parts[0]
        let count = parts[1]
        let n_sources = parts[2]
        let src_summary = parts[3]
        let known_tag = parts[4]
        if known_tag == "NEW" { new_count = new_count + 1 }
        let ns = safe_float(n_sources)
        if ns >= 2.0 { cross_count = cross_count + 1 }

        let marker = if known_tag == "NEW" { " <<<" } else { "" }
        let cross_marker = if ns >= 2.0 { " [CROSS-SOURCE]" } else { "" }
        println("  centroid=" + centroid + "  n=" + count + "  sources=" + n_sources + " (" + src_summary + ")  [" + known_tag + "]" + cross_marker + marker)

        // Show n6/physics proximity for new clusters
        if known_tag == "NEW" {
            let cv = safe_float(centroid)
            println("    -> nearest n6: " + nearest_n6(cv))
            println("    -> nearest physics: " + nearest_physics(cv))
        }
        i = i + 1
    }
    println("")
    println("  total clusters: " + to_string(clusters.len()) + " | new: " + to_string(new_count) + " | cross-source: " + to_string(cross_count))
    println("")
}

fn print_resonances_report(resonances: list) {
    println("--- CROSS-SOURCE RESONANCE (value in 2+ source categories) ---")
    println("")
    if resonances.len() == 0 {
        println("  (no cross-source resonances)")
        println("")
        return
    }
    let mut new_count: i64 = 0
    let mut i: i64 = 0
    while i < resonances.len() {
        let entry: string = resonances[i]
        let parts = entry.split("|")
        let value = parts[0]
        let n_cats = parts[1]
        let cats = parts[2]
        let lbls = if parts.len() > 3 { parts[3] } else { "" }
        let known_tag = if parts.len() > 4 { parts[4] } else { "?" }
        if known_tag == "***NEW***" { new_count = new_count + 1 }
        let marker = if known_tag == "***NEW***" { " <<<" } else { "" }

        println("  " + value + " in " + n_cats + " sources: " + cats + " [" + known_tag + "]" + marker)
        if known_tag == "***NEW***" {
            let cv = safe_float(value)
            println("    -> nearest n6: " + nearest_n6(cv))
            println("    -> nearest physics: " + nearest_physics(cv))
        }
        if lbls != "" && lbls.len() < 120 {
            println("    labels: " + lbls)
        }
        i = i + 1
    }
    println("")
    println("  total resonances: " + to_string(resonances.len()) + " | new: " + to_string(new_count))
    println("")
}

fn print_surprises_report(surprises: list, max_show: i64) {
    println("--- SURPRISE FINDINGS (near n6/physics but NOT already known) ---")
    println("")
    if surprises.len() == 0 {
        println("  (no surprising patterns)")
        println("")
        return
    }
    let show = if max_show < surprises.len() { max_show } else { surprises.len() }
    let mut i: i64 = 0
    while i < show {
        let entry: string = surprises[i]
        let parts = entry.split("|")
        let stars = parts[0]
        let value = parts[1]
        let score = parts[2]
        let near_n6 = parts[3]
        let near_phys = parts[4]
        let source = if parts.len() > 5 { parts[5] } else { "?" }
        let label = if parts.len() > 6 { parts[6] } else { "" }

        println("  " + stars + " value=" + value + " surprise=" + score)
        println("     near n6:  " + near_n6)
        println("     near phys: " + near_phys)
        println("     source: " + source)
        if label != "" && label.len() < 80 { println("     label:  " + label) }
        println("")
        i = i + 1
    }
    if surprises.len() > max_show {
        println("  ... and " + to_string(surprises.len() - max_show) + " more")
    }
    println("")
}

fn print_live_report(vals: list, srcs: list, labels: list) {
    println("--- LIVE SYSTEM METRICS (macOS) ---")
    println("")
    let mut i: i64 = 0
    while i < vals.len() {
        let v: f64 = vals[i]
        let src: string = srcs[i]
        let lbl: string = labels[i]
        let known_tag = if is_known_n6(v) { " [MATCHES n6!]" } else { "" }
        println("  " + lbl + " = " + to_string(round4f(v)) + "  (" + src + ")" + known_tag)
        if !is_known_n6(v) && v > 0.01 {
            println("    nearest n6:  " + nearest_n6(v))
            println("    nearest phys: " + nearest_physics(v))
        }
        i = i + 1
    }
    println("")
}

fn print_summary(total: i64, clusters: list, resonances: list, surprises: list) {
    // Count stats
    let mut new_clusters: i64 = 0
    let mut cross_clusters: i64 = 0
    let mut ci: i64 = 0
    while ci < clusters.len() {
        let e: string = clusters[ci]
        if e.contains("|NEW") { new_clusters = new_clusters + 1 }
        let parts = e.split("|")
        if parts.len() >= 3 { if safe_float(parts[2]) >= 2.0 { cross_clusters = cross_clusters + 1 } }
        ci = ci + 1
    }
    let mut new_res: i64 = 0
    let mut ri: i64 = 0
    while ri < resonances.len() {
        let e: string = resonances[ri]
        if e.contains("***NEW***") { new_res = new_res + 1 }
        ri = ri + 1
    }

    println("================================================================")
    println("  SUMMARY")
    println("================================================================")
    println("")
    println("  Total values scanned:      " + to_string(total))
    println("  Clusters (3+ members):     " + to_string(clusters.len()) + " (new: " + to_string(new_clusters) + ")")
    println("  Cross-source clusters:     " + to_string(cross_clusters))
    println("  Cross-source resonances:   " + to_string(resonances.len()) + " (new: " + to_string(new_res) + ")")
    println("  Surprise findings:         " + to_string(surprises.len()))
    println("")

    let bscore = to_float(cross_clusters) * 3.0 + to_float(new_res) * 2.0 + to_float(surprises.len())
    if bscore > 20.0 {
        println("  >>> BREAKTHROUGH POTENTIAL: HIGH (" + round2(bscore) + ")")
        println("  >>> Multiple unexpected patterns across independent sources")
    } else if bscore > 5.0 {
        println("  >> Breakthrough potential: MODERATE (" + round2(bscore) + ")")
        println("  >> Interesting patterns worth investigating")
    } else {
        println("  > Breakthrough potential: LOW (" + round2(bscore) + ")")
        println("  > Data mostly matches known constants")
    }
    println("")
}

