    println("")
    println("What counts as REAL discovery:")
    println("  - Value in 2+ independent sources                -> cross-source resonance")
    println("  - Cluster of 3+ values within 1%                 -> unexpected concentration")
    println("  - Close to n6 ratio/product but NOT already known -> potential new constant")
    println("  - Matches physics constant from different domain  -> cross-domain validation")
    println("")
    println("What is NOT a discovery:")
    println("  - Exact match to known n6 table (6,12,2,4,5,24,7,...,8128)")
    println("  - Simple recombination of hardcoded constants")
}
