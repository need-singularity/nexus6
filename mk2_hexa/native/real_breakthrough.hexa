if mode == "scan" {
    print_header()

    println("[Phase 1] Loading data sources...")
    let dlog = load_discovery_log()
    let atlas = load_math_atlas()
    let live = load_live_metrics()

    // Merge all parallel-list triples
    let dlog_v: list = dlog[0]
    let dlog_s: list = dlog[1]
    let dlog_l: list = dlog[2]
    let atlas_v: list = atlas[0]
    let atlas_s: list = atlas[1]
    let atlas_l: list = atlas[2]
    let live_v: list = live[0]
    let live_s: list = live[1]
    let live_l: list = live[2]

    let all_v = dlog_v + atlas_v + live_v
    let all_s = dlog_s + atlas_s + live_s
    let all_l = dlog_l + atlas_l + live_l
    println("  TOTAL: " + to_string(all_v.len()) + " values from 3 sources")
    println("")

    println("[Phase 2] Building histogram...")
    let hist = build_histogram(all_v, 1.0)
    print_histogram(hist, 1.0, 20)
    println("")

    println("[Phase 3] Detecting clusters...")
    let clusters = detect_clusters(all_v, all_s, 0.01)
    print_clusters_report(clusters)

    println("[Phase 4] Cross-source resonance...")
    let resonances = find_resonances(all_v, all_s, all_l)
    print_resonances_report(resonances)

    println("[Phase 5] Surprise analysis...")
    let surprises = compute_surprises(all_v, all_s, all_l)
    print_surprises_report(surprises, 15)

    print_summary(all_v.len(), clusters, resonances, surprises)
}

