// NEXUS-6 SSE Dashboard Server
// ==============================
// Lightweight Server-Sent Events endpoint for the 15-dimension growth dashboard.
// Reads growth_log.jsonl + growth_bus.jsonl and streams live updates.
//
// Usage:
//   hexa sse_dashboard.hexa              # start on port 6600
//   hexa sse_dashboard.hexa --port 6601  # custom port
//   hexa sse_dashboard.hexa --stop       # stop running server
//   hexa sse_dashboard.hexa --status     # check if running
//
// Endpoints:
//   GET /events    SSE stream (snapshot + discovery + breakthrough)
//   GET /status    JSON health check
//   GET /snapshot  Current state as JSON (one-shot)
//
// Heartbeat: 15s keepalive. Auto-reconnect friendly (Last-Event-ID support).

let home = exec("printenv HOME").trim()
let nx = home + "/Dev/nexus"
let pid_file = nx + "/shared/.sse_dashboard.pid"
let log_dir = home + "/Library/Logs/nexus"

// Parse args
let args = get_args()
let port = "6600"
let action = "start"

let i = 0
while i < length(args) {
  if args[i] == "--port" {
    i = i + 1
    if i < length(args) { port = args[i] }
  }
  if args[i] == "--stop" { action = "stop" }
  if args[i] == "--status" { action = "status" }
  i = i + 1
}

if action == "stop" {
  try {
    let pid = exec("cat " + pid_file + " 2>/dev/null").trim()
    if pid != "" {
      exec("kill " + pid + " 2>/dev/null || true")
      exec("rm -f " + pid_file)
      print("SSE server stopped (PID " + pid + ")")
    } else {
      print("SSE server not running")
    }
  } catch err {
    print("SSE server not running")
  }
} else if action == "status" {
  try {
    let pid = exec("cat " + pid_file + " 2>/dev/null").trim()
    if pid != "" {
      let alive = exec("kill -0 " + pid + " 2>/dev/null && echo alive || echo dead").trim()
      if alive == "alive" {
        print("SSE server running (PID " + pid + ", port " + port + ")")
      } else {
        exec("rm -f " + pid_file)
        print("SSE server not running (stale PID cleaned)")
      }
    } else {
      print("SSE server not running")
    }
  } catch err {
    print("SSE server not running")
  }
} else {
  // Check if already running
  try {
    let old_pid = exec("cat " + pid_file + " 2>/dev/null").trim()
    if old_pid != "" {
      let alive = exec("kill -0 " + old_pid + " 2>/dev/null && echo alive || echo dead").trim()
      if alive == "alive" {
        print("SSE server already running (PID " + old_pid + "). Use --stop first.")
      }
    }
  } catch err {}

  // Ensure log directory
  exec("mkdir -p " + log_dir)

  // Launch SSE server as background Python process
  let server_script = "
import json, os, sys, time, signal, threading
from http.server import HTTPServer, BaseHTTPRequestHandler
from datetime import datetime

HOME = os.path.expanduser('~')
NX = os.path.join(HOME, 'Dev', 'nexus')
GROWTH_LOG = os.path.join(NX, 'scripts', 'growth_log.jsonl')
GROWTH_BUS = os.path.join(NX, 'shared', 'growth_bus.jsonl')
VERIFIED   = os.path.join(NX, 'shared', 'verified_constants.jsonl')
TOPO       = os.path.join(NX, 'shared', 'cycle', 'topology.jsonl')
PID_FILE   = os.path.join(NX, 'shared', '.sse_dashboard.pid')
PORT = int(sys.argv[1]) if len(sys.argv) > 1 else 6600

TARGETS = {
    'performance': 10000, 'architecture': 100, 'lenses': 200,
    'modules': 4, 'tests': 1000, 'hypotheses': 150, 'dse': 322,
    'experiments': 50, 'calculators': 50, 'cross_resonance': 100,
    'knowledge_graph': 500, 'red_team': 100, 'atlas': 2000,
    'documentation': 90, 'integration': 50,
}
DIMS = list(TARGETS.keys())

clients = []
clients_lock = threading.Lock()
last_snapshot = {}
last_bus_pos = 0
last_log_pos = 0
event_id = 0
shutdown_flag = threading.Event()

def tail_jsonl(path, seek_pos=0):
    lines = []
    try:
        size = os.path.getsize(path)
        if size < seek_pos:
            seek_pos = 0
        with open(path, 'r') as f:
            f.seek(seek_pos)
            for raw in f:
                raw = raw.strip()
                if raw:
                    try:
                        lines.append(json.loads(raw))
                    except json.JSONDecodeError:
                        pass
            new_pos = f.tell()
    except FileNotFoundError:
        return [], seek_pos
    return lines, new_pos

def count_lines(path):
    try:
        with open(path, 'r') as f:
            return sum(1 for _ in f)
    except FileNotFoundError:
        return 0

def build_snapshot():
    snap = {'ts': datetime.now().isoformat(timespec='seconds'), 'dims': {}}
    try:
        last_line = None
        with open(GROWTH_LOG, 'r') as f:
            for line in f:
                line = line.strip()
                if line:
                    last_line = line
        if last_line:
            entry = json.loads(last_line)
            for d in DIMS:
                val = float(entry.get(d, 0))
                tgt = TARGETS[d]
                pct = min(val / max(tgt, 0.001), 1.0) * 100
                snap['dims'][d] = {'value': val, 'target': tgt, 'pct': round(pct, 1)}
            snap['cycle'] = entry.get('cycle', '?')
            snap['log_ts'] = entry.get('timestamp', '?')
    except (FileNotFoundError, json.JSONDecodeError):
        for d in DIMS:
            snap['dims'][d] = {'value': 0, 'target': TARGETS[d], 'pct': 0}
    snap['closures_total'] = count_lines(VERIFIED)
    snap['topology_total'] = count_lines(TOPO)
    return snap

def broadcast_sse(event_type, data):
    global event_id
    event_id += 1
    payload = f'id: {event_id}\\nevent: {event_type}\\ndata: {json.dumps(data, ensure_ascii=False)}\\n\\n'
    raw = payload.encode('utf-8')
    dead = []
    with clients_lock:
        for i, (wfile, lock) in enumerate(clients):
            try:
                with lock:
                    wfile.write(raw)
                    wfile.flush()
            except (BrokenPipeError, ConnectionResetError, OSError):
                dead.append(i)
        for i in reversed(dead):
            clients.pop(i)

def send_heartbeat():
    raw = f': heartbeat {datetime.now().isoformat(timespec=\"seconds\")}\\n\\n'.encode('utf-8')
    dead = []
    with clients_lock:
        for i, (wfile, lock) in enumerate(clients):
            try:
                with lock:
                    wfile.write(raw)
                    wfile.flush()
            except (BrokenPipeError, ConnectionResetError, OSError):
                dead.append(i)
        for i in reversed(dead):
            clients.pop(i)

def poll_loop(interval_sec=10):
    global last_snapshot, last_bus_pos, last_log_pos
    hb = 0
    last_snapshot = build_snapshot()
    while not shutdown_flag.is_set():
        new_entries, last_log_pos = tail_jsonl(GROWTH_LOG, last_log_pos)
        if new_entries:
            last_snapshot = build_snapshot()
            broadcast_sse('snapshot', last_snapshot)
        new_bus, last_bus_pos = tail_jsonl(GROWTH_BUS, last_bus_pos)
        for evt in new_bus:
            et = evt.get('type', 'discovery')
            if et == 'breakthrough' or evt.get('breakthrough'):
                broadcast_sse('breakthrough', evt)
            else:
                broadcast_sse('discovery', evt)
        hb += 1
        if hb % max(1, 15 // interval_sec) == 0:
            send_heartbeat()
        if hb % max(1, 60 // interval_sec) == 0:
            last_snapshot = build_snapshot()
            broadcast_sse('snapshot', last_snapshot)
        shutdown_flag.wait(timeout=interval_sec)

class SSEHandler(BaseHTTPRequestHandler):
    protocol_version = 'HTTP/1.1'
    def log_message(self, fmt, *args):
        pass
    def _cors(self):
        self.send_header('Access-Control-Allow-Origin', '*')
        self.send_header('Access-Control-Allow-Methods', 'GET, OPTIONS')
        self.send_header('Access-Control-Allow-Headers', 'Cache-Control, Last-Event-ID')
    def do_OPTIONS(self):
        self.send_response(204)
        self._cors()
        self.end_headers()
    def do_GET(self):
        if self.path == '/events':
            self._sse()
        elif self.path == '/status':
            self._status()
        elif self.path == '/snapshot':
            self._snap()
        else:
            self.send_error(404)
    def _sse(self):
        self.send_response(200)
        self.send_header('Content-Type', 'text/event-stream')
        self.send_header('Cache-Control', 'no-cache, no-store, must-revalidate')
        self.send_header('Connection', 'keep-alive')
        self.send_header('X-Accel-Buffering', 'no')
        self._cors()
        self.end_headers()
        lock = threading.Lock()
        entry = (self.wfile, lock)
        snap = last_snapshot or build_snapshot()
        try:
            init = f'id: {event_id}\\nevent: snapshot\\ndata: {json.dumps(snap, ensure_ascii=False)}\\n\\n'
            self.wfile.write(init.encode('utf-8'))
            self.wfile.flush()
        except (BrokenPipeError, ConnectionResetError, OSError):
            return
        with clients_lock:
            clients.append(entry)
        try:
            while not shutdown_flag.is_set():
                shutdown_flag.wait(timeout=1)
        except (BrokenPipeError, ConnectionResetError, OSError):
            pass
        finally:
            with clients_lock:
                if entry in clients:
                    clients.remove(entry)
    def _status(self):
        self.send_response(200)
        self.send_header('Content-Type', 'application/json')
        self._cors()
        self.end_headers()
        with clients_lock:
            nc = len(clients)
        s = {'status': 'running', 'ts': datetime.now().isoformat(timespec='seconds'),
             'clients': nc, 'event_id': event_id, 'dims': len(DIMS)}
        self.wfile.write(json.dumps(s).encode('utf-8'))
    def _snap(self):
        self.send_response(200)
        self.send_header('Content-Type', 'application/json')
        self._cors()
        self.end_headers()
        snap = last_snapshot or build_snapshot()
        self.wfile.write(json.dumps(snap, ensure_ascii=False).encode('utf-8'))

class ThreadedHTTPServer(HTTPServer):
    allow_reuse_address = True
    daemon_threads = True
    def process_request(self, request, client_address):
        t = threading.Thread(target=self._proc, args=(request, client_address), daemon=True)
        t.start()
    def _proc(self, request, client_address):
        try:
            self.finish_request(request, client_address)
        except Exception:
            self.handle_error(request, client_address)
        finally:
            self.shutdown_request(request)

# Write PID
with open(PID_FILE, 'w') as f:
    f.write(str(os.getpid()))

def cleanup(signum, frame):
    shutdown_flag.set()
    try:
        os.remove(PID_FILE)
    except:
        pass
    sys.exit(0)

signal.signal(signal.SIGTERM, cleanup)
signal.signal(signal.SIGINT, cleanup)

poll_thread = threading.Thread(target=poll_loop, args=(10,), daemon=True)
poll_thread.start()

server = ThreadedHTTPServer(('127.0.0.1', PORT), SSEHandler)
print(f'[SSE] NEXUS-6 Dashboard on http://127.0.0.1:{PORT}')
print(f'[SSE] /events (SSE) | /status (JSON) | /snapshot (JSON)')
try:
    server.serve_forever()
except KeyboardInterrupt:
    pass
finally:
    shutdown_flag.set()
    try:
        os.remove(PID_FILE)
    except:
        pass
    server.server_close()
"

  // Write the server script to a temp file and launch it
  let tmp_script = nx + "/shared/.sse_server_impl.py"
  write_file(tmp_script, server_script)

  print("Starting NEXUS-6 SSE Dashboard Server on port " + port + "...")
  exec("nohup /usr/bin/python3 " + tmp_script + " " + port + " > " + log_dir + "/sse-dashboard.log 2>&1 &")

  // Wait briefly and verify
  exec("sleep 1")
  try {
    let pid = exec("cat " + pid_file + " 2>/dev/null").trim()
    if pid != "" {
      let alive = exec("kill -0 " + pid + " 2>/dev/null && echo alive || echo dead").trim()
      if alive == "alive" {
        print("SSE server started successfully (PID " + pid + ")")
        print("  Endpoints:")
        print("    http://127.0.0.1:" + port + "/events    SSE stream")
        print("    http://127.0.0.1:" + port + "/status    health check")
        print("    http://127.0.0.1:" + port + "/snapshot  current state")
      } else {
        print("ERROR: SSE server failed to start. Check " + log_dir + "/sse-dashboard.log")
      }
    } else {
      print("ERROR: PID file not created. Check " + log_dir + "/sse-dashboard.log")
    }
  } catch err {
    print("ERROR: " + to_string(err))
  }
}
