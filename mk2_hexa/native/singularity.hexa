// ════════════════════════════════════════════════════════════════

fn cmd_frontier() {
    let points = load_points()

    println("=== singularity recursion — frontier ===")
    println("")

    let frontier = find_frontier(points, default_eps, 10)
    println("프론티어 (저밀도, 상위 10):")

    let mut i = 0
    while i < len(frontier) {
        let entry = frontier[i]
        let p = entry.point
        println("  " + p.id + " density=" + to_string(entry.density) + " domain=" + p.domain)
        println("    invariant_str: " + p.singularity.invariant_str)
        i = i + 1
    }

    println("")
    println("=== frontier 완료 ===")
}

