// 검증
// ════════════════════════════════════════════════════════════════

// djb2 해시 기본 검증
let h1 = djb2_hash("hello")
let h2 = djb2_hash("hello")
let h3 = djb2_hash("world")
assert h1 == h2
assert h1 != h3

// simhash 검증
let sh1 = simhash("n=6 sigma tau alpha")
let sh2 = simhash("n=6 sigma tau alpha")
assert sh1 == sh2
assert sh1 > 0

// 거리 검증
let d_same = hash_distance(sh1, sh2)
assert d_same == 0.0

let sh3 = simhash("banana quantum chromodynamics")
let d_diff = hash_distance(sh1, sh3)
assert d_diff > 0.0

// Budget 검증
let b = budget_default()
assert budget_check(b) == "allowed"

let b_full = Budget {
    tick_count: 100,
    cpu_sec_used: 0,
    total_points: 50000,
    max_total_points: 50000,
    global_cpu_sec_budget: 86400
}
assert budget_check(b_full) == "exhausted_points"

// Budget JSON 왕복 검증
let b_json = budget_to_json(b)
let b_parsed = budget_from_json(b_json)
assert b_parsed.tick_count == 0
assert b_parsed.max_total_points == 50000

// Point ID 생성 검증
assert next_point_id([]) == "p_000000"

// 오일러 특성수 검증
assert euler_characteristic(5, 7, 3) == 1
assert euler_characteristic(1, 0, 0) == 1

// 경계 후보 빈 토폴로지
let empty_cands = compute_boundary_candidates([], [])
assert len(empty_cands) == 0

// Union-Find 검증
let uf = uf_make(5)
assert uf_find(uf, 0) == 0
assert uf_find(uf, 4) == 4
let uf2 = uf_union(uf, 0, 1)
assert uf_find(uf2, 0) == uf_find(uf2, 1)

println("=== singularity.hexa verified ===")

