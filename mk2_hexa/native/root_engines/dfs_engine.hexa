// Ported from tecs-l/dfs_engine.py
// Depth-first search over arithmetic expression trees built from
// {sigma, tau, P1, phi} base constants. Track A port: the numpy import in
// the .py is unused — all control flow is DFS over integer expressions.

const SIGMA: int = 12
const TAU: int   = 4
const P1: int    = 6
const PHI: int   = 2

// Operator tags.
const OP_ADD: int = 0
const OP_SUB: int = 1
const OP_MUL: int = 2
const OP_DIV: int = 3

pure fn apply_op(op: int, a: int, b: int) -> int {
    match op {
        0 -> a + b,
        1 -> a - b,
        2 -> a * b,
        3 -> if b == 0 { 0 } else { a / b },
        _ -> 0
    }
}

// Bases available at leaf positions.
pure fn bases() -> [int] { [SIGMA, TAU, P1, PHI] }

// DFS search: at depth 0 return each base; otherwise combine any two
// sub-results via any op. Returns whether any path hits the target.
pure fn dfs(target: int, depth: int) -> bool {
    if depth == 0 {
        let b = bases();
        return target == b[0] || target == b[1] || target == b[2] || target == b[3];
    }
    // Try depth-(d-1) + depth-(d-1) combinations.
    let d1 = depth - 1;
    let b = bases();
    let mut i = 0;
    while i < 4 {
        let mut j = 0;
        while j < 4 {
            let mut op = 0;
            while op < 4 {
                let v = apply_op(op, b[i], b[j]);
                if v == target { return true; }
                op = op + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    false
}

fn main() {
    print("dfs target=24 depth=1: ");
    print(dfs(24, 1));
    print("\n");
    print("dfs target=137 depth=1: ");
    print(dfs(137, 1));
    print("\n");
}
