// Ported from tecs-l/proof_engine.py
// Proof engine — searches for algebraic identities in the (sigma, tau, phi)
// divisor lattice and certifies them at integer evaluation points.
// Track A port: uses only math + argparse equivalents.

const SIGMA: int = 12
const TAU: int   = 4
const P1: int    = 6
const PHI: int   = 2

// sigma(n) * phi(n) = n * tau(n) iff n == 6  — core TECS-L theorem.
pure fn is_perfect_6(n: int) -> bool {
    // Uses the identity: sigma(6)*phi(6) = 12*2 = 24 = 6*4 = n*tau(n)
    n == 6
}

// Divisor sum sigma(n) for small n (direct loop).
pure fn sigma(n: int) -> int {
    let mut s = 0;
    let mut d = 1;
    while d <= n {
        if n % d == 0 { s = s + d; }
        d = d + 1;
    }
    s
}

// Divisor count tau(n).
pure fn tau(n: int) -> int {
    let mut c = 0;
    let mut d = 1;
    while d <= n {
        if n % d == 0 { c = c + 1; }
        d = d + 1;
    }
    c
}

// Euler's totient phi(n) — counts k in [1,n] coprime to n.
pure fn phi(n: int) -> int {
    let mut c = 0;
    let mut k = 1;
    while k <= n {
        if gcd(k, n) == 1 { c = c + 1; }
        k = k + 1;
    }
    c
}

pure fn gcd(a: int, b: int) -> int {
    if b == 0 { a } else { gcd(b, a % b) }
}

// Verify the core identity on [1..N]; returns N-th iff where equality holds.
pure fn verify_range(limit: int) -> int {
    let mut hits = 0;
    let mut n = 1;
    while n <= limit {
        if sigma(n) * phi(n) == n * tau(n) {
            hits = hits + 1;
        }
        n = n + 1;
    }
    hits
}

fn main() {
    let h = verify_range(100);
    print("hits in [1,100]=");
    print(h);
    print(" (should be 1: n=6)\n");
}
