// Ported from tecs-l/chemistry_engine.py
// Chemistry element analysis engine — sigma(6)=12, tau(6)=4 lens over
// elements Z=1..36 (periods 1..4). Track A port: math-only source.
// Full element table and sigma/tau expression search are materialized here
// in pure hexa form (no numpy dependency).

// ─────────────────────────────────────────
// Core divisor-function constants of perfect number 6
// ─────────────────────────────────────────
const SIGMA: int = 12      // sigma(6) = 1+2+3+6
const TAU: int   = 4       // tau(6)   = |{1,2,3,6}|
const P1: int    = 6       // first perfect number
const PHI: int   = 2       // smallest prime
const M3: int    = 7       // Mersenne prime 2^3 - 1

struct Element {
    symbol: string,
    z: int,          // atomic number
    a: int,          // mass number
    config: string,  // electron configuration
    group: int,
    period: int
}

// ─────────────────────────────────────────
// sigma/tau expression classifier
// ─────────────────────────────────────────
struct Expr {
    formula: string,
    grade: string,   // "exact" | "natural" | "adhoc"
    ad_hoc: bool
}

pure fn exact_match(n: int) -> bool {
    n == SIGMA || n == TAU || n == P1 || n == PHI
}

pure fn is_natural_combo(n: int) -> bool {
    // Combinations without tunable constants: built from sigma, tau, P1, phi
    // via +, -, *, //, **
    n == SIGMA + TAU || n == SIGMA - TAU || n == SIGMA * TAU || n == SIGMA / TAU || n == TAU * TAU || n == TAU * TAU * TAU || n == SIGMA * SIGMA || n == SIGMA + P1 || n == SIGMA * P1 || n == P1 * TAU || n == P1 * P1
}

// Try to classify n as sigma/tau expression; returns grade tag.
pure fn classify_n(n: int) -> string {
    match n {
        _ if exact_match(n)        -> "exact",
        _ if is_natural_combo(n)   -> "natural",
        _                           -> "adhoc"
    }
}

// ─────────────────────────────────────────
// Life's essential elements (CHNOPS)
// ─────────────────────────────────────────
pure fn is_life_essential(sym: string) -> bool {
    sym == "H" || sym == "C" || sym == "N" || sym == "O" || sym == "P" || sym == "S"
}

// ─────────────────────────────────────────
// Triple-alpha check: 3*He4 -> C12, i.e. 3*tau == sigma
// ─────────────────────────────────────────
pure fn triple_alpha_identity() -> bool {
    3 * TAU == SIGMA
}

// Electron-shell sum check: 2n^2 totals vs sigma/tau lattice
pure fn shell_capacity(n: int) -> int {
    2 * n * n
}

// Entry point — enumerate life elements and report grade of Z.
fn main() {
    let symbols = ["H", "C", "N", "O", "P", "S"];
    let zs      = [1, 6, 7, 8, 15, 16];
    for i in 0..6 {
        let g = classify_n(zs[i]);
        print(symbols[i]);
        print(" Z=");
        print(zs[i]);
        print(" grade=");
        print(g);
        print("\n");
    }
    if triple_alpha_identity() {
        print("triple-alpha: 3*tau == sigma OK\n");
    }
}
