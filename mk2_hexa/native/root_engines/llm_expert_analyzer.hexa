// Ported from tecs-l/llm_expert_analyzer.py
// Lightweight LLM-expert routing analyzer: given per-expert activation counts
// it scores balance against a uniform ideal and against a sigma/tau weighted
// ideal. Track A port: the numpy usage is just arithmetic mean/std, which we
// inline here in pure hexa.

const SIGMA: int = 12
const TAU: int   = 4

pure fn sum_i(xs: [int], n: int) -> int {
    let mut s = 0;
    let mut i = 0;
    while i < n { s = s + xs[i]; i = i + 1; }
    s
}

pure fn mean_f(xs: [int], n: int) -> float {
    to_float(sum_i(xs, n)) / to_float(n)
}

pure fn variance(xs: [int], n: int) -> float {
    let mu = mean_f(xs, n);
    let mut acc = 0.0;
    let mut i = 0;
    while i < n {
        let d = to_float(xs[i]) - mu;
        acc = acc + d * d;
        i = i + 1;
    }
    acc / to_float(n)
}

// Balance score: lower variance == better routing.
pure fn balance_score(counts: [int], n: int) -> float {
    let v = variance(counts, n);
    1.0 / (1.0 + v)
}

// sigma/tau ideal: expert i gets (SIGMA - (i * TAU)) weight if positive.
pure fn sigmatau_ideal(n_experts: int) -> float {
    let mut s = 0;
    let mut i = 0;
    while i < n_experts {
        let w = SIGMA - i * TAU;
        if w > 0 { s = s + w; }
        i = i + 1;
    }
    to_float(s) / to_float(n_experts)
}

fn main() {
    let counts = [12, 8, 6, 4];
    let s = balance_score(counts, 4);
    print("balance=");
    print(s);
    print(" ideal=");
    print(sigmatau_ideal(4));
    print("\n");
}
