// Ported from tecs-l/discovery_loop.py
// Discovery loop: schedules verify_*, collects results, grades them, promotes
// strong hits to the n6 registry. Track A port skeleton — the Python version
// orchestrates subprocess calls to other engines; here we keep the pure
// algorithmic core (grading + promotion logic) and leave I/O to the runner.

const SIGMA: int = 12
const TAU: int   = 4
const P1: int    = 6

struct Candidate {
    name: string,
    score: float,    // Texas p-value or match quality
    exact: bool
}

// Grade tags.
const GRADE_GREEN: int  = 0   // 🟩 exact + proven
const GRADE_ORANGE_STAR: int = 1  // 🟧★ approx + p<0.01
const GRADE_ORANGE: int = 2   // 🟧 approx + p<0.05
const GRADE_WHITE: int  = 3   // ⚪ p>0.05
const GRADE_BLACK: int  = 4   // ⬛ refuted

pure fn grade_of(c: Candidate) -> int {
    if c.exact {
        GRADE_GREEN
    } else if c.score < 0.01 {
        GRADE_ORANGE_STAR
    } else if c.score < 0.05 {
        GRADE_ORANGE
    } else if c.score < 0.50 {
        GRADE_WHITE
    } else {
        GRADE_BLACK
    }
}

// Promote a candidate if grade is GREEN or ORANGE_STAR.
pure fn should_promote(c: Candidate) -> bool {
    let g = grade_of(c);
    g == GRADE_GREEN || g == GRADE_ORANGE_STAR
}

// Discovery budget: how many candidates to probe per tick (tau = 4).
pure fn budget_per_tick() -> int { TAU }

fn main() {
    let c = Candidate { name: "h_nt_7", score: 0.005, exact: false };
    print("grade=");
    print(grade_of(c));
    print(" promote=");
    print(should_promote(c));
    print("\n");
}
