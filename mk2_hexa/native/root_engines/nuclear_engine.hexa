// Ported from tecs-l/nuclear_engine.py
// Nuclear physics engine — magic numbers, triple-alpha, binding-energy curve,
// all expressed through sigma(6)=12, tau(6)=4 lens. Track A port: math-only.

const SIGMA: int = 12
const TAU: int   = 4
const P1: int    = 6
const PHI: int   = 2

// Nuclear magic numbers (closed shells, protons or neutrons).
// {2, 8, 20, 28, 50, 82, 126}
pure fn is_magic(n: int) -> bool {
    n == 2 || n == 8 || n == 20 || n == 28 || n == 50 || n == 82 || n == 126
}

// Classify a magic number as sigma/tau expression.
pure fn magic_as_sigmatau(n: int) -> string {
    match n {
        2   -> "phi",                  // 2
        8   -> "sigma-tau",             // 12-4
        20  -> "sigma+sigma-tau",       // 12+12-4
        28  -> "sigma*tau-sigma-8",     // not natural — adhoc
        50  -> "sigma*tau+phi",         // 48+2
        82  -> "sigma*P1+sigma-tau-2",  // adhoc
        126 -> "sigma*P1+sigma*tau+P1", // 72+48+6
        _   -> "nonmagic"
    }
}

// Triple-alpha: 3 He-4 -> C-12. Key identity: 3*tau == sigma.
pure fn triple_alpha() -> bool {
    3 * TAU == SIGMA
}

// Semi-empirical mass formula (Bethe–Weizsäcker, Z protons, N neutrons).
// Returns binding energy in MeV. Coefficients from PDG.
pure fn binding_energy(z: int, n: int) -> float {
    let a   = z + n;
    if a == 0 { return 0.0; }
    let a_f = to_float(a);
    let av  = 15.75;
    let as_ = 17.80;
    let ac  = 0.711;
    let asy = 23.70;
    let ap  = 11.18;

    let vol = av * a_f;
    let sur = as_ * pow(a_f, 2.0 / 3.0);
    let cou = ac * to_float(z * (z - 1)) / pow(a_f, 1.0 / 3.0);
    let sym = asy * pow(to_float(n - z), 2.0) / a_f;

    let pair = if (z % 2 == 0) && (n % 2 == 0) { ap / pow(a_f, 0.5) } else if (z % 2 == 1) && (n % 2 == 1) { -ap / pow(a_f, 0.5) } else { 0.0 };

    vol - sur - cou - sym + pair
}

fn main() {
    let magics = [2, 8, 20, 28, 50, 82, 126];
    for m in magics {
        print(m);
        print(" -> ");
        print(magic_as_sigmatau(m));
        print("\n");
    }
    if triple_alpha() {
        print("triple-alpha OK\n");
    }
    // Fe-56 binding energy check (~492 MeV)
    print(binding_energy(26, 30));
    print("\n");
}
