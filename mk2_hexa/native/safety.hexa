// safety.hexa — 자율운영 안전 게이트 (n=6 임계점)
// 사용: hexa safety.hexa check <phi> <stability> <anomaly_rate> <n6_exact>
//       hexa safety.hexa defaults

fn min_f(a: f64, b: f64) -> f64 { if a < b { return a } return b }
fn max_f(a: f64, b: f64) -> f64 { if a > b { return a } return b }
fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x } return x }

// n=6 기반 임계점
// phi_threshold = 1/(sigma-phi) = 1/10 = 0.1
// stability_threshold = 0.5
// max_anomaly_rate = 1/sigma = 1/12 ≈ 0.0833
fn default_phi_threshold() -> f64 { return 0.1 }
fn default_stability_threshold() -> f64 { return 0.5 }
fn default_max_anomaly_rate() -> f64 { return 1.0 / 12.0 }

fn check_gate(phi: f64, stability: f64, anomaly_rate: f64, n6_exact: f64) -> string {
    let phi_th = default_phi_threshold()
    let stab_th = default_stability_threshold()
    let anom_th = default_max_anomaly_rate()

    let mut failures = ""
    let mut fail_count = 0

    if phi < phi_th {
        failures = failures + "phi_score=" + to_string(phi) + " < " + to_string(phi_th)
        fail_count = fail_count + 1
    }
    if stability < stab_th {
        if fail_count > 0 { failures = failures + ", " }
        failures = failures + "stability=" + to_string(stability) + " < " + to_string(stab_th)
        fail_count = fail_count + 1
    }
    if anomaly_rate > anom_th {
        if fail_count > 0 { failures = failures + ", " }
        failures = failures + "anomaly_rate=" + to_string(anomaly_rate) + " > " + to_string(anom_th)
        fail_count = fail_count + 1
    }

    if fail_count > 0 {
        return "BLOCK: " + failures
    }

    // confidence 계산
    let phi_margin = if phi_th > 0.0 { min_f(phi / phi_th, 2.0) / 2.0 } else { 1.0 }
    let stab_margin = if stab_th > 0.0 { min_f(stability / stab_th, 2.0) / 2.0 } else { 1.0 }
    let anom_margin = if anom_th > 0.0 { max_f(1.0 - anomaly_rate / anom_th, 0.0) } else { 1.0 }
    let n6_bonus = n6_exact * 0.1
    let confidence = min_f((phi_margin + stab_margin + anom_margin) / 3.0 + n6_bonus, 1.0)

    return "ALLOW (confidence: " + to_string(confidence * 100.0) + "%)"
}

// ─── MAIN ───
let a = args()
let mode = if a.len() >= 3 { a[2] } else { "defaults" }

if mode == "defaults" {
    println("╔═══════════════════════════════════╗")
    println("║  NEXUS-6 Safety Gate (n=6)        ║")
    println("╠═══════════════════════════════════╣")
    println("  phi_threshold      : " + to_string(default_phi_threshold()) + "  (1/(σ-φ) = 1/10)")
    println("  stability_threshold: " + to_string(default_stability_threshold()))
    println("  max_anomaly_rate   : " + to_string(default_max_anomaly_rate()) + "  (1/σ = 1/12)")
    println("╚═══════════════════════════════════╝")
}

if mode == "check" {
    let phi = if a.len() >= 4 { to_float(a[3]) } else { 0.8 }
    let stab = if a.len() >= 5 { to_float(a[4]) } else { 0.9 }
    let anom = if a.len() >= 6 { to_float(a[5]) } else { 0.01 }
    let n6ex = if a.len() >= 7 { to_float(a[6]) } else { 0.5 }

    println("  phi=" + to_string(phi) + " stability=" + to_string(stab) + " anomaly=" + to_string(anom) + " n6_exact=" + to_string(n6ex))
    println("  → " + check_gate(phi, stab, anom, n6ex))
}
