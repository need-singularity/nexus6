// mk2_hexa/native/anima_status.hexa — anima 학습 현황 대시보드
// 실행: hexa mk2_hexa/native/anima_status.hexa
// 데이터: anima/config/training_runs.json + growth_loop_state.json + runpod.json

let a = args()
let home = exec("printenv HOME")
let anima_dir = home + "/Dev/anima/anima"
let config_dir = anima_dir + "/config"

// ─── 날짜 ───
let today = exec("date +%Y-%m-%d").trim()

// ─── training_runs.json 파싱 ───
let tr_path = config_dir + "/training_runs.json"
let mut tr_raw = ""
try { tr_raw = read_file(tr_path) } catch err {
    println("❌ training_runs.json 읽기 실패: " + tr_path)
}

// ─── growth_loop_state.json 파싱 (상위 10줄만 — 176KB 전체 로드 방지) ───
let gl_path = config_dir + "/growth_loop_state.json"
let mut gl_raw = ""
try { gl_raw = exec("head -15 " + gl_path + " 2>/dev/null") } catch err {}

fn extract_json_int(content: string, key: string) -> i64 {
    let search = "\"" + key + "\":"
    if !content.contains(search) { return 0 }
    let parts = content.split(search)
    if len(parts) < 2 { return 0 }
    let after = parts[1].trim()
    // 첫 번째 숫자만 추출
    let num_part = after.split(",")[0].split("}")[0].split("\n")[0].trim()
    to_int(num_part)
}

fn extract_json_str(content: string, key: string) -> string {
    let search = "\"" + key + "\":\""
    if !content.contains(search) { return "" }
    let parts = content.split(search)
    if len(parts) < 2 { return "" }
    let after = parts[1]
    let end_parts = after.split("\"")
    if len(end_parts) >= 1 { end_parts[0] } else { "" }
}

fn extract_json_float(content: string, key: string) -> float {
    let search = "\"" + key + "\":"
    if !content.contains(search) { return 0.0 }
    let parts = content.split(search)
    if len(parts) < 2 { return 0.0 }
    let after = parts[1].trim()
    let mut num_str = ""
    let mut i = 0
    while i < len(after) {
        let ch = after[i]
        if ch == "," || ch == "}" || ch == " " || ch == "\n" { i = len(after) }
        else { num_str = num_str + ch }
        i = i + 1
    }
    to_float(num_str)
}

// ─── RunPod 상태 (runpod.json에서 읽기, API 호출 없음) ───
let mut pod_status = "확인 필요 (runpodctl pod list)"
let mut pod_count = 0
let rp_path = config_dir + "/runpod.json"
let mut rp_raw = ""
try { rp_raw = read_file(rp_path) } catch err {}
if len(rp_raw) > 0 {
    let rp_status = extract_json_str(rp_raw, "status")
    let rp_name = extract_json_str(rp_raw, "name")
    if len(rp_status) > 0 {
        pod_status = rp_name + " (" + rp_status + ")"
    }
}

// ─── 성장 루프 데이터 ───
let cycle = extract_json_int(gl_raw, "cycle")
let harvested = extract_json_int(gl_raw, "total_harvested")
let applied = extract_json_int(gl_raw, "total_applied")
let self_disc = extract_json_int(gl_raw, "total_self_discoveries")

// ─── 학습 이력 파싱 (runs 블록 내 각 run) ───
// 수동 파싱: 각 run key를 찾아서 필드 추출
struct TrainRun {
    name: string,
    ce: string,
    phi: string,
    steps: string,
    status: string,
    date: string,
}

fn parse_run(content: string, run_key: string) -> TrainRun {
    let search = "\"" + run_key + "\":"
    if !content.contains(search) {
        return TrainRun { name: run_key, ce: "?", phi: "?", steps: "?", status: "?", date: "?" }
    }
    let parts = content.split(search)
    if len(parts) < 2 {
        return TrainRun { name: run_key, ce: "?", phi: "?", steps: "?", status: "?", date: "?" }
    }
    // 이 run의 블록만 추출 (다음 run key까지)
    let block = parts[1]
    // "    }," + newline + "    \"" 패턴으로 분리 (다음 run 시작)
    let block_parts = block.split("\n    \"")
    let run_block = if len(block_parts) >= 1 { block_parts[0] } else { block }

    let mut ce_val = "?"
    if run_block.contains("\"ce_best\":") {
        let cp = run_block.split("\"ce_best\":")
        if len(cp) >= 2 { ce_val = cp[1].split(",")[0].trim() }
    } else if run_block.contains("\"ce_at_5000\":") {
        let cp = run_block.split("\"ce_at_5000\":")
        if len(cp) >= 2 { ce_val = cp[1].split(",")[0].trim() + "@5K" }
    } else if run_block.contains("\"ce_3000\":") {
        let cp = run_block.split("\"ce_3000\":")
        if len(cp) >= 2 { ce_val = cp[1].split(",")[0].trim() + "@3K" }
    }

    let mut phi_val = "?"
    if run_block.contains("\"phi_best\":") {
        let pp = run_block.split("\"phi_best\":")
        if len(pp) >= 2 { phi_val = pp[1].split(",")[0].split("}")[0].trim() }
    } else if run_block.contains("\"phi_at_5000\":") {
        let pp = run_block.split("\"phi_at_5000\":")
        if len(pp) >= 2 { phi_val = pp[1].split(",")[0].trim() }
    }

    let mut steps_val = "?"
    if run_block.contains("\"steps\":") {
        let sp = run_block.split("\"steps\":")
        if len(sp) >= 2 { steps_val = sp[1].split(",")[0].trim() }
    }

    let mut status_val = "?"
    if run_block.contains("\"status\"") {
        let st = run_block.split("\"status\"")
        if len(st) >= 2 {
            let after_s = st[1].split("\"")
            // after_s[0] = ": ", after_s[1] = value
            if len(after_s) >= 2 { status_val = after_s[1] }
        }
    }
    let mut date_val = "?"
    if run_block.contains("\"date\"") {
        let dt = run_block.split("\"date\"")
        if len(dt) >= 2 {
            let after_d = dt[1].split("\"")
            if len(after_d) >= 2 { date_val = after_d[1] }
        }
    }

    TrainRun { name: run_key, ce: ce_val, phi: phi_val, steps: steps_val, status: status_val, date: date_val }
}

// ─── 각 run 파싱 ───
let complete_keys = "v14.0|v14.1|animalm_14b_v01|animalm_14b_v02|animalm_14b_v03|animalm_14b_v04"
let progress_keys = "v14.3_128c|v3_274M|animalm_72b_v05|animalm_7b_fresh"
let planned_keys = "animalm_14b_v05|animalm_32b_v01"

let ck = complete_keys.split("|")
let pk = progress_keys.split("|")
let plk = planned_keys.split("|")

// ─── 표시용 이름 매핑 ───
fn display_name(key: string) -> string {
    if key == "v14.0" { "v14.0 (34.5M)" }
    else if key == "v14.1" { "v14.1 tension-lr" }
    else if key == "v14.3_128c" { "v14.3 128c" }
    else if key == "v3_274M" { "v3 274M" }
    else if key == "animalm_14b_v01" { "AnimaLM 14B v0.1" }
    else if key == "animalm_14b_v02" { "AnimaLM 14B v0.2" }
    else if key == "animalm_14b_v03" { "AnimaLM 14B v0.3" }
    else if key == "animalm_14b_v04" { "AnimaLM 14B v0.4" }
    else if key == "animalm_72b_v05" { "AnimaLM 72B v0.5" }
    else if key == "animalm_7b_fresh" { "AnimaLM 7B fresh" }
    else if key == "animalm_14b_v05" { "AnimaLM 14B v0.5" }
    else if key == "animalm_32b_v01" { "AnimaLM 32B v0.1" }
    else { key }
}

fn pad(s: string, width: i64) -> string {
    let mut r = s
    while len(r) < width { r = r + " " }
    r
}

fn status_icon(s: string) -> string {
    if s.contains("complete") { "done" }
    else if s.contains("in_progress") { "run " }
    else if s.contains("crashed") { "CRASH" }
    else if s.contains("stopped") { "stop" }
    else if s.contains("planned") { "plan" }
    else { s }
}

// ─── 출력 ───
println("┌─────────────────────────────────────────────────────────────┐")
println("│  anima 학습 현황 — " + today + "                                │")
println("├─────────────────────────────────────────────────────────────┤")
println("│                                                             │")

// 완료
println("│  ■ 완료된 학습 (" + to_string(len(ck)) + "건)                                         │")
println("│  ┌──────────────────┬──────────┬───────┬────────┬──────────┐│")
println("│  │ 모델             │ CE best  │ Φ     │ Steps  │ 날짜     ││")
println("│  ├──────────────────┼──────────┼───────┼────────┼──────────┤│")

let mut ci = 0
while ci < len(ck) {
    let r = parse_run(tr_raw, ck[ci])
    let star = if ck[ci] == "animalm_14b_v04" { "★" } else { " " }
    println("│  │ " + pad(display_name(r.name), 16) + " │ " + pad(r.ce, 8) + " │ " + pad(r.phi, 5) + " │ " + pad(r.steps, 6) + " │ " + pad(r.date, 7) + star + "││")
    ci = ci + 1
}
println("│  └──────────────────┴──────────┴───────┴────────┴──────────┘│")
println("│                                                             │")

// 진행/중단
println("│  ■ 진행/중단 (" + to_string(len(pk)) + "건)                                           │")
println("│  ┌──────────────────┬──────────┬───────┬────────┬──────────┐│")
println("│  │ 모델             │ CE       │ Φ     │ 상태   │ 비고     ││")
println("│  ├──────────────────┼──────────┼───────┼────────┼──────────┤│")

let mut pi = 0
while pi < len(pk) {
