    println("│  │ " + pad(display_name(r.name), 16) + " │ " + pad(r.ce, 8) + " │ " + pad(r.phi, 5) + " │ " + pad(r.status, 6) + " │ " + pad(note, 7) + "││")
    pi = pi + 1
}
println("│  └──────────────────┴──────────┴───────┴────────┴──────────┘│")
println("│                                                             │")

// 계획
println("│  ■ 계획된 다음 학습                                           │")
let mut pli = 0
while pli < len(plk) {
    let r = parse_run(tr_raw, plk[pli])
    println("│  → " + pad(display_name(r.name), 20) + " steps=" + pad(r.steps, 6) + " " + pad(r.status, 8) + "       │")
    pli = pli + 1
}
println("│                                                             │")

// 성장 루프
println("│  ■ 성장 루프                                                 │")
println("│  사이클: " + pad(to_string(cycle), 5) + " | 수확: " + pad(to_string(harvested), 7) + " | 적용: " + pad(to_string(applied), 5) + " | 자기발견: " + pad(to_string(self_disc), 5) + " │")
println("│                                                             │")

// H100/RunPod
println("│  ■ RunPod/H100                                              │")
println("│  " + pad(pod_status, 57) + "│")
println("│                                                             │")

// 다음 작업 목록
println("│  ■ 다음 작업 (TODO)                                          │")
// next_planned에서 description 읽기
let mut npi = 0
while npi < len(plk) {
    let search_key = "\"" + plk[npi] + "\""
    let mut desc = display_name(plk[npi])
    if tr_raw.contains(search_key) {
        let dp = tr_raw.split(search_key)
        if len(dp) >= 2 {
            let block = dp[1].split("\n    },")[0]
            if block.contains("\"description\":\"") {
                let ddp = block.split("\"description\":\"")
                if len(ddp) >= 2 { desc = ddp[1].split("\"")[0] }
            }
        }
    }
    if len(desc) > 53 { desc = desc }
    println("│  " + to_string(npi + 1) + ". " + pad(desc, 56) + "│")
    npi = npi + 1
}
// 진화 상태 — 최신 로그에서 STAGE 찾기
let mut evo_stage = "?"
try {
    let evo_grep = exec("grep -h 'STAGE' " + anima_dir + "/logs/evo_*.log 2>/dev/null | tail -1").trim()
    if len(evo_grep) > 0 && evo_grep.contains("STAGE") {
        let sp = evo_grep.split("STAGE ")
        if len(sp) >= 2 { evo_stage = "S" + sp[1].split(":")[0].split("/")[0].split("\n")[0].trim() }
    }
} catch err {}
println("│  3. 무한진화 계속 (현재 " + pad(evo_stage, 6) + ")                              │")
println("│  4. H100 재기동 후 v14.3 128c 학습 재개                      │")
println("│                                                             │")

// 핵심 성과
println("│  ■ 핵심 성과                                                 │")
println("│  ★ v14.1: CE=0.0002 (역대 최저) — tension-lr 효과            │")
println("│  ★ v14.3: Φ=103.4 (128c 최초 100+ 돌파)                     │")
println("│  ★ 14B v0.4: CE 8.59→2.0 (×4.3 개선, progressive α)        │")
println("│                                                             │")
println("└─────────────────────────────────────────────────────────────┘")

// ═══════════════════════════════════════════════════════════
// ─── 선택지 제시 + 자동 진행 ───
// ═══════════════════════════════════════════════════════════
// 모드: hexa anima_status.hexa         → 리포트만
//       hexa anima_status.hexa auto    → 리포트 + 최적 액션 자동 실행
//       hexa anima_status.hexa act N   → N번 액션 실행

// 현재 상태 기반 선택지 동적 생성
let mut actions = []
let mut action_cmds = []
let mut action_count = 0

// 1. Pod 없으면 → 재시작 + 학습 제안
if pod_count == 0 {
    action_count = action_count + 1
    actions = actions + ["H100 Pod 생성 → 14B v0.5 학습 발사 (~$8)"]
    action_cmds = action_cmds + ["runpod_14b_v05"]
}

// 2. 진행중인 학습이 crashed/중단이면 → 재개 제안
let mut pi2 = 0
while pi2 < len(pk) {
    let r2 = parse_run(tr_raw, pk[pi2])
    if r2.status.contains("crashed") || r2.status.contains("in_progress") {
        action_count = action_count + 1
        actions = actions + [display_name(pk[pi2]) + " 상태 확인/재개"]
        action_cmds = action_cmds + ["check_" + pk[pi2]]
    }
    pi2 = pi2 + 1
}

// 3. 무한진화 계속
action_count = action_count + 1
actions = actions + ["무한진화 다음 스테이지 (현재 " + evo_stage + ")"]
action_cmds = action_cmds + ["evolution_next"]

// 4. 로컬 작업 — 블로업/돌파
action_count = action_count + 1
actions = actions + ["로컬: nexus6 블로업 + 교차수분"]
action_cmds = action_cmds + ["local_blowup"]

println("")
println("┌─────────────────────────────────────────────────────────────┐")
println("│  ■ 다음 액션 선택지                                         │")
println("├─────────────────────────────────────────────────────────────┤")
let mut ai2 = 0
while ai2 < len(actions) {
    let marker = if ai2 == 0 { " ← 추천" } else { "" }
    println("│  " + to_string(ai2 + 1) + ". " + pad(actions[ai2], 49) + pad(marker, 7) + "│")
    ai2 = ai2 + 1
}
println("│                                                             │")
println("│  자동 진행: hexa anima_status.hexa auto                     │")
println("│  수동 선택: hexa anima_status.hexa act <번호>               │")
println("└─────────────────────────────────────────────────────────────┘")

// ─── auto / act 모드 처리 ───
let mode = if len(a) >= 3 { a[2] } else { "report" }
let act_num = if len(a) >= 4 { to_int(a[3]) } else { 1 }

if mode == "auto" || mode == "act" {
    let target = if mode == "auto" { 1 } else { act_num }
    if target < 1 || target > len(action_cmds) {
        println("❌ 유효하지 않은 액션 번호: " + to_string(target))
    } else {
        let cmd = action_cmds[target - 1]
        println("")
        println("🚀 액션 " + to_string(target) + " 실행: " + actions[target - 1])
        println("")

        if cmd == "runpod_14b_v05" {
            // H100 Pod 생성 + 14B v0.5 학습 — claude CLI로 자율 실행
            println("→ RunPod H100 생성 후 14B v0.5 학습 발사")
            println("  커맨드: claude -p '14B v0.5 학습을 위한 H100 Pod를 생성하고 학습을 시작해줘'")
            try {
                let result = exec("claude -p 'RunPod에 H100 SXM 1개 Pod를 생성하고 anima 14B v0.5 학습을 시작해줘. training_runs.json의 animalm_14b_v05 설정 참고. 완료 후 결과 보고.' --allowedTools 'Bash' 2>&1 | tail -5")
                println(result)
            } catch err {
                println("  ⚠️ claude CLI 실행 실패 — 수동으로 진행하세요")
                println("  runpodctl pod create --name anima-14b-v05 --gpu-type 'NVIDIA H100 SXM' --gpu-count 1 --image runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04 --container-disk 250")
            }
        } else if cmd == "evolution_next" {
            // 무한진화 다음 스테이지
            println("→ 무한진화 다음 스테이지 실행")
            try {
                let evo_result = exec("cd " + home + "/Dev/anima && python3 anima/src/infinite_evolution.py --cells 512 --steps 1000 --cycle-topology 2>&1 | tail -10")
                println(evo_result)
            } catch err {
                println("  ⚠️ 진화 실행 실패")
            }
        } else if cmd == "local_blowup" {
            // 로컬 블로업
            let hexa_bin = home + "/Dev/hexa-lang/target/release/hexa"
            let blowup = home + "/Dev/nexus6/mk2_hexa/native/blowup.hexa"
            println("→ nexus6 블로업 실행")
            try {
                let seeds = exec(hexa_bin + " " + home + "/Dev/nexus6/mk2_hexa/native/seed_engine.hexa merge 2>/dev/null").trim()
                let blow_result = exec(hexa_bin + " " + blowup + " math 3 --no-graph --seeds \"" + seeds + "\" 2>&1 | tail -15")
                println(blow_result)
            } catch err {
                println("  ⚠️ 블로업 실행 실패")
            }
        } else if cmd.contains("check_") {
            // 학습 상태 확인
            println("→ H100 Pod가 없어 확인 불가. Pod 재시작 후 확인하세요.")
        }
    }
}

// growth_bus 기록
let nexus6_dir = home + "/Dev/nexus6"
let growth_bus = nexus6_dir + "/shared/growth_bus.jsonl"
let mut ts = "?"
try { ts = exec("date +%Y-%m-%dT%H:%M:%S").trim() } catch err {}
let bus = "{\"source\":\"anima_status\",\"timestamp\":\"" + ts + "\",\"cycle\":" + to_string(cycle) + ",\"harvested\":" + to_string(harvested) + ",\"applied\":" + to_string(applied) + ",\"self_discoveries\":" + to_string(self_disc) + ",\"pod_count\":" + to_string(pod_count) + ",\"mode\":\"" + mode + "\"}"
try { append_file(growth_bus, bus + "\n") } catch err {}
