// ─── CLI ENTRY POINT ───

fn main() {
    let argv = args()
    let mut cmd = if argv.len() >= 3 { to_string(argv[2]) } else { "" }
    let mut target = if argv.len() >= 3 { to_string(argv[2]) } else { "" }

    if cmd == "help" || cmd == "--help" || cmd == "-h" || cmd == "" { show_help() ; return }
    if cmd == "status" { show_status() ; return }

    if cmd == "design" {
        if target == "" { println("  ERROR: specify domain — energy, transport, biotech, materials, computing, communication") ; return }
        let mut valid = false
        let mut i: i64 = 0
        while i < DOMAINS.len() { if to_string(DOMAINS[i]) == target { valid = true } ; i = i + 1 }
        if !valid { println("  ERROR: unknown domain '" + target + "'") ; return }
        let grade = run_design_pipeline(target)
        if grade == "OPTIMAL" { println("\n  Result: OPTIMAL architecture for " + target) }
        if grade == "VIABLE" { println("\n  Result: VIABLE (consider re-annealing)") }
        if grade != "OPTIMAL" && grade != "VIABLE" { println("\n  Result: SUBOPTIMAL — increase iterations") }
        return
    }

    if cmd == "optimize" {
        let ok = run_optimize_all()
        if ok { println("\n  OPTIMIZATION COMPLETE: majority at OPTIMAL") }
        if !ok { println("\n  OPTIMIZATION PARTIAL: re-run for convergence") }
        return
    }

    println("  ERROR: unknown command '" + cmd + "' — try: hexa arch_quantum.hexa help")
}

main()
