// dse_resonance_verify.hexa — Verify DSE cross-pairs from dse_cross_results.json
// Reads shared/dse/dse_cross_results.json, validates each pair's shared constants
// Checks: constant count consistency, score thresholds, duplicate pairs
//
// Usage:
//   hexa dse_resonance_verify.hexa              Full verification report
//   hexa dse_resonance_verify.hexa --summary    Compact one-line summary
//   hexa dse_resonance_verify.hexa --high-only  Verify high-confidence pairs only

fn main() {
    let home = exec("printenv HOME").trim()
    let shared = home + "/Dev/nexus/shared"
    let dse_path = shared + "/dse_cross_results.json"
    let bus_path = shared + "/growth_bus.jsonl"

    let a = args()
    let mode = if a.len() >= 3 { a[2] } else { "" }

    if mode == "--help" {
        println("dse_resonance_verify.hexa -- Verify DSE cross-pairs")
        println("Usage: hexa dse_resonance_verify.hexa [--summary|--high-only]")
        return
    }

    // Load DSE results
    let mut raw = ""
    try { raw = read_file(dse_path) } catch e {
        println("[ERROR] cannot read " + dse_path + " -- " + to_string(e))
        return
    }

    // Extract pair_count and high_confidence_count from top-level
    let mut declared_pairs: i64 = 0
    let mut declared_hc: i64 = 0
    try {
        let pp = raw.split("\"pair_count\":")
        if pp.len() >= 2 { declared_pairs = to_int(to_float(pp[1].split(",")[0].trim())) }
    } catch e {}
    try {
        let hp = raw.split("\"high_confidence_count\":")
        if hp.len() >= 2 { declared_hc = to_int(to_float(hp[1].split(",")[0].trim())) }
    } catch e {}

    // Parse high_confidence array entries
    let mut hc_raw = ""
    try {
        let hcp = raw.split("\"high_confidence\":[")
        if hcp.len() >= 2 { hc_raw = hcp[1].split("]")[0] }
    } catch e {}

    let entries = hc_raw.split("},{")
    let n_entries = to_int(entries.len())

    let mut verified: i64 = 0
    let mut warnings: i64 = 0
    let mut errors: i64 = 0
    let mut seen_keys = #{}
    let mut low_score: i64 = 0
    let mut zero_consts: i64 = 0

    let mut i: i64 = 0
    while i < n_entries {
        let entry = entries[i]
        i = i + 1

        // Extract fields
        let mut a_val = ""
        let mut b_val = ""
        let mut n_consts: i64 = 0
        let mut n_lenses: i64 = 0
        let mut score: f64 = 0.0

        try {
            let ap = entry.split("\"a\":\"")
            if ap.len() >= 2 { a_val = ap[1].split("\"")[0] }
        } catch e {}
        try {
            let bp = entry.split("\"b\":\"")
            if bp.len() >= 2 { b_val = bp[1].split("\"")[0] }
        } catch e {}
        try {
            let np = entry.split("\"n_consts\":")
            if np.len() >= 2 { n_consts = to_int(to_float(np[1].split(",")[0].split("}")[0].trim())) }
        } catch e {}
        try {
            let lp = entry.split("\"n_lenses\":")
            if lp.len() >= 2 { n_lenses = to_int(to_float(lp[1].split(",")[0].split("}")[0].trim())) }
        } catch e {}
        try {
            let sp = entry.split("\"score\":")
            if sp.len() >= 2 { score = to_float(sp[1].split(",")[0].split("}")[0].trim()) }
        } catch e {}

        if a_val == "" || b_val == "" { continue }

        // Check: duplicate pair
        let key = a_val + "|" + b_val
        let key_rev = b_val + "|" + a_val
        if seen_keys.contains_key(key) || seen_keys.contains_key(key_rev) {
            warnings = warnings + 1
            if mode != "--summary" { println("  [WARN] duplicate pair: " + a_val + " <-> " + b_val) }
        }
        seen_keys[key] = 1

        // Check: n_lenses >= 3 for high_confidence
        if n_lenses < 3 {
            errors = errors + 1
            if mode != "--summary" { println("  [ERR] " + a_val + " <-> " + b_val + " n_lenses=" + to_string(n_lenses) + " < 3") }
        }

        // Check: zero constants
        if n_consts == 0 {
            zero_consts = zero_consts + 1
        }

        // Check: low score
        if score < 0.01 { low_score = low_score + 1 }

        verified = verified + 1
    }

    let ts = exec("date -u +%Y-%m-%dT%H:%M:%S").trim()
    let pass = errors == 0

    if mode == "--summary" {
        let status = if pass { "PASS" } else { "FAIL" }
        println("[dse_verify] " + status + " verified=" + to_string(verified) + " err=" + to_string(errors) + " warn=" + to_string(warnings) + " declared_pairs=" + to_string(declared_pairs) + " hc=" + to_string(declared_hc))
    } else {
        println("")
        println("=== DSE RESONANCE VERIFY ===")
        println("  declared pairs:       " + to_string(declared_pairs))
        println("  declared high-conf:   " + to_string(declared_hc))
        println("  verified entries:     " + to_string(verified))
        println("  errors:              " + to_string(errors))
        println("  warnings:            " + to_string(warnings))
        println("  zero-const pairs:    " + to_string(zero_consts))
        println("  low-score (<0.01):   " + to_string(low_score))
        println("  status:              " + if pass { "PASS" } else { "FAIL" })
        println("============================")
    }

    // Append to growth_bus
    try {
        let evt = "{\"ts\":\"" + ts + "\",\"type\":\"dse_resonance_verify\",\"verified\":" + to_string(verified) + ",\"errors\":" + to_string(errors) + ",\"warnings\":" + to_string(warnings) + ",\"pass\":" + if pass { "true" } else { "false" } + ",\"source\":\"dse_resonance_verify.hexa\"}\n"
        let existing = exec("cat " + bus_path)
        write_file(bus_path, existing + evt)
    } catch e {}
}

main()
