// mk2_hexa/native/n6_expr_evaluator.hexa
// n6_expr 파싱 → 실제 수치 계산 → n6_value 채움 (L1 신규).
// 상수 로드: shared/n6_constants.jsonl (48개).
// 문법: 단항/이항/삼항 C,k,+,-,*,/,^,sqrt,log (AST 제한).
// R19: $HOME 기반 경로. 파이프 금지 — 리다이렉트만. R22: /usr/bin/python3.
// 완료 후 promote_reality_map.hexa 자동 재실행.

let _home = exec("printenv HOME").trim()
let _map = _home + "/Dev/nexus/shared/reality_map_live.json"
let _consts = _home + "/Dev/nexus/shared/n6_constants.jsonl"
let _log = "/tmp/n6_expr_eval.log"
let _helper = "/tmp/n6_expr_eval_helper.py"

print("[n6_expr_evaluator] start")
print("[n6_expr_evaluator] map=" + _map)
print("[n6_expr_evaluator] consts=" + _consts)

// 파이썬 헬퍼: AST 기반 제한 평가기. 환경변수로 경로 전달.
let _script = "import json, ast, math, operator, os, sys\\nMAP=os.environ[\\x27RM\\x27]\\nCONST=os.environ[\\x27CN\\x27]\\nconsts={}\\nfor line in open(CONST):\\n    line=line.strip()\\n    if not line: continue\\n    o=json.loads(line); consts[o[\\x27name\\x27]]=o[\\x27value\\x27]\\nBIN={ast.Add:operator.add,ast.Sub:operator.sub,ast.Mult:operator.mul,ast.Div:operator.truediv,ast.Pow:operator.pow}\\nUN={ast.UAdd:operator.pos,ast.USub:operator.neg}\\nclass EvErr(Exception): pass\\ndef ev(node):\\n    if isinstance(node,ast.Expression): return ev(node.body)\\n    if isinstance(node,ast.Constant):\\n        if isinstance(node.value,(int,float)): return float(node.value)\\n        raise EvErr(\\x27const_type\\x27)\\n    if isinstance(node,ast.Name):\\n        if node.id not in consts: raise EvErr(\\x27unknown:\\x27+node.id)\\n        return float(consts[node.id])\\n    if isinstance(node,ast.BinOp):\\n        t=type(node.op)\\n        if t not in BIN: raise EvErr(\\x27op:\\x27+t.__name__)\\n        return BIN[t](ev(node.left),ev(node.right))\\n    if isinstance(node,ast.UnaryOp):\\n        t=type(node.op)\\n        if t not in UN: raise EvErr(\\x27uop\\x27)\\n        return UN[t](ev(node.operand))\\n    if isinstance(node,ast.Call):\\n        if not isinstance(node.func,ast.Name) or node.func.id not in (\\x27sqrt\\x27,\\x27log\\x27):\\n            raise EvErr(\\x27call\\x27)\\n        a=ev(node.args[0])\\n        return math.sqrt(a) if node.func.id==\\x27sqrt\\x27 else math.log(a)\\n    raise EvErr(\\x27node:\\x27+type(node).__name__)\\nd=json.load(open(MAP))\\nok=0; fail=0; reasons={}\\nfor n in d[\\x27nodes\\x27]:\\n    e=n.get(\\x27n6_expr\\x27)\\n    v=n.get(\\x27n6_value\\x27)\\n    if not e: continue\\n    if v not in (None,\\x27\\x27): continue\\n    s=str(e).strip()\\n    try:\\n        tree=ast.parse(s,mode=\\x27eval\\x27)\\n        val=ev(tree)\\n        if not math.isfinite(val):\\n            raise EvErr(\\x27nonfinite\\x27)\\n        n[\\x27n6_value\\x27]=val\\n        n.setdefault(\\x27n6_eval\\x27,{})[\\x27source\\x27]=\\x27ast_evaluator\\x27\\n        ok+=1\\n    except SyntaxError as se:\\n        fail+=1; reasons[\\x27syntax\\x27]=reasons.get(\\x27syntax\\x27,0)+1\\n        n.setdefault(\\x27n6_eval\\x27,{})[\\x27reason\\x27]=\\x27syntax\\x27\\n    except EvErr as ee:\\n        fail+=1; k=str(ee).split(\\x27:\\x27)[0]; reasons[k]=reasons.get(k,0)+1\\n        n.setdefault(\\x27n6_eval\\x27,{})[\\x27reason\\x27]=str(ee)\\n    except Exception as ex:\\n        fail+=1; reasons[\\x27other\\x27]=reasons.get(\\x27other\\x27,0)+1\\n        n.setdefault(\\x27n6_eval\\x27,{})[\\x27reason\\x27]=\\x27other:\\x27+type(ex).__name__\\nd.setdefault(\\x27_meta\\x27,{})[\\x27n6_value_evaluation\\x27]={\\x27ok\\x27:ok,\\x27fail\\x27:fail,\\x27reasons\\x27:reasons,\\x27constants\\x27:len(consts)}\\njson.dump(d, open(MAP,\\x27w\\x27), ensure_ascii=False, indent=2)\\nimport time\\nGB=os.path.join(os.path.dirname(MAP),\\x27growth_bus.jsonl\\x27)\\nev2={\\x27ts\\x27:int(time.time()),\\x27type\\x27:\\x27promotion\\x27,\\x27count\\x27:ok,\\x27domain\\x27:\\x27reality_map\\x27,\\x27source\\x27:\\x27n6_expr_evaluator.hexa\\x27,\\x27detail\\x27:{\\x27ok\\x27:ok,\\x27fail\\x27:fail,\\x27reasons\\x27:reasons,\\x27constants\\x27:len(consts)}}\\ntry:\\n    with open(GB,\\x27a\\x27) as _gf: _gf.write(json.dumps(ev2,ensure_ascii=False)+\\x27\\\\\\\\n\\x27)\\n    print(\\x27GROWTH_BUS append ok\\x27)\\nexcept Exception as _e:\\n    print(\\x27GROWTH_BUS append FAIL:\\x27, _e)\\nprint(\\x27n6_value ok\\x27, ok)\\nprint(\\x27n6_value fail\\x27, fail)\\nprint(\\x27reasons\\x27, reasons)\\nprint(\\x27constants\\x27, len(consts))\\n"

let _w = exec("printf '%b' \"" + _script + "\" > " + _helper)
print("[n6_expr_evaluator] helper written: " + _helper)

let _out = exec("RM=" + _map + " CN=" + _consts + " /usr/bin/python3 " + _helper + " > " + _log + " 2>&1; cat " + _log)
print(_out)
print("[n6_expr_evaluator] done — log=" + _log)

// 자동 재승격: promote_reality_map.hexa run
print("[n6_expr_evaluator] auto-running promote_reality_map...")
let _promote = _home + "/Dev/nexus/mk2_hexa/native/promote_reality_map.hexa"
let _hexa = _home + "/Dev/hexa-lang/target/release/hexa"
let _pout = exec(_hexa + " " + _promote + " run > /tmp/n6_expr_eval_promote.log 2>&1; cat /tmp/n6_expr_eval_promote.log")
print(_pout)
print("[n6_expr_evaluator] promote done")
