// ── helpers ──

fn is_prime(n: int) -> bool {
    if n < 2 { return false }
    if n < 4 { return true }
    if n % 2 == 0 || n % 3 == 0 { return false }
    let mut i = 5
    while i * i <= n {
        if n % i == 0 || n % (i + 2) == 0 { return false }
        i = i + 6
    }
    true
}

// sum of prime factors (with multiplicity)
fn sopfr_fn(n: int) -> int {
    let mut s = 0
    let mut v = n
    let mut p = 2
    while p * p <= v {
        while v % p == 0 {
            s = s + p
            v = v / p
        }
        p = p + 1
    }
    if v > 1 { s = s + v }
    s
}

// number of distinct prime factors
fn omega_fn(n: int) -> int {
    let mut c = 0
    let mut v = n
    let mut p = 2
    while p * p <= v {
        if v % p == 0 {
            c = c + 1
            while v % p == 0 { v = v / p }
        }
        p = p + 1
    }
    if v > 1 { c = c + 1 }
    c
}

// distinct prime factors as array
fn prime_factors(n: int) -> [int] {
    let mut res = []
    let mut v = n
    let mut p = 2
    while p * p <= v {
        if v % p == 0 {
            res = res + [p]
            while v % p == 0 { v = v / p }
        }
        p = p + 1
    }
    if v > 1 { res = res + [v] }
    res
}

// divisors of n
fn divisors_of(n: int) -> [int] {
    let mut res = []
    let mut d = 1
    while d * d <= n {
        if n % d == 0 {
            res = res + [d]
            if d != n / d { res = res + [n / d] }
        }
        d = d + 1
    }
    res
}

// is squarefree?
fn is_squarefree(n: int) -> bool {
    let mut v = n
    let mut p = 2
    while p * p <= v {
        if v % (p * p) == 0 { return false }
        p = p + 1
    }
    true
}

// count points on y^2 = x^3 + ax + b over F_p
fn count_pts(a: int, b: int, p: int) -> int {
    let mut cnt = 1
    let mut x = 0
    while x < p {
        let rhs = (x * x * x + a * x + b) % p
        let rhs_pos = (rhs % p + p) % p
        if rhs_pos == 0 {
            cnt = cnt + 1
        } else {
            // Euler criterion: rhs^((p-1)/2) mod p
            let exp = (p - 1) / 2
            let mut acc = 1
            let mut base = rhs_pos % p
            let mut e = exp
            while e > 0 {
                if e % 2 == 1 { acc = (acc * base) % p }
                base = (base * base) % p
                e = e / 2
            }
            if acc == 1 { cnt = cnt + 2 }
        }
        x = x + 1
    }
    cnt
}

