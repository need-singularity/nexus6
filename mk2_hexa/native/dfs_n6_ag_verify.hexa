// GENERALIZATION TEST: Perfect numbers 6, 28, 496
// ════════════════════════════════════════════════════════════
let sep = "============================================================"
println(sep)
println("GENERALIZATION TEST: Perfect numbers 6, 28, 496")
println(sep)

let perfects = [6, 28, 496]
let mut pi = 0
while pi < len(perfects) {
    let pn = perfects[pi]
    let s = sigma(pn)
    let t = tau(pn)
    let p = phi(pn)
    let sp = sopfr_fn(pn)
    let om = omega_fn(pn)
    println("")
    println("  n = " + to_string(pn) + ":")
    println("    sigma=" + to_string(s) + ", tau=" + to_string(t) + ", phi=" + to_string(p) + ", sopfr=" + to_string(sp) + ", omega=" + to_string(om))
    println("    -sigma/tau = " + to_string(0 - s / t))
    println("    n^2 = " + to_string(pn * pn))
    pi = pi + 1
}

