let mut fi = 0
while fi < len(pf6) {
    let pp = pf6[fi]
    prod_p2 = prod_p2 * pp * pp
    fi = fi + 1
}
println("  prod_{p|6} p^2 = " + to_string(prod_p2))
println("  This equals n^2 = 36 iff n is squarefree (which 6 is!)")
