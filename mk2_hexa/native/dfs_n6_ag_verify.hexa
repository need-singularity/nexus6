// ════════════════════════════════════════════════════════════
// DISCOVERY 5: X_0(6) genus 0
// ════════════════════════════════════════════════════════════
println("")
println(sep)
println("DISC 5: Genus(X_0(6))=0 and Genus(X_0(12))=0")
println(sep)

println("  X_0(N) genus formula (Riemann-Hurwitz):")
println("  g = 1 + mu/12 - nu2/4 - nu3/3 - nu_inf/2")
println("")
println("  For N=6:")
println("  mu = 6 * prod_{p|6}(1+1/p) = 6*(3/2)*(4/3) = 12")
println("  nu2 = prod(1+(-4/p)) for p|6: p=2: factor=0, so nu2=0")
println("  nu3 = prod(1+(-3/p)) for p|6: p=3: factor=0, so nu3=0")

// nu_inf = sum_{d|N} phi(gcd(d, N/d))
let divs6 = divisors_of(6)
let mut nu_inf = 0
let mut di = 0
while di < len(divs6) {
    let d = divs6[di]
    nu_inf = nu_inf + phi(gcd(d, 6 / d))
    di = di + 1
}
println("  nu_inf = " + to_string(nu_inf))

// g(X_0(6)) = 1 + 12/12 - 0 - 0 - nu_inf/2
// Use integer arithmetic: multiply everything by 12
// g*12 = 12 + 12 - 0 - 0 - 6*nu_inf
let g6_num = 12 + 12 - 6 * nu_inf
println("  g(X_0(6)) = (12 + 12 - 0 - 0 - 6*" + to_string(nu_inf) + ")/12 = " + to_string(g6_num) + "/12 = " + to_string(g6_num / 12))

println("")
println("  For N=12:")
let divs12 = divisors_of(12)
let mut nu_inf_12 = 0
let mut di2 = 0
while di2 < len(divs12) {
    let d = divs12[di2]
    nu_inf_12 = nu_inf_12 + phi(gcd(d, 12 / d))
    di2 = di2 + 1
}
println("  mu=24, nu_inf=" + to_string(nu_inf_12))
let g12_num = 12 + 24 - 6 * nu_inf_12
println("  g(X_0(12)) = (12+24-0-0-6*" + to_string(nu_inf_12) + ")/12 = " + to_string(g12_num) + "/12 = " + to_string(g12_num / 12))
println("")
println("  Key: Both X_0(n) and X_0(2n) for n=6 have genus 0")
println("  And X_0(sigma(6)) = X_0(12) has genus 0")
println("  sigma(6) = 12. EXACT. Grade: EXACT")

