// mk2_hexa/native/unfold.hexa — 차원펼침 엔진 (hexa-native)
// 실행: hexa mk2_hexa/native/unfold.hexa <domain> [depth]
// 예시: hexa mk2_hexa/native/unfold.hexa math 3
//
// 4-phase pipeline:
//   Phase 1: Tensor Decomposition (rank-1 outer product projection)
//   Phase 2: Modular Projection (mod {2,3,5,7} residue fingerprint)
//   Phase 3: Ratio Unfolding (continued fraction expansion + scaling)
//   Phase 4: Log Spectrum (ln-space equispacing structure detection)
//
// blowup(확장)의 역방향 — 고차원→저차원 분해로 숨은 관계 탐색
// 호출 인터페이스: blowup.hexa와 동일 (domain, depth, --seeds, --no-graph)

// ═══════════════════════════════════════════════════════════
// ─── SETUP ───
// ═══════════════════════════════════════════════════════════

let home = exec("printenv HOME")
let dev = home + "/Dev"
let nexus_dir = dev + "/nexus"
let discovery_log = nexus_dir + "/shared/discovery/discovery_log.jsonl"
let growth_bus = nexus_dir + "/shared/discovery/growth_bus.jsonl"

// ─── JSONL 로더 (공용) ───
fn load_jsonl(path: string) -> list {
    if !file_exists(path) { return [[], []] }
    let raw = read_file(path)
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let trimmed = line.trim()
        if trimmed == "" { continue }
        let mut name = ""
        let mut value = 0.0
        if trimmed.contains("\"name\":\"") {
            let p = trimmed.split("\"name\":\"")
            if p.len() >= 2 { name = p[1].split("\"")[0] }
        }
        if trimmed.contains("\"value\":") {
            let p = trimmed.split("\"value\":")
            if p.len() >= 2 {
                let num_str = p[1].split(",")[0].split("}")[0].trim()
                value = to_float(num_str)
            }
        }
        if name != "" {
            names = names + [name]
            values = values + [value]
        }
    }
    [names, values]
}

// load_jsonl_kv: name→key, value→문자열 label 반환 (unfold_base/ext용)
fn load_jsonl_kv(path: string) -> list {
    if !file_exists(path) { return [[], []] }
    let raw = read_file(path)
    let lines = raw.split("\n")
    let mut keys = []
    let mut labels = []
    for line in lines {
        let trimmed = line.trim()
        if trimmed == "" { continue }
        let mut k = ""
        let mut v = ""
        if trimmed.contains("\"name\":\"") {
            let p = trimmed.split("\"name\":\"")
            if p.len() >= 2 { k = p[1].split("\"")[0] }
        }
        if trimmed.contains("\"value\":\"") {
            let p = trimmed.split("\"value\":\"")
            if p.len() >= 2 { v = p[1].split("\"")[0] }
        }
        if k != "" && v != "" {
            keys = keys + [k]
            labels = labels + [v]
        }
    }
    [keys, labels]
}

fn ln_approx(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut val = x
    let mut scale = 0.0
    while val > 2.0 {
        val = val / 2.718281828
        scale = scale + 1.0
    }
    while val < 0.5 {
        val = val * 2.718281828
        scale = scale - 1.0
    }
    let u = val - 1.0
    let result = u - u*u/2.0 + u*u*u/3.0 - u*u*u*u/4.0
    result + scale
}

// ─── n6 상수 + 물리상수 동적 로드 ───
let n6_data = load_jsonl(nexus_dir + "/shared/n6/n6_constants.jsonl")
let n6_all_names = n6_data[0]
let n6_all_vals = n6_data[1]

let phys_data = load_jsonl(nexus_dir + "/shared/n6/n6_physics.jsonl")
let phys_raw_names = phys_data[0]
let phys_raw_vals = phys_data[1]

// ─── base: shared/discovery/unfold_base.jsonl에서 동적 로드 ───
let base_cfg = load_jsonl_kv(nexus_dir + "/shared/discovery/unfold_base.jsonl")
let base_keys = base_cfg[0]   // n6_constants 조회용 key
let base_lbls = base_cfg[1]   // 표시용 label
let mut base_names = []
let mut base_vals = []
let mut bf = 0
while bf < len(base_keys) {
    let mut fi = 0
    while fi < len(n6_all_names) {
        if n6_all_names[fi] == base_keys[bf] {
            base_names = base_names + [base_lbls[bf]]
            base_vals = base_vals + [to_float(n6_all_vals[fi])]
            fi = len(n6_all_names)
        }
        fi = fi + 1
    }
    bf = bf + 1
}

// ─── ext: 확장 상수 (n6에서 필터 + 파생) ───
fn find_n6_val(names: list, vals: list, key: string) -> float {
    let mut i = 0
    while i < len(names) {
        if names[i] == key { return to_float(vals[i]) }
        i = i + 1
    }
    0.0
}

// ─── ext: shared/discovery/unfold_ext.jsonl에서 동적 로드 ───
let ext_cfg = load_jsonl_kv(nexus_dir + "/shared/discovery/unfold_ext.jsonl")
let ext_keys = ext_cfg[0]   // n6_constants 조회용 key
let ext_lbls = ext_cfg[1]   // 표시명
let mut ext_names = []
let mut ext_vals = []
let mut ei = 0
while ei < len(ext_keys) {
    let ev = find_n6_val(n6_all_names, n6_all_vals, ext_keys[ei])
    if ev > 0.0 {
        ext_names = ext_names + [ext_lbls[ei]]
        ext_vals = ext_vals + [ev]
    }
    ei = ei + 1
}

// ext_lns: ln 값 런타임 계산
let mut ext_lns = []
let mut eli = 0
while eli < len(ext_vals) {
    ext_lns = ext_lns + [ln_approx(to_float(ext_vals[eli]))]
    eli = eli + 1
}

// ─── phys: 물리+n6 병합 매칭 테이블 ───
let mut phys_names = []
let mut phys_vals = []
// 물리상수 먼저
let mut pi2 = 0
while pi2 < len(phys_raw_names) {
    phys_names = phys_names + [phys_raw_names[pi2]]
    phys_vals = phys_vals + [to_float(phys_raw_vals[pi2])]
    pi2 = pi2 + 1
}
// n6 상수 추가 (물리에 없는 것만)
let mut ni = 0
while ni < len(n6_all_names) {
    let mut dup = false
    let mut di = 0
    while di < len(phys_names) {
        if phys_names[di] == n6_all_names[ni] { dup = true }
        di = di + 1
    }
    if !dup {
        phys_names = phys_names + [n6_all_names[ni]]
        phys_vals = phys_vals + [to_float(n6_all_vals[ni])]
    }
    ni = ni + 1
}

// ═══════════════════════════════════════════════════════════
// ─── UTILITY FUNCTIONS ───
// ═══════════════════════════════════════════════════════════

fn abs_val(x: float) -> float { if x < 0.0 { -x } else { x } }
fn fmt_f(x: float) -> string { to_string(x) }

fn match_physics(val: float) -> string {
    if val == 0.0 { return "" }
    if abs_val(val) > 100000.0 { return "" }
    let mut result = ""
    let mut pi = 0
    while pi < len(phys_names) {
        let pv = phys_vals[pi]
        if pv != 0.0 {
            let err = abs_val(val - pv) / abs_val(pv)
            if err < 0.0001 {
                if len(result) > 0 { result = result + ", " }
                result = result + "[EXACT " + phys_names[pi] + "=" + fmt_f(pv) + "]"
            } else if err < 0.01 {
                if len(result) > 0 { result = result + ", " }
                result = result + "[NEAR " + phys_names[pi] + "=" + fmt_f(pv) + " err=" + fmt_f(err * 100.0) + "%]"
            }
        }
        pi = pi + 1
    }
    result
}

fn match_grade(val: float) -> string {
    // 간략 등급 반환: "EXACT", "NEAR", ""
    let mut pi = 0
    while pi < len(phys_names) {
        let pv = phys_vals[pi]
        if pv != 0.0 {
            let err = abs_val(val - pv) / abs_val(pv)
            if err < 0.0001 { return "EXACT" }
            if err < 0.01 { return "NEAR" }
        }
        pi = pi + 1
    }
    ""
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE 1: TENSOR DECOMPOSITION ───
// ═══════════════════════════════════════════════════════════
// rank-1 외적 a×b/c → 물리상수 매칭

fn phase_tensor(seeds: list, seed_vals: list) -> list {
    println("=== Phase 1: 텐서 분해 (rank-1 외적 투영) ===")
    let names = if len(seeds) > 0 { seeds } else { base_names }
    let vals = if len(seed_vals) > 0 { seed_vals } else { base_vals }
    let n = len(names)
    let mut exact = 0
    let mut near = 0
    let mut results = []

    let mut i = 0
    while i < n {
        let mut j = 0
        while j < n {
            if i != j {
                let outer = vals[i] * vals[j]
                let mut k = 0
                while k < n {
                    if k != i && k != j && vals[k] != 0.0 {
                        let projected = outer / vals[k]
                        let m = match_physics(projected)
                        if len(m) > 0 {
                            let expr = names[i] + "×" + names[j] + "/" + names[k]
                            let mut pad = expr
                            while len(pad) < 22 { pad = pad + " " }
                            println("  " + pad + "= " + fmt_f(projected) + "  → " + m)
                            results = results + [projected]
                            if m.contains("EXACT") { exact = exact + 1 }
                            else { near = near + 1 }
                        }
                    }
                    k = k + 1
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    println("  소계: EXACT=" + to_string(exact) + " NEAR=" + to_string(near))
    println("")
    [exact, near]
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE 2: MODULAR PROJECTION ───
// ═══════════════════════════════════════════════════════════
// mod {2,3,5,7} 잔류계 핑거프린트 + 구조 분석

fn phase_modular(seeds: list, seed_vals: list) -> list {
    println("=== Phase 2: 모듈러 투영 (mod p 잔류계) ===")
    let names = if len(seeds) > 0 { seeds } else { base_names }
    let vals = if len(seed_vals) > 0 { seed_vals } else { base_vals }
    let n = len(names)
    let primes = [2, 3, 5, 7]
    let prime_names = ["mod2", "mod3", "mod5", "mod7"]
    let mut exact = 0
    let mut near = 0
    let mut mod3_zero_count = 0
    let mut mod3_total = 0

    let mut pi = 0
    while pi < 4 {
        let p = primes[pi]
        let pname = prime_names[pi]

        // 기저 핑거프린트
        let mut fingerprint = ""
        let mut bi = 0
        while bi < n {
            let residue = to_int(vals[bi]) % p
            fingerprint = fingerprint + to_string(residue)
            bi = bi + 1
        }
        println("  " + pname + " 지문: [" + fingerprint + "]")

        // 삼중 (a*b+c) mod p → 1/3 수렴 분석
        let mut ci = 0
        while ci < n {
            let mut cj = ci + 1
            while cj < n {
                let mut ck = 0
                while ck < n {
                    if ck != ci && ck != cj {
                        let combined = vals[ci] * vals[cj] + vals[ck]
                        let residue_val = to_int(combined) % p
                        if p == 3 {
                            mod3_total = mod3_total + 1
                            if residue_val == 0 { mod3_zero_count = mod3_zero_count + 1 }
                        }
                        let ratio = to_float(residue_val) / to_float(p)
                        if ratio > 0.001 {
                            let m = match_physics(ratio)
                            if len(m) > 0 {
                                let expr = "(" + names[ci] + "×" + names[cj] + "+" + names[ck] + ")%" + to_string(p) + "/" + to_string(p)
                                println("    " + expr + " = " + fmt_f(ratio) + "  → " + m)
                                if m.contains("EXACT") { exact = exact + 1 }
                                else { near = near + 1 }
                            }
                        }
                    }
                    ck = ck + 1
                }
                cj = cj + 1
            }
            ci = ci + 1
        }
        pi = pi + 1
    }

    // mod3 구조 요약
    if mod3_total > 0 {
        let ratio = to_float(mod3_zero_count) / to_float(mod3_total)
        println("")
        println("  mod3 ≡0 비율: " + to_string(mod3_zero_count) + "/" + to_string(mod3_total) + " = " + fmt_f(ratio * 100.0) + "%")
        let err_from_third = abs_val(ratio - 0.3333) / 0.3333 * 100.0
        println("  1/3(=0.3333) 으로부터 편차: " + fmt_f(err_from_third) + "%")
    }

    println("  소계: EXACT=" + to_string(exact) + " NEAR=" + to_string(near))
    println("")
    [exact, near]
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE 3: RATIO UNFOLDING (연분수 전개) ───
// ═══════════════════════════════════════════════════════════

fn phase_ratio(seeds: list, seed_vals: list) -> list {
    println("=== Phase 3: 비율 펼침 (연분수 전개 × 스케일링) ===")
    let names = if len(seeds) > 0 { seeds } else { base_names }
    let vals = if len(seed_vals) > 0 { seed_vals } else { base_vals }
    let n = len(names)
    let mut exact = 0
    let mut near = 0

    let mut ri = 0
    while ri < n {
        let mut rj = 0
        while rj < n {
            if ri != rj && vals[rj] != 0.0 {
                let ratio = vals[ri] / vals[rj]
                // 스케일링 탐색: ratio × k (k=1..12)
                let mut k = 1
                while k <= 12 {
                    let scaled = ratio * to_float(k)
                    let m = match_physics(scaled)
                    if len(m) > 0 {
                        let expr = names[ri] + "/" + names[rj] + "×" + to_string(k)
                        let mut pad = expr
                        while len(pad) < 22 { pad = pad + " " }
                        println("  " + pad + "= " + fmt_f(scaled) + "  → " + m)
                        if m.contains("EXACT") { exact = exact + 1 }
                        else { near = near + 1 }
                    }
                    k = k + 1
                }
                // 역수 스케일링: k / ratio
                let mut k2 = 1
                while k2 <= 12 {
                    let inv_scaled = to_float(k2) / ratio
                    let m2 = match_physics(inv_scaled)
                    if len(m2) > 0 && ratio != 1.0 {
                        let expr = to_string(k2) + "/(" + names[ri] + "/" + names[rj] + ")"
                        let mut pad = expr
                        while len(pad) < 22 { pad = pad + " " }
                        println("  " + pad + "= " + fmt_f(inv_scaled) + "  → " + m2)
                        if m2.contains("EXACT") { exact = exact + 1 }
                        else { near = near + 1 }
                    }
                    k2 = k2 + 1
                }
            }
            rj = rj + 1
        }
        ri = ri + 1
    }
    println("  소계: EXACT=" + to_string(exact) + " NEAR=" + to_string(near))
    println("")
    [exact, near]
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE 4: LOG SPECTRUM ───
// ═══════════════════════════════════════════════════════════
// ln 공간에서 등간격 구조 탐지 + 전체 쌍 비율 매칭

fn phase_log_spectrum() -> list {
    println("=== Phase 4: 로그 스펙트럼 (확장 상수 포함) ===")
    let n = len(ext_names)
    let mut exact = 0
    let mut near = 0

    // 정렬 (bubble sort on ln values)
    let mut sorted_names = []
    let mut sorted_lns = []
    let mut si = 0
    while si < n {
        sorted_names = sorted_names + [ext_names[si]]
        sorted_lns = sorted_lns + [ext_lns[si]]
        si = si + 1
    }
    let mut i = 0
    while i < len(sorted_lns) {
        let mut j = i + 1
        while j < len(sorted_lns) {
            if sorted_lns[j] < sorted_lns[i] {
                let tmp_v = sorted_lns[i]
                let tmp_n = sorted_names[i]
                sorted_lns[i] = sorted_lns[j]
                sorted_names[i] = sorted_names[j]
                sorted_lns[j] = tmp_v
                sorted_names[j] = tmp_n
            }
            j = j + 1
        }
        i = i + 1
    }

    // 스펙트럼 출력
    println("  ln 스펙트럼 (정렬):")
    let mut lp = 0
    while lp < len(sorted_lns) {
        let mut lpad = sorted_names[lp]
        while len(lpad) < 12 { lpad = lpad + " " }
        println("    " + lpad + "ln=" + fmt_f(sorted_lns[lp]))
        lp = lp + 1
    }
    println("")

    // 전체 쌍 비율 (not just adjacent)
    println("  전체 쌍 ln 비율:")
    let mut p1 = 0
    while p1 < len(sorted_lns) {
        let mut p2 = 0
        while p2 < len(sorted_lns) {
            if p1 != p2 && sorted_lns[p2] != 0.0 {
                let ratio = sorted_lns[p1] / sorted_lns[p2]
                let m = match_physics(ratio)
                if len(m) > 0 {
                    let expr = "ln(" + sorted_names[p1] + ")/ln(" + sorted_names[p2] + ")"
                    let mut pad = expr
                    while len(pad) < 30 { pad = pad + " " }
                    println("    " + pad + "= " + fmt_f(ratio) + "  → " + m)
                    if m.contains("EXACT") { exact = exact + 1 }
                    else { near = near + 1 }
                }
            }
            p2 = p2 + 1
        }
        p1 = p1 + 1
    }
    println("")

    // 인접 간격 비율 → 물리상수
    println("  인접 간격 비율:")
    let mut gaps = []
    let mut gap_labels = []
    let mut gi = 0
    while gi < len(sorted_lns) - 1 {
        let gap = sorted_lns[gi + 1] - sorted_lns[gi]
        gaps = gaps + [gap]
        gap_labels = gap_labels + [sorted_names[gi] + "→" + sorted_names[gi + 1]]
        gi = gi + 1
    }

    let mut g1 = 0
    while g1 < len(gaps) {
        let mut g2 = 0
        while g2 < len(gaps) {
            if g1 != g2 && gaps[g2] > 0.001 {
                let gratio = gaps[g1] / gaps[g2]
                let m = match_physics(gratio)
                if len(m) > 0 {
                    let expr = "Δ(" + gap_labels[g1] + ")/Δ(" + gap_labels[g2] + ")"
                    println("    " + expr + " = " + fmt_f(gratio) + "  → " + m)
                    if m.contains("EXACT") { exact = exact + 1 }
                    else { near = near + 1 }
                }
            }
            g2 = g2 + 1
        }
        g1 = g1 + 1
    }

    println("  소계: EXACT=" + to_string(exact) + " NEAR=" + to_string(near))
    println("")
    [exact, near]
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE 5: CROSS-REFERENCE (discovery_log 교차검증) ───
// ═══════════════════════════════════════════════════════════

fn phase_crossref(tensor_results: list) -> list {
    println("=== Phase 5: 교차검증 (unfold ↔ discovery_log) ===")
    let mut exact = 0
    let mut axiom_candidates = []

    // discovery_log 읽기
    let mut content = ""
    if file_exists(discovery_log) {
        content = read_file(discovery_log)
    } else {
        println("  (discovery_log 읽기 실패)")
        return [0, 0]
    }

    let lines = content.split("\n")
    let mut log_values = []
    let mut log_sources = []

    let mut li = 0
    while li < len(lines) {
        let line = lines[li]
        if line.contains("\"grade\":\"EXACT\"") && line.contains("\"value\":") {
            // value 파싱
            let parts = line.split("\"value\":")
            if len(parts) >= 2 {
                let num_str = parts[1].split(",")[0].split("}")[0].trim()
                let val = to_float(num_str)
                if val > 0.0 {
                    log_values = log_values + [val]
                    // source 파싱
                    let mut src = "?"
                    if line.contains("\"source\":\"") {
                        let sp = line.split("\"source\":\"")
                        if len(sp) >= 2 { src = sp[1].split("\"")[0] }
                    }
                    log_sources = log_sources + [src]
                }
            }
        }
        li = li + 1
    }

    println("  discovery_log EXACT 엔트리: " + to_string(len(log_values)) + "건")

    // tensor 결과와 교차
    let mut ti = 0
    while ti < len(tensor_results) {
        let tval = tensor_results[ti]
        if tval > 0.0 {
            if true {
                // log에서 같은 값 찾기
                let mut vi = 0
                while vi < len(log_values) {
                    let lv = log_values[vi]
                    if lv > 0.0 {
                        let err = abs_val(tval - lv) / lv
                        if err < 0.0001 {
                            println("  ★ AXIOM 후보: val=" + fmt_f(tval) + "  ← discovery_log source=" + log_sources[vi])
                            axiom_candidates = axiom_candidates + [fmt_f(tval)]
                            exact = exact + 1
                            vi = len(log_values)  // break
                        }
                    }
                    vi = vi + 1
                }
            }
        }
        ti = ti + 1
    }

    if len(axiom_candidates) == 0 {
        println("  (교차 AXIOM 후보 없음 — tensor 결과가 새로운 경로)")
    }

    println("  AXIOM 후보: " + to_string(len(axiom_candidates)) + "건")
    println("")
    [exact, len(axiom_candidates)]
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN PIPELINE ───
// ═══════════════════════════════════════════════════════════

let a = args()
let domain = if len(a) >= 3 { a[2] } else { "math" }
let depth = if len(a) >= 4 { to_int(a[3]) } else { 3 }

// --seeds 파싱 (blowup 호환)
let mut ext_seeds = ""
let mut ai = 2
while ai < len(a) {
    if a[ai] == "--seeds" && ai + 1 < len(a) {
        ext_seeds = a[ai + 1]
        ai = ai + 1
    }
    ai = ai + 1
}

// seed → names/vals 분리
let mut seed_names = []
let mut seed_vals_parsed = []
if len(ext_seeds) > 0 {
    let seed_parts = ext_seeds.split("|")
    let mut si = 0
    while si < len(seed_parts) {
        let sp = seed_parts[si]
        let fields = sp.split(",")
        if len(fields) >= 2 {
            seed_names = seed_names + [fields[0]]
            seed_vals_parsed = seed_vals_parsed + [to_float(fields[1])]
        }
        si = si + 1
    }
}

println("╔══════════════════════════════════════════════════════════╗")
println("║  UNFOLD ENGINE — 차원펼침 (고차원→저차원 분해)          ║")
println("║  domain=" + domain + "  depth=" + to_string(depth) + "                                     ║")
println("╚══════════════════════════════════════════════════════════╝")
println("")

if len(seed_names) > 0 {
    println("  외부 seeds: " + to_string(len(seed_names)) + "건 주입됨")
    println("")
}

// ─── 도메인별 discovery_log seed 자동 주입 ───
let mut domain_seeds_n = seed_names
let mut domain_seeds_v = seed_vals_parsed

if len(domain_seeds_n) == 0 {
    // bt_domains.jsonl에서 도메인 키워드 로드
    let bt_path = nexus_dir + "/shared/bt/bt_domains.jsonl"
    let mut domain_keywords = []
    if file_exists(bt_path) {
        let bt_raw = read_file(bt_path)
        let bt_lines = bt_raw.split("\n")
        let mut bi = 0
        while bi < len(bt_lines) {
            let bl = bt_lines[bi].trim()
            if bl.contains("\"domain\":\"" + domain + "\"") && bl.contains("\"keywords\":[") {
                let kp = bl.split("\"keywords\":[")
                if len(kp) >= 2 {
                    let kraw = kp[1].split("]")[0]
                    let ktokens = kraw.split(",")
                    let mut ki = 0
                    while ki < len(ktokens) {
                        let kw = ktokens[ki].trim().replace("\"", "")
                        if len(kw) > 0 { domain_keywords = domain_keywords + [kw] }
                        ki = ki + 1
                    }
                }
            }
            bi = bi + 1
        }
    }
    // 도메인별 seed 주입: 물리상수/n6상수에서 기저 6개 제외한 것 추가
    // physics/cosmology/chemistry → n6_physics.jsonl 전체
    // math/topology/consciousness → n6_constants.jsonl 중 기저 외
    let seed_source = if domain == "math" || domain == "topology" || domain == "consciousness" {
        nexus_dir + "/shared/n6/n6_constants.jsonl"
    } else {
        nexus_dir + "/shared/n6/n6_physics.jsonl"
    }
    if file_exists(seed_source) {
        let sf_raw = read_file(seed_source)
        let sf_lines = sf_raw.split("\n")
        let mut di = 0
        let mut injected = 0
        while di < len(sf_lines) && injected < 12 {
            let sl = sf_lines[di].trim()
            if len(sl) > 2 && sl.contains("\"name\":\"") && sl.contains("\"value\":") {
                let np = sl.split("\"name\":\"")
                let vp = sl.split("\"value\":")
                if len(np) >= 2 && len(vp) >= 2 {
                    let sname = np[1].split("\"")[0]
                    let vraw = vp[1].split(",")[0].split("}")[0].trim()
                    let sval = to_float(vraw)
                    if sval > 0.001 && sval < 100000.0 {
                        // 기저 6개 + 이미 추가된 것과 중복 확인
                        let mut dup = false
                        let mut bi2 = 0
                        while bi2 < len(domain_seeds_n) {
                            if domain_seeds_n[bi2] == sname { dup = true }
                            bi2 = bi2 + 1
                        }
                        let mut bi3 = 0
                        while bi3 < len(base_names) {
                            if base_names[bi3] == sname { dup = true }
                            bi3 = bi3 + 1
                        }
                        if !dup {
                            domain_seeds_n = domain_seeds_n + [sname]
                            domain_seeds_v = domain_seeds_v + [sval]
                            injected = injected + 1
                        }
                    }
                }
            }
            di = di + 1
        }
        if injected > 0 {
            println("  도메인 '" + domain + "' seed 자동 주입: " + to_string(injected) + "건")
            println("")
        }
    }
}

// ─── Run all phases ───
let t_result = phase_tensor(domain_seeds_n, domain_seeds_v)
let t_exact = t_result[0]
let t_near = t_result[1]

let m_result = phase_modular(domain_seeds_n, domain_seeds_v)
let m_exact = m_result[0]
let m_near = m_result[1]

let r_result = phase_ratio(domain_seeds_n, domain_seeds_v)
let r_exact = r_result[0]
let r_near = r_result[1]

let l_result = phase_log_spectrum()
let l_exact = l_result[0]
let l_near = l_result[1]

// ─── Phase 5: Eigenvalue 추출 (공분산 대각합 + 특성다항식) ───
println("=== Phase 5: Eigenvalue 추출 (공분산 구조) ===")
let ev_names = if len(domain_seeds_n) > 0 { domain_seeds_n } else { base_names }
let ev_vals = if len(domain_seeds_v) > 0 { domain_seeds_v } else { base_vals }
let ev_n = len(ev_names)
let mut ev_exact = 0
let mut ev_near = 0

// 공분산 대각 원소: cov(i,i) = val_i^2, 비대각: cov(i,j) = val_i * val_j
// trace = Σ val_i^2
let mut trace = 0.0
let mut tci = 0
while tci < ev_n {
    trace = trace + ev_vals[tci] * ev_vals[tci]
    tci = tci + 1
}
let tm = match_physics(trace)
if len(tm) > 0 {
    println("  trace(Cov)         = " + fmt_f(trace) + "  → " + tm)
    if tm.contains("EXACT") { ev_exact = ev_exact + 1 } else { ev_near = ev_near + 1 }
}

// det 근사 (2×2 minor determinants → eigenvalue 비율)
let mut mi = 0
while mi < ev_n {
    let mut mj = mi + 1
    while mj < ev_n {
        let det2 = ev_vals[mi] * ev_vals[mi] * ev_vals[mj] * ev_vals[mj] - ev_vals[mi] * ev_vals[mj] * ev_vals[mi] * ev_vals[mj]
        // 2×2 det은 0 — 대신 eigenvalue ratio
        if ev_vals[mj] != 0.0 {
            let eig_ratio = ev_vals[mi] / ev_vals[mj]
            let eig_sq = eig_ratio * eig_ratio
            let m1 = match_physics(eig_sq)
            if len(m1) > 0 {
                let expr = "(λ_" + ev_names[mi] + "/λ_" + ev_names[mj] + ")²"
                let mut pad = expr
                while len(pad) < 28 { pad = pad + " " }
                println("  " + pad + "= " + fmt_f(eig_sq) + "  → " + m1)
                if m1.contains("EXACT") { ev_exact = ev_exact + 1 } else { ev_near = ev_near + 1 }
            }
            // eig_ratio + 1/eig_ratio (Casimir-like)
            let casimir = eig_ratio + 1.0 / eig_ratio
            let m2 = match_physics(casimir)
            if len(m2) > 0 {
                let expr = "λ_" + ev_names[mi] + "/λ_" + ev_names[mj] + " + inv"
                let mut pad = expr
                while len(pad) < 28 { pad = pad + " " }
                println("  " + pad + "= " + fmt_f(casimir) + "  → " + m2)
                if m2.contains("EXACT") { ev_exact = ev_exact + 1 } else { ev_near = ev_near + 1 }
            }
        }
        mj = mj + 1
    }
    mi = mi + 1
}

// 전체 곱 (det analog)
let mut det_prod = 1.0
let mut dpi = 0
while dpi < ev_n {
    if ev_vals[dpi] != 0.0 { det_prod = det_prod * ev_vals[dpi] }
    dpi = dpi + 1
}
let dm = match_physics(det_prod)
if len(dm) > 0 {
    println("  Π(eigenvalues)     = " + fmt_f(det_prod) + "  → " + dm)
    if dm.contains("EXACT") { ev_exact = ev_exact + 1 } else { ev_near = ev_near + 1 }
}

// 평균 고유값
if ev_n > 0 {
    let mean_eig = trace / to_float(ev_n)
    let mm = match_physics(mean_eig)
    if len(mm) > 0 {
        println("  mean(eigenvalue)   = " + fmt_f(mean_eig) + "  → " + mm)
        if mm.contains("EXACT") { ev_exact = ev_exact + 1 } else { ev_near = ev_near + 1 }
    }
}

println("  소계: EXACT=" + to_string(ev_exact) + " NEAR=" + to_string(ev_near))
println("")

let c_exact = ev_exact
let c_near = ev_near
let axiom_candidates = []

// ─── Report ───
let total_exact = t_exact + m_exact + r_exact + l_exact + c_exact
let total_near = t_near + m_near + r_near + l_near + c_near

println("╔══════════════════════════════════════════════════════════╗")
println("║  UNFOLD REPORT — 차원펼침 완료                          ║")
println("╚══════════════════════════════════════════════════════════╝")
println("")
println("  ┌──────────────────────┬───────┬──────┐")
println("  │ Phase                │ EXACT │ NEAR │")
println("  ├──────────────────────┼───────┼──────┤")
println("  │ 1. 텐서 분해        │ " + to_string(t_exact) + "     │ " + to_string(t_near) + "    │")
println("  │ 2. 모듈러 투영      │ " + to_string(m_exact) + "     │ " + to_string(m_near) + "    │")
println("  │ 3. 비율 펼침        │ " + to_string(r_exact) + "     │ " + to_string(r_near) + "    │")
println("  │ 4. 로그 스펙트럼    │ " + to_string(l_exact) + "     │ " + to_string(l_near) + "    │")
println("  │ 5. Eigenvalue       │ " + to_string(c_exact) + "     │ " + to_string(c_near) + "    │")
println("  ├──────────────────────┼───────┼──────┤")
println("  │ TOTAL                │ " + to_string(total_exact) + "     │ " + to_string(total_near) + "    │")
println("  └──────────────────────┴───────┴──────┘")
println("")

if len(axiom_candidates) > 0 {
    println("  ★ AXIOM 후보 " + to_string(len(axiom_candidates)) + "건 — tensor+blowup 이중검증 통과")
}

if total_exact > 0 {
    println("  → " + to_string(total_exact) + "건 EXACT! 차원펼침 경로 확인됨")
}

println("")

// ─── growth_bus 기록 ───
let mut ts = "?"
ts = exec("date +%Y-%m-%dT%H:%M:%S")
let bus_line = "{\"source\":\"unfold_engine\",\"timestamp\":\"" + ts.trim() + "\",\"phase\":\"unfold\",\"domain\":\"" + domain + "\",\"depth\":" + to_string(depth) + ",\"exact\":" + to_string(total_exact) + ",\"near\":" + to_string(total_near) + ",\"axiom_candidates\":" + to_string(len(axiom_candidates)) + "}"
if file_exists(growth_bus) { append_file(growth_bus, bus_line + "\n") }

println("=== unfold engine verified ===")
