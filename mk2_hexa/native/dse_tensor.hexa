// mk2_hexa/native/dse_tensor.hexa — Tensor Network DSE (텐서 네트워크 DSE)
// Represent domain relationships as tensors, contract to find hidden structure.
//
// Pipeline:
//   T1: Read DSE cross results (347 domains, 59702 pairs)
//   T2: Build adjacency tensor T[i][j] = resonance_score
//   T3: Tensor contraction: T_contracted[i] = Sum_j T[i][j]
//   T4: Find tensor rank: independent directions in domain space
//   T5: Rank-1 approximation = dominant structure. Residual = hidden.
//   T6: Report: dominant domains, hidden connections, tensor rank
//
// Usage:
//   hexa dse_tensor.hexa scan         full pipeline
//   hexa dse_tensor.hexa contract     contraction only
//   hexa dse_tensor.hexa rank         rank analysis
//   hexa dse_tensor.hexa hidden       hidden structure report
//   hexa dse_tensor.hexa help         usage

// ═══════════════════════════════════════════════════════════
// ─── n=6 CONSTANTS (inline) ───
// ═══════════════════════════════════════════════════════════

comptime const N6      = 6
comptime const SIGMA6  = 12
comptime const PHI6    = 2
comptime const TAU6    = 4
comptime const SOPFR6  = 5
comptime const J2_6    = 24
comptime const M3_6    = 7

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {}
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

fn min_f(a: f64, b: f64) -> f64 {
    if a < b { return a }
    return b
}

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 20 {
        g = (g + x / g) / 2.0
        i = i + 1
    }
    return g
}

fn fmt3(x: f64) -> string {
    let neg = x < 0.0
    let ax = abs_f(x)
    let i = to_int(ax * 1000.0 + 0.5)
    let whole = i / 1000
    let frac = i - whole * 1000
    let mut fs = to_string(frac)
    if frac < 100 { fs = "0" + fs }
    if frac < 10 { fs = "0" + fs }
    let mut s = to_string(whole) + "." + fs
    if neg { s = "-" + s }
    return s
}

fn fmt1(x: f64) -> string {
    let neg = x < 0.0
    let ax = abs_f(x)
    let i = to_int(ax * 10.0 + 0.5)
    let whole = i / 10
    let frac = i - whole * 10
    let mut s = to_string(whole) + "." + to_string(frac)
    if neg { s = "-" + s }
    return s
}

fn pad_right(s: string, width: i64) -> string {
    let parts = s.split("")
    let slen = to_int(parts.len()) - 2
    if slen >= width { return s }
    let mut r = s
    let mut i: i64 = 0
    while i < width - slen {
        r = r + " "
        i = i + 1
    }
    return r
}

fn pad_left(s: string, width: i64) -> string {
    let parts = s.split("")
    let slen = to_int(parts.len()) - 2
    if slen >= width { return s }
    let mut r = ""
    let mut i: i64 = 0
    while i < width - slen {
        r = r + " "
        i = i + 1
    }
    return r + s
}

fn json_str(line: string, field: string) -> string {
    let marker = "\"" + field + "\":\""
    let parts = line.split(marker)
    if parts.len() < 2 { return "" }
    let rest = parts[1]
    let end_parts = rest.split("\"")
    if end_parts.len() < 1 { return "" }
    return end_parts[0]
}

fn json_num(line: string, field: string) -> f64 {
    let marker = "\"" + field + "\":"
    let parts = line.split(marker)
    if parts.len() < 2 { return 0.0 }
    let rest = parts[1]
    let end_str = rest.split(",")[0].split("}")[0].split("]")[0].trim()
    return safe_float(end_str)
}

fn now_ts() -> string { exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim() }

// ═══════════════════════════════════════════════════════════
// ─── T1: LOAD DSE CROSS RESULTS ───
// ═══════════════════════════════════════════════════════════

struct TensorEntry {
    domain_a: string,
    domain_b: string,
    score: f64
}

let mut _loaded_domains_set = #{}

fn load_cross_results(shared: string) -> list {
    let path = shared + "/dse_cross_results.json"
    let mut raw = ""
    try { raw = read_file(path) } catch e {
        println("[ERROR] cannot read " + path)
        return []
    }

    // Extract high_confidence array
    let mut entries = []
    let mut domains_set = #{}
    let mut domains = []

    // Parse high_confidence entries: {"a":"...","b":"...","resonance":...}
    let mut hc_raw = ""
    try {
        let hcp = raw.split("\"high_confidence\":[")
        if hcp.len() >= 2 { hc_raw = hcp[1].split("]")[0] }
    } catch e {}

    // If no high_confidence, try top_pairs
    if hc_raw == "" {
        try {
            let tp = raw.split("\"top_pairs\":[")
            if tp.len() >= 2 {
                // Find matching closing bracket
                let rest = tp[1]
                let chunks = rest.split("},{")
                let mut ci = 0
                while ci < chunks.len() {
                    let chunk = chunks[ci]
                    ci = ci + 1
                    let a = json_str(chunk, "a")
                    let b = json_str(chunk, "b")
                    let score = json_num(chunk, "resonance")
                    if a == "" || b == "" { continue }
                    if !domains_set.contains_key(a) {
                        domains_set[a] = to_int(domains.len())
                        domains = domains + [a]
                    }
                    if !domains_set.contains_key(b) {
                        domains_set[b] = to_int(domains.len())
                        domains = domains + [b]
                    }
                    entries = entries + [#{"a": a, "b": b, "score": to_string(score)}]
                }
            }
        } catch e {}
    }

    if hc_raw != "" {
        let chunks = hc_raw.split("},{")
        let mut ci = 0
        while ci < chunks.len() {
            let chunk = chunks[ci]
            ci = ci + 1
            let a = json_str(chunk, "a")
            let b = json_str(chunk, "b")
            let mut score = json_num(chunk, "resonance")
            if score == 0.0 { score = json_num(chunk, "score") }
            if a == "" || b == "" { continue }
            if !domains_set.contains_key(a) {
                domains_set[a] = to_int(domains.len())
                domains = domains + [a]
            }
            if !domains_set.contains_key(b) {
                domains_set[b] = to_int(domains.len())
                domains = domains + [b]
            }
            entries = entries + [#{"a": a, "b": b, "score": to_string(score)}]
        }
    }

    // Also load domain_seeds.jsonl for full domain list
    let seeds_path = shared + "/domain_seeds.jsonl"
    try {
        let seeds_raw = read_file(seeds_path)
        let lines = seeds_raw.split("\n")
        let mut li = 0
        while li < lines.len() {
            let line = lines[li].trim()
            li = li + 1
            if line == "" { continue }
            let domain = json_str(line, "domain")
            if domain != "" && !domains_set.contains_key(domain) {
                domains_set[domain] = to_int(domains.len())
                domains = domains + [domain]
            }
        }
    } catch e {}

    _loaded_domains_set = domains_set
    return [domains, entries]
}

// ═══════════════════════════════════════════════════════════
// ─── T2: BUILD ADJACENCY TENSOR ───
// ═══════════════════════════════════════════════════════════

fn build_tensor(domains: list, domains_set: list, entries: list) -> list {
    let n = to_int(domains.len())
    // Represent as flat list: T[i*n + j] = score
    // Also build contracted vector and row sums
    let mut tensor_flat = []
    let mut i: i64 = 0
    while i < n * n {
        tensor_flat = tensor_flat + [0.0]
        i = i + 1
    }

    // Fill tensor from entries
    let mut ei = 0
    while ei < entries.len() {
        let entry = entries[ei]
        ei = ei + 1
        let a = to_string(entry["a"])
        let b = to_string(entry["b"])
        let score = safe_float(to_string(entry["score"]))
        if !domains_set.contains_key(a) || !domains_set.contains_key(b) { continue }
        let idx_a = to_int(domains_set[a])
        let idx_b = to_int(domains_set[b])
        tensor_flat[idx_a * n + idx_b] = score
        tensor_flat[idx_b * n + idx_a] = score  // symmetric
    }

    return tensor_flat
}

// ═══════════════════════════════════════════════════════════
// ─── T3: TENSOR CONTRACTION ───
// ═══════════════════════════════════════════════════════════

fn contract_tensor(tensor_flat: list, n: i64) -> list {
    // T_contracted[i] = Sum_j T[i][j]  — total resonance per domain
    let mut contracted = []
    let mut i: i64 = 0
    while i < n {
        let mut sum = 0.0
        let mut j: i64 = 0
        while j < n {
            sum = sum + to_float(tensor_flat[i * n + j])
            j = j + 1
        }
        contracted = contracted + [sum]
        i = i + 1
    }
    return contracted
}

// ═══════════════════════════════════════════════════════════
// ─── T4: TENSOR RANK (power iteration for dominant eigenvalue) ───
// ═══════════════════════════════════════════════════════════

let mut _pi_eigenvalue = 0.0

fn power_iteration(tensor_flat: list, n: i64, iters: i64) -> list {
    // Returns eigenvector via power iteration; eigenvalue stored in _pi_eigenvalue
    // Start with uniform vector
    let mut v = []
    let norm_init = 1.0 / sqrt_f(to_float(n))
    let mut i: i64 = 0
    while i < n {
        v = v + [norm_init]
        i = i + 1
    }

    let mut eigenvalue = 0.0
    let mut iter: i64 = 0
    while iter < iters {
        // w = T * v
        let mut w = []
        let mut i2: i64 = 0
        while i2 < n {
            let mut dot = 0.0
            let mut j: i64 = 0
            while j < n {
                dot = dot + to_float(tensor_flat[i2 * n + j]) * to_float(v[j])
                j = j + 1
            }
            w = w + [dot]
            i2 = i2 + 1
        }

        // Compute norm of w
        let mut norm_sq = 0.0
        let mut k: i64 = 0
        while k < n {
            norm_sq = norm_sq + to_float(w[k]) * to_float(w[k])
            k = k + 1
        }
        let norm = sqrt_f(norm_sq)
        if norm < 0.0000001 {
            _pi_eigenvalue = 0.0
            return v
        }

        eigenvalue = norm

        // Normalize w -> v
        let mut new_v = []
        let mut m: i64 = 0
        while m < n {
            new_v = new_v + [to_float(w[m]) / norm]
            m = m + 1
        }
        v = new_v
        iter = iter + 1
    }

    _pi_eigenvalue = eigenvalue
    return v
}

fn estimate_rank(tensor_flat: list, n: i64) -> list {
    // Estimate rank via successive deflation
    // rank = number of significant eigenvalues
    let mut current_tensor = []
    let mut ci: i64 = 0
    while ci < n * n {
        current_tensor = current_tensor + [to_float(tensor_flat[ci])]
        ci = ci + 1
    }

    let mut eigenvalues = []
    let mut eigenvectors = []
    let max_rank = if n < 20 { n } else { 20 }

    let mut rank_iter: i64 = 0
    while rank_iter < max_rank {
        let vec = power_iteration(current_tensor, n, 50)
        let ev = _pi_eigenvalue

        if ev < 0.001 {
            // No more significant eigenvalues
            eigenvalues = eigenvalues + [ev]
            eigenvectors = eigenvectors + [vec]
            rank_iter = max_rank  // exit
            continue
        }

        eigenvalues = eigenvalues + [ev]
        eigenvectors = eigenvectors + [vec]

        // Deflate: T = T - ev * v * v^T
        let mut i3: i64 = 0
        while i3 < n {
            let mut j3: i64 = 0
            while j3 < n {
                let vi = to_float(vec[i3])
                let vj = to_float(vec[j3])
                current_tensor[i3 * n + j3] = to_float(current_tensor[i3 * n + j3]) - ev * vi * vj
                j3 = j3 + 1
            }
            i3 = i3 + 1
        }

        rank_iter = rank_iter + 1
    }

    return [eigenvalues, eigenvectors]
}

// ═══════════════════════════════════════════════════════════
// ─── T5: RANK-1 APPROXIMATION + RESIDUAL (HIDDEN STRUCTURE) ───
// ═══════════════════════════════════════════════════════════

fn find_hidden_structure(tensor_flat: list, n: i64, ev1: f64, vec1: list) -> list {
    // Residual = T - ev1 * v1 * v1^T
    // Large residual entries = hidden connections not captured by dominant structure
    let mut hidden = []
    let mut i: i64 = 0
    while i < n {
        let mut j: i64 = 0
        while j < n {
            if j > i {
                let original = to_float(tensor_flat[i * n + j])
                let rank1 = ev1 * to_float(vec1[i]) * to_float(vec1[j])
                let residual = abs_f(original - rank1)
                if residual > 0.01 {
                    hidden = hidden + [#{"i": to_string(i), "j": to_string(j), "residual": to_string(residual), "original": to_string(original)}]
                }
            }
            j = j + 1
        }
        i = i + 1
    }

    // Sort by residual (descending) — simple bubble sort
    let mut si = 0
    while si < hidden.len() {
        let mut sj = si + 1
        while sj < hidden.len() {
            let ri = safe_float(to_string(hidden[si]["residual"]))
            let rj = safe_float(to_string(hidden[sj]["residual"]))
            if rj > ri {
                let tmp = hidden[si]
                hidden[si] = hidden[sj]
                hidden[sj] = tmp
            }
            sj = sj + 1
        }
        si = si + 1
    }

    return hidden
}

// ═══════════════════════════════════════════════════════════
// ─── n=6 RESONANCE CHECK ───
// ═══════════════════════════════════════════════════════════

fn n6_check_value(v: f64) -> string {
    if abs_f(v - to_float(N6)) < 0.5 { return "n" }
    if abs_f(v - to_float(SIGMA6)) < 0.5 { return "sigma" }
    if abs_f(v - to_float(PHI6)) < 0.5 { return "phi" }
    if abs_f(v - to_float(TAU6)) < 0.5 { return "tau" }
    if abs_f(v - to_float(SOPFR6)) < 0.5 { return "sopfr" }
    if abs_f(v - to_float(J2_6)) < 0.5 { return "J2" }
    if abs_f(v - to_float(M3_6)) < 0.5 { return "M3" }
    return ""
}

fn n6_rank_check(rank: i64) -> string {
    // Check if tensor rank itself resonates with n=6
    if rank == N6 { return "EXACT n=6" }
    if rank == SIGMA6 { return "EXACT sigma(6)=12" }
    if rank == TAU6 { return "EXACT tau(6)=4" }
    if rank == PHI6 { return "EXACT phi(6)=2" }
    if rank == SOPFR6 { return "EXACT sopfr(6)=5" }
    return ""
}

// ═══════════════════════════════════════════════════════════
// ─── REPORT FUNCTIONS ───
// ═══════════════════════════════════════════════════════════

fn report_contraction(domains: list, contracted: list) {
    println("")
    println("[T3] Tensor Contraction -- total resonance per domain")
    println("  " + pad_right("DOMAIN", 30) + pad_left("RESONANCE", 12))
    println("  " + pad_right("------------------------------", 30) + pad_left("----------", 12))

    // Sort by resonance (descending) — collect indices
    let n = to_int(domains.len())
    let mut indices = []
    let mut i: i64 = 0
    while i < n {
        indices = indices + [i]
        i = i + 1
    }

    let mut si = 0
    while si < indices.len() {
        let mut sj = si + 1
        while sj < indices.len() {
            let vi = to_float(contracted[to_int(indices[si])])
            let vj = to_float(contracted[to_int(indices[sj])])
            if vj > vi {
                let tmp = indices[si]
                indices[si] = indices[sj]
                indices[sj] = tmp
            }
            sj = sj + 1
        }
        si = si + 1
    }

    let top_n = if n < 20 { n } else { 20 }
    let mut ti: i64 = 0
    while ti < top_n {
        let idx = to_int(indices[ti])
        let dom = to_string(domains[idx])
        let val = to_float(contracted[idx])
        let n6tag = n6_check_value(val)
        let tag = if n6tag != "" { " [n6:" + n6tag + "]" } else { "" }
        println("  " + pad_right(dom, 30) + pad_left(fmt3(val), 12) + tag)
        ti = ti + 1
    }
}

fn report_rank(eigenvalues: list, n: i64) {
    println("")
    println("[T4] Tensor Rank Analysis")

    let mut significant: i64 = 0
    let mut total_energy = 0.0
    let mut ei: i64 = 0
    while ei < eigenvalues.len() {
        let ev = to_float(eigenvalues[ei])
        total_energy = total_energy + ev * ev
        if ev > 0.001 { significant = significant + 1 }
        ei = ei + 1
    }

    println("  matrix dimension:      " + to_string(n))
    println("  significant eigenvals: " + to_string(significant))
    println("  effective rank:        " + to_string(significant))

    let n6tag = n6_rank_check(significant)
    if n6tag != "" {
        println("  ** n=6 RESONANCE:      " + n6tag + " **")
    }

    // Energy distribution
    println("")
    println("  eigenvalue spectrum:")
    let show_n = if to_int(eigenvalues.len()) < 10 { to_int(eigenvalues.len()) } else { 10 }
    let mut si: i64 = 0
    while si < show_n {
        let ev = to_float(eigenvalues[si])
        let pct = if total_energy > 0.0 { ev * ev / total_energy * 100.0 } else { 0.0 }
        println("    lambda_" + to_string(si + 1) + " = " + pad_left(fmt3(ev), 10) + "  (" + fmt1(pct) + "% energy)")
        si = si + 1
    }

    // Dominance ratio: lambda_1 / sum(lambda_i)
    if eigenvalues.len() > 0 {
        let ev1 = to_float(eigenvalues[0])
        let dominance = if total_energy > 0.0 { ev1 * ev1 / total_energy * 100.0 } else { 0.0 }
        println("")
        println("  dominance ratio: " + fmt1(dominance) + "% (rank-1 captures this much)")
    }
}

fn report_hidden(hidden: list, domains: list) {
    println("")
    println("[T5] Hidden Structure -- residual after rank-1 subtraction")

    let show_n = if to_int(hidden.len()) < 15 { to_int(hidden.len()) } else { 15 }
    if show_n == 0 {
        println("  (no significant hidden connections found)")
        return
    }

    println("  " + pad_right("DOMAIN A", 25) + pad_right("DOMAIN B", 25) + pad_left("RESIDUAL", 10) + pad_left("ORIGINAL", 10))
    println("  " + pad_right("------------------------", 25) + pad_right("------------------------", 25) + pad_left("--------", 10) + pad_left("--------", 10))

    let n_domains = to_int(domains.len())
    let mut hi: i64 = 0
    while hi < show_n {
        let entry = hidden[hi]
        let idx_i = to_int(safe_float(to_string(entry["i"])))
        let idx_j = to_int(safe_float(to_string(entry["j"])))
        let da = if idx_i < n_domains { to_string(domains[idx_i]) } else { "?" }
        let db = if idx_j < n_domains { to_string(domains[idx_j]) } else { "?" }
        let res = safe_float(to_string(entry["residual"]))
        let orig = safe_float(to_string(entry["original"]))
        println("  " + pad_right(da, 25) + pad_right(db, 25) + pad_left(fmt3(res), 10) + pad_left(fmt3(orig), 10))
        hi = hi + 1
    }

    println("")
    println("  total hidden connections: " + to_string(hidden.len()))
}

fn report_summary(domains: list, entries: list, contracted: list, eigenvalues: list, hidden: list) {
    let n = to_int(domains.len())
    let n_pairs = to_int(entries.len())
    let n_hidden = to_int(hidden.len())
    let mut rank: i64 = 0
    let mut ri: i64 = 0
    while ri < eigenvalues.len() {
        if to_float(eigenvalues[ri]) > 0.001 { rank = rank + 1 }
        ri = ri + 1
    }

    // Find max contracted domain
    let mut max_val = 0.0
    let mut max_dom = ""
    let mut mi: i64 = 0
    while mi < n {
        let v = to_float(contracted[mi])
        if v > max_val {
            max_val = v
            max_dom = to_string(domains[mi])
        }
        mi = mi + 1
    }

    println("")
    println("=== TENSOR DSE SUMMARY ===")
    println("  domains:            " + to_string(n))
    println("  pairs loaded:       " + to_string(n_pairs))
    println("  tensor rank:        " + to_string(rank))
    println("  hidden connections: " + to_string(n_hidden))
    println("  hub domain:         " + max_dom + " (" + fmt3(max_val) + ")")

    let n6tag = n6_rank_check(rank)
    if n6tag != "" {
        println("  n=6 resonance:      " + n6tag)
    }
}

fn write_results(shared: string, domains: list, contracted: list, eigenvalues: list, hidden: list) {
    let out_path = shared + "/dse_tensor_results.jsonl"
    let ts = now_ts()

    let mut content = ""
    // Write contracted values
    let mut i: i64 = 0
    while i < domains.len() {
        let dom = to_string(domains[i])
        let val = to_float(contracted[i])
        content = content + "{\"type\":\"contraction\",\"domain\":\"" + dom + "\",\"resonance\":" + fmt3(val) + ",\"ts\":\"" + ts + "\"}\n"
        i = i + 1
    }

    // Write eigenvalues
    let mut ei: i64 = 0
    while ei < eigenvalues.len() {
        let ev = to_float(eigenvalues[ei])
        if ev > 0.001 {
            content = content + "{\"type\":\"eigenvalue\",\"index\":" + to_string(ei) + ",\"value\":" + fmt3(ev) + ",\"ts\":\"" + ts + "\"}\n"
        }
        ei = ei + 1
    }

    // Write top hidden connections
    let top_h = if to_int(hidden.len()) < 30 { to_int(hidden.len()) } else { 30 }
    let mut hi: i64 = 0
    while hi < top_h {
        let entry = hidden[hi]
        let idx_i = to_int(safe_float(to_string(entry["i"])))
        let idx_j = to_int(safe_float(to_string(entry["j"])))
        let da = if idx_i < to_int(domains.len()) { to_string(domains[idx_i]) } else { "?" }
        let db = if idx_j < to_int(domains.len()) { to_string(domains[idx_j]) } else { "?" }
        let res = to_string(entry["residual"])
        content = content + "{\"type\":\"hidden\",\"a\":\"" + da + "\",\"b\":\"" + db + "\",\"residual\":" + res + ",\"ts\":\"" + ts + "\"}\n"
        hi = hi + 1
    }

    try { write_file(out_path, content) } catch e {
        println("[WARN] failed to write " + out_path)
    }
}

fn print_help() {
    println("dse_tensor.hexa -- Tensor Network DSE")
    println("")
    println("Usage:")
    println("  hexa dse_tensor.hexa scan       full pipeline (T1~T6)")
    println("  hexa dse_tensor.hexa contract    contraction only")
    println("  hexa dse_tensor.hexa rank        rank analysis")
    println("  hexa dse_tensor.hexa hidden      hidden structure report")
    println("  hexa dse_tensor.hexa help        this message")
    println("")
    println("Reads: shared/dse/dse_cross_results.json, shared/discovery/domain_seeds.jsonl")
    println("Writes: shared/dse_tensor_results.jsonl")
}

// ═══════════════════════════════════════════════════════════
// ─── THEOREM + PROOF ───
// ═══════════════════════════════════════════════════════════

theorem tensor_symmetry {
    // Adjacency tensor T is symmetric: T[i][j] == T[j][i]
    // Contraction preserves n=6 structure: if T has rank 6, the
    // dominant eigenvector aligns with the 6 fundamental constants
    assert 6 * 2 == 12          // n * phi = sigma
    assert 12 / 4 == 3          // sigma / tau = n/phi
    assert 6 + 12 + 2 + 4 == 24 // n + sigma + phi + tau = J2
}

proof tensor_rank_finite {
    // For N domains, tensor rank <= N
    // Effective rank << N indicates hidden low-dimensional structure
    // Rank-1 subtraction leaves residual = non-dominant connections
    invariant 6 * 6 == 36       // n^2 = maximum rank-1 tensor entries for n=6
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

fn main() {
    let home = exec("printenv HOME").trim()
    let shared = home + "/Dev/nexus/shared"

    let a = args()
    let mode = if a.len() >= 3 { to_string(a[2]) } else { "scan" }

    if mode == "help" || mode == "--help" || mode == "-h" {
        print_help()
        return
    }

    println("")
    println("=== TENSOR NETWORK DSE ===")
    println("  mode: " + mode)
    println("  time: " + now_ts())

    // ─── T1: Load ───
    println("")
    println("[T1] Loading DSE cross results...")
    let loaded = load_cross_results(shared)
    if loaded.len() < 2 {
        println("[ERROR] failed to load data")
        return
    }
    let domains = loaded[0]
    let domains_set = _loaded_domains_set
    let entries = loaded[1]
    let n = to_int(domains.len())
    println("  domains: " + to_string(n))
    println("  pairs:   " + to_string(entries.len()))

    if n == 0 {
        println("[ERROR] no domains loaded")
        return
    }

    // ─── T2: Build tensor ───
    println("")
    println("[T2] Building adjacency tensor (" + to_string(n) + " x " + to_string(n) + ")...")
    let tensor_flat = build_tensor(domains, domains_set, entries)
    println("  tensor size: " + to_string(tensor_flat.len()) + " elements")

    // ─── T3: Contraction ───
    let contracted = contract_tensor(tensor_flat, n)

    if mode == "contract" || mode == "scan" {
        report_contraction(domains, contracted)
    }

    // ─── T4: Rank ───
    let rank_result = estimate_rank(tensor_flat, n)
    let eigenvalues = rank_result[0]
    let eigenvectors = rank_result[1]

    if mode == "rank" || mode == "scan" {
        report_rank(eigenvalues, n)
    }

    // ─── T5: Hidden structure ───
    let ev1 = if eigenvalues.len() > 0 { to_float(eigenvalues[0]) } else { 0.0 }
    let vec1 = if eigenvectors.len() > 0 { eigenvectors[0] } else { [] }
    let hidden = if vec1.len() > 0 { find_hidden_structure(tensor_flat, n, ev1, vec1) } else { [] }

    if mode == "hidden" || mode == "scan" {
        report_hidden(hidden, domains)
    }

    // ─── T6: Summary + write ───
    if mode == "scan" {
        report_summary(domains, entries, contracted, eigenvalues, hidden)
        write_results(shared, domains, contracted, eigenvalues, hidden)
        println("")
        println("[T6] Results written to shared/dse_tensor_results.jsonl")
    }

    println("")
    println("[done]")
}

main()
