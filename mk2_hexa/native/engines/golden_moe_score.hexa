// Ported from tecs-l/engines/golden_moe_score.py
// Golden MoE design element-wise hypothesis-based score evaluator.
// Track A port: source is pure dict/arithmetic reporting (no torch, no numpy).
// We materialize the 7 design elements (E1..E7) and their hypothesis weights
// as compile-time arrays, then compute per-element confidence and an overall
// correlation-adjusted success probability in pure hexa.
//
// Scoring rule (mirrors the Python source):
//   - result == 1  (true)    : pts = |w|                , counted as n_true
//   - result == 0  (false)   : pts = w  (may be negative), counted as n_false
//   - result == -1 (unknown) : pts = 0                  , counted as n_unknown
//   - max_score accumulates |w| only when w > 0
//   - confidence        = max(0, score) / max_score * 100
//   - unknown_penalty   = n_unknown * 5
//   - adjusted          = max(0, confidence - unknown_penalty)
//   - overall (indep.)  = product(adjusted_i / 100)
//   - correlation adj.  = sqrt(overall_pct) * 10

const N_ELEMENTS: int = 7
const MAX_HYPS: int  = 5          // largest element (E7) holds 5 hypotheses
const N_HYPS: [int]  = [4, 4, 3, 3, 2, 3, 5]

// Weights per element, padded with 0.0 to MAX_HYPS.
const W_E1: [float] = [ 1.0,  0.8,  0.6, -0.3, 0.0]
const W_E2: [float] = [ 1.0,  0.8,  0.6,  0.9, 0.0]
const W_E3: [float] = [ 1.0,  0.5,  0.3,  0.0, 0.0]
const W_E4: [float] = [ 0.8,  0.4,  0.5,  0.0, 0.0]
const W_E5: [float] = [ 0.7,  0.3,  0.0,  0.0, 0.0]
const W_E6: [float] = [ 0.9,  0.7,  0.5,  0.0, 0.0]
const W_E7: [float] = [ 1.0,  0.8,  0.7, -0.2, -0.1]

// Results per element: 1 = true, 0 = false, -1 = unknown.
const R_E1: [int] = [ 1,  1,  1,  0,  0]
const R_E2: [int] = [ 1,  1,  1,  1,  0]
const R_E3: [int] = [ 1, -1, -1,  0,  0]
const R_E4: [int] = [ 1,  1, -1,  0,  0]
const R_E5: [int] = [ 1,  1,  0,  0,  0]
const R_E6: [int] = [ 1,  1, -1,  0,  0]
const R_E7: [int] = [ 1,  1,  1,  0, -1]

pure fn abs_f(x: float) -> float {
    if x < 0.0 { -x } else { x }
}

pure fn max_f(a: float, b: float) -> float {
    if a > b { a } else { b }
}

// Score a single element given its weight vector, result vector, and hyp count.
pure fn element_score(ws: [float], rs: [int], n: int) -> float {
    let mut score = 0.0;
    let mut max_score = 0.0;
    let mut n_unknown = 0;
    let mut i = 0;
    while i < n {
        let w = ws[i];
        let r = rs[i];
        if w > 0.0 { max_score = max_score + abs_f(w); }
        if r == 1 {
            score = score + abs_f(w);
        } else if r == 0 {
            score = score + w;
        } else {
            n_unknown = n_unknown + 1;
        }
        i = i + 1;
    }
    let conf = if max_score > 0.0 {
        max_f(0.0, score) / max_score * 100.0
    } else { 0.0 };
    let penalty = to_float(n_unknown) * 5.0;
    max_f(0.0, conf - penalty)
}

// sqrt via Newton iteration — avoids pulling in math deps.
pure fn sqrt_f(x: float) -> float {
    if x <= 0.0 { 0.0 } else {
        let mut y = x;
        let mut i = 0;
        while i < 32 {
            y = 0.5 * (y + x / y);
            i = i + 1;
        }
        y
    }
}

pure fn score_element(idx: int) -> float {
    if idx == 0 { element_score(W_E1, R_E1, N_HYPS[0]) }
    else if idx == 1 { element_score(W_E2, R_E2, N_HYPS[1]) }
    else if idx == 2 { element_score(W_E3, R_E3, N_HYPS[2]) }
    else if idx == 3 { element_score(W_E4, R_E4, N_HYPS[3]) }
    else if idx == 4 { element_score(W_E5, R_E5, N_HYPS[4]) }
    else if idx == 5 { element_score(W_E6, R_E6, N_HYPS[5]) }
    else             { element_score(W_E7, R_E7, N_HYPS[6]) }
}

// Overall success probability = product(adjusted_i / 100) * 100, then
// correlation-adjusted as sqrt(pct) * 10 (capped at 100).
pure fn overall_pct() -> float {
    let mut p = 1.0;
    let mut i = 0;
    while i < N_ELEMENTS {
        p = p * (score_element(i) / 100.0);
        i = i + 1;
    }
    p * 100.0
}

pure fn correlated_pct() -> float {
    let raw = sqrt_f(overall_pct()) * 10.0;
    if raw > 100.0 { 100.0 } else { raw }
}

fn main() {
    print("Golden MoE Design Scorecard\n");
    let mut i = 0;
    while i < N_ELEMENTS {
        let s = score_element(i);
        print("  E");
        print(i + 1);
        print(" = ");
        print(s);
        print("%\n");
        i = i + 1;
    }
    print("  overall(indep) = ");
    print(overall_pct());
    print("%\n");
    print("  correlation-adjusted = ");
    print(correlated_pct());
    print("%\n");
}
