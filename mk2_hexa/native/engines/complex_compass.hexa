// mk2_hexa/native/complex_compass.hexa
// 포팅 원본: tecs-l/complex_compass.py (81 LOC)
//
// 복소 고정점:  I* = b / (1 - a·e^(iθ))
//   Let denom = (1 - a·cos θ) - i·a·sin θ
//   |denom|² = (1-a·cos θ)² + (a·sin θ)²
//   I*_real  = b·(1-a·cos θ) / |denom|²
//   I*_imag  = b·a·sin θ     / |denom|²
//   |I*|     = b / sqrt(|denom|²)
//
// Monte Carlo 모집단 평균/표준편차는 brain_analyzer.hexa 와 동일 샘플러로 계산.
//
// AI-native: @pure 전역

let PI = 3.141592653589793
let A = 0.7
let B = 0.1

// @pure
fn fixed_point_real(theta: float) -> float {
    let denom_r = 1.0 - A * cos(theta)
    let denom_i = 0.0 - A * sin(theta)
    let d2 = denom_r * denom_r + denom_i * denom_i
    B * denom_r / d2
}

// @pure
fn fixed_point_imag(theta: float) -> float {
    let denom_r = 1.0 - A * cos(theta)
    let denom_i = 0.0 - A * sin(theta)
    let d2 = denom_r * denom_r + denom_i * denom_i
    B * (0.0 - denom_i) / d2
}

// @pure
fn fixed_point_abs(theta: float) -> float {
    let denom_r = 1.0 - A * cos(theta)
    let denom_i = 0.0 - A * sin(theta)
    sqrt((B * B) / (denom_r * denom_r + denom_i * denom_i))
}

// @pure
fn fabs(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

// Gamma(k), Beta(a,b) — integer shapes (brain_analyzer와 동일)
fn sample_gamma(k: int) -> float {
    let mut prod = 1.0
    let mut i = 0
    while i < k {
        let u = random()
        let uu = if u < 0.000001 { 0.000001 } else { u }
        prod = prod * uu
        i = i + 1
    }
    0.0 - log(prod)
}
fn sample_beta(a: int, b: int) -> float {
    let x = sample_gamma(a)
    let y = sample_gamma(b)
    x / (x + y)
}
fn clip(x: float, lo: float, hi: float) -> float {
    if x < lo { return lo }
    if x > hi { return hi }
    x
}
fn population_stats() -> list {
    let N = 5000
    let mut sg = 0.0
    let mut sg2 = 0.0
    let mut i = 0
    while i < N {
        let d = clip(sample_beta(2, 5), 0.01, 0.99)
        let p = clip(sample_beta(5, 2), 0.01, 0.99)
        let ii = clip(sample_beta(5, 2), 0.05, 0.99)
        let g = d * p / ii
        sg = sg + g
        sg2 = sg2 + g * g
        i = i + 1
    }
    let mean = sg / to_float(N)
    let var = sg2 / to_float(N) - mean * mean
    let std = sqrt(if var < 0.0 { 0.0 } else { var })
    [mean, std]
}

fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0)) / 10000.0
    to_string(r)
}
fn fmt2(x: float) -> string {
    let r = to_float(to_int(x * 100.0)) / 100.0
    to_string(r)
}

// ─── 본 계산 ───
fn compass(D: float, P: float, theta: float, stats: list) -> list {
    let i_eff = fixed_point_abs(theta)
    if i_eff < 0.01 { return [] }
    let fp_r = fixed_point_real(theta)
    let fp_i = fixed_point_imag(theta)
    let G = D * P / i_eff
    let std = if stats[1] < 0.00001 { 1.0 } else { stats[1] }
    let z = (G - stats[0]) / std
    let phase_bonus = fabs(sin(theta)) * 0.1
    let raw = (if z / 10.0 > 1.0 { 1.0 } else { z / 10.0 }) * 0.3 + 0.3 + 0.35 * 0.4 + phase_bonus
    let comp = if raw < 0.0 { 0.0 } else if raw > 1.0 { 1.0 } else { raw }
    [theta, theta / PI, fp_r, fp_i, i_eff, G, z, comp, 1.0 / i_eff]
}

// ─── CLI ───
let argv = args()
let mut mode = "help"
let mut arg_theta = 0.0
let mut arg_D = 0.7
let mut arg_P = 0.95

let mut i = 0
while i < len(argv) {
    let a = argv[i]
    if a == "--scan" {
        mode = "scan"
        i = i + 1
        continue
    }
    if a == "--theta" && i + 1 < len(argv) {
        mode = "theta"
        arg_theta = to_float(argv[i+1])
        i = i + 2
        continue
    }
    if a == "--deficit" && i + 1 < len(argv) {
        arg_D = to_float(argv[i+1])
        i = i + 2
        continue
    }
    if a == "--plasticity" && i + 1 < len(argv) {
        arg_P = to_float(argv[i+1])
        i = i + 2
        continue
    }
    i = i + 1
}

println("════════════════════════════════════════════════════════════")
println("   🧭 Complex Compass Calculator (hexa port)")
println("════════════════════════════════════════════════════════════")

let stats = population_stats()

if mode == "scan" {
    println("")
    println("  Full θ scan (D=" + fmt2(arg_D) + ", P=" + fmt2(arg_P) + ")")
    println("  θ/π   |  |I*|  |  G    |  Z      |  Compass | Amp   | Zone")
    println("  ------+--------+-------+---------+----------+-------+---------")
    let mut k = 0
    while k <= 20 {
        let theta = to_float(k) / 20.0 * PI
        let r = compass(arg_D, arg_P, theta, stats)
        if len(r) > 0 {
            let i_eff = r[4]
            let zone = if i_eff >= 0.213 && i_eff <= 0.5 {
                "🎯Golden"
            } else if i_eff < 0.213 {
                "⚡Chaos"
            } else {
                "○Over"
            }
            println("  " + fmt2(r[1]) + "  | " + fmt4(r[4]) + " | " + fmt2(r[5]) + "  | " + fmt2(r[6]) + "σ | " + fmt2(r[7] * 100.0) + "%    | " + fmt2(r[8]) + "  | " + zone)
        }
        k = k + 1
    }
} else if mode == "theta" {
    let r = compass(arg_D, arg_P, arg_theta, stats)
    if len(r) > 0 {
        println("")
        println("  θ     = " + fmt4(r[0]) + " = " + fmt4(r[1]) + "π")
        println("  I*    = " + fmt4(r[2]) + " + " + fmt4(r[3]) + "i")
        println("  |I*|  = " + fmt4(r[4]))
        println("  G     = " + fmt2(r[5]))
        println("  Z     = " + fmt2(r[6]) + "σ")
        println("  Compass       = " + fmt2(r[7] * 100.0) + "%")
        println("  Amplification = ×" + fmt2(r[8]))
    }
} else {
    println("")
    println("  Usage: --scan  |  --theta <radians>  [--deficit D --plasticity P]")
}
