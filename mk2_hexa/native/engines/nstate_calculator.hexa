// mk2_hexa/native/nstate_calculator.hexa
// 포팅 원본: tecs-l/nstate_calculator.py (63 LOC)
// 공식: width = ln((N+1)/N), upper = 1/2, lower = 1/2 - width
//
// AI-native 의도 (attr 시스템 구현 시 자동 활성 — todo #303):
//   @pure   : golden_zone / find_n_for_width — 부작용 0, DSE+const-prop 대상
//   @memoize: golden_zone(N) — 상수 테이블 반복 조회 시 O(1) 히트
//
// 실행:
//   hexa nstate_calculator.hexa            → 표 출력
//   hexa nstate_calculator.hexa --n 137    → N=137 상세
//   hexa nstate_calculator.hexa --find 0.118 → width → N 역산

let E = 2.718281828459045

// @pure @memoize
fn golden_zone_width(N: int) -> float {
    log(to_float(N + 1) / to_float(N))
}

// @pure @memoize
fn golden_zone_lower(N: int) -> float {
    0.5 - golden_zone_width(N)
}

// @pure @memoize
fn golden_zone_center(N: int) -> float {
    (0.5 + golden_zone_lower(N)) / 2.0
}

// @pure — width → N 역산: N = 1 / (exp(w) - 1)
fn find_n_for_width(target_width: float) -> int {
    let ew = pow(E, target_width)
    let n_float = 1.0 / (ew - 1.0)
    to_int(round(n_float))
}

// ─── 특수 N 레이블 (SSOT: 하드코딩 금지지만, 이건 원본 파이썬 상수 그대로 포팅 —
//     향후 shared/n6/n6_constants.jsonl 로 이관 예정) ───
fn special_label(N: int) -> string {
    if N == 3 { return "Our Model" }
    if N == 4 { return "Weinberg Angle" }
    if N == 6 { return "Perfect Number" }
    if N == 8 { return "Strong αs/Expert" }
    if N == 26 { return "AI Element" }
    if N == 137 { return "Fine Structure α" }
    ""
}

// ─── CLI 파싱 ───
let argv = args()
let mut mode = "table"
let mut arg_n = 0
let mut arg_w = 0.0

let mut i = 0
while i < len(argv) {
    let a = argv[i]
    if a == "--n" && i + 1 < len(argv) {
        mode = "n"
        arg_n = to_int(argv[i + 1])
        i = i + 2
        continue
    }
    if a == "--find" && i + 1 < len(argv) {
        mode = "find"
        arg_w = to_float(argv[i + 1])
        i = i + 2
        continue
    }
    i = i + 1
}

// ─── 출력 ───
println("════════════════════════════════════════════════════════════")
println("   📐 N-State Generalization Calculator (hexa port)")
println("════════════════════════════════════════════════════════════")
println("  Formula: width = ln((N+1)/N), upper = 1/2, lower = 1/2-width")

if mode == "find" {
    let N = find_n_for_width(arg_w)
    let w = golden_zone_width(N)
    println("")
    println("  width = " + to_string(arg_w) + " → N = " + to_string(N))
    println("  Verification: ln(" + to_string(N + 1) + "/" + to_string(N) + ") = " + to_string(w))
} else if mode == "n" {
    let w = golden_zone_width(arg_n)
    let lo = golden_zone_lower(arg_n)
    let c = golden_zone_center(arg_n)
    println("")
    println("  N = " + to_string(arg_n) + ":")
    println("  Width  = " + to_string(w))
    println("  Upper  = 0.5")
    println("  Lower  = " + to_string(lo))
    println("  Center = " + to_string(c))
} else {
    println("")
    println("    N    |   Width    |  Lower   | Upper  | Physical Match")
    println("  -------+------------+----------+--------+----------------")
    // @parallel 후보 (counter loop) — 향후 M315
    let ns = [2, 3, 4, 5, 6, 7, 8, 10, 16, 26, 50, 100, 137, 500, 1000]
    let mut k = 0
    while k < len(ns) {
        let N = ns[k]
        let w = golden_zone_width(N)
        let lo = golden_zone_lower(N)
        let lbl = special_label(N)
        println("  " + to_string(N) + "\t| " + to_string(w) + "\t| " + to_string(lo) + "\t| 0.5    | " + lbl)
        k = k + 1
    }
}

println("")
