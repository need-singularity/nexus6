println("--- 10. D_6 root system ---")
// |Phi(D_n)| = 2n(n-1), h(D_n) = 2(n-1), mu(D_n) = n
let phi_D6 = 2 * n * (n - 1)
let h_D6 = 2 * (n - 1)
let mu_D6 = n
println("  |Phi(D_6)| = 2·6·5 = " + to_string(phi_D6) + " = sigma·sopfr = " + to_string(sig * sopfr_n) + " ★ J3")
