println("  B_2/4 denom = " + to_string(b2_den) + "   |im(J)_3| = 24 = sigma·phi")
println("  B_4/8 denom = " + to_string(b4_den) + "  |im(J)_7| = 240 = sigma·tau·sopfr ★ G1/G4 STRONG")
let prod_sts = sig * tau_n * sopfr_n
println("  Verification: sigma*tau*sopfr = " + to_string(sig) + "*" + to_string(tau_n) + "*" + to_string(sopfr_n) + " = " + to_string(prod_sts))
assert prod_sts == 240

