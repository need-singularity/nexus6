// @pure — 분수 denominator 계산: gcd 이용
fn gcd(a: int, b: int) -> int {
    let mut x = if a < 0 { 0 - a } else { a }
    let mut y = if b < 0 { 0 - b } else { b }
    while y != 0 {
        let t = x % y
        x = y
        y = t
    }
    x
}

// @pure — num/den 기약화 후 den 반환
fn denom(num: int, den: int) -> int {
    let g = gcd(num, den)
    let d = den / g
    if d < 0 { 0 - d } else { d }
}

let n = 6
let sig = sigma(n)      // 12
let tau_n = tau(n)      // 4
let phi_n = phi(n)      // 2
let sopfr_n = sopfr(n)  // 5

