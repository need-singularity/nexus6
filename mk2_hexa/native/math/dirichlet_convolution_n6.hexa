// Ported from tecs-l/math/dirichlet_convolution_n6.py
// Dirichlet convolution f ∗ g for n=6 characterizations.

// @pure
fn mobius(n: int) -> int {
    if n == 1 { return 1 }
    let mut temp = n
    let mut num_factors = 0
    let mut p = 2
    while p * p <= temp {
        if temp % p == 0 {
            num_factors = num_factors + 1
            temp = temp / p
            if temp % p == 0 { return 0 }
        }
        p = p + 1
    }
    if temp > 1 { num_factors = num_factors + 1 }
    if num_factors % 2 == 0 { 1 } else { 0 - 1 }
}

// @pure
fn divisors_sum(n: int, f: int) -> int {
    // f = 0: sum of 1 = τ;  f = 1: sum of d = σ;  f = -1: sum of μ
    // Not composable — use helper per function below
    0
}

println("══════════════════════════════════════════════════════════════════════")
println("  Dirichlet convolution — n=6 characterization")
println("══════════════════════════════════════════════════════════════════════")

// Identity: (1 ∗ 1)(n) = τ(n)
println("")
println("## Identity 1: (1 ∗ 1)(n) = τ(n)")
let mut n = 1
while n <= 10 {
    // sum over divisors of 1*1 = τ(n)
    // compute manually
    let mut cnt = 0
    let mut d = 1
    while d * d <= n {
        if n % d == 0 {
            cnt = cnt + 1
            if d != n / d { cnt = cnt + 1 }
        }
        d = d + 1
    }
    let t = tau(n)
    assert cnt == t
    println("  n=" + to_string(n) + "  (1∗1) = " + to_string(cnt) + "  τ = " + to_string(t))
    n = n + 1
}

// Identity: (1 ∗ id)(n) = σ(n)
println("")
println("## Identity 2: (1 ∗ id)(n) = σ(n)  [sum of divisors]")
let mut m = 1
while m <= 10 {
    let mut s = 0
    let mut d = 1
    while d * d <= m {
        if m % d == 0 {
            s = s + d
            if d != m / d { s = s + m / d }
        }
        d = d + 1
    }
    assert s == sigma(m)
    m = m + 1
}
println("  verified for n=1..10")

// Möbius inversion: Σ_{d|n} μ(d) = [n=1]
println("")
println("## Möbius sum Σ_{d|n} μ(d)")
let mut k = 1
while k <= 12 {
    let mut s = 0
    let mut d = 1
    while d * d <= k {
        if k % d == 0 {
            s = s + mobius(d)
            if d != k / d { s = s + mobius(k / d) }
        }
        d = d + 1
    }
    let expected = if k == 1 { 1 } else { 0 }
    assert s == expected
    println("  n=" + to_string(k) + "  Σμ = " + to_string(s))
    k = k + 1
}

// μ(6), μ(30), μ(42)
println("")
println("## μ at small squarefree")
assert mobius(1) == 1
assert mobius(6) == 1   // 6 = 2·3 (2 primes) → (-1)² = 1
assert mobius(30) == 0 - 1  // 3 primes → −1
println("  μ(1)=1, μ(2)=−1, μ(3)=−1, μ(6)=1, μ(30)=−1, μ(210)=1")

// Master at n=6: σ(6)·φ(6) = 6·τ(6)
let master_l = sigma(6) * phi(6)
let master_r = 6 * tau(6)
assert master_l == master_r
println("")
println("## Master: σ(6)·φ(6) = 6·τ(6) = " + to_string(master_l) + " ✓")

// (μ ∗ id)(n) = φ(n)  — classical Möbius inversion of φ
println("")
println("## (μ ∗ id)(n) = φ(n)")
let mut q = 1
while q <= 10 {
    let mut s = 0
    let mut d = 1
    while d * d <= q {
        if q % d == 0 {
            s = s + mobius(d) * (q / d)
            if d != q / d { s = s + mobius(q / d) * d }
        }
        d = d + 1
    }
    let p = phi(q)
    assert s == p
    println("  n=" + to_string(q) + "  (μ∗id) = " + to_string(s) + " = φ(" + to_string(q) + ")")
    q = q + 1
}

println("")
println("SUMMARY: Dirichlet algebra recovers τ, σ, φ, [n=1]; master at n=6 ✓.")
