// Ported from tecs-l/math/verify_hph9_hph11.py
// H-PH-9 Perfect Number String Unification + H-PH-11 Partition M-theory
// Verification of τ/σ/φ properties on first 6 perfect numbers.

// Using first 4 perfects only — P5/P6 too slow for interpreted tau/sigma/phi
let P = [6, 28, 496, 8128]

println("══════════════════════════════════════════════════════════════════════")
println("  H-PH-9 & H-PH-11 — Perfect Number Verification (hexa port)")
println("══════════════════════════════════════════════════════════════════════")

// ── Section 1: tau/sigma/phi of first 6 perfect numbers ──
println("")
println("## 1. Basic properties")
println("   k | P_k       | τ(P_k) | σ(P_k)       | φ(P_k)")
println("  ---+-----------+--------+--------------+------------")
let mut i = 0
let mut pass_count = 0
let mut fail_count = 0
while i < len(P) {
    let pk = P[i]
    let t = tau(pk)
    let s = sigma(pk)
    let ph = phi(pk)
    println("  " + to_string(i + 1) + "\t| " + to_string(pk) + "\t| " + to_string(t) + "\t| " + to_string(s) + "\t| " + to_string(ph))
    i = i + 1
}

// ── Section 2: dimension mapping — τ(P_k) = spacetime dims ──
println("")
println("## 2. τ(P_k) = physical dimensions")
// τ(6)=4 spacetime, τ(28)=6 CY3, τ(496)=10 superstring, τ(8128)=14 G2
let expected = [4, 6, 10, 14]
let labels = ["spacetime", "Calabi-Yau", "superstring-10D", "G2 holonomy"]
let mut j = 0
while j < len(expected) {
    let computed = tau(P[j])
    let ok = computed == expected[j]
    if ok { pass_count = pass_count + 1 } else { fail_count = fail_count + 1 }
    let status = if ok { "PASS" } else { "FAIL" }
    println("  τ(P" + to_string(j + 1) + ") = " + to_string(computed) + " expected " + to_string(expected[j]) + " (" + labels[j] + ") " + status)
    j = j + 1
}

// ── Section 3: τ(6) + τ(28) = τ(496)?
println("")
println("## 3. Dimension addition: τ(6)+τ(28) = τ(496)?")
let lhs = tau(6) + tau(28)
let rhs = tau(496)
let s3 = if lhs == rhs { "PASS" } else { "FAIL" }
println("  " + to_string(tau(6)) + " + " + to_string(tau(28)) + " = " + to_string(lhs) + " vs τ(496)=" + to_string(rhs) + " " + s3)
if lhs == rhs { pass_count = pass_count + 1 } else { fail_count = fail_count + 1 }

// ── Section 4: Leech / E8 identities ──
println("")
println("## 4. Leech / E8 identities")
let leech = sigma(6) * phi(6)
assert leech == 24
println("  σ(6)·φ(6) = " + to_string(leech) + " = 24 (Leech dim) ✓")
let e8_phi = phi(496)
let e8_ok = if e8_phi == 240 { "PASS" } else { "FAIL (got " + to_string(e8_phi) + ")" }
println("  φ(496) = " + to_string(e8_phi) + " expected 240 (E8 roots) " + e8_ok)
assert 248 + 248 == 496
println("  248 + 248 = 496 (E8×E8) ✓")

// ── Section 5: Master identity σ(n)·φ(n) = n·τ(n) at n=6 ──
println("")
println("## 5. Master identity σφ = nτ at n=6")
let master_l = sigma(6) * phi(6)
let master_r = 6 * tau(6)
assert master_l == master_r
println("  σ(6)·φ(6) = " + to_string(master_l) + " = 6·τ(6) = " + to_string(master_r) + " ✓ (ONLY n=1,6)")

// ── Section 6: partition function (integer partitions of small n) ──
fn partitions(n: int) -> int {
    let mut dp = []
    let mut init = 0
    while init <= n { dp = dp + [0]; init = init + 1 }
    dp[0] = 1
    let mut k = 1
    while k <= n {
        let mut j2 = k
        while j2 <= n {
            dp[j2] = dp[j2] + dp[j2 - k]
            j2 = j2 + 1
        }
        k = k + 1
    }
    dp[n]
}

println("")
println("## 6. Partition function p(n) small values")
let mut q = 1
while q <= 10 {
    println("  p(" + to_string(q) + ") = " + to_string(partitions(q)))
    q = q + 1
}

println("")
println("SUMMARY: pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
