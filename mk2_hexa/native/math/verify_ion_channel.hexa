// Ported from tecs-l/math/scripts/verify_ion_channel.py
// Verify ion channel selectivity connections to perfect number 6.

let n = 6
let s = sigma(n)       // 12
let p = phi(n)          // 2
let t = tau(n)          // 4
let sp = s * p           // 24

println("============================================================")
println("ION CHANNEL SELECTIVITY vs PERFECT NUMBER 6")
println("============================================================")

println("")
println("--- Arithmetic of n=6 ---")
println("  sigma(6) = " + to_string(s))
println("  phi(6)   = " + to_string(p))
println("  tau(6)   = " + to_string(t))
println("  sigma*phi = " + to_string(sp))
println("  sigma/tau = " + to_string(s) + "/" + to_string(t) + " = " + to_string(s / t))

// 1. Four major ion channel types = tau(6)
println("")
println("--- Connection 1: Ion Channel Types ---")
let channel_count = 4
println("  Major voltage-gated ion channels: Na+, K+, Ca2+, Cl-")
println("  Count = " + to_string(channel_count))
println("  tau(6) = " + to_string(t))
println("  Match: " + to_string(channel_count == t))
println("  NOTE: tau(6)=4 is common. Weak on its own.")

// 5. Na/K pump ratio = sigma/tau : phi = 3:2
println("")
println("--- Connection 5: Na+/K+ Pump Ratio (KEY) ---")
let pump_na_out = 3
let pump_k_in = 2
let ratio_sigma_tau = s / t  // 12/4 = 3
let ratio_phi = p            // 2
println("  Na+/K+ ATPase pumps: 3 Na+ out : 2 K+ in")
println("  sigma(6)/tau(6) = " + to_string(s) + "/" + to_string(t) + " = " + to_string(ratio_sigma_tau))
println("  phi(6) = " + to_string(ratio_phi))
println("  Pump ratio = sigma/tau : phi = " + to_string(ratio_sigma_tau) + ":" + to_string(ratio_phi))
println("  EXACT MATCH: " + to_string(ratio_sigma_tau == pump_na_out && ratio_phi == pump_k_in))

// 7. Transmembrane segments = sigma*phi = 24
println("")
println("--- Connection 7: Transmembrane Segments (REMARKABLE) ---")
let domains = t              // 4
let tm_per_domain = n        // 6
let total_tm = domains * tm_per_domain
println("  Voltage-gated channels: 4 domains x 6 TM segments each = " + to_string(total_tm))
println("  sigma * phi = " + to_string(sp))
println("  EXACT MATCH: tau*n = sigma*phi = " + to_string(total_tm == sp))

// Check tau(n)*n = sigma(n)*phi(n) across perfect numbers
println("")
println("--- Generalization Test: tau*n = sigma*phi for perfect numbers ---")
println("     n  |   tau*n  | sigma*phi |  match")
println("  -----+----------+-----------+-------")
let perfects = [6, 28, 496, 8128]
let mut i = 0
while i < 4 {
    let pn = perfects[i]
    let ss = sigma(pn)
    let pp = phi(pn)
    let tt = tau(pn)
    let tn = tt * pn
    let spp = ss * pp
    println("  " + to_string(pn) + "\t| " + to_string(tn) + "\t| " + to_string(spp) + "\t| " + to_string(tn == spp))
    i = i + 1
}

// 2. Resting membrane potential search
println("")
println("--- Connection 2: Resting Potential ~ -70mV (brute force) ---")
println("  Search: a*sigma + b*phi + c*tau + d*n = -70, complexity <= 8")
let target = -70
let mut found = 0
let mut best_a = 0
let mut best_b = 0
let mut best_c = 0
let mut best_d = 0
let mut best_comp = 99
let mut a = -10
while a <= 10 {
    let mut b = -10
    while b <= 10 {
        let mut c = -10
        while c <= 10 {
            let mut d = -10
            while d <= 10 {
                let val = a * s + b * p + c * t + d * n
                if val == target {
                    let aa = if a < 0 { -a } else { a }
                    let bb = if b < 0 { -b } else { b }
                    let cc = if c < 0 { -c } else { c }
                    let dd = if d < 0 { -d } else { d }
                    let comp = aa + bb + cc + dd
                    if comp <= 8 {
                        found = found + 1
                        if comp < best_comp {
                            best_comp = comp
                            best_a = a
                            best_b = b
                            best_c = c
                            best_d = d
                        }
                    }
                }
                d = d + 1
            }
            c = c + 1
        }
        b = b + 1
    }
    a = a + 1
}
println("  Found " + to_string(found) + " representations (complexity <= 8)")
println("  Best (min complexity=" + to_string(best_comp) + "): " + to_string(best_a) + "*sigma + " + to_string(best_b) + "*phi + " + to_string(best_c) + "*tau + " + to_string(best_d) + "*n = -70")
let check_val = -s * n + p
println("  KNOWN CLEAN FORM: -sigma*n + phi = -" + to_string(s) + "*" + to_string(n) + " + " + to_string(p) + " = " + to_string(check_val))
println("  Match -70: " + to_string(check_val == target))

// 8. Refractory period
println("")
println("--- Connection 8: Refractory Period ---")
let rel_refract = 2
let total_refract = 3
println("  Relative refractory: ~2ms = phi(6) = " + to_string(p) + " -> " + to_string(rel_refract == p))
println("  Total: ~3ms = sigma/tau = " + to_string(s / t) + " -> " + to_string(total_refract == s / t))
println("  NOTE: approximate and cherry-picked.")

// 9. Saltatory conduction
println("")
println("--- Connection 9: Myelination Speed ---")
let speed_boost = 6
println("  Myelinated boost ~6x, n=6 -> " + to_string(speed_boost == n))
println("  NOTE: actual 5-50x, weak.")

// Summary
println("")
println("============================================================")
println("SUMMARY: Exact arithmetic connections")
println("============================================================")
println("  [STRONG] Pump 3:2 = sigma/tau:phi            (exact)")
println("  [STRONG] 4x6=24 TM segments = sigma*phi      (exact)")
println("  [EXACT ] tau*n = sigma*phi at n=6 only among perfects")
println("  [MODER.] -70mV = -sigma*n + phi              (clean formula)")
println("  [WEAK  ] Refractory 3ms = sigma/tau          (approximate)")
println("  [WEAK  ] Myelination 6x = n                  (cherry-picked)")
println("")
println("Anchor: n=6 perfect. sigma*phi = n*tau is the structural identity.")
