// Ported from tecs-l/math/difftopo_n6.py
// Differential topology for n=6 — exotic spheres, cobordism, surgery theory.
// n=6 constants: σ=12, φ=2, τ=4, sopfr=5, n=6.

let N = 6
let SIGMA = 12
let PHI = 2
let TAU = 4
let SOPFR = 5

assert sigma(6) == SIGMA
assert phi(6) == PHI
assert tau(6) == TAU

println("══════════════════════════════════════════════════════════════════════")
println("  DIFFERENTIAL TOPOLOGY FOR n=6")
println("  σ=12 φ=2 τ=4 sopfr=5 n=6")
println("══════════════════════════════════════════════════════════════════════")

// 1. EXOTIC SPHERES: known |bP_{4k}| values
println("")
println("## 1. Exotic spheres: |bP_{4k}| (Kervaire–Milnor)")
println("  k=1 (dim 3) : |bP_4|  = 1")
println("  k=2 (dim 7) : |bP_8|  = 28  = σ(6) + τ(6)·4  = 12+16")
let b8 = sigma(6) + tau(6) * 4
assert b8 == 28
println("  k=3 (dim 11): |bP_12| = 992 = 2^5 · 31")
assert 992 == 32 * 31
println("  k=4 (dim 15): |bP_16| = 8128 = P_4 (4th perfect)")

// 2. Theta_n  (group of homotopy spheres)
println("")
println("## 2. |Θ_n| (homotopy spheres)")
println("  Θ_1..Θ_6: 1, 1, 1, 1, 1, 1  (trivial through dim 6)")
println("  Θ_7 = 28 (= |bP_8|)")
println("  Θ_8 = 2")
println("  → matches τ(6) + σ(6)·2 = 28 for Θ_7")

// 3. Cobordism ring Ω_* (oriented): Ω_4=Z, Ω_8=Z², etc.
println("")
println("## 3. Cobordism Ω_* (oriented, low dim)")
println("  Ω_0 = ℤ    Ω_1 = 0     Ω_2 = 0")
println("  Ω_3 = 0    Ω_4 = ℤ     Ω_5 = 0")
println("  Ω_6 = 0    Ω_7 = 0     Ω_8 = ℤ²")

// 4. Pontryagin/Euler numbers of S^4, CP², HP¹
println("")
println("## 4. Characteristic numbers")
println("  χ(S^2)  = 2  = φ(6)")
println("  χ(S^4)  = 2  = φ(6)")
println("  χ(S^6)  = 2  = φ(6)")
println("  χ(CP²)  = 3  = τ(6) − 1")
println("  χ(CP³)  = 4  = τ(6)")
println("  χ(T^6)  = 0")
assert phi(6) == 2

// 5. Bernoulli |B_{2k}| denominators relevant to bP_{4k} formula
println("")
println("## 5. Bernoulli B_{2k} for k=1..4 (num, den)")
println("  B_2  =  1/6   (den = 6 = n)")
println("  B_4  = −1/30  (den = 30 = σ(29) + 1?)")
println("  B_6  =  1/42  (den = 42 = σ(6)·τ(6) − σ(6)·φ(6)/4)")
println("  B_8  = −1/30")
// B_2 den = 6
assert 6 == N

// 6. Dimension check: manifolds up to diffeomorphism
println("")
println("## 6. Smooth structures on S^n")
println("  n  | count")
println("  ---+------")
let dims = [1, 2, 3, 4, 5, 6, 7]
let counts = [1, 1, 1, 0, 1, 1, 28]  // 0 = unknown for n=4
let mut i = 0
while i < len(dims) {
    let c = counts[i]
    let c_str = if c == 0 { "?" } else { to_string(c) }
    println("  " + to_string(dims[i]) + "\t|  " + c_str)
    i = i + 1
}
println("  S^7 has 28 smooth structures = |bP_8| ← ties to n=6")

println("")
println("SUMMARY: exotic-sphere count bP_8=28 = σ(6)+τ(6)·4 ties diff.topo to n=6.")
