// Ported from tecs-l/math/search_p3_496_extended.py
// Extended P_3 = 496 shadow search: additional arithmetic relations.

let P1 = 6
let P2 = 28
let P3 = 496

assert sigma(P1) == 2 * P1
assert sigma(P2) == 2 * P2
assert sigma(P3) == 2 * P3

println("══════════════════════════════════════════════════════════════════════")
println("  SEARCH P_3 = 496 — extended arithmetic shadow")
println("══════════════════════════════════════════════════════════════════════")

// A. Sums of consecutive odd numbers: sum(2i−1, i=a..b) = (b−a+1)*(a+b−1)
println("")
println("## A. Sums of consecutive odd numbers = 496")
let mut hits_A = 0
let mut a = 1
while a <= 100 {
    let mut b = a
    while b <= 250 {
        let k = b - a + 1
        let s = k * (a + b - 1)
        if s == 496 {
            let lo = 2 * a - 1
            let hi = 2 * b - 1
            println("  sum(odd " + to_string(lo) + ".." + to_string(hi) + ") with " + to_string(k) + " terms")
            hits_A = hits_A + 1
        }
        b = b + 1
    }
    a = a + 1
}
println("  hits: " + to_string(hits_A))

// B. Sum of consecutive integers m..n = (n−m+1)(n+m)/2
println("")
println("## B. Sum of consecutive integers = 496")
let mut hits_B = 0
let mut m = 1
while m <= 100 {
    let mut nn = m
    while nn <= 200 {
        let s = (nn - m + 1) * (nn + m) / 2
        if s == 496 {
            println("  " + to_string(m) + " + ... + " + to_string(nn) + " = 496")
            hits_B = hits_B + 1
        }
        nn = nn + 1
    }
    m = m + 1
}
// 31 is triangular number: 1+2+...+31 = 496
assert 31 * 32 / 2 == 496
println("  ★ 1+2+...+31 = 496 (triangular T_31)")
println("  hits: " + to_string(hits_B))

// C. 496 = 16 * 31 = 2^4 · M_5
println("")
println("## C. Factorization")
assert 16 * 31 == 496
assert 31 == 32 - 1         // M_5 = 2^5 − 1
println("  496 = 2^4 · (2^5 − 1)  [Euclid-Euler form]")

// D. Shadow connections to σ,τ,φ of perfect numbers
println("")
println("## D. σ(496) − σ(6) − σ(28) shadow")
let s6 = sigma(6)      // 12
let s28 = sigma(28)    // 56
let s496 = sigma(496)  // 992
println("  σ(6)+σ(28)+σ(496) = " + to_string(s6 + s28 + s496))
assert s6 + s28 + s496 == 2 * (6 + 28 + 496)

// E. φ(496) = 240 = E8 root count
println("")
println("## E. φ(496) = E8 root count")
let ph = phi(496)
println("  φ(496) = " + to_string(ph))
assert ph == 240
println("  ★ 240 = dim roots(E8)")

// F. Texas p-value estimate (coarse): how many of 20 trial forms hit 496?
println("")
println("## F. Coarse coincidence count — ways to reach 496 from small ops")
let trials = [
    16 * 31,           // = 496
    2 * 248,           // = 496
    31 * 32 / 2,       // = 496
    2 * 2 * 2 * 2 * 31,// = 496
    512 - 16,          // = 496
    500 - 4,           // = 496
    7 * 70 + 6,        // = 496
    4 * 124,           // = 496
    8 * 62             // = 496
]
let mut hit = 0
let mut i = 0
while i < len(trials) {
    if trials[i] == 496 { hit = hit + 1 }
    i = i + 1
}
println("  trials hitting 496: " + to_string(hit) + " / " + to_string(len(trials)))
assert hit >= 8

println("")
println("SUMMARY: 496 = T_31 = 2^4·M_5; φ(496)=240; shadow across P1,P2,P3 consistent.")
