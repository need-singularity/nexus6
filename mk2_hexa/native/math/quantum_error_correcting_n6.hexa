// Ported from tecs-l/math/quantum_error_correcting_n6.py
// QEC codes and n=6 arithmetic (Steane, Shor, CSS).

let n = 6
let sigma_n = sigma(n)   // 12
let phi_n   = phi(n)     // 2
let tau_n   = tau(n)     // 4
let sigma_tau = sigma_n / tau_n  // 3

assert sigma_n == 12
assert phi_n == 2
assert tau_n == 4
assert sigma_tau == 3

println("══════════════════════════════════════════════════════════════════════")
println("  QEC codes and n=6 arithmetic")
println("══════════════════════════════════════════════════════════════════════")
println("  σ=" + to_string(sigma_n) + " τ=" + to_string(tau_n) + " φ=" + to_string(phi_n) + " σ/τ=" + to_string(sigma_tau))

// ────────────────────────────────────────────────
// 1. Steane [[7,1,3]] code: [[2^r−1, 2^r−1−2r, 3]] with r = σ/τ = 3
// ────────────────────────────────────────────────
let r = sigma_tau    // 3
let n_steane = 1     // 2^r − 1 = 7, computed below
// compute 2^r
let mut pw = 1
let mut ii = 0
while ii < r { pw = pw * 2; ii = ii + 1 }
let n_code = pw - 1          // 7
let k_code = n_code - 2 * r  // 1
let d_code = 3

println("")
println("## 1. Steane [[7,1,3]] from r = σ/τ = 3")
println("  n = 2^r − 1 = " + to_string(n_code))
println("  k = n − 2r = " + to_string(k_code))
println("  d = 3 = σ/τ")
assert n_code == 7
assert k_code == 1
assert d_code == sigma_tau
assert n_code == n + 1         // n+1 = 7 ✓

// 2. Shor [[9,1,3]] code  — note 9 = 3² = (σ/τ)²
println("")
println("## 2. Shor [[9,1,3]]")
let shor_n = sigma_tau * sigma_tau
assert shor_n == 9
println("  n_shor = 9 = (σ/τ)² ✓")

// 3. [[5,1,3]] perfect code — smallest QEC, n = 5 = sopfr(6)
println("")
println("## 3. [[5,1,3]] perfect code")
let sopfr_n = 5
println("  n = 5 = sopfr(6) ✓")

// 4. Parameters dictionary — checks d = σ/τ for many named codes
println("")
println("## 4. QEC family — distance d matches σ/τ = 3")
let codes_n = [5, 7, 9, 15]
let codes_d = [3, 3, 3, 3]
let mut i = 0
while i < len(codes_n) {
    assert codes_d[i] == sigma_tau
    println("  [[" + to_string(codes_n[i]) + ",?," + to_string(codes_d[i]) + "]]   d=σ/τ ✓")
    i = i + 1
}

// 5. Hamming bound for perfect [[n,k,d]] with d=3:
// 2^(n−k) ≥ 1 + 3n  →  for n=5, k=1: 2^4 = 16 ≥ 16 ✓ (perfect)
println("")
println("## 5. Hamming bound for perfect [[5,1,3]]")
let lhs = 16    // 2^(5−1)
let rhs = 1 + 3 * 5
println("  2^(n−k) = " + to_string(lhs) + "   1+3n = " + to_string(rhs))
assert lhs == rhs
println("  ★ Exactly saturated — perfect code")

// 6. Qubit count vs n=6: Shor 9 qubits, sigma(6)=12 ≈ Shor + 3
println("")
println("## 6. σ(6) = Shor + 3 = 12")
assert sigma_n == 9 + 3

println("")
println("SUMMARY: Steane/Shor/[[5,1,3]] distances all = σ/τ = 3; perfect code bound saturated.")
