// 포팅 원본: tecs-l/math/task1_theory.py (226 LOC)
//
// Task 1: THEORETICAL analysis of pi_R(x)
//
// Key structural observation:
//   R(p) = (p^2-1)/(2p) ~ p/2
//
// The set of achievable R values is a multiplicative free semigroup
// generated by {R(p^a): p prime, a >= 1}.
//
// 범위: Python 300k sieve → hexa 1000 (인터프리터 속도 감안)
// x_vals: Python [10..50000] → hexa [10..100] (DFS 복잡도 감안)

// --- Sieve of Eratosthenes ---
fn sieve_primes(limit: int) {
    let mut is_p = []
    let mut i = 0
    while i <= limit {
        if i < 2 { is_p = is_p + [0] }
        else { is_p = is_p + [1] }
        i = i + 1
    }
    i = 2
    while i * i <= limit {
        if is_p[i] == 1 {
            let mut j = i * i
            while j <= limit {
                is_p[j] = 0
                j = j + i
            }
        }
        i = i + 1
    }
    let mut result = []
    i = 2
    while i <= limit {
        if is_p[i] == 1 { result = result + [i] }
        i = i + 1
    }
    result
}

// --- GCD for Fraction math ---
fn my_gcd(a: int, b: int) -> int {
    let mut x = a
    let mut y = b
    if x < 0 { x = -x }
    if y < 0 { y = -y }
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    x
}

// --- Fraction as [num, den] ---
fn frac_new(n: int, d: int) {
    let g = my_gcd(n, d)
    [n / g, d / g]
}

fn frac_mul(a, b) {
    let n = a[0] * b[0]
    let d = a[1] * b[1]
    let g = my_gcd(n, d)
    [n / g, d / g]
}

fn frac_gt(a, b) -> bool {
    a[0] * b[1] > b[0] * a[1]
}

fn frac_key(a) {
    to_string(a[0]) + ":" + to_string(a[1])
}

fn frac_to_f(a) -> float {
    to_float(a[0]) / to_float(a[1])
}

// --- Exact pi_R computation (iterative stack-based DFS) ---
// Uses #{} map for O(1) dedup instead of linear search
fn exact_pi_R(x_max: int, primes) -> int {
    let x_frac = frac_new(x_max, 1)

    // Build all_generators: list of lists of prime-power R-values
    let mut all_generators = []
    let mut pi = 0
    while pi < len(primes) {
        let p = primes[pi]
        let rp = frac_new(p * p - 1, 2 * p)
        if frac_gt(rp, x_frac) { break }

        let mut choices = []
        let mut a = 1
        while a <= 6 {
            let mut pa1 = 1
            let mut ex = 0
            while ex <= a {
                pa1 = pa1 * p
                ex = ex + 1
            }
            let rpa = frac_new(pa1 - 1, p * (a + 1))
            if frac_gt(rpa, x_frac) { break }
            choices = choices + [rpa]
            a = a + 1
        }
        if len(choices) > 0 {
            all_generators = all_generators + [choices]
        }
        pi = pi + 1
    }

    let n_gen = len(all_generators)

    // Use map for O(1) dedup
    let mut seen = #{"1:1": true}

    // Stack-based DFS: each entry = [gen_idx, cur_num, cur_den]
    let mut stack = []
    let mut gi = 0
    while gi < n_gen {
        let choices = all_generators[gi]
        let mut ci = 0
        while ci < len(choices) {
            let c = choices[ci]
            if !frac_gt(c, x_frac) {
                stack = stack + [[gi, c[0], c[1]]]
            }
            ci = ci + 1
        }
        gi = gi + 1
    }

    while len(stack) > 0 {
        let top = stack[len(stack) - 1]
        stack = stack.pop()
        let idx = top[0]
        let cur = [top[1], top[2]]
        let key = frac_key(cur)

        if !has_key(seen, key) {
            seen[key] = true
            // Push children: generators after idx
            let mut ni = idx + 1
            while ni < n_gen {
                let choices = all_generators[ni]
                let mut ci = 0
                while ci < len(choices) {
                    let c = choices[ci]
                    let prod = frac_mul(cur, c)
                    if frac_gt(prod, x_frac) { break }
                    stack = stack + [[ni, prod[0], prod[1]]]
                    ci = ci + 1
                }
                ni = ni + 1
            }
        }
    }

    len(keys(seen))
}

// --- Count primes <= n ---
fn count_primes_up_to(primes, n: int) -> int {
    let mut c = 0
    let mut i = 0
    while i < len(primes) {
        if primes[i] <= n { c = c + 1 }
        else { break }
        i = i + 1
    }
    c
}

// --- Main ---
println("======================================================================")
println("TASK 1: THEORETICAL ANALYSIS (hexa port)")
println("======================================================================")

let primes = sieve_primes(1000)

// Reduced x_vals for interpreter speed
let x_vals = [10, 20, 50, 100]

println("")
println("Exact pi_R(x) computation:")
println("       x     pi_R(x)    pi(2x)      comp   pi_R/pi(2x)  ln(ratio)")
println("----------------------------------------------------------")

let mut data_x = []
let mut data_pi = []
let mut data_pi2x = []
let mut data_comp = []

let mut vi = 0
while vi < len(x_vals) {
    let x = x_vals[vi]
    let pi_x = exact_pi_R(x, primes)
    let pi_2x = count_primes_up_to(primes, 2 * x)
    let comp = pi_x - pi_2x
    let ratio = to_float(pi_x) / to_float(pi_2x)
    let ln_ratio = log(ratio)

    data_x = data_x + [x]
    data_pi = data_pi + [pi_x]
    data_pi2x = data_pi2x + [pi_2x]
    data_comp = data_comp + [comp]

    let x_s = to_string(x)
    let pi_s = to_string(pi_x)
    let pi2_s = to_string(pi_2x)
    let comp_s = to_string(comp)
    let ratio_s = to_string(round(ratio * 10000.0) / 10000.0)
    let lr_s = to_string(round(ln_ratio * 10000.0) / 10000.0)
    println("  " + x_s + "        " + pi_s + "       " + pi2_s + "      " + comp_s + "      " + ratio_s + "     " + lr_s)
    vi = vi + 1
}

println("")
println("Asymptotic form testing:")
println("       x     pi_R(x)    2x/lnx    ratio1   x*(lnx)^0.5   ratio2")
println("------------------------------------------------------------")

let mut ai = 0
while ai < len(data_x) {
    let x = data_x[ai]
    let pi_x = data_pi[ai]
    if x > 1 {
        let xf = to_float(x)
        let lnx = log(xf)
        let f1 = 2.0 * xf / lnx
        let f2 = xf * sqrt(lnx)
        let r1 = to_float(pi_x) / f1
        let r2 = to_float(pi_x) / f2
        let f1_s = to_string(round(f1 * 100.0) / 100.0)
        let f2_s = to_string(round(f2 * 100.0) / 100.0)
        let r1_s = to_string(round(r1 * 10000.0) / 10000.0)
        let r2_s = to_string(round(r2 * 10000.0) / 10000.0)
        println("  " + to_string(x) + "        " + to_string(pi_x) + "      " + f1_s + "    " + r1_s + "       " + f2_s + "      " + r2_s)
    }
    ai = ai + 1
}

// --- Theoretical bounds output ---
println("")
println("======================================================================")
println("THEORETICAL BOUNDS AND CONCLUSION")
println("======================================================================")
println("")
println("EXACT LOWER BOUND (from primes):")
println("  R(p) = (p^2-1)/(2p) are distinct for all primes p")
println("  Count: pi(2x+1) ~ 2x/ln(2x) ~ 2x/ln(x)")
println("")
println("COMPOSITE CONTRIBUTION:")
println("  C2(x) ~ (2x/ln x) * ln(ln x)  [Mertens theorem]")
println("")
println("TOTAL:")
println("  pi_R(x) ~ (2x/ln x) * (1 + ln ln x + higher order)")
println("")

println("Ratio pi_R(x)/pi(2x) at computed points:")
let mut ri = 0
while ri < len(data_x) {
    let x = data_x[ri]
    let pi_x = data_pi[ri]
    let pi_2x = data_pi2x[ri]
    if pi_2x > 0 {
        let ratio = to_float(pi_x) / to_float(pi_2x)
        let xf = to_float(x)
        let lnlnx = log(log(xf))
        let rlnln = ratio / lnlnx
        let r_s = to_string(round(ratio * 10000.0) / 10000.0)
        let ll_s = to_string(round(lnlnx * 10000.0) / 10000.0)
        let rll_s = to_string(round(rlnln * 10000.0) / 10000.0)
        println("  x=" + to_string(x) + ": ratio=" + r_s + ", ln(ln(x))=" + ll_s + ", ratio/lnlnx=" + rll_s)
    }
    ri = ri + 1
}

println("")
println("CONCLUSION:")
println("  pi_R(x) ~ C * x * ln(ln x) / ln(x)  where C ~ 2")
println("  (from prime bijection R(p) <-> p/2)")
println("")
println("======================================================================")
println("Port complete: task1_theory.py -> task1_theory.hexa")
println("======================================================================")
