// 포팅 원본: tecs-l/math/task1_asymptotic_refined.py (318 LOC)
// Task 1 REFINED: pi_R(x) asymptotic analysis
// R(p) ~ p/2, so for x=50000 we need primes up to ~100000
// Correct asymptotic: pi_R(x) ~ 2x/ln(x)

fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0)) / 10000.0
    to_string(r)
}

fn fmt1(x: float) -> string {
    let r = to_float(to_int(x * 10.0)) / 10.0
    to_string(r)
}

fn fmt2(x: float) -> string {
    let r = to_float(to_int(x * 100.0)) / 100.0
    to_string(r)
}

fn abs_f(x: float) -> float {
    if x < 0.0 { 0.0 - x } else { x }
}

// @pure — is_prime trial division
fn is_prime_fn(n: int) -> bool {
    if n < 2 { return false }
    if n == 2 { return true }
    if n % 2 == 0 { return false }
    let mut i = 3
    while i * i <= n {
        if n % i == 0 { return false }
        i = i + 2
    }
    true
}

// sieve primes up to limit
fn sieve_primes(limit: int) -> [int] {
    let mut is_p = [true] * (limit + 1)
    is_p[0] = false
    is_p[1] = false
    let mut i = 2
    while i * i <= limit {
        if is_p[i] {
            let mut j = i * i
            while j <= limit {
                is_p[j] = false
                j = j + i
            }
        }
        i = i + 1
    }
    let mut result = []
    let mut k = 2
    while k <= limit {
        if is_p[k] {
            result = result.push(k)
        }
        k = k + 1
    }
    result
}

// R(p) = (p^2 - 1) / (2p) as float
fn R_prime(p: int) -> float {
    let pf = to_float(p)
    (pf * pf - 1.0) / (2.0 * pf)
}

// R(p^a) = (p^(a+1) - 1) / (p * (a+1)) as float
fn R_prime_power(p: int, a: int) -> float {
    let pf = to_float(p)
    (pow(pf, to_float(a + 1)) - 1.0) / (pf * to_float(a + 1))
}

// compute pi_R(x): count distinct R values <= x_max
// Uses parallel arrays instead of tuples (hexa pitfall)
fn compute_pi_R(x_max: float) -> int {
    let prime_limit = to_int(2.0 * x_max) + 100
    let primes = sieve_primes(prime_limit)

    // use map for distinct R value tracking
    let mut distinct = #{}
    distinct["1.0"] = true

    // R(p) for all primes with R(p) <= x_max
    // parallel arrays: rp_vals[i] = R(primes_in_range[i])
    let mut rp_vals = []
    let mut pi = 0
    while pi < primes.len() {
        let p = primes[pi]
        let rp = R_prime(p)
        if rp <= x_max {
            let key = to_string(rp)
            distinct[key] = true
            rp_vals = rp_vals.push(rp)
        }
        pi = pi + 1
    }

    // Prime power R values (small primes only)
    let pp_limit = if primes.len() < 30 { primes.len() } else { 30 }
    let mut ppi = 0
    while ppi < pp_limit {
        let p = primes[ppi]
        let mut a = 2
        while a < 15 {
            let rpa = R_prime_power(p, a)
            if rpa > x_max {
                a = 15
            } else {
                let key = to_string(rpa)
                distinct[key] = true
            }
            a = a + 1
        }
        ppi = ppi + 1
    }

    // 2-prime products R(p)*R(q) <= x_max
    let n_pr = rp_vals.len()
    let mut i = 0
    while i < n_pr {
        let rp_i = rp_vals[i]
        if rp_i > x_max {
            i = n_pr
        } else {
            let mut j = i + 1
            while j < n_pr {
                let rp_j = rp_vals[j]
                let rpq = rp_i * rp_j
                if rpq > x_max {
                    j = n_pr
                } else {
                    let key = to_string(rpq)
                    distinct[key] = true
                    // 3-prime products
                    let mut k = j + 1
                    while k < n_pr {
                        let rp_k = rp_vals[k]
                        let rpqr = rpq * rp_k
                        if rpqr > x_max {
                            k = n_pr
                        } else {
                            let key3 = to_string(rpqr)
                            distinct[key3] = true
                        }
                        k = k + 1
                    }
                }
                j = j + 1
            }
        }
        i = i + 1
    }

    keys(distinct).len()
}

// count primes p where R(p) <= x
fn count_primes_with_R_leq(x: float) -> int {
    let prime_limit = to_int(2.0 * x) + 100
    let primes = sieve_primes(prime_limit)
    let mut count = 0
    let mut i = 0
    while i < primes.len() {
        let rp = R_prime(primes[i])
        if rp <= x {
            count = count + 1
        }
        i = i + 1
    }
    count
}

// =============================================
// MAIN ANALYSIS
// =============================================

println("======================================================================")
println("TASK 1: REFINED pi_R(x) ANALYSIS (hexa port)")
println("======================================================================")
println("")
println("KEY INSIGHT: computation n_max=50000 was insufficient.")
println("For x=50000, we need primes up to ~100000 to get all R(p) <= 50000.")
println("This explains why the ratio drops for large x -- systematic UNDERCOUNTING.")
println("")

// Reduced x_vals for hexa performance
let x_vals = [10, 20, 50, 100, 200, 500, 1000, 2000]

println("         x      pi_R(x)  # primes<=2x  ratio to 2x/ln(2x)")
println("------------------------------------------------------------")

// parallel result arrays
let mut res_x = []
let mut res_pi = []
let mut res_np = []
let mut res_ratio = []

let mut vi = 0
while vi < x_vals.len() {
    let x = x_vals[vi]
    let xf = to_float(x)
    let pi_x = compute_pi_R(xf)
    let n_primes = count_primes_with_R_leq(xf)

    let ratio = if x > 1 {
        let asymp = 2.0 * xf / log(2.0 * xf)
        to_float(pi_x) / asymp
    } else {
        0.0
    }

    res_x = res_x.push(x)
    res_pi = res_pi.push(pi_x)
    res_np = res_np.push(n_primes)
    res_ratio = res_ratio.push(ratio)

    let x_str = to_string(x)
    let pi_str = to_string(pi_x)
    let np_str = to_string(n_primes)
    let r_str = fmt4(ratio)
    println("  " + x_str + "    " + pi_str + "    " + np_str + "    " + r_str)

    vi = vi + 1
}

println("")
println("ASYMPTOTIC FORMS COMPARISON:")
println("         x    pi_R(x)    C*x/ln(x)   C*x/ln(x)^2   # primes 2x")
println("------------------------------------------------------------")

let mut ri = 0
while ri < res_x.len() {
    let x = res_x[ri]
    let pi_x = res_pi[ri]
    let n_primes = res_np[ri]
    if x > 1 {
        let xf = to_float(x)
        let lnx = log(xf)
        let f1 = xf / lnx
        let f2 = xf / (lnx * lnx)
        let line = "  " + to_string(x) + "    " + to_string(pi_x) + "    " + fmt1(f1) + "    " + fmt2(f2) + "    " + to_string(n_primes)
        println(line)
    }
    ri = ri + 1
}

// =============================================
// THEORETICAL BOUNDS
// =============================================

println("")
println("======================================================================")
println("THEORETICAL BOUNDS")
println("======================================================================")
println("")
println("LOWER BOUND (from primes alone):")
println("  # distinct R(p) values <= x = # primes p with (p^2-1)/(2p) <= x")
println("  ~ pi(2x) ~ 2x/ln(2x) ~ 2x/ln(x)")
println("  So pi_R(x) >= (2 + o(1)) * x/ln(x)")
println("")
println("UPPER BOUND: products with 2+ factors are O(x/ln^2(x)) = o(x/ln(x))")
println("  Prime powers p^a with a>=2: count ~ pi(sqrt(3x)) = O(sqrt(x)/ln(x))")
println("  Hence dominant term is from primes: ~ 2x/ln(x)")
println("")

println("Numerical check: pi_R(x) / (x/ln(x)):")
let check_vals = [100, 500, 1000, 2000]
let mut ci = 0
while ci < check_vals.len() {
    let x = check_vals[ci]
    let xf = to_float(x)
    let pi_x = compute_pi_R(xf)
    let ratio_c = to_float(pi_x) / (xf / log(xf))
    let line = "  x=" + to_string(x) + ": pi_R(x)=" + to_string(pi_x) + ", ratio=" + fmt4(ratio_c)
    println(line)
    ci = ci + 1
}

// =============================================
// PRIME COUNTING COMPARISON
// =============================================

println("")
println("======================================================================")
println("PRIME COUNTING COMPARISON")
println("======================================================================")
println("")
println("Since R(p) ~ p/2, the set {R(p): p prime} bijects with primes.")
println("Distinct R(p) values <= x correspond to primes p <= 2x + O(1).")
println("Prime counting: pi(x) ~ x/ln(x)  [PNT]")
println("So # distinct prime R-values <= x ~ pi(2x) ~ 2x/ln(x)")
println("")
println("NON-PRIME CONTRIBUTIONS (all sub-dominant):")
println("  R(p^2) ~ p^2/3 => count ~ pi(sqrt(3x)) = O(sqrt(x)/ln(x))")
println("  R(pq) = R(p)*R(q) ~ pq/4 => count ~ x/ln^2(x)")
println("  For large x, PRIMES dominate: pi_R(x) ~ 2x/ln(x)")
println("")

println("Verification: pi_R(x)*ln(x)/(2x) should -> 1 for large x:")
let ver_vals = [100, 500, 1000, 2000]
let mut vvi = 0
while vvi < ver_vals.len() {
    let x = ver_vals[vvi]
    let xf = to_float(x)
    let pi_x = compute_pi_R(xf)
    let ratio_v = to_float(pi_x) * log(xf) / (2.0 * xf)
    let line = "  x=" + to_string(x) + ": pi_R(x)=" + to_string(pi_x) + ", ratio=" + fmt4(ratio_v)
    println(line)
    vvi = vvi + 1
}

