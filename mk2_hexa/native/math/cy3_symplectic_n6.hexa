// Ported from tecs-l/math/cy3_symplectic_n6.py
// CY3 / Symplectic 6-manifolds / Mirror symmetry — n=6 connections.
// Verifies that σ(6)=12 appears as Betti-sum / |chi| in known CY_3 families.

// @pure
fn cy3_sum_b(h11: int, h21: int) -> int { 4 + 2 * h11 + 2 * h21 }
// @pure
fn cy3_chi(h11: int, h21: int) -> int { 2 * (h11 - h21) }

let n = 6
let sigma_n = sigma(n)
let phi_n   = phi(n)
let tau_n   = tau(n)
assert sigma_n == 12
assert phi_n == 2
assert tau_n == 4

println("══════════════════════════════════════════════════════════════════════")
println("  CY3 / Symplectic 6-manifolds — n=6")
println("══════════════════════════════════════════════════════════════════════")
println("  σ(6)=" + to_string(sigma_n) + " φ(6)=" + to_string(phi_n) + " τ(6)=" + to_string(tau_n))

// Known CY_3 families (name tag, h11, h21)
let families = [
    [1, 101],    // Quintic in CP^4
    [1, 89],     // Sextic
    [1, 149],    // Octic
    [1, 145],    // Dectic
    [1, 40],     // CICY [5|5]
    [2, 83],     // CICY [3,3|3]
    [19, 19],    // Schoen
    [3, 39],     // Borcea-Voisin
    [11, 11],
    [12, 12],    // self-mirror
    [2, 2],
    [3, 3],
    [6, 6]
]

println("")
println("## Hodge data: sum_b, chi, |chi| vs σ(6)")
println("   h11 | h21 |  sum_b | chi | |chi|÷σ(6)")
println("   ----+-----+--------+-----+-----------")

let mut hits = 0
let mut i = 0
while i < len(families) {
    let h11 = families[i][0]
    let h21 = families[i][1]
    let sb = cy3_sum_b(h11, h21)
    let ch = cy3_chi(h11, h21)
    let abs_ch = if ch < 0 { -ch } else { ch }
    let div = if sigma_n > 0 && abs_ch % sigma_n == 0 { "yes" } else { "-" }
    if abs_ch == sigma_n || sb == sigma_n { hits = hits + 1 }
    println("   " + to_string(h11) + "\t| " + to_string(h21) + "\t| " + to_string(sb) + "\t| " + to_string(ch) + "\t| " + div)
    i = i + 1
}
println("")
println("Families with σ(6) hit (|chi|=12 or sum_b=12): " + to_string(hits))

// Symplectic 6-manifold basics
println("")
println("## Symplectic 6-manifold dimensions")
println("  dim_R = 6, dim_C = 3 = σ(6)/τ(6)")
assert 6 / 2 == 3
assert sigma_n / tau_n == 3

// Mirror symmetry swap: h11 <-> h21 preserves |chi|
println("")
println("## Mirror symmetry invariance")
let a = 1
let b = 101
assert cy3_sum_b(a, b) == cy3_sum_b(b, a)
let ca = cy3_chi(a, b)
let cb = cy3_chi(b, a)
assert ca == -cb
println("  sum_b(h11,h21) = sum_b(h21,h11) ✓")
println("  chi flips sign under mirror ✓")

println("")
println("SUMMARY: σ(6)=12 matches Betti-sum on self-mirror CY_3 with h=2 (sum_b=12).")
