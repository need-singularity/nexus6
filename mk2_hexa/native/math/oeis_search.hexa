// 포팅 원본: tecs-l/math/oeis_search.py (76 LOC)
// OEIS 웹 API로 정수열 검색 → 매칭 확인

// substring-based index_of from offset
fn find_from(s: string, needle: string, offset: int) -> int {
    if offset >= len(s) { return 0 - 1 }
    let tail = s.substring(offset, len(s))
    let i = tail.index_of(needle)
    if i < 0 { return 0 - 1 }
    i + offset
}

fn search_oeis(terms: list, label: string) {
    let query = ""
    let mut i = 0
    while i < len(terms) {
        if i > 0 { query = query + "," }
        query = query + to_string(terms[i])
        i = i + 1
    }
    println("")
    println("════════════════════════════════════════════════════════════")
    println("Searching OEIS for " + label + ": " + query)

    let url = "https://oeis.org/search?q=" + query + "&fmt=json"
    let cmd = "curl -s -m 15 -H 'User-Agent: Mozilla/5.0' '" + url + "'"
    let raw = exec(cmd)

    if len(raw) < 10 || raw.contains("Could not") {
        println("  NO MATCHES FOUND — potentially new!")
    } else if raw.contains("\"number\"") {
        // 첫 3개 결과 추출 (OEIS returns bare JSON array)
        let mut pos = 0
        let mut found = 0
        while found < 3 {
            let ni = find_from(raw, "\"number\":", pos)
            if ni < 0 { break }
            let name_i = find_from(raw, "\"name\":\"", ni)
            if name_i < 0 { break }
            let name_start = name_i + 8
            let name_end = find_from(raw, "\"", name_start)
            if name_end < 0 { break }
            let num_start = ni + 9
            let num_end = find_from(raw, ",", num_start)
            let anum = raw.substring(num_start, num_end).trim()
            let name = raw.substring(name_start, name_end)
            found = found + 1
            println("  [" + to_string(found) + "] A" + anum + ": " + name)
            pos = name_end + 1
        }
        if found == 0 { println("  (parse failed)") }
    } else {
        println("  Error or empty response")
    }

    exec("sleep 2")
}

println("══════════════════════════════════════════════════════════════════════")
println("OEIS SEQUENCE SEARCH — nexus identity sequences")
println("══════════════════════════════════════════════════════════════════════")

let seq_a = [1, 6, 28, 54, 96, 120, 135, 196, 224, 234, 270, 360, 496]
search_oeis(seq_a, "Seq A: n where sigma*phi/(n*tau) is integer")

let seq_d = [1, 2, 3, 6]
search_oeis(seq_d, "Seq D: tau(sigma(n))=n")

let seq_f = [1, 6]
search_oeis(seq_f, "Seq F: phi(n)^2=tau(n)")

let seq_j = [1, 6, 24, 28, 40, 84, 96, 117, 120, 224, 234, 252, 288, 360]
search_oeis(seq_j, "Seq J: n divides lcm(sigma(n),phi(n))")

let seq_k = [1, 6]
search_oeis(seq_k, "Seq K: Dirichlet conv collapse")

let tau_sig = [1, 2, 3, 2, 4, 6, 4, 4, 2, 6, 6, 6, 4, 8, 8, 2, 6, 4, 6, 8]
search_oeis(tau_sig, "tau(sigma(n)) values")

let r_num = [1, 3, 4, 7, 12, 1, 24, 15, 26, 9, 60, 14, 84, 18, 16]
search_oeis(r_num, "R(n) numerators")

let r_den = [1, 4, 3, 6, 5, 1, 7, 8, 9, 5, 11, 9, 13, 7, 5]
search_oeis(r_den, "R(n) denominators")

let rp_num = [1, 4, 12, 24, 60, 84, 144, 180, 264, 420, 480, 684, 840, 924, 1104]
search_oeis(rp_num, "R(p) numerators = (p^2-1)/2 at primes")

let seq_i = [1, 2, 6, 42, 1806, 47058]
search_oeis(seq_i, "Seq I: n'=n-1 (primary pseudoperfect)")

println("")
println("══════════════════════════════════════════════════════════════════════")
