// Ported from tecs-l/math/verify_three_hypotheses_v2.py
// Verify three arithmetic hypotheses on σ/φ/τ relations.

println("══════════════════════════════════════════════════════════════════════")
println("  Three arithmetic hypotheses v2")
println("══════════════════════════════════════════════════════════════════════")

// H1: σ(n) + τ(n) = φ(n) + 2n ?
println("")
println("## H1: σ(n) + τ(n) = φ(n) + 2n ?")
let mut sols1 = []
let mut n = 1
while n <= 200 {
    if sigma(n) + tau(n) == phi(n) + 2 * n { sols1 = sols1 + [n] }
    n = n + 1
}
println("  solutions in [1,200]: " + to_string(sols1))

// H2: σ(n)·τ(n) = φ(n)·(n+1) ?
println("")
println("## H2: σ(n)·τ(n) = φ(n)·(n+1) ?")
let mut sols2 = []
let mut m = 1
while m <= 200 {
    if sigma(m) * tau(m) == phi(m) * (m + 1) { sols2 = sols2 + [m] }
    m = m + 1
}
println("  solutions in [1,200]: " + to_string(sols2))

// H3: σ(n)·φ(n) = n·τ(n)  (MASTER — known {1, 6})
println("")
println("## H3: MASTER σ(n)·φ(n) = n·τ(n)")
let mut sols3 = []
let mut k = 1
while k <= 2000 {
    if sigma(k) * phi(k) == k * tau(k) { sols3 = sols3 + [k] }
    k = k + 1
}
println("  solutions in [1,2000]: " + to_string(sols3))
assert len(sols3) == 2
println("  → exactly {1, 6} ★★★")

// Verification at n=6 for H1, H2
println("")
println("## Values at n=6")
println("  σ(6)=" + to_string(sigma(6)) + " τ(6)=" + to_string(tau(6)) + " φ(6)=" + to_string(phi(6)))
println("  H1 LHS = σ+τ = " + to_string(sigma(6) + tau(6)) + "  RHS = φ+2n = " + to_string(phi(6) + 12))
println("  H2 LHS = στ  = " + to_string(sigma(6) * tau(6)) + "  RHS = φ(n+1) = " + to_string(phi(6) * 7))
println("  H3 LHS = σφ  = " + to_string(sigma(6) * phi(6)) + "  RHS = nτ     = " + to_string(6 * tau(6)) + " ★")

// Count how often σ·φ − n·τ ∈ {-k,..,k}
println("")
println("## Δ = σφ − nτ distribution in [1, 100]")
let mut dpos = 0
let mut dneg = 0
let mut dzer = 0
let mut j = 1
while j <= 100 {
    let d = sigma(j) * phi(j) - j * tau(j)
    if d > 0 { dpos = dpos + 1 }
    else if d < 0 { dneg = dneg + 1 }
    else { dzer = dzer + 1 }
    j = j + 1
}
println("  positive: " + to_string(dpos) + "  zero: " + to_string(dzer) + "  negative: " + to_string(dneg))

println("")
println("SUMMARY: H1/H2 non-unique, H3 (master) unique {1, 6}.")
