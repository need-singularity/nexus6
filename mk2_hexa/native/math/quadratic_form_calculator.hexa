// mk2_hexa/native/quadratic_form_calculator.hexa
// 포팅 원본: tecs-l/math/quadratic_form_calculator.py (203 LOC)
// r_k(n) = n의 k-제곱수 분해 표현 수
// Jacobi: r_4(n) = 8·Σ{d|n, 4∤d}, r_8(n) = 16·Σ(-1)^(n-d)·d^3
//
// AI-native: @pure @memoize — r_k(n) 재귀 → 자동 메모화 후보
//            sympy 전부 제거, hexa sigma/tau/phi 빌트인 사용

// @pure — 정수 제곱근 (floor)
fn isqrt(n: int) -> int {
    if n < 0 { return 0 }
    let mut x = n
    let mut y = (x + 1) / 2
    while y < x {
        x = y
        y = (x + n / x) / 2
    }
    x
}

// @pure — divisor list
fn divisors(n: int) -> list {
    let mut d = []
    let mut i = 1
    while i * i <= n {
        if n % i == 0 {
            d = d + [i]
            if i * i != n { d = d + [n / i] }
        }
        i = i + 1
    }
    d
}

// @pure — r_2(n): signed ordered pairs (x, y) with x² + y² = n
fn r_2(n: int) -> int {
    let mut count = 0
    let lim = isqrt(n)
    let mut x = 0 - lim
    while x <= lim {
        let rem = n - x * x
        if rem >= 0 {
            let y = isqrt(rem)
            if y * y == rem {
                count = count + (if y == 0 { 1 } else { 2 })
            }
        }
        x = x + 1
    }
    count
}

// @pure — r_3(n)
fn r_3(n: int) -> int {
    let mut count = 0
    let lim = isqrt(n)
    let mut x = 0 - lim
    while x <= lim {
        let rem = n - x * x
        if rem >= 0 { count = count + r_2(rem) }
        x = x + 1
    }
    count
}

// @pure — Jacobi r_4(n) = 8 Σ_{d|n, 4∤d} d
fn r_4_jacobi(n: int) -> int {
    let ds = divisors(n)
    let mut s = 0
    let mut i = 0
    while i < len(ds) {
        if ds[i] % 4 != 0 { s = s + ds[i] }
        i = i + 1
    }
    8 * s
}

// @pure — r_8(n) = 16 Σ_{d|n} (-1)^(n-d) d³
fn r_8_formula(n: int) -> int {
    let ds = divisors(n)
    let mut s = 0
    let mut i = 0
    while i < len(ds) {
        let d = ds[i]
        let parity = (n - d) % 2
        let sign = if parity == 0 { 1 } else { 0 - 1 }
        s = s + sign * d * d * d
        i = i + 1
    }
    16 * s
}

fn analyze_n(n: int) {
    let sig = sigma(n)
    let t = tau(n)
    let ph = phi(n)
    println("")
    println("════════════════════════════════════════════════════════════")
    println("Quadratic Form Analysis: n = " + to_string(n))
    println("════════════════════════════════════════════════════════════")
    println("  sigma=" + to_string(sig) + ", tau=" + to_string(t) + ", phi=" + to_string(ph))
    let divides_4 = n % 4 == 0
    println("  4 | " + to_string(n) + ": " + to_string(divides_4))
    if !divides_4 {
        println("  → r_4(" + to_string(n) + ") = 8·sigma = " + to_string(8 * sig) + "  (Jacobi full)")
    } else {
        let ds = divisors(n)
        let mut sn4 = 0
        let mut i = 0
        while i < len(ds) {
            if ds[i] % 4 != 0 { sn4 = sn4 + ds[i] }
            i = i + 1
        }
        println("  → r_4(" + to_string(n) + ") = 8·" + to_string(sn4) + " = " + to_string(8 * sn4) + " (< 8σ=" + to_string(8 * sig) + ")")
    }
    // Legendre: r_3(n) = 0 iff n = 4^a(8b+7)
    let mut tm = n
    while tm % 4 == 0 { tm = tm / 4 }
    let r3_zero = tm % 8 == 7
    println("  r_3(" + to_string(n) + ") = 0  (Legendre): " + to_string(r3_zero))
    println("")
    println("   k |   r_k(n)  | connection")
    println("  ---+-----------+------------------")

    let r1 = if isqrt(n) * isqrt(n) == n && n > 0 { 2 } else { 0 }
    let r2 = r_2(n)
    let r3 = r_3(n)
    let r4 = r_4_jacobi(n)
    let r8 = r_8_formula(n)

    // connection finder
    fn conn_of(rk: int, sg: int, tt: int, p: int) -> string {
        if rk == sg { return "= sigma" }
        if rk == tt { return "= tau" }
        if rk == p { return "= phi" }
        if rk == sg * p { return "= sigma*phi" }
        if rk == 8 * sg { return "= 8·sigma" }
        if rk > 0 {
            let q = isqrt(rk)
            if q * q == rk { return "= " + to_string(q) + "²" }
        }
        ""
    }

    println("   1 | " + to_string(r1) + "\t| " + conn_of(r1, sig, t, ph))
    println("   2 | " + to_string(r2) + "\t| " + conn_of(r2, sig, t, ph))
    println("   3 | " + to_string(r3) + "\t| " + conn_of(r3, sig, t, ph))
    println("   4 | " + to_string(r4) + "\t| " + conn_of(r4, sig, t, ph))
    println("   8 | " + to_string(r8) + "\t| " + conn_of(r8, sig, t, ph))
}

fn check_perfect() {
    let perfects = [6, 28, 496, 8128]
    let mut i = 0
    while i < len(perfects) {
        let p = perfects[i]
        println("")
        println("############################################################")
        println("Perfect number P = " + to_string(p))
        println("############################################################")
        let sig = sigma(p)
        let d4 = p % 4 == 0
        let r4 = r_4_jacobi(p)
        println("  sigma=" + to_string(sig) + "  4|n=" + to_string(d4))
        println("  r_4 = " + to_string(r4) + ",  8·sigma = " + to_string(8 * sig))
        println("  r_4 = 8σ?  " + to_string(r4 == 8 * sig))
        if p <= 28 {
            println("  r_3 = " + to_string(r_3(p)))
            let r8 = r_8_formula(p)
            let q = isqrt(if r8 > 0 { r8 } else { 0 })
            let is_sq = if r8 > 0 && q * q == r8 { "sqrt=" + to_string(q) } else { "not square" }
            println("  r_8 = " + to_string(r8) + "  (" + is_sq + ")")
        }
        i = i + 1
    }
}

// ─── CLI ───
let argv = args()
let mut arg_n = -1
let mut arg_k = -1
let mut do_perfect = false
let mut idx = 0
while idx < len(argv) {
    let a = argv[idx]
    if a == "--perfect" {
        do_perfect = true
        idx = idx + 1
        continue
    }
    if a == "--n" && idx + 1 < len(argv) {
        arg_n = to_int(argv[idx+1])
        idx = idx + 2
        continue
    }
    if a == "--k" && idx + 1 < len(argv) {
        arg_k = to_int(argv[idx+1])
        idx = idx + 2
        continue
    }
    idx = idx + 1
}

if do_perfect {
    check_perfect()
} else if arg_n > 0 {
    if arg_k == 4 {
        println("r_4(" + to_string(arg_n) + ") = " + to_string(r_4_jacobi(arg_n)))
    } else if arg_k == 8 {
        println("r_8(" + to_string(arg_n) + ") = " + to_string(r_8_formula(arg_n)))
    } else if arg_k == 3 {
        println("r_3(" + to_string(arg_n) + ") = " + to_string(r_3(arg_n)))
    } else if arg_k == 2 {
        println("r_2(" + to_string(arg_n) + ") = " + to_string(r_2(arg_n)))
    } else {
        analyze_n(arg_n)
    }
} else {
    analyze_n(6)
    check_perfect()
}
