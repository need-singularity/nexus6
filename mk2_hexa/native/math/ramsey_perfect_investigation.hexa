// Ported from tecs-l/math/ramsey_perfect_investigation.py
// Ramsey numbers R(s, t) and perfect number connections.

// @pure
fn choose(n: int, k: int) -> int {
    if k < 0 || k > n { return 0 }
    if k == 0 || k == n { return 1 }
    let mut r = 1
    let mut i = 1
    while i <= k {
        r = r * (n - i + 1) / i
        i = i + 1
    }
    r
}

println("══════════════════════════════════════════════════════════════════════")
println("  RAMSEY NUMBERS × PERFECT NUMBERS")
println("══════════════════════════════════════════════════════════════════════")

// Known Ramsey numbers
println("")
println("## Known R(s, t)")
println("  R(3,3) =  6   ← n ★★★")
println("  R(3,4) =  9")
println("  R(3,5) = 14")
println("  R(3,6) = 18")
println("  R(4,4) = 18")
println("  R(3,7) = 23")
println("  R(4,5) = 25")

// R(3,3) = 6 = n is the fundamental result
// "Friends and strangers theorem"
println("")
println("## R(3,3)=6 — friends-and-strangers theorem")
println("  Among any 6 people, there are 3 mutual friends OR 3 mutual strangers.")
println("  6 = smallest such number ← n=6 is Ramsey-minimal")

// Perfect numbers
println("")
println("## Perfect numbers via sigma")
let mut perfs = []
let mut n = 1
while n <= 10000 {
    if sigma(n) == 2 * n { perfs = perfs + [n] }
    n = n + 1
}
println("  P1..P4 = " + to_string(perfs))
assert perfs[0] == 6
println("  First perfect = 6 = R(3,3) ★★★")

// Graph theory: C(6,2)=15 edges in K_6
let e6 = choose(6, 2)
assert e6 == 15
println("")
println("## K_6 complete graph")
println("  |V| = 6")
println("  |E| = C(6,2) = " + to_string(e6))
println("  2-coloring: by pigeonhole, some vertex has ≥ 3 edges same color → K_3")

// C(5,2) = 10 < 9 = needed for R(3,4)? Actually R(3,3)=6 proof uses pigeonhole.
let e5 = choose(5, 2)
println("")
println("## K_5: |E| = " + to_string(e5) + " — can 2-color without monochromatic triangle (pentagon)")

// Show R(3,3) ≤ 6: pigeonhole at vertex v with 5 edges → 3 same color
println("")
println("## R(3,3) ≤ 6 proof sketch")
println("  vertex v has 5 edges, 2 colors → ≥⌈5/2⌉ = 3 same color")
println("  3 neighbors: if any edge among them is that color → monochromatic triangle")
println("  else the 3 form another-color triangle. QED.")

// R(3,3) ≥ 6: 2-color K_5 avoiding monochromatic K_3 (pentagram)
println("")
println("## R(3,3) ≥ 6: pentagram 2-coloring of K_5 avoids mono K_3")

// Connection: σ(6)=12 = number of edges in K_4 × 2 (K_4 has C(4,2)=6 edges)
let e4 = choose(4, 2)
assert e4 == 6
println("")
println("## K_4 has " + to_string(e4) + " edges = n")

println("")
println("SUMMARY: R(3,3)=6=n=P_1 links Ramsey theory to first perfect number.")
