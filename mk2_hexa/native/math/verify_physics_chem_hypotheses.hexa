// Ported from tecs-l/math/verify_physics_chem_hypotheses.py
// Verify H-PH-3/4/5/6 and H-CHEM-4: n=6 physics/chem hypotheses.

let n = 6
let s = sigma(n)   // 12
let t = tau(n)     // 4
let p = phi(n)     // 2

assert s == 12
assert t == 4
assert p == 2

println("══════════════════════════════════════════════════════════════════════")
println("  PHYSICS / CHEM hypotheses on n=6")
println("══════════════════════════════════════════════════════════════════════")
println("  σ(6)=" + to_string(s) + " τ(6)=" + to_string(t) + " φ(6)=" + to_string(p))

// ── H-PH-3: τ*φ = σ → nuclear physics shell? ──────────────────
println("")
println("## H-PH-3: τ(n)·φ(n) = σ(n)")
let tp = t * p      // 8
println("  τ(6)·φ(6) = " + to_string(tp))
println("  σ(6)     = " + to_string(s))
println("  equal?   " + if tp == s { "YES" } else { "NO" })
assert tp == 8
assert s == 12
// The numerical claim is 8 ≠ 12 — claim REFUTED for n=6.
// But find all n ≤ 1000 with τ(n)*φ(n) = σ(n)
let mut hits = []
let mut k = 1
while k <= 100 {
    if tau(k) * phi(k) == sigma(k) { hits = hits + [k] }
    k = k + 1
}
println("  solutions in [1,100]: " + to_string(hits))
// Known: {1, 3, 14, 42}
assert len(hits) == 4

// ── H-PH-4: 6 quarks + 6 leptons = σ(6) = 12 ──────────────────
println("")
println("## H-PH-4: 6 quarks + 6 leptons = σ(6)")
let total_fermions = 6 + 6
assert total_fermions == s
println("  12 = σ(6) ✓")
// But 3 generations × 4 fermions each = 12
assert 3 * 4 == s
assert s / t == 3            // generations
assert t == 4                 // per-generation fermions
println("  generations = σ/τ = 3, per-gen = τ = 4")

// ── H-PH-5: Planck units and 6 ────────────────────────────────
println("")
println("## H-PH-5: Planck units — 3 base from (hbar, G, c)")
// 3 independent base units = σ/τ
let n_base = 3
assert n_base == s / t
println("  3 base units = σ(6)/τ(6) ✓ (trivial: 3 constants → 3 units)")
println("  VERDICT: structural but trivial (WHITE CIRCLE)")

// ── H-PH-6: R-chain vs radioactive decay ──────────────────────
// R(n) = floor(σ(n)*φ(n)/τ(n))
println("")
println("## H-PH-6: R-chain decay (small n)")
// Spot-check for n ∈ {6, 12, 24}: compute R(n) = σ(n)·φ(n)/τ(n)
let r6  = sigma(6) * phi(6) / tau(6)     // 12·2/4 = 6
let r12 = sigma(12) * phi(12) / tau(12)  // 28·4/6 = 18
let r24 = sigma(24) * phi(24) / tau(24)  // 60·8/8 = 60
println("  R(6) = " + to_string(r6))
println("  R(12) = " + to_string(r12))
println("  R(24) = " + to_string(r24))
assert r6 == 6    // 6 is a fixed point of R
println("  ★ 6 is fixed point of R: R(6)=6")

// ── H-CHEM-4: R-chain vs Arrhenius — no temperature analogue ─
println("")
println("## H-CHEM-4: R-chain ↔ Arrhenius")
println("  R-chain lacks T analogue → mapping fails")
println("  VERDICT: loose analogy only (WHITE CIRCLE)")

println("")
println("SUMMARY:")
println("  H-PH-3: REFUTED (τφ≠σ for n=6; sol = {1,3,14,42})")
println("  H-PH-4: arithmetic correct (σ=12 = fermions), structural weak")
println("  H-PH-5: trivial")
println("  H-PH-6: loose (R-chain decreases but not exponential)")
println("  H-CHEM-4: loose")
