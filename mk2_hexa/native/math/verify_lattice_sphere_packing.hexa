// Ported from tecs-l/math/verify_lattice_sphere_packing.py
// H-LAT: lattice sphere-packing density tied to n=6 arithmetic constants.
// σ(6)·φ(6)=24 = Leech dim, τ(6)=4, φ(6)=2, σ(6)=12.

println("══════════════════════════════════════════════════════════════════════")
println("  H-LAT — Lattice sphere-packing dimensions from n=6")
println("══════════════════════════════════════════════════════════════════════")

// Key identities
assert sigma(6) * phi(6) == 24
assert sigma(6) == 12
assert phi(6) == 2
assert tau(6) == 4

println("")
println("## Anchor values")
println("  σ(6) = " + to_string(sigma(6)) + "  (12)")
println("  φ(6) = " + to_string(phi(6)) + "  (2)")
println("  τ(6) = " + to_string(tau(6)) + "  (4)")
println("  σ·φ  = " + to_string(sigma(6) * phi(6)) + " (Leech dim 24)")

// Famous lattice dims tied to n=6 arithmetic
println("")
println("## Lattice dimensions derived")
println("  E8       : dim 8    = σ(6) - φ(6)·2 = 12 - 4 = 8 ✓")
let e8 = sigma(6) - phi(6) * 2
assert e8 == 8
println("  D4       : dim 4    = τ(6)               = 4 ✓")
println("  Leech Λ24: dim 24   = σ(6)·φ(6)          = 24 ✓")
println("  CY3      : dim 6    = n                   = 6 ✓")

// Kissing numbers
println("")
println("## Kissing numbers (reference)")
println("  D4   : 24     (= σ(6)·φ(6))")
println("  E8   : 240    (= 24·10, or φ(496))")
println("  Λ24  : 196560 (= 24·8190 + small)")

// Verify φ(496) = 240 (E8 root count)
let e8_roots = phi(496)
println("")
println("## φ(496) = E8 root count")
println("  φ(496) = " + to_string(e8_roots) + " expected 240")
let ok = if e8_roots == 240 { "PASS ★" } else { "FAIL" }
println("  status: " + ok)

// Packing density expressions (rational num/den)
println("")
println("## Packing densities (rational form num/den)")
println("  D4 : π²/16")
println("  E8 : π⁴/384")
println("  Λ24: π¹²/(12!)")

// Show 12! for Λ24 denom
// @pure
fn fact(k: int) -> int {
    if k <= 1 { return 1 }
    let mut r = 1
    let mut i = 2
    while i <= k { r = r * i; i = i + 1 }
    r
}
let f12 = fact(12)
println("  12! = " + to_string(f12))
println("  σ(6)² = " + to_string(sigma(6) * sigma(6)))

// sigma/phi table in [1, 30]
println("")
println("## σ·φ in [1, 30] — how rare is 24?")
let mut count24 = 0
let mut n = 1
while n <= 30 {
    if sigma(n) * phi(n) == 24 { count24 = count24 + 1 }
    n = n + 1
}
println("  count of n with σ(n)·φ(n) = 24 in [1,30] = " + to_string(count24))

println("")
println("SUMMARY: n=6 generates D4, E8, Λ24 dimensions via σ/φ/τ arithmetic.")
