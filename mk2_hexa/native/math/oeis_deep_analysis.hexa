// mk2_hexa/native/oeis_deep_analysis.hexa
// 포팅 원본: tecs-l/math/oeis_deep_analysis.py (221 LOC)
// Deep analysis: Seq A, D, J — OEIS candidate characterization
//
// AI-native: @pure, hexa sigma/phi/tau 빌트인, sympy 제거
// 범위: N=1000 (Python 10000/100000 → 인터프리터 속도)

let N = 1000

// @pure — gcd
fn gcd_int(a: int, b: int) -> int {
    let mut x = if a < 0 { 0 - a } else { a }
    let mut y = if b < 0 { 0 - b } else { b }
    while y != 0 {
        let t = x % y
        x = y
        y = t
    }
    x
}

// @pure — 소인수 개수 ω(n)
fn omega_n(n: int) -> int {
    let mut m = n
    let mut c = 0
    let mut p = 2
    while p * p <= m {
        if m % p == 0 {
            c = c + 1
            while m % p == 0 { m = m / p }
        }
        p = p + 1
    }
    if m > 1 { c = c + 1 }
    c
}

// @pure — Ω(n) (중복 포함)
fn big_omega(n: int) -> int {
    let mut m = n
    let mut c = 0
    let mut p = 2
    while p * p <= m {
        while m % p == 0 {
            m = m / p
            c = c + 1
        }
        p = p + 1
    }
    if m > 1 { c = c + 1 }
    c
}

// @pure — is prime
fn is_prime(n: int) -> bool {
    if n < 2 { return false }
    if n == 2 { return true }
    if n % 2 == 0 { return false }
    let mut i = 3
    while i * i <= n {
        if n % i == 0 { return false }
        i = i + 2
    }
    true
}

println("══════════════════════════════════════════════════════════════════════")
println("OEIS DEEP ANALYSIS: Seq A, D, J  (hexa port)")
println("══════════════════════════════════════════════════════════════════════")
println("  Range: n = 1.." + to_string(N))

// ─── Seq A: R(n) integer ───
println("")
println("── Seq A: {n : σ(n)·φ(n) / (n·τ(n)) ∈ ℤ} ──")
let mut seq_A = []
let mut n = 1
while n <= N {
    let num = sigma(n) * phi(n)
    let den = n * tau(n)
    if num % den == 0 { seq_A = seq_A + [n] }
    n = n + 1
}
println("  Count: " + to_string(len(seq_A)))
println("  Members: " + to_string(seq_A))

// ω distribution
let mut omega_buckets = [0, 0, 0, 0, 0, 0, 0, 0]
let mut i = 0
while i < len(seq_A) {
    let om = omega_n(seq_A[i])
    if om < 8 { omega_buckets[om] = omega_buckets[om] + 1 }
    i = i + 1
}
println("  ω distribution (0..7): " + to_string(omega_buckets))

// primes / prime powers
let mut primes_A = []
let mut pps_A = []
let mut j = 0
while j < len(seq_A) {
    let m = seq_A[j]
    if is_prime(m) { primes_A = primes_A + [m] }
    if omega_n(m) == 1 && m > 1 { pps_A = pps_A + [m] }
    j = j + 1
}
println("  Primes in Seq A: " + to_string(primes_A))
println("  Prime powers (ω=1) in Seq A: " + to_string(pps_A))

// Perfect numbers membership
let perfects = [6, 28, 496]
let mut pi2 = 0
while pi2 < len(perfects) {
    let p = perfects[pi2]
    let mut in_A = false
    let mut k = 0
    while k < len(seq_A) {
        if seq_A[k] == p { in_A = true }
        k = k + 1
    }
    println("  " + to_string(p) + " in Seq A? " + (if in_A { "YES" } else { "NO" }))
    pi2 = pi2 + 1
}

// ─── Seq D: τ(σ(n)) = n ───
println("")
println("── Seq D: {n : τ(σ(n)) = n} ──")
let mut seq_D = []
let mut m = 1
while m <= N {
    if tau(sigma(m)) == m { seq_D = seq_D + [m] }
    m = m + 1
}
println("  Count: " + to_string(len(seq_D)))
println("  Members: " + to_string(seq_D))
println("  All divisors of 6? {1,2,3,6} — " + (if len(seq_D) == 4 && seq_D[0] == 1 && seq_D[1] == 2 && seq_D[2] == 3 && seq_D[3] == 6 { "YES ★" } else { "CHECK" }))

// ─── Seq J: n | lcm(σ, φ) ───
println("")
println("── Seq J: {n : n | lcm(σ(n), φ(n))} ──")
let mut seq_J = []
let mut q = 1
while q <= N {
    let s = sigma(q)
    let p = phi(q)
    let g = gcd_int(s, p)
    let l = (s / g) * p  // lcm via division-first to avoid overflow
    if l % q == 0 { seq_J = seq_J + [q] }
    q = q + 1
}
println("  Count: " + to_string(len(seq_J)))
let mut head_J = []
let mut hj = 0
while hj < len(seq_J) && hj < 25 {
    head_J = head_J + [seq_J[hj]]
    hj = hj + 1
}
println("  First 25: " + to_string(head_J))

// ─── R(p) = (p²−1)/(2p) is NEVER integer for prime p ≥ 2 ───
println("")
println("── R(n) at primes: closed form ──")
println("  R(p) = (p²−1)/(2p);  check (p²−1) mod (2p)")
let small_primes = [2, 3, 5, 7, 11, 13]
let mut sp = 0
while sp < len(small_primes) {
    let p = small_primes[sp]
    let rem = (p * p - 1) % (2 * p)
    println("  p=" + to_string(p) + ": (p²−1) mod 2p = " + to_string(rem))
    sp = sp + 1
}
println("  → R(p) is NEVER integer for prime p ≥ 2 (confirmed: no primes in Seq A)")

// ─── Overlap Seq A ∩ Seq J ───
println("")
println("── Overlap: Seq A ∩ Seq J ──")
let mut overlap = []
let mut ai = 0
while ai < len(seq_A) {
    let a = seq_A[ai]
    let mut ji = 0
    while ji < len(seq_J) {
        if seq_J[ji] == a {
            overlap = overlap + [a]
            ji = len(seq_J)
        }
        ji = ji + 1
    }
    ai = ai + 1
}
println("  |A ∩ J| = " + to_string(len(overlap)))
println("  Members: " + to_string(overlap))

// ─── Seq D uniqueness and divisors of 6 ───
println("")
println("── Key observation: Seq D = divisors(6) ──")
let divs6 = [1, 2, 3, 6]
println("  divisors(6) = " + to_string(divs6))
let mut match_d = len(seq_D) == len(divs6)
if match_d {
    let mut dk = 0
    while dk < len(divs6) {
        if seq_D[dk] != divs6[dk] { match_d = false }
        dk = dk + 1
    }
}
println("  Seq D = divisors(6)? " + (if match_d { "YES ★" } else { "NO" }))

// ─── Final summary ───
println("")
println("══════════════════════════════════════════════════════════════════════")
println("FINAL OEIS CANDIDATE SUMMARY")
println("══════════════════════════════════════════════════════════════════════")
println("  A: {n : σφ/(nτ) ∈ ℤ}                              " + to_string(len(seq_A)) + " terms")
println("     - no primes, no prime powers")
println("     - contains all perfects (6, 28, 496)")
println("  D: {n : τ(σ(n)) = n}                              " + to_string(len(seq_D)) + " terms")
println("     - {1, 2, 3, 6} = divisors(6) ★ structural")
println("  J: {n : n | lcm(σ(n), φ(n))}                      " + to_string(len(seq_J)) + " terms")
println("     - superset of A (contains 6, 24, 28, 40, ...)")
println("")
println("  Dirichlet collapse {n : (σ*φ)(n) = σ(n)·φ(n)} = {1, 6} (from r_spectrum.hexa)")
