// mk2_hexa/native/search_new_identities.hexa
// 포팅 원본: tecs-l/math/search_new_identities.py (338 LOC)
// 새 arithmetic identity 자동 탐색 — 작은 finite solution set 찾기

let LIMIT = 300

// @pure — Dedekind ψ(n) = n · Π(1 + 1/p)
fn psi_n(n: int) -> int {
    let mut m = n
    let mut r = n
    let mut p = 2
    while p * p <= m {
        if m % p == 0 {
            r = r * (p + 1) / p
            while m % p == 0 { m = m / p }
        }
        p = p + 1
    }
    if m > 1 { r = r * (m + 1) / m }
    r
}

// @pure — Jordan J_2(n) = n² · Π(1 − 1/p²)
fn J2_n(n: int) -> int {
    let mut m = n
    let mut num = n * n
    let mut den = 1
    let mut p = 2
    while p * p <= m {
        if m % p == 0 {
            num = num * (p * p - 1)
            den = den * (p * p)
            while m % p == 0 { m = m / p }
        }
        p = p + 1
    }
    if m > 1 {
        num = num * (m * m - 1)
        den = den * (m * m)
    }
    num / den
}

// @pure — ω(n) distinct primes
fn omega_n(n: int) -> int {
    let mut m = n
    let mut c = 0
    let mut p = 2
    while p * p <= m {
        if m % p == 0 {
            c = c + 1
            while m % p == 0 { m = m / p }
        }
        p = p + 1
    }
    if m > 1 { c = c + 1 }
    c
}

// @pure — Ω(n) total prime factors with multiplicity
fn big_omega_n(n: int) -> int {
    let mut m = n
    let mut c = 0
    let mut p = 2
    while p * p <= m {
        while m % p == 0 {
            m = m / p
            c = c + 1
        }
        p = p + 1
    }
    if m > 1 { c = c + 1 }
    c
}

// ─── Identity test functions (id #) ───
fn t_id(idx: int, n: int) -> bool {
    let s = sigma(n)
    let t = tau(n)
    let p = phi(n)
    let psi_v = psi_n(n)
    let j2 = J2_n(n)
    let om = omega_n(n)
    let bom = big_omega_n(n)

    // G1.1 σ·ω = n·Ω
    if idx == 1 { return s * om == n * bom }
    // G1.3 φ·σ = n²
    if idx == 2 { return p * s == n * n }
    // G2.4 σ·ψ = n·τ²
    if idx == 3 { return s * psi_v == n * t * t }
    // G2.5 ψ·φ = n·σ
    if idx == 4 { return psi_v * p == n * s }
    // G2.6 ψ² = n·σ·τ
    if idx == 5 { return psi_v * psi_v == n * s * t }
    // G3.7 J2·τ = n·σ
    if idx == 6 { return j2 * t == n * s }
    // G3.8 J2 = σ·φ
    if idx == 7 { return j2 == s * p }
    // B1 σ + φ = 2n
    if idx == 8 { return s + p == 2 * n }
    // B2 σ − φ = n
    if idx == 9 { return s - p == n }
    // B3 σ = 2φ
    if idx == 10 { return s == 2 * p }
    // B4 σ·τ = n·ψ
    if idx == 11 { return s * t == n * psi_v }
    // B5 φ·τ = σ
    if idx == 12 { return p * t == s }
    // B7 J2 = n·φ
    if idx == 13 { return j2 == n * p }
    // B8 σ·ω = n·τ
    if idx == 14 { return s * om == n * t }
    // B13 σ·φ = n·ψ
    if idx == 15 { return s * p == n * psi_v }
    // K1 σ·φ = n·τ  (master)
    if idx == 16 { return s * p == n * t }
    // K2 σ·τ = n·φ
    if idx == 17 { return s * t == n * p }
    // K3 τ·φ = σ
    if idx == 18 { return t * p == s }
    // K4 τ·ψ = n²
    if idx == 19 { return t * psi_v == n * n }
    // K5 φ·ψ = n·τ
    if idx == 20 { return p * psi_v == n * t }
    false
}

let id_tags = ["G1.1", "G1.3", "G2.4", "G2.5", "G2.6", "G3.7", "G3.8", "B1", "B2", "B3", "B4", "B5", "B7", "B8", "B13", "K1", "K2", "K3", "K4", "K5"]
let id_descs = ["σ·ω = n·Ω", "φ·σ = n²", "σ·ψ = n·τ²", "ψ·φ = n·σ", "ψ² = n·σ·τ", "J₂·τ = n·σ", "J₂ = σ·φ", "σ + φ = 2n", "σ − φ = n", "σ = 2φ", "σ·τ = n·ψ", "φ·τ = σ", "J₂ = n·φ", "σ·ω = n·τ", "σ·φ = n·ψ", "σ·φ = n·τ (master)", "σ·τ = n·φ", "τ·φ = σ", "τ·ψ = n²", "φ·ψ = n·τ"]

println("══════════════════════════════════════════════════════════════════════")
println("ARITHMETIC IDENTITY SEARCH: 20 candidates  (hexa port)")
println("══════════════════════════════════════════════════════════════════════")
println("  Search range: n = 1.." + to_string(LIMIT))
println("")

// ─── Run all identities ───
println("    tag |  identity                | #sols | solutions               | n=6  | grade")
println("  ------+--------------------------+-------+-------------------------+------+--------")

let mut id = 1
let mut star_count = 0
while id <= 20 {
    let mut sols = []
    let mut n = 1
    while n <= LIMIT {
        if t_id(id, n) { sols = sols + [n] }
        n = n + 1
    }

    let mut has_6 = false
    let mut k = 0
    while k < len(sols) {
        if sols[k] == 6 { has_6 = true }
        k = k + 1
    }

    let cnt = len(sols)
    let mut grade = ""
    if cnt == 0 { grade = "⬛" }
    else if cnt == 1 && sols[0] == 6 {
        grade = "⭐ STAR"
        star_count = star_count + 1
    }
    else if cnt <= 3 && has_6 { grade = "🟩" }
    else if cnt <= 10 && has_6 { grade = "🟩 weak" }
    else if has_6 { grade = "⚪" }
    else { grade = "⬛" }

    let sol_head = if cnt > 6 {
        let mut h = []
        let mut z = 0
        while z < 6 {
            h = h + [sols[z]]
            z = z + 1
        }
        to_string(h) + "…"
    } else {
        to_string(sols)
    }

    let n6_tag = if has_6 { "✓" } else { "−" }
    println("  " + id_tags[id - 1] + "\t| " + id_descs[id - 1] + "\t| " + to_string(cnt) + "\t| " + sol_head + "\t| " + n6_tag + "\t| " + grade)
    id = id + 1
}

println("")
println("══════════════════════════════════════════════════════════════════════")
println("STAR identities (unique to n=6 in [1, " + to_string(LIMIT) + "])")
println("══════════════════════════════════════════════════════════════════════")
println("")

let mut id2 = 1
while id2 <= 20 {
    let mut sols = []
    let mut n = 1
    while n <= LIMIT {
        if t_id(id2, n) { sols = sols + [n] }
        n = n + 1
    }
    if len(sols) == 1 && sols[0] == 6 {
        println("  ★ " + id_tags[id2 - 1] + ": " + id_descs[id2 - 1])
    }
    id2 = id2 + 1
}

println("")
println("  Total ⭐ STAR identities: " + to_string(star_count))
println("")
println("  Note: G2.5 (ψ·φ = n·σ) and B5 (φ·τ = σ) and K3 (τ·φ = σ) are equivalent forms")
println("        of variants of σφ = nτ family — checking which are actually distinct.")
