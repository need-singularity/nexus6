// mk2_hexa/native/ramsey_perfect_deeper.hexa
// 포팅 원본: tecs-l/math/ramsey_perfect_deeper.py (245 LOC)
//
// R(3,k) vs C(k,2): 완전수 관계 심층 분석
//
// AI-native: @pure, hexa sigma 빌트인으로 완전수 판정

// @pure
fn ck2(k: int) -> int { k * (k - 1) / 2 }

// @pure
fn is_perfect(n: int) -> bool { sigma(n) == 2 * n }

fn fmt3(x: float) -> string {
    let r = to_float(to_int(x * 1000.0)) / 1000.0
    to_string(r)
}
fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0)) / 10000.0
    to_string(r)
}

println("════════════════════════════════════════════════════════════════════════")
println("DEEPER ANALYSIS: R(3,k) = C(k,2) phenomenon  (hexa port)")
println("════════════════════════════════════════════════════════════════════════")

// R(3,k) 알려진 값
let r3k_k = [3, 4, 5, 6, 7, 8, 9]
let r3k_v = [6, 9, 14, 18, 23, 28, 36]

println("")
println("   k | R(3,k) | C(k,2) | C(k+1,2) | R/C(k,2) | R/C(k+1,2) | R=C(k,2)?")
println("  ---+--------+--------+----------+----------+------------+----------")
let mut i = 0
while i < len(r3k_k) {
    let k = r3k_k[i]
    let r = r3k_v[i]
    let c2 = ck2(k)
    let c12 = ck2(k + 1)
    let rc2 = to_float(r) / to_float(c2)
    let rc12 = to_float(r) / to_float(c12)
    let eq = if r == c2 { "YES ✓" } else { "" }
    println("   " + to_string(k) + " | " + to_string(r) + "\t| " + to_string(c2) + "\t| " + to_string(c12) + "\t| " + fmt3(rc2) + "\t| " + fmt4(rc12) + "\t| " + eq)
    i = i + 1
}

println("")
println("CRITICAL OBSERVATION:")
println("  R(3,k)/C(k,2)가 2.0 → 1.0으로 단조 감소")
println("  k=8,9: R(3,k) = C(k,2)  (exact hits)")
println("  Known: R(3,k) ~ c·k²/log(k), C(k,2) ~ k²/2 → 비율 → 0")

// ─── Radziszowski bounds for k=10..15 ───
println("")
println("════════════════════════════════════════════════════════════════════════")
println("KNOWN BOUNDS R(3,k), k=10..15  (Radziszowski DS1)")
println("════════════════════════════════════════════════════════════════════════")
println("   k | lower | upper | C(k,2) | C(k,2) in range?")
println("  ---+-------+-------+--------+------------------")
let bk = [10, 11, 12, 13, 14, 15]
let lo = [40, 46, 52, 59, 66, 73]
let hi = [42, 51, 59, 68, 77, 88]
let mut j = 0
while j < len(bk) {
    let k = bk[j]
    let c = ck2(k)
    let tag = if c >= lo[j] && c <= hi[j] { "YES" }
              else if c < lo[j] { "NO (too low)" }
              else { "NO (too high)" }
    println("   " + to_string(k) + " | " + to_string(lo[j]) + "\t| " + to_string(hi[j]) + "\t| " + to_string(c) + "\t| " + tag)
    j = j + 1
}

println("")
println("k=10: C(10,2)=45 > upper=42 → R(3,10) < 45 → already dropped below C(k,2)!")
println("R(3,32) = 496 = C(32,2) is IMPOSSIBLE — ratio crossed below 1 at k=10.")

// ─── 완전수 판정 ───
println("")
println("════════════════════════════════════════════════════════════════════════")
println("Perfect number checks on C(k,2)")
println("════════════════════════════════════════════════════════════════════════")
let check_k = [3, 4, 8, 16, 32, 64]
let mut m = 0
while m < len(check_k) {
    let k = check_k[m]
    let c = ck2(k)
    let is_p = is_perfect(c)
    let mp_base = k  // k = 2^p requires 2^p-1 Mersenne prime
    println("  k=" + to_string(k) + ": C(k,2)=" + to_string(c) + "  σ=" + to_string(sigma(c)) + "  perfect? " + (if is_p { "YES" } else { "no" }))
    m = m + 1
}

println("")
println("  Mechanism: k = 2^p → C(k,2) = 2^(p-1)·(2^p-1)")
println("  Perfect ⇔ 2^p-1 = Mersenne prime")
println("  k=4 (p=2, M=3)  → C=6  perfect ✓")
println("  k=8 (p=3, M=7)  → C=28 perfect ✓")
println("  k=16(p=4, M=15) → C=120 NOT perfect (15 not prime)")
println("  k=32(p=5, M=31) → C=496 perfect ✓ (but R(3,32) ≠ 496)")
println("  k=64(p=6, M=63) → C=2016 NOT perfect (63 not prime)")

// ─── 두 Hit의 서로 다른 메커니즘 ───
println("")
println("════════════════════════════════════════════════════════════════════════")
println("Two DIFFERENT mechanisms for the two perfect-number hits")
println("════════════════════════════════════════════════════════════════════════")
println("")
println("  | k | R(3,k) | mechanism               | why perfect               |")
println("  |---|--------|-------------------------|---------------------------|")
println("  | 3 |   6    | R = C(k+1,2) = C(4,2)   | 4=2², M₂=3,  C(4,2)=2·3  |")
println("  | 8 |  28    | R = C(k,2)   = C(8,2)   | 8=2³, M₃=7,  C(8,2)=4·7  |")
println("")
println("  Mechanism 1: Ramsey upper bound R(s,t) ≤ C(s+t-2, s-1) = C(4,2) tight.")
println("  Mechanism 2: Transient equality R(3,k)=C(k,2) at k=8,9 crossing point.")

// ─── 점근 추정: k²/(2 ln k) = 496 → k ≈ ? ───
println("")
println("════════════════════════════════════════════════════════════════════════")
println("Asymptotic: when does R(3,k) ≈ 496 naturally?")
println("════════════════════════════════════════════════════════════════════════")
println("")
println("  R(3,k) ~ k²/(2 ln k)  (Shearer-type)")
println("  Solve k²/(2 ln k) = 496 via binary search")

// Binary search for k
let mut lo_k = 10.0
let mut hi_k = 100.0
let mut iter = 0
while iter < 60 {
    let mid = (lo_k + hi_k) / 2.0
    let v = mid * mid / (2.0 * log(mid))
    if v < 496.0 { lo_k = mid } else { hi_k = mid }
    iter = iter + 1
}
let k_est = (lo_k + hi_k) / 2.0
println("  k ≈ " + fmt3(k_est))
let ki = to_int(k_est)
println("  For k ≈ " + to_string(ki) + ": C(k,2) = " + to_string(ck2(ki)))
println("  So R(3,~" + to_string(ki) + ") ≈ 496 is arithmetically possible,")
println("  but NOT as C(k,2) structure — just natural growth crossing 496.")

println("")
println("════════════════════════════════════════════════════════════════════════")
println("FINAL GRADE: 🟧★  (structural p=0.047, two distinct mechanisms)")
println("════════════════════════════════════════════════════════════════════════")
println("  R(3,32)=496 refuted. R(3,k)=496 for some k≈46 is accidental.")
println("  The coincidence is real but LIMITED — won't recur after k=9.")
