// 병렬 배열: hits[i] = (doms[i], forms[i], notes[i], tags[i])
// tags ∈ {"Yes","Weak","Dup","Tautology","Negative"}
let doms  = ["Sequences", "Sequences", "Factorization", "Factorization", "Perfect Number", "Graph Theory", "Binomial", "Lie Algebra", "Lie Algebra", "Lie Algebra", "Consecutive Sum", "Exterior Power", "Exotic Spheres", "Exotic Spheres", "Odd Sums", "Odd Sums", "Sigma Chain"]
let forms = ["T_31 = sum(1..31) = 496", "H_16 = 16*(2*16-1) = 496", "2^tau(6) * Phi_6(6) = 16*31 = 496", "2^4 * (2^5-1) = 496", "2^(p-1)*(2^p-1) for p=5", "C(32,2) = K_32 edges = 496", "C(32,2) = 496", "dim(SO(32)) = 32*31/2 = 496", "dim(E8 x E8) = 2*248 = 496", "dim(D_16) = dim(SO(32)) = 16*31", "sum(1..31) = 496", "Lambda^2(R^32) = C(32,2) = 496", "sigma(496) = 992 = |Theta_11|", "|Theta_11| = 2*496", "sum odd(55..69) = 496", "sum odd(121..127) = 496", "sigma^2(6)=sigma(12)=28=P2"]
let notes = ["31st triangular number; 31=Mersenne prime", "16th hexagonal number", "tau(6)=4, Phi_6(6)=31; CONNECTS P1 to P3", "Mersenne perfect number form", "Definition of P3", "K_32 complete graph", "Same as K_32 (overlaps graph)", "Heterotic string gauge group", "Other anomaly-free gauge group in 10D", "D_n = SO(2n) series; n=16", "Same as T_31 (Triangular)", "2nd exterior power of R^32", "Perfect number sigma = Theta_11", "992 = 2*P3", "8 consecutive odds: 55,57,...,69", "4 consecutive odds: 121,123,125,127", "496 NOT in chain, but P2=28 IS at k=2"]
let tags  = ["Yes", "Yes", "Yes", "Yes", "Tautology", "Yes", "Dup", "Yes", "Yes", "Dup", "Dup", "Yes", "Yes", "Yes", "Weak", "Weak", "Negative"]

// @pure
fn count_tag_of(tags: list, tag: string) -> int {
    let mut n = 0
    let mut i = 0
    while i < len(tags) {
        if tags[i] == tag { n = n + 1 }
        i = i + 1
    }
    n
}
fn count_tag(tag: string) -> int { count_tag_of(tags, tag) }

let total_all = len(tags)
let total_structural = count_tag("Yes")
let total_weak = count_tag("Weak")
let total_other = total_all - total_structural - total_weak

println("══════════════════════════════════════════════════════════════════════")
println("P3=496 SHADOW REPORT — STRUCTURED (hexa port)")
println("══════════════════════════════════════════════════════════════════════")
println("")
println("  Total hits found: " + to_string(total_all))
println("  Structural (independent, non-trivial): " + to_string(total_structural))
println("  Weak (consecutive sum, not deep): " + to_string(total_weak))
println("  Duplicates/tautologies: " + to_string(total_other))

println("")
println("--- STRUCTURAL HITS (count towards shadow density) ---")
let mut i = 0
let mut idx = 0
while i < len(tags) {
    if tags[i] == "Yes" {
        idx = idx + 1
        println("  " + to_string(idx) + ". [" + doms[i] + "] " + forms[i])
        println("       → " + notes[i])
    }
    i = i + 1
}

println("")
println("--- WEAK HITS (noted but not counted as structural) ---")
let mut j = 0
while j < len(tags) {
    if tags[j] == "Weak" {
        println("  [" + doms[j] + "] " + forms[j] + " → " + notes[j])
    }
    j = j + 1
}

