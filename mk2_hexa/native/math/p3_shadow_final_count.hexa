// ─── 대조 검증: hexa sigma/tau 빌트인으로 공식 직접 확인 ───
println("")
println("--- Inline verification (hexa sigma/tau builtins) ---")
let p1 = 6
let tau6 = tau(p1)
let phi6_at_6 = 6 * 6 - 6 + 1  // 6th cyclotomic at x=6 = x^2-x+1 = 31
let formula = pow(2, tau6) * phi6_at_6
println("  tau(6) = " + to_string(tau6))
println("  Phi_6(6) = 6^2 - 6 + 1 = " + to_string(phi6_at_6))
println("  2^tau(6) * Phi_6(6) = " + to_string(formula))
assert formula == 496
println("  ✓ 496 identity verified")
