// Ported from tecs-l/math/verify_game_prob.py
// H-GAME: game-theoretic probabilities anchored at n=6 (6-sided die, 6 faces, etc.)

// @pure
fn fact(k: int) -> int {
    if k <= 1 { return 1 }
    let mut r = 1
    let mut i = 2
    while i <= k { r = r * i; i = i + 1 }
    r
}

// @pure
fn choose(n: int, k: int) -> int {
    if k < 0 || k > n { return 0 }
    if k == 0 || k == n { return 1 }
    let mut r = 1
    let mut i = 1
    while i <= k {
        r = r * (n - i + 1) / i
        i = i + 1
    }
    r
}

println("══════════════════════════════════════════════════════════════════════")
println("  H-GAME — game theory probabilities at n=6")
println("══════════════════════════════════════════════════════════════════════")

// 6-sided die: P(sum = s with k dice)
println("")
println("## 6-sided die sum distribution (k dice)")
println("  k=1: faces 1..6, uniform 1/6")
println("  k=2: sum 2..12, total outcomes = 36")

// Count ways for 2-dice sum
println("")
println("  2-dice sums (count of outcomes):")
let mut s = 2
while s <= 12 {
    let mut ways = 0
    let mut a = 1
    while a <= 6 {
        let b = s - a
        if b >= 1 && b <= 6 { ways = ways + 1 }
        a = a + 1
    }
    println("    sum=" + to_string(s) + "  ways=" + to_string(ways) + "/36")
    s = s + 1
}

// Poker-like: choose(6,k) small combinations
println("")
println("## Binomial coefficients C(6, k)")
let mut k = 0
while k <= 6 {
    println("  C(6, " + to_string(k) + ") = " + to_string(choose(6, k)))
    k = k + 1
}
let total = 1 + 6 + 15 + 20 + 15 + 6 + 1
assert total == 64
println("  sum = 64 = 2^6 ✓")

// 6-card hand from 52: C(52,6)
let c52_6 = choose(52, 6)
println("")
println("## Poker-style: C(52, 6) = " + to_string(c52_6))

// 6! permutations
let f6 = fact(6)
assert f6 == 720
println("  6! = " + to_string(f6) + " permutations of 6 elements")

// σ(6)·φ(6) = 6! / 30 = 24
println("")
println("## Master identity connection")
println("  σ(6)·φ(6) = " + to_string(sigma(6) * phi(6)) + " = 24")
println("  6! / 5!   = " + to_string(f6 / fact(5)) + " = 6")
println("  6! / 30   = " + to_string(f6 / 30) + " = 24 = σ·φ ✓")

// τ(6)=4 = D4 lattice kissing / 6 = 24/6
println("")
println("## τ(6) = 4 anchor")
assert tau(6) == 4
println("  τ(6)=4 = spacetime dim = simple root count D4/6")

println("")
println("SUMMARY: game-theory combinatorics at n=6 land on σφ=24, τ=4, φ=2.")
