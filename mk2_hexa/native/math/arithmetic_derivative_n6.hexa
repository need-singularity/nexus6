// 포팅 원본: tecs-l/math/arithmetic_derivative_n6.py (469 LOC)
//
// Arithmetic Derivative at n=6: Complete Exploration
// n' defined by: p'=1 for prime p, (ab)'=a'b+ab' (Leibniz rule)
//
// hexa builtins used: sigma(n), phi(n), tau(n), sopfr(n)
// Limits reduced: Python 10K→500, Python 100→100 (kept)

// ── helpers ──

fn pad(s: string, w: int) -> string {
    let mut r = s
    while len(r) < w { r = " " + r }
    r
}

fn fmt2(x: float) -> string {
    to_string(to_float(to_int(x * 100.0)) / 100.0)
}

fn fmt6(x: float) -> string {
    to_string(to_float(to_int(x * 1000000.0)) / 1000000.0)
}

fn fmt8(x: float) -> string {
    to_string(to_float(to_int(x * 100000000.0)) / 100000000.0)
}

fn repeat_str(ch: string, n: int) -> string {
    let mut r = ""
    let mut i = 0
    while i < n {
        r = r + ch
        i = i + 1
    }
    r
}

// ── prime factorization → parallel arrays ──

fn is_prime(n: int) -> bool {
    if n < 2 { return false }
    if n < 4 { return true }
    if n % 2 == 0 || n % 3 == 0 { return false }
    let mut i = 5
    while i * i <= n {
        if n % i == 0 || n % (i + 2) == 0 { return false }
        i = i + 6
    }
    true
}

// Returns [primes_array, exponents_array]
fn factorint(n: int) -> list {
    let mut primes = []
    let mut exps = []
    if n <= 1 { return [primes, exps] }
    let mut x = n
    let mut d = 2
    while d * d <= x {
        if x % d == 0 {
            let mut e = 0
            while x % d == 0 {
                e = e + 1
                x = x / d
            }
            primes = primes + [d]
            exps = exps + [e]
        }
        d = d + 1
    }
    if x > 1 {
        primes = primes + [x]
        exps = exps + [1]
    }
    [primes, exps]
}

// ── arithmetic derivative ──
// n' = n * sum(a_i / p_i)  (using integer arithmetic to stay exact)
fn arith_deriv(n: int) -> int {
    if n < 0 { return -arith_deriv(-n) }
    if n <= 1 { return 0 }
    let f = factorint(n)
    let primes = f[0]
    let exps = f[1]
    // n' = sum( a_i * n / p_i )  — exact integer since p_i divides n
    let mut result = 0
    let mut i = 0
    while i < len(primes) {
        result = result + exps[i] * (n / primes[i])
        i = i + 1
    }
    result
}

fn my_sopfr(n: int) -> int {
    if n <= 1 { return 0 }
    let f = factorint(n)
    let primes = f[0]
    let exps = f[1]
    let mut s = 0
    let mut i = 0
    while i < len(primes) {
        s = s + primes[i] * exps[i]
        i = i + 1
    }
    s
}

fn is_squarefree(n: int) -> bool {
    if n <= 1 { return n == 1 }
    let f = factorint(n)
    let exps = f[1]
    let mut i = 0
    while i < len(exps) {
        if exps[i] > 1 { return false }
        i = i + 1
    }
    true
}

fn num_prime_factors(n: int) -> int {
    if n <= 1 { return 0 }
    let f = factorint(n)
    len(f[0])
}

// log_derivative as (numerator, denominator) pair — fraction a/b
// ld(n) = sum(a_i / p_i), returned as reduced fraction
fn gcd_fn(a: int, b: int) -> int {
    let mut x = abs(a)
    let mut y = abs(b)
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    x
}

// Returns [numerator, denominator] of log derivative n'/n
fn log_deriv(n: int) -> list {
    if n <= 1 { return [0, 1] }
    let f = factorint(n)
    let primes = f[0]
    let exps = f[1]
    // sum a_i/p_i  as fraction
    let mut num = 0
    let mut den = 1
    let mut i = 0
    while i < len(primes) {
        // num/den + exps[i]/primes[i] = (num*primes[i] + exps[i]*den) / (den*primes[i])
        num = num * primes[i] + exps[i] * den
        den = den * primes[i]
        let g = gcd_fn(abs(num), abs(den))
        if g > 1 {
            num = num / g
            den = den / g
        }
        i = i + 1
    }
    [num, den]
}

fn frac_str(nd: list) -> string {
    to_string(nd[0]) + "/" + to_string(nd[1])
}

fn frac_eq(a: list, b: list) -> bool {
    a[0] * b[1] == b[0] * a[1]
}

fn frac_float(nd: list) -> float {
    to_float(nd[0]) / to_float(nd[1])
}

