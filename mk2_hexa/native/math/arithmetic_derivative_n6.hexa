println("")
println(repeat_str("=", 70))
println("SUMMARY: ARITHMETIC DERIVATIVE CHARACTERIZATIONS OF 6")
println(repeat_str("=", 70))
println("")
println("  1. n' = n-1:  UNIQUE solution n=6 in [1,500]")
println("     (equivalently: sopfr(n)=n-1 for semiprimes)")
println("")
println("  2. ld(n) = n'/n = (n-1)/n:  UNIQUE solution n=6 in [1,500]")
println("     At n=6: ld(6) = 1/2 + 1/3 = 5/6 = Compass upper bound")
println("")
println("  3. For even perfect numbers 2^{p-1}*M_p:")
println("     ld = (p-1)/2 + 1/M_p = (n-1)/n  ONLY at p=2 (n=6)")
println("     Grows too fast for p>=3.")
println("")
println("  4. Derivative chain: 6 -> 5 -> 1 -> 0  (length 3)")
println("     Shortest chain for any composite > 4.")
println("")
println("  5. n' + phi(n)' = n:  holds at n=6  (5 + 1 = 6)")
println("     [Check other solutions above]")
println("")
println("  6. Connection web at n=6:")
println("     n' = 5 = sopfr(6) = sigma(6)/tau(6) + 2 ...")
println("     ld(6) = 5/6 = 1 - 1/6 = Compass upper bound")
println("     = H_3 - 1 = (1 + 1/2 + 1/3) - 1")
println("     = sigma_{-1}(6) - 1  (since sigma_{-1}(6) = 2 for perfect 6)")
println("     Wait: sigma_{-1}(6) = 1 + 1/2 + 1/3 + 1/6 = 2")
println("     ld(6) = 1/2 + 1/3 = 2 - 1 - 1/6 = 5/6")
println("     So ld(6) = sigma_{-1}(6) - 1 - 1/n!")
println("")

// Final verification of sigma_{-1} connection
// sigma_{-1}(6) = 1 + 1/2 + 1/3 + 1/6 = 2  (as fraction: 12/6 = 2)
// ld(6) = 1/2 + 1/3 = 5/6
// s_{-1} - 1 - 1/6 = 2 - 1 - 1/6 = 5/6
let s_m1 = [2, 1]
let ld6_val = [5, 6]
// s_m1 - 1 - 1/6 = 2 - 1 - 1/6 = 5/6
let rhs = [5, 6]
println("  sigma_{-1}(6) = 2/1 = 2.0")
println("  ld(6) = " + frac_str(ld6_val) + " = " + fmt8(frac_float(ld6_val)))
println("  sigma_{-1}(6) - 1 - 1/6 = " + frac_str(rhs) + " = ld(6)? " + to_string(frac_eq(rhs, ld6_val)))
println("  sigma_{-1}(6) - 1 = 1 = 1/2 + 1/3 + 1/6")
println("  ld(6) = sigma_{-1}(6) - 1 - 1/n = 2 - 1 - 1/6 = 5/6  YES")
println("")
println("  BEAUTIFUL IDENTITY:")
println("    ld(n) = sigma_{-1}(n) - 1 - 1/n  for n=6")
println("    5/6   = 2 - 1 - 1/6 = 5/6  YES")
println("")

// Check if this holds for other perfect numbers
println("  Does ld(n) = sigma_{-1}(n) - 1 - 1/n for other perfect numbers?")
pi = 0
while pi < len(perfects) {
    let pn = perfects[pi]
    // For perfect n, sigma_{-1}(n) = sigma(n)/n = 2n/n = 2 always
    // So RHS = 2 - 1 - 1/n = (n-1)/n
    let ld_val = log_deriv(pn)
    let rhs_frac = [pn - 1, pn]
    println("    n=" + to_string(pn) + ": ld=" + fmt6(frac_float(ld_val)) + ", sigma_{-1}-1-1/n=" + fmt6(to_float(pn - 1) / to_float(pn)) + ", equal=" + to_string(frac_eq(ld_val, rhs_frac)))
    pi = pi + 1
}

println("")
println("  FOR PERFECT n: sigma_{-1}(n) = 2 always.")
println("  So the identity ld(n) = sigma_{-1}(n) - 1 - 1/n")
println("  becomes ld(n) = 2 - 1 - 1/n = (n-1)/n")
println("  Which is exactly 'n' = n-1'!")
println("  This holds ONLY at n=6 among perfect numbers (verified above).")
