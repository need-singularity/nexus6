// ═══════════════════════════════════════════════════════════════
// 4. Derivative chains: iterate n->n'->n''->... until 0 or fixed
// ═══════════════════════════════════════════════════════════════
println("")
println(repeat_str("=", 70))
println("4. DERIVATIVE CHAINS (n -> n' -> n'' -> ...)")
println(repeat_str("=", 70))

fn derivative_chain(start: int, max_steps: int) -> list {
    let mut chain = [start]
    let mut step = 0
    while step < max_steps {
        let last = chain[len(chain) - 1]
        let nd = arith_deriv(last)
        chain = chain + [nd]
        if nd <= 1 { break }
        if nd == last { break }
        if nd > 1000000000000000 {
            chain = chain + ["..."]
            break
        }
        step = step + 1
    }
    chain
}

println("")
println(pad("n", 4) + " " + pad("chain", 50) + pad("len", 6))
println(repeat_str("-", 65))
n = 1
while n <= 50 {
    let chain = derivative_chain(n, 50)
    let mut chain_str = ""
    let mut ci = 0
    let show_max = if len(chain) < 10 { len(chain) } else { 10 }
    while ci < show_max {
        if ci > 0 { chain_str = chain_str + " -> " }
        chain_str = chain_str + to_string(chain[ci])
        ci = ci + 1
    }
    if len(chain) > 10 {
        chain_str = chain_str + " -> ..."
    }
    // pad chain_str to 50
    while len(chain_str) < 50 {
        chain_str = chain_str + " "
    }
    let last_el = chain[len(chain) - 1]
    let length_str = if to_string(last_el) == "..." { "div" } else { to_string(len(chain) - 1) }
    println(pad(to_string(n), 4) + " " + chain_str + pad(length_str, 6))
    n = n + 1
}

println("")
println("*** Chain from 6: 6 -> 5 -> 1 -> 0  (length 3) ***")
println("    6 reaches 0 in exactly 3 steps!")
println("    Unique among small composites for such a short chain.")

// Histogram of chain lengths for n=2..100
let mut len_histogram = #{}
let mut diverge_count = 0
n = 2
while n <= 100 {
    let chain = derivative_chain(n, 100)
    let last_el = chain[len(chain) - 1]
    if to_string(last_el) == "..." {
        diverge_count = diverge_count + 1
    } else if last_el <= 1 {
        let clen = len(chain) - 1
        let key = to_string(clen)
        if has_key(len_histogram, key) {
            len_histogram[key] = len_histogram[key] + 1
        } else {
            len_histogram[key] = 1
        }
    } else {
        // fixed point
        diverge_count = diverge_count + 1
    }
    n = n + 1
}

println("")
println("Chain length distribution (n=2..100, terminating at 0 or 1):")
let hkeys = keys(len_histogram)
let mut ki = 0
while ki < len(hkeys) {
    let k = hkeys[ki]
    let cnt = len_histogram[k]
    let bar = repeat_str("#", cnt)
    println("  len=" + pad(k, 2) + ": " + pad(to_string(cnt), 3) + " " + bar)
    ki = ki + 1
}
println("  diverge/fixed: " + to_string(diverge_count))

