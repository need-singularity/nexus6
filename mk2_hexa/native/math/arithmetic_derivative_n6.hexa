// ═══════════════════════════════════════════════════════════════
// 6. Arithmetic logarithmic derivative ld(n) = n'/n
// ═══════════════════════════════════════════════════════════════
println("")
println(repeat_str("=", 70))
println("6. ARITHMETIC LOGARITHMIC DERIVATIVE ld(n) = n'/n")
println(repeat_str("=", 70))

println("")
println(pad("n", 4) + pad("n_prime", 9) + pad("ld(n)", 13) + pad("decimal", 11) + pad("(n-1)/n", 11) + pad("match", 7))
println(repeat_str("-", 60))

n = 2
while n <= 30 {
    let nd = arith_deriv(n)
    let ld = log_deriv(n)
    let nm1_n = [n - 1, n]
    let gn = gcd_fn(abs(n - 1), abs(n))
    let nm1_reduced = [(n - 1) / gn, n / gn]
    let match_ld = frac_eq(ld, nm1_n)
    let match_str = if match_ld { "YES" } else { "" }
    println(pad(to_string(n), 4) + pad(to_string(nd), 9) + pad(frac_str(ld), 13) + pad(fmt6(frac_float(ld)), 11) + pad(frac_str(nm1_reduced), 11) + pad(match_str, 7))
    n = n + 1
}

println("")
println("*** ld(6) = 5/6 = (6-1)/6 = Compass upper bound! ***")

// Check: for which n does ld(n) = (n-1)/n?
println("")
println("Searching ld(n) = (n-1)/n for n=2..500:")
let mut ld_solutions = []
n = 2
while n <= 500 {
    let ld = log_deriv(n)
    let nm1_n = [n - 1, n]
    if frac_eq(ld, nm1_n) {
        ld_solutions = ld_solutions + [n]
        if n <= 100 || len(ld_solutions) <= 20 {
            println("  n=" + to_string(n) + ": ld=" + frac_str(ld) + " = (n-1)/n")
        }
    }
    n = n + 1
}

println("")
println("Total solutions: " + to_string(len(ld_solutions)))
println("Solutions: " + to_string(ld_solutions))
if ld_solutions == [6] {
    println("")
    println("*** ld(n) = (n-1)/n has UNIQUE solution n=6! ***")
}

// Perfect numbers
println("")
println("--- Logarithmic derivatives of perfect numbers ---")
let perfects = [6, 28, 496]
let mut pi = 0
while pi < len(perfects) {
    let pn = perfects[pi]
    let ld = log_deriv(pn)
    let nm1 = [pn - 1, pn]
    let nd = arith_deriv(pn)
    let f = factorint(pn)
    println("  ld(" + to_string(pn) + ") = " + frac_str(ld) + " = " + fmt8(frac_float(ld)))
    let gp = gcd_fn(abs(pn - 1), abs(pn))
    println("    (n-1)/n = " + to_string((pn - 1) / gp) + "/" + to_string(pn / gp) + " = " + fmt8(to_float(pn - 1) / to_float(pn)))
    println("    n' = " + to_string(nd) + ", n-1 = " + to_string(pn - 1) + ", n'=n-1: " + to_string(nd == pn - 1))
    println("    factorization: (" + to_string(f[0]) + "," + to_string(f[1]) + ")")
    println("")
    pi = pi + 1
}

// General formula for even perfect numbers
println("--- General formula for even perfect 2^{p-1} * M_p ---")
println("  ld = (p-1)/2 + 1/M_p")
println("")
// Mersenne primes: (p, M_p)
let mersenne_p = [2, 3, 5, 7, 13]
let mersenne_mp = [3, 7, 31, 127, 8191]
let mut msi = 0
while msi < len(mersenne_p) {
    let p = mersenne_p[msi]
    let mp = mersenne_mp[msi]
    // pn = 2^(p-1) * mp
    let mut pow2 = 1
    let mut pi2 = 0
    while pi2 < p - 1 {
        pow2 = pow2 * 2
        pi2 = pi2 + 1
    }
    let pn = pow2 * mp
    // ld_formula = (p-1)/2 + 1/mp as fraction
    // (p-1)*mp + 2 / (2*mp)
    let lf_num = (p - 1) * mp + 2
    let lf_den = 2 * mp
    let lf_g = gcd_fn(abs(lf_num), abs(lf_den))
    let lf = [lf_num / lf_g, lf_den / lf_g]
    let ld_actual = log_deriv(pn)
    let nm1_n = [pn - 1, pn]

    let pm1_2_g = gcd_fn(abs(p - 1), 2)
    println("  p=" + to_string(p) + ", M_p=" + to_string(mp) + ", n=" + to_string(pn) + ":")
    println("    ld = (p-1)/2 + 1/M_p = " + to_string((p - 1) / pm1_2_g) + "/" + to_string(2 / pm1_2_g) + " + 1/" + to_string(mp) + " = " + frac_str(lf) + " = " + fmt8(frac_float(lf)))
    let nm_g = gcd_fn(abs(pn - 1), abs(pn))
    println("    (n-1)/n = " + to_string((pn - 1) / nm_g) + "/" + to_string(pn / nm_g) + " = " + fmt8(to_float(pn - 1) / to_float(pn)))
    println("    ld = (n-1)/n? " + to_string(frac_eq(lf, nm1_n)))
    if p == 2 {
        println("    *** At p=2: ld = 1/2 + 1/3 = 5/6 = (n-1)/n. UNIQUE! ***")
    }
    println("")
    msi = msi + 1
}

// Why only p=2 works
println("--- Why ld = (n-1)/n only at p=2 (n=6) ---")
println("  Need: (p-1)/2 + 1/M_p = (2^{p-1}*M_p - 1) / (2^{p-1}*M_p)")
println("  Let N = 2^{p-1}*M_p. Then:")
println("  (p-1)/2 + 1/M_p = (N-1)/N")
println("  N*[(p-1)/2 + 1/M_p] = N-1")
println("  N*(p-1)/2 + N/M_p = N-1")
println("  2^{p-1}*M_p*(p-1)/2 + 2^{p-1} = 2^{p-1}*M_p - 1")
println("  2^{p-2}*M_p*(p-1) + 2^{p-1} = 2^{p-1}*M_p - 1")
println("")
println("  At p=2: 2^0 * 3 * 1 + 2^1 = 2^1 * 3 - 1")
println("          3 + 2 = 6 - 1 = 5  YES")
println("  At p=3: 2^1 * 7 * 2 + 2^2 = 2^2 * 7 - 1")
println("          28 + 4 = 28 - 1?  32 != 27  NO")
println("  Grows too fast on the left side for p>=3.")

