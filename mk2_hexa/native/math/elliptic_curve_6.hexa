// Ported from tecs-l/math/elliptic_curve_6.py
// 6 as congruent number, elliptic curve y² = x³ − 36x, rational points.

// @pure
fn isqrt(n: int) -> int {
    if n < 2 { return n }
    let mut x = n
    let mut y = (x + 1) / 2
    while y < x {
        x = y
        y = (x + n / x) / 2
    }
    x
}

// @pure
fn is_square(n: int) -> bool {
    if n < 0 { return false }
    let r = isqrt(n)
    r * r == n
}

println("══════════════════════════════════════════════════════════════════════")
println("  ELLIPTIC CURVES CONNECTED TO n=6")
println("══════════════════════════════════════════════════════════════════════")

// 1. 6 is a congruent number — right triangle (3,4,5) area = 6
let a = 3
let b = 4
let c = 5
assert a * a + b * b == c * c
assert a * b == 12     // 2*Area = 12 → Area = 6
println("")
println("## 1. 6 IS a congruent number (triangle 3-4-5, area = 6)")
println("  3² + 4² = " + to_string(a*a + b*b) + " = 5²")
println("  area = 3·4/2 = 6  ✓")

// Arithmetic function connections: sides match σ/τ, τ, sopfr of 6
assert sigma(6) / tau(6) == a       // 12/4 = 3
assert tau(6) == b                  // τ(6)=4
assert 2 + 3 == c                   // sopfr(6) = 5
println("  ★ σ/τ=" + to_string(sigma(6)/tau(6)) + " (=a), τ=" + to_string(tau(6)) + " (=b), sopfr=5 (=c)")

// 2. Elliptic curve E: y² = x³ − 36x. Find integer points x in [-50, 50]
println("")
println("## 2. E: y² = x³ − 36x   (integer x ∈ [−50, 50])")
let mut points_count = 0
let mut x = -50
while x <= 50 {
    let rhs = x * x * x - 36 * x
    if rhs >= 0 && is_square(rhs) {
        let y = isqrt(rhs)
        points_count = points_count + 1
        if y != 0 { points_count = points_count + 1 }
        if y == 0 {
            println("  (" + to_string(x) + ", 0) — 2-torsion")
        } else {
            println("  (" + to_string(x) + ", ±" + to_string(y) + ")")
        }
    }
    x = x + 1
}
println("")
println("  Integer points found (with signs): " + to_string(points_count))

// 2-torsion at x=-6, 0, 6 (since x³-36x = x(x-6)(x+6))
assert (-6) * (-6) * (-6) - 36 * (-6) == 0
assert 0 * 0 * 0 - 36 * 0 == 0
assert 6 * 6 * 6 - 36 * 6 == 0
println("  2-torsion: (−6,0), (0,0), (6,0)  → E[2] = Z/2 × Z/2 ✓")

// 3. Discriminant Δ = 4·(−36)³ = −4·6^6
let disc = 4 * (-36) * (-36) * (-36)
// Equivalent to -4*36^3 = -186624
println("")
println("## 3. Discriminant Δ")
println("  Δ = 4·(−36)³ = " + to_string(disc))
// 6^6 = 46656; -4 * 46656 = -186624
assert disc == -186624

// conductor / Mordell-Weil rank note: rank(E) = 1 (known)
println("")
println("## 4. Rank of E (known fact)")
println("  rank(E(ℚ)) = 1 — proved via BSD for small discriminant")
println("  E[2] ⊕ Z ≅ (Z/2)² ⊕ Z")

println("")
println("SUMMARY: 6 is congruent number; E: y²=x³−36x has E[2]=(Z/2)², rank 1.")
