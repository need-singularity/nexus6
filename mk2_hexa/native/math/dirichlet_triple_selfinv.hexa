// mk2_hexa/native/dirichlet_triple_selfinv.hexa
// 포팅 원본: tecs-l/math/dirichlet_triple_selfinv.py (272 LOC, core 앞 180줄)
//
// 정리: σ^{-1}(n)=σ(n), φ^{-1}(n)=φ(n), τ^{-1}(n)=τ(n) 동시 성립 ⇔ squarefree & ω(n) even
// 이유: multiplicative f의 Dirichlet 역 f^{-1}는 squarefree n에서 μ(n)·f(n)
//       따라서 μ(n) = 1 (ω even) ⇒ f^{-1}(n) = f(n)
//
// AI-native: @pure divisors, ω, μ, is_squarefree; Dirichlet inverse는 sieve

let MAX_N = 200

// @pure
fn divisors(n: int) -> list {
    let mut d = []
    let mut i = 1
    while i * i <= n {
        if n % i == 0 {
            d = d + [i]
            if i * i != n { d = d + [n / i] }
        }
        i = i + 1
    }
    d
}

// @pure
fn omega_n(n: int) -> int {
    let mut m = n
    let mut c = 0
    let mut p = 2
    while p * p <= m {
        if m % p == 0 {
            c = c + 1
            while m % p == 0 { m = m / p }
        }
        p = p + 1
    }
    if m > 1 { c = c + 1 }
    c
}

// @pure
fn is_squarefree(n: int) -> bool {
    let mut d = 2
    while d * d <= n {
        if n % (d * d) == 0 { return false }
        d = d + 1
    }
    true
}

// @pure — Möbius μ(n)
fn mobius(n: int) -> int {
    if n == 1 { return 1 }
    let mut m = n
    let mut nf = 0
    let mut p = 2
    while p * p <= m {
        if m % p == 0 {
            nf = nf + 1
            m = m / p
            if m % p == 0 { return 0 }
        }
        p = p + 1
    }
    if m > 1 { nf = nf + 1 }
    if nf % 2 == 0 { 1 } else { 0 - 1 }
}

// Dirichlet 역: f^{-1}(1)=1,  f^{-1}(n) = − Σ_{d<n, d|n} f(n/d) · f^{-1}(d)
// f를 tag로 구분: "sigma" / "phi" / "tau"
fn f_val(tag: string, n: int) -> int {
    if tag == "sigma" { return sigma(n) }
    if tag == "phi"   { return phi(n) }
    tau(n)
}

fn dirichlet_inverse(tag: string, N: int) -> list {
    let mut inv = []
    // 초기화: inv[0]=0, inv[1]=1, 나머지 0
    let mut z = 0
    while z <= N {
        inv = inv + [if z == 1 { 1 } else { 0 }]
        z = z + 1
    }
    let mut n = 2
    while n <= N {
        let ds = divisors(n)
        let mut s = 0
        let mut i = 0
        while i < len(ds) {
            let d = ds[i]
            if d < n { s = s + f_val(tag, n / d) * inv[d] }
            i = i + 1
        }
        inv[n] = 0 - s
        n = n + 1
    }
    inv
}

println("══════════════════════════════════════════════════════════════════════")
println("TRIPLE SELF-INVERSE: f^{-1}(n) = f(n) for f = σ, φ, τ  (hexa port)")
println("══════════════════════════════════════════════════════════════════════")
println("")
println("[Sweep] Computing Dirichlet inverses for σ/φ/τ up to N=" + to_string(MAX_N) + "...")

let sigma_inv = dirichlet_inverse("sigma", MAX_N)
let phi_inv = dirichlet_inverse("phi", MAX_N)
let tau_inv = dirichlet_inverse("tau", MAX_N)

// Triple self-inverse 집합
let mut triple = []
let mut n = 1
while n <= MAX_N {
    if sigma_inv[n] == sigma(n) && phi_inv[n] == phi(n) && tau_inv[n] == tau(n) {
        triple = triple + [n]
    }
    n = n + 1
}

// Squarefree + even ω 집합
let mut sqfree_even = []
let mut m = 1
while m <= MAX_N {
    if is_squarefree(m) && omega_n(m) % 2 == 0 {
        sqfree_even = sqfree_even + [m]
    }
    m = m + 1
}

println("")
println("n where ALL THREE f^{-1}(n) = f(n), n=1.." + to_string(MAX_N) + ":")
println("  Count: " + to_string(len(triple)))
println("  First 30: " + to_string(triple))
println("")
println("Squarefree n with even ω(n), n=1.." + to_string(MAX_N) + ":")
println("  Count: " + to_string(len(sqfree_even)))
println("  First 30: " + to_string(sqfree_even))

let mut match_all = len(triple) == len(sqfree_even)
if match_all {
    let mut k = 0
    while k < len(triple) {
        if triple[k] != sqfree_even[k] { match_all = false }
        k = k + 1
    }
}
println("")
println("Triple self-inverse == {squarefree ∧ ω even}? " + (if match_all { "YES ✓" } else { "NO" }))

// ─── 이론: f multiplicative ⇒ f^{-1}(p) = -f(p),  squarefree n에서 f^{-1}(n) = μ(n)·f(n) ───
println("")
println("══════════════════════════════════════════════════════════════════════")
println("THEOREM CHECK: for multiplicative f, f^{-1}(n) = μ(n)·f(n) on squarefree n")
println("══════════════════════════════════════════════════════════════════════")

fn check_mu_identity(tag: string, inv: list, upto: int) -> bool {
    let mut ok = true
    let mut n = 1
    while n <= upto {
        if is_squarefree(n) {
            let lhs = inv[n]
            let rhs = mobius(n) * f_val(tag, n)
            if lhs != rhs { ok = false }
        }
        n = n + 1
    }
    ok
}

let sig_ok = check_mu_identity("sigma", sigma_inv, MAX_N)
let phi_ok = check_mu_identity("phi", phi_inv, MAX_N)
let tau_ok = check_mu_identity("tau", tau_inv, MAX_N)
println("  σ^{-1}(n) = μ(n)·σ(n)  on squarefree n ≤ " + to_string(MAX_N) + ": " + (if sig_ok { "YES" } else { "NO" }))
println("  φ^{-1}(n) = μ(n)·φ(n)  on squarefree n ≤ " + to_string(MAX_N) + ": " + (if phi_ok { "YES" } else { "NO" }))
println("  τ^{-1}(n) = μ(n)·τ(n)  on squarefree n ≤ " + to_string(MAX_N) + ": " + (if tau_ok { "YES" } else { "NO" }))

// ─── n=6의 특수성: master identity σφ = nτ ───
println("")
println("══════════════════════════════════════════════════════════════════════")
println("WHAT MAKES n=6 SPECIAL?")
println("══════════════════════════════════════════════════════════════════════")
println("")
println("  Self-inverse는 ALL squarefree even-ω에서 성립 (6, 10, 14, 15, 21, ...)")
println("  UNIQUE identity for n=6: σ(n)·φ(n) = n·τ(n)  (master)")

let mut combined = []
let mut q = 1
while q <= MAX_N {
    let s_ok = sigma_inv[q] == sigma(q)
    let p_ok = phi_inv[q] == phi(q)
    let t_ok = tau_inv[q] == tau(q)
    let master = sigma(q) * phi(q) == q * tau(q)
    if s_ok && p_ok && t_ok && master { combined = combined + [q] }
    q = q + 1
}
println("")
println("  n with BOTH self-inverse AND master identity (n ≤ " + to_string(MAX_N) + "): " + to_string(combined))

// Perfect numbers in self-inverse set
let mut perfect_self = []
let mut r = 0
while r < len(triple) {
    let nn = triple[r]
    if sigma(nn) == 2 * nn { perfect_self = perfect_self + [nn] }
    r = r + 1
}
println("  Perfect numbers ∩ self-inverse: " + to_string(perfect_self))
println("")
println("  ∴ n=6 is the UNIQUE perfect number in the triple self-inverse set,")
println("     AND the UNIQUE n satisfying master identity σφ=nτ.")
