// Ported from tecs-l/math/ppp_explore.py
// Explores PPP (product-of-primes-perfect): n = σ(n) - n type conditions
// and variants of the master identity σφ = nτ.

println("══════════════════════════════════════════════════════════════════════")
println("  PPP_EXPLORE — perfect/abundant/deficient variants")
println("══════════════════════════════════════════════════════════════════════")

// Classification by σ(n) / n ratio
println("")
println("## Classification n in [1, 30]")
println("    n  | σ(n) | abundance (σ-2n) | type")
println("  -----+------+------------------+----------")
let mut n = 1
while n <= 30 {
    let s = sigma(n)
    let ab = s - 2 * n
    let t = if ab < 0 { "deficient" } else if ab == 0 { "PERFECT ★" } else { "abundant" }
    println("   " + to_string(n) + "\t| " + to_string(s) + "\t| " + to_string(ab) + "\t\t| " + t)
    n = n + 1
}

// Perfect numbers in [1, 10000]
println("")
println("## Perfect numbers in [1, 10000]")
let mut perfs = []
let mut k = 1
while k <= 10000 {
    if sigma(k) == 2 * k { perfs = perfs + [k] }
    k = k + 1
}
println("  " + to_string(perfs))
assert len(perfs) == 4  // 6, 28, 496, 8128
println("  count = 4 (first 4 Mersenne perfects)")

// PPP master: σφ=nτ solutions in [1, 1000]
println("")
println("## σ(n)·φ(n) = n·τ(n) solutions in [1, 1000]")
let mut master_sols = []
let mut m = 1
while m <= 1000 {
    if sigma(m) * phi(m) == m * tau(m) { master_sols = master_sols + [m] }
    m = m + 1
}
println("  " + to_string(master_sols))
println("  → only {1, 6} ★★★")

// Rational R(n) = σφ/(nτ) — how many land near 1?
println("")
println("## R(n) = σφ/(nτ) near integer values in [1,20]")
println("    n  | σφ     | nτ    | R num/den")
println("  -----+--------+-------+-----------")
let mut q = 1
while q <= 20 {
    let sp = sigma(q) * phi(q)
    let nt = q * tau(q)
    println("   " + to_string(q) + "\t| " + to_string(sp) + "\t| " + to_string(nt) + "\t| " + to_string(sp) + "/" + to_string(nt))
    q = q + 1
}

// Abundance distribution: count of deficient/perfect/abundant in [1,1000]
let mut def_c = 0
let mut per_c = 0
let mut abu_c = 0
let mut r = 1
while r <= 1000 {
    let sr = sigma(r)
    if sr < 2 * r { def_c = def_c + 1 }
    else if sr == 2 * r { per_c = per_c + 1 }
    else { abu_c = abu_c + 1 }
    r = r + 1
}
println("")
println("## Abundance census [1, 1000]")
println("  deficient: " + to_string(def_c))
println("  perfect  : " + to_string(per_c))
println("  abundant : " + to_string(abu_c))

println("")
println("SUMMARY: master identity σφ=nτ uniquely picks {1, 6}. n=6 perfect.")
