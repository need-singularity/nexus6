// 포팅 원본: tecs-l/math/game_theory_n6_deep.py (352 LOC)
// Deep analysis: Game Theory n=6 — Banzhaf, Shapley, Nash, XOR, Wythoff
// hexa-native port: σ/φ/τ/sopfr builtins, no semicolons

let PI = 3.141592653589793
let sig_6 = sigma(6)
let tau_6 = tau(6)
let phi_6 = phi(6)
let sopf_6 = sopfr(6)

fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0)) / 10000.0
    to_string(r)
}
fn fmt6(x: float) -> string {
    let r = to_float(to_int(x * 1000000.0)) / 1000000.0
    to_string(r)
}
fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

fn fact(k: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= k {
        r = r * i
        i = i + 1
    }
    r
}

// integer XOR (bit-by-bit, hexa ^ parse workaround)
fn ixor(a: int, b: int) -> int {
    let mut result = 0
    let mut bit = 1
    let mut aa = a
    let mut bb = b
    while aa > 0 || bb > 0 {
        let ar = aa % 2
        let br = bb % 2
        if ar != br { result = result + bit }
        bit = bit * 2
        aa = aa / 2
        bb = bb / 2
    }
    result
}

// divisors sorted ascending
fn divisors(n: int) -> list {
    let mut d = []
    let mut i = 1
    while i * i <= n {
        if n % i == 0 {
            d = d + [i]
            if i * i != n { d = d + [n / i] }
        }
        i = i + 1
    }
    let mut a = d
    let sz = len(a)
    let mut p = 0
    while p < sz - 1 {
        let mut mn = p
        let mut q = p + 1
        while q < sz {
            if a[q] < a[mn] { mn = q }
            q = q + 1
        }
        if mn != p {
            let t = a[p]
            a[p] = a[mn]
            a[mn] = t
        }
        p = p + 1
    }
    a
}

// sum of a list
fn list_sum(arr: list) -> int {
    let mut s = 0
    let mut i = 0
    while i < len(arr) {
        s = s + arr[i]
        i = i + 1
    }
    s
}

// mex (minimum excludant) of a map used as set (string keys)
fn mex_of(s: map) -> int {
    let mut m = 0
    while has_key(s, to_string(m)) {
        m = m + 1
    }
    m
}

fn min_i(a: int, b: int) -> int { if a < b { a } else { b } }
fn max_i(a: int, b: int) -> int { if a > b { a } else { b } }

// ──────────────────────────────────────────────
println("══════════════════════════════════════════════════════════════════════")
println("DEEP ANALYSIS: Game Theory n=6 Findings  (hexa port)")
println("══════════════════════════════════════════════════════════════════════")

let divs_6 = [1, 2, 3, 6]

// ══ FINDING 1: Banzhaf [12; 1,2,3,6] -> equal power = 1/tau ══
println("")
println("══ FINDING 1: Banzhaf symmetry ══")
println("Game [12; 1,2,3,6]: all players Banzhaf = 1/4 = 1/tau(6)")
println("")
println("WHY? At quota = total_weight = sigma(6) = 12:")
println("Only the full coalition {1,2,3,6} achieves weight >= quota")
println("So each player is a swing voter in exactly 1 winning coalition")
println("")
println("Grand coalition weight = 12 = quota = sigma(6)")

let mut fi = 0
while fi < 4 {
    let w = divs_6[fi]
    let remaining = list_sum(divs_6) - w
    let label = if remaining < 12 { "< quota -> CRITICAL" } else { ">= quota -> not critical" }
    let msg = "  Remove player " + to_string(fi + 1) + " (w=" + to_string(w) + "): remaining = " + to_string(remaining) + " " + label
    println(msg)
    fi = fi + 1
}

println("")
println("Result: Banzhaf(player_i) = 1 swing each")
println("  Normalized: 1/4 = 1/tau(6) for ALL players")
println("  Grade: GREEN (exact, forced by structure)")

// ── Generalization to n=28 ──
println("")
println("--- Generalization to n=28 ---")
let divs_28 = [1, 2, 4, 7, 14, 28]
let sigma_28 = sigma(28)
let tau_28 = tau(28)
println("n=28: sigma=" + to_string(sigma_28) + ", tau=" + to_string(tau_28))

let mut gi = 0
while gi < len(divs_28) {
    let w28 = divs_28[gi]
    let rem28 = sigma_28 - w28
    let lab28 = if rem28 < sigma_28 { "< quota -> CRITICAL" } else { ">= quota" }
    let msg28 = "  Remove (w=" + to_string(w28) + "): remaining=" + to_string(rem28) + " " + lab28
    println(msg28)
    gi = gi + 1
}
println("  Same result: Banzhaf = 1/tau(28) = 1/" + to_string(tau_28) + " for all players")
println("  Generalizes to ANY perfect number!")

// ══ FINDING 2: Shapley at quota = sigma(6) ══
println("")
println("══ FINDING 2: Shapley at quota = sigma(6) ══")
println("Game [12; 1,2,3,6]: all players Shapley = 1/4 = 1/tau(6)")
println("Forced: at quota = total weight, last player always pivotal")
println("Shapley = (tau-1)!/tau! = 1/tau = 1/" + to_string(tau_6))

// ══ FINDING 3: Shapley at quota = n = 6 ══
println("")
println("══ FINDING 3: Shapley at quota = n = 6 ══")
println("Game [6; 1,2,3,6]: Shapley values")
println("  Shapley(w=6) = 3/4")
println("  Shapley(w=1) = Shapley(w=2) = Shapley(w=3) = 1/12")
println("  Ratio: player w=6 has 9x more power than w=1")

// Brute-force Shapley for 4 players via flat permutation list
let perms_flat = [0,1,2,3, 0,1,3,2, 0,2,1,3, 0,2,3,1, 0,3,1,2, 0,3,2,1, 1,0,2,3, 1,0,3,2, 1,2,0,3, 1,2,3,0, 1,3,0,2, 1,3,2,0, 2,0,1,3, 2,0,3,1, 2,1,0,3, 2,1,3,0, 2,3,0,1, 2,3,1,0, 3,0,1,2, 3,0,2,1, 3,1,0,2, 3,1,2,0, 3,2,0,1, 3,2,1,0]

// --- Shapley at quota=6 ---
println("")
println("--- Shapley brute-force at quota=6 ---")
let quota6 = 6
let mut sh6 = [0, 0, 0, 0]
let mut pk6 = 0
while pk6 < 24 {
    let base = pk6 * 4
    let mut cumul = 0
    let mut kk = 0
    while kk < 4 {
        let player = perms_flat[base + kk]
        let prev = cumul
        cumul = cumul + divs_6[player]
        if prev < quota6 && cumul >= quota6 {
            sh6[player] = sh6[player] + 1
            kk = 4
        }
        kk = kk + 1
    }
    pk6 = pk6 + 1
}
let n_perms = fact(4)
let mut pi6 = 0
while pi6 < 4 {
    let v = to_float(sh6[pi6]) / to_float(n_perms)
    let line = "  d=" + to_string(divs_6[pi6]) + ": " + to_string(sh6[pi6]) + "/" + to_string(n_perms) + " = " + fmt6(v)
    println(line)
    pi6 = pi6 + 1
}
assert sh6[3] == 18
assert sh6[0] == 2
assert sh6[1] == 2
assert sh6[2] == 2
println("  Verified: Shapley(6)=18/24=3/4, others=2/24=1/12")

// --- Shapley at quota=7 ---
println("")
println("--- Shapley brute-force at quota=7 ---")
let quota7 = 7
let mut sh7 = [0, 0, 0, 0]
let mut pk7 = 0
while pk7 < 24 {
    let base7 = pk7 * 4
    let mut cumul7 = 0
    let mut kk7 = 0
    while kk7 < 4 {
        let player7 = perms_flat[base7 + kk7]
        let prev7 = cumul7
        cumul7 = cumul7 + divs_6[player7]
        if prev7 < quota7 && cumul7 >= quota7 {
            sh7[player7] = sh7[player7] + 1
            kk7 = 4
        }
        kk7 = kk7 + 1
    }
    pk7 = pk7 + 1
}
let mut pi7 = 0
while pi7 < 4 {
    let v7 = to_float(sh7[pi7]) / to_float(n_perms)
    let line7 = "  d=" + to_string(divs_6[pi7]) + ": " + to_string(sh7[pi7]) + "/" + to_string(n_perms) + " = " + fmt6(v7)
    println(line7)
    pi7 = pi7 + 1
}
assert sh7[3] == 18
assert sh7[0] == 2
println("  quotas 6 and 7 give identical Shapley values!")

// ══ FINDING 4: Nash equilibria connection ══
println("")
println("══ FINDING 4: Nash Equilibria ══")
println("At n=6:")
let sqrt_3pi = sqrt(3.0 * PI)
let st_ratio = to_float(sig_6) / to_float(tau_6)
println("  E[mixed NE] ~ sqrt(3*pi) = " + fmt6(sqrt_3pi))
println("  sigma(6)/tau(6) = " + fmt4(st_ratio))
let ne_err = abs_f(sqrt_3pi - st_ratio) / st_ratio * 100.0
println("  error: " + fmt4(ne_err) + "%")

// Check perfect numbers
println("")
println("--- Checking for other perfect numbers ---")
let pn_n = [6, 28, 496]
let pn_s = [12, 56, 992]
let pn_t = [4, 6, 10]
let mut pni = 0
while pni < 3 {
    let nn = pn_n[pni]
    let sig = pn_s[pni]
    let tt = pn_t[pni]
    let ne_f = sqrt(PI * to_float(nn) / 2.0)
    let ratio = to_float(sig) / to_float(tt)
    let diff_pct = abs_f(ne_f - ratio) / ratio * 100.0
    let pnline = "  n=" + to_string(nn) + ": sqrt(pi*" + to_string(nn) + "/2)=" + fmt4(ne_f) + ", sigma/tau=" + to_string(sig) + "/" + to_string(tt) + "=" + fmt4(ratio) + ", diff=" + fmt4(diff_pct) + "%"
    println(pnline)
    pni = pni + 1
}
println("  Near-match for n=6 only (coincidence)")

// ══ FINDING 5: XOR(divisors of 6) = 6 ══
println("")
println("══ FINDING 5: XOR(divisors) = n ══")

let mut xor_matches = []
let mut xn = 1
while xn <= 49 {
    let ds = divisors(xn)
    let mut xv = 0
    let mut di = 0
    while di < len(ds) {
        xv = ixor(xv, ds[di])
        di = di + 1
    }
    if xv == xn { xor_matches = xor_matches + [xn] }
    xn = xn + 1
}
println("Numbers where XOR(divisors) = n (1..49): " + to_string(xor_matches))

let mut has_6 = false
let mut xi = 0
while xi < len(xor_matches) {
    if xor_matches[xi] == 6 { has_6 = true }
    xi = xi + 1
}
println("  n=6 in matches? " + (if has_6 { "YES" } else { "NO" }))
assert has_6

// Perfect number XOR check
let perf_ns = [6, 28]
let perf_divs_all = [[1,2,3,6], [1,2,4,7,14,28]]
let mut pxi = 0
while pxi < 2 {
    let pds = perf_divs_all[pxi]
    let mut pxv = 0
    let mut pdj = 0
    while pdj < len(pds) {
        pxv = ixor(pxv, pds[pdj])
        pdj = pdj + 1
    }
    let pn = perf_ns[pxi]
    let eq_str = if pxv == pn { "= n" } else { "!= " + to_string(pn) }
    println("  Perfect n=" + to_string(pn) + ": XOR(divisors) = " + to_string(pxv) + " " + eq_str)
    pxi = pxi + 1
}

// ══ FINDING 6: Wythoff (2,3) analysis ══
println("")
println("══ FINDING 6: Wythoff (2,3) = (phi(6), sigma/tau(6)) ══")
println("  (2,3) is NOT a Wythoff P-position (Grundy = 5, winning)")
println("  Grundy(2,3) = 5 = sopfr(6)!")
println("  sopfr(6) = 2+3 = 5 (sum of prime factors)")
println("  phi(6)+sigma/tau = 2+3 = 5 = sopfr(6)")

// Compute Wythoff Grundy up to max_pos=10
// Store in a flat array: G[a * 11 + b] for 0 <= a <= b <= 10
let max_pos = 10
let grid_sz = (max_pos + 1) * (max_pos + 1)
let mut G = []
let mut gi2 = 0
while gi2 < grid_sz {
    G = G + [-1]
    gi2 = gi2 + 1
}

let mut total = 0
while total <= max_pos * 2 {
    let mut a = 0
    let a_limit = min_i(total + 1, max_pos + 1)
    while a < a_limit {
        let b = total - a
        if b <= max_pos && a <= b {
            let mut mex_set = #{}
            // Remove from a
            let mut k = 1
            while k <= a {
                let pa = min_i(a - k, b)
                let pb = max_i(a - k, b)
                if pa >= 0 && pb <= max_pos {
                    let idx = pa * (max_pos + 1) + pb
                    if G[idx] >= 0 { mex_set[to_string(G[idx])] = true }
                }
                k = k + 1
            }
            // Remove from b
            k = 1
            while k <= b {
                let pa2 = min_i(a, b - k)
                let pb2 = max_i(a, b - k)
                if pa2 >= 0 && pb2 <= max_pos {
                    let idx2 = pa2 * (max_pos + 1) + pb2
                    if G[idx2] >= 0 { mex_set[to_string(G[idx2])] = true }
                }
                k = k + 1
            }
            // Remove from both (diagonal)
            let diag_max = min_i(a, b)
            k = 1
            while k <= diag_max {
                let pa3 = min_i(a - k, b - k)
                let pb3 = max_i(a - k, b - k)
                if pa3 >= 0 && pb3 <= max_pos {
                    let idx3 = pa3 * (max_pos + 1) + pb3
                    if G[idx3] >= 0 { mex_set[to_string(G[idx3])] = true }
                }
                k = k + 1
            }
            let mval = mex_of(mex_set)
            G[a * (max_pos + 1) + b] = mval
        }
        a = a + 1
    }
    total = total + 1
}

// Check Grundy(2,3)
let g23 = G[2 * (max_pos + 1) + 3]
println("  Wythoff Grundy(2,3) = " + to_string(g23))
assert g23 == 5

// Find positions where Grundy(a,b) = a+b
println("")
println("Positions where Grundy(a,b) = a+b (up to 10):")
let mut sum_match_count = 0
let mut sa = 0
while sa <= max_pos {
    let mut sb = sa
    while sb <= max_pos {
        let gv = G[sa * (max_pos + 1) + sb]
        if gv == sa + sb && (sa + sb) > 0 {
            println("  (" + to_string(sa) + "," + to_string(sb) + "): Grundy=" + to_string(gv))
            sum_match_count = sum_match_count + 1
        }
        sb = sb + 1
    }
    sa = sa + 1
}
println("Total such positions: " + to_string(sum_match_count))
println("(2,3) is one: Grundy=5=sopfr(6)")

// ══ FINDING 7: Shapley n=28 at quota=28 ══
println("")
println("══ FINDING 7: Shapley for n=28 at quota=28 ══")
// n=28 has 6 players → 6!=720 permutations (feasible with reduced scope)
// Instead, use the structural argument: at quota=n, only player w=n
// alone can meet quota (28 >= 28), so Shapley(w=28) dominates.
// Without player 28, max weight = 1+2+4+7+14 = 28 = quota exactly.
// So subsets without 28 CAN also reach quota.
// Full enumeration of 720 perms is heavy for interpreter — use formula.
let tau_28b = tau(28)
println("  Game [28; 1,2,4,7,14,28]: tau=" + to_string(tau_28b))
println("  At quota=28: player w=28 alone meets quota")
println("  But 1+2+4+7+14 = 28 also meets quota")
println("  Smallest player Shapley ~ 1/(tau*(tau-1)) = 1/30")
let sh_small_28 = 1.0 / to_float(tau_28b * (tau_28b - 1))
println("  1/sigma(28) = " + fmt6(1.0 / to_float(sigma_28)) + "  vs  1/(tau*(tau-1)) = " + fmt6(sh_small_28))
println("  For n=6: sigma = tau*(tau-1) = 12 [UNIQUE]")
println("  For n=28: tau*(tau-1) = 30 != 56 = sigma")

