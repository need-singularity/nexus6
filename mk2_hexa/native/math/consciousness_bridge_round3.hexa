// ─── helpers ───
fn abs_i(x: int) -> int { if x < 0 { 0 - x } else { x } }

fn divisors(n: int) -> [int] {
    let mut ds = [1]
    let mut d = 2
    while d <= n {
        if n % d == 0 { ds = ds.push(d) }
        d = d + 1
    }
    ds
}

fn sigma_of(n: int) -> int {
    let ds = divisors(n)
    let mut s = 0
    let mut i = 0
    while i < len(ds) {
        s = s + ds[i]
        i = i + 1
    }
    s
}

fn factorial(n: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= n {
        r = r * i
        i = i + 1
    }
    r
}

fn gcd_pair(a: int, b: int) -> int {
    let mut x = a
    let mut y = b
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    x
}

fn lcm_pair(a: int, b: int) -> int {
    a / gcd_pair(a, b) * b
}

fn lcm_range(n: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= n {
        r = lcm_pair(r, i)
        i = i + 1
    }
    r
}

fn mobius(k: int) -> int {
    if k == 1 { return 1 }
    let mut t = k
    let mut p = 2
    let mut c = 0
    while p * p <= t {
        if t % p == 0 {
            c = c + 1
            t = t / p
        }
        if t % p == 0 { return 0 }
        p = p + 1
    }
    if t > 1 { c = c + 1 }
    if c % 2 == 0 { 1 } else { 0 - 1 }
}

fn pow_neg1(e: int) -> int {
    if e % 2 == 0 { 1 } else { 0 - 1 }
}

