// mk2_hexa/native/investigate_sigma_phi_tau.hexa
// 포팅 원본: tecs-l/math/investigate_sigma_phi_tau.py
// Goal: σ(n) + φ(n) + τ(n) = 3n 해 탐색 + 매개 케이스 증명
// Known solutions (n ≤ 1e6): {2, 4, 6, 90, 408, 5856}
// builtins 활용: sigma / phi / tau

fn pow_int(base: int, exp: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < exp { r = r * base  i = i + 1 }
    r
}

fn is_prime(n: int) -> bool {
    if n < 2 { return false }
    if n < 4 { return true }
    if n % 2 == 0 { return false }
    let mut p = 3
    while p * p <= n {
        if n % p == 0 { return false }
        p = p + 2
    }
    true
}

// ── PART 1: 직접 탐색 ──
fn search_solutions(limit: int) -> list {
    let mut sols = []
    let mut n = 1
    while n <= limit {
        if sigma(n) + phi(n) + tau(n) == 3 * n {
            sols = sols + [n]
        }
        n = n + 1
    }
    sols
}

// ── PART 2: n = 2^a · p 매개 케이스 ──
// 유도: p = (3·2^(a-1) + 2a + 1) / (2^(a-1) + 1)
fn search_2a_p(amax: int) -> list {
    let mut out = []
    let mut a = 1
    while a <= amax {
        let pow2 = pow_int(2, a - 1)
        let num = 3 * pow2 + 2 * a + 1
        let den = pow2 + 1
        if num % den == 0 {
            let p = num / den
            if p > 2 && is_prime(p) {
                let n = pow_int(2, a) * p
                out = out + [n]
            }
        }
        a = a + 1
    }
    out
}

// ── PART 3: n = 2^a · 3 · p 매개 케이스 ──
// 유도: p = (7·2^a + 4a) / 4
fn search_2a_3_p(amax: int) -> list {
    let mut out = []
    let mut a = 1
    while a <= amax {
        let num = 7 * pow_int(2, a) + 4 * a
        if num % 4 == 0 {
            let p = num / 4
            if p > 3 && is_prime(p) {
                let n = pow_int(2, a) * 3 * p
                out = out + [n]
            }
        }
        a = a + 1
    }
    out
}

// ── PART 4: n = 2^a · 3^b · p 일반 케이스 ──
fn search_2a_3b_p(amax: int, bmax: int) -> list {
    let mut out = []
    let mut a = 1
    while a <= amax {
        let mut b = 1
        while b <= bmax {
            let s_coeff = (pow_int(2, a + 1) - 1) * (pow_int(3, b + 1) - 1) / 2
            let p_coeff = pow_int(2, a) * pow_int(3, b - 1)
            let t_val = (a + 1) * (b + 1) * 2
            let rhs_coeff = pow_int(2, a) * pow_int(3, b + 1)
            let a_co = s_coeff + p_coeff - rhs_coeff
            let b_const = s_coeff - p_coeff + t_val
            if a_co != 0 {
                let nb = 0 - b_const
                if a_co != 0 && nb % a_co == 0 {
                    let p = nb / a_co
                    if p > 3 && is_prime(p) {
                        let n = pow_int(2, a) * pow_int(3, b) * p
                        out = out + [n]
                    }
                }
            }
            b = b + 1
        }
        a = a + 1
    }
    out
}

// ── verify helper ──
fn verify_all(sols: list) -> int {
    let mut ok = 0
    let mut i = 0
    while i < len(sols) {
        let n = sols[i]
        if sigma(n) + phi(n) + tau(n) == 3 * n { ok = ok + 1 }
        i = i + 1
    }
    ok
}

// ── report ──
println("======================================================================")
println("INVESTIGATE: σ(n) + φ(n) + τ(n) = 3n — hexa port")
println("======================================================================")

// 탐색 (기본 10000, 큰 값은 런타임↑)
let limit = 100
println("")
println("--- PART 1: 직접 탐색 (n ≤ " + to_string(limit) + ") ---")
let sols = search_solutions(limit)
println("  solutions: " + to_string(sols))
println("  count: " + to_string(len(sols)))
println("  verified: " + to_string(verify_all(sols)) + " / " + to_string(len(sols)))

// 알려진 해 검증
println("")
println("--- KNOWN: [2, 4, 6, 90, 408, 5856] ---")
let known = [2, 4, 6, 90, 408, 5856]
let mut i = 0
while i < len(known) {
    let n = known[i]
    let s = sigma(n)
    let p = phi(n)
    let t = tau(n)
    let sum = s + p + t
    let mark = if sum == 3 * n { "🟧 PASS" } else { "⬛ FAIL" }
    println("  " + mark + " n=" + to_string(n) + "  σ=" + to_string(s) + "  φ=" + to_string(p) + "  τ=" + to_string(t) + "  sum=" + to_string(sum) + "  3n=" + to_string(3 * n))
    i = i + 1
}

// PART 2: 2^a · p
println("")
println("--- PART 2: n = 2^a · p (a ≤ 30) ---")
let r2 = search_2a_p(30)
println("  solutions: " + to_string(r2))
println("  verified: " + to_string(verify_all(r2)) + " / " + to_string(len(r2)))

// PART 3: 2^a · 3 · p
println("")
println("--- PART 3: n = 2^a · 3 · p (a ≤ 30) ---")
let r3 = search_2a_3_p(30)
println("  solutions: " + to_string(r3))
println("  verified: " + to_string(verify_all(r3)) + " / " + to_string(len(r3)))

// PART 4: 2^a · 3^b · p
println("")
println("--- PART 4: n = 2^a · 3^b · p (a ≤ 15, b ≤ 10) ---")
let r4 = search_2a_3b_p(15, 10)
println("  solutions: " + to_string(r4))
println("  verified: " + to_string(verify_all(r4)) + " / " + to_string(len(r4)))

// ── 프라임 케이스 증명 (정적 체크) ──
println("")
println("--- 매개 증명 (정적) ---")
// n=p: 2p+2 = 3p → p=2
let prime_ok = (2 * 2 + 2) == (3 * 2)
// n=p²: p=2 → n=4
let p2_ok = (2 * 4 + 4) == (3 * 4)
// n=2p: p=3 → n=6
let twop_ok = (4 * 3 + 6) == (3 * 6)
println("  " + (if prime_ok { "🟧" } else { "⬛" }) + " n=prime → n=2 유일")
println("  " + (if p2_ok { "🟧" } else { "⬛" }) + " n=p² → n=4 유일")
println("  " + (if twop_ok { "🟧" } else { "⬛" }) + " n=2p → n=6 유일")

println("")
println("======================================================================")
println("DONE — strong numerical evidence for finiteness")
println("======================================================================")
