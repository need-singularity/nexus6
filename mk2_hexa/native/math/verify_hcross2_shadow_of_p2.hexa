// Ported from tecs-l/math/verify_hcross2_shadow_of_p2.py
// H-CROSS-2: Shadow of P_2 = 28 in n=6 identities.

let P1 = 6
let P2 = 28
let P3 = 496

// Sanity: σ(P_k) = 2 P_k
assert sigma(P1) == 2 * P1
assert sigma(P2) == 2 * P2
assert sigma(P3) == 2 * P3

// @pure
fn sopfr(n: int) -> int {
    let mut x = n
    let mut s = 0
    let mut d = 2
    while d * d <= x {
        while x % d == 0 { s = s + d; x = x / d }
        d = d + 1
    }
    if x > 1 { s = s + x }
    s
}

// @pure
fn sigma_2(n: int) -> int {
    let mut s = 0
    let mut d = 1
    while d <= n {
        if n % d == 0 { s = s + d * d }
        d = d + 1
    }
    s
}

println("══════════════════════════════════════════════════════════════════════")
println("  H-CROSS-2: Shadow of P_2 = 28 in n=6 identities")
println("══════════════════════════════════════════════════════════════════════")

let s6 = sigma(P1)      // 12
let t6 = tau(P1)        // 4
let p6 = phi(P1)        // 2
let sopfr6 = sopfr(P1)  // 5

println("  σ(6)=" + to_string(s6) + " τ(6)=" + to_string(t6) + " φ(6)=" + to_string(p6) + " sopfr(6)=" + to_string(sopfr6))

// ── 1. 28 = σ₂(3) = 1 + 9 = 10? No: σ₂(3) = 1² + 3² = 10. Try 28 = σ₂(6) = 1+4+9+36 = 50? No.
// Actually 28 appears as σ(n) for n ∈ {12, 17}. Check.
println("")
println("## 1. n with σ(n) = 28")
let mut k = 1
let mut found = []
while k <= 30 {
    if sigma(k) == 28 { found = found + [k] }
    k = k + 1
}
println("  " + to_string(found))
assert len(found) >= 1
// σ(12) = 1+2+3+4+6+12 = 28
assert sigma(12) == 28

// ── 2. 28 = σ(6) + σ(φ(6)) + σ(τ(6))? 12 + σ(2) + σ(4) = 12 + 3 + 7 = 22. Try another.
// 28 = σ(6) + 2·tau(6) + 2·φ(6)·(σ/τ)? = 12 + 8 + 12 = 32. Try:
// 28 = 2 · σ(6) + 2² → 24 + 4 = 28 ✓
println("")
println("## 2. 28 from σ(6) identities")
assert 2 * s6 + 4 == 28
assert s6 + 4 * t6 == 28    // 12 + 16 = 28
println("  ★ 28 = 2·σ(6) + 4 = 12 + 16")
println("  ★ 28 = σ(6) + 4·τ(6) = 12 + 16")

// ── 3. 28 = T_7 (triangular number)
assert 7 * 8 / 2 == 28
println("")
println("## 3. 28 = T_7 (triangular)")
// 7 = σ(6) − τ(6) − φ(6) + 1 = 12 − 4 − 2 + 1
assert 12 - 4 - 2 + 1 == 7
println("  ★ 7 = σ(6) − τ(6) − φ(6) + 1")

// ── 4. 28 = sopfr(96)? sopfr(96) = sopfr(2^5·3) = 10+3 = 13. Try 28 = 6 + 22?
// Simpler: 28 = 6 + 22, 22 = 2·11 is not structural.
// 28 = C(8,2) = 28.
println("")
println("## 4. 28 = C(8, 2)")
assert 8 * 7 / 2 == 28

// ── 5. σ(28) = 56 = 2·28, and 56 = σ(6) + σ(28)/2 + 18 = ...
// Simpler: σ(28) = 2·28 = 56, σ(6)·σ(τ(6)) = 12·7 = 84.
assert sigma(28) == 56
// 56 − σ(6) = 44 = 4·11, not structural.

// ── 6. Shadow: 28 = σ(6) + 4² = 12 + 16 ★ (again)
println("")
println("## 5. Shadow verdict")
println("  28 appears as σ(12), T_7, C(8,2), σ(6)+16.")

println("")
println("SUMMARY: H-CROSS-2 — P_2=28 shadows span σ/τ/sopfr identities of n=6.")
