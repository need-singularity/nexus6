fn repeat_char(ch: string, n: int) -> string {
    let mut out = ""
    for i in 0..n { out = out + ch }
    out
}

fn abs_f(x: float) -> float {
    if x < 0.0 { 0.0 - x } else { x }
}

// ─── Fibonacci helper ───
fn fibonacci(k: int) -> int {
    let mut a = 0
    let mut b = 1
    for i in 0..k {
        let tmp = b
        b = a + b
        a = tmp
    }
    a
}

// ─── XOR helper ───
fn xor_val(a: int, b: int) -> int {
    a ^ b
}

