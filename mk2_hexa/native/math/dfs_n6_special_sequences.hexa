// Ported from tecs-l/math/dfs_n6_special_sequences.py
// DFS: n=6 identities with Catalan, Fibonacci, Bell, Motzkin, Bernoulli.

// @pure
fn catalan(k: int) -> int {
    // C_k = binomial(2k, k) / (k+1)
    let mut num = 1
    let mut i = 1
    while i <= k {
        num = num * (k + i)
        i = i + 1
    }
    let mut den = 1
    let mut j = 1
    while j <= k {
        den = den * j
        j = j + 1
    }
    num / den / (k + 1)
}

// @pure
fn fib(k: int) -> int {
    if k < 2 { return k }
    let mut a = 0
    let mut b = 1
    let mut i = 2
    while i <= k {
        let t = a + b
        a = b
        b = t
        i = i + 1
    }
    b
}

// @pure
fn factorial(k: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= k { r = r * i; i = i + 1 }
    r
}

let n = 6
let sigma_n = sigma(n)  // 12
let tau_n   = tau(n)    // 4
let phi_n   = phi(n)    // 2
let sopfr_n = 5          // 2+3

println("══════════════════════════════════════════════════════════════════════")
println("  DFS: n=6 connections to Special Sequences")
println("══════════════════════════════════════════════════════════════════════")
println("  σ=" + to_string(sigma_n) + " τ=" + to_string(tau_n) + " φ=" + to_string(phi_n) + " sopfr=" + to_string(sopfr_n))

// Catalan checks
println("")
println("## CATALAN")
let c2 = catalan(2)
let c4 = catalan(4)
let c5 = catalan(5)
let c6 = catalan(6)
println("  C_2=" + to_string(c2) + " C_4=" + to_string(c4) + " C_5=" + to_string(c5) + " C_6=" + to_string(c6))
assert c2 == phi_n                             // C_phi(6) = phi(6)
assert c4 == 2 * sopfr_n + tau_n               // 14 = 2·5 + 4
assert c4 == 14
assert c5 == 42                                // sanity
println("  ★ C_φ(6) = φ(6) = 2")
println("  ★ C_4 = 14 = 2·sopfr(6) + τ(6)")

// Fibonacci checks
println("")
println("## FIBONACCI (F_0=0, F_1=1)")
let f6 = fib(6)
let f12 = fib(12)
println("  F_6 = " + to_string(f6))
println("  F_12 = " + to_string(f12) + "  (σ(6)=12)")
assert f6 == 8
assert f12 == 144
// 144 = 12^2 = σ(6)^2
assert f12 == sigma_n * sigma_n
println("  ★ F_σ(6) = σ(6)² = 144")

// Factorial / 6! = 720
println("")
println("## FACTORIAL")
let f6_val = factorial(6)
println("  6! = " + to_string(f6_val))
assert f6_val == 720
// 720 = σ(6) * 60 = 12 * 60
assert f6_val == sigma_n * 60
// 720 / 6 = 120 = 5!
assert f6_val / 6 == factorial(5)

// Bell number B_3 = 5 = sopfr(6)
// B_0..B_4 = 1,1,2,5,15
let bell = [1, 1, 2, 5, 15, 52]
println("")
println("## BELL")
println("  B_3 = " + to_string(bell[3]) + " = sopfr(6) ★")
assert bell[3] == sopfr_n

// Motzkin M_0..M_6 = 1,1,2,4,9,21,51
let motz = [1, 1, 2, 4, 9, 21, 51]
println("")
println("## MOTZKIN")
println("  M_τ(6) = M_4 = " + to_string(motz[4]))
assert motz[4] == 9
// 9 = 3^2 = (σ/τ)^2
assert motz[4] == (sigma_n / tau_n) * (sigma_n / tau_n)
println("  ★ M_τ(6) = (σ/τ)² = 9")

println("")
println("SUMMARY: n=6 matches Catalan/Fibonacci/Bell/Motzkin via σ,τ,φ,sopfr.")
