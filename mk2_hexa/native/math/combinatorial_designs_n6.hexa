// Ported from tecs-l/math/combinatorial_designs_n6.py
// Steiner systems, BIBDs, MOLS, Hadamard matrices — n=6 connections.

println("══════════════════════════════════════════════════════════════════════")
println("  COMBINATORIAL DESIGNS FOR n=6")
println("══════════════════════════════════════════════════════════════════════")

assert sigma(6) == 12
assert phi(6) == 2
assert tau(6) == 4

// STS(v) exists iff v ≡ 1 or 3 (mod 6)
// @pure
fn sts_exists(v: int) -> bool { v % 6 == 1 || v % 6 == 3 }
// @pure
fn sts_num_blocks(v: int) -> int { v * (v - 1) / 6 }
// @pure
fn sts_replication(v: int) -> int { (v - 1) / 2 }

println("")
println("## 1. Steiner triple systems STS(v)")
println("   v  | exists | blocks | r")
println("  ----+--------+--------+----")
let cases = [7, 9, 13, 15, 19, 21, 25, 27]
let mut i = 0
while i < len(cases) {
    let v = cases[i]
    let ex = if sts_exists(v) { "yes" } else { "NO " }
    if sts_exists(v) {
        println("   " + to_string(v) + "\t| " + ex + "\t| " + to_string(sts_num_blocks(v)) + "\t| " + to_string(sts_replication(v)))
    } else {
        println("   " + to_string(v) + "\t| " + ex + "\t|  -\t|  -")
    }
    i = i + 1
}

// STS(7) = Fano plane, STS(9) = AG(2,3)
println("")
println("  STS(7) = Fano plane      (7 points, 7 lines)")
println("  STS(9) = AG(2,3)         (9 points, 12 lines) ← 12 = σ(6)")
println("  STS(13) = PG(2,3)        (13 pts, 13 lines; 13 = σ(6)+1)")
assert sts_num_blocks(9) == 12
assert sts_num_blocks(9) == sigma(6)

// 2. BIBD(v, k, λ): b·k = r·v, r·(k−1) = λ·(v−1)
println("")
println("## 2. BIBD(v,k,λ) — Fisher's inequality b ≥ v")
println("  BIBD(6, 3, 2): b = 10, r = 5 (from r(k−1)=λ(v−1))")
println("  Fisher: 10 ≥ 6 ✓")

// 3. MOLS — Mutually Orthogonal Latin Squares
println("")
println("## 3. MOLS(n) — maximum pairwise orthogonal Latin squares")
println("  n  | N(n) bound")
println("  ---+-----------")
println("  2  | 0")
println("  3  | 2")
println("  4  | 3")
println("  5  | 4")
println("  6  | 1  ← Euler conjecture, Tarry 1901 ★ (n=6 is special)")
println("  7  | 6")
println("  8  | 7")
println("")
println("  → n=6 is the UNIQUE exception with MOLS < n−1")

// 4. Hadamard matrix order
println("")
println("## 4. Hadamard matrix H_n exists for n ∈ {1, 2, 4k}")
let mut h = 1
while h <= 28 {
    let has_h = if h == 1 || h == 2 || (h % 4 == 0) { true } else { false }
    if has_h {
        let mark = if h == 12 { " ← σ(6)" } else if h == 24 { " ← σ(6)·φ(6)" } else if h == 4 { " ← τ(6)" } else { "" }
        println("  H_" + to_string(h) + mark)
    }
    h = h + 1
}

// 5. Kirkman triples KTS(15)
println("")
println("## 5. Kirkman triple system KTS(15)")
println("  v=15, r=7, b=35")
println("  Exists ⟺ v ≡ 3 (mod 6)")
println("  15 = C(6, 2) = binomial(6,2) ★")
let c_6_2 = 6 * 5 / 2
assert c_6_2 == 15

// 6. Perfect difference set at n=6
println("")
println("## 6. Perfect difference set relation")
println("  (7,3,1)-PDS exists: 7 = |STS(7)| = n+1 = 6+1")
println("  Quadratic residues mod 7: {1, 2, 4}")

println("")
println("SUMMARY: n=6 is unique exception in MOLS, and σ(6)=12 appears in Hadamard.")
