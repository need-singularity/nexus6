// 포팅 원본: tecs-l/math/task2_R_divides_n.py (352 LOC)
// Task 2: R(n)|n pattern analysis
// R(n) = sigma(n)*phi(n) / (n*tau(n))
// Find all n where R(n) is integer AND R(n) | n

// ═══════════════════════════════════════════════════════════════
// Factorization
// ═══════════════════════════════════════════════════════════════

fn factorize(n: int) -> map {
    let mut factors = #{}
    let mut rem = n
    let mut d = 2
    while d * d <= rem {
        while rem % d == 0 {
            let key = to_string(d)
            let cur = if has_key(factors, key) { factors[key] } else { 0 }
            factors[key] = cur + 1
            rem = rem / d
        }
        d = d + 1
    }
    if rem > 1 {
        let key = to_string(rem)
        let cur = if has_key(factors, key) { factors[key] } else { 0 }
        factors[key] = cur + 1
    }
    factors
}

// ═══════════════════════════════════════════════════════════════
// R(n) computation using exact integer arithmetic
// We compute numerator and denominator separately, then simplify
// ═══════════════════════════════════════════════════════════════

fn int_pow(base: int, exp: int) -> int {
    let mut result = 1
    let mut i = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    result
}

// R(n) = product over prime powers of (p^(a+1)-1) / (p*(a+1))
// Returns [numerator, denominator] after simplification
fn compute_R_frac(n: int) -> list {
    if n == 1 {
        return [1, 1]
    }
    let factors = factorize(n)
    let ks = keys(factors)
    let mut num = 1
    let mut den = 1
    let mut i = 0
    while i < ks.len() {
        let p = to_int(ks[i])
        let a = factors[ks[i]]
        num = num * (int_pow(p, a + 1) - 1)
        den = den * (p * (a + 1))
        i = i + 1
    }
    // simplify
    let g = gcd(abs(num), abs(den))
    if g > 0 {
        num = num / g
        den = den / g
    }
    [num, den]
}

fn compute_sigma(n: int) -> int {
    let factors = factorize(n)
    let ks = keys(factors)
    let mut result = 1
    let mut i = 0
    while i < ks.len() {
        let p = to_int(ks[i])
        let a = factors[ks[i]]
        result = result * ((int_pow(p, a + 1) - 1) / (p - 1))
        i = i + 1
    }
    result
}

fn compute_phi(n: int) -> int {
    let factors = factorize(n)
    let ks = keys(factors)
    let mut result = n
    let mut i = 0
    while i < ks.len() {
        let p = to_int(ks[i])
        result = (result / p) * (p - 1)
        i = i + 1
    }
    result
}

fn compute_tau(n: int) -> int {
    let factors = factorize(n)
    let ks = keys(factors)
    let mut result = 1
    let mut i = 0
    while i < ks.len() {
        let a = factors[ks[i]]
        result = result * (a + 1)
        i = i + 1
    }
    result
}

// ═══════════════════════════════════════════════════════════════
// Search
// ═══════════════════════════════════════════════════════════════

fn search_solutions(n_max: int) -> list {
    let mut solutions = []
    let mut n = 1
    while n <= n_max {
        let r = compute_R_frac(n)
        let num = r[0]
        let den = r[1]
        // R(n) is integer when denominator == 1
        if den == 1 {
            let r_int = num
            // Check R(n) | n
            if r_int > 0 && n % r_int == 0 {
                let ratio = n / r_int
                solutions = solutions + [[n, r_int, ratio]]
            }
        }
        if n % 5000 == 0 {
            println("  Progress: n=" + to_string(n) + ", solutions so far: " + to_string(solutions.len()))
        }
        n = n + 1
    }
    solutions
}

// ═══════════════════════════════════════════════════════════════
// Factor string helper
// ═══════════════════════════════════════════════════════════════

fn factor_str(n: int) -> string {
    if n <= 1 {
        return to_string(n)
    }
    let factors = factorize(n)
    let ks = keys(factors).sort()
    let mut parts = []
    let mut i = 0
    while i < ks.len() {
        let key = ks[i]
        let a = factors[key]
        if a > 1 {
            parts = parts + [key + "^" + to_string(a)]
        } else {
            parts = parts + [key]
        }
        i = i + 1
    }
    parts.join(" * ")
}

// ═══════════════════════════════════════════════════════════════
// Analysis
// ═══════════════════════════════════════════════════════════════

fn analyze_factorizations(solutions: list) {
    println("")
    println("======================================================================")
    println("FACTORIZATION ANALYSIS")
    println("======================================================================")

    let mut i = 0
    while i < solutions.len() {
        let sol = solutions[i]
        let n = sol[0]
        let R = sol[1]
        let ratio = sol[2]
        let fs = factor_str(n)
        let sig = compute_sigma(n)
        let ph = compute_phi(n)
        let ta = compute_tau(n)

        println("")
        println("n = " + to_string(n) + " = " + fs)
        println("  R(n) = " + to_string(R))
        println("  n/R  = " + to_string(ratio))
        println("  sigma(n) = " + to_string(sig) + ", phi(n) = " + to_string(ph) + ", tau(n) = " + to_string(ta))
        let sp = sig * ph
        let nt = n * ta
        println("  sigma*phi = " + to_string(sp) + ", n*tau = " + to_string(nt))

        // Check multiply perfect
        if sig == 2 * n {
            println("  *** n is PERFECT (sigma(n)=2n) ***")
        }
        if sig % n == 0 {
            let k = sig / n
            if k > 2 {
                println("  *** n is " + to_string(k) + "x MULTIPLY PERFECT ***")
            }
        }

        // Check ratio against known perfect/Mersenne
        let perfect = [6, 28, 496, 8128, 33550336]
        let mersenne = [1, 3, 7, 31, 127, 8191, 131071, 524287]
        let mut j = 0
        while j < perfect.len() {
            if ratio == perfect[j] {
                println("  *** n/R = " + to_string(ratio) + " is a PERFECT NUMBER ***")
            }
            if R == perfect[j] {
                println("  *** R = " + to_string(R) + " is a PERFECT NUMBER ***")
            }
            j = j + 1
        }
        j = 0
        while j < mersenne.len() {
            if ratio == mersenne[j] {
                println("  *** n/R = " + to_string(ratio) + " is a MERSENNE NUMBER ***")
            }
            if R == mersenne[j] {
                println("  *** R = " + to_string(R) + " is a MERSENNE NUMBER ***")
            }
            j = j + 1
        }

        i = i + 1
    }
    println("")
}

fn perfect_number_structure() {
    println("======================================================================")
    println("PERFECT NUMBER / MERSENNE STRUCTURE")
    println("======================================================================")

    println("")
    println("Known pattern for even perfect numbers (Euler):")
    println("  n = 2^(p-1) * M_p where M_p = 2^p - 1 is Mersenne prime")
    println("  sigma(n) = 2n")
    println("")

    let test_ns = [6, 28, 496, 8128]
    let mut i = 0
    while i < test_ns.len() {
        let n = test_ns[i]
        let r = compute_R_frac(n)
        let num = r[0]
        let den = r[1]
        let sig = compute_sigma(n)
        let is_perfect = if sig == 2 * n { "perfect" } else { "" }

        if den == 1 && num > 0 && n % num == 0 {
            let q = n / num
            println("  n=" + to_string(n) + " R=" + to_string(num) + " n/R=" + to_string(q) + " sigma=" + to_string(sig) + " " + is_perfect + " R|n:divides")
        } else if den == 1 {
            println("  n=" + to_string(n) + " R=" + to_string(num) + " n/R=N/A sigma=" + to_string(sig) + " " + is_perfect + " R|n:not divides")
        } else {
            let frac_s = to_string(num) + "/" + to_string(den)
            println("  n=" + to_string(n) + " R=" + frac_s + " n/R=N/A sigma=" + to_string(sig) + " " + is_perfect + " R not integer")
        }
        i = i + 1
    }
}

fn characterize_solutions(solutions: list) {
    println("")
    println("======================================================================")
    println("CHARACTERIZATION ATTEMPT")
    println("======================================================================")

    println("")
    println("For R(n) to be an integer:")
    println("  R(n) = prod_p (p^(a+1)-1)/(p(a+1))")
    println("  Each factor must combine to give an integer product.")
    println("")

    println("Known solutions and their factorizations:")
    let mut i = 0
    while i < solutions.len() {
        let sol = solutions[i]
        let n = sol[0]
        let R = sol[1]
        let ratio = sol[2]
        let fs = factor_str(n)
        let rs = factor_str(ratio)
        println("  n=" + to_string(n) + "  " + fs + "  R=" + to_string(R) + "  n/R=" + to_string(ratio) + "  (" + rs + ")")
        i = i + 1
    }

    // n/R values
    println("")
    println("Pattern observations:")
    let mut ratio_list = ""
    i = 0
    while i < solutions.len() {
        let ratio = solutions[i][2]
        if i > 0 {
            ratio_list = ratio_list + ", "
        }
        ratio_list = ratio_list + to_string(ratio)
        i = i + 1
    }
    println("  n/R values: [" + ratio_list + "]")

    // sigma of ratio
    i = 0
    while i < solutions.len() {
        let ratio = solutions[i][2]
        if ratio > 1 {
            let sig_r = compute_sigma(ratio)
            if sig_r == 2 * ratio {
                println("  n/R = " + to_string(ratio) + " is PERFECT")
            } else if sig_r % ratio == 0 {
                let k = sig_r / ratio
                println("  n/R = " + to_string(ratio) + ": sigma/n = " + to_string(k))
            } else {
                println("  n/R = " + to_string(ratio) + ": sigma = " + to_string(sig_r))
            }
        }
        i = i + 1
    }
}

fn multiply_perfect_connection(solutions: list) {
    println("")
    println("======================================================================")
    println("MULTIPLY PERFECT NUMBER CONNECTION")
    println("======================================================================")

    println("")
    println("Multiply perfect numbers: sigma(n) = k*n for integer k >= 2")
    println("  k=2: perfect (6, 28, 496, 8128, ...)")
    println("  k=3: triperfect (120, 672, ...)")
    println("  k=4: 30240, 32760, ...")
    println("")

    let known_triperfect = [120, 672, 523776]
    let known_perfect = [6, 28, 496, 8128, 33550336]

    let mut i = 0
    while i < solutions.len() {
        let n = solutions[i][0]
        let sig = compute_sigma(n)
        let mut mult_type = ""
        if sig % n == 0 {
            let k = sig / n
            mult_type = to_string(k) + "x perfect"
        } else {
            mult_type = "sigma/n = " + to_string(sig) + "/" + to_string(n)
        }
        let mut extra = ""
        let mut j = 0
        while j < known_triperfect.len() {
            if n == known_triperfect[j] {
                extra = extra + " *** TRIPERFECT ***"
            }
            j = j + 1
        }
        j = 0
        while j < known_perfect.len() {
            if n == known_perfect[j] {
                extra = extra + " *** PERFECT ***"
            }
            j = j + 1
        }
        println("  n = " + to_string(n) + ": sigma(n) = " + to_string(sig) + ", " + mult_type + extra)
        i = i + 1
    }
}

fn extended_search_analysis(solutions: list) {
    println("")
    println("======================================================================")
    println("EXTENDED SEARCH ANALYSIS")
    println("======================================================================")

    println("")
    println("Total solutions found: " + to_string(solutions.len()))
    println("")

    let mut i = 0
    while i < solutions.len() {
        let sol = solutions[i]
        let n = sol[0]
        let R = sol[1]
        let ratio = sol[2]
        let fs = factor_str(n)
        println("  n=" + to_string(n) + "  " + fs + "  R=" + to_string(R) + "  n/R=" + to_string(ratio))
        i = i + 1
    }

    // Differences between consecutive solutions
    println("")
    println("Differences between consecutive solutions:")
    i = 1
    while i < solutions.len() {
        let cur = solutions[i][0]
        let prev = solutions[i - 1][0]
        println("  " + to_string(cur) + " - " + to_string(prev) + " = " + to_string(cur - prev))
        i = i + 1
    }

    println("")
    println("Ratios between consecutive solutions:")
    i = 1
    while i < solutions.len() {
        let cur = solutions[i][0]
        let prev = solutions[i - 1][0]
        if prev > 0 {
            let r = to_float(cur) / to_float(prev)
            println("  " + to_string(cur) + " / " + to_string(prev) + " = " + to_string(r))
        }
        i = i + 1
    }
}

// ═══════════════════════════════════════════════════════════════
// Main
// ═══════════════════════════════════════════════════════════════

println("TASK 2: R(n)|n PATTERN ANALYSIS")
println("======================================================================")

// Verify known solutions
println("")
println("Verifying known solutions n <= 10000:")
let known_solutions = [[1,1,1], [6,1,6], [28,4,7], [120,6,20], [672,24,28], [1080,30,36], [1782,66,27]]

let mut ki = 0
while ki < known_solutions.len() {
    let ks = known_solutions[ki]
    let n = ks[0]
    let r_expected = ks[1]
    let ratio_expected = ks[2]
    let r = compute_R_frac(n)
    let num = r[0]
    let den = r[1]
    let ok = if den == 1 && num == r_expected && n % r_expected == 0 { "OK" } else { "FAIL" }
    let r_str = if den == 1 { to_string(num) } else { to_string(num) + "/" + to_string(den) }
    println("  n=" + to_string(n) + " R_exp=" + to_string(r_expected) + " ratio_exp=" + to_string(ratio_expected) + " " + ok + " (computed R=" + r_str + ")")
    ki = ki + 1
}

// Full search n <= 10000
println("")
println("======================================================================")
println("FULL SEARCH n <= 10000")
let solutions_10k = search_solutions(10000)
println("")
println("Found " + to_string(solutions_10k.len()) + " solutions:")
let mut si = 0
while si < solutions_10k.len() {
    let sol = solutions_10k[si]
    println("  n=" + to_string(sol[0]) + ", R=" + to_string(sol[1]) + ", n/R=" + to_string(sol[2]))
    si = si + 1
}

analyze_factorizations(solutions_10k)
perfect_number_structure()
multiply_perfect_connection(solutions_10k)
characterize_solutions(solutions_10k)

// Extended search n <= 30000 (reduced from 100000 for interpreter speed)
println("")
println("======================================================================")
println("EXTENDED SEARCH n <= 30000")
let solutions_ext = search_solutions(30000)
extended_search_analysis(solutions_ext)

// Final characterization
println("")
println("======================================================================")
println("FINAL CHARACTERIZATION")
println("======================================================================")

println("")
println("All solutions found:")
let mut fi = 0
while fi < solutions_ext.len() {
    let sol = solutions_ext[fi]
    let n = sol[0]
    let R = sol[1]
    let ratio = sol[2]
    let fs = factor_str(n)
    let sig = compute_sigma(n)
    let mut k_str = ""
    if sig % n == 0 {
        k_str = to_string(sig / n)
    } else {
        k_str = to_string(sig) + "/" + to_string(n)
    }
    println("  n=" + to_string(n) + ": " + fs + ", R=" + to_string(R) + ", n/R=" + to_string(ratio) + ", sigma/n=" + k_str)
    fi = fi + 1
}

println("")
println("THEORETICAL ANALYSIS:")
println("")
println("For R(n) = prod R(p^a) to be integer, we need:")
println("  prod (p^(a+1)-1)/(p(a+1)) in Z")
println("")
println("For a=1 (prime p): R(p) = (p^2-1)/(2p) = (p-1)(p+1)/(2p)")
println("  Not integer for any prime p")
println("  For p=2: R(2) = 3/4, not integer")
println("")
println("HYPOTHESIS: Solutions are related to multiply perfect numbers:")
println("  n=1: trivially R=1")
println("  n=6 (perfect): sigma(6)=12=2*6")
println("  n=28 (perfect): sigma(28)=56=2*28")
println("  n=120 (triperfect): sigma(120)=360=3*120")
println("  n=672 (triperfect): sigma(672)=2016=3*672")
