// Ported from tecs-l/math/d_sign_structure.py
// Sign structure of Δ(n) = σ(n)·φ(n) − n·τ(n) and its distribution.

println("══════════════════════════════════════════════════════════════════════")
println("  Δ(n) = σφ − nτ  sign structure")
println("══════════════════════════════════════════════════════════════════════")

// Δ at small n
println("")
println("## Δ(n) for n in [1, 20]")
println("   n | σφ    | nτ    | Δ     | sign")
let mut n = 1
while n <= 20 {
    let sp = sigma(n) * phi(n)
    let nt = n * tau(n)
    let d = sp - nt
    let sg = if d > 0 { "+" } else if d == 0 { "0" } else { "−" }
    println("  " + to_string(n) + "\t| " + to_string(sp) + "\t| " + to_string(nt) + "\t| " + to_string(d) + "\t|  " + sg)
    n = n + 1
}

// Count signs in [1, 2000]
let mut pos = 0
let mut neg = 0
let mut zer = 0
let mut m = 1
while m <= 2000 {
    let d = sigma(m) * phi(m) - m * tau(m)
    if d > 0 { pos = pos + 1 }
    else if d == 0 { zer = zer + 1 }
    else { neg = neg + 1 }
    m = m + 1
}
println("")
println("## Sign census in [1, 2000]")
println("  positive: " + to_string(pos))
println("  zero    : " + to_string(zer) + "  ★ (= {1, 6})")
println("  negative: " + to_string(neg))

// Anchor
assert zer == 2
println("  → Δ=0 only at n=1, 6 (master identity)")

// Zeros confirmation
let mut zeros = []
let mut k = 1
while k <= 2000 {
    if sigma(k) * phi(k) - k * tau(k) == 0 { zeros = zeros + [k] }
    k = k + 1
}
println("  zeros list: " + to_string(zeros))

// Magnitude of Δ at specific anchors
println("")
println("## Δ magnitude at perfect numbers")
let perfs = [6, 28, 496, 8128]
let mut i = 0
while i < len(perfs) {
    let p = perfs[i]
    let d = sigma(p) * phi(p) - p * tau(p)
    println("  Δ(" + to_string(p) + ") = " + to_string(d))
    i = i + 1
}

// For n=6: Δ=0; for n=28: Δ should be ≠0
assert sigma(6) * phi(6) - 6 * tau(6) == 0
let d28 = sigma(28) * phi(28) - 28 * tau(28)
println("")
println("  Only n=1 and n=6 give Δ=0. n=28 (2nd perfect) gives Δ=" + to_string(d28))

println("")
println("SUMMARY: sign(Δ) mostly +, with Δ=0 exclusively at {1, 6}.")
