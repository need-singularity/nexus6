// ─── helper functions ───

fn divisors(k: int) -> [int] {
    let mut d = []
    let mut i = 1
    while i * i <= k {
        if k % i == 0 {
            d = d.push(i)
            if i != k / i {
                d = d.push(k / i)
            }
        }
        i = i + 1
    }
    d.sort()
}

fn sigma_fn(k: int) -> int { divisors(k).sum() }
fn tau_fn(k: int) -> int { len(divisors(k)) }

fn phi_fn(k: int) -> int {
    let mut r = k
    let mut t = k
    let mut p = 2
    while p * p <= t {
        if t % p == 0 {
            while t % p == 0 {
                t = t / p
            }
            r = r - r / p
        }
        p = p + 1
    }
    if t > 1 {
        r = r - r / t
    }
    r
}

fn sopfr_fn(k: int) -> int {
    let mut s = 0
    let mut t = k
    let mut p = 2
    while p * p <= t {
        while t % p == 0 {
            s = s + p
            t = t / p
        }
        p = p + 1
    }
    if t > 1 {
        s = s + t
    }
    s
}

fn omega_fn(m: int) -> int {
    let mut cnt = 0
    let mut t = m
    let mut p = 2
    while p * p <= t {
        if t % p == 0 {
            cnt = cnt + 1
            while t % p == 0 {
                t = t / p
            }
        }
        p = p + 1
    }
    if t > 1 {
        cnt = cnt + 1
    }
    cnt
}

fn factorial(n: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= n {
        r = r * i
        i = i + 1
    }
    r
}

fn comb(n: int, k: int) -> int {
    if k < 0 || k > n { return 0 }
    if k == 0 || k == n { return 1 }
    let kk = if k > n - k { n - k } else { k }
    let mut r = 1
    let mut i = 0
    while i < kk {
        r = r * (n - i)
        r = r / (i + 1)
        i = i + 1
    }
    r
}

fn abs_val(x: int) -> int {
    if x < 0 { 0 - x } else { x }
}

// ─── Stirling numbers of second kind (memoized via map) ───
let mut stirling_cache = #{}

fn stirling2_key(n: int, k: int) -> string {
    to_string(n) + "," + to_string(k)
}

fn stirling2(n: int, k: int) -> int {
    if n == 0 && k == 0 { return 1 }
    if n == 0 || k == 0 { return 0 }
    if k > n { return 0 }
    let key = stirling2_key(n, k)
    if has_key(stirling_cache, key) {
        return stirling_cache[key]
    }
    let val = k * stirling2(n - 1, k) + stirling2(n - 1, k - 1)
    stirling_cache[key] = val
    val
}

// ─── Lah numbers ───
fn lah(n: int, k: int) -> int {
    if n == k { return 1 }
    if k == 0 || k > n { return 0 }
    if k == 1 { return factorial(n) }
    comb(n - 1, k - 1) * factorial(n) / factorial(k)
}

// ─── Catalan numbers ───
fn catalan(n: int) -> int {
    comb(2 * n, n) / (n + 1)
}

// ─── Bernoulli numbers as rational (num, den) pairs ───
// Use integer-based exact rational arithmetic
// bernoulli(n) -> [numerator, denominator]

fn gcd_abs(a: int, b: int) -> int {
    let mut x = abs_val(a)
    let mut y = abs_val(b)
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    x
}

fn rat_simplify(n: int, d: int) {
    if d < 0 {
        return rat_simplify(0 - n, 0 - d)
    }
    if n == 0 { return [0, 1] }
    let g = gcd_abs(n, d)
    [n / g, d / g]
}

fn rat_add(a, b) {
    let num = a[0] * b[1] + b[0] * a[1]
    let den = a[1] * b[1]
    rat_simplify(num, den)
}

fn rat_mul(a, b) {
    rat_simplify(a[0] * b[0], a[1] * b[1])
}

fn rat_neg(a) {
    [0 - a[0], a[1]]
}

fn rat_div(a, b) {
    rat_simplify(a[0] * b[1], a[1] * b[0])
}

// Bernoulli cache
let mut bern_cache = #{}

fn bernoulli(n: int) {
    let key = to_string(n)
    if has_key(bern_cache, key) {
        return bern_cache[key]
    }
    let mut result = [0, 1]
    if n == 0 {
        result = [1, 1]
    } else if n == 1 {
        result = [-1, 2]
    } else if n % 2 == 1 && n > 1 {
        result = [0, 1]
    } else {
        let mut s = [0, 1]
        let mut k = 0
        while k < n {
            let bk = bernoulli(k)
            let c = [comb(n + 1, k), 1]
            s = rat_add(s, rat_mul(c, bk))
            k = k + 1
        }
        result = rat_neg(rat_div(s, [n + 1, 1]))
    }
    bern_cache[key] = result
    result
}

