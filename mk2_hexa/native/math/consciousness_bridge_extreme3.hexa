// ─── 헬퍼 함수 ───
fn divisors(k: int) -> [int] {
    let mut d = []
    let mut i = 1
    while i * i <= k {
        if k % i == 0 {
            d = d.push(i)
            if i != k / i {
                d = d.push(k / i)
            }
        }
        i = i + 1
    }
    d.sort()
}

fn sigma_fn(k: int) -> int {
    let d = divisors(k)
    d.sum()
}

fn tau_fn(k: int) -> int {
    let d = divisors(k)
    len(d)
}

fn phi_fn(k: int) -> int {
    let mut r = k
    let mut t = k
    let mut p = 2
    while p * p <= t {
        if t % p == 0 {
            while t % p == 0 {
                t = t / p
            }
            r = r - r / p
        }
        p = p + 1
    }
    if t > 1 {
        r = r - r / t
    }
    r
}

fn sopfr_fn(k: int) -> int {
    let mut s = 0
    let mut t = k
    let mut p = 2
    while p * p <= t {
        while t % p == 0 {
            s = s + p
            t = t / p
        }
        p = p + 1
    }
    if t > 1 {
        s = s + t
    }
    s
}

fn comb(n: int, r: int) -> int {
    if r < 0 || r > n {
        return 0
    }
    let mut result = 1
    let mut i = 0
    while i < r {
        result = result * (n - i) / (i + 1)
        i = i + 1
    }
    result
}

fn repeat_str(ch: string, count: int) -> string {
    let mut s = ""
    let mut i = 0
    while i < count {
        s = s + ch
        i = i + 1
    }
    s
}

fn abs_f(x: float) -> float {
    if x < 0.0 {
        0.0 - x
    } else {
        x
    }
}

