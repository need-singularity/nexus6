// Game Theory and Social Choice Theory for n=6
// Items 1 (Nash equilibria), 2 (Shapley value), 4 (Sprague-Grundy/Wythoff), 7 (Banzhaf)

let PI = 3.141592653589793
let n = 6
let sig_6 = sigma(6)
let phi_6 = phi(6)
let tau_6 = tau(6)
let sopf_6 = sopfr(6)
let divs = [1, 2, 3, 6]
let total_weight = 12

// ── helpers ──
fn fmt4(x: float) -> string {
    let r = to_float(to_int(x * 10000.0)) / 10000.0
    to_string(r)
}
fn fmt6(x: float) -> string {
    let r = to_float(to_int(x * 1000000.0)) / 1000000.0
    to_string(r)
}
fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

fn fact(k: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= k {
        r = r * i
        i = i + 1
    }
    r
}

// XOR (hexa ^ parse issue — manual bit-by-bit)
fn ixor(a: int, b: int) -> int {
    let mut result = 0
    let mut bit = 1
    let mut aa = a
    let mut bb = b
    while aa > 0 || bb > 0 {
        let ar = aa % 2
        let br = bb % 2
        if ar != br { result = result + bit }
        bit = bit * 2
        aa = aa / 2
        bb = bb / 2
    }
    result
}

// divisors of n, sorted
fn divisors_of(n: int) -> list {
    let mut d = []
    let mut i = 1
    while i * i <= n {
        if n % i == 0 {
            d = d + [i]
            if i * i != n { d = d + [n / i] }
        }
        i = i + 1
    }
    let mut a = d
    let sz = len(a)
    let mut p = 0
    while p < sz - 1 {
        let mut mn = p
        let mut q = p + 1
        while q < sz {
            if a[q] < a[mn] { mn = q }
            q = q + 1
        }
        if mn != p {
            let t = a[p]
            a[p] = a[mn]
            a[mn] = t
        }
        p = p + 1
    }
    a
}

