// Wythoff Grundy values — reduced to max_pos=10 for speed
println("")
println("--- Computing Wythoff Grundy values (max_pos=10) ---")

// Store Grundy values in a flat array indexed by a*11+b (a<=b, a,b in [0,10])
let max_pos = 10
let grid = max_pos + 1
let mut G = []
let mut init_i = 0
while init_i < grid * grid {
    G = G + [-1]
    init_i = init_i + 1
}

fn mex(s: list) -> int {
    let mut m = 0
    let mut found = true
    while found {
        found = false
        let mut ci = 0
        while ci < len(s) {
            if s[ci] == m {
                found = true
                ci = len(s)
            }
            ci = ci + 1
        }
        if found { m = m + 1 }
    }
    m
}

let mut total_g = 0
while total_g <= max_pos * 2 {
    let mut a = 0
    while a <= total_g && a <= max_pos {
        let b = total_g - a
        if b <= max_pos && a <= b {
            let mut mex_set = []
            // Remove from first pile
            let mut r1 = 1
            while r1 <= a {
                let na = a - r1
                let nb = b
                let lo = if na < nb { na } else { nb }
                let hi = if na < nb { nb } else { na }
                let idx = lo * grid + hi
                if G[idx] >= 0 { mex_set = mex_set + [G[idx]] }
                r1 = r1 + 1
            }
            // Remove from second pile
            let mut r2 = 1
            while r2 <= b {
                let na = a
                let nb = b - r2
                let lo = if na < nb { na } else { nb }
                let hi = if na < nb { nb } else { na }
                let idx = lo * grid + hi
                if G[idx] >= 0 { mex_set = mex_set + [G[idx]] }
                r2 = r2 + 1
            }
            // Remove from both
            let lim = if a < b { a } else { b }
            let mut r3 = 1
            while r3 <= lim {
                let na = a - r3
                let nb = b - r3
                let lo = if na < nb { na } else { nb }
                let hi = if na < nb { nb } else { na }
                let idx = lo * grid + hi
                if G[idx] >= 0 { mex_set = mex_set + [G[idx]] }
                r3 = r3 + 1
            }
            G[a * grid + b] = mex(mex_set)
        }
        a = a + 1
    }
    total_g = total_g + 1
}

let grundy_23 = G[2 * grid + 3]
println("")
println("Grundy value at (2, 3) = " + to_string(grundy_23))
println("(phi(6)=2, sigma/tau=3)")

println("")
println("P-positions (Grundy=0) up to (6,6):")
