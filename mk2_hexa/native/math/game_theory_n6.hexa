    let s1 = fmt6(to_float(sh[1]) / d)
    let s2 = fmt6(to_float(sh[2]) / d)
    let s3 = fmt6(to_float(sh[3]) / d)
    println("  Quota=" + to_string(q) + " | " + s0 + " | " + s1 + " | " + s2 + " | " + s3)
    qi = qi + 1
}

