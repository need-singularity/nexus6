// Simple LCG PRNG
let mut prng_state = 42
fn next_rand() -> float {
    prng_state = (prng_state * 1103515245 + 12345) % 2147483648
    to_float(prng_state) / 2147483648.0
}
fn rand_gauss() -> float {
    // Box-Muller approximate: use 6 uniform sums (CLT)
    let mut s = 0.0
    let mut ci = 0
    while ci < 6 {
        s = s + next_rand()
        ci = ci + 1
    }
    s - 3.0
}

// count pure NE in 6x6 game stored flat
fn count_pure_ne_6(a_flat: list, b_flat: list) -> int {
    let mut ne_cnt = 0
    let mut i = 0
    while i < 6 {
        let mut j = 0
        while j < 6 {
            let aij = a_flat[i * 6 + j]
            // check row best-response for player 1
            let mut br1 = true
            let mut kk = 0
            while kk < 6 {
                if a_flat[kk * 6 + j] > aij { br1 = false }
                kk = kk + 1
            }
            if br1 {
                // check col best-response for player 2
                let bij = b_flat[i * 6 + j]
                let mut br2 = true
                let mut ll = 0
                while ll < 6 {
                    if b_flat[i * 6 + ll] > bij { br2 = false }
                    ll = ll + 1
                }
                if br2 { ne_cnt = ne_cnt + 1 }
            }
            j = j + 1
        }
        i = i + 1
    }
    ne_cnt
}

let num_sims = 200
let mut ne_total = 0
let mut si = 0
while si < num_sims {
    let mut af = []
    let mut bf = []
    let mut fi = 0
    while fi < 36 {
        af = af + [rand_gauss()]
        bf = bf + [rand_gauss()]
        fi = fi + 1
    }
    ne_total = ne_total + count_pure_ne_6(af, bf)
    si = si + 1
}
let sim_avg = to_float(ne_total) / to_float(num_sims)
println("  Simulated E[pure NE] at n=6 = " + fmt4(sim_avg))
println("  sqrt(3*pi) = " + fmt4(ne_n6))
