println("Quota = sigma(6) = " + to_string(sig_6) + ", Total weight = " + to_string(total_weight))

fn banzhaf_swings(weights: list, quota: int) -> list {
    let np = len(weights)
    let mut swings = [0, 0, 0, 0]
    let mut bits = 1
    let limit = 16
    while bits < limit {
        let mut coal_w = 0
        let mut members = []
        if bits % 2 == 1 {
            coal_w = coal_w + weights[0]
            members = members + [0]
        }
        if (bits / 2) % 2 == 1 {
            coal_w = coal_w + weights[1]
            members = members + [1]
        }
        if (bits / 4) % 2 == 1 {
            coal_w = coal_w + weights[2]
            members = members + [2]
        }
        if (bits / 8) % 2 == 1 {
            coal_w = coal_w + weights[3]
            members = members + [3]
        }
        if coal_w >= quota {
            let mut mi = 0
            while mi < len(members) {
                let p = members[mi]
                if coal_w - weights[p] < quota {
                    swings[p] = swings[p] + 1
                }
                mi = mi + 1
            }
        }
        bits = bits + 1
    }
    swings
}

// Banzhaf for [12; 1,2,3,6]
