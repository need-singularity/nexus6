// Ported from tecs-l/math/f2_euler_product.py
// F2 Euler product: ∏_{p|n} (1 − 1/p²) and multiplicative function experiments.

// @pure
fn jordan_j2(n: int) -> int {
    // J_2(n) = n² · prod_{p|n}(1 − 1/p²) = prod(p^(2e) − p^(2e−2))
    if n <= 0 { return 0 }
    let mut result = n * n
    let mut temp = n
    let mut p = 2
    while p * p <= temp {
        if temp % p == 0 {
            result = result / (p * p) * (p * p - 1)
            while temp % p == 0 { temp = temp / p }
        }
        p = p + 1
    }
    if temp > 1 {
        result = result / (temp * temp) * (temp * temp - 1)
    }
    result
}

println("══════════════════════════════════════════════════════════════════════")
println("  F2 Euler product J₂(n) = n²·∏(1 − 1/p²)")
println("══════════════════════════════════════════════════════════════════════")

// Table
println("")
println("## J_2(n) in [1, 20]")
println("   n | J₂(n) | n²")
let mut n = 1
while n <= 20 {
    let j2 = jordan_j2(n)
    println("  " + to_string(n) + "\t| " + to_string(j2) + "\t| " + to_string(n * n))
    n = n + 1
}

// J_2(6) = 6²·(1−1/4)·(1−1/9) = 36·3/4·8/9 = 24
let j26 = jordan_j2(6)
assert j26 == 24
println("")
println("  J₂(6) = " + to_string(j26) + " = 24 = σ(6)·φ(6)  ★ double identity")

// J_2(n) / φ(n)² ratio for small n
println("")
println("## J₂(n) vs φ(n)²")
println("   n | J₂    | φ²")
let mut k = 1
while k <= 12 {
    let j2 = jordan_j2(k)
    let ph = phi(k)
    println("  " + to_string(k) + "\t| " + to_string(j2) + "\t| " + to_string(ph * ph))
    k = k + 1
}

// Connection: J_2 = Jordan totient = φ for n=p prime gives p²−1
println("")
println("## Prime check: J₂(p) = p² − 1")
let primes = [2, 3, 5, 7, 11, 13]
let mut i = 0
while i < len(primes) {
    let p = primes[i]
    let j2 = jordan_j2(p)
    let expected = p * p - 1
    assert j2 == expected
    println("  J₂(" + to_string(p) + ") = " + to_string(j2) + " = " + to_string(p) + "² − 1 ✓")
    i = i + 1
}

// Sum J_2 over n ≤ 20
let mut s = 0
let mut m = 1
while m <= 20 {
    s = s + jordan_j2(m)
    m = m + 1
}
println("")
println("  Σ J₂(n) for n∈[1,20] = " + to_string(s))

// σφ vs J2 master connection
println("")
println("## Master: σ(n)·φ(n) vs J₂(n)")
println("   n | σφ   | J₂   | equal?")
let mut q = 1
while q <= 12 {
    let sp = sigma(q) * phi(q)
    let j2 = jordan_j2(q)
    let eq = if sp == j2 { "★" } else { "" }
    println("  " + to_string(q) + "\t| " + to_string(sp) + "\t| " + to_string(j2) + "\t|  " + eq)
    q = q + 1
}

println("")
println("SUMMARY: J₂(6)=24=σ(6)·φ(6); Jordan totient connects Euler product to n=6.")
