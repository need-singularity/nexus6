// 포팅 원본: tecs-l/math/task1_fast.py (325 LOC)
// Fast exact pi_R(x) computation
// R(p^a) = (p^(a+1) - 1) / (p * (a+1))
// Uses log-sums for fast comparison, exact num/den for collision detection
// Reduced limits for interpreter speed

// --- sieve of primes up to limit ---
fn sieve_primes(limit: int) -> list {
    let mut sieve = []
    let mut i = 0
    while i <= limit {
        sieve = sieve + [1]
        i = i + 1
    }
    sieve[0] = 0
    sieve[1] = 0
    let mut p = 2
    while p * p <= limit {
        if sieve[p] == 1 {
            let mut j = p * p
            while j <= limit {
                sieve[j] = 0
                j = j + p
            }
        }
        p = p + 1
    }
    let mut primes = []
    let mut k = 2
    while k <= limit {
        if sieve[k] == 1 { primes = primes + [k] }
        k = k + 1
    }
    primes
}

// --- count primes up to n ---
fn count_primes_up_to(primes: list, n: int) -> int {
    let mut c = 0
    let mut i = 0
    while i < len(primes) {
        if primes[i] <= n { c = c + 1 }
        else { return c }
        i = i + 1
    }
    c
}

// --- pi_R_float: float-based counting with exact collision detection ---
// Returns count of distinct R-products <= x_max
// Uses DFS with log-based pruning, exact num/den for uniqueness
fn pi_R_float(x_max: int, primes: list) -> int {
    let log_x = log(to_float(x_max))

    // Build generators per prime: list of [log_val, rpa_num, rpa_den]
    let mut generators = []
    let mut pi = 0
    while pi < len(primes) {
        let p = primes[pi]
        let mut p_gens = []
        let mut a = 1
        while a < 15 {
            let rpa_num = pow(p, a + 1) - 1
            let rpa_den = p * (a + 1)
            let ratio_f = to_float(rpa_num) / to_float(rpa_den)
            if ratio_f > to_float(x_max) { break }
            let log_rpa = log(to_float(rpa_num)) - log(to_float(rpa_den))
            p_gens = p_gens + [[log_rpa, rpa_num, rpa_den]]
            a = a + 1
        }
        if len(p_gens) > 0 {
            generators = generators + [p_gens]
        }
        let check_num = p * p - 1
        let check_den = 2 * p
        if to_float(check_num) / to_float(check_den) > to_float(x_max) { break }
        pi = pi + 1
    }

    // DFS using a map of rounded-log -> [num, den] for collision detection
    // Key: round(log, 8) as string
    let mut log_set = #{}
    log_set["0.00000000"] = [1, 1]
    let mut total_count = 1

    // Iterative DFS with explicit stack using index pointer (avoid costly pop)
    // Stack entries: [gen_idx, log_current, num_current, den_current]
    let mut stack = [[0, 0.0, 1, 1]]
    let mut sp = 0

    while sp < len(stack) {
        let entry = stack[sp]
        sp = sp + 1

        let gen_idx = entry[0]
        let log_current = entry[1]
        let num_current = entry[2]
        let den_current = entry[3]

        let mut gi = gen_idx
        while gi < len(generators) {
            let p_gens = generators[gi]
            let mut ai = 0
            while ai < len(p_gens) {
                let gen = p_gens[ai]
                let log_rpa = gen[0]
                let rpa_num = gen[1]
                let rpa_den = gen[2]
                let new_log = log_current + log_rpa
                if new_log > log_x + 0.0000000001 { break }

                let new_num = num_current * rpa_num
                let new_den = den_current * rpa_den
                let g = gcd(new_num, new_den)
                let red_num = new_num / g
                let red_den = new_den / g

                // Use num/den pair as unique key (exact)
                let key = to_string(red_num) + "/" + to_string(red_den)

                if !has_key(log_set, key) {
                    log_set[key] = [red_num, red_den]
                    total_count = total_count + 1
                    stack = stack + [[gi + 1, new_log, red_num, red_den]]
                }
                ai = ai + 1
            }
            gi = gi + 1
        }
    }

    total_count
}

// --- format float to 4 decimal places (simple) ---
fn fmt4(x: float) -> string {
    let scaled = round(x * 10000.0)
    let int_part = floor(x)
    let frac = scaled - int_part * 10000.0
    let frac_i = to_int(frac)
    let mut frac_s = to_string(frac_i)
    while len(frac_s) < 4 { frac_s = "0" + frac_s }
    to_string(to_int(int_part)) + "." + frac_s
}

// --- pad string to width ---
fn pad_right(s: string, w: int) -> string {
    let mut r = s
    while len(r) < w { r = r + " " }
    r
}

fn pad_left(s: string, w: int) -> string {
    let mut r = s
    while len(r) < w { r = " " + r }
    r
}

// --- main analysis ---
fn analyze_growth_rate() {
    let sep = "======================================================================"
    println(sep)
    println("pi_R(x) GROWTH RATE ANALYSIS (FAST VERSION — HEXA PORT)")
    println(sep)

    let primes = sieve_primes(1000)

    // Reduced x values for interpreter speed (x>100 too slow in hexa interpreter)
    let x_vals = [10, 20, 50, 100]

    println("")
    println("Float-based counting with exact collision detection:")
    let header = pad_left("x", 8) + pad_left("pi_R(x)", 10) + pad_left("pi(2x)", 8) + pad_left("ratio", 10) + pad_left("lnlnx", 10)
    println(header)
    println("------------------------------------------------------")

    let mut i = 0
    while i < len(x_vals) {
        let x = x_vals[i]
        let pi_x = pi_R_float(x, primes)
        let pi_2x = count_primes_up_to(primes, 2 * x)
        let mut ratio = 0.0
        if pi_2x > 0 { ratio = to_float(pi_x) / to_float(pi_2x) }
        let lnx = log(to_float(x))
        let lnlnx = log(lnx)

        let line = pad_left(to_string(x), 8) + pad_left(to_string(pi_x), 10) + pad_left(to_string(pi_2x), 8) + pad_left(fmt4(ratio), 10) + pad_left(fmt4(lnlnx), 10)
        println(line)
        i = i + 1
    }
}

fn print_heuristic() {
    println("")
    let sep = "======================================================================"
    println(sep)
    println("WHY COMPOSITES CONTRIBUTE ~ ln(ln x) EXTRA")
    println(sep)
    println("")
    println("HEURISTIC DERIVATION:")
    println("")
    println("P_1(x) = pi(2x+1) ~ 2x/ln(x)")
    println("P_2(x) ~ (2x/ln x) * ln ln x / 2")
    println("P_k(x) ~ (2x/ln x) * (ln ln x)^(k-1) / k!   [Selberg-Sathe analog]")
    println("")
    println("Total:")
    println("  pi_R(x) ~ sum_{k>=1} P_k(x)")
    println("          ~ (2x/ln x) * (e^(ln ln x) - 1) / ln ln x")
    println("          ~ 2x / ln ln x   (dominant term)")
    println("")
    println("NUMERICAL EVIDENCE:")
    println("  x=100:  ratio pi_R/pi(2x) ~ 10.8")
    println("  x=500:  ratio pi_R/pi(2x) ~ 14.0")
    println("  x=1000: ratio pi_R/pi(2x) ~ 15.7")
    println("  x=5000: ratio pi_R/pi(2x) ~ 19.5")
    println("")
    println("The true asymptotic is:")
    println("  pi_R(x) = Theta(x / ln(x)^beta)  for some 0 < beta < 1")
}

fn verify_form() {
    println("")
    println("Verification: pi_R(x) vs C * x * ln(ln x) / ln(x):")
    let header = pad_left("x", 8) + pad_left("pi_R(x)", 10) + pad_left("form", 12) + pad_left("ratio", 10)
    println(header)
    println("----------------------------------------")

    let primes = sieve_primes(1000)
    let x_vals = [50, 100]

    let mut i = 0
    while i < len(x_vals) {
        let x = x_vals[i]
        let pi_x = pi_R_float(x, primes)
        let lnx = log(to_float(x))
        let lnlnx = log(lnx)
        let form = to_float(x) * lnlnx / lnx
        let ratio = to_float(pi_x) / form
        let line = pad_left(to_string(x), 8) + pad_left(to_string(pi_x), 10) + pad_left(fmt4(form), 12) + pad_left(fmt4(ratio), 10)
        println(line)
        i = i + 1
    }
}

// --- entry point ---
fn main() {
    analyze_growth_rate()
    print_heuristic()
    verify_form()
    println("")
    println("Done.")
}

main()
