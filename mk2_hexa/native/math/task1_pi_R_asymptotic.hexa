// SQUAREFREE ANALYSIS
// ══════════════════════════════════════════════════════

println("")
println(sep60)
println("SQUAREFREE ANALYSIS")
println(sep60)

println("")
println("Squarefree 2-prime products R(pq):")
let sqhdr = pad_left("p", 4) + pad_left("q", 4) + pad_left("R(p)", 10) + pad_left("R(q)", 10) + pad_left("R(pq)", 12)
println(sqhdr)

let mut si = 0
while si < 8 && si < len(primes) {
    let p = primes[si]
    let rp = to_float(p * p - 1) / to_float(2 * p)
    let mut sj = si + 1
    let sj_end = si + 5
    while sj < sj_end && sj < len(primes) {
        let q = primes[sj]
        let rq = to_float(q * q - 1) / to_float(2 * q)
        let rpq = rp * rq
        let sqline = pad_left(to_string(p), 4) + pad_left(to_string(q), 4) + pad_left(fmt(rp, 4), 10) + pad_left(fmt(rq, 4), 10) + pad_left(fmt(rpq, 4), 12)
        println(sqline)
        sj = sj + 1
    }
    si = si + 1
}

// ── R values by type (n <= 500) ──
println("")
println("R values by type (n <= 500):")

let mut count_unit = 0
let mut count_sq1 = 0
let mut count_sq2 = 0
let mut count_sq3 = 0
let mut count_nonsq = 0

let mut ni = 1
while ni <= 500 {
    let factors = factorize(ni)
    let omega = len(factors) / 2
    let mut max_exp = 0
    let mut fi = 1
    while fi < len(factors) {
        if factors[fi] > max_exp { max_exp = factors[fi] }
        fi = fi + 2
    }
    if ni == 1 {
        count_unit = count_unit + 1
    } else {
        if max_exp == 1 {
            if omega == 1 { count_sq1 = count_sq1 + 1 }
            if omega == 2 { count_sq2 = count_sq2 + 1 }
            if omega >= 3 { count_sq3 = count_sq3 + 1 }
        } else {
            count_nonsq = count_nonsq + 1
        }
    }
    ni = ni + 1
}

println("  n=1:            " + to_string(count_unit) + " values")
println("  squarefree-1:   " + to_string(count_sq1) + " values")
println("  squarefree-2:   " + to_string(count_sq2) + " values")
println("  squarefree-3+:  " + to_string(count_sq3) + " values")
println("  non-squarefree: " + to_string(count_nonsq) + " values")

