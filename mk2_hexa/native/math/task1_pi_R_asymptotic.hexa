let N_MAX = 2500
let sep60 = repeat_str("=", 60)
let sep70 = repeat_str("-", 70)
let sep50 = repeat_str("-", 50)

println(sep60)
println("TASK 1: pi_R(x) ASYMPTOTIC ANALYSIS")
println(sep60)

// ── Step 1: R(n) 전수 계산 ──
println("")
println("Computing R(n) for n=1.." + to_string(N_MAX) + "...")

let mut r_values = []
let mut r_min = 999999.0
let mut r_max = 0.0
let mut n = 1
while n <= N_MAX {
    let r = compute_R(n)
    r_values = r_values + [r]
    if r < r_min { r_min = r }
    if r > r_max { r_max = r }
    n = n + 1
}

println("R(n) range: [" + fmt(r_min, 4) + ", " + fmt(r_max, 4) + "]")

// ── Step 2: asymptotic table ──
let x_test = [10, 20, 50, 100, 200, 500, 1000]

println("")
println(sep70)
let hdr = pad_left("x", 8) + pad_left("pi_R(x)", 10) + pad_left("x*sqrt(ln x)", 14) + pad_left("ratio", 10) + pad_left("x/ln(x)", 10) + pad_left("ratio2", 10)
println(hdr)
println(sep70)

let mut results_x = []
let mut results_pi = []
let mut results_r1 = []
let mut results_r2 = []

let mut idx = 0
while idx < len(x_test) {
    let x = x_test[idx]
    let xf = to_float(x)

    // count distinct R values <= x
    let pi_x = count_distinct_R(N_MAX, xf)

    let lnx = my_ln(xf)
    let x_sqrtlnx = xf * my_sqrt(lnx)
    let ratio = to_float(pi_x) / x_sqrtlnx
    let x_over_lnx = xf / lnx
    let ratio2 = to_float(pi_x) / x_over_lnx

    results_x = results_x + [x]
    results_pi = results_pi + [pi_x]
    results_r1 = results_r1 + [ratio]
    results_r2 = results_r2 + [ratio2]

    let line = pad_left(to_string(x), 8) + pad_left(to_string(pi_x), 10) + pad_left(fmt(x_sqrtlnx, 2), 14) + pad_left(fmt(ratio, 4), 10) + pad_left(fmt(x_over_lnx, 2), 10) + pad_left(fmt(ratio2, 4), 10)
    println(line)

    idx = idx + 1
}
println(sep70)

// ── x/(ln x)^1.5 table ──
println("")
println(sep50)
let hdr2 = pad_left("x", 8) + pad_left("pi_R(x)", 10) + pad_left("x/(lnx)^1.5", 14) + pad_left("ratio", 10)
println(hdr2)
println(sep50)

let mut j = 0
while j < len(results_x) {
    let x = results_x[j]
    let xf = to_float(x)
    let pi_x = results_pi[j]
    let lnx = my_ln(xf)
    let denom = xf / (lnx * my_sqrt(lnx))
    let r = to_float(pi_x) / denom
    let line2 = pad_left(to_string(x), 8) + pad_left(to_string(pi_x), 10) + pad_left(fmt(denom, 2), 14) + pad_left(fmt(r, 4), 10)
    println(line2)
    j = j + 1
}
println(sep50)

