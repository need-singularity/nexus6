// PRIME CONTRIBUTION ANALYSIS
// ══════════════════════════════════════════════════════

println("")
println(sep60)
println("PRIME CONTRIBUTION ANALYSIS")
println(sep60)

let primes = sieve_primes(2000)

println("")
println("R(p) = (p^2-1)/(2p) values for small primes:")
let phdr = pad_left("p", 6) + pad_left("R(p) float", 12) + pad_left("p/2", 8)
println(phdr)

let mut pi = 0
while pi < 20 && pi < len(primes) {
    let p = primes[pi]
    let rp = to_float(p * p - 1) / to_float(2 * p)
    let half = to_float(p) / 2.0
    let pline = pad_left(to_string(p), 6) + pad_left(fmt(rp, 4), 12) + pad_left(fmt(half, 4), 8)
    println(pline)
    pi = pi + 1
}

println("")
println("Prime-only pi_R(x) analysis:")
println("R(p) <= x iff p ~ 2x (since R(p) ~ p/2)")
println("")
let phdr2 = pad_left("x", 8) + pad_left("primes R(p)<=x", 18) + pad_left("pi(2x)", 10) + pad_left("2x/ln(2x)", 12)
println(phdr2)
println(repeat_str("-", 55))

let x_vals = [10, 50, 100, 500, 1000]
let mut xi = 0
while xi < len(x_vals) {
    let x = x_vals[xi]
    let xf = to_float(x)
    // count primes with R(p) <= x
    let mut count = 0
    let mut pi2x = 0
    let mut pk = 0
    while pk < len(primes) {
        let p = primes[pk]
        let rp = to_float(p * p - 1) / to_float(2 * p)
        if rp <= xf { count = count + 1 }
        if p <= 2 * x { pi2x = pi2x + 1 }
        pk = pk + 1
    }
    let asymp = 2.0 * xf / my_ln(2.0 * xf)
    let pline2 = pad_left(to_string(x), 8) + pad_left(to_string(count), 18) + pad_left(to_string(pi2x), 10) + pad_left(fmt(asymp, 2), 12)
    println(pline2)
    xi = xi + 1
}

