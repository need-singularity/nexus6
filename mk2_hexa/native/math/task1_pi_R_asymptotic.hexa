// 포팅 원본: tecs-l/math/task1_pi_R_asymptotic.py (311 LOC)
//
// Task 1: π_R(x) 점근선 분석
// π_R(x) = x 이하 서로 다른 R(n) 값의 개수
// R(n) = σ(n)·φ(n) / (n·τ(n))
//
// R은 곱셈적: R(p^a) = (p^(a+1)-1) / (p·(a+1))
// 특수 경우: R(p) = (p²-1)/(2p)
//
// 범위: N=2500 (인터프리터 속도 감안, Python 50k → hexa 2500)

// ── math helpers ──
fn my_sqrt(x: float) -> float {
    sqrt(x)
}

fn my_ln(x: float) -> float {
    log(x)
}

fn my_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    x
}

fn fmt(x: float, decimals: int) -> string {
    // hexa에는 포맷 내장 없으므로 to_string 사용
    to_string(x)
}

fn pad_left(s: string, width: int) -> string {
    let mut result = s
    while len(result) < width {
        result = " " + result
    }
    result
}

fn repeat_str(s: string, n: int) -> string {
    let mut result = ""
    let mut i = 0
    while i < n {
        result = result + s
        i = i + 1
    }
    result
}

// ── factorization ──
fn factorize(n: int) -> [int] {
    // 반환: [p1, a1, p2, a2, ...] 형태의 flat 배열
    let mut result = []
    let mut temp = n
    let mut d = 2
    while d * d <= temp {
        let mut count = 0
        while temp % d == 0 {
            count = count + 1
            temp = temp / d
        }
        if count > 0 {
            result = result + [d, count]
        }
        d = d + 1
    }
    if temp > 1 {
        result = result + [temp, 1]
    }
    result
}

// ── R(n) as float (σ(n)·φ(n) / (n·τ(n))) ──
fn compute_R(n: int) -> float {
    if n == 1 { return 1.0 }
    let s = sigma(n)
    let p = phi(n)
    let t = tau(n)
    to_float(s) * to_float(p) / (to_float(n) * to_float(t))
}

// ── R(p^a) exact as numerator/denominator pair ──
// R(p^a) = (p^(a+1)-1) / (p·(a+1))
fn R_prime_power_num(p: int, a: int) -> int {
    pow(p, a + 1) - 1
}

fn R_prime_power_den(p: int, a: int) -> int {
    p * (a + 1)
}

// ── R as rational (numerator, denominator) via factorization ──
fn compute_R_rational(n: int) -> [int] {
    if n == 1 { return [1, 1] }
    let factors = factorize(n)
    let mut num = 1
    let mut den = 1
    let mut i = 0
    while i < len(factors) {
        let p = factors[i]
        let a = factors[i + 1]
        num = num * R_prime_power_num(p, a)
        den = den * R_prime_power_den(p, a)
        i = i + 2
    }
    // simplify with gcd
    let g = gcd(num, den)
    [num / g, den / g]
}

// ── sieve of primes ──
fn sieve_primes(limit: int) -> [int] {
    let mut is_p = []
    let mut i = 0
    while i <= limit {
        if i < 2 {
            is_p = is_p + [false]
        } else {
            is_p = is_p + [true]
        }
        i = i + 1
    }
    let mut j = 2
    while j * j <= limit {
        if is_p[j] {
            let mut k = j * j
            while k <= limit {
                is_p[k] = false
                k = k + j
            }
        }
        j = j + 1
    }
    let mut primes = []
    let mut m = 2
    while m <= limit {
        if is_p[m] {
            primes = primes + [m]
        }
        m = m + 1
    }
    primes
}

// ── count distinct R values up to x ──
// 유리수를 문자열 키로 집합 관리 (#{} map 사용)
fn count_distinct_R(n_max: int, x_limit: float) -> int {
    let mut seen = #{}
    let mut n = 1
    while n <= n_max {
        let rv = compute_R(n)
        if rv <= x_limit + 0.0001 {
            // 유리수로 정확한 키 생성
            let rat = compute_R_rational(n)
            let key = to_string(rat[0]) + "/" + to_string(rat[1])
            seen[key] = true
        }
        n = n + 1
    }
    len(keys(seen))
}

