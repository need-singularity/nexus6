while i0_10 < 10 {
    let i0 = to_float(i0_10) / 10.0
    let mut cur = i0
    let mut seasons = [i0]
    let mut step = 0
    while step < TAU_VAL {
        cur = 0.7 * cur + 0.1
        seasons = seasons.push(cur)
        step = step + 1
