// ─── 헬퍼 함수 ───
fn abs_f(x: float) -> float {
    if x < 0.0 { 0.0 - x } else { x }
}

fn factorial(n: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= n {
        r = r * i
        i = i + 1
    }
    r
}

fn fibonacci(k: int) -> int {
    let mut a = 0
    let mut b = 1
    let mut i = 0
    while i < k {
        let t = b
        b = a + b
        a = t
        i = i + 1
    }
    a
}

fn pad_right(s: string, w: int) -> string {
    let mut out = s
    while len(out) < w {
        out = out + " "
    }
    out
}

fn pad_left(s: string, w: int) -> string {
    let mut out = s
    while len(out) < w {
        out = " " + out
    }
    out
}

fn float_str(v: float, decimals: int) -> string {
    // simple formatting: multiply, round, split
    let mult = pow(10.0, to_float(decimals))
    let rounded = round(v * mult)
    let int_part = to_int(rounded)
    let is_neg = int_part < 0
    let abs_int = if is_neg { 0 - int_part } else { int_part }
    let whole = abs_int / to_int(mult)
    let frac = abs_int % to_int(mult)
    let mut frac_s = to_string(frac)
    while len(frac_s) < decimals {
        frac_s = "0" + frac_s
    }
    let sign = if is_neg { "-" } else { "" }
    sign + to_string(whole) + "." + frac_s
}

