let diff1 = abs_f(c07_4 - gz_lower)
let pct1 = diff1 / gz_lower * 100.0
println("Difference: " + float_str(diff1, 6) + " (" + float_str(pct1, 1) + "% error)")
println("")
println("RESULT: After exactly tau=4 iterations, ALL starting points converge")
println("        to within " + float_str(max_err, 4) + " of the fixed point 1/3.")
