    let error = abs_f(cur - 1.0 / 3.0)
    errors = errors.push(error)
    let line = pad_left(float_str(i0, 3), 8) + " " + pad_left(float_str(seasons[1], 4), 8) + " " + pad_left(float_str(seasons[2], 4), 8) + " " + pad_left(float_str(seasons[3], 4), 8) + " " + pad_left(float_str(seasons[4], 4), 8) + " " + pad_left(float_str(error, 6), 10)
    println(line)
    i0_10 = i0_10 + 1
}

let mut sum_err = 0.0
let mut max_err = 0.0
let mut ei = 0
while ei < len(errors) {
    sum_err = sum_err + errors[ei]
    if errors[ei] > max_err { max_err = errors[ei] }
    ei = ei + 1
}
let avg_err = sum_err / to_float(len(errors))

println("")
println("Average error after tau=4 seasons: " + float_str(avg_err, 6))
println("Maximum error after tau=4 seasons: " + float_str(max_err, 6))
let c07_4 = pow(0.7, 4.0)
