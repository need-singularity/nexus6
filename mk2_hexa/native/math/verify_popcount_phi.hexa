// Ported from tecs-l/math/verify_popcount_phi.py
// THEOREM: popcount(n) = phi(n) has solutions exactly {1, 2, 3, 6} = divisors of 6.

// @pure
fn popcount(n: int) -> int {
    let mut x = n
    let mut c = 0
    while x > 0 {
        c = c + (x % 2)
        x = x / 2
    }
    c
}

// @pure
fn digit_sum_base(n: int, base: int) -> int {
    let mut x = n
    let mut s = 0
    while x > 0 {
        s = s + (x % base)
        x = x / base
    }
    s
}

println("══════════════════════════════════════════════════════════════════════")
println("  THEOREM: popcount(n) = phi(n)  <==>  n in {1, 2, 3, 6} = div(6)")
println("══════════════════════════════════════════════════════════════════════")

// Part 1: exhaustive check up to 10000 (hexa port — smaller range for speed)
let LIMIT = 10000
let mut solutions = []
let mut n = 1
while n <= LIMIT {
    if popcount(n) == phi(n) { solutions = solutions + [n] }
    n = n + 1
}
println("")
println("Solutions in [1, " + to_string(LIMIT) + "]: " + to_string(solutions))
println("Expected (divisors of 6)   : [1, 2, 3, 6]")

// Anchor verification for n=6
assert popcount(1) == phi(1)
assert popcount(2) == phi(2)
assert popcount(3) == phi(3)
assert popcount(6) == phi(6)
println("✓ {1,2,3,6} all satisfy popcount(n)=phi(n)")

// n=4,5 should fail
assert popcount(4) != phi(4)
assert popcount(5) != phi(5)
println("✓ n=4,5 do NOT satisfy (phi > popcount)")

// Near-miss table
println("")
println("Near-miss table (n=1..15):")
println("   n | pop(n) | phi(n) | gap")
println("  ---+--------+--------+-----")
let mut k = 1
while k <= 15 {
    let pc = popcount(k)
    let ph = phi(k)
    let gap = ph - pc
    let mark = if pc == ph { " ★" } else { "" }
    println("  " + to_string(k) + "\t|  " + to_string(pc) + "\t|  " + to_string(ph) + "\t| " + to_string(gap) + mark)
    k = k + 1
}

// Part 4 lite: base-b digit sum = phi(n)
println("")
println("Generalization: s_b(n) = phi(n) for bases b=2..6, n in [1,1000]")
let mut b = 2
while b <= 6 {
    let mut sols = []
    let mut m = 1
    while m <= 1000 {
        if digit_sum_base(m, b) == phi(m) { sols = sols + [m] }
        m = m + 1
    }
    println("  base " + to_string(b) + ": count=" + to_string(len(sols)) + "  first=" + to_string(sols))
    b = b + 1
}

println("")
println("SUMMARY: popcount = phi iff n ∈ div(6). n=6 anchor locked.")
