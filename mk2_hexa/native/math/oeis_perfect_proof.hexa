println("")
println("══════════════════════════════════════════════════════════════════════")
println("CHARACTERIZATION: R(n) = 1  (cross-ref with r_spectrum.hexa)")
println("══════════════════════════════════════════════════════════════════════")
println("")
println("  R(n) = σ·φ/(n·τ) = 1   ⇔   σ(n)·φ(n) = n·τ(n)")
println("  n=1: 1·1 = 1·1 = 1                           ✓")
println("  n=6: 12·2 = 6·4 = 24                         ✓")
println("  r_spectrum.hexa --find-eq 1 --N 10000 → [6]  ✓")
