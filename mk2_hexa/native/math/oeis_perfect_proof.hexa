// ─── OEIS submission drafts ───
println("")
println("══════════════════════════════════════════════════════════════════════")
println("OEIS SUBMISSION DRAFTS")
println("══════════════════════════════════════════════════════════════════════")
println("")
println("Sequence A: Numbers n such that R(n) is integer.")
println("  Formula: R(n) = σ(n)·φ(n)/(n·τ(n))")
println("  Contains all even perfect numbers (via Fermat's little theorem).")
println("  Cf. A000203, A000010, A000005, A000396.")
println("")
println("Sequence D: Fixed points of n → τ(σ(n))")
let fixed = [1, 2, 3, 6]
let mut f = 0
while f < len(fixed) {
    let nn = fixed[f]
    let val = tau(sigma(nn))
    println("  n=" + to_string(nn) + ": τ(σ(" + to_string(nn) + ")) = τ(" + to_string(sigma(nn)) + ") = " + to_string(val) + "  (n? " + (if val == nn { "YES" } else { "NO" }) + ")")
    f = f + 1
}
println("  Appears to contain only divisors of 6.")
