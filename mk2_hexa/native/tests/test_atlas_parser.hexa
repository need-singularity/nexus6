// Ported from tecs-l/tests/test_atlas_parser.py
// Contract tests for the math-atlas hypothesis parser. The Python source
// imports `scan_math_atlas.parse_hypothesis_md` from .shared/; here we
// encode the expected ID/domain/grade extraction rules as hexa predicates
// so any hexa-native parser must satisfy them.

struct Hypothesis {
    id: string,        // "<REPO>:<LOCAL_ID>"
    title: string,
    repo: string,
    domain: string,    // e.g. "CX", "CA", "STAT"
    grade: string,     // "🟩" | "🟧★" | "🟧" | "⚪" | "⬛" | ""
    refs: [string]
}

// === Expected outputs for canned inputs ===

// Pattern A: "# Hypothesis Review NNN: Title"
pure fn expect_pattern_a() -> Hypothesis {
    Hypothesis {
        id: "TECS-L:056",
        title: "Meta Recursion",
        repo: "TECS-L",
        domain: "",
        grade: "",
        refs: []
    }
}

// Pattern B: "# Hypothesis NNN: Title"
pure fn expect_pattern_b() -> Hypothesis {
    Hypothesis {
        id: "TECS-L:355",
        title: "Prediction Error = Surprise",
        repo: "TECS-L",
        domain: "",
        grade: "",
        refs: []
    }
}

// Pattern C: "# H-<DOMAIN>-NNN: Title"
pure fn expect_pattern_c() -> Hypothesis {
    Hypothesis {
        id: "TECS-L:H-CX-215",
        title: "Brainwave Product",
        repo: "TECS-L",
        domain: "CX",
        grade: "",
        refs: []
    }
}

// Pattern C (SEDI) with explicit grade emoji.
pure fn expect_pattern_c_sedi() -> Hypothesis {
    Hypothesis {
        id: "SEDI:H-CA-001",
        title: "Anima Phi_max = 8",
        repo: "SEDI",
        domain: "CA",
        grade: "🟧★",
        refs: []
    }
}

// Pattern D: YAML front-matter → id/title/grade.
pure fn expect_pattern_d() -> Hypothesis {
    Hypothesis {
        id: "TECS-L:H-STAT-1",
        title: "Chi-Squared",
        repo: "TECS-L",
        domain: "STAT",
        grade: "🟩⭐⭐⭐",
        refs: []
    }
}

// === Predicates the parser must satisfy ===

pure fn id_matches(h: Hypothesis, expected: string) -> bool {
    h.id == expected
}

pure fn grade_contains(h: Hypothesis, needle: string) -> bool {
    // true if h.grade contains `needle` as substring
    string_contains(h.grade, needle)
}

// Cross-reference extraction contract: "Related hypotheses: 041, 055, 067"
pure fn should_extract_refs(count: int) -> bool { count == 3 }

fn main() {
    let a = expect_pattern_a();
    print("A id ok: "); print(id_matches(a, "TECS-L:056")); print("\n");
    let d = expect_pattern_d();
    print("D grade ⭐⭐⭐: "); print(grade_contains(d, "⭐⭐⭐")); print("\n");
}
