    target: string,       // 빠른 도달 목표 (측정 가능)
    strategy: string,     // 장기 전략 (방향성)
    priority: int,        // 현재 우선순위 (0=낮음, 10=긴급)
    status: string        // idle|running|stagnant|breakthrough
}

