// nexus_hub.hexa — 중앙 톱니바퀴 (Central Gear)
// 10개 프로젝트를 자율 조율하는 메타 오케스트레이터
// 사용: hexa nexus_hub.hexa status|tick|report|crossfeed

// ─── 설정 ───

comptime const VERSION = "1.0.0"
comptime const MAX_CONCURRENT = 2
comptime const BURST_CONCURRENT = 4
comptime const HUB_INTERVAL_SEC = 300

let HOME = env("HOME")
let DEV = HOME + "/Dev"
let HEXA = DEV + "/hexa-lang/target/release/hexa"
let ENGINE_DIR = DEV + "/nexus6/mk2_hexa/native"
let BUS_FILE = DEV + "/nexus6/shared/growth_bus.jsonl"

// ─── 프로젝트 레지스트리 ───

