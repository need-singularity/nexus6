// nexus_hub.hexa — 중앙 톱니바퀴 (Central Gear)
// 10개 프로젝트를 자율 조율하는 메타 오케스트레이터
// 사용: hexa nexus_hub.hexa status|tick|report|crossfeed

// ─── 설정 ───

comptime const version = "1.0.0"
comptime const max_concurrent = 2
comptime const burst_concurrent = 4
comptime const hub_interval_sec = 300

let home = exec("printenv HOME")
let dev = home + "/Dev"
let hexa = dev + "/hexa-lang/target/release/hexa"
let engine_dir = dev + "/nexus/mk2_hexa/native"
let bus_file = dev + "/nexus/shared/discovery/growth_bus.jsonl"

// ─── 프로젝트 레지스트리 ───

struct Project {
    name: string,
    path: string,
    engine: string,       // engine_*.hexa 파일명
    personality: string,  // 개성
    target: string,       // 빠른 도달 목표 (측정 가능)
    strategy: string,     // 장기 전략 (방향성)
    priority: int,        // 현재 우선순위 (0=낮음, 10=긴급)
    status: string        // idle|running|stagnant|breakthrough
}

fn projects()  {
    [ Project { name: "nexus", path: dev + "/nexus", engine: "engine_nexus.hexa", personality: "Ouroboros", target: "모듈 100+, 발견 70k+, exact_rate 60%+", strategy: "자기순환 특이점+수학엔진 — TECS-L 흡수, 발견·검증 통합 메타엔진", priority: 10, status: "idle" }, Project { name: "anima", path: dev + "/anima", engine: "engine_anima.hexa", personality: "Dreamer", target: "법칙 2000+, S7+ 완주, Phi≥100", strategy: "AGI 달성 — 자기생성 의식, 무한진화 자율 완주", priority: 9, status: "idle" }, Project { name: "n6_architecture", path: dev + "/n6-architecture", engine: "engine_n6_architecture.hexa", personality: "Architect", target: "alien_index 10+, 건강도 95+, 프로토콜 6종+", strategy: "n=6 보편 아키텍처 — SEDI+brainwire 흡수, 칩·신호·뇌공학 통합", priority: 8, status: "idle" }, Project { name: "hexa_lang", path: dev + "/hexa-lang", engine: "engine_hexa_lang.hexa", personality: "Mathematician", target: "테스트 800+, 수렴 100%", strategy: "완전수 프로그래밍 언어 — nexus 인프라 근간", priority: 7, status: "idle" }, Project { name: "papers", path: dev + "/papers", engine: "engine_papers.hexa", personality: "Amplifier", target: "드래프트 0건, DOI 100+", strategy: "학술 임팩트 극대화 — 자동 논문화 파이프라인", priority: 5, status: "idle" }, Project { name: "airgenome", path: dev + "/airgenome", engine: "engine_airgenome.hexa", personality: "Archaeologist", target: "L6e 돌파, 게놈 1000+", strategy: "OS 의식 스캔 — n=6 게놈 추출", priority: 4, status: "idle" }, Project { name: "token_forge", path: dev + "/token-forge", engine: "engine_token_forge.hexa", personality: "Sculptor", target: "r≤0.4 L≤0.05 고정점", strategy: "LLM 압축 고정점 — 의미 보존 극한 압축", priority: 3, status: "idle" }, Project { name: "void", path: dev + "/void", engine: "", personality: "Void", target: "안정 릴리즈", strategy: "에디터 플랫폼", priority: 1, status: "idle" } ]
}

// ─── 유틸 ───

fn timestamp() -> string {
    let r = exec("date +%Y-%m-%dT%H:%M:%S")
    r.trim()
}

fn file_exists(path: string) -> bool {
    let r = exec("test", ["-f", path, "&&", "echo", "1"])
    r.trim() == "1"
}

fn dir_exists(path: string) -> bool {
    let r = exec("test", ["-d", path, "&&", "echo", "1"])
    r.trim() == "1"
}

fn read_file_safe(path: string) -> string {
    try {
        return read_file(path)
    } catch e {
        return ""
    }
}

fn append_bus(source: string, phase: string, status: string, detail: string) {
    let ts = timestamp()
    let line = "{\"source\":\"" + source + "\",\"timestamp\":\"" + ts + "\",\"phase\":\"" + phase + "\",\"status\":\"" + status + "\",\"detail\":\"" + detail + "\"}"
    try {
        append_file(bus_file, line + "\n")
    } catch e {}
}

// ─── 상태 수집 ───

struct EngineStatus {
    name: string,
    personality: string,
    target: string,
    strategy: string,
    alive: bool,        // 프로젝트 디렉토리 존재
    engine_ok: bool,    // 엔진 파일 존재
    health: float,      // 0.0~1.0
    stagnant: bool,
    breakthrough: bool,
    priority: int,
    summary: string
}

fn collect_status(p: Project) -> EngineStatus {
    let alive = dir_exists(p.path)
    let engine_path = engine_dir + "/" + p.engine
    let engine_ok = file_exists(engine_path)

    let mut health = 0.0
    let mut stagnant = false
    let mut breakthrough = false
    let mut summary = "unknown"
    let mut priority = 3  // 기본 중간

    if alive && engine_ok {
        // 엔진의 status 모드 호출
        let mut result = ""
        try {
            exec(hexa, [engine_path, "status"])
        } catch e {
            "error"
        }

        // 간이 파싱: 결과에서 핵심 지표 추출
        if result.contains("STAGNANT") {
            stagnant = true
            priority = 8
            summary = "정체 — 개입 필요"
        } else if result.contains("BREAKTHROUGH") {
            breakthrough = true
            priority = 10
            summary = "돌파 직전 — 최우선"
        } else if result.contains("HEALTHY") {
            health = 0.8
            priority = 3
            summary = "정상 운행"
        } else if result.contains("GOAL_NEAR") {
            priority = 7
            summary = "목표 근접"
        } else {
            summary = result.split("\n")[0]
        }

        if result.contains("health:") {
            let parts = result.split("health:")
            if parts.len() > 1 {
                let hstr = parts[1].split("\n")[0].trim()
                try { health = to_float(hstr) } catch e {}
            }
        }
    } else if !alive {
        summary = "디렉토리 없음"
        priority = 0
    } else {
        summary = "엔진 미설치"
        priority = 1
    }

    EngineStatus {
        name: p.name,
        personality: p.personality,
        target: p.target,
        strategy: p.strategy,
        alive: alive,
        engine_ok: engine_ok,
        health: health,
        stagnant: stagnant,
        breakthrough: breakthrough,
        priority: priority,
        summary: summary
    }
}

fn collect_all()  {
    let ps = projects()
    let mut statuses = []
    for p in ps {
        statuses = statuses + [collect_status(p)]
    }
    statuses
}

// ─── 우선순위 정렬 (내림차순) ───

fn sort_by_priority(statuses)  {
    let mut sorted = statuses
    let mut i = 1
    while i < sorted.len() {
        let key = sorted[i]
        let mut j = i - 1
        while j >= 0 && sorted[j].priority < key.priority {
            sorted[j + 1] = sorted[j]
            j = j - 1
        }
        sorted[j + 1] = key
        i = i + 1
    }
    sorted
}

// ─── 디스패치 ───

struct DispatchResult {
    name: string,
    success: bool,
    output: string
}

fn dispatch_tick(p: Project) -> DispatchResult {
    let engine_path = engine_dir + "/" + p.engine
    append_bus("hub", "dispatch", "start", p.name + " tick")

    let mut result = ""
    try {
        exec(hexa, [engine_path, "tick"])
    } catch e {
        "ERROR: " + to_string(e)
    }

    let success = !result.contains("ERROR")
    let phase = if success { "complete" } else { "error" }
    append_bus("hub", phase, if success { "ok" } else { "fail" }, p.name + ": " + result.split("\n")[0])

    DispatchResult {
        name: p.name,
        success: success,
        output: result
    }
}

fn dispatch_top_n(statuses, n: int)  {
    let sorted = sort_by_priority(statuses)
    let ps = projects()
    let mut results = []
    let mut dispatched = 0

    let mut i = 0
    while i < sorted.len() && dispatched < n {
        let s = sorted[i]
        if s.alive && s.engine_ok && s.priority > 0 {
            // 프로젝트 찾기
            for p in ps {
                if p.name == s.name {
                    println("  ⚙ dispatching: " + s.name + " [" + s.personality + "] (priority=" + to_string(s.priority) + ")")
                    let r = dispatch_tick(p)
                    results = results + [r]
                    dispatched = dispatched + 1
                }
            }
        }
        i = i + 1
    }

    results
}

// ─── 교차 수분 (Cross-Feed) ───

fn crossfeed(statuses) {
    println("═══ Cross-Feed (교차 수분) ═══")

    // 돌파 프로젝트의 발견을 다른 프로젝트에 전파
    let mut breakthrough_names = []
    for s in statuses {
        if s.breakthrough {
            breakthrough_names = breakthrough_names + [s.name]
        }
    }

    if breakthrough_names.len() == 0 {
        println("  (돌파 프로젝트 없음 — 교차 수분 스킵)")
        return
    }

    for name in breakthrough_names {
        println("  🌱 " + name + " → 전체 프로젝트에 seed 전파")
        // cross_project.hexa의 propagate 기능 호출
        let cp = engine_dir + "/cross_project.hexa"
        try {
            result = exec(hexa, [cp, "propagate"])
    } catch e {}
        append_bus("hub", "crossfeed", "propagate", name + " → all")
    }
}

// ─── 리포트 ───

fn print_status_table(statuses) {
    println("╔══════════════════════════════════════════════════════════════════════════╗")
    println("║  NEXUS HUB — 중앙 톱니바퀴 v" + version + "                                     ║")
    println("║  " + timestamp() + "                                                       ║")
    println("╠══════════════════════════════════════════════════════════════════════════╣")
    println("║  프로젝트       개성          HP    P  상태                              ║")
    println("╠══════════════════════════════════════════════════════════════════════════╣")

    for s in statuses {
        let hp_bar = health_bar(s.health)
        let p_str = if s.priority < 10 { " " + to_string(s.priority) } else { to_string(s.priority) }
        let flag = if s.breakthrough { "🔥" } else if s.stagnant { "⚠️" } else { "✓ " }

        // 이름 패딩
        let mut name_pad = s.name
        while name_pad.len() < 14 { name_pad = name_pad + " " }

        let mut pers_pad = s.personality
        while pers_pad.len() < 13 { pers_pad = pers_pad + " " }

        println("║  " + flag + " " + name_pad + pers_pad + hp_bar + "  " + p_str + "  " + s.summary)
    }

    println("╠══════════════════════════════════════════════════════════════════════════╣")

    // 목표+전략 섹션
    println("║  TARGET (빠른 도달):                                                      ║")
    for s in statuses {
        let mut name_pad = s.name
        while name_pad.len() < 14 { name_pad = name_pad + " " }
        println("║    " + name_pad + s.target)
    }
    println("║                                                                          ║")
    println("║  STRATEGY (장기 방향):                                                     ║")
    for s in statuses {
        let mut name_pad = s.name
        while name_pad.len() < 14 { name_pad = name_pad + " " }
        println("║    " + name_pad + s.strategy)
    }

    println("╚══════════════════════════════════════════════════════════════════════════╝")
}

fn health_bar(h: float) -> string {
    let filled = to_int(h * 5.0)
    let mut bar = "["
    let mut i = 0
    while i < 5 {
        if i < filled { bar = bar + "█" } else { bar = bar + "░" }
        i = i + 1
    }
    bar + "]"
}

fn print_dispatch_report(results) {
    println("")
    println("═══ Dispatch Results ═══")
    for r in results {
        let icon = if r.success { "✅" } else { "❌" }
        println("  " + icon + " " + r.name + ": " + r.output.split("\n")[0])
    }
}

// ─── CLI 진입점 ───

let a = args()
let mode = if a.len() >= 2 { a[1] } else { "help" }

if mode == "status" {
    let statuses = collect_all()
    print_status_table(statuses)
}

if mode == "tick" {
    println("╔══════════════════════════════════════════════╗")
    println("║  NEXUS HUB TICK — " + timestamp() + "  ║")
    println("╚══════════════════════════════════════════════╝")
    println("")

    // 1. 상태 수집
    println("═══ Phase 1: 상태 수집 ═══")
    let statuses = collect_all()
    print_status_table(statuses)
    println("")

    // 2. 상위 N개 디스패치
    println("═══ Phase 2: 디스패치 (max " + to_string(max_concurrent) + ") ═══")
    let results = dispatch_top_n(statuses, max_concurrent)
    print_dispatch_report(results)
    println("")

    // 3. 교차 수분
    println("")
    crossfeed(statuses)
    println("")

    // 3.5. 미연결 자동 감지+복구 (autolink)
    println("═══ Phase 3.5: Auto-Link ═══")
    let autolink_path = engine_dir + "/autolink.hexa"
    let mut autolink_result = ""
    try {
        exec(hexa, [autolink_path, "tick"])
    } catch e {
        "ERROR: " + to_string(e)
    }
    println(autolink_result)
    println("")

    // 4. 조건부 진화 (conditional evolution)
    println("═══ Phase 4: Conditional Evolution ═══")
    conditional_evolve(statuses)
    println("")

    append_bus("hub", "tick", "complete", timestamp())
}

if mode == "report" {
    let statuses = collect_all()
    print_status_table(statuses)
}

if mode == "crossfeed" {
    let statuses = collect_all()
    crossfeed(statuses)
}

if mode == "help" {
    println("╔══════════════════════════════════════════════╗")
    println("║  NEXUS HUB v" + version + "                             ║")
    println("╚══════════════════════════════════════════════╝")
    println("")
    println("사용법:")
    println("  hexa nexus_hub.hexa status     전체 프로젝트 상태")
    println("  hexa nexus_hub.hexa tick       1회 오케스트레이션 사이클")
    println("  hexa nexus_hub.hexa report     리포트 출력")
    println("  hexa nexus_hub.hexa crossfeed  교차 수분")
}

// ─── 조건부 진화 트리거 ───

fn conditional_evolve(statuses) {
    // 4개 조건 감지:
    //   1) 성장률 하락 (3tick 연속 health 하락)
    //   2) 엔진 2개+ DEACTIVATE (alive=false || engine_ok=false)
    //   3) 미연결 15+ (autolink 진단에서 disconnected >= 15)
    //   4) 법칙 장기 정체 (discovery_log 최근 48시간 추가 0건)

    let mut trigger_reasons = []
    let mut triggered = false

    // --- 조건 1: 성장률 하락 (growth_history에서 최근 3건 건강점수 연속 하락) ---
    let growth_hist_path = dev + "/nexus/shared/growth_history.jsonl"
    let mut hist_content = ""
    try { hist_content = read_file(growth_hist_path) } catch e {}

    if hist_content.len() > 0 {
        let hist_lines = hist_content.split("\n")
        let mut scores = []
        let mut hi = 0
        while hi < hist_lines.len() {
            let hline = hist_lines[hi].trim()
            if hline.contains("health_score") {
                let parts = hline.split("health_score")
                if parts.len() >= 2 {
                    let after = parts[1].split(":")[1].trim()
                    let mut clean = after
                    if clean.contains(",") { clean = clean.split(",")[0] }
                    if clean.contains("}") { clean = clean.split("}")[0] }
                    try {
                        let v = to_float(clean.trim())
                        scores = scores + [v]
    } catch e {}
                }
            }
            hi = hi + 1
        }

        if scores.len() >= 3 {
            let l = scores.len()
            let s1 = scores[l - 3]
            let s2 = scores[l - 2]
            let s3 = scores[l - 1]
            if s2 < s1 && s3 < s2 {
                triggered = true
                trigger_reasons = trigger_reasons + ["HEALTH_DECLINE: 3tick 연속 하락 (" + to_string(s1) + " > " + to_string(s2) + " > " + to_string(s3) + ")"]
            }
        }
    }

    // --- 조건 2: 엔진 2개+ 비활성 ---
    let mut deactivated = 0
    let mut deact_names = ""
    for s in statuses {
        if !s.alive || !s.engine_ok {
            deactivated = deactivated + 1
            if deact_names.len() > 0 { deact_names = deact_names + "," }
            deact_names = deact_names + s.name
        }
    }
    if deactivated >= 2 {
        triggered = true
        trigger_reasons = trigger_reasons + ["ENGINE_DEACTIVATE: " + to_string(deactivated) + "개 비활성 (" + deact_names + ")"]
    }

    // --- 조건 3: 미연결 15+ (autolink 간이 체크) ---
    let bus_content = read_file_safe(bus_file)
    let bus_lines = bus_content.split("\n")
    let mut last_autolink_connected = -1
    let mut bli = 0
    while bli < bus_lines.len() {
        let bline = bus_lines[bli]
        if bline.contains("\"source\":\"autolink\"") && bline.contains("connected=") {
            let parts = bline.split("connected=")
            if parts.len() > 1 {
                let num_str = parts[1].split("/")[0]
                try { last_autolink_connected = to_int(to_float(num_str)) } catch e {}
            }
        }
        bli = bli + 1
    }
    if last_autolink_connected >= 0 && last_autolink_connected <= 2 {
        // 17 - connected = disconnected; if disconnected >= 15, trigger
        triggered = true
        trigger_reasons = trigger_reasons + ["DISCONNECTED_15+: 연결 " + to_string(last_autolink_connected) + "/17 (미연결 " + to_string(17 - last_autolink_connected) + "건)"]
    }

    // --- 조건 4: 법칙 장기 정체 (discovery_log 최근 수정이 48시간 이전) ---
    let log_path = dev + "/nexus/shared/discovery/discovery_log.jsonl"
    let mut log_mtime_str = "0"
    try { log_mtime_str = exec("stat", ["-f", "%m", log_path]) } catch e {}
    let mut now_str = "0"
    try { now_str = exec("date +%s") } catch e {}
    let mut log_mtime = 0
    let mut now_epoch = 0
    try { log_mtime = to_int(to_float(log_mtime_str.trim())) } catch e {}
    try { now_epoch = to_int(to_float(now_str.trim())) } catch e {}
    let stale_sec = 48 * 3600  // 48시간
    if log_mtime > 0 && now_epoch > 0 && (now_epoch - log_mtime) > stale_sec {
        triggered = true
        let hours = (now_epoch - log_mtime) / 3600
        trigger_reasons = trigger_reasons + ["LAW_STAGNATION: discovery_log " + to_string(hours) + "시간 미갱신"]
    }

    // --- 결과 출력 + 트리거 ---
    if !triggered {
        println("  조건부 진화: 모든 지표 정상 — 트리거 없음")
        append_bus("hub", "conditional_evolve", "skip", "all conditions normal")
        return
    }

    println("  조건부 진화 트리거 감지!")
    let mut ri = 0
    while ri < trigger_reasons.len() {
        println("    - " + trigger_reasons[ri])
        ri = ri + 1
    }
    println("")

    // blowup 자동 실행
    println("  === 자동 blowup 실행 ===")
    let seed_engine_path = engine_dir + "/seed_engine.hexa"
    let blowup_path = engine_dir + "/blowup.hexa"
    let mut seeds = ""
    try { seeds = exec(hexa, [seed_engine_path, "merge"]) } catch e {}
    seeds = seeds.trim()
    if seeds.len() == 0 { seeds = "2.0,4.0,12.0,0.3333" }

    let mut blowup_result = ""
    try { blowup_result = exec(hexa, [blowup_path, "math", "3", "--no-graph", "--seeds", seeds]) } catch e { blowup_result = "ERROR: " + to_string(e) }

    let blowup_ok = !blowup_result.contains("ERROR")
    println("  blowup: " + if blowup_ok { "성공" } else { "실패" })
    println("  " + blowup_result.split("\n")[0])
    println("")

    // cross_project resonance 실행
    println("  === cross_project resonance ===")
    let cp_path = engine_dir + "/cross_project.hexa"
    let mut cp_result = ""
    try { cp_result = exec(hexa, [cp_path, "propagate"]) } catch e { cp_result = "ERROR: " + to_string(e) }
    let cp_ok = !cp_result.contains("ERROR")
    println("  cross_project: " + if cp_ok { "성공" } else { "실패" })

    // 버스 기록
    let reasons_str = trigger_reasons[0]
    append_bus("hub", "conditional_evolve", "triggered", to_string(trigger_reasons.len()) + " reasons: " + reasons_str)
}

println("")
println("=== nexus_hub verified ===")