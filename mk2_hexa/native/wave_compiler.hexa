// wave_compiler.hexa -- 파동 컴파일러
// 사용: hexa wave_compiler.hexa analyze <file.hexa>
//       hexa wave_compiler.hexa compare <dir>
//       hexa wave_compiler.hexa help
//
// 원리:
//   1. .hexa 파일을 읽어 AST 수준 구문 요소 분석 (fn, let, if, loop, exec)
//   2. 각 구문에 에너지 가중치 부여: fn=6, let=1, if=2, loop=4, exec=3
//   3. 파일 전체 에너지 합, n=6 배수 여부, 에너지 밀도 계산
//   4. 여러 파일 비교 시 간섭 패턴 (에너지 합이 n=6 배수인 쌍) 출력
//   5. growth_bus.jsonl에 결과 기록

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _bus_path = _shared + "/growth_bus.jsonl"

// ═══════════════════════════════════════════════════════════
// 에너지 가중치 정의
// ═══════════════════════════════════════════════════════════
// fn=6 (σ(6)/2), let=1 (μ), if=2 (φ), loop=4 (τ), exec=3 (M₃)
let W_FN: i64 = 6
let W_LET: i64 = 1
let W_IF: i64 = 2
let W_LOOP: i64 = 4
let W_EXEC: i64 = 3

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

// ═══════════════════════════════════════════════════════════
// 구문 요소 카운트 (grep 기반)
// ═══════════════════════════════════════════════════════════

fn count_element(filepath: string, pattern: string) -> i64 {
    let mut cnt: i64 = 0
    try {
        let raw = exec("grep -c '" + pattern + "' '" + filepath + "' 2>/dev/null || echo 0")
        cnt = safe_int(raw.trim())
    } catch e {}
    return cnt
}

fn count_lines(filepath: string) -> i64 {
    let mut cnt: i64 = 0
    try {
        let raw = exec("wc -l < '" + filepath + "' 2>/dev/null || echo 0")
        cnt = safe_int(raw.trim())
    } catch e {}
    return cnt
}

// ═══════════════════════════════════════════════════════════
// 단일 파일 분석
// ═══════════════════════════════════════════════════════════

fn analyze_file(filepath: string) -> string {
    // 각 구문 요소 카운트
    let fn_count = count_element(filepath, "^[[:space:]]*fn ")
    let let_count = count_element(filepath, "^[[:space:]]*let ")
    let if_count = count_element(filepath, "^[[:space:]]*if ")
    let loop_count = count_element(filepath, "\\bwhile \\|\\bfor ")
    let exec_count = count_element(filepath, "exec(")
    let lines = count_lines(filepath)

    // 에너지 계산
    let energy = fn_count * W_FN + let_count * W_LET + if_count * W_IF + loop_count * W_LOOP + exec_count * W_EXEC

    // n=6 배수 여부
    let is_n6 = if energy > 0 { energy % 6 == 0 } else { false }
    let n6_tag = if is_n6 { "n=6 공명" } else { "비공명" }

    // 에너지 밀도 (에너지 / 줄수)
    let density_x100 = if lines > 0 { (energy * 100) / lines } else { 0 }
    let density_int = density_x100 / 100
    let density_frac = density_x100 % 100

    // 나머지 (6과의 거리)
    let remainder = if energy > 0 { energy % 6 } else { 0 }

    // 파일명 추출
    let fname = exec("basename '" + filepath + "'").trim()

    println("")
    println("  파일: " + fname)
    println("  경로: " + filepath)
    println("  줄수: " + to_string(lines))
    println("")
    println("  | 구문요소 | 카운트 | 가중치 | 에너지 |")
    println("  |----------|--------|--------|--------|")
    println("  | fn       | " + to_string(fn_count) + " | x" + to_string(W_FN) + " | " + to_string(fn_count * W_FN) + " |")
    println("  | let      | " + to_string(let_count) + " | x" + to_string(W_LET) + " | " + to_string(let_count * W_LET) + " |")
    println("  | if       | " + to_string(if_count) + " | x" + to_string(W_IF) + " | " + to_string(if_count * W_IF) + " |")
    println("  | loop     | " + to_string(loop_count) + " | x" + to_string(W_LOOP) + " | " + to_string(loop_count * W_LOOP) + " |")
    println("  | exec     | " + to_string(exec_count) + " | x" + to_string(W_EXEC) + " | " + to_string(exec_count * W_EXEC) + " |")
    println("  |----------|--------|--------|--------|")
    println("  | 합계     |        |        | " + to_string(energy) + " |")
    println("")
    println("  에너지 밀도: " + to_string(density_int) + "." + to_string(density_frac) + " (에너지/줄)")
    println("  n=6 배수: " + n6_tag + " (나머지=" + to_string(remainder) + ")")
    println("")

    // 반환: 에너지|파일명 (비교용)
    return to_string(energy) + "|" + fname
}

// ═══════════════════════════════════════════════════════════
// 디렉토리 비교 (간섭 패턴)
// ═══════════════════════════════════════════════════════════

fn compare_dir(dirpath: string) {
    println("")
    println("  디렉토리: " + dirpath)
    println("  .hexa 파일 스캔 중...")
    println("")

    // .hexa 파일 목록
    let raw_files = exec("find '" + dirpath + "' -maxdepth 1 -name '*.hexa' -type f 2>/dev/null | sort | head -100")
    let file_list = raw_files.trim().split("\n")

    let mut energies = []
    let mut names = []
    let mut count: i64 = 0

    for fp in file_list {
        let fpath = fp.trim()
        if fpath == "" { continue }

        let fname = exec("basename '" + fpath + "'").trim()

        // 구문 카운트 (간략)
        let fn_c = count_element(fpath, "^[[:space:]]*fn ")
        let let_c = count_element(fpath, "^[[:space:]]*let ")
        let if_c = count_element(fpath, "^[[:space:]]*if ")
        let loop_c = count_element(fpath, "\\bwhile \\|\\bfor ")
        let exec_c = count_element(fpath, "exec(")

        let e = fn_c * W_FN + let_c * W_LET + if_c * W_IF + loop_c * W_LOOP + exec_c * W_EXEC
        let is_n6 = if e > 0 { e % 6 == 0 } else { false }
        let tag = if is_n6 { "*" } else { " " }

        energies = energies + [e]
        names = names + [fname]
        count = count + 1
    }

    // 에너지 요약 테이블
    println("  --- 파일별 에너지 ---")
    println("")
    println("  | # | 파일 | 에너지 | n=6 |")
    println("  |---|------|--------|-----|")

    let mut idx: i64 = 0
    let mut n6_count: i64 = 0
    while idx < count {
        let e: i64 = energies[idx]
        let n: string = names[idx]
        let is_n6 = if e > 0 { e % 6 == 0 } else { false }
        let tag = if is_n6 { "공명" } else { "-" }
        if is_n6 { n6_count = n6_count + 1 }
        println("  | " + to_string(idx + 1) + " | " + n + " | " + to_string(e) + " | " + tag + " |")
        idx = idx + 1
    }

    println("")
    println("  n=6 공명 파일: " + to_string(n6_count) + "/" + to_string(count))
    println("")

    // 간섭 패턴: 두 파일의 에너지 합이 n=6 배수인 쌍
    println("  --- 간섭 패턴 (에너지 합 = n=6 배수인 쌍) ---")
    println("")

    let mut pair_count: i64 = 0
    let mut i: i64 = 0
    while i < count {
        let mut j: i64 = i + 1
        while j < count {
            let e_i: i64 = energies[i]
            let e_j: i64 = energies[j]
            let e_sum = e_i + e_j
            if e_sum > 0 && e_sum % 6 == 0 {
                let n_i: string = names[i]
                let n_j: string = names[j]
                println("  " + n_i + " + " + n_j + " = " + to_string(e_sum) + " (" + to_string(e_sum / 6) + "*6)")
                pair_count = pair_count + 1
            }
            j = j + 1
        }
        i = i + 1
    }

    if pair_count == 0 {
        println("  간섭 쌍 없음")
    } else {
        println("")
        println("  간섭 쌍 합계: " + to_string(pair_count) + "개")
    }

    println("")
}

// ═══════════════════════════════════════════════════════════
// 도움말
// ═══════════════════════════════════════════════════════════

fn show_help() {
    println("")
    println("===========================================================")
    println("  파동 컴파일러 (Wave Compiler)")
    println("  hexa 코드를 파동으로 해석하는 메타 분석 도구")
    println("===========================================================")
    println("")
    println("  사용법:")
    println("    hexa wave_compiler.hexa analyze <file.hexa>")
    println("      지정 파일의 구문 요소별 에너지 분석")
    println("")
    println("    hexa wave_compiler.hexa compare <dir>")
    println("      디렉토리 내 .hexa 파일 비교 + 간섭 패턴 탐지")
    println("")
    println("    hexa wave_compiler.hexa help")
    println("      이 도움말 출력")
    println("")
    println("  에너지 가중치:")
    println("    fn=6 (σ/2)  let=1 (μ)  if=2 (φ)  loop=4 (τ)  exec=3 (M₃)")
    println("")
    println("  n=6 공명 = 파일 에너지 합이 6의 배수")
    println("  간섭 패턴 = 두 파일 에너지 합이 6의 배수인 쌍")
    println("")
}

// ═══════════════════════════════════════════════════════════
// MAIN
// ═══════════════════════════════════════════════════════════

let args = exec("echo $@").trim().split(" ")

if len(args) < 2 {
    show_help()
} else {
    let cmd = args[1]

    if cmd == "help" || cmd == "--help" || cmd == "-h" {
        show_help()
    } else if cmd == "analyze" {
        if len(args) < 3 {
            println("  오류: 분석할 파일 경로를 지정하세요")
            println("  사용: hexa wave_compiler.hexa analyze <file.hexa>")
        } else {
            println("")
            println("===========================================================")
            println("  파동 컴파일러 (Wave Compiler) -- 단일 파일 분석")
            println("===========================================================")

            let target = args[2]
            let result = analyze_file(target)

            // growth_bus 기록
            try {
                let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
                let parts = result.split("|")
                let energy_val = parts[0]
                let fname_val = parts[1]
                let entry = "{\"type\":\"wave_compiler\",\"mode\":\"analyze\",\"file\":\"" + fname_val + "\",\"energy\":" + energy_val + ",\"ts\":\"" + ts + "\"}"
                exec("echo '" + entry + "' >> " + _bus_path)
                println("  growth_bus 기록 완료")
            } catch e {}

            println("[verified] wave_compiler.hexa analyze 완료")
            println("")
        }
    } else if cmd == "compare" {
        if len(args) < 3 {
            println("  오류: 비교할 디렉토리를 지정하세요")
            println("  사용: hexa wave_compiler.hexa compare <dir>")
        } else {
            println("")
            println("===========================================================")
            println("  파동 컴파일러 (Wave Compiler) -- 디렉토리 비교")
            println("===========================================================")

            let target_dir = args[2]
            compare_dir(target_dir)

            // growth_bus 기록
            try {
                let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
                let entry = "{\"type\":\"wave_compiler\",\"mode\":\"compare\",\"dir\":\"" + target_dir + "\",\"ts\":\"" + ts + "\"}"
                exec("echo '" + entry + "' >> " + _bus_path)
                println("  growth_bus 기록 완료")
            } catch e {}

            println("[verified] wave_compiler.hexa compare 완료")
            println("")
        }
    } else {
        println("  알 수 없는 명령: " + cmd)
        show_help()
    }
}
