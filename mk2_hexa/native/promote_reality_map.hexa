// mk2_hexa/native/promote_reality_map.hexa
// reality_map_live.json EMPIRICAL→EXACT 승격 엔진 (L1 신규, n6_expr 정밀도 재계산).
// 대상 6레벨: L1_atom, L3_molecule, L5_material, L7_celestial, L8_galactic, L9_cosmological.
// CONJECTURE 95 재검증. 파이프 금지 — 리다이렉트/heredoc만. 로그: /tmp/rm_promote.log.
// R19: 경로는 $HOME 기반, 타겟 레벨은 고정 6개 (요청 A1~A6).

let _home = exec("printenv HOME").trim()
let _map = _home + "/Dev/nexus/shared/reality_map_live.json"
let _log = "/tmp/rm_promote.log"
let _helper = "/tmp/rm_promote_helper.py"

let _args = args()
let _mode = if _args.len() >= 3 { _args[2] } else { "run" }

print("[promote_reality_map] start mode=" + _mode)
print("[promote_reality_map] map=" + _map)

// 파이썬 헬퍼: printf '%b' 로 /tmp 에 기록 (파이프 없음, 리다이렉트만).
let _script = "import json, math, os\\nP=os.environ[\\x27RM\\x27]\\nT={\\x27L1_atom\\x27,\\x27L3_molecule\\x27,\\x27L5_material\\x27,\\x27L7_celestial\\x27,\\x27L8_galactic\\x27,\\x27L9_cosmological\\x27}\\nREL=1e-3\\nd=json.load(open(P))\\ndef N(x):\\n    try:\\n        f=float(x)\\n        return f if math.isfinite(f) else None\\n    except Exception:\\n        return None\\ne2x=0\\nc2e=0\\nkc=0\\nbl={}\\nfor n in d[\\x27nodes\\x27]:\\n    g=n.get(\\x27grade\\x27); lv=n.get(\\x27level\\x27)\\n    m=N(n.get(\\x27measured\\x27)); v=N(n.get(\\x27n6_value\\x27)); u=N(n.get(\\x27uncertainty\\x27)) or 0.0\\n    ok=False; dl=None; tl=None\\n    if m is not None and v is not None:\\n        dl=abs(m-v); tl=max(abs(u), REL*max(abs(m),1e-30)); ok=dl<=tl\\n    if g==\\x27EMPIRICAL\\x27 and lv in T and ok:\\n        n[\\x27grade\\x27]=\\x27EXACT\\x27\\n        n.setdefault(\\x27promotion\\x27,{})[\\x27from\\x27]=\\x27EMPIRICAL\\x27\\n        n[\\x27promotion\\x27][\\x27delta\\x27]=dl; n[\\x27promotion\\x27][\\x27tol\\x27]=tl\\n        e2x+=1; bl[lv]=bl.get(lv,0)+1\\n    elif g==\\x27CONJECTURE\\x27:\\n        if ok:\\n            n[\\x27grade\\x27]=\\x27EMPIRICAL\\x27\\n            n.setdefault(\\x27promotion\\x27,{})[\\x27from\\x27]=\\x27CONJECTURE\\x27\\n            c2e+=1\\n        else:\\n            kc+=1\\nd.setdefault(\\x27_meta\\x27,{})[\\x27last_promotion\\x27]={\\x27empirical_to_exact\\x27:e2x,\\x27conjecture_to_empirical\\x27:c2e,\\x27conjecture_kept\\x27:kc,\\x27by_level\\x27:bl,\\x27rel_tol\\x27:REL}\\njson.dump(d, open(P,\\x27w\\x27), ensure_ascii=False, indent=2)\\nimport time\\nGB=os.path.join(os.path.dirname(P),\\x27growth_bus.jsonl\\x27)\\nev={\\x27ts\\x27:int(time.time()),\\x27type\\x27:\\x27promotion\\x27,\\x27count\\x27:e2x+c2e,\\x27domain\\x27:\\x27reality_map\\x27,\\x27source\\x27:\\x27promote_reality_map.hexa\\x27,\\x27detail\\x27:{\\x27empirical_to_exact\\x27:e2x,\\x27conjecture_to_empirical\\x27:c2e,\\x27conjecture_kept\\x27:kc,\\x27by_level\\x27:bl}}\\ntry:\\n    with open(GB,\\x27a\\x27) as f: f.write(json.dumps(ev,ensure_ascii=False)+\\x27\\\\\\\\n\\x27)\\n    print(\\x27GROWTH_BUS append ok\\x27)\\nexcept Exception as _e:\\n    print(\\x27GROWTH_BUS append FAIL:\\x27, _e)\\nprint(\\x27EMPIRICAL->EXACT\\x27, e2x)\\nprint(\\x27CONJECTURE->EMPIRICAL\\x27, c2e)\\nprint(\\x27CONJECTURE kept\\x27, kc)\\nprint(\\x27by_level\\x27, bl)\\n"

if _mode == "dry" {
    print("[promote] dry — helper not written")
} else {
    let _w = exec("printf '%b' \"" + _script + "\" > " + _helper)
    print("[promote] helper written: " + _helper)
    let _out = exec("RM=" + _map + " /usr/bin/python3 " + _helper + " > " + _log + " 2>&1; cat " + _log)
    print(_out)
    print("[promote_reality_map] done — log=" + _log)
}
