// Ported from tecs-l/scripts/tecs_chain.py — 2026-04-10
// TECS-L Engine Chain — chain engine selection logic (pure).
// Given (depth, wall_state), decide engine set and chain level.

fn select_engines(level: i64) -> list {
    if level <= 0 {
        return ["dfs", "convergence"]
    }
    if level == 1 {
        return ["convergence", "quantum"]
    }
    return ["dfs", "convergence", "quantum", "perfect"]
}

fn plan_cycle(depth: i64, threshold: f64, wall_depth: i64, wall_threshold: f64) -> list {
    let eff_depth = if wall_depth > 0 { wall_depth } else { depth }
    let eff_threshold = if wall_threshold > 0.0 { wall_threshold } else { threshold }
    let lvl_raw = eff_depth - 1
    let lvl = if lvl_raw > 2 { 2 } else { lvl_raw }
    let lvl_c = if lvl < 0 { 0 } else { lvl }
    let engines = select_engines(lvl_c)
    return [to_string(eff_depth), to_string(eff_threshold), to_string(lvl_c), to_string(len(engines)), engines]
}

println("=================================================================")
println("tecs_chain.hexa — chained cycle planning demo")
println("=================================================================")

let plans = [
    plan_cycle(2, 0.001, 0, 0.0),
    plan_cycle(3, 0.0001, 0, 0.0),
    plan_cycle(2, 0.01, 4, 0.00001),
    plan_cycle(1, 0.1, 0, 0.0)
]

let mut i = 0
while i < len(plans) {
    let p = plans[i]
    println("  plan " + to_string(i) + ":")
    println("    depth=" + to_string(p[0]) + "  threshold=" + to_string(p[1]) + "  level=" + to_string(p[2]))
    println("    engines(" + to_string(p[3]) + ")=" + to_string(p[4]))
    i = i + 1
}

println("")
println("=================================================================")
println("SUMMARY: engine set depends on depth/wall-break state")
println("=================================================================")
