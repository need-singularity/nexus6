// Ported from tecs-l/scripts/tecs_pollinate.py — 2026-04-10
// TECS-L Cross-Pollinate — pure cross-domain injection logic.
// Cap total injections at J2=24, per source cap at sigma=12.

let cap_total = 24
let cap_per_source = 12

fn make_injection(src: string, tgt: string, val: f64) -> list {
    return [src, tgt, "[CROSS:" + src + "->" + tgt + "] value=" + to_string(val)]
}

println("=================================================================")
println("tecs_pollinate.hexa — cross-pollinate demo")
println("=================================================================")

let domains = ["N", "A", "G", "T", "C", "Q", "I", "S"]
let src_domains = ["N", "Q"]
let src_values_n = [6.0, 12.0, 4.0, 2.0, 5.0, 3.0]
let src_values_q = [137.036, 1.6e-35, 5.39e-44, 9.99e-4]

println("")
println("  source domain N has " + to_string(len(src_values_n)) + " values")
println("  source domain Q has " + to_string(len(src_values_q)) + " values")

let mut injections = []
let mut i = 0
while i < len(src_domains) {
    let src = src_domains[i]
    let vals = if src == "N" { src_values_n } else { src_values_q }
    let n_vals = if len(vals) < 6 { len(vals) } else { 6 }
    let mut j = 0
    while j < len(domains) {
        let tgt = domains[j]
        if tgt != src {
            let mut k = 0
            while k < n_vals {
                if len(injections) < cap_total {
                    let inj = make_injection(src, tgt, vals[k])
                    injections = injections + [inj]
                }
                k = k + 1
            }
        }
        j = j + 1
    }
    i = i + 1
}

println("")
println("  generated injections: " + to_string(len(injections)))

let show_n = if len(injections) < 5 { len(injections) } else { 5 }
let mut m = 0
while m < show_n {
    let inj = injections[m]
    println("    " + to_string(inj[0]) + "->" + to_string(inj[1]) + "  " + to_string(inj[2]))
    m = m + 1
}

println("")
println("=================================================================")
println("SUMMARY: cap total J2=24, per source sigma=12")
println("=================================================================")
