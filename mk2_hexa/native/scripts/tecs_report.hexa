// Ported from tecs-l/scripts/tecs_report.py — 2026-04-10
// TECS-L Discovery Loop Report — ASCII dashboard (pure compute demo).

fn stage_for(n: i64) -> list {
    if n >= 1000 { return ["cosmic", "5"] }
    if n >= 500 { return ["forest", "4"] }
    if n >= 200 { return ["tree", "3"] }
    if n >= 50 { return ["sapling", "2"] }
    if n >= 10 { return ["sprout", "1"] }
    return ["seed", "0"]
}

fn bar_of(filled: i64, total: i64, width: i64) -> string {
    if total == 0 { return "............" }
    let ratio = to_float(filled) / to_float(total)
    let r = if ratio > 1.0 { 1.0 } else { ratio }
    let n = to_int(r * to_float(width))
    let mut s = ""
    let mut i = 0
    while i < n {
        s = s + "#"
        i = i + 1
    }
    while i < width {
        s = s + "."
        i = i + 1
    }
    return s
}

println("=================================================================")
println("tecs_report.hexa — discovery loop dashboard")
println("=================================================================")

let total = 342
let grade_exact = 85
let grade_struct = 120
let grade_other = 137
let cycle = 28
let nodes = 520
let edges = 910
let hubs = 42

let stage = stage_for(total)
println("")
println("  Cycle: " + to_string(cycle) + "  Stage: " + to_string(stage[0]) + " (idx " + to_string(stage[1]) + ")")
println("  Discoveries: " + to_string(total) + "  exact=" + to_string(grade_exact) + "  struct=" + to_string(grade_struct) + "  other=" + to_string(grade_other))
println("  Graph: " + to_string(nodes) + "n/" + to_string(edges) + "e  hubs=" + to_string(hubs))

println("")
println("  Stage progress (seed -> cosmic):")
let stages = ["seed", "sprout", "sapling", "tree", "forest", "cosmic"]
let stage_idx = to_int(to_float(stage[1]))
let mut i = 0
while i < len(stages) {
    let marker = if i < stage_idx { "[OK]" } else { if i == stage_idx { "[--]" } else { "[  ]" } }
    println("    " + marker + "  " + to_string(stages[i]))
    i = i + 1
}

println("")
println("  Engine distribution (bars width=20):")
let engines = ["dfs", "convergence", "quantum", "perfect"]
let counts = [120, 140, 60, 22]
let mut j = 0
while j < len(engines) {
    let b = bar_of(counts[j], 200, 20)
    println("    " + to_string(engines[j]) + "  |" + b + "|  " + to_string(counts[j]))
    j = j + 1
}

println("")
println("  Domain distribution:")
let domains = ["N", "A", "G", "T", "C", "Q", "I", "S"]
let dcounts = [85, 60, 30, 15, 45, 50, 32, 25]
let mut k = 0
while k < len(domains) {
    println("    " + to_string(domains[k]) + "  " + to_string(dcounts[k]))
    k = k + 1
}

println("")
println("=================================================================")
println("SUMMARY: dashboard for " + to_string(total) + " discoveries, stage=" + to_string(stage[0]))
println("=================================================================")
