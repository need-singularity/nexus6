// Ported from tecs-l/scripts/operator_algebra_n6.py — 2026-04-10
// Operator Algebras / Jones Index / Temperley-Lieb / ADE classification for n=6

let n_val = 6
let sigma = 12
let phi_val = 2
let tau = 4
let sopfr_v = 5
let pi_c = 3.141592653589793
let e_c = 2.718281828459045

println("======================================================================")
println("OPERATOR ALGEBRAS FOR n=6")
println("sigma=12, phi=2, tau=4, sopfr=5, n=6")
println("======================================================================")

println("")
println("1. JONES INDEX VALUES: 4*cos^2(pi/k)")
let mut k = 3
while k <= 11 {
    let x = cos(pi_c / to_float(k))
    let val = 4.0 * x * x
    println("  k=" + to_string(k) + "  [M:N]=" + to_string(val))
    k = k + 1
}

let val_k6 = 4.0 * cos(pi_c / 6.0) * cos(pi_c / 6.0)
let val_k4 = 4.0 * cos(pi_c / 4.0) * cos(pi_c / 4.0)
println("")
println("  k=6 gives " + to_string(val_k6) + " vs sigma/tau = " + to_string(sigma / tau))
println("  k=4 gives " + to_string(val_k4) + " vs phi = " + to_string(phi_val))

let diff6 = val_k6 - 3.0
let abs6 = if diff6 < 0.0 { 0.0 - diff6 } else { diff6 }
if abs6 < 1.0e-10 {
    println("  PASS: 4*cos^2(pi/6) == sigma/tau == 3")
}

println("")
println("2. TEMPERLEY-LIEB ALGEBRA delta=2*cos(pi/(n+1))")
let mut m = 1
while m <= 9 {
    let d = 2.0 * cos(pi_c / to_float(m + 1))
    println("  TL_" + to_string(m) + "  delta=" + to_string(d) + "  delta^2=" + to_string(d * d))
    m = m + 1
}

let delta_s = 2.0 * cos(pi_c / 6.0)
println("")
println("  TL_sopfr (n=5): delta=" + to_string(delta_s) + "  delta^2=" + to_string(delta_s * delta_s))
println("  sqrt(3) = " + to_string(sqrt(3.0)))
let diff_d = delta_s - sqrt(3.0)
let abs_d = if diff_d < 0.0 { 0.0 - diff_d } else { diff_d }
if abs_d < 1.0e-10 {
    println("  PASS: delta(TL_5) = sqrt(sigma/tau)")
}

println("")
println("3. ADE CLASSIFICATION — E_6 subfactor")
let e6 = 3.0 + sqrt(3.0)
let e7 = (5.0 + sqrt(13.0)) / 2.0
let e8 = (5.0 + sqrt(17.0)) / 2.0
println("  E_6 = 3+sqrt(3) = " + to_string(e6))
println("  E_7 = (5+sqrt(13))/2 = " + to_string(e7))
println("  E_8 = (5+sqrt(17))/2 = " + to_string(e8))

let sig_tau = 3.0
let st_sqrt = sqrt(sig_tau)
let e6_check = sig_tau + st_sqrt
println("  sigma/tau + sqrt(sigma/tau) = " + to_string(e6_check))
let diff_e6 = e6 - e6_check
let abs_e6 = if diff_e6 < 0.0 { 0.0 - diff_e6 } else { diff_e6 }
if abs_e6 < 1.0e-10 {
    println("  PASS: E_6 = sigma/tau + sqrt(sigma/tau) = 3+sqrt(3)")
}

println("")
println("4. CONNES Type III_lambda factors")
let lambdas = [0.5, 0.36787944117144233, 0.3333333333333333, 0.5, 0.16666666666666666]
let lnames = ["1/2", "1/e", "1/3", "1/phi", "1/6"]
let mut i = 0
while i < len(lambdas) {
    let lam = lambdas[i]
    let ln_lam = log(lam)
    let period = 0.0 - 2.0 * pi_c / ln_lam
    println("  lambda=" + lnames[i] + "  -log=" + to_string(0.0 - ln_lam) + "  T=" + to_string(period))
    i = i + 1
}

println("")
println("5. Catalan numbers (TL dimension)")
let mut cn = 1
let mut j = 1
while j <= 6 {
    cn = cn * 2 * (2 * j - 1) / (j + 1)
    println("  C_" + to_string(j) + " = " + to_string(cn))
    j = j + 1
}

println("")
println("======================================================================")
println("SUMMARY: Jones index sigma/tau=3 = 4*cos^2(pi/6); E_6 = 3+sqrt(3)")
println("======================================================================")
