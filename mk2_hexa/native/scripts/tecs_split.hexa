// Ported from tecs-l/scripts/tecs_split.py — 2026-04-10
// TECS-L Domain Split — pure split decision logic.
// Given hypothesis_count > SPLIT_THRESHOLD, split parent into sub-domains.

let split_threshold = 500

fn parent_subs(parent: string) -> list {
    if parent == "N" {
        return ["N1", "N2", "N3"]
    }
    if parent == "A" {
        return ["A1", "A2"]
    }
    return []
}

fn sub_name(code: string) -> string {
    if code == "N1" { return "Prime/Divisor" }
    if code == "N2" { return "Arithmetic Functions" }
    if code == "N3" { return "Sequences/Constants" }
    if code == "A1" { return "Real/Complex Analysis" }
    if code == "A2" { return "Special Functions" }
    return "unknown"
}

fn classify(fname: string, parent: string) -> string {
    let f = fname
    if parent == "N" {
        if f.contains("prime") { return "N1" }
        if f.contains("divisor") { return "N1" }
        if f.contains("sigma") { return "N2" }
        if f.contains("tau") { return "N2" }
        if f.contains("phi") { return "N2" }
        if f.contains("fibonacci") { return "N3" }
        if f.contains("catalan") { return "N3" }
        return "N1"
    }
    if parent == "A" {
        if f.contains("zeta") { return "A2" }
        if f.contains("gamma") { return "A2" }
        if f.contains("bessel") { return "A2" }
        return "A1"
    }
    return ""
}

println("=================================================================")
println("tecs_split.hexa — domain split logic demo")
println("=================================================================")

// Simulate split decision
let parents = ["N", "A", "N"]
let hyp_counts = [600, 400, 800]

println("")
let mut i = 0
while i < len(parents) {
    let p = parents[i]
    let hc = hyp_counts[i]
    let over = hc >= split_threshold
    let subs = parent_subs(p)
    let mark = if over { "SPLIT" } else { "keep" }
    println("  parent=" + p + "  hyp=" + to_string(hc) + "  " + mark + "  subs=" + to_string(len(subs)))
    if over {
        let mut j = 0
        while j < len(subs) {
            let s = subs[j]
            println("    -> " + s + " (" + sub_name(s) + ")")
            j = j + 1
        }
    }
    i = i + 1
}

println("")
println("  Classification test (parent=N):")
let files = ["h100-prime-gap.md", "h200-sigma-6.md", "h300-fibonacci.md", "h400-divisor.md"]
let mut k = 0
while k < len(files) {
    let f = files[k]
    let sub = classify(f, "N")
    println("    " + f + "  -> " + sub)
    k = k + 1
}

println("")
println("=================================================================")
println("SUMMARY: split when hyp_count >= 500; classify by keywords")
println("=================================================================")
