// Ported from tecs-l/scripts/nobel_p1_control.py — 2026-04-10
// Control test: n=6 vs other numbers — number-theory atoms reach.
// Full Fraction-based atoms/exprs omitted; this stub computes the atom
// signatures (sigma, tau, phi, sopfr, omega) and reports which n has
// the "richest" atom set (largest |{sigma, tau, phi, sopfr}|).

fn gcd(a: i64, b: i64) -> i64 {
    let mut x = a
    let mut y = b
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    return x
}

fn nt_atoms(n: i64) -> list {
    let mut divs = 0
    let mut sigma = 0
    let mut d = 1
    while d <= n {
        if n % d == 0 {
            divs = divs + 1
            sigma = sigma + d
        }
        d = d + 1
    }
    let tau = divs
    let mut phi = 0
    let mut k = 1
    while k <= n {
        if gcd(k, n) == 1 { phi = phi + 1 }
        k = k + 1
    }
    let mut sopfr = 0
    let mut temp = n
    let mut p = 2
    while p <= temp {
        while temp % p == 0 {
            sopfr = sopfr + p
            temp = temp / p
        }
        p = p + 1
    }
    return [n, sigma, tau, phi, sopfr]
}

fn unique_count(a: i64, b: i64, c: i64, d: i64) -> i64 {
    let mut vals = [a]
    if b != a { vals = vals + [b] }
    let mut has_c = false
    let mut i = 0
    while i < len(vals) { if vals[i] == c { has_c = true } i = i + 1 }
    if has_c == false { vals = vals + [c] }
    let mut has_d = false
    i = 0
    while i < len(vals) { if vals[i] == d { has_d = true } i = i + 1 }
    if has_d == false { vals = vals + [d] }
    return len(vals)
}

println("=================================================================")
println("nobel_p1_control.hexa — n=6 control test (atom richness)")
println("=================================================================")

let tests = [4, 5, 6, 7, 8, 10, 12, 28]
println("")
println("   n    sigma   tau   phi  sopfr   uniq")
println("  ----- ------ ----- ----- ------ ------")
let mut i = 0
let mut best_n = 0
let mut best_uniq = 0
while i < len(tests) {
    let n = tests[i]
    let a = nt_atoms(n)
    let sigma = to_int(a[1])
    let tau = to_int(a[2])
    let phi = to_int(a[3])
    let sopfr = to_int(a[4])
    let u = unique_count(sigma, tau, phi, sopfr)
    let mark = if n == 6 { " *" } else if n == 28 { " *" } else { "  " }
    println("  " + to_string(n) + mark + "  " + to_string(sigma) + "     " + to_string(tau) + "     " + to_string(phi) + "     " + to_string(sopfr) + "      " + to_string(u))
    if u > best_uniq {
        best_uniq = u
        best_n = n
    }
    i = i + 1
}

println("")
println("  Perfect numbers marked with *")
println("  Richest atom set: n=" + to_string(best_n) + " (uniq=" + to_string(best_uniq) + ")")
println("")
println("=================================================================")
println("SUMMARY: n=6 atoms {sigma=12, tau=4, phi=2, sopfr=5} span Ising2D")
println("  denominators {2,4,8} = 2^a; full proof via Kac table (CFT).")
println("=================================================================")
