// Ported from tecs-l/scripts/predict_post_discovery.py — 2026-04-10
// Predictor: given current discovery log, what's the next most-likely
// n=6 identity to be confirmed? Pure demo — weighted candidate list.

fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x } return x }

println("=================================================================")
println("predict_post_discovery.hexa — next candidate ranker")
println("=================================================================")

// Candidates: [name, base_score, weight_from_atoms, weight_from_history]
let names = [
    "Ising3D_alpha",
    "XY3D_eta",
    "Heis3D_nu",
    "DP_beta",
    "Perc3D_nu",
    "SAW3D_gamma",
    "Tri_delta",
    "KPZ_z_2D"
]
let base = [0.62, 0.58, 0.71, 0.27, 0.88, 1.15, 4.25, 1.50]
let atom_w = [0.95, 0.92, 0.88, 0.65, 0.90, 0.83, 0.70, 0.95]
let hist_w = [0.81, 0.77, 0.79, 0.55, 0.74, 0.72, 0.61, 0.86]

let mut i = 0
let mut best_i = 0
let mut best_score = 0.0
while i < len(names) {
    let b = to_float(base[i])
    let aw = to_float(atom_w[i])
    let hw = to_float(hist_w[i])
    let score = aw * hw + b * 0.01
    println("  " + to_string(names[i]) + "  base=" + to_string(b) + "  score=" + to_string(score))
    if score > best_score { best_score = score; best_i = i }
    i = i + 1
}

println("")
println("  Next most-likely: " + to_string(names[best_i]) + "  score=" + to_string(best_score))
println("")
println("=================================================================")
println("SUMMARY: KPZ_z_2D expected next (highest atom+history product).")
println("=================================================================")
