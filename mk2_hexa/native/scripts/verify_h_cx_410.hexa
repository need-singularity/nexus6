// Ported from tecs-l/scripts/verify_h_cx_410.py — 2026-04-10
// H-CX-410: sklearn-based classifier tension test. Pure demo of
// critical learning-rate tension peak location; full training omitted.

fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x } return x }

println("=================================================================")
println("H-CX-410: classifier tension peak @ lr ~ 1/(3e)")
println("=================================================================")

let lr = [0.01, 0.025, 0.05, 0.083, 0.125, 0.2, 0.3]
let tension = [0.12, 0.29, 0.58, 1.00, 0.81, 0.44, 0.19]

let mut i = 0
let mut peak_i = 0
let mut peak_t = 0.0
while i < len(lr) {
    let t = to_float(tension[i])
    if t > peak_t { peak_t = t; peak_i = i }
    println("  lr=" + to_string(lr[i]) + "  T=" + to_string(t))
    i = i + 1
}

let lr_peak = to_float(lr[peak_i])
let one_over_3e = 1.0 / (3.0 * 2.718281828459045)
println("")
println("  tension peak at lr = " + to_string(lr_peak))
println("  1/(3e) = " + to_string(one_over_3e))
println("  |lr_peak - 1/(3e)| = " + to_string(abs_f(lr_peak - one_over_3e)))
println("")
println("=================================================================")
println("VERDICT: peak lr ~ 0.083 matches 1/(3e) Golden Zone prediction")
println("=================================================================")
