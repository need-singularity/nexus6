// Ported from tecs-l/scripts/verify_hsim4.py — 2026-04-10
// H-SIM-4: Speed of Light = Maximum Clock Speed
// Verify c = lp/tp and compute universe computational capacity.

let hbar = 1.054571817e-34
let c = 2.99792458e8
let big_g = 6.67430e-11

let lp = sqrt(hbar * big_g / (c * c * c))
let tp = sqrt(hbar * big_g / (c * c * c * c * c))
let mp = sqrt(hbar * c / big_g)
let ep = mp * c * c

println("======================================================================")
println("H-SIM-4: Speed of Light = Maximum Clock Speed")
println("======================================================================")

println("")
println("--- Planck Units ---")
println("  lp = " + to_string(lp) + " m")
println("  tp = " + to_string(tp) + " s")
println("  mp = " + to_string(mp) + " kg")
println("  Ep = " + to_string(ep) + " J")

println("")
println("--- 1. Verify c = lp/tp ---")
let c_planck = lp / tp
let diff = c - c_planck
let abs_diff = if diff < 0.0 { 0.0 - diff } else { diff }
println("  c (defined)   = " + to_string(c))
println("  lp / tp       = " + to_string(c_planck))
println("  |Difference|  = " + to_string(abs_diff))
println("  --> c = lp/tp by construction")

println("")
println("--- 2. Universe Computational Capacity ---")
let r_univ = 4.4e26
let n_cells = r_univ / lp
let cells3 = n_cells * n_cells * n_cells
let clock = 1.0 / tp
let ops_per_sec = cells3 / tp
println("  R_obs     = " + to_string(r_univ) + " m")
println("  N_cells   = " + to_string(n_cells))
println("  N_cells^3 = " + to_string(cells3))
println("  clock     = " + to_string(clock) + " ticks/s")
println("  ops/sec   = " + to_string(ops_per_sec))
println("  log10(ops/sec) = " + to_string(log(ops_per_sec) / log(10.0)))

println("")
println("--- 3. Bremermann Limit ---")
let brem_per_kg = c * c / hbar
let m_universe = 1.5e53
let brem_total = brem_per_kg * m_universe
println("  Bremermann/kg = " + to_string(brem_per_kg))
println("  Bremermann_total = " + to_string(brem_total))
println("  Grid/Bremermann  = " + to_string(ops_per_sec / brem_total))
if ops_per_sec > brem_total {
    println("  --> Grid ops EXCEED Bremermann (simulator must be larger)")
} else {
    println("  --> Grid ops within Bremermann budget")
}

println("")
println("--- 4. Lorentz factors ---")
let fracs = [0.0, 0.1, 0.5, 0.8, 0.9, 0.99, 0.999]
let mut i = 0
while i < len(fracs) {
    let v = fracs[i]
    let g = 1.0 / sqrt(1.0 - v * v)
    println("  v/c=" + to_string(v) + "  gamma=" + to_string(g))
    i = i + 1
}

println("")
println("======================================================================")
println("SUMMARY: c=lp/tp (exact), grid ops=" + to_string(ops_per_sec))
println("======================================================================")
