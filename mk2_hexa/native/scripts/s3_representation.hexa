// Ported from tecs-l/scripts/s3_representation.py — 2026-04-10
// S_3 (symmetric group) representation theory + n=6 constant matching

println("============================================================")
println("S_3 Symmetric Group Representation Theory")
println("============================================================")

println("")
println("[1] Conjugacy Classes")
println("  e (identity):      size=1, order=1")
println("  (ij) transposition: size=3, order=2")
println("  (ijk) 3-cycle:      size=2, order=3")

println("")
println("[2] Character Table")
println("  rep         | e | (ij) | (ijk) | dim")
println("  trivial     | 1 |  1   |   1   |  1")
println("  sign        | 1 | -1   |   1   |  1")
println("  standard    | 2 |  0   |  -1   |  2")

let dim_sum = 1 + 1 + 4
println("")
println("  Verification: sum(d_i^2) = 1 + 1 + 4 = " + to_string(dim_sum))
if dim_sum == 6 {
    println("  PASS: sum(d_i^2) = |S_3| = 6")
}

println("")
println("[3] Orthogonality (inner products)")
// <trivial, trivial> = (1*1*1 + 3*1*1 + 2*1*1)/6 = 6/6 = 1
let inner_tt = (1 * 1 * 1 + 3 * 1 * 1 + 2 * 1 * 1)
println("  <chi_1, chi_1>*6 = " + to_string(inner_tt) + "  normalized=" + to_string(inner_tt / 6))
let inner_ts = (1 * 1 * 1 + 3 * 1 * 0 - 2 * 1 * 1)
println("  <chi_1, chi_3>*6 = " + to_string(inner_ts))
let inner_ss = (1 * 2 * 2 + 3 * 0 * 0 + 2 * 1 * 1)
println("  <chi_3, chi_3>*6 = " + to_string(inner_ss) + "  normalized=" + to_string(inner_ss / 6))

println("")
println("[4] |S_3| = 6 = Perfect Number")
println("  Divisors of 6: 1, 2, 3, 6")
let div_sum = 1 + 2 + 3 + 6
println("  sigma(6) = " + to_string(div_sum))
if div_sum == 12 {
    println("  PASS: sigma(6) = 12 = 2*6 (perfect)")
}
let harmonic = 1.0 / 1.0 + 1.0 / 2.0 + 1.0 / 3.0 + 1.0 / 6.0
println("  Harmonic sum 1/1+1/2+1/3+1/6 = " + to_string(harmonic))

println("")
println("[5] Egyptian fraction {1/2, 1/3, 1/6}")
let half = 1.0 / 2.0
let third = 1.0 / 3.0
let sixth = 1.0 / 6.0
let e1 = half + third + sixth
let e2 = half * third + half * sixth + third * sixth
let e3 = half * third * sixth
println("  e_1 (sum)     = " + to_string(e1))
println("  e_2 (pair sum) = " + to_string(e2))
println("  e_3 (product)  = " + to_string(e3))

let diff_e1 = e1 - 1.0
let abs_e1 = if diff_e1 < 0.0 { 0.0 - diff_e1 } else { diff_e1 }
if abs_e1 < 1.0e-10 {
    println("  PASS: 1/2+1/3+1/6 = 1")
}

println("")
println("[6] Character table absolute sum")
let char_abs = 1 + 1 + 1 + 1 + 1 + 1 + 2 + 0 + 1
println("  |1|+|1|+|1|+|1|+|-1|+|1|+|2|+|0|+|-1| = " + to_string(char_abs))
if char_abs == 8 {
    println("  PASS: char abs sum = 8")
}

println("")
println("[7] Power sums of {1/2, 1/3, 1/6}")
let p1 = half + third + sixth
let p2 = half * half + third * third + sixth * sixth
let p3 = half * half * half + third * third * third + sixth * sixth * sixth
println("  p_1 = " + to_string(p1))
println("  p_2 = " + to_string(p2))
println("  p_3 = " + to_string(p3))

println("")
println("============================================================")
println("SUMMARY: S_3 naturally generates {1/2, 1/3, 1/6, 2, 6, 8}")
println("============================================================")
