// Ported from tecs-l/scripts/tecs_forge.py — 2026-04-10
// TECS-L Domain Forge — pure forge decision logic.
// Given candidate domains and hypothesis counts, decide which to forge.

fn candidate_names() -> list {
    return ["M", "K", "E", "B", "D", "P"]
}

fn candidate_label(code: string) -> string {
    if code == "M" { return "Music/Audio" }
    if code == "K" { return "Consciousness" }
    if code == "E" { return "Evolution" }
    if code == "B" { return "Biology" }
    if code == "D" { return "Material Science" }
    if code == "P" { return "Cosmology/Particle" }
    return "unknown"
}

fn candidate_impact(code: string) -> f64 {
    if code == "M" { return 0.12 }
    if code == "K" { return 0.13 }
    if code == "E" { return 0.11 }
    if code == "B" { return 0.12 }
    if code == "D" { return 0.11 }
    if code == "P" { return 0.10 }
    return 0.0
}

fn should_forge(hyp_count: i64, all_healthy: bool) -> bool {
    if hyp_count >= 10 { return true }
    if all_healthy {
        if hyp_count >= 3 { return true }
    }
    return false
}

println("=================================================================")
println("tecs_forge.hexa — domain forge decision demo")
println("=================================================================")

let codes = candidate_names()
let hyp_counts = [15, 5, 2, 12, 0, 8]
let all_healthy = true

println("")
println("  candidates (hyp_count, all_healthy=" + to_string(all_healthy) + "):")
let mut forged_count = 0
let mut i = 0
while i < len(codes) {
    let code = codes[i]
    let hyp = hyp_counts[i]
    let go = should_forge(hyp, all_healthy)
    let mark = if go { "FORGE" } else { "skip" }
    println("    " + code + " (" + candidate_label(code) + ")  hyp=" + to_string(hyp) + "  impact=" + to_string(candidate_impact(code)) + "  " + mark)
    if go { forged_count = forged_count + 1 }
    i = i + 1
}

println("")
println("  total forged: " + to_string(forged_count) + " / " + to_string(len(codes)))

println("")
println("=================================================================")
println("SUMMARY: forge threshold hyp>=10 OR (healthy AND hyp>=3)")
println("=================================================================")
