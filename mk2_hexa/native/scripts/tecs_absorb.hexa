// Ported from tecs-l/scripts/tecs_absorb.py — 2026-04-10
// TECS-L Keyword Absorb — pure token extraction + domain-specificity logic.

fn is_stopword(w: string) -> bool {
    let sw = ["the", "and", "for", "with", "from", "that", "this", "are", "was",
              "err", "error", "value", "result", "cross", "type", "mode",
              "convergence", "discovery", "cycle", "domain", "target"]
    let mut i = 0
    while i < len(sw) {
        if to_string(sw[i]) == w { return true }
        i = i + 1
    }
    return false
}

fn is_n6_token(w: string) -> bool {
    let tok = ["sigma", "phi", "tau", "mu", "sopfr", "j2", "jordan",
               "euler", "gamma", "golden", "pi", "ln", "log", "exp", "sqrt",
               "zeta", "bernoulli", "ramanujan", "dedekind", "carmichael",
               "mertens", "boltzmann", "mobius", "dirichlet"]
    let mut i = 0
    while i < len(tok) {
        if to_string(tok[i]) == w { return true }
        i = i + 1
    }
    return false
}

fn extract_tokens(content: string) -> list {
    let words = content.split(" ")
    let mut tokens = []
    let mut i = 0
    while i < len(words) {
        let w = to_string(words[i])
        if len(w) >= 3 {
            if is_stopword(w) == false {
                tokens = tokens + [w]
            }
        }
        i = i + 1
    }
    return tokens
}

fn count_token(tokens: list, t: string) -> i64 {
    let mut c = 0
    let mut i = 0
    while i < len(tokens) {
        if to_string(tokens[i]) == t { c = c + 1 }
        i = i + 1
    }
    return c
}

println("=================================================================")
println("tecs_absorb.hexa — keyword absorb demo")
println("=================================================================")

let sample = "fibonacci discovery resonance phi cycle ramsey fibonacci kepler newton fibonacci"
let tokens = extract_tokens(sample)
println("")
println("  input: " + sample)
println("  tokens (non-stop): " + to_string(tokens))

println("")
println("  frequency > 1:")
let seen = ["fibonacci", "kepler", "newton", "ramsey", "resonance", "phi"]
let mut i = 0
while i < len(seen) {
    let t = to_string(seen[i])
    let c = count_token(tokens, t)
    let n6 = is_n6_token(t)
    if c > 0 {
        let mark = if n6 { "(n6-known)" } else { "" }
        println("    " + t + "  count=" + to_string(c) + "  " + mark)
    }
    i = i + 1
}

println("")
println("  domain specificity example:")
let domain_n_count = 5
let global_count = 8
let specificity = to_float(domain_n_count) / to_float(global_count)
println("    token in domain N: " + to_string(domain_n_count) + "/" + to_string(global_count) + " = " + to_string(specificity))
if specificity > 0.5 {
    println("    ABSORB (specificity > 0.5)")
}

println("")
println("=================================================================")
println("SUMMARY: extract+filter+specificity > 0.5 absorbs new keyword")
println("=================================================================")
