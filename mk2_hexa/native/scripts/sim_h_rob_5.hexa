// Ported from tecs-l/scripts/sim_h_rob_5.py — 2026-04-10
// H-ROB-5: Mitosis = Swarm Fission (deterministic simplified variant)
// Coverage model: per-robot efficiency = f(N) with coordination cost.

let area = 100.0
let sense_r = 15.0
let steps = 200
let grid_res = 20
let n_vals = [1, 2, 3, 4, 5, 6, 8, 10, 12]

fn coverage_model(n: i64) -> f64 {
    // Approximate: each robot covers ~ steps cells in its strip
    // Saturates at strip_cells = grid_res * (grid_res / n)
    let strip_cells = to_float(400 / n)
    let max_cov = to_float(n) * strip_cells
    let visited = to_float(steps) * 1.0
    let n_visit = to_float(n) * visited
    let cov = if n_visit < max_cov { n_visit / 400.0 } else { max_cov / 400.0 }
    return cov
}

fn overhead_model(n: i64) -> f64 {
    // Pairs within sense radius ~ density
    let fn_f = to_float(n)
    return 0.3 * (fn_f - 1.0) / 12.0
}

println("=================================================================")
println("H-ROB-5: Mitosis = Swarm Fission (simplified deterministic)")
println("=================================================================")
println("  area=" + to_string(area) + " steps=" + to_string(steps) + " sense_r=" + to_string(sense_r))

println("")
let mut i = 0
let mut best_eff_n = 1
let mut best_eff = 0.0
let mut best_net_n = 1
let mut best_net = 0.0 - 1.0e9
while i < len(n_vals) {
    let n = n_vals[i]
    let cov = coverage_model(n)
    let ovh = overhead_model(n)
    let eff = cov / to_float(n)
    let alpha = 0.5
    let net = cov - alpha * ovh * to_float(n)
    println("  N=" + to_string(n) + "  cov=" + to_string(cov) + "  ovh=" + to_string(ovh) + "  eff/robot=" + to_string(eff) + "  net=" + to_string(net))
    if eff > best_eff {
        best_eff = eff
        best_eff_n = n
    }
    if net > best_net {
        best_net = net
        best_net_n = n
    }
    i = i + 1
}

println("")
println("Best efficiency: N=" + to_string(best_eff_n))
println("Best net benefit: N=" + to_string(best_net_n))

println("")
if best_eff_n == 2 {
    println("PASS: N=2 optimal = sigma_-1(6) = 2 (Mitosis prediction)")
} else {
    println("Mitosis prediction: N=" + to_string(best_eff_n))
}

println("=================================================================")
