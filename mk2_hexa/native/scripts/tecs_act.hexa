// Ported from tecs-l/scripts/tecs_act.py — 2026-04-10
// TECS-L Discovery Action — pure mode->engine selection + rotation logic.

fn mode_engines(mode: string) -> list {
    if mode == "dfs" { return ["dfs", "convergence"] }
    if mode == "pair" { return ["convergence", "quantum"] }
    if mode == "backtrack" { return ["convergence", "perfect"] }
    return ["dfs", "convergence", "quantum", "perfect"]
}

fn domain_map(disc: string) -> string {
    let d = disc
    if d.contains("number") { return "N" }
    if d.contains("analysis") { return "A" }
    if d.contains("algebra") { return "G" }
    if d.contains("topology") { return "T" }
    if d.contains("combinat") { return "C" }
    if d.contains("quantum") { return "Q" }
    if d.contains("information") { return "I" }
    if d.contains("statistic") { return "S" }
    return "N"
}

fn rotate_mode(current: string) -> string {
    if current == "dfs" { return "pair" }
    if current == "pair" { return "backtrack" }
    if current == "backtrack" { return "dfs" }
    return "dfs"
}

println("=================================================================")
println("tecs_act.hexa — discovery action logic demo")
println("=================================================================")

let modes = ["dfs", "pair", "backtrack"]
let mut i = 0
while i < len(modes) {
    let m = modes[i]
    let engs = mode_engines(m)
    println("  mode=" + m + "  engines=" + to_string(engs))
    i = i + 1
}

println("")
println("  domain classification:")
let raws = ["number-theory", "statistical-mech", "quantum-gravity", "combinat-ric"]
let mut j = 0
while j < len(raws) {
    let r = raws[j]
    println("    " + r + "  -> " + domain_map(r))
    j = j + 1
}

println("")
println("  mode rotation (stagnation trigger):")
let mut cur = "dfs"
let mut step = 0
while step < 5 {
    let nxt = rotate_mode(cur)
    println("    " + cur + " -> " + nxt)
    cur = nxt
    step = step + 1
}

let stagnant_trigger = 3
let current_stagnant = 4
let should_rotate = current_stagnant >= stagnant_trigger
println("")
println("  stagnant=" + to_string(current_stagnant) + "  trigger=" + to_string(stagnant_trigger) + "  rotate=" + to_string(should_rotate))

println("")
println("=================================================================")
println("SUMMARY: mode->engines + rotation on stagnation")
println("=================================================================")
