// Ported from tecs-l/scripts/tecs_wall.py — 2026-04-10
// TECS-L Wall Detect — pure detection logic (state read simplified).
// Demonstrates decline/plateau/zero wall detection on cycle history.

let decline_window = 3
let min_cycles_before = 3
let max_depth = 6
let threshold_factor = 0.1

fn detect_wall(counts: list) -> list {
    if len(counts) < decline_window {
        return ["false", "not_enough"]
    }
    let n = len(counts)
    let r0 = counts[n - 3]
    let r1 = counts[n - 2]
    let r2 = counts[n - 1]

    if r0 == 0 {
        if r1 == 0 {
            if r2 == 0 {
                return ["true", "zero_wall"]
            }
        }
    }

    if r0 >= r1 {
        if r1 >= r2 {
            if r2 < r0 {
                return ["true", "decline_wall"]
            }
        }
    }

    if r0 == r1 {
        if r1 == r2 {
            if n >= min_cycles_before * 2 {
                return ["true", "plateau_wall"]
            }
        }
    }

    return ["false", "no_wall"]
}

println("=================================================================")
println("tecs_wall.hexa — Wall Detect demo")
println("=================================================================")

let case_counts = [
    [5, 3, 2, 1, 0, 0, 0],
    [10, 8, 6, 4, 3],
    [2, 2, 2, 2, 2, 2, 2, 2],
    [1, 5, 3, 8],
    [1, 2]
]
let case_expected = [
    "zero_wall expected",
    "decline_wall expected",
    "plateau_wall expected",
    "no_wall expected",
    "not_enough expected"
]

let mut i = 0
while i < len(case_counts) {
    let counts = case_counts[i]
    let expected = case_expected[i]
    let result = detect_wall(counts)
    println("  cycles=" + to_string(counts) + "  -> " + to_string(result[0]) + " " + to_string(result[1]) + "  (" + expected + ")")
    i = i + 1
}

println("")
println("=================================================================")
println("SUMMARY: wall detection logic (decline/plateau/zero)")
println("=================================================================")
