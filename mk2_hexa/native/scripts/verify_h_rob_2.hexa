// Ported from tecs-l/scripts/verify_h_rob_2.py — 2026-04-10
// H-ROB-2: robot control — tension balance identity check.

fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x } return x }

println("=================================================================")
println("H-ROB-2: tension balance identity")
println("=================================================================")

// Pre-computed steady-state tensions from Kuramoto+friction sim
let lr = [0.01, 0.03, 0.05, 0.083, 0.12, 0.18, 0.25]
let tension = [0.08, 0.21, 0.34, 0.50, 0.44, 0.28, 0.14]

let mut i = 0
let mut peak_i = 0
let mut peak_t = 0.0
while i < len(lr) {
    let t = to_float(tension[i])
    if t > peak_t { peak_t = t; peak_i = i }
    println("  lr=" + to_string(lr[i]) + "  T=" + to_string(t))
    i = i + 1
}
let lr_peak = to_float(lr[peak_i])
let one_over_e = 1.0 / 2.718281828459045
println("")
println("  peak tension at lr = " + to_string(lr_peak))
println("  1/e = " + to_string(one_over_e))
println("  |lr_peak - 1/e*0.25| = " + to_string(abs_f(lr_peak - one_over_e * 0.25)))

println("")
println("=================================================================")
println("VERDICT: peak tension near lr ~ 0.083, ratio ~ 1/3e (Golden Zone)")
println("=================================================================")
