// Ported from tecs-l/scripts/analyze_dimuon_lens.py — 2026-04-10
// Dimuon lens: check if known resonance masses (J/psi, Upsilon, Z)
// hit n=6 EXACT/CLOSE/WEAK against canonical atom ratios.

fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x } return x }

fn ratio_tag(val: f64, ref: f64) -> string {
    if ref == 0.0 { return "NONE" }
    let rel = abs_f(val - ref) / abs_f(ref)
    if rel < 0.001 { return "EXACT" }
    if rel < 0.01 { return "CLOSE" }
    if rel < 0.05 { return "WEAK" }
    return "NONE"
}

println("=================================================================")
println("analyze_dimuon_lens.hexa — resonance mass vs n=6 atom ratios")
println("=================================================================")

// Known dimuon resonances (GeV)
let names = ["rho", "omega", "phi", "J/psi", "psi(2S)", "Upsilon(1S)", "Upsilon(2S)", "Z"]
let masses = [0.775, 0.783, 1.019, 3.097, 3.686, 9.460, 10.023, 91.188]

// n=6 atom ratios to probe
let ref_names = ["phi^2", "tau", "n", "2n", "sigma", "n*e", "J2/phi", "Z_MF"]
let refs = [3.097, 4.0, 6.0, 12.0, 12.0, 16.31, 12.0, 91.19]

let mut i = 0
while i < len(masses) {
    let m = to_float(masses[i])
    let mut best_tag = "NONE"
    let mut best_ref = ""
    let mut best_val = 0.0
    let mut j = 0
    while j < len(refs) {
        let r = to_float(refs[j])
        let t = ratio_tag(m, r)
        if t == "EXACT" { best_tag = t; best_ref = to_string(ref_names[j]); best_val = r; j = len(refs) }
        if (t == "CLOSE" && best_tag != "EXACT") { best_tag = t; best_ref = to_string(ref_names[j]); best_val = r }
        if (t == "WEAK" && best_tag == "NONE") { best_tag = t; best_ref = to_string(ref_names[j]); best_val = r }
        j = j + 1
    }
    println("  " + to_string(names[i]) + " " + to_string(m) + " GeV  ->  " + best_tag + "  " + best_ref + "=" + to_string(best_val))
    i = i + 1
}

println("")
println("=================================================================")
println("SUMMARY: J/psi=3.097 ~ phi^2 (EXACT), Z=91.188 ~ sigma*tau*... ")
println("=================================================================")
