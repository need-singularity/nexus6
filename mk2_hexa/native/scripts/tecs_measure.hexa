// Ported from tecs-l/scripts/tecs_measure.py — 2026-04-10
// TECS-L Domain Health Measurement — pure classification + health logic.

fn classify(fname: string) -> list {
    let f = fname
    let mut matches = []
    if f.contains("sigma") || f.contains("tau") || f.contains("phi") || f.contains("perfect") || f.contains("divisor") || f.contains("prime") || f.contains("number") { matches = matches + ["N"] }
    if f.contains("analysis") || f.contains("zeta") || f.contains("riemann") || f.contains("golden") { matches = matches + ["A"] }
    if f.contains("group") || f.contains("algebra") || f.contains("su2") || f.contains("e8") || f.contains("lie") { matches = matches + ["G"] }
    if f.contains("topology") || f.contains("knot") || f.contains("homology") { matches = matches + ["T"] }
    if f.contains("fibonacci") || f.contains("catalan") || f.contains("combinat") { matches = matches + ["C"] }
    if f.contains("quantum") || f.contains("planck") || f.contains("cmb") { matches = matches + ["Q"] }
    if f.contains("entropy") || f.contains("information") || f.contains("qubit") { matches = matches + ["I"] }
    if f.contains("ising") || f.contains("boltzmann") || f.contains("statistic") { matches = matches + ["S"] }
    if len(matches) == 0 { matches = ["N"] }
    return matches
}

fn health_of(gap: f64, stagnant: i64) -> string {
    if gap > 0.75 { return "critical" }
    if stagnant >= 3 { return "stagnant" }
    if gap > 0.4 { return "behind" }
    if gap > 0.1 { return "on_track" }
    return "thriving"
}

fn compute_gap(exact: i64, total: i64, target_rate: f64) -> f64 {
    if total == 0 { return 1.0 }
    let exact_rate = to_float(exact) / to_float(total)
    if target_rate <= 0.0 { return 0.0 }
    let progress = exact_rate / target_rate
    let p = if progress > 1.0 { 1.0 } else { progress }
    return 1.0 - p
}

println("=================================================================")
println("tecs_measure.hexa — domain health measurement demo")
println("=================================================================")

println("")
println("  Classification test:")
let files = ["h100-prime-gap.md", "h200-sigma-6.md", "h300-fibonacci.md", "h400-quantum-cmb.md", "h500-ising-2d.md"]
let mut i = 0
while i < len(files) {
    let f = files[i]
    let ds = classify(f)
    println("    " + f + "  -> " + to_string(ds))
    i = i + 1
}

println("")
println("  Health computation:")
let domains = ["N", "A", "G", "T", "C", "Q", "I", "S"]
let hyp = [450, 320, 180, 95, 210, 280, 150, 100]
let exact = [150, 90, 20, 10, 40, 70, 35, 18]
let target_rate = 0.6

let mut best_code = "?"
let mut best_score = 0.0 - 1.0
let weights = [0.12, 0.12, 0.11, 0.10, 0.10, 0.13, 0.11, 0.12]
let mut j = 0
while j < len(domains) {
    let code = domains[j]
    let gap = compute_gap(exact[j], hyp[j], target_rate)
    let health = health_of(gap, 0)
    let score = gap * weights[j]
    println("    " + code + "  hyp=" + to_string(hyp[j]) + "  exact=" + to_string(exact[j]) + "  gap=" + to_string(gap) + "  health=" + health + "  score=" + to_string(score))
    if score > best_score {
        best_score = score
        best_code = code
    }
    j = j + 1
}

println("")
println("  weakest domain: " + best_code + "  score=" + to_string(best_score))

println("")
println("=================================================================")
println("SUMMARY: health=critical/behind/on_track/thriving/stagnant")
println("=================================================================")
