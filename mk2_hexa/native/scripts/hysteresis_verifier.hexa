// Ported from tecs-l/scripts/hysteresis_verifier.py — 2026-04-10
// Hysteresis Verifier — Landau free energy cusp control
// F(G,I) = G^4/4 - f(I)*G^2/2 + (D*P)*G; dG/dt = -G^3 + f(I)*G - D*P

fn landau_force(g: f64, a: f64, b: f64) -> f64 {
    return 0.0 - g * g * g + a * g - b
}

fn f_of_i(i: f64, i_c: f64, c: f64) -> f64 {
    return c * (i_c - i)
}

fn clamp(x: f64, lo: f64, hi: f64) -> f64 {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn sweep(i_start: f64, i_end: f64, dp: f64, i_c: f64, c: f64, n_steps: i64, dt: f64, relax: i64) -> list {
    let mut is = []
    let mut gs = []
    let a_init = f_of_i(i_start, i_c, c)
    let mut g = 0.0
    if a_init > 0.0 {
        if i_end > i_start {
            g = 0.0 - sqrt(a_init) - 0.1
        } else {
            g = sqrt(a_init) + 0.1
        }
    }
    let di = (i_end - i_start) / to_float(n_steps)
    let mut step = 0
    while step <= n_steps {
        let i = i_start + di * to_float(step)
        let a = f_of_i(i, i_c, c)
        let mut r = 0
        while r < relax {
            let force = landau_force(g, a, dp)
            g = g + dt * force
            g = clamp(g, 0.0 - 10.0, 10.0)
            r = r + 1
        }
        is = is + [i]
        gs = gs + [g]
        step = step + 1
    }
    return [is, gs]
}

fn measure_hysteresis(fi: list, fg: list, bi: list, bg: list, threshold: f64) -> i64 {
    let mut count = 0
    let mut i = 0
    while i < len(fi) {
        let i_f = fi[i]
        // find nearest j
        let mut best_j = 0
        let mut best_d = 1.0e9
        let mut j = 0
        while j < len(bi) {
            let d = abs_f(bi[j] - i_f)
            if d < best_d {
                best_d = d
                best_j = j
            }
            j = j + 1
        }
        if best_d < 0.02 {
            let diff = abs_f(fg[i] - bg[best_j])
            if diff > threshold {
                count = count + 1
            }
        }
        i = i + 1
    }
    return count
}

let dp = 0.3
let i_c = 0.5
let c = 3.0
let i_min = 0.05
let i_max = 0.95

println("=================================================================")
println("  Hysteresis Verifier")
println("=================================================================")
println("")
println("  Parameters:")
println("    D*P = " + to_string(dp))
println("    I_c = " + to_string(i_c))
println("    c   = " + to_string(c))
println("    I   = [" + to_string(i_min) + ", " + to_string(i_max) + "]")

let a_crit = pow(27.0 * dp * dp / 4.0, 1.0 / 3.0)
let i_hyst_start = i_c - a_crit / c
println("")
println("  Theoretical hysteresis start I = " + to_string(i_hyst_start))

println("")
println("  Forward sweep ...")
let fwd = sweep(i_min, i_max, dp, i_c, c, 100, 0.01, 50)
println("  Backward sweep ...")
let bwd = sweep(i_max, i_min, dp, i_c, c, 100, 0.01, 50)

let fi = fwd[0]
let fg = fwd[1]
let bi = bwd[0]
let bg = bwd[1]

let hyst_count = measure_hysteresis(fi, fg, bi, bg, 0.3)

println("")
println("=================================================================")
println("  Results")
println("=================================================================")
println("  Hysteresis points: " + to_string(hyst_count))

let gz_lower = 0.5 - log(4.0 / 3.0)
let gz_upper = 0.5
println("  Golden Zone: [" + to_string(gz_lower) + ", " + to_string(gz_upper) + "]")

if hyst_count > 0 {
    println("  PASS: Hysteresis found")
} else {
    println("  No hysteresis detected")
}

println("")
println("=================================================================")
println("SUMMARY: I cusp control, hysteresis " + to_string(hyst_count) + " pts")
println("=================================================================")
