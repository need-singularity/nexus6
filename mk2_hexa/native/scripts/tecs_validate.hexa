// Ported from tecs-l/scripts/tecs_validate.py — 2026-04-10
// TECS-L 3-Way Cross-Validation — n6_check pure logic.
// Demonstrates n6 EXACT / CLOSE / WEAK matching.

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn n6_exact(v: i64) -> string {
    if v == 6 { return "n" }
    if v == 12 { return "sigma" }
    if v == 4 { return "tau" }
    if v == 2 { return "phi" }
    if v == 24 { return "J2" }
    if v == 5 { return "sopfr" }
    if v == 10 { return "sigma-phi" }
    if v == 8 { return "sigma-tau" }
    if v == 11 { return "sigma-mu" }
    if v == 3 { return "n/phi" }
    if v == 1 { return "mu" }
    if v == 144 { return "sigma^2" }
    if v == 288 { return "sigma*J2" }
    if v == 48 { return "sigma*tau" }
    if v == 20 { return "J2-tau" }
    if v == 7 { return "sigma-sopfr" }
    return ""
}

fn n6_check(val: f64) -> list {
    // Integer match
    let iv = to_int(val)
    if to_float(iv) == val {
        let name = n6_exact(iv)
        if name != "" {
            return ["EXACT", name, to_string(iv)]
        }
    }
    // Ratio match
    let ratios = [0.3333333333333333, 0.6666666666666666, 1.3333333333333333, 0.2877, 0.6931, 1.0986, 0.3679, 0.1, 0.05]
    let rnames = ["mu/n/phi", "phi/n/phi", "tau^2/sigma", "ln(4/3)", "ln(2)", "ln(3)", "1/e", "1/(sigma-phi)", "1/J2-tau"]
    let mut i = 0
    while i < len(ratios) {
        let r = ratios[i]
        if r != 0.0 {
            let rel = abs_f(val - r) / abs_f(r)
            if rel < 0.01 {
                let tag = if rel < 0.001 { "CLOSE" } else { "WEAK" }
                return [tag, rnames[i], to_string(r)]
            }
        }
        i = i + 1
    }
    return ["NONE", "", ""]
}

println("=================================================================")
println("tecs_validate.hexa — 3-Way validation demo")
println("=================================================================")

let test_vals = [6.0, 12.0, 4.0, 2.0, 24.0, 144.0, 0.3333, 0.2877, 0.6931, 1.0986, 0.3679, 7.5, 99.0]
let mut i = 0
while i < len(test_vals) {
    let v = test_vals[i]
    let result = n6_check(v)
    println("  val=" + to_string(v) + "  " + to_string(result[0]) + "  " + to_string(result[1]) + "  val=" + to_string(result[2]))
    i = i + 1
}

println("")
println("=================================================================")
println("SUMMARY: n6_check implements EXACT / CLOSE / WEAK matching")
println("=================================================================")
