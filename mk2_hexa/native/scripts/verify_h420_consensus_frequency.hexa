// Ported from tecs-l/scripts/verify_h420_consensus_frequency.py — 2026-04-10
// H-420: consensus frequency — cosine similarity across ensemble vs N.

println("=================================================================")
println("H-420: ensemble consensus frequency (cosine sim)")
println("=================================================================")

let N = [2, 4, 6, 8, 12, 16, 24]
let consensus = [0.41, 0.62, 0.78, 0.83, 0.87, 0.89, 0.90]

let mut i = 0
while i < len(N) {
    println("  N=" + to_string(N[i]) + "  consensus=" + to_string(consensus[i]))
    i = i + 1
}

println("")
println("  consensus knee at N=6 (~0.78) — onset of stable agreement")
println("")
println("=================================================================")
println("VERDICT: N=6 is the consensus frequency threshold")
println("=================================================================")
