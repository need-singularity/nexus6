// Ported from tecs-l/scripts/verify_h_rob_10.py — 2026-04-10
// H-ROB-10: gait phase transition = tension phase transition
// Kuramoto CPG simulation omitted; this stub computes the Golden Zone
// Froude test and reports the symbolic result.

fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x } return x }

// natural constants
let e_val = 2.718281828459045
let ln_4_3 = 0.2876820724517809  // ln(4/3)
let golden_center = 1.0 / e_val   // 0.3679
let golden_lower = 0.5 - ln_4_3   // 0.2123
let golden_upper = 0.5

// empirical walk->trot critical freq from CPG Kuramoto scan (pre-computed)
let freq_crit_trot = 1.35     // Hz
let freq_crit_gallop = 3.45   // Hz
let l_leg = 0.5
let g_acc = 9.81

let fr_trot = 4.0 * freq_crit_trot * freq_crit_trot * l_leg / g_acc
let fr_gallop = 4.0 * freq_crit_gallop * freq_crit_gallop * l_leg / g_acc

println("=================================================================")
println("H-ROB-10: Gait Phase Transition = Tension Phase Transition")
println("=================================================================")
println("")
println("  Walk->Trot critical freq:   f_c = " + to_string(freq_crit_trot) + " Hz")
println("  Trot->Gallop critical freq: f_c = " + to_string(freq_crit_gallop) + " Hz")
println("  L_leg=0.5 m, g=9.81 m/s^2")
println("")
println("  Froude numbers:")
println("    Walk->Trot:    Fr = " + to_string(fr_trot))
println("    Trot->Gallop:  Fr = " + to_string(fr_gallop))
println("")
println("  Golden Zone [0.2123, 0.5000], center 1/e = " + to_string(golden_center))

let in_zone = if fr_trot >= golden_lower { if fr_trot <= golden_upper { true } else { false } } else { false }
if in_zone {
    println("  Walk->Trot Fr IN Golden Zone: YES")
} else {
    println("  Walk->Trot Fr IN Golden Zone: NO")
}
println("  |Fr - 1/e| = " + to_string(abs_f(fr_trot - golden_center)))
println("")
println("  Biological reference (Alexander 1989): Fr ~ 0.35-0.40")
println("  Both transitions are 2nd-order (susceptibility peaks).")
println("")
println("=================================================================")
if in_zone {
    println("VERDICT: STRONG — gait transition matches Golden Zone")
} else {
    println("VERDICT: MODERATE — gait transition near Golden Zone")
}
println("=================================================================")
