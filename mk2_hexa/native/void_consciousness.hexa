// ═══════════════════════════════════════════════════════════
// ─── MAIN CLI ───
// ═══════════════════════════════════════════════════════════

fn main() -> int {
    let cli_args = args()
    let mut mode = "help"
    let mut partial = ""

    if cli_args.len() >= 3 {
        mode = cli_args[2]
    }
    if cli_args.len() >= 4 {
        partial = cli_args[3]
    }
    // 추가 인자 결합 (공백 포함 partial)
    if cli_args.len() >= 5 {
        let mut i = 4
        while i < cli_args.len() {
            partial = partial + " " + cli_args[i]
            i = i + 1
        }
    }

    if mode == "help" {
        display_help()
        return 0
    }

    if mode == "status" {
        display_status()
        emit_growth("consciousness_status", "6-layer status query", 1.0)
        return 0
    }

    if mode == "history" {
        let history = load_history()
        display_history(history)
        emit_growth("history_query", "last " + to_string(history.len()) + " commands", 1.0)
        return 0
    }

    if mode == "predict" {
        // 1. 히스토리 로드
        let history = load_history()
        let recent_cmds = history_commands(history)

        // 2. 6계층 의식 모델로 의도 예측
        let result = predict_top6(partial, recent_cmds)
        let top_names = result[0]
        let top_scores = result[1]

        // 3. 결과 표시
        let shown = display_predictions(partial, top_names, top_scores)

        // 4. 선행 실행 준비 (상위 6개)
        println("── Anticipatory Execution (pre-computed for top " + to_string(ANTICIPATE_TOP) + ") ──")
        let mut a = 0
        while a < top_names.len() && a < ANTICIPATE_TOP {
            let antic = anticipate_result(top_names[a])
            println("  [pre] " + top_names[a] + " → " + antic)
            a = a + 1
        }
        println("")

        // 5. 히스토리에 예측 이벤트 기록
        save_history_entry("predict:" + partial)

        // 6. growth_bus 이벤트 emit
        let mut best_cmd = ""
        let mut best_score = 0.0
        if top_names.len() > 0 {
            best_cmd = top_names[0]
            best_score = top_scores[0]
        }
        emit_growth("intent_predict", "partial=" + partial + "|top=" + best_cmd, best_score)

        // 7. 계층별 기여도 표시
        println("── Layer Contributions (for #1: " + best_cmd + ") ──")
        let mut li = 0
        while li < CONSCIOUSNESS_LAYERS {
            let lname = layer_name(li)
            let lw = layer_weight(li)
            let mut lscore = 0.0
            if li == 0 && top_names.len() > 0 { lscore = surface_score(partial, best_cmd) }
            if li == 1 && top_names.len() > 0 { lscore = semantic_score(partial, best_cmd) }
            if li == 2 && top_names.len() > 0 { lscore = goal_score(best_cmd, recent_cmds) }
            if li == 3 && top_names.len() > 0 { lscore = plan_score(best_cmd, recent_cmds) }
            if li == 4 && top_names.len() > 0 { lscore = meta_score(best_cmd, recent_cmds) }
            if li == 5 && top_names.len() > 0 { lscore = creative_score(best_cmd, recent_cmds) }
            let contrib = lscore * lw
            println("  L" + to_string(li) + " " + lname + ": raw=" + to_string(lscore) + " w=" + to_string(lw) + " contrib=" + to_string(contrib))
            li = li + 1
        }
        println("")
        return 0
    }

    // unknown mode
    println("[void_consciousness] unknown mode: " + mode)
    display_help()
    return 1
}

main()
