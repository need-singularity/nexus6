// wave_airgenome.hexa -- 대기 성분 공명 (분자 진동수 x n=6 고조파 매핑)
// 사용: hexa wave_airgenome.hexa
//       hexa wave_airgenome.hexa --help
//       hexa wave_airgenome.hexa --threshold T    공명 임계값 (기본 0.1)
//
// 원리:
//   1. 주요 대기 분자 12종의 기본 진동수(cm-1)
//   2. 진동수를 n=6 고조파(6,12,24,36,48,72,120,720)로 나눠서 배수 근접도 분석
//   3. n=6 공명 분자: 진동수 % 6k < threshold 인 것
//   4. 센서 최적 밴드: n=6 공명 주파수 대역 제안
//   5. growth_bus.jsonl 기록

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _bus_path = _shared + "/growth_bus.jsonl"

let args = exec("echo $@").trim().split(" ")

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

fn safe_float(s: string) -> f64 {
    let mut v: f64 = 0.0
    try { v = to_float(s.trim()) } catch e {}
    return v
}

// ═══════════════════════════════════════════════════════════
// 도움말
// ═══════════════════════════════════════════════════════════

let mut show_help = false
let mut threshold: f64 = 0.1  // 공명 임계값 (나머지/고조파 비율)
for a in args {
    if a == "--help" || a == "-h" { show_help = true }
}
// --threshold T 파싱
let mut ai: i64 = 0
while ai < len(args) - 1 {
    if args[ai] == "--threshold" {
        threshold = safe_float(args[ai + 1])
        if threshold <= 0.0 { threshold = 0.1 }
    }
    ai = ai + 1
}

if show_help {
    println("")
    println("  wave_airgenome.hexa -- 대기 성분 공명")
    println("")
    println("  사용법:")
    println("    hexa wave_airgenome.hexa                     전체 분석")
    println("    hexa wave_airgenome.hexa --threshold 0.05    엄격한 임계값")
    println("    hexa wave_airgenome.hexa --help              이 도움말")
    println("")
    println("  대기 분자 12종 x n=6 고조파 8종 = 96 교차점 분석")
    println("  공명 조건: (진동수 % 고조파) / 고조파 < threshold")
    println("")
}

if show_help {  } else {

// ═══════════════════════════════════════════════════════════
// 대기 분자 정의
// ═══════════════════════════════════════════════════════════

let mol_names = ["N2", "O2", "CO2", "H2O", "CH4", "N2O", "O3", "SO2", "NO2", "CO", "Ar", "He"]
let mol_freq = [2331, 1556, 2349, 3657, 3019, 2224, 1103, 1151, 1318, 2143, 0, 0]
// 대기 중 농도 (ppm 기준, 대략)
let mol_conc = ["780840", "209460", "420", "25000", "1.9", "0.33", "0.07", "0.01", "0.02", "0.1", "9340", "5.2"]

// n=6 고조파 목록
let harmonics = [6, 12, 24, 36, 48, 72, 120, 720]
let harmonic_labels = ["n", "sigma", "J2", "6^2", "sigma*tau", "sigma*n", "5!", "6!"]

println("")
println("===========================================================")
println("  대기 성분 공명 -- 분자 진동수 x n=6 고조파 매핑")
println("  12 분자 x 8 고조파 = 96 교차점, 임계값: " + to_string(threshold))
println("===========================================================")
println("")

// ═══════════════════════════════════════════════════════════
// 1. 분자별 기본 정보
// ═══════════════════════════════════════════════════════════

println("  --- 대기 분자 기본 진동수 ---")
println("")
println("| 분자 | 진동수(cm-1) | 대기 농도(ppm) | 비고 |")
println("|------|------------|--------------|------|")

let mut mi: i64 = 0
while mi < len(mol_names) {
    let note = if mol_freq[mi] == 0 { "단원자, 진동 없음" } else { "" }
    println("| " + mol_names[mi] + " | " + to_string(mol_freq[mi]) + " | " + mol_conc[mi] + " | " + note + " |")
    mi = mi + 1
}
println("")

// ═══════════════════════════════════════════════════════════
// 2. 진동수 / 고조파 = 배수 근접도 분석
// ═══════════════════════════════════════════════════════════

println("  --- n=6 고조파 배수 근접도 행렬 ---")
println("")

// 헤더
let mut header = "| 분자\\고조파 |"
let mut hi: i64 = 0
while hi < len(harmonics) {
    header = header + " " + harmonic_labels[hi] + "(" + to_string(harmonics[hi]) + ") |"
    hi = hi + 1
}
println(header)

let mut sep = "|------------|"
hi = 0
while hi < len(harmonics) {
    sep = sep + "---------|"
    hi = hi + 1
}
println(sep)

// 공명 카운트 추적
let mut resonance_count: i64 = 0
let mut resonance_molecules = []
let mut resonance_harmonics_list = []
let mut resonance_ratios = []

mi = 0
while mi < len(mol_names) {
    let freq: i64 = mol_freq[mi]
    let mut row = "| " + mol_names[mi] + " |"

    if freq == 0 {
        hi = 0
        while hi < len(harmonics) {
            row = row + " - |"
            hi = hi + 1
        }
    } else {
        hi = 0
        while hi < len(harmonics) {
            let h: i64 = harmonics[hi]
            let quotient: i64 = freq / h
            let remainder: i64 = freq - (quotient * h)
            // 근접도: min(remainder, h-remainder) / h
            let mut closest_rem: i64 = remainder
            if (h - remainder) < remainder { closest_rem = h - remainder }
            let proximity: f64 = to_float(closest_rem) / to_float(h)

            if proximity < threshold {
                // 공명!
                let actual_multiple: i64 = if closest_rem == remainder { quotient } else { quotient + 1 }
                row = row + " *" + to_string(actual_multiple) + "x* |"
                resonance_count = resonance_count + 1
                resonance_molecules = resonance_molecules + [mol_names[mi]]
                resonance_harmonics_list = resonance_harmonics_list + [h]
                resonance_ratios = resonance_ratios + [proximity]
            } else {
                // 비율 표시 (소수점 2자리)
                let pct: i64 = to_int(proximity * 100.0)
                row = row + " " + to_string(pct) + "% |"
            }
            hi = hi + 1
        }
    }

    println(row)
    mi = mi + 1
}

println("")

// ═══════════════════════════════════════════════════════════
// 3. n=6 공명 분자 목록
// ═══════════════════════════════════════════════════════════

println("  --- n=6 공명 분자 ---")
println("")

if resonance_count == 0 {
    println("  공명 분자 없음 (임계값 " + to_string(threshold) + " 에서)")
} else {
    println("| 분자 | 진동수 | 고조파 | 배수 | 근접도 |")
    println("|------|--------|--------|------|--------|")

    let mut ri: i64 = 0
    while ri < resonance_count {
        let rmol: string = resonance_molecules[ri]
        let rh: i64 = resonance_harmonics_list[ri]
        let rr: f64 = resonance_ratios[ri]

        // 해당 분자의 진동수 찾기
        let mut rfreq: i64 = 0
        let mut fi: i64 = 0
        while fi < len(mol_names) {
            if mol_names[fi] == rmol { rfreq = mol_freq[fi] }
            fi = fi + 1
        }

        let multiple: i64 = (rfreq + rh / 2) / rh   // 반올림 나눗셈
        let pct_r: i64 = to_int(rr * 1000.0)
        let pct_str = to_string(pct_r / 10) + "." + to_string(pct_r % 10) + "%"

        println("| " + rmol + " | " + to_string(rfreq) + " | " + to_string(rh) + " | " + to_string(multiple) + "x | " + pct_str + " |")
        ri = ri + 1
    }
}

println("")

// ═══════════════════════════════════════════════════════════
// 4. 센서 최적 밴드 제안
// 공명 주파수 ± 오차 범위 = 센서 밴드
// ═══════════════════════════════════════════════════════════

println("  --- 센서 최적 밴드 제안 (n=6 공명 기반) ---")
println("")

if resonance_count == 0 {
    println("  공명 없음 -- 임계값을 높여서 재시도하세요")
} else {
    println("| 분자 | 중심 주파수(cm-1) | 밴드폭(cm-1) | 고조파 기원 |")
    println("|------|-----------------|------------|-----------|")

    // 고유 분자별로 최적 밴드 1개씩
    let mut seen_mol = []
    let mut ri2: i64 = 0
    while ri2 < resonance_count {
        let rmol2: string = resonance_molecules[ri2]
        // 중복 체크
        let mut dup = false
        for sm in seen_mol { if sm == rmol2 { dup = true } }
        if !dup {
            seen_mol = seen_mol + [rmol2]
            let rh2: i64 = resonance_harmonics_list[ri2]

            // 해당 분자 진동수
            let mut rfreq2: i64 = 0
            let mut fi2: i64 = 0
            while fi2 < len(mol_names) {
                if mol_names[fi2] == rmol2 { rfreq2 = mol_freq[fi2] }
                fi2 = fi2 + 1
            }

            // 밴드폭 = 고조파 * threshold * 2 (양쪽)
            let bandwidth: i64 = to_int(to_float(rh2) * threshold * 2.0)
            let bw_show = if bandwidth < 1 { 1 } else { bandwidth }

            println("| " + rmol2 + " | " + to_string(rfreq2) + " | +-" + to_string(bw_show) + " | " + to_string(rh2) + " 고조파 |")
        }
        ri2 = ri2 + 1
    }
}

println("")

// ═══════════════════════════════════════════════════════════
// 5. ASCII 공명 스펙트럼
// ═══════════════════════════════════════════════════════════

println("  --- 공명 스펙트럼 (분자별 공명 횟수) ---")
println("")

// 분자별 공명 횟수 카운트
let mut mol_res_count = []
mi = 0
while mi < len(mol_names) {
    let mut cnt: i64 = 0
    let mut ri3: i64 = 0
    while ri3 < resonance_count {
        if resonance_molecules[ri3] == mol_names[mi] { cnt = cnt + 1 }
        ri3 = ri3 + 1
    }
    mol_res_count = mol_res_count + [cnt]
    mi = mi + 1
}

mi = 0
while mi < len(mol_names) {
    let rc: i64 = mol_res_count[mi]
    let mut bar = ""
    let mut bi: i64 = 0
    while bi < rc {
        bar = bar + "##"
        bi = bi + 1
    }
    let label = mol_names[mi]
    if rc > 0 {
        println("  " + label + "\t" + bar + " " + to_string(rc) + " 공명")
    } else {
        if mol_freq[mi] > 0 {
            println("  " + label + "\t. 0")
        } else {
            println("  " + label + "\t- (무진동)")
        }
    }
    mi = mi + 1
}

println("")

// ═══════════════════════════════════════════════════════════
// 요약
// ═══════════════════════════════════════════════════════════

let mut unique_mol: i64 = 0
let mut seen2 = []
let mut ri4: i64 = 0
while ri4 < resonance_count {
    let mut dup2 = false
    for s2 in seen2 { if s2 == resonance_molecules[ri4] { dup2 = true } }
    if !dup2 {
        unique_mol = unique_mol + 1
        seen2 = seen2 + [resonance_molecules[ri4]]
    }
    ri4 = ri4 + 1
}

println("  요약:")
println("  - 분석 대상: 12 분자 x 8 고조파 = 96 교차점")
println("  - 공명 발견: " + to_string(resonance_count) + "건 (" + to_string(unique_mol) + "종 분자)")
println("  - 임계값: " + to_string(threshold))
println("  - 무진동 분자: Ar, He (단원자)")
println("")

// ═══════════════════════════════════════════════════════════
// growth_bus 기록
// ═══════════════════════════════════════════════════════════

try {
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
    let entry = "{\"type\":\"wave_airgenome\",\"molecules\":12,\"harmonics\":8,\"crosspoints\":96,\"resonances\":" + to_string(resonance_count) + ",\"unique_molecules\":" + to_string(unique_mol) + ",\"threshold\":" + to_string(threshold) + ",\"ts\":\"" + ts + "\"}"
    exec("echo '" + entry + "' >> " + _bus_path)
} catch e {}

println("  growth_bus 기록 완료")
println("")
println("[verified] wave_airgenome.hexa 실행 완료")
println("")

}
