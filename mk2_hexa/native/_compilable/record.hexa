// record.hexa — AlienIndex(d,r) + Record (Mk.I+ 호환)

struct AlienIndex {
    d: i64,
    r: i64
}

fn alien_new(d: i64, r: i64) -> AlienIndex {
    return AlienIndex { d: d, r: r }
}

fn can_promote(ai: AlienIndex) -> bool {
    return ai.r == 10
}

// 승격: (d, 10) → (d+1, 0). r != 10 이면 sentinel (-1).
fn breakthrough_ai(ai: AlienIndex) -> AlienIndex {
    if ai.r == 10 {
        return alien_new(ai.d + 1, 0)
    }
    return alien_new(-1, 0)
}

fn is_sentinel(ai: AlienIndex) -> bool {
    return ai.d == -1
}

// === 검증 ===
println("=== AlienIndex self-test ===")
let a1 = alien_new(0, 10)
let a2 = alien_new(0, 9)
let a3 = alien_new(3, 10)

println("a1=(0,10) can_promote=", can_promote(a1))
println("a2=(0,9) can_promote=", can_promote(a2))
println("a3=(3,10) can_promote=", can_promote(a3))

let child1 = breakthrough_ai(a1)
let child2 = breakthrough_ai(a2)
let child3 = breakthrough_ai(a3)

println("a1 → child=(", child1.d, ",", child1.r, ") [expect (1,0)]")
println("a2 → child sentinel?", is_sentinel(child2), "[expect true]")
println("a3 → child=(", child3.d, ",", child3.r, ") [expect (4,0)]")

assert can_promote(a1)
assert !can_promote(a2)
assert can_promote(a3)
assert child1.d == 1
assert child1.r == 0
assert is_sentinel(child2)
assert child3.d == 4
assert child3.r == 0
println("✅ AlienIndex tests passed")

// === 자기유사 승격 체인 (재귀 없이 iter) ===
println("")
println("=== self-similar promotion chain ===")
let mut cur = alien_new(0, 10)
let mut depth = 0
while can_promote(cur) && depth < 10 {
    let nxt = breakthrough_ai(cur)
    if is_sentinel(nxt) { depth = 10 }
    else {
        cur = alien_new(nxt.d, 10)   // 가정: 각 d 에서 r=10 달성
        depth = depth + 1
        println("  d", cur.d, ": r=10 (breakthrough), continuing...")
    }
}
println("chain length:", depth)
