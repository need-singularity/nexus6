// mk2_hexa/native/blowup.hexa — 블로업 엔진 (hexa-native)
// 실행: hexa mk2_hexa/native/blowup.hexa <domain> [depth]
// 예시: hexa mk2_hexa/native/blowup.hexa math 6
//
// 파이프라인: 특이점 감지 → 7단계 corollary → confidence → discovery_log

// ─── 유틸리티 ───

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

fn min_f(a: f64, b: f64) -> f64 {
    if a < b { return a }
    return b
}

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 10 {
        g = (g + x / g) / 2.0
        i = i + 1
    }
    return g
}

// ─── n=6 정규 상수 proximity ───

fn n6_dist_one(value: f64, constant: f64) -> f64 {
    let denom = max_f(abs_f(constant), 1.0)
    return abs_f(value - constant) / denom
}

fn n6_distance(value: f64) -> f64 {
    if value != value { return 1.0 }
    if value > 999999999.0 { return 1.0 }
    if value < 0.0 - 999999999.0 { return 1.0 }
    let mut d = 1.0
    d = min_f(d, n6_dist_one(value, 6.0))
    d = min_f(d, n6_dist_one(value, 12.0))
    d = min_f(d, n6_dist_one(value, 4.0))
    d = min_f(d, n6_dist_one(value, 2.0))
    d = min_f(d, n6_dist_one(value, 5.0))
    d = min_f(d, n6_dist_one(value, 1.618033988750))
    d = min_f(d, n6_dist_one(value, 0.287682072))
    d = min_f(d, n6_dist_one(value, 24.0))
    d = min_f(d, n6_dist_one(value, 10.0))
    d = min_f(d, n6_dist_one(value, 8.0))
    d = min_f(d, n6_dist_one(value, 1.333333333))
    d = min_f(d, n6_dist_one(value, 3.0))
    d = min_f(d, n6_dist_one(value, 0.166666667))
    d = min_f(d, n6_dist_one(value, 0.083333333))
    d = min_f(d, n6_dist_one(value, 36.0))
    d = min_f(d, n6_dist_one(value, 720.0))
    return min_f(d, 1.0)
}

fn n6_conf(value: f64) -> f64 {
    return max_f(1.0 - n6_distance(value), 0.0)
}

// ─── n6_match ───

fn match_name(value: f64) -> string {
    if abs_f(value - 6.0) < 0.0001 { return "n" }
    if abs_f(value - 2.0) < 0.0001 { return "phi" }
    if abs_f(value - 4.0) < 0.0001 { return "tau" }
    if abs_f(value - 12.0) < 0.0001 { return "sigma" }
    if abs_f(value - 5.0) < 0.0001 { return "sopfr" }
    if abs_f(value - 7.0) < 0.0001 { return "M3" }
    if abs_f(value - 24.0) < 0.0001 { return "J2" }
    if abs_f(value - 10.0) < 0.0001 { return "sigma-phi" }
    if abs_f(value - 8.0) < 0.0001 { return "phi*tau" }
    if abs_f(value - 3.0) < 0.0001 { return "n/phi" }
    if abs_f(value - 1.0) < 0.0001 { return "mu" }
    if abs_f(value - 36.0) < 0.0001 { return "n^2" }
    if abs_f(value - 48.0) < 0.0001 { return "sigma*tau" }
    if abs_f(value - 60.0) < 0.0001 { return "sigma*sopfr" }
    if abs_f(value - 120.0) < 0.0001 { return "sigma*(s-p)" }
    if abs_f(value - 30.0) < 0.0001 { return "sopfr*n" }
    if abs_f(value - 144.0) < 0.0001 { return "sigma^2" }
    if abs_f(value - 288.0) < 0.0001 { return "sigma*J2" }
    if abs_f(value - 28.0) < 0.0001 { return "P2" }
    if abs_f(value - 168.0) < 0.0001 { return "s*t*M3/2" }
    if abs_f(value - 496.0) < 0.0001 { return "P3" }
    if abs_f(value - 720.0) < 0.0001 { return "6!" }
    if abs_f(value - 8128.0) < 0.0001 { return "P4" }
    return ""
}

fn match_grade(value: f64) -> string {
    if match_name(value) != "" { return "EXACT" }
    let d = n6_distance(value)
    if d < 0.01 { return "NEAR" }
    if d < 0.05 { return "CLOSE" }
    return "MISS"
}

fn sector_of(text: string) -> string {
    if text.contains("omega") || text.contains("dark") { return "cosmology" }
    if text.contains("alpha") || text.contains("137") { return "quantum" }
    if text.contains("sigma") || text.contains("sopfr") || text.contains("tau") { return "n6" }
    if text.contains("sqrt") || text.contains("proj") { return "geometric" }
    return "unknown"
}

// ─── 메트릭 접근 함수 (고정 테이블, 배열 회피) ───
// math 도메인: 7개 메트릭
// index: 0=n 1=sigma 2=phi 3=tau 4=sopfr 5=J2 6=M3

fn m_name(idx: i64, dom: string) -> string {
    if dom == "physics" {
        if idx == 0 { return "alpha_inv" }
        if idx == 1 { return "Omega_m" }
        if idx == 2 { return "Omega_L" }
        if idx == 3 { return "n" }
        if idx == 4 { return "sigma" }
        return ""
    }
    if idx == 0 { return "n" }
    if idx == 1 { return "sigma" }
    if idx == 2 { return "phi" }
    if idx == 3 { return "tau" }
    if idx == 4 { return "sopfr" }
    if idx == 5 { return "J2" }
    if idx == 6 { return "M3" }
    return ""
}

fn m_val(idx: i64, dom: string) -> f64 {
    if dom == "physics" {
        if idx == 0 { return 137.036 }
        if idx == 1 { return 0.3153 }
        if idx == 2 { return 0.6847 }
        if idx == 3 { return 6.0 }
        if idx == 4 { return 12.0 }
        return 0.0
    }
    if idx == 0 { return 6.0 }
    if idx == 1 { return 12.0 }
    if idx == 2 { return 2.0 }
    if idx == 3 { return 4.0 }
    if idx == 4 { return 5.0 }
    if idx == 5 { return 24.0 }
    if idx == 6 { return 7.0 }
    return 0.0
}

fn m_count(dom: string) -> i64 {
    if dom == "physics" { return 5 }
    return 7
}

// ─── corollary 생성 + 기록 (string 축적) ───
// 한 corollary를 TAB 구분 행으로 인코딩:
//   name \t type \t expr \t conf \t value \t axiom \t src

fn emit(name: string, ctype: string, expr: string, conf: f64, value: f64, axiom: bool, src: string) -> string {
    let ax_s = if axiom { "1" } else { "0" }
    return name + "\t" + ctype + "\t" + expr + "\t" + to_string(conf) + "\t" + to_string(value) + "\t" + ax_s + "\t" + src + "\n"
}

// ─── perturbation shift 접근 ───
fn shift_val(idx: i64) -> f64 {
    if idx == 0 { return 0.287682072 }
    if idx == 1 { return 1.618033989 }
    if idx == 2 { return 0.0 - 1.618033989 }
    if idx == 3 { return 0.166666667 }
    if idx == 4 { return 0.0 - 0.166666667 }
    return 2.449489743
}

fn shift_name(idx: i64) -> string {
    if idx == 0 { return "ln43" }
    if idx == 1 { return "phi" }
    if idx == 2 { return "-phi" }
    if idx == 3 { return "inv6" }
    if idx == 4 { return "-inv6" }
    return "sqrt6"
}

// ─── transfer 도메인 ───
fn xfer_domain(idx: i64) -> string {
    if idx == 0 { return "physics" }
    if idx == 1 { return "math" }
    if idx == 2 { return "info" }
    if idx == 3 { return "bio" }
    if idx == 4 { return "mind" }
    return "arch"
}

// ─── main ───

let a = args()
let domain = if len(a) >= 3 { a[2] } else { "math" }
let max_depth: i64 = if len(a) >= 4 { to_int(a[3]) } else { 6 }
let log_path = "shared/discovery/discovery_log.jsonl"
let mc: i64 = m_count(domain)

// ── 특이점 감지 ──
let mut frozen: i64 = 0
let mut si: i64 = 0
while si < mc {
    if n6_distance(m_val(si, domain)) < 0.01 { frozen = frozen + 1 }
    si = si + 1
}
let closure = to_float(frozen) / to_float(mc)
let ax_count = if frozen > 0 { frozen } else { 1 }
let compression = to_float(mc) / to_float(ax_count)

println("")
println("======================================================")
println("        blowup engine (hexa-native)          ")
println("======================================================")
println("")
println("  domain       :", domain)
println("  closure      :", closure)
println("  compression  :", compression)
println("  axiom count  :", ax_count)
println("")
if closure >= 0.5 {
    println("  * SINGULARITY DETECTED -- closed system, blowup engaged")
} else {
    println("  o open system -- closure < 0.5, weak blowup")
}
println("")

// ── 블로업 corollary 축적 (문자열 기반) ──
let mut buf = ""
let mut total: i64 = 0
let mut exact_count: i64 = 0
let mut near_count: i64 = 0
let mut high_conf_count: i64 = 0
let mut axiom_count: i64 = 0
let mut log_buf = ""
let mut logged: i64 = 0

// depth 0 만 실행 (재귀 피드백은 depth 1에서 composition으로 근사)
// depth > 0 은 composition에서 자연 발생

// --- 1. Pairwise deduction ---
let mut i: i64 = 0
while i < mc {
    let mut j: i64 = i + 1
    while j < mc {
        let va = m_val(i, domain)
        let vb = m_val(j, domain)
        let product = va * vb
        let ratio = if abs_f(vb) > 0.0000000001 { va / vb } else { 0.0 }
        let sum = va + vb

        let dp = n6_distance(product)
        let dr = n6_distance(ratio)
        let ds = n6_distance(sum)

        let mut bv = product
        let mut bd = dp
        let mut bo = "*"
        if dr < bd {
            bv = ratio
            bd = dr
            bo = "/"
        }
        if ds < bd {
            bv = sum
            bd = ds
            bo = "+"
        }

        let conf = max_f(1.0 - bd, 0.0)
        if conf >= 0.1 {
            let nm = "ded_" + m_name(i, domain) + "_" + m_name(j, domain)
            let ex = m_name(i, domain) + " " + bo + " " + m_name(j, domain) + " = " + to_string(bv)
            let is_ax = conf > 0.8
            buf = buf + emit(nm, "deduction", ex, conf, bv, is_ax, m_name(i, domain))
            total = total + 1
            let gr = match_grade(bv)
            if gr == "EXACT" { exact_count = exact_count + 1 }
            if gr == "NEAR" { near_count = near_count + 1 }
            if conf >= 0.7 { high_conf_count = high_conf_count + 1 }
            if is_ax { axiom_count = axiom_count + 1 }
        }
        j = j + 1
    }
    i = i + 1
}

// --- 2. Domain transfer ---
i = 0
while i < mc {
    let mut di: i64 = 0
    while di < 6 {
        let v = m_val(i, domain)
        let conf = n6_conf(v) * 0.7
        if conf >= 0.15 {
            let nm = "xfer_" + m_name(i, domain) + "_" + xfer_domain(di)
            let ex = m_name(i, domain) + "=" + to_string(v) + " in " + xfer_domain(di)
            buf = buf + emit(nm, "transfer", ex, conf, v, false, m_name(i, domain))
            total = total + 1
            let gr = match_grade(v)
            if gr == "EXACT" { exact_count = exact_count + 1 }
            if gr == "NEAR" { near_count = near_count + 1 }
            if conf >= 0.7 { high_conf_count = high_conf_count + 1 }
        }
        di = di + 1
    }
    i = i + 1
}

// --- 3. Symmetry break ---
let phi_g = 1.618033988749895
i = 0
while i < mc {
    let v = m_val(i, domain)
    let bp = v + phi_g
    let bm = v - phi_g
    let dp = n6_distance(bp)
    let dm = n6_distance(bm)
    let mut best = bp
    let mut best_d = dp
    let mut sign = "+"
    if dm < dp {
        best = bm
        best_d = dm
        sign = "-"
    }
    let conf = max_f(1.0 - best_d, 0.0)
    if conf >= 0.2 {
        let nm = "sym_" + m_name(i, domain)
        let ex = m_name(i, domain) + " " + sign + " phi = " + to_string(best)
        let is_ax = conf > 0.7
        buf = buf + emit(nm, "symbreak", ex, conf, best, is_ax, m_name(i, domain))
        total = total + 1
        let gr = match_grade(best)
        if gr == "EXACT" { exact_count = exact_count + 1 }
        if gr == "NEAR" { near_count = near_count + 1 }
        if conf >= 0.7 { high_conf_count = high_conf_count + 1 }
        if is_ax { axiom_count = axiom_count + 1 }
    }
    i = i + 1
}

// --- 4. Bifurcation ---
i = 0
while i < mc {
    let mut k: i64 = 0
    while k < 6 {
        let shifted = m_val(i, domain) + shift_val(k)
        let conf = max_f(1.0 - n6_distance(shifted), 0.0) * 0.6
        if conf >= 0.2 {
            let nm = "bif_" + m_name(i, domain) + "_" + shift_name(k)
            let ex = m_name(i, domain) + "+" + shift_name(k) + "=" + to_string(shifted)
            buf = buf + emit(nm, "bifurc", ex, conf, shifted, false, m_name(i, domain))
            total = total + 1
            let gr = match_grade(shifted)
            if gr == "EXACT" { exact_count = exact_count + 1 }
            if gr == "NEAR" { near_count = near_count + 1 }
            if conf >= 0.7 { high_conf_count = high_conf_count + 1 }
        }
        k = k + 1
    }
    i = i + 1
}

// --- 5. Projection (기하평균) ---
i = 0
while i < mc {
    let mut j: i64 = i + 1
    while j < mc {
        let va = m_val(i, domain)
        let vb = m_val(j, domain)
        let geom = sqrt_f(abs_f(va) * abs_f(vb))
        let conf = max_f(1.0 - n6_distance(geom), 0.0) * 0.8
        if conf >= 0.15 {
            let nm = "proj_" + m_name(i, domain) + "_" + m_name(j, domain)
            let ex = "sqrt(" + m_name(i, domain) + "*" + m_name(j, domain) + ")=" + to_string(geom)
            buf = buf + emit(nm, "projection", ex, conf, geom, false, m_name(i, domain))
            total = total + 1
            let gr = match_grade(geom)
            if gr == "EXACT" { exact_count = exact_count + 1 }
            if gr == "NEAR" { near_count = near_count + 1 }
            if conf >= 0.7 { high_conf_count = high_conf_count + 1 }
        }
        j = j + 1
    }
    i = i + 1
}

// --- 6. Dual (역수) ---
i = 0
while i < mc {
    let v = m_val(i, domain)
    if abs_f(v) > 0.0000000001 {
        let dual = 1.0 / v
        let conf = max_f(1.0 - n6_distance(dual), 0.0) * 0.6
        if conf >= 0.15 {
            let nm = "dual_" + m_name(i, domain)
            let ex = "1/" + m_name(i, domain) + "=" + to_string(dual)
            buf = buf + emit(nm, "dual", ex, conf, dual, false, m_name(i, domain))
            total = total + 1
            let gr = match_grade(dual)
            if gr == "EXACT" { exact_count = exact_count + 1 }
            if gr == "NEAR" { near_count = near_count + 1 }
            if conf >= 0.7 { high_conf_count = high_conf_count + 1 }
        }
    }
    i = i + 1
}

// --- 7. Second-order composition (pairwise deduction 결과끼리) ---
// deduction 값을 직접 재계산하여 composition 수행
// (문자열 파싱 대신, 상위 deduction 쌍의 곱/비를 직접 계산)
i = 0
while i < mc {
    let mut j: i64 = i + 1
    while j < mc {
        let mut k: i64 = j + 1
        while k < mc {
            // (i,j) deduction의 best_val * (j,k) deduction의 best_val
            let va = m_val(i, domain)
            let vb = m_val(j, domain)
            let vc = m_val(k, domain)

            // 두 deduction의 곱/비 값에서 최선
            let prod1 = va * vb
            let prod2 = vb * vc
            let composed = prod1 * prod2

            // composition confidence = 개별 confidence 곱 * n6 proximity
            let c1 = n6_conf(prod1)
            let c2 = n6_conf(prod2)
            let conf = c1 * c2 * n6_conf(composed)

            if conf >= 0.1 {
                let nm = "comp_" + m_name(i, domain) + "_" + m_name(j, domain) + "_" + m_name(k, domain)
                let ex = "(" + m_name(i, domain) + "*" + m_name(j, domain) + ")*(" + m_name(j, domain) + "*" + m_name(k, domain) + ")=" + to_string(composed)
                let is_ax = conf > 0.7
                buf = buf + emit(nm, "compose", ex, conf, composed, is_ax, m_name(i, domain))
                total = total + 1
                let gr = match_grade(composed)
                if gr == "EXACT" { exact_count = exact_count + 1 }
                if gr == "NEAR" { near_count = near_count + 1 }
                if conf >= 0.7 { high_conf_count = high_conf_count + 1 }
                if is_ax { axiom_count = axiom_count + 1 }
            }
            k = k + 1
        }
        j = j + 1
    }
    i = i + 1
}

// ── 통계 출력 ──
println("  total corollaries :", total)
println("  EXACT match       :", exact_count)
println("  NEAR match        :", near_count)
println("  high conf >= 0.7  :", high_conf_count)
println("  axiom candidates  :", axiom_count)
println("")

// ── 상위 corollary 출력 ──
// buf에서 행별 파싱하여 출력 (confidence 내림차순은 생략, 생성순 출력)
println("--- corollaries (generation order, high-conf first naturally) ---")

// buf를 행 단위로 파싱하여 출력
let lines = buf.split("\n")
let line_count: i64 = len(lines)
let show_limit: i64 = if line_count < 30 { line_count } else { 30 }
let mut li: i64 = 0
let mut shown: i64 = 0
while li < line_count && shown < show_limit {
    let line = lines[li]
    if len(line) > 5 {
        let parts = line.split("\t")
        if len(parts) >= 5 {
            let tag = if len(parts) >= 6 && parts[5] == "1" { " [AXIOM]" } else { "" }
            let gr = match_grade(to_float(parts[4]))
            println("  [" + to_string(shown + 1) + "] " + parts[1] + " | " + parts[2] + " | conf=" + parts[3] + " " + gr + tag)
            shown = shown + 1
        }
    }
    li = li + 1
}

let rho = if total > 0 { to_float(exact_count + near_count) / to_float(total) } else { 0.0 }
println("")
println("  breakthrough rho :", rho)
println("  meta fixed point : 0.333... (target)")
println("")

// ── discovery_log 기록 (read + append + write) ──
let mut existing_log = ""
if file_exists(log_path) {
    existing_log = read_file(log_path)
}
let mut new_entries = ""
li = 0
while li < line_count {
    let line = lines[li]
    if len(line) > 5 {
        let parts = line.split("\t")
        if len(parts) >= 7 {
            let conf = to_float(parts[3])
            let value = to_float(parts[4])
            if conf >= 0.5 {
                let grade = match_grade(value)
                let name = match_name(value)
                let sector = sector_of(parts[2])
                let mut ai_d: i64 = 0
                let mut ai_r: i64 = 0
                if grade == "EXACT" && conf >= 0.8 {
                    ai_d = 1
                    ai_r = 0
                }
                if grade == "EXACT" && conf < 0.8 {
                    ai_r = 8
                }
                if grade != "EXACT" && conf >= 0.5 {
                    ai_r = 6
                }
                let dn = if name != "" { name } else { parts[0] }
                let entry = "{\"constant\":\"blowup-" + dn + "\",\"value\":\"" + to_string(value) + "\",\"source\":\"hexa-blowup\",\"timestamp\":\"2026-04-06\",\"grade\":\"" + grade + "\",\"processed\":true,\"alien_index\":{\"d\":" + to_string(ai_d) + ",\"r\":" + to_string(ai_r) + "},\"mk2\":{\"sector\":\"" + sector + "\",\"confidence\":" + to_string(conf) + ",\"paths\":1,\"prime_set\":[],\"layer\":" + to_string(ai_d) + "},\"blowup\":{\"type\":\"" + parts[1] + "\",\"src\":\"" + parts[6] + "\"}}"
                new_entries = new_entries + entry + "\n"
                logged = logged + 1
            }
        }
    }
    li = li + 1
}
if logged > 0 {
    write_file(log_path, existing_log + new_entries)
}

if logged > 0 {
    println("  discovery_log:", logged, "entries ->", log_path)
}
println("")
println("done.")
