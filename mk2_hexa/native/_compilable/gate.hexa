// gate.hexa — 12-gate 매트릭스 (Mk.I+ 호환)

let SIGMA_J2 = 288
let PHI_THRESHOLD = 0.1
let PERT_BASE = 999
let PERT_BREAKTHROUGH = 2401
let triple_n = 3

// Verdict: passed + confidence + gate_num
struct Verdict {
    passed: bool,
    confidence: f64,
    gate_num: i64
}

fn verdict_pass(conf: f64) -> Verdict {
    return Verdict { passed: true, confidence: conf, gate_num: 0 }
}

fn verdict_block(gate: i64) -> Verdict {
    return Verdict { passed: false, confidence: 0.0, gate_num: gate }
}

// === L-PIPELINE 4 gates ===

fn gate_source(in_whitelist: bool) -> Verdict {
    if in_whitelist { return verdict_pass(1.0) }
    return verdict_block(1)
}

fn gate_hash(hash_len: i64) -> Verdict {
    if hash_len >= 72 { return verdict_pass(1.0) }   // 288bit = 72 hex
    return verdict_block(2)
}

fn gate_phi(phi_delta: f64) -> Verdict {
    let mut ad = phi_delta
    if ad < 0.0 { ad = 0.0 - ad }
    if ad > 0.1 { return verdict_block(3) }
    return verdict_pass(1.0 - ad / 0.1)
}

fn gate_invariant(stable_runs: i64) -> Verdict {
    if stable_runs >= triple_n { return verdict_pass(0.85) }
    return verdict_block(4)
}

// === L-BREAKTHROUGH 4 gates ===

fn gate_paths(n: i64) -> bool { return n >= 3 }
fn gate_blowup(rediscovered: bool) -> bool { return rediscovered }
fn gate_mk2(conf: f64) -> bool { return conf >= 0.7 }
fn gate_pvalue(p: f64) -> bool { return p < 0.01 }

fn bt_count(paths: i64, blow: bool, mk2: f64, pval: f64) -> i64 {
    let mut c = 0
    if gate_paths(paths) { c = c + 1 }
    if gate_blowup(blow) { c = c + 1 }
    if gate_mk2(mk2) { c = c + 1 }
    if gate_pvalue(pval) { c = c + 1 }
    return c
}

// === L-MK2_HEXA 4 gates ===

fn mk_consensus(n: i64) -> bool { return n >= 12 }
fn mk_classify(conf: f64) -> bool { return conf >= 0.7 }

// === 12-gate unified evaluate ===

fn unified_total(pipe: i64, bt: i64, mk: i64) -> i64 {
    return pipe + bt + mk
}

// === 테스트 ===
println("=== 12-gate matrix test ===")

// Case 1: strong evidence
let v1 = gate_source(true)
let v2 = gate_hash(80)
let v3 = gate_phi(0.05)
let v4 = gate_invariant(3)
let mut pipe_count = 0
if v1.passed { pipe_count = pipe_count + 1 }
if v2.passed { pipe_count = pipe_count + 1 }
if v3.passed { pipe_count = pipe_count + 1 }
if v4.passed { pipe_count = pipe_count + 1 }
let bt = bt_count(5, true, 0.95, 0.001)
let mut mk = 0
if mk_consensus(12) { mk = mk + 1 }
if mk_classify(0.8) { mk = mk + 1 }

let total = unified_total(pipe_count, bt, mk + 2)  // fake 2 more mk gates
println("pipeline:", pipe_count, "/4")
println("breakthrough:", bt, "/4")
println("mk2_hexa:", mk + 2, "/4")
println("total:", total, "/12")

assert pipe_count == 4
assert bt == 4
assert total >= 10
println("✅ 12-gate test passed (strong case)")

// Case 2: weak evidence
let bt_weak = bt_count(1, false, 0.3, 0.5)
println("weak case bt:", bt_weak, "/4")
assert bt_weak == 0
println("✅ weak case correctly fails")
