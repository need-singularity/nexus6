// grading.hexa — r ∈ {0..10} 산출 (Mk.I+ 호환)

fn rank_from_n6_quality(q: f64) -> i64 {
    if q >= 1.0 { return 9 }
    if q >= 0.8 { return 7 }
    if q >= 0.5 { return 5 }
    return 0
}

fn rank_from_lens_consensus(count: i64) -> i64 {
    if count >= 12 { return 8 }
    if count >= 7  { return 7 }
    if count >= 3  { return 6 }
    if count >= 1  { return 3 }
    return 0
}

fn rank_from_mk2_confidence(conf: f64) -> i64 {
    if conf >= 0.9 { return 10 }
    if conf >= 0.7 { return 9 }
    if conf >= 0.5 { return 8 }
    if conf >= 0.3 { return 7 }
    return 0
}

fn imax(a: i64, b: i64) -> i64 {
    if a > b { return a }
    return b
}

fn combine_signals_v2(n6_q: f64, lens_c: i64, mk2_c: f64) -> i64 {
    let r_n6 = rank_from_n6_quality(n6_q)
    let r_lens = rank_from_lens_consensus(lens_c)
    let r_mk2 = rank_from_mk2_confidence(mk2_c)
    return imax(imax(r_n6, r_lens), r_mk2)
}

// === 검증 ===
println("=== grading self-test ===")
println("n6_q=1.0 →", rank_from_n6_quality(1.0), "(expect 9)")
println("n6_q=0.8 →", rank_from_n6_quality(0.8), "(expect 7)")
println("mk2_c=0.9 →", rank_from_mk2_confidence(0.9), "(expect 10)")
println("mk2_c=0.3 →", rank_from_mk2_confidence(0.3), "(expect 7)")
println("lens=12 →", rank_from_lens_consensus(12), "(expect 8)")
println("combined(1.0, 3, 0.9) =", combine_signals_v2(1.0, 3, 0.9), "(expect 10)")

assert rank_from_n6_quality(1.0) == 9
assert rank_from_n6_quality(0.8) == 7
assert rank_from_n6_quality(0.5) == 5
assert rank_from_n6_quality(0.0) == 0
assert rank_from_mk2_confidence(1.0) == 10
assert rank_from_mk2_confidence(0.29) == 0
assert rank_from_lens_consensus(0) == 0
assert rank_from_lens_consensus(99) == 8
assert combine_signals_v2(1.0, 3, 0.9) == 10
assert combine_signals_v2(0.0, 0, 0.0) == 0
println("✅ all grading tests passed")
