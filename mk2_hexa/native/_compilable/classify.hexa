// classify.hexa — 3-way 스코어링 (Mk.I+ 호환)

struct ClassifyResult {
    sector_id: i64,     // 0=cosmology 1=electroweak 2=math 3=unknown
    confidence: f64,
    kw_score: f64,
    val_score: f64,
    ps_score: f64
}

fn sector_name(id: i64) -> string {
    if id == 0 { return "cosmology" }
    if id == 1 { return "electroweak" }
    if id == 2 { return "mathematical" }
    return "unknown"
}

// 값 근접도 (hint 리스트 중 가장 가까운 것과 상대오차 → 0~1 점수)
fn value_closeness(value: f64, h1: f64, h2: f64, h3: f64) -> f64 {
    let mut best = 1.0
    let mut diff = value - h1
    if diff < 0.0 { diff = 0.0 - diff }
    let mut base = h1
    if base < 0.0 { base = 0.0 - base }
    if base < 0.0000001 { base = 1.0 }
    let rel1 = diff / base
    if rel1 < best { best = rel1 }

    diff = value - h2
    if diff < 0.0 { diff = 0.0 - diff }
    base = h2
    if base < 0.0 { base = 0.0 - base }
    if base < 0.0000001 { base = 1.0 }
    let rel2 = diff / base
    if rel2 < best { best = rel2 }

    diff = value - h3
    if diff < 0.0 { diff = 0.0 - diff }
    base = h3
    if base < 0.0 { base = 0.0 - base }
    if base < 0.0000001 { base = 1.0 }
    let rel3 = diff / base
    if rel3 < best { best = rel3 }

    let mut score = 1.0 - best * 10.0
    if score < 0.0 { score = 0.0 }
    if score > 1.0 { score = 1.0 }
    return score
}

// 단일 섹터 스코어 (0.5 kw + 0.3 val + 0.2 ps)
fn sector_score(kw_hits: i64, kw_total: i64, val: f64, ps_j: f64) -> f64 {
    let mut kw = 0.0
    if kw_total > 0 {
        kw = to_float(kw_hits) / to_float(kw_total)
        if kw > 1.0 { kw = 1.0 }
    }
    return 0.5 * kw + 0.3 * val + 0.2 * ps_j
}

// 3 섹터 비교 → 최고 점수 선택
fn classify_best(c_kw: i64, c_val: f64, c_ps: f64, e_kw: i64, e_val: f64, e_ps: f64, m_kw: i64, m_val: f64, m_ps: f64) -> ClassifyResult {
    let sc = sector_score(c_kw, 5, c_val, c_ps)
    let se = sector_score(e_kw, 3, e_val, e_ps)
    let sm = sector_score(m_kw, 4, m_val, m_ps)
    let mut best = sc
    let mut best_id: i64 = 0
    if se > best {
        best = se
        best_id = 1
    }
    if sm > best {
        best = sm
        best_id = 2
    }
    if best < 0.1 { best_id = 3 }
    return ClassifyResult { sector_id: best_id, confidence: best, kw_score: 0.0, val_score: 0.0, ps_score: 0.0 }
}

// === 테스트: 0.6666 = Omega_Lambda = cosmology (2/3 ratio) ===
println("=== classify self-test ===")
let val = 0.6666
let cs = value_closeness(val, 0.333, 0.667, 0.048)      // cosmology hints
let es = value_closeness(val, 0.2286, 0.23122, 0.0)     // electroweak hints
let ms = value_closeness(val, 0.333, 0.5, 0.25)         // math hints

println("cosmology closeness:", cs)
println("electroweak closeness:", es)
println("math closeness:", ms)

let r = classify_best(2, cs, 0.7, 0, es, 0.0, 1, ms, 0.1)
println("best sector:", sector_name(r.sector_id), " confidence:", r.confidence)

assert cs > 0.9   // 0.6666 ≈ 0.667
assert r.sector_id == 0   // cosmology wins
println("✅ classify: 0.6666 → cosmology (2/3)")

// === 테스트 2: 0.2286 = Weinberg = electroweak ===
let val2 = 0.2286
let cs2 = value_closeness(val2, 0.333, 0.667, 0.048)
let es2 = value_closeness(val2, 0.2286, 0.23122, 0.0)
let ms2 = value_closeness(val2, 0.333, 0.5, 0.25)
let r2 = classify_best(0, cs2, 0.1, 3, es2, 0.9, 0, ms2, 0.1)
println("0.2286 best:", sector_name(r2.sector_id), " conf:", r2.confidence)
assert r2.sector_id == 1    // electroweak wins
println("✅ classify: 0.2286 → electroweak (8/35)")
