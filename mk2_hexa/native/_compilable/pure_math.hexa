// pure_math.hexa — 수론 함수 (Mk.I+ 호환)

fn gcd_int(a: i64, b: i64) -> i64 {
    let mut x = a
    let mut y = b
    if x < 0 { x = -x }
    if y < 0 { y = -y }
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    return x
}

fn tau_fn(n: i64) -> i64 {
    if n <= 0 { return 0 }
    let mut count = 0
    let mut i = 1
    while i * i <= n {
        if n % i == 0 {
            count = count + 1
            if i != n / i { count = count + 1 }
        }
        i = i + 1
    }
    return count
}

fn sigma_fn(n: i64) -> i64 {
    if n <= 0 { return 0 }
    let mut s = 0
    let mut i = 1
    while i * i <= n {
        if n % i == 0 {
            s = s + i
            let j = n / i
            if i != j { s = s + j }
        }
        i = i + 1
    }
    return s
}

fn phi_fn(n: i64) -> i64 {
    if n <= 0 { return 0 }
    if n == 1 { return 1 }
    let mut result = n
    let mut x = n
    let mut p = 2
    while p * p <= x {
        if x % p == 0 {
            while x % p == 0 { x = x / p }
            result = result - result / p
        }
        p = p + 1
    }
    if x > 1 { result = result - result / x }
    return result
}

fn sopfr_fn(n: i64) -> i64 {
    if n <= 1 { return 0 }
    let mut s = 0
    let mut x = n
    let mut p = 2
    while p * p <= x {
        while x % p == 0 {
            s = s + p
            x = x / p
        }
        p = p + 1
    }
    if x > 1 { s = s + x }
    return s
}

fn is_perfect(n: i64) -> bool {
    return sigma_fn(n) == 2 * n
}

fn is_n6_exact(n: i64) -> bool {
    return sigma_fn(n) * phi_fn(n) == n * tau_fn(n)
}

// === 증명 (실행 시점 검증) ===
println("=== pure_math self-test ===")
println("tau(6)   =", tau_fn(6),   "(expect 4)")
println("sigma(6) =", sigma_fn(6), "(expect 12)")
println("phi(6)   =", phi_fn(6),   "(expect 2)")
println("sopfr(6) =", sopfr_fn(6), "(expect 5)")
println("gcd(12,18)=", gcd_int(12, 18), "(expect 6)")
println("sigma(105)=", sigma_fn(105), "(expect 192)")
println("phi(105) =", phi_fn(105),   "(expect 48)")

assert tau_fn(6) == 4
assert sigma_fn(6) == 12
assert phi_fn(6) == 2
assert sopfr_fn(6) == 5
assert sigma_fn(105) == 192
assert phi_fn(105) == 48
assert is_perfect(6)
assert is_perfect(28)
assert is_n6_exact(6)

println("perfect(6)=", is_perfect(6))
println("perfect(28)=", is_perfect(28))
println("n6_exact(6)=", is_n6_exact(6))
println("✅ all pure_math tests passed")
