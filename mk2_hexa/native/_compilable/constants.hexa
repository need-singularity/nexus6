// constants.hexa — n=6 테이블 (Mk.I+ 호환)
// hexa-lang 실제 컴파일 가능 버전

let N = 6
let SIGMA = 12          // σ(6)
let PHI = 2             // φ(6)
let TAU = 4             // τ(6)
let SOPFR = 5           // 2+3
let J2 = 24             // σ·(σ-τ)/(σ-φ)·τ
let MU = 1              // μ(6)

// 파생 상수
let SIGMA_J2 = SIGMA * J2            // 288 — BT-346
let SIGMA_SQ = SIGMA * SIGMA         // 144
let PHI_TAU = PHI * TAU              // 8
let SIGMA_MINUS_PHI = SIGMA - PHI    // 10
let SIGMA_MINUS_TAU = SIGMA - TAU    // 8
let SIGMA_MINUS_SOPFR = SIGMA - SOPFR // 7

let PERT_BASE = 999
let PERT_BREAKTHROUGH = 2401         // 7^4 — BT-345
let TRIPLE = 3                        // n/φ — BT-276

// 검증
println("=== n=6 constants ===")
println("N=", N, "SIGMA=", SIGMA, "PHI=", PHI, "TAU=", TAU)
println("σ·J₂=", SIGMA_J2)
println("(σ-sopfr)^τ=", 7*7*7*7)
assert SIGMA == 12
assert PHI == 2
assert TAU == 4
assert SIGMA_J2 == 288
assert PERT_BREAKTHROUGH == 2401
assert TAU + PHI == N
assert SIGMA * PHI == N * TAU

println("BT-344 (τ+φ=n):", TAU + PHI == N)
println("BT-345 (2401=7^4):", PERT_BREAKTHROUGH == 7*7*7*7)
println("BT-346 (σ·J₂=288):", SIGMA_J2 == 288)
println("완전수 유일성 (σ·φ=n·τ):", SIGMA * PHI == N * TAU)
