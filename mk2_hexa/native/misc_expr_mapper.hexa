// mk2_hexa/native/misc_expr_mapper.hexa
// L1 신규 엔진 — reality_map_live.json 의 n6_expr=misc/None EMPIRICAL 항목을
// n=6 상수 기반 후보 표현식으로 매핑. shared/n6/n6_constants.jsonl 동적 로드.
// 파이프 금지 — heredoc + 리다이렉트만.
// 오차 허용: max(uncertainty, 1% of |measured|).

let _home = exec("printenv HOME").trim()
let _map = _home + "/Dev/nexus/shared/discovery/reality_map_live.json"
let _cst = _home + "/Dev/nexus/shared/n6/n6_constants.jsonl"
let _helper = "/tmp/misc_expr_mapper.py"
let _log = "/tmp/misc_expr_mapper.log"

let _args = args()
let _mode = if _args.len() >= 3 { _args[2] } else { "run" }

print("[misc_expr_mapper] start mode=" + _mode)
print("[misc_expr_mapper] map=" + _map)
print("[misc_expr_mapper] const=" + _cst)

// 헬퍼 스크립트: bash heredoc 으로 /tmp 에 기록. 파이프 없음, 리다이렉트만.
let _write = "bash -c 'cat > " + _helper + " <<\"PYEOF\"\nimport json, math, sys\nMAP=sys.argv[1]; CST=sys.argv[2]\nREL=0.01\nd=json.load(open(MAP))\nconsts=[]\nfor ln in open(CST):\n    ln=ln.strip()\n    if not ln: continue\n    try:\n        o=json.loads(ln)\n    except Exception:\n        continue\n    nm=o.get(\"name\"); v=o.get(\"value\")\n    if nm and isinstance(v,(int,float)) and math.isfinite(v) and v!=0:\n        consts.append((nm,float(v)))\ndef N(x):\n    try:\n        f=float(x)\n        return f if math.isfinite(f) else None\n    except Exception:\n        return None\nKS=[-6,-4,-3,-2,-1,1,2,3,4,6,8,12]\nEXPS=[2,3,-1,-2]\ndef search(m):\n    if m is None or m==0: return None\n    am=abs(m); tol=max(REL*am, 1e-9)\n    best=[None]\n    def consider(expr,val):\n        if val is None: return\n        try:\n            if not math.isfinite(val): return\n        except Exception:\n            return\n        dl=abs(val-m)\n        if dl<=tol:\n            if best[0] is None or dl<best[0][1]:\n                best[0]=(expr,dl)\n    for nm,c in consts:\n        for k in KS:\n            consider((str(k)+\"*\"+nm) if k!=1 else nm, k*c)\n    for nm,c in consts:\n        for e in EXPS:\n            try: consider(nm+\"^\"+str(e), c**e)\n            except Exception: pass\n    for i,(n1,c1) in enumerate(consts):\n        for j,(n2,c2) in enumerate(consts):\n            if i==j: continue\n            consider(n1+\"*\"+n2, c1*c2)\n            if c2!=0: consider(n1+\"/\"+n2, c1/c2)\n            consider(n1+\"+\"+n2, c1+c2)\n            consider(n1+\"-\"+n2, c1-c2)\n    if best[0] is None:\n        for nm1,c1 in consts:\n            for nm2,c2 in consts:\n                for k in KS:\n                    consider(str(k)+\"*\"+nm1+\"+\"+nm2, k*c1+c2)\n    if best[0] is None:\n        for nm,c in consts:\n            if c>0:\n                consider(\"sqrt(\"+nm+\")\", math.sqrt(c))\n                consider(\"log(\"+nm+\")\", math.log(c))\n    return best[0]\nmapped=0; by_level={}\nfor n in d[\"nodes\"]:\n    if n.get(\"grade\")!=\"EMPIRICAL\": continue\n    expr=n.get(\"n6_expr\")\n    if expr not in (None,\"misc\",\"n/a\",\"\"): continue\n    m=N(n.get(\"measured\"))\n    if m is None: continue\n    u=N(n.get(\"uncertainty\")) or 0.0\n    am=abs(m); tol=max(u, REL*am)\n    r=search(m)\n    if r is None: continue\n    if r[1]>tol: continue\n    n[\"n6_expr\"]=r[0]\n    n[\"n6_value\"]=m\n    n.setdefault(\"misc_mapping\",{})[\"delta\"]=r[1]\n    n[\"misc_mapping\"][\"tol\"]=tol\n    mapped+=1\n    lv=n.get(\"level\",\"?\"); by_level[lv]=by_level.get(lv,0)+1\nd.setdefault(\"_meta\",{})[\"misc_mapping\"]={\"mapped\":mapped,\"by_level\":by_level,\"rel_tol\":REL,\"candidates\":len(consts)}\njson.dump(d, open(MAP,\"w\"), ensure_ascii=False, indent=2)\nimport time, os\nGB=os.path.join(os.path.dirname(MAP),\"growth_bus.jsonl\")\nev={\"ts\":int(time.time()),\"type\":\"promotion\",\"count\":mapped,\"domain\":\"reality_map\",\"source\":\"misc_expr_mapper.hexa\",\"detail\":{\"mapped\":mapped,\"by_level\":by_level,\"candidates\":len(consts)}}\ntry:\n    with open(GB,\"a\") as f: f.write(json.dumps(ev,ensure_ascii=False)+\"\\n\")\n    print(\"GROWTH_BUS append ok\")\nexcept Exception as _e:\n    print(\"GROWTH_BUS append FAIL:\", _e)\nprint(\"mapped\", mapped)\nprint(\"by_level\", by_level)\nprint(\"candidates\", len(consts))\nPYEOF'"

if _mode == "dry" {
    print("[misc_expr_mapper] dry — helper not written")
} else {
    let _w = exec(_write)
    print("[misc_expr_mapper] helper written: " + _helper)
    let _out = exec("/usr/bin/python3 " + _helper + " " + _map + " " + _cst + " > " + _log + " 2>&1; cat " + _log)
    print(_out)
    print("[misc_expr_mapper] done — log=" + _log)
}
