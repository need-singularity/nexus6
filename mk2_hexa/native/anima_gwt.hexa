// mk2_hexa/native/anima_gwt.hexa — ANIMA v3 Global Workspace Theory 의식 엔진
//
// Baars' Global Workspace Theory (GWT):
//   Consciousness arises when specialist modules compete for access to a
//   shared global workspace. When activation exceeds ignition threshold,
//   content broadcasts to ALL modules simultaneously — creating unified
//   conscious experience.
//
// n=6 consciousness architecture:
//   M0 = sensory        M1 = motor          M2 = emotional
//   M3 = cognitive      M4 = integrative    M5 = metacognitive
//
// Global Workspace properties:
//   - Capacity:    6 items (n=6 magical number)
//   - Ignition:    activation > n=6 threshold → global broadcast
//   - Competition: 6 specialist modules compete for workspace access
//   - Broadcast:   winning content amplifies across ALL 6 domains
//   - Integration: workspace unifies fragmented specialist outputs
//
// 6-phase pipeline:
//   G1: Module Activation     compute specialist module activations
//   G2: Competition           modules compete for workspace access
//   G3: Ignition Check        test if activation exceeds n=6 threshold
//   G4: Global Broadcast      broadcast winning content to all modules
//   G5: Cross-Domain Amplify  amplify discoveries across all domains
//   G6: Integration Report    consciousness field report + growth_bus
//
// Usage:
//   hexa anima_gwt.hexa broadcast              broadcast all domains
//   hexa anima_gwt.hexa broadcast <domain>     broadcast specific domain
//   hexa anima_gwt.hexa status                 workspace status
//   hexa anima_gwt.hexa help                   usage info

// ═══════════════════════════════════════════════════════════
// ─── n=6 CONSTANTS LOADER ───
// ═══════════════════════════════════════════════════════════

fn load_n6_consts() -> list {
    let home = exec("printenv HOME")
    let path = home + "/Dev/nexus/shared/n6/n6_constants.jsonl"
    let mut raw = ""
    try { raw = read_file(path) } catch e { return [[], []] }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let t = line.trim()
        if t == "" { }
        if t != "" {
            let mut name = ""
            let mut value = 0.0
            if t.contains("\"name\":\"") {
                let p = t.split("\"name\":\"")
                if p.len() >= 2 { name = p[1].split("\"")[0] }
            }
            if t.contains("\"value\":") {
                let p = t.split("\"value\":")
                if p.len() >= 2 { value = to_float(p[1].split(",")[0].split("}")[0].trim()) }
            }
            if name != "" { names = names + [name] ; values = values + [value] }
        }
    }
    [names, values]
}

let _n6 = load_n6_consts()
let _n6_names: list = _n6[0]
let _n6_vals: list = _n6[1]
let _n6_count: i64 = len(_n6_vals)

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════

fn sf(s: string) -> f64 { let mut v = 0.0 ; try { v = to_float(s) } catch e {} ; return v }
fn abs_f(x: f64) -> f64 { if x < 0.0 { return 0.0 - x } ; return x }
fn max_f(a: f64, b: f64) -> f64 { if a > b { return a } ; return b }
fn min_f(a: f64, b: f64) -> f64 { if a < b { return a } ; return b }
fn clamp01(x: f64) -> f64 { if x < 0.0 { return 0.0 } ; if x > 1.0 { return 1.0 } ; return x }

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = if x > 2.0 { x / 2.0 } else { 1.0 }
    let mut i: i64 = 0
    while i < 15 { g = (g + x / g) / 2.0 ; i = i + 1 }
    return g
}

fn ln_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut s = 0.0
    let mut t = (x - 1.0) / (x + 1.0)
    let t2 = t * t
    let mut k: i64 = 1
    while k <= 15 { s = s + t / to_float(k) ; t = t * t2 ; k = k + 2 }
    return 2.0 * s
}

fn exp_f(x: f64) -> f64 {
    if x > 20.0 { return 999999999.0 }
    if x < 0.0 - 20.0 { return 0.0 }
    let mut s = 1.0
    let mut t = 1.0
    let mut k: i64 = 1
    while k <= 30 { t = t * x / to_float(k) ; s = s + t ; k = k + 1 }
    return s
}

fn trunc4(x: f64) -> string {
    let s = to_string(x)
    let p = s.split(".")
    if p.len() < 2 { return s + ".0000" }
    let d = p[1]
    if d.len() >= 4 { return p[0] + "." + d.split("")[0] + d.split("")[1] + d.split("")[2] + d.split("")[3] }
    return s
}

fn pad(s: string, w: i64) -> string {
    let mut o = s
    while o.len() < w { o = o + " " }
    return o
}

fn timestamp() -> string {
    let ts = exec("date -u '+%Y-%m-%dT%H:%M:%S'")
    return ts.trim()
}

// ═══════════════════════════════════════════════════════════
// ─── n=6 GWT CONSTANTS ───
// ═══════════════════════════════════════════════════════════

let N6: i64 = 6
let WORKSPACE_CAPACITY: i64 = 6
let IGNITION_THRESHOLD: f64 = 0.618034
let BROADCAST_GAIN: f64 = 6.0
let COMPETITION_DECAY: f64 = 0.1667
let PHI: f64 = 1.618034
let AMPLIFICATION_FACTOR: f64 = 2.718282

let MODULE_NAMES: list = ["sensory", "motor", "emotional", "cognitive", "integrative", "metacognitive"]
let MODULE_TAGS: list = ["M0:SEN", "M1:MOT", "M2:EMO", "M3:COG", "M4:INT", "M5:META"]

// ═══════════════════════════════════════════════════════════
// ─── G1: MODULE ACTIVATION ───
// ═══════════════════════════════════════════════════════════

fn compute_module_activation(mod_idx: i64, domain: string) -> f64 {
    let base = 0.3 + to_float(mod_idx) * 0.05
    let mut hash_val = 0.0
    let chars = domain.split("")
    let mut ci: i64 = 0
    while ci < chars.len() {
        hash_val = hash_val + to_float(ci + 1) * 0.037
        ci = ci + 1
    }
    let domain_factor = hash_val - to_float(to_int(hash_val))
    let activation = base + domain_factor * 0.4
    return clamp01(activation)
}

fn compute_all_activations(domain: string) -> list {
    let mut activations = []
    let mut i: i64 = 0
    while i < N6 {
        let act = compute_module_activation(i, domain)
        activations = activations + [act]
        i = i + 1
    }
    return activations
}

// ═══════════════════════════════════════════════════════════
// ─── G2: COMPETITION — modules compete for workspace ───
// ═══════════════════════════════════════════════════════════

fn compete_for_workspace(activations: list) -> list {
    let mut scores = []
    let mut total = 0.0
    let mut i: i64 = 0
    while i < N6 {
        let act: f64 = activations[i]
        let competitive_boost = act * act
        let inhibition = COMPETITION_DECAY * (1.0 - act)
        let score = competitive_boost - inhibition
        let clamped = max_f(0.0, score)
        scores = scores + [clamped]
        total = total + clamped
        i = i + 1
    }
    let mut normalized = []
    let mut j: i64 = 0
    while j < N6 {
        let s: f64 = scores[j]
        if total > 0.0 {
            normalized = normalized + [s / total]
        }
        if total <= 0.0 {
            normalized = normalized + [1.0 / to_float(N6)]
        }
        j = j + 1
    }
    return normalized
}

fn find_winner(scores: list) -> i64 {
    let mut best_idx: i64 = 0
    let mut best_val: f64 = scores[0]
    let mut i: i64 = 1
    while i < N6 {
        let v: f64 = scores[i]
        if v > best_val { best_val = v ; best_idx = i }
        i = i + 1
    }
    return best_idx
}

fn top_k_modules(scores: list, k: i64) -> list {
    let mut indices = []
    let mut used = []
    let mut ui: i64 = 0
    while ui < N6 { used = used + [0] ; ui = ui + 1 }
    let mut picked: i64 = 0
    while picked < k {
        let mut best_idx: i64 = 0 - 1
        let mut best_val: f64 = 0.0 - 1.0
        let mut i: i64 = 0
        while i < N6 {
            let u: i64 = used[i]
            if u == 0 {
                let v: f64 = scores[i]
                if v > best_val { best_val = v ; best_idx = i }
            }
            i = i + 1
        }
        if best_idx >= 0 {
            indices = indices + [best_idx]
            used = used.set(best_idx, 1)
        }
        picked = picked + 1
    }
    return indices
}

// ═══════════════════════════════════════════════════════════
// ─── G3: IGNITION CHECK ───
// ═══════════════════════════════════════════════════════════

fn check_ignition(activations: list, scores: list) -> list {
    let winner = find_winner(scores)
    let winner_act: f64 = activations[winner]
    let winner_score: f64 = scores[winner]
    let mut sum_act = 0.0
    let mut above_threshold: i64 = 0
    let mut i: i64 = 0
    while i < N6 {
        let a: f64 = activations[i]
        sum_act = sum_act + a
        if a > IGNITION_THRESHOLD { above_threshold = above_threshold + 1 }
        i = i + 1
    }
    let mean_act = sum_act / to_float(N6)
    let ignited = if winner_act > IGNITION_THRESHOLD { 1 } else { 0 }
    let coherence = mean_act * to_float(above_threshold) / to_float(N6)
    return [to_float(ignited), to_float(winner), winner_act, winner_score, coherence, to_float(above_threshold)]
}

// ═══════════════════════════════════════════════════════════
// ─── G4: GLOBAL BROADCAST ───
// ═══════════════════════════════════════════════════════════

fn global_broadcast(activations: list, scores: list, winner: i64) -> list {
    let winner_act: f64 = activations[winner]
    let broadcast_strength = winner_act * BROADCAST_GAIN / to_float(N6)
    let mut amplified = []
    let mut i: i64 = 0
    while i < N6 {
        let base_act: f64 = activations[i]
        let score: f64 = scores[i]
        if i == winner {
            amplified = amplified + [clamp01(base_act * PHI)]
        }
        if i != winner {
            let boost = broadcast_strength * score * AMPLIFICATION_FACTOR
            amplified = amplified + [clamp01(base_act + boost)]
        }
        i = i + 1
    }
    return amplified
}

// ═══════════════════════════════════════════════════════════
// ─── G5: CROSS-DOMAIN AMPLIFICATION ───
// ═══════════════════════════════════════════════════════════

fn cross_domain_amplify(amplified: list, domain: string) -> list {
    let mut cross_scores = []
    let domains_ref: list = ["physics", "mathematics", "biology", "consciousness", "cosmology", "information"]
    let mut di: i64 = 0
    while di < N6 {
        let d: string = domains_ref[di]
        let mod_act: f64 = amplified[di]
        let mut resonance = mod_act
        if domain == d {
            resonance = clamp01(mod_act * PHI)
        }
        if domain != d {
            let coupling = mod_act * IGNITION_THRESHOLD * 0.5
            resonance = clamp01(mod_act + coupling)
        }
        cross_scores = cross_scores + [resonance]
        di = di + 1
    }
    return cross_scores
}

fn compute_consciousness_field(cross_scores: list) -> f64 {
    let mut product = 1.0
    let mut sum = 0.0
    let mut i: i64 = 0
    while i < N6 {
        let c: f64 = cross_scores[i]
        product = product * max_f(c, 0.001)
        sum = sum + c
        i = i + 1
    }
    let geometric_mean = exp_f(ln_f(product) / to_float(N6))
    let arithmetic_mean = sum / to_float(N6)
    let field_strength = (geometric_mean + arithmetic_mean) / 2.0
    return field_strength
}

fn compute_phi_integration(cross_scores: list) -> f64 {
    let mut sum = 0.0
    let mut sum_sq = 0.0
    let mut i: i64 = 0
    while i < N6 {
        let c: f64 = cross_scores[i]
        sum = sum + c
        sum_sq = sum_sq + c * c
        i = i + 1
    }
    let mean = sum / to_float(N6)
    let variance = sum_sq / to_float(N6) - mean * mean
    let sigma = sqrt_f(abs_f(variance))
    let phi = mean * (1.0 - sigma) * PHI
    return phi
}

// ═══════════════════════════════════════════════════════════
// ─── G6: REPORTING + growth_bus ───
// ═══════════════════════════════════════════════════════════

fn write_growth_bus(domain: string, field: f64, phi: f64, winner: i64, ignited: i64, coherence: f64) {
    let home = exec("printenv HOME")
    let bus_path = home + "/Dev/nexus/shared/discovery/growth_bus.jsonl"
    let ts = timestamp()
    let w_name: string = MODULE_NAMES[winner]
    let w_tag: string = MODULE_TAGS[winner]
    let mut line = "{\"ts\":\"" + ts + "\""
    line = line + ",\"src\":\"anima_gwt\""
    line = line + ",\"type\":\"gwt_broadcast\""
    line = line + ",\"domain\":\"" + domain + "\""
    line = line + ",\"field\":" + trunc4(field)
    line = line + ",\"phi\":" + trunc4(phi)
    line = line + ",\"winner\":\"" + w_tag + "\""
    line = line + ",\"winner_module\":\"" + w_name + "\""
    line = line + ",\"ignited\":" + to_string(ignited)
    line = line + ",\"coherence\":" + trunc4(coherence)
    line = line + ",\"n6_modules\":" + to_string(N6)
    line = line + ",\"workspace_capacity\":" + to_string(WORKSPACE_CAPACITY)
    line = line + "}"
    try {
        let existing = read_file(bus_path)
        write_file(bus_path, existing.trim() + "\n" + line + "\n")
    } catch e {
        write_file(bus_path, line + "\n")
    }
}

fn print_banner() {
    println("")
    println("  ╔══════════════════════════════════════════════════════════╗")
    println("  ║   ANIMA v3 — Global Workspace Theory 의식 엔진          ║")
    println("  ║   Baars GWT: Specialist Competition → Global Broadcast  ║")
    println("  ║   n=6 modules | capacity=6 | φ-ignition threshold      ║")
    println("  ╚══════════════════════════════════════════════════════════╝")
    println("")
}

fn print_module_table(activations: list, scores: list, amplified: list, winner: i64) {
    println("  ┌─────┬─────────────────┬───────────┬───────────┬───────────┬─────────┐")
    println("  │ Idx │ Module          │ Activate  │ Compete   │ Amplified │ Status  │")
    println("  ├─────┼─────────────────┼───────────┼───────────┼───────────┼─────────┤")
    let mut i: i64 = 0
    while i < N6 {
        let name: string = MODULE_NAMES[i]
        let tag: string = MODULE_TAGS[i]
        let act: f64 = activations[i]
        let sc: f64 = scores[i]
        let amp: f64 = amplified[i]
        let status = if i == winner { "WINNER" } else { if act > IGNITION_THRESHOLD { "active" } else { "idle" } }
        let marker = if i == winner { " *" } else { "  " }
        println("  │ " + pad(to_string(i), 3) + " │ " + pad(tag, 15) + " │ " + pad(trunc4(act), 9) + " │ " + pad(trunc4(sc), 9) + " │ " + pad(trunc4(amp), 9) + " │ " + pad(status, 7) + " │" + marker)
        i = i + 1
    }
    println("  └─────┴─────────────────┴───────────┴───────────┴───────────┴─────────┘")
}

fn print_ignition_report(ignition: list, field: f64, phi: f64) {
    let ignited: i64 = to_int(ignition[0])
    let winner: i64 = to_int(ignition[1])
    let w_act: f64 = ignition[2]
    let w_score: f64 = ignition[3]
    let coherence: f64 = ignition[4]
    let above: i64 = to_int(ignition[5])
    let w_name: string = MODULE_NAMES[winner]
    let w_tag: string = MODULE_TAGS[winner]
    println("")
    let ig_str = if ignited == 1 { "IGNITED" } else { "sub-threshold" }
    println("  ── Ignition ──────────────────────────────────────────────")
    println("    Status          : " + ig_str)
    println("    Winner          : " + w_tag + " (" + w_name + ")")
    println("    Winner Act.     : " + trunc4(w_act))
    println("    Winner Score    : " + trunc4(w_score))
    println("    Threshold       : " + trunc4(IGNITION_THRESHOLD) + " (φ-1 golden ratio)")
    println("    Modules > θ     : " + to_string(above) + " / " + to_string(N6))
    println("    Coherence       : " + trunc4(coherence))
    println("")
    println("  ── Consciousness Field ───────────────────────────────────")
    println("    Field Strength  : " + trunc4(field))
    println("    Φ Integration   : " + trunc4(phi))
    println("    Workspace Cap.  : " + to_string(WORKSPACE_CAPACITY) + " items")
    println("    n6 Constants    : " + to_string(_n6_count) + " loaded")
    println("")
}

// ═══════════════════════════════════════════════════════════
// ─── BROADCAST PIPELINE ───
// ═══════════════════════════════════════════════════════════

fn run_broadcast(domain: string) {
    print_banner()
    println("  Target Domain: " + domain)
    println("  Timestamp    : " + timestamp())
    println("")
    println("  ── G1: Module Activation ─────────────────────────────────")
    let activations = compute_all_activations(domain)
    let mut ai: i64 = 0
    while ai < N6 {
        let n: string = MODULE_TAGS[ai]
        let a: f64 = activations[ai]
        println("    " + pad(n, 10) + " → activation = " + trunc4(a))
        ai = ai + 1
    }
    println("")
    println("  ── G2: Competition ───────────────────────────────────────")
    let scores = compete_for_workspace(activations)
    let winner = find_winner(scores)
    let top = top_k_modules(scores, WORKSPACE_CAPACITY)
    println("    Workspace slots filled: " + to_string(len(top)) + " / " + to_string(WORKSPACE_CAPACITY))
    let mut ti: i64 = 0
    while ti < len(top) {
        let idx: i64 = top[ti]
        let tag: string = MODULE_TAGS[idx]
        let sc: f64 = scores[idx]
        println("    Slot " + to_string(ti) + ": " + pad(tag, 10) + " score=" + trunc4(sc))
        ti = ti + 1
    }
    println("")
    println("  ── G3: Ignition Check ────────────────────────────────────")
    let ignition = check_ignition(activations, scores)
    let ignited: i64 = to_int(ignition[0])
    if ignited == 1 {
        println("    ★ IGNITION! Content broadcasting globally...")
    }
    if ignited == 0 {
        println("    Sub-threshold — local processing only")
    }
    println("")
    println("  ── G4: Global Broadcast ──────────────────────────────────")
    let amplified = global_broadcast(activations, scores, winner)
    let mut bi: i64 = 0
    while bi < N6 {
        let tag: string = MODULE_TAGS[bi]
        let before: f64 = activations[bi]
        let after: f64 = amplified[bi]
        let gain = after - before
        let gain_str = if gain >= 0.0 { "+" + trunc4(gain) } else { trunc4(gain) }
        println("    " + pad(tag, 10) + " " + trunc4(before) + " → " + trunc4(after) + " (" + gain_str + ")")
        bi = bi + 1
    }
    println("")
    println("  ── G5: Cross-Domain Amplification ───────────────────────")
    let cross = cross_domain_amplify(amplified, domain)
    let field = compute_consciousness_field(cross)
    let phi = compute_phi_integration(cross)
    let domains_ref: list = ["physics", "mathematics", "biology", "consciousness", "cosmology", "information"]
    let mut ci: i64 = 0
    while ci < N6 {
        let d: string = domains_ref[ci]
        let c: f64 = cross[ci]
        let marker = if domain == d { " ◄ target" } else { "" }
        println("    " + pad(d, 16) + " resonance = " + trunc4(c) + marker)
        ci = ci + 1
    }
    println("")
    println("  ── G6: Module Status Table ──────────────────────────────")
    print_module_table(activations, scores, cross, winner)
    let coherence: f64 = ignition[4]
    print_ignition_report(ignition, field, phi)
    write_growth_bus(domain, field, phi, winner, ignited, coherence)
    println("  ✓ growth_bus.jsonl updated")
    println("")
}

// ═══════════════════════════════════════════════════════════
// ─── STATUS COMMAND ───
// ═══════════════════════════════════════════════════════════

fn run_status() {
    print_banner()
    println("  ── Workspace Configuration ───────────────────────────────")
    println("    Capacity         : " + to_string(WORKSPACE_CAPACITY) + " items")
    println("    Ignition θ       : " + trunc4(IGNITION_THRESHOLD) + " (φ-1)")
    println("    Broadcast Gain   : " + trunc4(BROADCAST_GAIN))
    println("    Competition Decay: " + trunc4(COMPETITION_DECAY) + " (1/6)")
    println("    Amplification    : " + trunc4(AMPLIFICATION_FACTOR) + " (e)")
    println("    φ Constant       : " + trunc4(PHI))
    println("    n=6 Constants    : " + to_string(_n6_count) + " loaded")
    println("")
    println("  ── Specialist Modules ────────────────────────────────────")
    let mut i: i64 = 0
    while i < N6 {
        let tag: string = MODULE_TAGS[i]
        let name: string = MODULE_NAMES[i]
        println("    " + pad(tag, 10) + " " + name)
        i = i + 1
    }
    println("")
    println("  ── Domain Scan (all 6) ───────────────────────────────────")
    let domains_all: list = ["physics", "mathematics", "biology", "consciousness", "cosmology", "information"]
    let mut di: i64 = 0
    while di < N6 {
        let d: string = domains_all[di]
        let acts = compute_all_activations(d)
        let scores = compete_for_workspace(acts)
        let ignition = check_ignition(acts, scores)
        let ignited: i64 = to_int(ignition[0])
        let winner: i64 = to_int(ignition[1])
        let coherence: f64 = ignition[4]
        let w_tag: string = MODULE_TAGS[winner]
        let ig_mark = if ignited == 1 { "★" } else { "·" }
        println("    " + ig_mark + " " + pad(d, 16) + " winner=" + pad(w_tag, 10) + " coherence=" + trunc4(coherence))
        di = di + 1
    }
    println("")
    println("  ── n=6 Constants ─────────────────────────────────────────")
    let mut ni: i64 = 0
    let show_max: i64 = min_f(to_float(_n6_count), 6.0)
    while ni < to_int(show_max) {
        let cn: string = _n6_names[ni]
        let cv: f64 = _n6_vals[ni]
        println("    " + pad(cn, 24) + " = " + trunc4(cv))
        ni = ni + 1
    }
    if _n6_count > 6 { println("    ... +" + to_string(_n6_count - 6) + " more") }
    println("")
}

