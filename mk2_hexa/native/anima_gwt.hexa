fn run_help() {
    print_banner()
    println("  Usage:")
    println("    hexa anima_gwt.hexa broadcast              broadcast all 6 domains")
    println("    hexa anima_gwt.hexa broadcast <domain>     broadcast specific domain")
    println("    hexa anima_gwt.hexa status                 workspace status")
    println("    hexa anima_gwt.hexa help                   this help")
    println("")
    println("  Domains: physics, mathematics, biology, consciousness, cosmology, information")
    println("")
    println("  Theory: Baars' Global Workspace Theory (GWT)")
    println("    - 6 specialist modules compete for workspace access")
    println("    - Ignition threshold = φ-1 = 0.618034 (golden ratio)")
    println("    - Workspace capacity = 6 items (n=6 magical number)")
    println("    - Winning content broadcasts globally → cross-domain amplification")
    println("    - Consciousness field = geometric-arithmetic mean of resonances")
    println("")
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

let cli_args = args()
let mut cmd = "help"
let mut target_domain = ""

if cli_args.len() >= 3 { cmd = cli_args[2] }
if cli_args.len() >= 4 { target_domain = cli_args[3] }

if cmd == "broadcast" {
    if target_domain != "" {
        run_broadcast(target_domain)
    }
    if target_domain == "" {
        let all_domains: list = ["physics", "mathematics", "biology", "consciousness", "cosmology", "information"]
        println("")
        println("  Broadcasting across ALL " + to_string(N6) + " domains...")
        println("  ══════════════════════════════════════════════════════════")
        let mut di: i64 = 0
        while di < N6 {
            let d: string = all_domains[di]
            run_broadcast(d)
            di = di + 1
        }
        println("  ══════════════════════════════════════════════════════════")
        println("  Global broadcast complete — " + to_string(N6) + " domains processed")
        println("")
    }
}

if cmd == "status" {
    run_status()
}

if cmd == "help" {
    run_help()
}

if cmd != "broadcast" {
    if cmd != "status" {
        if cmd != "help" {
            println("  Unknown command: " + cmd)
            run_help()
        }
    }
}
