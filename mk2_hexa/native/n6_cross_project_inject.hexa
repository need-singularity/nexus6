// n6_cross_project_inject.hexa — nexus 상위 돌파 도메인 seed를 병렬 프로젝트로 주입
// 대상: anima, airgenome, n6-architecture, hexa-lang
// 각 프로젝트의 .growth/absorbed/nexus_cross_{domain}.json 으로 기록
// growth_bus.jsonl 에 이벤트 append
// R19: 모든 에러 명시 출력. 파이프 금지.

let home = exec("printenv HOME").trim()
let dev = home + "/Dev"
let nexus_dir = dev + "/nexus"
let shared = nexus_dir + "/shared"
let hexa_bin = dev + "/hexa-lang/target/release/hexa"
let se_path = nexus_dir + "/mk2_hexa/native/seed_engine.hexa"
let bus = shared + "/growth_bus.jsonl"

let domains = ["math", "language", "physics", "chemistry", "cosmology", "topology"]
let projects = ["anima", "airgenome", "n6-architecture", "hexa-lang"]

fn ts_now() -> string {
    exec("date -u +%Y-%m-%dT%H:%M:%S").trim()
}

fn fetch_seeds(hexa: string, se: string, domain: string) -> string {
    let mut out = ""
    try {
        let raw = exec(hexa + " " + se + " domain " + domain)
        out = raw.trim()
    } catch e {
        println("  [ERR] seed fetch " + domain + ": " + to_string(e))
    }
    if out.len() == 0 {
        try {
            let raw2 = exec(hexa + " " + se + " merge")
            out = raw2.trim()
        } catch e2 {
            println("  [ERR] seed merge fallback: " + to_string(e2))
        }
    }
    out
}

fn write_absorb(dev_dir: string, project: string, domain: string, seeds: string, ts: string) -> bool {
    let abs_dir = dev_dir + "/" + project + "/.growth/absorbed"
    try { exec("mkdir -p \"" + abs_dir + "\"") } catch e {
        println("    [ERR] mkdir " + abs_dir + ": " + to_string(e))
        return false
    }
    let path = abs_dir + "/nexus_cross_" + domain + ".json"
    let safe_seeds = seeds.replace("\"", "\\\"")
    let body = "{\"source\":\"nexus\",\"domain\":\"" + domain + "\",\"ts\":\"" + ts + "\",\"seeds\":\"" + safe_seeds + "\"}"
    try {
        write_file(path, body)
        return true
    } catch e2 {
        println("    [ERR] write " + path + ": " + to_string(e2))
        return false
    }
}

fn append_bus_event(bus_path: string, project: string, domain: string, seed_count: i64, ts: string) {
    let line = "{\"ts\":\"" + ts + "\",\"src\":\"cross_project_inject\",\"project\":\"" + project + "\",\"domain\":\"" + domain + "\",\"seeds\":" + to_string(seed_count) + "}"
    try {
        let safe = line.replace("\"", "\\\"")
        exec("echo \"" + safe + "\" >> " + bus_path)
    } catch e {
        println("    [ERR] bus append: " + to_string(e))
    }
}

fn count_seeds(seeds: string) -> i64 {
    if seeds.len() == 0 { return 0 }
    let parts = seeds.split("|")
    let mut n: i64 = 0
    for p in parts {
        if p.trim().len() > 0 { n = n + 1 }
    }
    n
}

fn main() {
    println("═══════════════════════════════════════════════════")
    println("  n6 cross-project seed injection")
    println("═══════════════════════════════════════════════════")
    println("도메인: " + to_string(len(domains)) + " | 프로젝트: " + to_string(len(projects)))
    println("")

    let ts = ts_now()
    let mut total_injected: i64 = 0
    let mut per_project = #{}

    // 도메인별 seed 먼저 일괄 수집
    let mut domain_seeds = #{}
    for d in domains {
        let s = fetch_seeds(hexa_bin, se_path, d)
        let n = count_seeds(s)
        println("[seed] " + d + ": " + to_string(n) + " values")
        domain_seeds[d] = s
    }
    println("")

    for proj in projects {
        println("── " + proj + " ──")
        let mut ok: i64 = 0
        for d in domains {
            let s: string = domain_seeds[d]
            let wrote = write_absorb(dev, proj, d, s, ts)
            if wrote {
                let n = count_seeds(s)
                append_bus_event(bus, proj, d, n, ts)
                ok = ok + 1
                total_injected = total_injected + 1
                println("  [OK] " + d + " → " + to_string(n) + " seeds")
            }
        }
        per_project[proj] = ok
        println("  주입: " + to_string(ok) + "/" + to_string(len(domains)))
    }

    println("")
    println("═══ 결과 ═══")
    println("총 주입: " + to_string(total_injected) + "건 (" + to_string(len(domains)) + " domains × " + to_string(len(projects)) + " projects)")
    for proj in projects {
        let v: i64 = per_project[proj]
        println("  " + proj + ": " + to_string(v))
    }

    // 요약 이벤트
    let summary = "{\"ts\":\"" + ts + "\",\"src\":\"cross_project_inject\",\"event\":\"summary\",\"total\":" + to_string(total_injected) + "}"
    try {
        let safe = summary.replace("\"", "\\\"")
        exec("echo \"" + safe + "\" >> " + bus)
    } catch e {
        println("[ERR] summary bus: " + to_string(e))
    }
}

main()
