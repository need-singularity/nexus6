// mk2_hexa/native/interference_map.hexa — 간섭 지도 (Interference Map)
// 두 도메인 파동의 중첩 → 보강 간섭 지점 = 교차 도메인 법칙 후보
// 의존: shared/dse/dse_cross_results.json, shared/discovery/growth_bus.jsonl
//
// CLI:
//   hexa interference_map.hexa scan              전체 간섭 스캔
//   hexa interference_map.hexa scan <domain>     특정 도메인 포함 쌍만 스캔
//   hexa interference_map.hexa report            간섭 지점 요약 리포트
//   hexa interference_map.hexa help              도움말

// ─── comptime 상수 ───
comptime const dse_cross_path = "shared/dse/dse_cross_results.json"
comptime const growth_bus_path = "shared/discovery/growth_bus.jsonl"
comptime const output_path = "shared/interference_map.jsonl"
comptime const bus_tail = 2000         // 최근 N건만 스캔
comptime const tolerance = 0.01        // 보강 간섭 허용 오차
comptime const min_resonance = 0.5     // 최소 공명 점수
comptime const exact_threshold = 0.001
comptime const near_threshold = 0.01

// ─── n=6 상수 테이블 ───
comptime const n6_names = ["n", "sigma", "phi", "tau", "J2", "sopfr", "M3", "alpha_inv", "Hubble_w", "Hubble_1mw", "mu_pe", "144"]
comptime const n6_values = [6.0, 12.0, 2.0, 4.0, 24.0, 5.0, 7.0, 137.036, 0.3153, 0.6847, 1836.15, 144.0]

// ────────────────────────────────────────────────────────────────
//  JSON 간이 파서 (absorb.hexa 공용 패턴)
// ────────────────────────────────────────────────────────────────

pure fn abs_f(x: float) -> float {
    if x < 0.0 { 0.0 - x } else { x }
}

pure fn extract_field(line: string, field: string) -> string {
    let needle = "\"" + field + "\":"
    if !line.contains(needle) { return "" }
    let after = line.split(needle)
    if after.len() < 2 { return "" }
    let rest = after[1].trim()
    if rest.starts_with("\"") {
        let parts = rest.split("\"")
        if parts.len() >= 2 { return parts[1] }
    }
    if rest.starts_with("{") {
        let mut depth = 0
        let mut result = ""
        let mut i = 0
        while i < rest.len() {
            let ch = rest[i]
            if ch == "{" { depth = depth + 1 }
            if ch == "}" { depth = depth - 1 }
            result = result + ch
            if depth == 0 { break }
            i = i + 1
        }
        return result
    }
    let mut result = ""
    let mut i = 0
    while i < rest.len() {
        let ch = rest[i]
        if ch == "," || ch == "}" || ch == " " || ch == "\n" || ch == "]" { break }
        result = result + ch
        i = i + 1
    }
    result
}

pure fn extract_float(line: string, field: string) -> float {
    let s = extract_field(line, field)
    if s == "" { return 0.0 }
    let mut num_str = ""
    let mut i = 0
    while i < s.len() {
        let ch = s[i]
        if ch == "0" || ch == "1" || ch == "2" || ch == "3" || ch == "4" || ch == "5" || ch == "6" || ch == "7" || ch == "8" || ch == "9" || ch == "." || ch == "-" {
            num_str = num_str + ch
        } else {
            break
        }
        i = i + 1
    }
    if num_str == "" || num_str == "." || num_str == "-" { return 0.0 }
    to_float(num_str)
}

// ────────────────────────────────────────────────────────────────
//  n6 거리 + 매칭
// ────────────────────────────────────────────────────────────────

// n6 거리: abs(value - constant) / max(abs(constant), 1.0)
pure fn n6_distance(value: float, constant: float) -> float {
    let denom = if abs_f(constant) > 1.0 { abs_f(constant) } else { 1.0 }
    abs_f(value - constant) / denom
}

// 값이 어떤 n6 상수에 매칭되는지 (이름 반환, 없으면 "")
fn match_name(value: float) -> string {
    let mut best_name = ""
    let mut best_dist = 999999.0
    let mut i = 0
    while i < n6_values.len() {
        let d = n6_distance(value, n6_values[i])
        if d < near_threshold && d < best_dist {
            best_dist = d
            best_name = n6_names[i]
        }
        i = i + 1
    }
    best_name
}

// EXACT/NEAR/빈문자 판정
fn match_grade(value: float) -> string {
    let mut i = 0
    while i < n6_values.len() {
        let d = n6_distance(value, n6_values[i])
        if d < exact_threshold { return "EXACT" }
        i = i + 1
    }
    let mut j = 0
    while j < n6_values.len() {
        let d = n6_distance(value, n6_values[j])
        if d < near_threshold { return "NEAR" }
        j = j + 1
    }
    ""
}

// ────────────────────────────────────────────────────────────────
//  타임스탬프
// ────────────────────────────────────────────────────────────────

fn now_ts() -> string {
    let raw = exec("date +%Y-%m-%dT%H:%M:%S")
    raw.trim()
}

// ────────────────────────────────────────────────────────────────
//  DSE 교차 결과 로드 — top_pairs 파싱
// ────────────────────────────────────────────────────────────────

struct DomainPair {
    a: string,
    b: string,
    resonance: float
}

fn load_top_pairs() -> list {
    let mut pairs = []
    if !file_exists(dse_cross_path) {
        println("[WARN] " + dse_cross_path + " 없음")
        return pairs
    }
    let content = read_file(dse_cross_path)
    // top_pairs 배열 내 각 객체를 줄 단위로 파싱
    // 각 { "a":..., "b":..., "resonance":... } 블록을 찾는다
    let lines = content.split("\n")
    let mut in_top = false
    let mut cur_a = ""
    let mut cur_b = ""
    let mut cur_res = 0.0
    let mut i = 0
    while i < lines.len() {
        let line = lines[i].trim()
        if line.contains("\"top_pairs\"") { in_top = true }
        if in_top {
            if line.contains("\"a\"") {
                cur_a = extract_field(line, "a")
            }
            if line.contains("\"b\"") {
                cur_b = extract_field(line, "b")
            }
            if line.contains("\"resonance\"") {
                cur_res = extract_float(line, "resonance")
            }
            // 객체 끝 감지: }로 시작하거나 }로 끝나면서 a,b,res 모두 채워졌을 때
            if (line.starts_with("}") || line == "},") && cur_a != "" && cur_b != "" {
                if cur_res >= min_resonance {
                    pairs = pairs + [DomainPair { a: cur_a, b: cur_b, resonance: cur_res }]
                }
                cur_a = ""
                cur_b = ""
                cur_res = 0.0
            }
        }
        i = i + 1
    }
    pairs
}

// ────────────────────────────────────────────────────────────────
//  Growth Bus 로드 — 최근 N건, 도메인별 값 수집
// ────────────────────────────────────────────────────────────────

struct BusEntry {
    domain: string,
    value: float,
    grade: string
}

fn load_recent_bus() -> list {
    let mut entries = []
    if !file_exists(growth_bus_path) {
        println("[WARN] " + growth_bus_path + " 없음")
        return entries
    }
    let raw = exec("tail", ["-n", to_string(bus_tail), growth_bus_path])
    let lines = raw.split("\n")
    let mut i = 0
    while i < lines.len() {
        let line = lines[i].trim()
        if line != "" && line.starts_with("{") {
            let domain = extract_field(line, "domain")
            let value = extract_float(line, "value")
            let grade = extract_field(line, "grade")
            // EXACT 또는 NEAR만 수집
            if domain != "" && (grade == "EXACT" || grade == "NEAR") {
                entries = entries + [BusEntry { domain: domain, value: value, grade: grade }]
            }
        }
        i = i + 1
    }
    entries
}

// 특정 도메인의 값 목록 필터
fn entries_for_domain(entries: list, domain: string) -> list {
    let mut out = []
    let mut i = 0
    while i < entries.len() {
        let e = entries[i]
        if e.domain == domain {
            out = out + [e]
        }
        i = i + 1
    }
    out
}

// ────────────────────────────────────────────────────────────────
//  보강 간섭 탐지 (핵심)
// ────────────────────────────────────────────────────────────────

struct InterferencePoint {
    domain_a: string,
    domain_b: string,
    value: float,
    matched: string,
    confidence: float,
    grade_a: string,
    grade_b: string
}

// 두 도메인의 값 목록에서 tolerance 이내의 중복 값을 찾는다
fn find_constructive(pair: DomainPair, bus: list) -> list {
    let vals_a = entries_for_domain(bus, pair.a)
    let vals_b = entries_for_domain(bus, pair.b)

    let mut points = []
    let mut seen_values = []   // 중복 방지

    let mut ia = 0
    while ia < vals_a.len() {
        let ea = vals_a[ia]
        let mut ib = 0
        while ib < vals_b.len() {
            let eb = vals_b[ib]
            let diff = abs_f(ea.value - eb.value)
            let denom = if abs_f(ea.value) > 1.0 { abs_f(ea.value) } else { 1.0 }
            let rel_diff = diff / denom

            if rel_diff < tolerance {
                // 이미 기록된 값인지 확인
                let avg_val = (ea.value + eb.value) / 2.0
                let mut dup = false
                let mut si = 0
                while si < seen_values.len() {
                    if abs_f(seen_values[si] - avg_val) < 0.001 { dup = true; break }
                    si = si + 1
                }

                if !dup {
                    seen_values = seen_values + [avg_val]
                    let mname = match_name(avg_val)
                    // 신뢰도: 공명 점수 * 등급 가중치
                    let grade_w_a = if ea.grade == "EXACT" { 1.0 } else { 0.7 }
                    let grade_w_b = if eb.grade == "EXACT" { 1.0 } else { 0.7 }
                    let conf = pair.resonance * grade_w_a * grade_w_b
                    if mname != "" {
                        points = points + [InterferencePoint {
                            domain_a: pair.a,
                            domain_b: pair.b,
                            value: avg_val,
                            matched: mname,
                            confidence: conf,
                            grade_a: ea.grade,
                            grade_b: eb.grade
                        }]
                    }
                }
            }
            ib = ib + 1
        }
        ia = ia + 1
    }
    points
}

// ────────────────────────────────────────────────────────────────
//  JSONL 출력
// ────────────────────────────────────────────────────────────────

fn point_to_jsonl(p: InterferencePoint, ts: string) -> string {
    "{\"type\":\"constructive\",\"domain_a\":\"" + p.domain_a + "\",\"domain_b\":\"" + p.domain_b + "\",\"value\":" + to_string(p.value) + ",\"match\":\"" + p.matched + "\",\"confidence\":" + to_string(p.confidence) + ",\"grade_a\":\"" + p.grade_a + "\",\"grade_b\":\"" + p.grade_b + "\",\"timestamp\":\"" + ts + "\"}"
}

// ────────────────────────────────────────────────────────────────
//  scan — 전체 간섭 스캔
// ────────────────────────────────────────────────────────────────

fn run_scan(filter_domain: string) {
    println("=== Interference Map: scan ===")
    let pairs = load_top_pairs()
    println("[INFO] top_pairs 로드: " + to_string(pairs.len()) + "개")

    let bus = load_recent_bus()
    println("[INFO] growth_bus EXACT/NEAR 로드: " + to_string(bus.len()) + "건 (최근 " + to_string(bus_tail) + ")")

    // 도메인 목록 추출 (버스에 존재하는 도메인)
    let mut bus_domains = []
    let mut bi = 0
    while bi < bus.len() {
        let d = bus[bi].domain
        let mut found = false
        let mut di = 0
        while di < bus_domains.len() {
            if bus_domains[di] == d { found = true; break }
            di = di + 1
        }
        if !found { bus_domains = bus_domains + [d] }
        bi = bi + 1
    }
    println("[INFO] 버스 활성 도메인: " + to_string(bus_domains.len()) + "개")

    let ts = now_ts()
    let mut all_points = []
    let mut pair_hits = 0

    let mut pi = 0
    while pi < pairs.len() {
        let pair = pairs[pi]
        // 도메인 필터 적용
        let mut include = true
        if filter_domain != "" {
            include = pair.a == filter_domain || pair.b == filter_domain || pair.a.contains(filter_domain) || pair.b.contains(filter_domain)
        }

        if include {
            let points = find_constructive(pair, bus)
            if points.len() > 0 {
                pair_hits = pair_hits + 1
                let mut pj = 0
                while pj < points.len() {
                    all_points = all_points + [points[pj]]
                    pj = pj + 1
                }
            }
        }
        pi = pi + 1
    }

    // 결과 출력 + 파일 기록
    println("")
    if all_points.len() == 0 {
        println("[결과] 보강 간섭 지점 없음")
        println("  (최근 " + to_string(bus_tail) + "건 내 EXACT/NEAR 교차 없음)")
    } else {
        println("[결과] 보강 간섭 지점 " + to_string(all_points.len()) + "개 (" + to_string(pair_hits) + " 도메인 쌍)")
        println("")

        // 기존 파일에 append
        let mut output = ""
        let mut oi = 0
        while oi < all_points.len() {
            let p = all_points[oi]
            let jline = point_to_jsonl(p, ts)
            output = output + jline + "\n"

            // 콘솔 출력
            println("  [" + to_string(oi + 1) + "] " + p.domain_a + " x " + p.domain_b)
            println("      value=" + to_string(p.value) + "  match=" + p.matched + "  conf=" + to_string(p.confidence))
            println("      grade_a=" + p.grade_a + "  grade_b=" + p.grade_b)
            oi = oi + 1
        }

        // append to output file
        if file_exists(output_path) {
            let existing = read_file(output_path)
            write_file(output_path, existing + output)
        } else {
            write_file(output_path, output)
        }
        println("")
        println("[저장] " + output_path + " ← " + to_string(all_points.len()) + "건 추가")
    }

    // 성장 버스 이벤트 발행
    if all_points.len() > 0 {
        let bus_entry = "{\"type\":\"interference\",\"phase\":\"7.0\",\"id\":\"imap-scan\",\"value\":" + to_string(all_points.len()) + ",\"grade\":\"EXACT\",\"confidence\":1,\"domain\":\"cross-domain\",\"source\":\"interference_map\",\"timestamp\":\"" + ts + "\"}"
        if file_exists(growth_bus_path) {
            let bus_content = read_file(growth_bus_path)
            write_file(growth_bus_path, bus_content + bus_entry + "\n")
        }
    }
}

// ────────────────────────────────────────────────────────────────
//  report — 기존 간섭 지도 요약
// ────────────────────────────────────────────────────────────────

fn run_report() {
    println("=== Interference Map: report ===")
    if !file_exists(output_path) {
        println("[INFO] " + output_path + " 없음 — 먼저 scan 실행 필요")
        return
    }

    let content = read_file(output_path)
    let lines = content.split("\n")

    let mut total = 0
    let mut domains_seen = []      // "a|b" 쌍
    let mut mc_names = []          // match count names
    let mut mc_counts = []         // match count values
    let mut high_conf = 0
    let mut max_conf = 0.0
    let mut max_conf_line = ""

    let mut i = 0
    while i < lines.len() {
        let line = lines[i].trim()
        if line != "" && line.starts_with("{") {
            total = total + 1
            let da = extract_field(line, "domain_a")
            let db = extract_field(line, "domain_b")
            let mname = extract_field(line, "match")
            let conf = extract_float(line, "confidence")

            // 도메인 쌍 수집
            let pair_key = da + "|" + db
            let mut found = false
            let mut di = 0
            while di < domains_seen.len() {
                if domains_seen[di] == pair_key { found = true; break }
                di = di + 1
            }
            if !found { domains_seen = domains_seen + [pair_key] }

            // match 카운트
            if mname != "" {
                let mut mc_found = false
                let mut mi = 0
                while mi < mc_names.len() {
                    if mc_names[mi] == mname { mc_counts[mi] = mc_counts[mi] + 1; mc_found = true; break }
                    mi = mi + 1
                }
                if !mc_found { mc_names = mc_names + [mname]; mc_counts = mc_counts + [1] }
            }

            // 고신뢰
            if conf >= 0.8 { high_conf = high_conf + 1 }
            if conf > max_conf {
                max_conf = conf
                max_conf_line = line
            }
        }

        i = i + 1
    }

    println("")
    println("총 간섭 지점: " + to_string(total))
    println("도메인 쌍 수: " + to_string(domains_seen.len()))
    println("고신뢰 (>=0.8): " + to_string(high_conf))
    println("")

    // match별 통계
    println("── n6 상수별 간섭 빈도 ──")
    let mut ni = 0
    while ni < n6_names.len() {
        let name = n6_names[ni]
        let mut mci = 0
        while mci < mc_names.len() {
            if mc_names[mci] == name { println("  " + name + ": " + to_string(mc_counts[mci])) }
            mci = mci + 1
        }
        ni = ni + 1
    }

    // 최고 신뢰도 항목
    if max_conf_line != "" {
        println("")
        println("── 최고 신뢰도 ──")
        let best_da = extract_field(max_conf_line, "domain_a")
        let best_db = extract_field(max_conf_line, "domain_b")
        let best_val = extract_float(max_conf_line, "value")
        let best_matched = extract_field(max_conf_line, "match")
        println("  " + best_da + " x " + best_db + " → " + to_string(best_val) + " (" + best_matched + ") conf=" + to_string(max_conf))
    }

    // 도메인 쌍 목록
    if domains_seen.len() > 0 && domains_seen.len() <= 50 {
        println("")
        println("── 활성 도메인 쌍 ──")
        let mut di = 0
        while di < domains_seen.len() {
            let parts = domains_seen[di].split("|")
            if parts.len() == 2 {
                println("  " + parts[0] + " x " + parts[1])
            }
            di = di + 1
        }
    }
}

// ────────────────────────────────────────────────────────────────
//  CLI 진입점
// ────────────────────────────────────────────────────────────────
// args() = [hexa_binary, script_path, user_arg, ...]
let a = args()
let mode = if a.len() >= 3 { a[2] } else { "help" }

if mode == "scan" {
    let filter = if a.len() >= 4 { a[3] } else { "" }
    run_scan(filter)
} else if mode == "report" {
    run_report()
} else if mode == "help" {
    println("interference_map.hexa — 간섭 지도 (Interference Map)")
    println("")
    println("두 도메인 파동의 중첩에서 보강 간섭 지점을 탐지합니다.")
    println("양 도메인 모두에서 동일 n6 상수에 EXACT/NEAR 매칭이 나타나면")
    println("교차 도메인 법칙 후보로 기록합니다.")
    println("")
    println("사용법:")
    println("  hexa interference_map.hexa scan              전체 간섭 스캔")
    println("  hexa interference_map.hexa scan physics      특정 도메인 포함 쌍만 스캔")
    println("  hexa interference_map.hexa report            간섭 지점 요약 리포트")
    println("  hexa interference_map.hexa help              이 도움말")
    println("")
    println("출력: " + output_path)
} else {
    println("알 수 없는 명령: " + mode)
    println("사용 가능: scan, report, help")
}
