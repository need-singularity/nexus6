// wave_papers.hexa — 논문간 교차 공명 (39편+ 논문 융합 후보 추출)
// 실행: hexa wave_papers.hexa
//
// 원리:
//   1. products.json에서 논문 목록 로드 (sections → domains/title)
//   2. 논문 제목/도메인에서 키워드 추출
//   3. 논문 쌍별 키워드 교차 → 공명 점수 (공유 키워드 수 × 6)
//   4. 공명 점수 상위 12쌍에서 "융합 논문" 후보 제목 자동 생성
//   5. growth_bus.jsonl 기록

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _bus_path = _shared + "/growth_bus.jsonl"
let _n6_repo = _dev + "/n6-architecture"
let _products_path = _n6_repo + "/config/products.json"
let _papers_dir = _n6_repo + "/docs/paper"

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

// ═══════════════════════════════════════════════════════════
// 논문 목록 추출 (docs/paper/*.md 파일명에서)
// ═══════════════════════════════════════════════════════════

fn extract_paper_list() -> string {
    let mut result = ""
    try {
        // n6-*-paper.md 파일명에서 도메인 추출
        result = exec("ls " + _papers_dir + "/n6-*-paper.md 2>/dev/null | sed 's|.*/n6-||;s|-paper\\.md||' | sort")
    } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// products.json에서 섹션 제목/도메인 추출
// ═══════════════════════════════════════════════════════════

fn extract_section_info() -> string {
    let mut result = ""
    try {
        // id와 title, domains 추출
        result = exec("/usr/bin/python3 -c \"import json; f=open('" + _products_path + "'); d=json.load(f); [print(s['id']+'\\t'+s.get('title','')+'\\t'+' '.join(s.get('domains',[]))) for s in d.get('sections',[])]\" 2>/dev/null")
    } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// 논문 제목 행 추출 (각 파일 첫 줄 #)
// ═══════════════════════════════════════════════════════════

fn extract_paper_title(domain: string) -> string {
    let mut result = ""
    try {
        result = exec("head -1 " + _papers_dir + "/n6-" + domain + "-paper.md 2>/dev/null | sed 's/^# //'").trim()
    } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// 키워드 추출: 도메인명을 '-'로 분리 + 제목 단어
// ═══════════════════════════════════════════════════════════

fn domain_to_keywords(domain: string) -> string {
    // '-' 분리 → 공백 구분 키워드 문자열
    let mut result = ""
    let parts = domain.split("-")
    for p in parts {
        let pt = p.trim()
        if pt != "" && len(pt) > 1 {
            if result != "" { result = result + " " }
            result = result + pt
        }
    }
    return result
}

// ═══════════════════════════════════════════════════════════
// MAIN
// ═══════════════════════════════════════════════════════════

println("")
println("===========================================================")
println("  논문간 교차 공명 (Wave Papers)")
println("  논문 키워드 교차로 융합 논문 후보 자동 추출")
println("===========================================================")
println("")

// 1. 논문 목록 수집
let paper_domains_raw = extract_paper_list()
let paper_domains_lines = paper_domains_raw.split("\n")

let mut paper_domains = []
let mut paper_keywords = []

for line in paper_domains_lines {
    let domain = line.trim()
    if domain == "" { continue }
    paper_domains = paper_domains + [domain]
    let kw = domain_to_keywords(domain)
    paper_keywords = paper_keywords + [kw]
}

let total_papers: i64 = len(paper_domains)
println("  논문 수: " + to_string(total_papers) + "편")
println("")

// 섹션 정보도 키워드에 추가
let section_raw = extract_section_info()
let section_lines = section_raw.split("\n")
let mut section_domains = []
let mut section_kw_map = []

for sl in section_lines {
    let st = sl.trim()
    if st == "" { continue }
    let parts = st.split("\t")
    if len(parts) >= 3 {
        section_domains = section_domains + [parts[0]]
        section_kw_map = section_kw_map + [parts[2]]
    }
}

// 2. 논문 쌍별 키워드 교차 → 공명 점수
println("  --- 교차 공명 계산 중... ---")
println("")

let mut pair_names = []
let mut pair_scores = []
let mut pair_shared = []
let mut total_checked: i64 = 0

let mut i: i64 = 0
while i < total_papers {
    let mut j: i64 = i + 1
    while j < total_papers {
        let dom_i: string = paper_domains[i]
        let dom_j: string = paper_domains[j]
        let kw_i: string = paper_keywords[i]
        let kw_j: string = paper_keywords[j]

        let words_i = kw_i.split(" ")
        let words_j = kw_j.split(" ")

        // 공유 키워드 카운트
        let mut shared_count: i64 = 0
        let mut shared_words = ""

        for wi in words_i {
            let wit = wi.trim()
            if wit == "" || len(wit) <= 1 { continue }
            for wj in words_j {
                let wjt = wj.trim()
                if wit == wjt {
                    shared_count = shared_count + 1
                    if shared_words != "" { shared_words = shared_words + "," }
                    shared_words = shared_words + wit
                }
            }
        }

        if shared_count > 0 {
            let score: i64 = shared_count * 6
            pair_names = pair_names + [dom_i + " + " + dom_j]
            pair_scores = pair_scores + [score]
            pair_shared = pair_shared + [shared_words]
        }

        total_checked = total_checked + 1
        j = j + 1
    }
    i = i + 1
}

println("  검사한 쌍: " + to_string(total_checked) + " | 공명 쌍: " + to_string(len(pair_scores)))
println("")

// 3. 상위 12쌍 추출 (간이 정렬)
println("  --- 공명 상위 12쌍 ---")
println("")
println("| 순위 | 논문 쌍 | 공명 점수 | 공유 키워드 | 융합 후보 |")
println("|------|---------|----------|------------|----------|")

let mut used = []
let mut ui: i64 = 0
while ui < len(pair_scores) {
    used = used + [false]
    ui = ui + 1
}

let mut fusion_candidates = []
let mut rank: i64 = 1
let max_rank: i64 = if len(pair_scores) < 12 { len(pair_scores) } else { 12 }

while rank <= max_rank {
    // 최대 점수 탐색
    let mut max_score: i64 = -1
    let mut max_idx: i64 = -1

    let mut mi: i64 = 0
    while mi < len(pair_scores) {
        let is_used: bool = used[mi]
        if !is_used {
            let sc: i64 = pair_scores[mi]
            if sc > max_score {
                max_score = sc
                max_idx = mi
            }
        }
        mi = mi + 1
    }

    if max_idx < 0 { rank = max_rank + 1 } else {
        used[max_idx] = true
        let pname: string = pair_names[max_idx]
        let pshared: string = pair_shared[max_idx]

        // 융합 논문 후보 제목 생성: 두 도메인 결합
        let pair_parts = pname.split(" + ")
        let fusion_title = if len(pair_parts) >= 2 {
            "n=6 " + pair_parts[0] + "-" + pair_parts[1] + " 통합 이론"
        } else {
            "n=6 " + pname + " 융합"
        }

        fusion_candidates = fusion_candidates + [fusion_title]

        println("| " + to_string(rank) + " | " + pname + " | " + to_string(max_score) + " | " + pshared + " | " + fusion_title + " |")
    }
    rank = rank + 1
}

println("")

// 4. 융합 논문 후보 요약
println("  --- 융합 논문 후보 ---")
println("")

let mut ci: i64 = 0
while ci < len(fusion_candidates) {
    let candidate: string = fusion_candidates[ci]
    println("  " + to_string(ci + 1) + ". " + candidate)
    ci = ci + 1
}

println("")

// 5. 공명 밀도 통계
let resonance_density = if total_checked > 0 { (len(pair_scores) * 100) / total_checked } else { 0 }
let avg_score = if len(pair_scores) > 0 {
    let mut sum: i64 = 0
    let mut si2: i64 = 0
    while si2 < len(pair_scores) {
        let ps: i64 = pair_scores[si2]
        sum = sum + ps
        si2 = si2 + 1
    }
    sum / len(pair_scores)
} else { 0 }

println("  --- 공명 통계 ---")
println("")
println("  총 논문: " + to_string(total_papers) + "편")
println("  검사 쌍: " + to_string(total_checked))
println("  공명 쌍: " + to_string(len(pair_scores)) + " (" + to_string(resonance_density) + "%)")
println("  평균 공명 점수: " + to_string(avg_score))
println("  융합 후보: " + to_string(len(fusion_candidates)) + "편")
println("")

// 6. growth_bus 기록
try {
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
    let entry = "{\"type\":\"wave_papers\",\"total_papers\":" + to_string(total_papers) + ",\"pairs_checked\":" + to_string(total_checked) + ",\"resonance_pairs\":" + to_string(len(pair_scores)) + ",\"fusion_candidates\":" + to_string(len(fusion_candidates)) + ",\"avg_score\":" + to_string(avg_score) + ",\"ts\":\"" + ts + "\"}"
    exec("echo '" + entry + "' >> " + _bus_path)
} catch e {}

println("  growth_bus 기록 완료")
println("")
println("[verified] wave_papers.hexa 실행 완료")
println("")
