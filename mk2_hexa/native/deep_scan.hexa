fn main() {
    let cli = args()
    let argc = to_int(cli.len())
    let mut cmd = "help"
    if argc >= 3 { cmd = cli[2] }

    if cmd == "help" {
        println("deep_scan.hexa -- Consolidated Deep Scan Engine (Waves 2-15)")
        println("")
        println("Usage: hexa deep_scan.hexa <command>")
        println("")
        println("Commands:")
        println("  help       Show this help")
        println("  wave2      Run Wave 2 (Sporadic, String, Elliptic, ...)")
        println("  wave3      Run Wave 3 (S6, ADE, SLE6, Ramsey, ...)")
        println("  wave4      Run Wave 4 (Nuclear, Music, Biology, ...)")
        println("  wave5      Run Wave 5 (Coloring, Chemistry, ...)")
        println("  wave6      Run Wave 6 (GF64, Dessins, Spectral, ...)")
        println("  wave7      Run Wave 7 (Galois, Painleve, Graphene, ...)")
        println("  wave8      Run Wave 8 (Chess, Polytope, Kepler, ...)")
        println("  wave9      Run Wave 9 (QFT, Yang-Mills, 6-vertex, ...)")
        println("  wave10     Run Wave 10 (Holonomy, Lorentz, ...)")
        println("  wave11     Run Wave 11 (Theorem of 6, Rubik, ...)")
        println("  wave12_15  Run Waves 12-15 batch")
        println("  all        Run all waves + summary")
        println("  summary    Summary only (loads all data)")
        println("  stats      Star distribution by wave")
        println("  explore    6-area gap scan (atlas,calc,readme,lenses,BT,scripts)")
        println("")
        println("n=6: sigma=" + to_string(sigma(6)) + " phi=" + to_string(phi_euler(6)) + " tau=" + to_string(tau_div(6)) + " sopfr=" + to_string(sopfr(6)))
        return
    }

    if cmd == "explore" { run_explore() }

    if cmd == "wave2" { run_wave2() }
    if cmd == "wave3" { run_wave3() }
    if cmd == "wave4" { run_wave4() }
    if cmd == "wave5" { run_wave5() }
    if cmd == "wave6" { run_wave6() }
    if cmd == "wave7" { run_wave7() }
    if cmd == "wave8" { run_wave8() }
    if cmd == "wave9" { run_wave9() }
    if cmd == "wave10" { run_wave10() }
    if cmd == "wave11" { run_wave11() }
    if cmd == "wave12_15" { run_wave12_15() }

    if cmd == "all" {
        run_wave2()
        run_wave3()
        run_wave4()
        run_wave5()
        run_wave6()
        run_wave7()
        run_wave8()
        run_wave9()
        run_wave10()
        run_wave11()
        run_wave12_15()
        print_summary()
        print_stats()
    }

    if cmd == "summary" {
        run_wave2()
        run_wave3()
        run_wave4()
        run_wave5()
        run_wave6()
        run_wave7()
        run_wave8()
        run_wave9()
        run_wave10()
        run_wave11()
        run_wave12_15()
        print_summary()
    }

    if cmd == "stats" {
        run_wave2()
        run_wave3()
        run_wave4()
        run_wave5()
        run_wave6()
        run_wave7()
        run_wave8()
        run_wave9()
        run_wave10()
        run_wave11()
        run_wave12_15()
        print_stats()
    }

    if cmd.starts_with("wave") {
        let total = to_int(d_dom.len())
        if total > 0 {
            let mut ts: i64 = 0
            let mut i: i64 = 0
            while i < total {
                ts = ts + to_int(d_star[i])
                i = i + 1
            }
            println("")
            println("  Discoveries: " + to_string(total) + ", Stars: " + to_string(ts))
        }
    }
}

main()
