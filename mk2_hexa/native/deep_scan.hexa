fn print_summary() {
    println("")
    bar()
    println("  GRAND SUMMARY -- Deep Scan Waves 2-15")
    bar()

    let total = to_int(d_dom.len())
    let mut star5: i64 = 0
    let mut star4: i64 = 0
    let mut star3: i64 = 0
    let mut total_stars: i64 = 0
    let mut i: i64 = 0
    while i < total {
        let s = to_int(d_star[i])
        total_stars = total_stars + s
        if s >= 5 { star5 = star5 + 1 }
        if s == 4 { star4 = star4 + 1 }
        if s == 3 { star3 = star3 + 1 }
        i = i + 1
    }

    println("")
    println("  Domains scanned: " + to_string(total))
    println("  Five-star:       " + to_string(star5))
    println("  Four-star:       " + to_string(star4))
    println("  Three-star:      " + to_string(star3))
    println("  Total stars:     " + to_string(total_stars))
    println("")
    println("  PROVEN UNIQUENESS THEOREMS:")
    println("   #1  Out(S_n)!=1 iff n=6 (Holder)")
    println("   #2  SLE_6 = percolation (Smirnov)")
    println("   #3  S^6 almost complex besides S^2 (Borel-Serre)")
    println("   #4  R(3,3)=6 (diagonal Ramsey)")
    println("   #5  Exotic S^7: 28=P2 types (Milnor)")
    println("   #6  Grothendieck's 6 operations")
    println("   #7  6 Painleve equations")
    println("   #8  CY3 dim=6 for strings")
    println("   #9  Max superconformal dim=6")
    println("  #10  Exotic R^n iff n=4=tau(6)")
    println("  #11  6-vertex ice rule C(4,2)=6")
    println("  #12  P1=6 regular polytopes in dim 4")
    println("  #13  Four Color: chi<=4=tau(6)")
    println("  #14  Abel-Ruffini: solvable iff n<=4")
    println("  #15  N(6)=1 MOLS (Euler fails)")
    println("  #16  Carbon Z=6 enables biology")
    println("  #17  6 = unique perfect+factorial+primorial+triangular")
    println("  #18  Berger: 7=n+1 holonomy types")
    println("")
    println("  n=6 constants: P1=6, sigma=12, phi=2, tau=4, sopfr=5")
    println("  Universals: C(6,2)=15, T(6)=21, 6!=720, 2sigma=24, 240(E8)")
}

fn print_stats() {
    println("")
    bar()
    println("  STAR DISTRIBUTION BY WAVE")
    bar()

    let total = to_int(d_dom.len())
    let mut wn: i64 = 2
    while wn <= 15 {
        let mut count: i64 = 0
        let mut ss: i64 = 0
        let mut s5: i64 = 0
        let mut s4: i64 = 0
        let mut s3: i64 = 0
        let mut i: i64 = 0
        while i < total {
            if to_int(d_wave[i]) == wn {
                count = count + 1
                let sv = to_int(d_star[i])
                ss = ss + sv
                if sv >= 5 { s5 = s5 + 1 }
                if sv == 4 { s4 = s4 + 1 }
                if sv == 3 { s3 = s3 + 1 }
            }
            i = i + 1
        }
        if count > 0 {
            println("  Wave " + to_string(wn) + ": " + to_string(count) + " disc, " + to_string(s5) + " five, " + to_string(s4) + " four, " + to_string(s3) + " three = " + to_string(ss) + " stars")
        }
        wn = wn + 1
    }
}

// ═══════════════════════════════════════════════════════════════
// ─── 6중 탐색 루프 (explore) ────────────────────────────────
// ═══════════════════════════════════════════════════════════════

fn explore_home() -> string {
    let r = exec("printenv HOME")
    r.trim()
}

fn explore_bus_append(area: string, kind: string, count: i64, detail: string) {
    let ehome = explore_home()
    let bus_path = ehome + "/Dev/nexus6/shared/growth_bus.jsonl"
    let mut ts = "?"
    try { ts = exec("date +%Y-%m-%dT%H:%M:%S") } catch e {}
    let line = "{\"source\":\"deep_scan_explore\",\"area\":\"" + area + "\",\"kind\":\"" + kind + "\",\"count\":" + to_string(count) + ",\"detail\":\"" + detail + "\",\"timestamp\":\"" + ts.trim() + "\"}"
    try { append_file(bus_path, line + "\n") } catch e {}
}

fn file_exists_explore(path: string) -> bool {
    let mut r = ""
    try { r = exec("test", ["-f", path, "&&", "echo", "1"]) } catch e {}
    r.trim() == "1"
}

// Area 1: atlas (shared/math_atlas/) -- 수학 아틀라스 갭
fn explore_atlas() -> i64 {
    println("  [1/6] Atlas scan...")
    let ehome = explore_home()
    let atlas_dir = ehome + "/Dev/nexus6/shared/math_atlas"
    let mut ls_result = ""
    try { ls_result = exec("ls", [atlas_dir]) } catch e { ls_result = "" }

    if ls_result.trim().len() == 0 {
        println("    atlas directory missing or empty -- GAP")
        explore_bus_append("atlas", "gap", 1, "atlas directory missing or empty")
        return 1
    }

    let files = ls_result.split("\n")
    let mut md_count: i64 = 0
    let mut fi: i64 = 0
    while fi < to_int(files.len()) {
        if files[fi].trim().ends_with(".md") || files[fi].trim().ends_with(".json") {
            md_count = md_count + 1
        }
        fi = fi + 1
    }

    let gaps = if md_count < 6 { 6 - md_count } else { 0 }
    println("    atlas files: " + to_string(md_count) + ", gaps: " + to_string(gaps))
    if gaps > 0 { explore_bus_append("atlas", "gap", gaps, "atlas files=" + to_string(md_count) + " target=6") }
    return gaps
}

// Area 2: calc (shared/calc/) -- 계산 스크립트 누락
fn explore_calc() -> i64 {
    println("  [2/6] Calc scan...")
    let ehome = explore_home()
    let calc_dir = ehome + "/Dev/nexus6/shared/calc"
    let mut ls_result = ""
    try { ls_result = exec("ls", [calc_dir]) } catch e { ls_result = "" }

    if ls_result.trim().len() == 0 {
        println("    calc directory missing -- GAP")
        explore_bus_append("calc", "gap", 1, "calc directory missing")
        return 1
    }

    let files = ls_result.split("\n")
    let mut script_count: i64 = 0
    let mut empty_count: i64 = 0
    let mut fi: i64 = 0
    while fi < to_int(files.len()) {
        let f = files[fi].trim()
        if f.ends_with(".py") || f.ends_with(".hexa") || f.ends_with(".sh") {
            script_count = script_count + 1
        }
        if f.len() > 0 {
            let fpath = calc_dir + "/" + f
            let mut sz = ""
            try { sz = exec("wc", ["-c", "<", fpath]) } catch e { sz = "0" }
            let mut size: i64 = 0
            try { size = to_int(to_float(sz.trim().split(" ")[0])) } catch e {}
            if size == 0 { empty_count = empty_count + 1 }
        }
        fi = fi + 1
    }

    println("    calc scripts: " + to_string(script_count) + ", empty: " + to_string(empty_count))
    if empty_count > 0 { explore_bus_append("calc", "incomplete", empty_count, "empty scripts in calc/") }
    return empty_count
}

// Area 3: readme (README.md, GROWTH.md) -- 문서 누락
fn explore_readme() -> i64 {
    println("  [3/6] README/GROWTH scan...")
    let ehome = explore_home()
    let nexus_dir = ehome + "/Dev/nexus6"
    let mut gaps: i64 = 0

    if !file_exists_explore(nexus_dir + "/README.md") {
        println("    README.md missing -- GAP")
        gaps = gaps + 1
    } else {
        println("    README.md exists")
    }

    if !file_exists_explore(nexus_dir + "/GROWTH.md") {
        println("    GROWTH.md missing -- GAP")
        gaps = gaps + 1
    } else {
        println("    GROWTH.md exists")
    }

    if gaps > 0 { explore_bus_append("readme", "missing", gaps, "documentation gap") }
    return gaps
}

// Area 4: lenses (custom_lenses.jsonl) -- 렌즈 커버리지
fn explore_lenses() -> i64 {
    println("  [4/6] Lenses scan...")
    let ehome = explore_home()
    let lenses_path = ehome + "/Dev/nexus6/shared/custom_lenses.jsonl"

    if !file_exists_explore(lenses_path) {
        println("    custom_lenses.jsonl missing -- GAP")
        explore_bus_append("lenses", "missing", 1, "custom_lenses.jsonl not found")
        return 1
    }

    let mut content = ""
    try { content = read_file(lenses_path) } catch e {}
    let lines = content.split("\n")
    let mut lens_count: i64 = 0
    let mut li: i64 = 0
    while li < to_int(lines.len()) {
        if lines[li].trim().len() > 2 { lens_count = lens_count + 1 }
        li = li + 1
    }

    // target: sigma*tau=48 lenses
    let target: i64 = 48
    let gaps = if lens_count < target { target - lens_count } else { 0 }
    println("    lenses: " + to_string(lens_count) + "/" + to_string(target) + ", gap: " + to_string(gaps))
    if gaps > 0 { explore_bus_append("lenses", "gap", gaps, "lens_count=" + to_string(lens_count) + " target=" + to_string(target)) }
    return gaps
}

// Area 5: BT-gap (domain coverage)
fn explore_bt_gaps() -> i64 {
    println("  [5/6] BT-gap scan...")
    let all_doms = ["ai-efficiency", "chip-architecture", "quantum-computing", "compiler-os", "programming-language", "software-design", "energy-architecture", "power-grid", "battery-architecture", "thermal-management", "robotics", "learning-algorithm", "blockchain", "network-protocol", "cryptography", "superconductor", "fusion", "plasma-physics", "biology", "cosmology-particle", "display-audio", "pure-mathematics", "solar-architecture", "material-synthesis", "environmental-protection", "paper", "dse-map", "chip-topology", "photonic-energy", "ccus", "civil-transport", "space-defense"]
    let covered = ["ai-efficiency", "chip-architecture", "energy-architecture", "power-grid", "battery-architecture", "fusion", "biology", "cosmology-particle", "display-audio", "pure-mathematics", "software-design", "cryptography", "blockchain", "network-protocol", "robotics", "environmental-protection", "solar-architecture", "material-synthesis", "superconductor", "photonic-energy"]

    let mut missing: i64 = 0
    let mut missing_names = ""
    let mut ai: i64 = 0
    while ai < to_int(all_doms.len()) {
        let d = all_doms[ai]
        let mut found = false
        let mut ci: i64 = 0
        while ci < to_int(covered.len()) {
            if covered[ci] == d { found = true }
            ci = ci + 1
        }
        if !found {
            missing = missing + 1
            if missing_names.len() > 0 { missing_names = missing_names + "," }
            missing_names = missing_names + d
        }
        ai = ai + 1
    }

    println("    BT coverage: " + to_string(to_int(covered.len())) + "/" + to_string(to_int(all_doms.len())) + " domains, gaps: " + to_string(missing))
    if missing > 0 { explore_bus_append("bt_gaps", "missing_domain", missing, missing_names) }
    return missing
}

// Area 6: scripts (scripts/) -- 스크립트 누락/권한
fn explore_scripts() -> i64 {
    println("  [6/6] Scripts scan...")
    let ehome = explore_home()
    let scripts_dir = ehome + "/Dev/nexus6/scripts"
    let mut ls_result = ""
    try { ls_result = exec("ls", [scripts_dir]) } catch e { ls_result = "" }

    if ls_result.trim().len() == 0 {
        println("    scripts directory missing -- GAP")
        explore_bus_append("scripts", "missing", 1, "scripts directory missing")
        return 1
    }

    let files = ls_result.split("\n")
    let mut sh_count: i64 = 0
    let mut non_exec: i64 = 0
    let mut fi: i64 = 0
    while fi < to_int(files.len()) {
        let f = files[fi].trim()
        if f.ends_with(".sh") {
            sh_count = sh_count + 1
            let fpath = scripts_dir + "/" + f
            let mut check = ""
            try { check = exec("test", ["-x", fpath, "&&", "echo", "1"]) } catch e {}
            if check.trim() != "1" {
                non_exec = non_exec + 1
            }
        }
        fi = fi + 1
    }

    println("    scripts: " + to_string(sh_count) + ", non-executable: " + to_string(non_exec))
    if non_exec > 0 { explore_bus_append("scripts", "non_executable", non_exec, "scripts without +x") }
    return non_exec
}

fn run_explore() {
    println("╔══════════════════════════════════════════════════════════════════╗")
    println("║  DEEP SCAN -- 6-Area Explore Loop                               ║")
    println("╚══════════════════════════════════════════════════════════════════╝")
    println("")

    let g1 = explore_atlas()
    let g2 = explore_calc()
    let g3 = explore_readme()
    let g4 = explore_lenses()
    let g5 = explore_bt_gaps()
    let g6 = explore_scripts()

    let total_gaps = g1 + g2 + g3 + g4 + g5 + g6

    println("")
    println("═══ Explore Summary ═══")
    println("  Area      Gaps")
    println("  ──────────────────")
    println("  atlas     " + to_string(g1))
    println("  calc      " + to_string(g2))
    println("  readme    " + to_string(g3))
    println("  lenses    " + to_string(g4))
    println("  BT-gap    " + to_string(g5))
    println("  scripts   " + to_string(g6))
    println("  ──────────────────")
    println("  TOTAL     " + to_string(total_gaps))
    println("")

    // n=6 matching
    if total_gaps == 6 { println("  n=6 resonance: gap count = n = 6!") }
    if total_gaps == 12 { println("  n=6 resonance: gap count = sigma(6) = 12!") }

    explore_bus_append("explore_total", "summary", total_gaps, "atlas=" + to_string(g1) + " calc=" + to_string(g2) + " readme=" + to_string(g3) + " lenses=" + to_string(g4) + " bt=" + to_string(g5) + " scripts=" + to_string(g6))
    println("  [growth_bus.jsonl: 6-area explore results recorded]")
}

