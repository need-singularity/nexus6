// ═══════════════════════════════════════════════════════════════
// ─── MATH UTILITIES ───
// ═══════════════════════════════════════════════════════════════

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 15 {
        g = (g + x / g) / 2.0
        i = i + 1
    }
    return g
}

fn ln_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut sum = 0.0
    let mut term = (x - 1.0) / (x + 1.0)
    let t2 = term * term
    let mut k: i64 = 1
    while k <= 15 {
        sum = sum + term / to_float(k)
        term = term * t2
        k = k + 2
    }
    return 2.0 * sum
}

fn gcd(a: i64, b: i64) -> i64 {
    let mut x = a
    let mut y = b
    if x < 0 { x = 0 - x }
    if y < 0 { y = 0 - y }
    while y > 0 {
        let t = y
        y = x - (x / y) * y
        x = t
    }
    return x
}

// ═══════════════════════════════════════════════════════════════
// ─── n=6 ARITHMETIC FUNCTIONS ───
// ═══════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut d: i64 = 1
    while d <= n {
        if n - (n / d) * d == 0 { s = s + d }
        d = d + 1
    }
    return s
}

fn phi_euler(n: i64) -> i64 {
    let mut count: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        if gcd(k, n) == 1 { count = count + 1 }
        k = k + 1
    }
    return count
}

fn tau_div(n: i64) -> i64 {
    let mut count: i64 = 0
    let mut d: i64 = 1
    while d <= n {
        if n - (n / d) * d == 0 { count = count + 1 }
        d = d + 1
    }
    return count
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut d: i64 = 2
    let mut t = n
    while d * d <= t {
        while t - (t / d) * d == 0 {
            s = s + d
            t = t / d
        }
        d = d + 1
    }
    if t > 1 { s = s + t }
    return s
}

// ═══════════════════════════════════════════════════════════════
// ─── DISCOVERY STORAGE ───
// ═══════════════════════════════════════════════════════════════

let mut d_wave: list = []
let mut d_dom: list = []
let mut d_star: list = []
let mut d_title: list = []

fn rec(w: i64, dom: string, s: i64, t: string) {
    d_wave = d_wave.push(w)
    d_dom = d_dom.push(dom)
    d_star = d_star.push(s)
    d_title = d_title.push(t)
}

fn stars_str(n: i64) -> string {
    let mut s = ""
    let mut i: i64 = 0
    while i < n { s = s + "*"
        i = i + 1 }
    return s
}

fn bar() {
    println("======================================================================")
}

fn show(dom: string, s: i64, title: string, line1: string, line2: string, line3: string) {
    println("")
    println("  " + stars_str(s) + " [" + dom + "] " + title)
    if line1.len() > 0 { println("    " + line1) }
    if line2.len() > 0 { println("    " + line2) }
    if line3.len() > 0 { println("    " + line3) }
}

