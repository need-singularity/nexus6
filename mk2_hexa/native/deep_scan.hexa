    rec(2, "STRING", 5, "bosonic=26, super=10=2sopfr, CY3=dim P1")
    show("STRING", 5, "Critical dimensions: bosonic=26, super=10=2*sopfr, CY3=dim P1", "Superstring: 10 = 2*sopfr, CY3 real dim = P1 = 6", "Central charge: c=15=C(P1,2) (super)", "")

