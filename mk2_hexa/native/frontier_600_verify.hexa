// ── helpers not in builtins ──

fn fact(n: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= n { r = r * i  i = i + 1 }
    r
}

fn omega(n: int) -> int {
    let mut c = 0
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { c = c + 1 }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { c = c + 1 }
    c
}

fn rad(n: int) -> int {
    let mut r = 1
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { r = r * p }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { r = r * t }
    r
}

fn pow_int(base: int, exp: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < exp { r = r * base  i = i + 1 }
    r
}

fn comb(n: int, k: int) -> int {
    let mut r = 1
    let mut i = 1
    while i <= k { r = r * (n - i + 1) / i  i = i + 1 }
    r
}

fn is_perfect(n: int) -> bool { sigma(n) == 2 * n }

fn partition_count(n: int) -> int {
    let mut p = []
    let mut idx = 0
    while idx <= n { p = p + [0]  idx = idx + 1 }
    p[0] = 1
    let mut i = 1
    while i <= n {
        let mut j = i
        while j <= n { p[j] = p[j] + p[j - i]  j = j + 1 }
        i = i + 1
    }
    p[n]
}

