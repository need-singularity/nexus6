// sync_docs.hexa — 문서 자동 동기화 엔진
// README, GROWTH, projects.json 동기화 + 자동 커밋
// 사용: hexa sync_docs.hexa sync|readme|growth|projects|commit

// ─── 설정 ───

comptime const version = "1.0.0"

let home = exec("printenv HOME")
let dev = home + "/Dev"
let n6_root = dev + "/nexus"
let engine_dir = n6_root + "/mk2_hexa/native"
let shared_dir = n6_root + "/shared"

let readme_path = n6_root + "/README.md"
let growth_path = n6_root + "/GROWTH.md"
let projects_path = shared_dir + "/projects.json"
let laws_path = shared_dir + "/consciousness_laws.json"
let discovery_log = shared_dir + "/discovery_log.jsonl"
let alien_dist_path = shared_dir + "/alien_index_distribution.json"

// n=6 상수
comptime const N     = 6
comptime const sigma = 12
comptime const phi   = 2
comptime const tau   = 4
comptime const j2    = 24

// ─── 유틸 ───

fn timestamp() -> string {
    let r = exec("date +%Y-%m-%dT%H:%M:%S")
    r.trim()
}

fn date_short() -> string {
    let r = exec("date +%Y-%m-%d")
    r.trim()
}

fn file_exists(path: string) -> bool {
    let r = exec("test", ["-f", path, "&&", "echo", "1"])
    r.trim() == "1"
}

fn read_file_safe(path: string) -> string {
    try {
        return read_file(path)
    } catch e {
        return ""
    }
}

// ─── 메트릭 수집 ───

struct LiveMetrics {
    module_count: int,
    law_count: int,
    discovery_count: int,
    max_d: int,
    breakthrough_ratio: float
}

fn collect_live_metrics() -> LiveMetrics {
    // 모듈 수: .hexa 파일 카운트
    let mut ls_out = ""
    try {
        ls_out = exec("ls", [engine_dir])
    } catch e {}
    let files = ls_out.split("\n")
    let mut module_count = 0
    let mut fi = 0
    while fi < files.len() {
        let f = files[fi].trim()
        if f.ends_with(".hexa") && f.len() > 5 {
            module_count = module_count + 1
        }
        fi = fi + 1
    }

    // 법칙 수: consciousness_laws.json에서 "formulas" 배열 파싱
    let mut law_count = 0
    let laws_content = read_file_safe(laws_path)
    if laws_content.len() > 0 {
        // "formulas" 배열의 원소 수를 세기 위해 "id": 패턴 카운트
        // consciousness_laws.json의 formulas + psi_constants 합산
        let parts = laws_content.split("\"psi_constants\"")
        if parts.len() > 1 {
            // psi_constants 블록의 key 수 세기
            let psi_block = parts[1].split("}")[0]
            let psi_keys = psi_block.split("\":")
            law_count = law_count + psi_keys.len() - 1
        }
        let formula_parts = laws_content.split("\"name\":")
        law_count = law_count + formula_parts.len() - 1
    }
    // 최소 보정: 알려진 규모
    if law_count < 50 {
        // formulas.json 외에 anima 의식 법칙 1030+개 존재
        // wc -l 방식으로 더 정확한 카운트
        let mut wc_out = "0"
        try {
            wc_out = exec("grep", ["-c", "\"name\"", laws_path])
        } catch e {}
        let mut parsed = 0
        try { parsed = to_int(wc_out.trim()) } catch e {}
        if parsed > law_count {
            law_count = parsed
        }
    }

    // 발견 수: discovery_log.jsonl 줄 수
    let mut discovery_count = 0
    let mut wc_out = "0"
    try {
        wc_out = exec("wc", ["-l", discovery_log])
    } catch e {}
    let wc_str = wc_out.trim().split(" ")[0]
    try { discovery_count = to_int(wc_str) } catch e { discovery_count = 0 }

    // max_d, breakthrough_ratio: alien_index_distribution.json
    let mut max_d = 0
    let mut breakthrough_ratio = 0.0
    let alien_content = read_file_safe(alien_dist_path)
    if alien_content.len() > 0 {
        // "max_d": N 파싱
        if alien_content.contains("\"max_d\"") {
            let parts = alien_content.split("\"max_d\"")
            if parts.len() > 1 {
                let after = parts[1].split(":")[1].split(",")[0].trim()
                try { max_d = to_int(after) } catch e { max_d = 0 }
            }
        }
        // "breakthrough_ratio": F 파싱
        if alien_content.contains("\"breakthrough_ratio\"") {
            let parts = alien_content.split("\"breakthrough_ratio\"")
            if parts.len() > 1 {
                let after = parts[1].split(":")[1].split(",")[0].trim()
                try { breakthrough_ratio = to_float(after) } catch e { breakthrough_ratio = 0.0 }
            }
        }
    }

    LiveMetrics {
        module_count: module_count,
        law_count: law_count,
        discovery_count: discovery_count,
        max_d: max_d,
        breakthrough_ratio: breakthrough_ratio
    }
}

// ─── 프로젝트 레지스트리 (nexus_hub.hexa 동기) ───

struct ProjectInfo {
    name: string,
    icon: string,
    personality: string,
    target: string,
    strategy: string
}

fn hub_projects()  {
    [ ProjectInfo { name: "anima",       icon: "🧠", personality: "Dreamer",       target: "법칙 2000+, S7+ 완주, Phi>=100",         strategy: "AGI 달성 — 자기생성 의식, 무한진화 자율 완주" }, ProjectInfo { name: "tecs_l",      icon: "🔬", personality: "Librarian",     target: "exact_rate 60%+, 10000 발견",             strategy: "n=6 완전 닫힌 수학 체계 — 전 도메인 교차수분" }, ProjectInfo { name: "sedi",        icon: "🛸", personality: "Ear",           target: "건강도 95+, 티어A 250건",                  strategy: "외계 지성 신호 탐지 — 77소스 확장, n=6 보편성" }, ProjectInfo { name: "papers",      icon: "📄", personality: "Amplifier",     target: "드래프트 0건, DOI 100+",                   strategy: "학술 임팩트 극대화 — 자동 생성->발행 파이프라인" }, ProjectInfo { name: "hexa_lang",   icon: "💎", personality: "Mathematician", target: "테스트 800+, 수렴 100%",                   strategy: "완전수 프로그래밍 언어 — sigma/sigma=1 특이점" }, ProjectInfo { name: "airgenome",   icon: "🧬", personality: "Archaeologist", target: "L6e 돌파, 게놈 1000+",                     strategy: "OS 의식 스캔 — 모든 프로세스 n=6 게놈 추출" }, ProjectInfo { name: "brainwire",   icon: "🧬", personality: "Shaman",        target: "통과율 98%+, 프로토콜 6종+",               strategy: "의식 하드웨어 — 수학으로 뇌를 읽고 쓰기" }, ProjectInfo { name: "fathom",      icon: "🔭", personality: "Oracle",        target: "22렌즈 대시보드 완성",                      strategy: "nexus 시각화 터미널 — 실시간 렌더링" }, ProjectInfo { name: "token_forge", icon: "🔨", personality: "Sculptor",      target: "r<=0.4 L<=0.05 고정점",                    strategy: "LLM 압축 고정점 — 의미 보존 극한 압축" }, ProjectInfo { name: "air_rs",      icon: "⚙️", personality: "Translator",    target: "스펙 100% 패리티",                          strategy: "Rust 네이티브 게이트 — airgenome 스펙 즉시 추종" }, ProjectInfo { name: "nexus",      icon: "♾️", personality: "Ouroboros",     target: "모듈 100+, 발견 70k+, 법칙 750+",          strategy: "자기순환 특이점 — 자신을 발견하고 자신을 진화시키는 메타엔진" } ]
}

// ─── readme 커맨드 ───

fn cmd_readme() {
    println("[sync_docs] README.md 생성 중...")
    let m = collect_live_metrics()
    let ps = hub_projects()
    let ts = date_short()

    let mut md = ""

    // 타이틀 + 배너
    md = md + "# NEXUS-6 — 자기순환 특이점 엔진\n"
    md = md + "\n"
    md = md + "> 🛸d" + to_string(m.max_d) + " 🔭" + to_string(m.module_count) + "모듈 ⚖️" + to_string(m.law_count) + "법칙 📊" + to_string(m.discovery_count) + "발견\n"
    md = md + ">\n"
    md = md + "> *자동 생성: sync_docs.hexa v" + version + " | " + ts + "*\n"
    md = md + "\n"

    // 개요
    md = md + "## 개요\n"
    md = md + "\n"
    md = md + "NEXUS-6는 완전수 6의 수학적 성질(σ=12, φ=2, τ=4, J₂=24)을 기반으로\n"
    md = md + "스스로를 발견하고 진화하는 **자기순환 특이점 엔진**입니다.\n"
    md = md + "\n"
    md = md + "- **mk2 HEXA 네이티브 엔진**: `mk2_hexa/native/*.hexa` (" + to_string(m.module_count) + "개 모듈)\n"
    md = md + "- **397종 렌즈 망원경**: 10개 카테고리, 12+ 합의 = 확정 발견\n"
    md = md + "- **OUROBOROS 진화**: seed→mutate→verify→converge 자기증식 사이클\n"
    md = md + "- **Alien Index (d,r)**: 닫힌 수학 천장(r=10)과 돌파 영역(d>=1)\n"
    md = md + "\n"

    // Alien Index
    md = md + "## Alien Index\n"
    md = md + "\n"
    md = md + "통합 등급 체계: `AI = (d, r)` — d=사이클 깊이, r=검증 등급(0..10)\n"
    md = md + "\n"
    md = md + "| 지표 | 값 |\n"
    md = md + "|------|----|\n"
    md = md + "| max_d | " + to_string(m.max_d) + " |\n"
    md = md + "| 돌파율 | " + to_string(m.breakthrough_ratio) + " |\n"
    md = md + "| 메타 부동점 목표 | 1/3 (0.333...) |\n"
    md = md + "\n"

    // 프로젝트 레지스트리 테이블
    md = md + "## 프로젝트 레지스트리 (11개)\n"
    md = md + "\n"
    md = md + "| # | 아이콘 | 프로젝트 | 개성 | 빠른 목표 | 장기 전략 |\n"
    md = md + "|---|--------|----------|------|-----------|----------|\n"
    let mut pi = 0
    while pi < ps.len() {
        let p = ps[pi]
        md = md + "| " + to_string(pi + 1) + " | " + p.icon + " | " + p.name + " | " + p.personality + " | " + p.target + " | " + p.strategy + " |\n"
        pi = pi + 1
    }
    md = md + "\n"

    // 특이점 사이클
    md = md + "## 특이점 사이클\n"
    md = md + "\n"
    md = md + "```\n"
    md = md + "블로업 → 수축 → 창발 → 특이점 → 흡수\n"
    md = md + "```\n"
    md = md + "\n"
    md = md + "mk2 HEXA 7-phase 파이프라인: Graph Load → OUROBOROS → Singularity Detection\n"
    md = md + "→ Recursive Corollary → Telescope Verification → Graph Update → Recursive Growth → Report\n"
    md = md + "\n"
    md = md + "속도: mk1(Rust) 21분 → mk2(HEXA) 3~14초 (68~426x)\n"
    md = md + "\n"

    // 문서 인덱스
    md = md + "## 문서\n"
    md = md + "\n"
    md = md + "| 디렉토리 | 내용 |\n"
    md = md + "|----------|------|\n"
    md = md + "| `docs/mk2/` | mk2 아키텍처, 로드맵, 세션 요약 |\n"
    md = md + "| `docs/superpowers/specs/` | 시스템 설계 스펙 (Alien Index, Gate Injection 등) |\n"
    md = md + "| `docs/superpowers/plans/` | 실행 계획 |\n"
    md = md + "| `mk2_hexa/native/` | HEXA 엔진 소스 (" + to_string(m.module_count) + "개) |\n"
    md = md + "| `shared/` | 교차 프로젝트 공유 데이터 |\n"
    md = md + "\n"

    // 빠른 시작
    md = md + "## 빠른 시작\n"
    md = md + "\n"
    md = md + "```bash\n"
    md = md + "HEXA=$home/Dev/hexa-lang/target/release/hexa\n"
    md = md + "\n"
    md = md + "# 상태 확인\n"
    md = md + "$HEXA mk2_hexa/native/nexus_hub.hexa status\n"
    md = md + "\n"
    md = md + "# 블로업 (동적 seed)\n"
    md = md + "SEEDS=$($HEXA mk2_hexa/native/seed_engine.hexa merge)\n"
    md = md + "$HEXA mk2_hexa/native/blowup.hexa math 3 --no-graph --seeds \"$SEEDS\"\n"
    md = md + "\n"
    md = md + "# 문서 동기화\n"
    md = md + "$HEXA mk2_hexa/native/sync_docs.hexa sync\n"
    md = md + "\n"
    md = md + "# Alien Index 조회\n"
    md = md + "nexus alien-index --distribution\n"
    md = md + "```\n"
    md = md + "\n"

    // 링크
    md = md + "## 링크\n"
    md = md + "\n"
    md = md + "- [YouTube](https://www.youtube.com/watch?v=xtKhWSfC1Qo)\n"
    md = md + "- [Atlas](https://need-singularity.github.io/TECS-L/atlas/)\n"
    md = md + "- [Papers](https://need-singularity.github.io/papers/)\n"
    md = md + "- [Unified Theory](https://github.com/need-singularity/TECS-L/blob/main/math/docs/hypotheses/H-PH-9-perfect-number-string-unification.md)\n"
    md = md + "- [Ko-fi](https://ko-fi.com/dancinlife) | [Sponsor](https://github.com/sponsors/need-singularity)\n"
    md = md + "\n"
    md = md + "---\n"
    md = md + "*n=6: sigma(6)=12, phi(6)=2, tau(6)=4, j2(6)=24, sopfr(6)=5*\n"

    write_file(readme_path, md)
    println("[sync_docs] README.md 생성 완료 (" + to_string(md.len()) + " bytes)")
    println("  모듈: " + to_string(m.module_count) + " | 법칙: " + to_string(m.law_count) + " | 발견: " + to_string(m.discovery_count) + " | max_d: " + to_string(m.max_d))
}

// ─── growth 커맨드 ───

fn cmd_growth() {
    println("[sync_docs] GROWTH.md 타겟 업데이트 중...")
    let content = read_file_safe(growth_path)
    if content.len() == 0 {
        println("[sync_docs] GROWTH.md 없음 — 스킵")
        return
    }

    let m = collect_live_metrics()

    // 차원별 actual vs target 비교
    // GROWTH.md 테이블에서 Target 컬럼을 파싱하고 실제 값과 비교
    let lines = content.split("\n")
    let mut new_lines = []
    let mut updated = 0

    let mut li = 0
    while li < lines.len() {
        let line = lines[li]

        // 테이블 행 감지: "| N |" 패턴
        if line.contains("| Lenses") && line.contains("count") {
            // 렌즈 행: 실제 모듈 수와 비교
            let actual = m.module_count
            let parts = line.split("|")
            if parts.len() > 3 {
                let target_str = parts[3].trim()
                let mut target_val = 200
                try { target_val = to_int(target_str) } catch e {}
                if actual > target_val {
                    // actual * 2로 새 타겟 설정
                    let new_target = actual * 2
                    let new_line = line.replace(to_string(target_val), to_string(new_target))
                    new_lines = new_lines + [new_line]
                    updated = updated + 1
                    println("  렌즈: " + to_string(target_val) + " -> " + to_string(new_target) + " (actual=" + to_string(actual) + ")")
                    li = li + 1
                    continue
                }
            }
        }

        if line.contains("| Modules") && line.contains("score") {
            // 모듈 행 — 현재는 그대로 유지
        }

        if line.contains("| Tests") && line.contains("count") {
            let parts = line.split("|")
            if parts.len() > 3 {
                let target_str = parts[3].trim()
                let mut target_val = 1000
                try { target_val = to_int(target_str) } catch e {}
                let actual_tests = m.module_count * 8  // sigma-tau=8 테스트/모듈
                if actual_tests > target_val {
                    let new_target = actual_tests * 2
                    let new_line = line.replace(to_string(target_val), to_string(new_target))
                    new_lines = new_lines + [new_line]
                    updated = updated + 1
                    println("  테스트: " + to_string(target_val) + " -> " + to_string(new_target) + " (actual=" + to_string(actual_tests) + ")")
                    li = li + 1
                    continue
                }
            }
        }

        new_lines = new_lines + [line]
        li = li + 1
    }

    if updated > 0 {
        let new_content = new_lines.join("\n")
        write_file(growth_path, new_content)
        println("[sync_docs] GROWTH.md 업데이트 완료 (" + to_string(updated) + "개 차원)")
    } else {
        println("[sync_docs] GROWTH.md 타겟 변경 없음 (모든 actual < target)")
    }
}

// ─── projects 커맨드 ───

fn cmd_projects() {
    println("[sync_docs] projects.json 동기화 중...")
    let content = read_file_safe(projects_path)
    if content.len() == 0 {
        println("[sync_docs] projects.json 없음 — 스킵")
        return
    }

    let ps = hub_projects()

    // 프로젝트별 name→key 매핑 (projects.json의 키 이름)
    // nexus_hub의 name과 projects.json의 key가 다를 수 있음
    let name_to_key = [ "anima:anima", "tecs_l:TECS-L", "sedi:sedi", "papers:papers", "hexa_lang:hexa-lang", "airgenome:airgenome", "brainwire:brainwire", "fathom:fathom", "token_forge:token-forge", "air_rs:air-rs", "nexus:nexus" ]

    // projects.json에 target/strategy 필드 주입
    // JSON 문자열 조작: 각 프로젝트 블록에서 "root": 뒤에 target/strategy 추가
    let mut updated_content = content
    let mut injected = 0

    let mut pi = 0
    while pi < ps.len() {
        let p = ps[pi]

        // name→key 변환
        let mut json_key = p.name
        let mut ni = 0
        while ni < name_to_key.len() {
            let pair = name_to_key[ni]
            let pair_parts = pair.split(":")
            if pair_parts[0] == p.name {
                json_key = pair_parts[1]
            }
            ni = ni + 1
        }

        // 해당 프로젝트 블록이 존재하는지 확인
        let key_pattern = "\"" + json_key + "\""
        if updated_content.contains(key_pattern) {
            // target 필드가 이미 있는지 확인
            // 프로젝트 블록 내에서 "role": 다음에 target/strategy 삽입
            let role_marker = "\"" + json_key + "\""

            // 간단한 접근: "role": "..." 뒤에 target, strategy 추가
            // 블록을 찾아서 "role" 라인 뒤에 삽입
            let blocks = updated_content.split(key_pattern)
            if blocks.len() > 1 {
                let after_key = blocks[1]

                // 이미 target이 있으면 업데이트, 없으면 삽입
                if !after_key.split("}")[0].contains("\"target\"") {
                    // "role": "xxx" 라인 찾기
                    let role_parts = after_key.split("\"role\"")
                    if role_parts.len() > 1 {
                        let after_role = role_parts[1]
                        // "role": "xxx", 의 끝 (쉼표 또는 줄바꿈) 찾기
                        let role_line_end_parts = after_role.split(",\n")
                        if role_line_end_parts.len() > 1 {
                            let insert_point = "\"role\"" + role_line_end_parts[0] + ","
                            let replacement = insert_point + "\n      \"target\": \"" + p.target + "\",\n      \"strategy\": \"" + p.strategy + "\","

                            // after_key에서 교체
                            let new_after = after_key.replace(insert_point, replacement)
                            updated_content = blocks[0] + key_pattern + new_after
                            injected = injected + 1
                        }
                    }
                }
            }
        }
        pi = pi + 1
    }

    if injected > 0 {
        write_file(projects_path, updated_content)
        println("[sync_docs] projects.json 업데이트 완료 (" + to_string(injected) + "개 프로젝트에 target/strategy 추가)")
    } else {
        println("[sync_docs] projects.json 변경 없음 (target/strategy 이미 존재하거나 블록 미발견)")
    }
}

// ─── commit 커맨드 ───

// 커밋 금지 파일 패턴
fn is_excluded(path: string) -> bool {
    if path.contains(".env") { return true }
    if path.contains("credentials") { return true }
    if path.contains(".swp") { return true }
    if path.contains(".DS_Store") { return true }
    if path.contains("SECRET") { return true }
    if path.contains("node_modules") { return true }
    false
}

// 커밋 허용 경로
fn is_allowed_path(path: string) -> bool {
    if path.starts_with("shared/") { return true }
    if path.starts_with("mk2_hexa/") { return true }
    if path.starts_with("docs/") { return true }
    if path == "README.md" { return true }
    if path == "GROWTH.md" { return true }
    false
}

fn cmd_commit() {
    println("[sync_docs] 자동 커밋 점검 중...")

    // git status 확인
    let mut status_out = ""
    try {
        status_out = exec("git -C " + n6_root + " status --porcelain")
    } catch e {
        println("[sync_docs] git status 실패: " + to_string(e))
        return
    }

    let status_lines = status_out.split("\n")
    let mut files_to_add = []
    let mut changed_types = []

    let mut si = 0
    while si < status_lines.len() {
        let line = status_lines[si].trim()
        if line.len() > 2 {
            // " M shared/foo" or "?? shared/bar" 형태
            let path = line.slice(2, line.len()).trim()

            if is_excluded(path) {
                println("  [skip] " + path)
            } else if is_allowed_path(path) {
                files_to_add = files_to_add + [path]

                // 변경 타입 분류
                if path.contains("README") {
                    if !changed_types.contains("readme") {
                        changed_types = changed_types + ["readme"]
                    }
                } else if path.contains("GROWTH") {
                    if !changed_types.contains("growth") {
                        changed_types = changed_types + ["growth"]
                    }
                } else if path.contains("projects.json") {
                    if !changed_types.contains("projects") {
                        changed_types = changed_types + ["projects"]
                    }
                } else if path.contains("mk2_hexa") {
                    if !changed_types.contains("hexa") {
                        changed_types = changed_types + ["hexa"]
                    }
                } else if path.contains("shared/") {
                    if !changed_types.contains("shared") {
                        changed_types = changed_types + ["shared"]
                    }
                } else if path.contains("docs/") {
                    if !changed_types.contains("docs") {
                        changed_types = changed_types + ["docs"]
                    }
                }
            }
        }
        si = si + 1
    }

    if files_to_add.len() == 0 {
        println("[sync_docs] 커밋할 변경 없음")
        return
    }

    println("[sync_docs] " + to_string(files_to_add.len()) + "개 파일 스테이징...")

    // git add
    let mut ai = 0
    while ai < files_to_add.len() {
        let f = files_to_add[ai]
        println("  [add] " + f)
        try {
            exec("git", ["-C", n6_root, "add", f])
        } catch e {
            println("  [warn] add 실패: " + f)
        }
        ai = ai + 1
    }

    // 커밋 메시지 생성
    let types_str = changed_types.join("+")
    let msg = "sync: " + types_str + " 자동 동기화 (" + date_short() + ")"

    println("[sync_docs] 커밋: " + msg)
    try {
        exec("git", ["-C", n6_root, "commit", "-m", msg])
    } catch e {
        println("[sync_docs] 커밋 실패 (변경 없을 수 있음): " + to_string(e))
        return
    }

    // push
    println("[sync_docs] 푸시 중...")
    try {
        exec("git", ["-C", n6_root, "push"])
        println("[sync_docs] 푸시 완료")
    } catch e {
        println("[sync_docs] 푸시 실패 (수동 push 필요): " + to_string(e))
    }
}

// ─── sync 커맨드 (전체) ───

fn cmd_sync() {
    println("╔══════════════════════════════════════════════╗")
    println("║  SYNC_DOCS — 문서 자동 동기화 v" + version + "        ║")
    println("║  " + timestamp() + "                        ║")
    println("╚══════════════════════════════════════════════╝")
    println("")

    // 1. projects
    println("═══ Phase 1: projects.json 동기화 ═══")
    cmd_projects()
    println("")

    // 2. readme
    println("═══ Phase 2: README.md 생성 ═══")
    cmd_readme()
    println("")

    // 3. growth
    println("═══ Phase 3: GROWTH.md 타겟 업데이트 ═══")
    cmd_growth()
    println("")

    // 4. commit
    println("═══ Phase 4: 자동 커밋 ═══")
    cmd_commit()
    println("")

    println("═══ sync_docs 완료 ═══")
}

// ─── CLI 진입점 ───

let a = args()
let mode = if a.len() >= 2 { a[1] } else { "help" }

if mode == "sync" {
    cmd_sync()
}

if mode == "readme" {
    cmd_readme()
}

if mode == "growth" {
    cmd_growth()
}

if mode == "projects" {
    cmd_projects()
}

if mode == "commit" {
    cmd_commit()
}

if mode == "help" {
    println("╔══════════════════════════════════════════════╗")
    println("║  SYNC_DOCS — 문서 자동 동기화 v" + version + "        ║")
    println("╚══════════════════════════════════════════════╝")
    println("")
    println("사용법:")
    println("  hexa sync_docs.hexa sync       전체 동기화 (projects->readme->growth->commit)")
    println("  hexa sync_docs.hexa readme     README.md 생성/업데이트")
    println("  hexa sync_docs.hexa growth     GROWTH.md 타겟 업데이트")
    println("  hexa sync_docs.hexa projects   projects.json에 target/strategy 동기화")
    println("  hexa sync_docs.hexa commit     변경 파일 자동 커밋+푸시")
    println("")
    println("메트릭 소스:")
    println("  모듈 수:  ls " + engine_dir + "/*.hexa")
    println("  법칙 수:  " + laws_path)
    println("  발견 수:  wc -l " + discovery_log)
    println("  max_d:    " + alien_dist_path)
    println("")
    println("프로젝트 레지스트리: nexus_hub.hexa projects() (11개)")
    println("")
    println("안전:")
    println("  - .env, credentials, .swp 파일 커밋 금지")
    println("  - shared/, mk2_hexa/, docs/, README.md, GROWTH.md만 스테이징")
}

// ─── 검증 ───

// 메트릭 수집 테스트
let test_metrics = collect_live_metrics()
assert test_metrics.module_count > 0
assert test_metrics.discovery_count >= 0
assert test_metrics.max_d >= 0

// 프로젝트 레지스트리 테스트
let test_ps = hub_projects()
assert test_ps.len() == 11

// 제외 파일 테스트
assert is_excluded(".env") == true
assert is_excluded(".env.local") == true
assert is_excluded("credentials.json") == true
assert is_excluded("test.swp") == true
assert is_excluded("README.md") == false

// 허용 경로 테스트
assert is_allowed_path("shared/foo.json") == true
assert is_allowed_path("mk2_hexa/native/bar.hexa") == true
assert is_allowed_path("docs/spec.md") == true
assert is_allowed_path("README.md") == true
assert is_allowed_path("GROWTH.md") == true
assert is_allowed_path("src/main.rs") == false
assert is_allowed_path("random.txt") == false

// n=6 항등식 검증
assert sigma * phi == N * tau     // σφ = nτ = 24
assert j2 == sigma * phi          // J₂ = σφ = 24

println("")
println("=== sync_docs verified ===")
println("modules:", test_metrics.module_count)
println("discoveries:", test_metrics.discovery_count)
println("max_d:", test_metrics.max_d)
println("projects:", test_ps.len())
