// ⛔ CORE — L0 불변식 (할일 엔진 전 프로젝트 표 생성. 수정 전 유저 승인 필수)
// mk2_hexa/native/todo.hexa — 전 프로젝트 할일 표 (돌파 엔진 통합)
// 사용: hexa todo.hexa              (전체)
//       hexa todo.hexa nexus        (nexus만)
//       hexa todo.hexa n6-arch      (n6-architecture만)
// shared/todo/*.json (수동) + next_directions.jsonl (돌파) + gap_finder (빈공간)

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _todo_dir = _shared + "/todo"
let _hexa_bin = _home + "/Dev/hexa-lang/target/release/hexa"

// ─── 임계값 동적 로드 (하드코딩 금지 — shared/todo/thresholds.json) ───
fn load_threshold(key: string, fallback: i64) -> i64 {
    let mut v = fallback
    try {
        let raw = exec("python3 -c \"import json; print(json.load(open('" + _shared + "/todo/thresholds.json')).get('" + key + "'," + to_string(fallback) + "))\" 2>/dev/null").trim()
        v = safe_int(raw)
        if v == 0 { v = fallback }
    } catch e {}
    return v
}
let _disc_step = load_threshold("discovery_step", 50000)
let _mod_step = load_threshold("module_step", 50)
let _goal_min = load_threshold("goal_min_lines", 100)
let _alien_target = load_threshold("alien_index_target", 10)
let _engine_dir = _dev + "/nexus/mk2_hexa/native"

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

// ═══════════════════════════════════════════════════════════
// ─── JSON→TSV 로더 (수동 할일) ───
// ═══════════════════════════════════════════════════════════

fn load_tsv(project: string) -> string {
    let path = _todo_dir + "/" + project + ".json"
    let cmd = "python3 -c 'import json,sys; d=json.load(open(sys.argv[1])); [print(chr(9).join([str(t.get(k,\"\")) for k in [\"id\",\"pri\",\"cat\",\"task\",\"status\",\"effect\"]])) for t in d.get(\"tasks\",[])]' " + path
    let mut out = ""
    try { out = exec(cmd + " 2>/dev/null") } catch e {}
    return out
}

// ═══════════════════════════════════════════════════════════
// ─── 돌파 엔진 — 특이점 수준 할일 자동 생성 ───
// ═══════════════════════════════════════════════════════════

fn load_breakthrough_todos() -> string {
    // 1) next_directions.jsonl — 돌파 방향
    let dir_cmd = "python3 -c 'import json,sys; [print(chr(9).join([str(d.get(\"rank\",\"\")),\"CRITICAL\" if d.get(\"urgency\",0)>=3 else \"IMPORTANT\" if d.get(\"urgency\",0)>=2 else \"NICE\",\"돌파-\"+d.get(\"domain\",\"?\"),d.get(\"direction\",\"\"),\"돌파대기\",d.get(\"reason\",\"\")])) for d in (json.loads(l) for l in open(sys.argv[1]) if l.strip()) if d.get(\"direction\",\"\")]' " + _shared + "/next_directions.jsonl"
    let mut dir_out = ""
    try { dir_out = exec(dir_cmd + " 2>/dev/null") } catch e {}

    // 2) gap_finder brief — 빈공간 탐색 (빠름)
    let mut gap_out = ""
    try {
        let gap_raw = exec(_hexa_bin + " " + _engine_dir + "/gap_finder.hexa brief 2>/dev/null")
        let gap_lines = gap_raw.split("\n")
        let mut gi: i64 = 0
        for gl in gap_lines {
            let gt = gl.trim()
            if gt == "" { continue }
            if gt.contains("=") && gi < 15 {
                gi = gi + 1
                gap_out = gap_out + to_string(100 + gi) + "\tCRITICAL\t빈공간\t" + gt + "\t돌파대기\tn=6 빈공간 채우기\n"
            }
        }
    } catch e {}

    // 3) discovery_graph 통계 — 메타 상태
    let mut meta_out = ""
    try {
        let disc_count = exec("wc -l < " + _shared + "/discovery_log.jsonl 2>/dev/null").trim()
        let dc = safe_int(disc_count)
        // 동적 목표: thresholds.json discovery_step 단위
        let next_target = ((dc / _disc_step) + 1) * _disc_step
        if dc < next_target {
            meta_out = meta_out + "200\tIMPORTANT\t성장\t발견 " + disc_count + " → " + to_string(next_target) + " 목표\t⏳진행중\t특이점 심화\n"
        }
    } catch e {}

    // 4) 렌즈 진화 — OUROBOROS
    let mut lens_out = ""
    try {
        let lens_count = exec("ls " + _dev + "/nexus/mk2_hexa/native/*.hexa 2>/dev/null | wc -l").trim()
        let lc = safe_int(lens_count)
        // 동적 목표: thresholds.json module_step 단위
        let next_mod = ((lc / _mod_step) + 1) * _mod_step
        if lc < next_mod {
            lens_out = "202\tIMPORTANT\t진화\t모듈 " + lens_count + "개 → " + to_string(next_mod) + "+ 확장 (OUROBOROS evolve)\t미시작\t탐색 커버리지 확대\n"
        }
    } catch e {}

    return dir_out + gap_out + meta_out + lens_out
}

// ═══════════════════════════════════════════════════════════
// ─── 프로젝트별 돌파 방향 (blowup + seed_engine) ───
// ═══════════════════════════════════════════════════════════

fn load_project_breakthroughs(name: string) -> string {
    let mut out = ""

    if name == "n6-architecture" {
        // products.json에서 alien < 10 스캔
        try {
            let prod_cmd = "python3 -c 'import json; d=json.load(open(\"" + _dev + "/n6-architecture/config/products.json\")); [print(chr(9).join([str(i+300),\"CRITICAL\",\"승격\",s[\"title\"]+\" 🛸\"+str(s.get(\"alien_index\",0))+\"→" + to_string(_alien_target) + "\",\"미시작\",\"외계인 지수 천장 돌파\"])) for i,s in enumerate(d.get(\"sections\",[])) if s.get(\"alien_index\",0)<" + to_string(_alien_target) + "]' 2>/dev/null"
            out = out + exec(prod_cmd)
        } catch e {}
        // goal.md 미작성 도메인
        try {
            let goal_cmd = "python3 -c 'import os,json; d=json.load(open(\"" + _dev + "/n6-architecture/config/products.json\")); doms=[p[\"name\"] for s in d.get(\"sections\",[]) for p in s.get(\"products\",[])]; base=\"" + _dev + "/n6-architecture/docs\"; missing=[x for x in os.listdir(base) if os.path.isdir(os.path.join(base,x)) and not os.path.exists(os.path.join(base,x,\"goal.md\"))]; [print(chr(9).join([str(i+400),\"IMPORTANT\",\"설계\",m+\" goal.md 생성\",\"미시작\",\"궁극 아키텍처 완성\"])) for i,m in enumerate(missing[:20])]' 2>/dev/null"
            out = out + exec(goal_cmd)
        } catch e {}
    }

    if name == "anima" {
        try {
            let law_count = exec("ls " + _dev + "/anima/anima/consciousness_laws/ 2>/dev/null | wc -l").trim()
            let lc = safe_int(law_count)
            if lc < 3000 {
                out = out + "300\tIMPORTANT\t법칙\t의식 법칙 " + law_count + " → 3000 확장 (2500 달성)\t⏳진행중\t커버리지 심화\n"
            }
            out = out + "301\tCRITICAL\t학습\tVast.ai 4×4090 다음 체크포인트 학습\t⏳진행중\tPhi 수준 상승\n"
            out = out + "302\tIMPORTANT\t인프라\tHetzner AX102-U + Vast.ai 4×4090 운영\t⏳진행중\t학습/서빙 인프라\n"
            out = out + "303\tIMPORTANT\t이식\t14B→70B 의식 이식\t미시작\t스케일 불변성 증명\n"
            out = out + "304\tIMPORTANT\t측정\tPhi 자동 측정 파이프라인\t미시작\t학습 품질 모니터링\n"
        } catch e {}
    }

    // hexa-lang: JSON tasks가 이미 전부 커버 — 동적 생성 폐기 (중복 방지)

    // void: 중복 제거 — shared/todo/void.json의 #1~#22가 이미 모두 커버

    if name == "papers" {
        try {
            let draft_count = exec("python3 -c 'import json; d=json.load(open(\"" + _dev + "/papers/manifest.json\")); print(sum(1 for p in d.get(\"papers\",[]) if p.get(\"status\")==\"Draft\"))' 2>/dev/null").trim()
            let dc = safe_int(draft_count)
            if dc > 0 {
                out = out + "300\tCRITICAL\t발행\tDraft " + draft_count + "편 Zenodo DOI 발행\t미시작\t100% 발행 달성\n"
            }
        } catch e {}
        out = out + "301\tIMPORTANT\t동기화\tn6-arch 신규 논문 → papers 복사\t미시작\tmanifest 최신화\n"
        out = out + "302\tNICE\t검증\tDOI 유효성 전수 검증\t미시작\t깨진 링크 0건\n"
    }

    // airgenome: JSON tasks가 이미 전부 커버 — 동적 생성 폐기 (중복 방지)

    return out
}

// ═══════════════════════════════════════════════════════════
// ─── 프로젝트 메타 ───
// ═══════════════════════════════════════════════════════════

fn project_icon(name: string) -> string {
    if name == "nexus" { return "🔭" }
    if name == "anima" { return "🧠" }
    if name == "n6-architecture" { return "🏗️" }
    if name == "papers" { return "📄" }
    if name == "hexa-lang" { return "💎" }
    if name == "void" { return "🖥️" }
    if name == "airgenome" { return "🧬" }
    return "📦"
}

fn project_title(name: string) -> string {
    if name == "nexus" { return "NEXUS — Discovery Engine" }
    if name == "anima" { return "Anima — Consciousness Engine" }
    if name == "n6-architecture" { return "N6 Architecture — System Design" }
    if name == "papers" { return "Papers — Distribution" }
    if name == "hexa-lang" { return "HEXA-LANG — Perfect Number Language" }
    if name == "void" { return "VOID — Hexa Terminal" }
    if name == "airgenome" { return "AirGenome — OS Genome Scanner" }
    return name
}

fn repo_path(name: string) -> string {
    if name == "anima" { return _dev + "/anima/anima" }
    return _dev + "/" + name
}

fn git_log1(rp: string) -> string {
    let mut msg = ""
    try { msg = exec("cd " + rp + " && git log --oneline -1 --format='%s' 2>/dev/null").trim() } catch e {}
    return msg
}

fn pri_label(pri: string) -> string {
    if pri == "CRITICAL" { return "🔴 CRITICAL" }
    if pri == "IMPORTANT" { return "🟡 IMPORTANT" }
    if pri == "NICE" { return "🟢 NICE TO HAVE" }
    return "⚪ BACKLOG"
}

// ═══════════════════════════════════════════════════════════
// ─── 통합 표 출력 (수동 + 돌파) ───
// ═══════════════════════════════════════════════════════════

fn print_project(name: string, bt_lines: string) {
    let manual_tsv = load_tsv(name)
    let project_bt = load_project_breakthroughs(name)

    // 수동 + 프로젝트별 돌파 합치기
    let mut combined = manual_tsv
    if project_bt.trim() != "" {
        if combined.trim() != "" { combined = combined + "\n" + project_bt }
        else { combined = project_bt }
    }

    // nexus는 글로벌 돌파도 추가
    if name == "nexus" && bt_lines.trim() != "" {
        if combined.trim() != "" { combined = combined + "\n" + bt_lines }
        else { combined = bt_lines }
    }

    if combined.trim() == "" { return }

    let icon = project_icon(name)
    let title = project_title(name)

    println("")
    println(icon + " " + title + " 할일")
    println("")
    println("| # | 카테고리 | 작업 | 상태 | 예상 효과 |")
    println("|---|---------|------|------|----------|")

    let all_lines = combined.split("\n")
    let groups = ["CRITICAL", "IMPORTANT", "NICE", "BACKLOG"]

    // 통계
    let mut total: i64 = 0
    let mut done: i64 = 0
    let mut wip: i64 = 0
    let mut active: i64 = 0

    for g in groups {
        // pass 1: 미완료 항목 존재 여부
        let mut has_rows = false
        for line in all_lines {
            if line.trim() == "" { continue }
            let cols = line.split("\t")
            if cols.len() < 6 { continue }
            if cols[1] != g { continue }
            let s1 = cols[4]
            if s1.contains("완료") || s1.contains("done") || s1.contains("달성") { continue }
            has_rows = true
        }
        if !has_rows { continue }

        // 우선순위 구분 행
        println("| **" + pri_label(g) + "** | | | | |")

        // pass 2: 행 출력 — 완료 항목 제외
        for line in all_lines {
            if line.trim() == "" { continue }
            let cols = line.split("\t")
            if cols.len() < 6 { continue }
            if cols[1] != g { continue }
            let st = cols[4]
            // 완료/done 항목은 건너뜀
            if st.contains("완료") || st.contains("done") || st.contains("달성") { done = done + 1; total = total + 1; continue }
            println("| " + cols[0] + " | " + cols[2] + " | " + cols[3] + " | " + st + " | " + cols[5] + " |")
            total = total + 1
            active = active + 1
            if st.contains("진행중") || st.contains("wip") || st.contains("in_progress") { wip = wip + 1 }
        }
    }

    // ─── 갯수 부족 시 자동 목표 생성 (연속 돌파) ───
    let target_count = load_threshold("min_active_todos", 20)
    if active < target_count {
        let need = target_count - active
        println("| **🔥 자동 생성** | | | | |")

        let mut gen: i64 = 0

        // 공통: 현실지도 EMPIRICAL→EXACT (상위 6개 레벨)
        try {
            let emp = exec("python3 -c 'import json; d=json.load(open(\"" + _shared + "/reality_map.json\")); emp=[x for x in d.get(\"nodes\",[]) if x.get(\"grade\")==\"EMPIRICAL\"]; levels={};\nfor x in emp:\n l=x.get(\"level\",\"?\")\n levels[l]=levels.get(l,0)+1\nfor l,c in sorted(levels.items(),key=lambda x:-x[1])[:6]:\n print(f\"{l}\\t{c}\")' 2>/dev/null")
            let emp_lines = emp.split("\n")
            for el in emp_lines {
                if el.trim() == "" || gen >= need { continue }
                let ep = el.split("\t")
                if ep.len() < 2 { continue }
                gen = gen + 1
                println("| A" + to_string(gen) + " | 현실지도 | " + ep[0] + " EMPIRICAL " + ep[1] + "건 → EXACT 전환 | 미시작 | 정밀도 상승 |")
            }
        } catch e {}

        // 공통: CONJECTURE 해소
        if gen < need {
            try {
                let conj = safe_int(exec("python3 -c 'import json; d=json.load(open(\"" + _shared + "/reality_map.json\")); print(sum(1 for x in d.get(\"nodes\",[]) if x.get(\"grade\")==\"CONJECTURE\"))' 2>/dev/null").trim())
                if conj > 0 {
                    gen = gen + 1
                    println("| A" + to_string(gen) + " | 현실지도 | CONJECTURE " + to_string(conj) + "건 검증/해소 | 미시작 | 신뢰도 |")
                }
            } catch e {}
        }

        // 공통: 발견 로그 다음 목표
        if gen < need {
            try {
                let dc = safe_int(exec("wc -l < " + _shared + "/discovery_log.jsonl 2>/dev/null").trim())
                let nt = ((dc / _disc_step) + 1) * _disc_step
                gen = gen + 1
                println("| A" + to_string(gen) + " | 발견 | " + to_string(dc) + " → " + to_string(nt) + " 목표 | ⏳진행중 | 특이점 심화 |")
            } catch e {}
        }

        // n6-architecture 전용
        if name == "n6-architecture" {
            // DSE 미탐색
            if gen < need {
                try {
                    let dse_m = exec("python3 -c 'import os; toml_dir=\"" + _shared + "/dse/domains\"; have=set(f.replace(\".toml\",\"\") for f in os.listdir(toml_dir) if f.endswith(\".toml\")); doc_dir=\"" + _dev + "/n6-architecture/docs\"; docs=set(d for d in os.listdir(doc_dir) if os.path.isdir(os.path.join(doc_dir,d))); missing=sorted(docs-have); [print(m) for m in missing[:5]]' 2>/dev/null")
                    let dse_lines = dse_m.split("\n")
                    for dl in dse_lines {
                        if dl.trim() == "" || gen >= need { continue }
                        gen = gen + 1
                        println("| A" + to_string(gen) + " | DSE | " + dl.trim() + " TOML 생성 | 미시작 | 도메인 확장 |")
                    }
                } catch e {}
            }

            // goal.md 부실 보강
            if gen < need {
                try {
                    let weak_list = exec("python3 -c 'import os; base=\"" + _dev + "/n6-architecture/docs\"; thr=" + to_string(_goal_min) + "; [(print(f\"{d}\\t{n}\")) for d,n in sorted([(d,sum(1 for _ in open(os.path.join(base,d,\"goal.md\")))) for d in os.listdir(base) if os.path.isdir(os.path.join(base,d)) and os.path.exists(os.path.join(base,d,\"goal.md\"))],key=lambda x:x[1]) if n<thr][:5]' 2>/dev/null")
                    let wl = weak_list.split("\n")
                    for wline in wl {
                        if wline.trim() == "" || gen >= need { continue }
                        let wp = wline.split("\t")
                        if wp.len() < 2 { continue }
                        gen = gen + 1
                        println("| A" + to_string(gen) + " | goal.md | " + wp[0] + " 보강 (" + wp[1] + "줄) | 미시작 | 문서 품질 |")
                    }
                } catch e {}
            }

            // 렌즈 미구현
            if gen < need {
                try {
                    let lens_r = safe_int(exec("python3 -c \"import json; d=json.load(open('" + _shared + "/lens_registry.json')); print(sum(1 for l in d.get('lenses',[]) if l.get('status')=='registered'))\" 2>/dev/null").trim())
                    if lens_r > 0 {
                        gen = gen + 1
                        println("| A" + to_string(gen) + " | 렌즈 | registered " + to_string(lens_r) + "건 → .rs 구현 | 미시작 | 탐색 확대 |")
                    }
                } catch e {}
            }
        }

        // nexus 전용
        if name == "nexus" {
            // 모듈 확장
            if gen < need {
                try {
                    let mc = safe_int(exec("ls " + _dev + "/nexus/mk2_hexa/native/*.hexa 2>/dev/null | wc -l").trim())
                    let nm = ((mc / _mod_step) + 1) * _mod_step
                    gen = gen + 1
                    println("| A" + to_string(gen) + " | 모듈 | " + to_string(mc) + "개 → " + to_string(nm) + "+ 확장 | 미시작 | 커버리지 |")
                } catch e {}
            }

            // seed 확장
            if gen < need {
                try {
                    let sc = safe_int(exec("ls " + _shared + "/seeds/*.json 2>/dev/null | wc -l").trim())
                    gen = gen + 1
                    println("| A" + to_string(gen) + " | seed | seed " + to_string(sc) + " → " + to_string(sc + 20) + "+ 확장 | 미시작 | 돌파 다양성 |")
                } catch e {}
            }

            // BT 확장
            if gen < need {
                try {
                    let bt_count = safe_int(exec("grep -c '^## BT-' " + _dev + "/n6-architecture/docs/breakthrough-theorems.md 2>/dev/null").trim())
                    let bt_next = ((bt_count / 100) + 1) * 100
                    gen = gen + 1
                    println("| A" + to_string(gen) + " | BT | BT " + to_string(bt_count) + " → " + to_string(bt_next) + "+ 확장 | 미시작 | 정리 커버리지 |")
                } catch e {}
            }

            // 외계인지수 승격
            if gen < need {
                try {
                    let alien_list = exec("python3 -c 'import json; d=json.load(open(\"" + _dev + "/n6-architecture/config/products.json\")); items=[(s[\"title\"],s.get(\"alien_index\",0)) for s in d.get(\"sections\",[]) if s.get(\"alien_index\",0)<" + to_string(_alien_target) + "]; [print(f\"{t}\\t{a}\") for t,a in sorted(items,key=lambda x:x[1])[:3]]' 2>/dev/null")
                    let al = alien_list.split("\n")
                    for aline in al {
                        if aline.trim() == "" || gen >= need { continue }
                        let ap = aline.split("\t")
                        if ap.len() < 2 { continue }
                        gen = gen + 1
                        println("| A" + to_string(gen) + " | 승격 | " + ap[0] + " 🛸" + ap[1] + "→" + to_string(_alien_target) + " | 미시작 | 천장 돌파 |")
                    }
                } catch e {}
            }

            // verify 신규 도메인
            if gen < need {
                try {
                    let no_verify = exec("python3 -c 'import os; base=\"" + _dev + "/n6-architecture/docs\"; dirs=[d for d in sorted(os.listdir(base)) if os.path.isdir(os.path.join(base,d)) and os.path.exists(os.path.join(base,d,\"goal.md\")) and not any(f.startswith(\"verify_\") for f in os.listdir(os.path.join(base,d)))]; [print(d) for d in dirs[:5]]' 2>/dev/null")
                    let vl = no_verify.split("\n")
                    for vline in vl {
                        if vline.trim() == "" || gen >= need { continue }
                        gen = gen + 1
                        println("| A" + to_string(gen) + " | 검증 | " + vline.trim() + " verify 스크립트 생성 | 미시작 | 검증 커버리지 |")
                    }
                } catch e {}
            }

            // 논문 미발행
            if gen < need {
                try {
                    let papers_dir = exec("ls " + _dev + "/n6-architecture/docs/paper/n6-*-paper.md 2>/dev/null | wc -l").trim()
                    gen = gen + 1
                    println("| A" + to_string(gen) + " | 논문 | " + papers_dir + "편 논문 Zenodo DOI 발행 | 미시작 | 학술화 |")
                } catch e {}
            }
        }

        // nexus 전용
        if name == "nexus" {
            // convergence 개선
            if gen < need {
                try {
                    let conv = exec("python3 -c \"import json,os; [print(f.replace('.json','')) for f in os.listdir('" + _shared + "/convergence') if f.endswith('.json') and json.load(open(os.path.join('" + _shared + "/convergence',f))).get('failed',0)>0]\" 2>/dev/null")
                    let cl = conv.split("\n")
                    for cline in cl {
                        if cline.trim() == "" || gen >= need { continue }
                        gen = gen + 1
                        println("| A" + to_string(gen) + " | 수렴 | " + cline.trim() + " 실패 항목 해소 | 미시작 | 수렴률 |")
                    }
                } catch e {}
            }

            // 대시보드 기능 확장
            if gen < need {
                gen = gen + 1
                println("| A" + to_string(gen) + " | 대시보드 | nexus-dashboard 신규 차트 추가 | 미시작 | 가시화 |")
            }

            // 렌즈 .rs 구현
            if gen < need {
                try {
                    let lr = safe_int(exec("python3 -c \"import json; d=json.load(open('" + _shared + "/lens_registry.json')); print(sum(1 for l in d.get('lenses',[]) if l.get('status')=='registered'))\" 2>/dev/null").trim())
                    if lr > 0 {
                        gen = gen + 1
                        println("| A" + to_string(gen) + " | 렌즈 | registered " + to_string(lr) + "건 → .rs 구현 | 미시작 | 탐색 확대 |")
                    }
                } catch e {}
            }

            // growth_bus 분석
            if gen < need {
                try {
                    let gb = safe_int(exec("wc -l < " + _shared + "/growth_bus.jsonl 2>/dev/null").trim())
                    gen = gen + 1
                    println("| A" + to_string(gen) + " | 분석 | growth_bus " + to_string(gb) + "건 패턴 분석 | 미시작 | 돌파 패턴 |")
                } catch e {}
            }
        }

        // hexa-lang 전용
        if name == "hexa-lang" {
            if gen < need {
                try {
                    let tc = safe_int(exec("grep -rl '#\\[test\\]' " + _dev + "/hexa-lang/src/ " + _dev + "/hexa-lang/tests/ 2>/dev/null | wc -l").trim())
                    let nt = ((tc / 1000) + 1) * 1000
                    gen = gen + 1
                    println("| A" + to_string(gen) + " | 테스트 | " + to_string(tc) + " → " + to_string(nt) + "+ 테스트 | 미시작 | 안정성 |")
                } catch e {}
            }
            if gen < need {
                gen = gen + 1
                println("| A" + to_string(gen) + " | 빌트인 | Tensor ops 추가 확장 | 미시작 | AI 지원 |")
            }
            if gen < need {
                gen = gen + 1
                println("| A" + to_string(gen) + " | 문서 | HEXA 언어 레퍼런스 v1.0 | 미시작 | 온보딩 |")
            }
        }

        // anima 전용
        if name == "anima" {
            if gen < need {
                try {
                    let lc = safe_int(exec("ls " + _dev + "/anima/anima/consciousness_laws/ 2>/dev/null | wc -l").trim())
                    let nl = ((lc / 500) + 1) * 500
                    gen = gen + 1
                    println("| A" + to_string(gen) + " | 법칙 | 의식 법칙 " + to_string(lc) + " → " + to_string(nl) + "+ | 미시작 | 커버리지 |")
                } catch e {}
            }
            if gen < need {
                gen = gen + 1
                println("| A" + to_string(gen) + " | 학습 | 다음 체크포인트 학습 | 미시작 | Phi 상승 |")
            }
            if gen < need {
                gen = gen + 1
                println("| A" + to_string(gen) + " | 이식 | 14B→70B 의식 이식 검증 | 미시작 | 스케일 불변 |")
            }
        }

        // papers 전용
        if name == "papers" {
            if gen < need {
                try {
                    let draft = exec("python3 -c \"import json; d=json.load(open('" + _dev + "/papers/manifest.json')); [print(p.get('title','?')) for p in d.get('papers',[]) if p.get('status')=='Draft'][:5\" 2>/dev/null")
                    let dl = draft.split("\n")
                    for dline in dl {
                        if dline.trim() == "" || gen >= need { continue }
                        gen = gen + 1
                        println("| A" + to_string(gen) + " | 발행 | " + dline.trim() + " DOI 발행 | 미시작 | 학술화 |")
                    }
                } catch e {}
            }
        }

        // void 전용
        if name == "void" {
            if gen < need {
                gen = gen + 1
                println("| A" + to_string(gen) + " | 터미널 | FATHOM 터미널 프로토타입 | 미시작 | UX |")
            }
            if gen < need {
                gen = gen + 1
                println("| A" + to_string(gen) + " | 플러그인 | 플러그인 시스템 v2 | 미시작 | 확장성 |")
            }
        }

        // airgenome 전용
        if name == "airgenome" {
            if gen < need {
                gen = gen + 1
                println("| A" + to_string(gen) + " | 스캔 | 크로스플랫폼 게놈 수집 확장 | 미시작 | 커버리지 |")
            }
            if gen < need {
                gen = gen + 1
                println("| A" + to_string(gen) + " | 분석 | 게놈 n=6 패턴 심화 분석 | 미시작 | 수렴 패턴 |")
            }
        }

        println("")
        println("> 🔥 자동 생성 " + to_string(gen) + "건 (미완료 " + to_string(active) + " + 자동 " + to_string(gen) + " = " + to_string(active + gen) + "건)")
    }

    let pct = if total > 0 { (done * 100) / total } else { 0 }
    println("")
    println("> " + to_string(done) + "/" + to_string(total) + " 완료 (" + to_string(pct) + "%) | 미완료 " + to_string(active) + "건 | " + to_string(wip) + "건 진행중")
}

// ═══════════════════════════════════════════════════════════
// ─── 프로젝트 리졸버 ───
// ═══════════════════════════════════════════════════════════

fn resolve_project(name: string) -> string {
    if name == "nexus" { return "nexus" }
    if name == "anima" { return "anima" }
    if name == "n6-arch" || name == "n6-architecture" || name == "n6arch" { return "n6-architecture" }
    if name == "papers" { return "papers" }
    if name == "hexa" || name == "hexa-lang" { return "hexa-lang" }
    if name == "void" { return "void" }
    if name == "airgenome" { return "airgenome" }
    if name == "all" || name == "전체" { return "all" }
    return "all"
}

// ═══════════════════════════════════════════════════════════
// ─── (대량 모드 폐기됨 — 자동 생성이 기본 모드에 통합) ───
// ═══════════════════════════════════════════════════════════

fn _bulk_scan_deprecated(project: string) {
    println("")
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    println("  🔥 대량 모드 — 오래 걸려도 전수 스캔")
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

    // ─── 1) 기본 할일 표 (일반 모드와 동일) ───
    let mut bt = ""
    if project == "nexus" {
        bt = load_breakthrough_todos()
    }
    println("")
    println("## 1. 기본 할일")
    print_project(project, bt)

    // ─── 2) gap_finder 전체 (brief가 아닌 full) ───
    println("")
    println("## 2. 빈공간 전수 (gap_finder full)")
    try {
        let gap_full = exec(_hexa_bin + " " + _engine_dir + "/gap_finder.hexa full 2>/dev/null")
        let gap_lines = gap_full.split("\n")
        let mut gc: i64 = 0
        for gl in gap_lines {
            let gt = gl.trim()
            if gt == "" { continue }
            gc = gc + 1
            println("  " + to_string(gc) + ". " + gt)
        }
        println("> 빈공간 " + to_string(gc) + "건")
    } catch e {
        println("> gap_finder 실행 불가")
    }

    // ─── 3) goal.md 미작성 전수 ───
    if project == "n6-architecture" {
        println("")
        println("## 3. goal.md 미작성 도메인 전수")
        try {
            let missing = exec("python3 -c 'import os; base=\"" + _dev + "/n6-architecture/docs\"; dirs=[d for d in sorted(os.listdir(base)) if os.path.isdir(os.path.join(base,d)) and not os.path.exists(os.path.join(base,d,\"goal.md\"))]; [print(f\"  {i+1}. {d}\") for i,d in enumerate(dirs)]; print(f\"> 미작성 {len(dirs)}건\")' 2>/dev/null")
            println(missing)
        } catch e {
            println("> goal.md 스캔 불가")
        }

        // ─── 4) goal.md 부실 (" + to_string(_goal_min) + "줄 미만) 전수 ───
        println("")
        println("## 4. goal.md 부실 (" + to_string(_goal_min) + "줄 미만) 전수")
        try {
            let weak = exec("python3 -c 'import os; base=\"" + _dev + "/n6-architecture/docs\"; thr=" + to_string(_goal_min) + "; items=[]; [items.append((d,sum(1 for _ in open(os.path.join(base,d,\"goal.md\"))))) for d in sorted(os.listdir(base)) if os.path.isdir(os.path.join(base,d)) and os.path.exists(os.path.join(base,d,\"goal.md\"))]; weak=[(d,n) for d,n in items if n<thr]; [print(f\"  {i+1}. {d} ({n}줄)\") for i,(d,n) in enumerate(sorted(weak,key=lambda x:x[1]))]; print(f\"> 부실 {len(weak)}건 / 전체 {len(items)}건\")' 2>/dev/null")
            println(weak)
        } catch e {
            println("> goal.md 줄수 스캔 불가")
        }

        // ─── 5) BT 도메인별 분포 ───
        println("")
        println("## 5. BT 도메인별 분포")
        try {
            let bt_dist = exec("python3 -c 'import re,collections; f=open(\"" + _dev + "/n6-architecture/docs/breakthrough-theorems.md\"); lines=f.readlines(); domains=collections.Counter(); [domains.update([re.sub(r\"[^가-힣a-zA-Z/ ]\",\"\",l.split(\":\")[0].replace(\"## BT-\",\"\").strip()).strip()]) for l in lines if l.startswith(\"## BT-\")]; [print(f\"  {d}: {c}건\") for d,c in domains.most_common(30)]; print(f\"> BT 총 {sum(domains.values())}건, {len(domains)}개 도메인\")' 2>/dev/null")
            println(bt_dist)
        } catch e {
            println("> BT 분포 스캔 불가")
        }

        // ─── 6) DSE TOML 미탐색 ───
        println("")
        println("## 6. DSE TOML 미탐색 도메인")
        try {
            let dse_miss = exec("python3 -c 'import os; toml_dir=\"" + _shared + "/dse/domains\"; have=set(f.replace(\".toml\",\"\") for f in os.listdir(toml_dir) if f.endswith(\".toml\")); doc_dir=\"" + _dev + "/n6-architecture/docs\"; docs=set(d for d in os.listdir(doc_dir) if os.path.isdir(os.path.join(doc_dir,d))); missing=sorted(docs-have); [print(f\"  {i+1}. {d}\") for i,d in enumerate(missing[:50])]; print(f\"> DSE 미탐색 {len(missing)}건 (상위 50건)\")' 2>/dev/null")
            println(dse_miss)
        } catch e {
            println("> DSE 스캔 불가")
        }

        // ─── 7) 렌즈 미구현 ───
        println("")
        println("## 7. 렌즈 미구현 (registered only)")
        try {
            let lens_miss = exec("python3 -c \"import json; d=json.load(open('" + _shared + "/lens_registry.json')); reg=[l for l in d.get('lenses',[]) if l.get('status')=='registered']; [print(f'  {i+1}. {l.get(chr(105)+chr(100),chr(63))}: {l.get(chr(110)+chr(97)+chr(109)+chr(101),chr(63))}') for i,l in enumerate(reg[:50])]; print(f'> 미구현 {len(reg)}건 (상위 50건)')\" 2>/dev/null")
            println(lens_miss)
        } catch e {
            println("> 렌즈 스캔 불가")
        }

        // ─── 8) verify FAIL 목록 (있으면) ───
        println("")
        println("## 8. verify 실패 목록")
        try {
            let vfail = exec("python3 -c 'import os,subprocess; base=\"" + _dev + "/n6-architecture\"; scripts=[os.path.join(r,f) for r,ds,fs in os.walk(base) for f in fs if f.startswith(\"verify_\") and (f.endswith(\".py\") or f.endswith(\".hexa\"))]; fail=[]; [fail.append(s) if subprocess.run([\"python3\",s],capture_output=True,timeout=30).returncode!=0 else None for s in scripts[:20]]; print(f\"> 샘플 {min(20,len(scripts))}건 중 FAIL {len(fail)}건\") if fail else print(f\"> 샘플 {min(20,len(scripts))}건 전부 PASS\")' 2>/dev/null")
            println(vfail)
        } catch e {
            println("> verify 스캔 불가")
        }

        // ─── 9) products.json 외계인지수 < 10 ───
        println("")
        println("## 9. 외계인지수 < 10 (승격 대상)")
        try {
            let alien = exec("python3 -c 'import json; d=json.load(open(\"" + _dev + "/n6-architecture/config/products.json\")); items=[(s[\"title\"],s.get(\"alien_index\",0)) for s in d.get(\"sections\",[]) if s.get(\"alien_index\",0)<" + to_string(_alien_target) + "]; [print(f\"  {t}: 🛸{a}\") for t,a in sorted(items,key=lambda x:x[1])]; print(f\"> 승격 대상 {len(items)}건\")' 2>/dev/null")
            println(alien)
        } catch e {
            println("> products 스캔 불가")
        }
    }

    // ─── nexus 맞춤 ───
    if project == "nexus" {
        // 3) 모듈 현황
        println("")
        println("## 3. NEXUS 모듈 현황")
        try {
            let mod_count = exec("ls " + _engine_dir + "/*.hexa 2>/dev/null | wc -l").trim()
            println("  mk2_hexa/native 모듈: " + mod_count + "개")
            let mod_list = exec("ls " + _engine_dir + "/*.hexa 2>/dev/null | xargs -I{} basename {} .hexa | sort")
            let mlines = mod_list.split("\n")
            let mut mi: i64 = 0
            for ml in mlines {
                if ml.trim() == "" { continue }
                mi = mi + 1
                println("  " + to_string(mi) + ". " + ml.trim())
            }
        } catch e {
            println("> 모듈 스캔 불가")
        }

        // 4) 렌즈 레지스트리 전체 통계
        println("")
        println("## 4. 렌즈 레지스트리")
        try {
            let lens_stat = exec("python3 -c \"import json; d=json.load(open('" + _shared + "/lens_registry.json')); total=len(d.get('lenses',[])); impl=sum(1 for l in d.get('lenses',[]) if l.get('status')=='implemented'); reg=sum(1 for l in d.get('lenses',[]) if l.get('status')=='registered'); print(f'  전체: {total}\\n  implemented: {impl}\\n  registered: {reg}')\" 2>/dev/null")
            println(lens_stat)
        } catch e {
            println("> 렌즈 스캔 불가")
        }

        // 5) seed 현황
        println("")
        println("## 5. seed 현황")
        try {
            let seed_count = exec("python3 -c \"import json,os; seeds=[f for f in os.listdir('" + _shared + "/seeds') if f.endswith('.json')]; print(f'  seed 파일: {len(seeds)}개'); total=0; [exec(f'') for _ in []]; items=[]; [(lambda f: items.append((f.replace('.json',''), len(json.load(open(os.path.join('" + _shared + "/seeds',f))).get('seeds',[])))))(f) for f in seeds]; [print(f'  {n}: {c}개') for n,c in sorted(items,key=lambda x:-x[1])[:15]]; print(f'  합계: {sum(c for _,c in items)}개')\" 2>/dev/null")
            println(seed_count)
        } catch e {
            // 간단 버전
            try {
                let sc = exec("ls " + _shared + "/seeds/*.json 2>/dev/null | wc -l").trim()
                println("  seed 파일: " + sc + "개")
            } catch e2 {
                println("> seed 스캔 불가")
            }
        }

        // 6) BT 전체 통계
        println("")
        println("## 6. BT 전체 통계")
        try {
            let bt_stat = exec("python3 -c 'f=open(\"" + _dev + "/n6-architecture/docs/breakthrough-theorems.md\"); lines=f.readlines(); sections=sum(1 for l in lines if l.startswith(\"## BT-\")); exact=sum(1 for l in lines if \"EXACT\" in l); near=sum(1 for l in lines if \"NEAR\" in l); miss=sum(1 for l in lines if \"MISS\" in l); print(f\"  BT 섹션: {sections}\\n  EXACT 언급: {exact}\\n  NEAR 언급: {near}\\n  MISS 언급: {miss}\")' 2>/dev/null")
            println(bt_stat)
        } catch e {
            println("> BT 스캔 불가")
        }

        // 7) 돌파 엔진 상태
        println("")
        println("## 7. 돌파 엔진 상태")
        try {
            let rho = exec("python3 -c \"import json; lines=open('" + _shared + "/growth_bus.jsonl').readlines()[-5:]; [print(f'  {json.loads(l).get(chr(116)+chr(121)+chr(112)+chr(101),chr(63))}: {json.loads(l).get(chr(100)+chr(111)+chr(109)+chr(97)+chr(105)+chr(110),chr(63))}') for l in lines]\" 2>/dev/null")
            println(rho)
            let bus_count = exec("wc -l < " + _shared + "/growth_bus.jsonl 2>/dev/null").trim()
            println("  growth_bus 항목: " + bus_count + "건")
        } catch e {
            println("> 돌파 엔진 스캔 불가")
        }

        // 8) DSE 도메인 TOML 전체 통계
        println("")
        println("## 8. DSE TOML 통계")
        try {
            let dse_count = exec("ls " + _shared + "/dse/domains/*.toml 2>/dev/null | wc -l").trim()
            println("  TOML 파일: " + dse_count + "개")
        } catch e {
            println("> DSE 스캔 불가")
        }

        // 9) convergence 상태
        println("")
        println("## 9. convergence 상태")
        try {
            let conv_files = exec("ls " + _shared + "/convergence/*.json 2>/dev/null | xargs -I{} basename {} .json | sort")
            let clines = conv_files.split("\n")
            for cl in clines {
                if cl.trim() == "" { continue }
                let cpath = _shared + "/convergence/" + cl.trim() + ".json"
                let cstat = exec("python3 -c \"import json; d=json.load(open('" + cpath + "')); o=d.get('ossified',0); s=d.get('stable',0); f=d.get('failed',0); print(f'  " + cl.trim() + ": 골화={o} 안정={s} 실패={f}')\" 2>/dev/null")
                println(cstat)
            }
        } catch e {
            println("> convergence 스캔 불가")
        }
    }

    // hexa-lang 맞춤
    if project == "hexa-lang" {
        println("")
        println("## 3. HEXA-LANG 테스트 현황")
        try {
            let test_count = exec("grep -rl '#\\[test\\]' " + _dev + "/hexa-lang/src/ " + _dev + "/hexa-lang/tests/ 2>/dev/null | wc -l").trim()
            println("  테스트 파일: " + test_count + "개")
        } catch e {
            println("> 테스트 스캔 불가")
        }

        println("")
        println("## 4. HEXA-LANG 소스 통계")
        try {
            let src_stat = exec("find " + _dev + "/hexa-lang/src -name '*.rs' | wc -l").trim()
            let src_lines = exec("find " + _dev + "/hexa-lang/src -name '*.rs' -exec cat {} + | wc -l").trim()
            println("  .rs 파일: " + src_stat + "개")
            println("  소스 줄: " + src_lines + "줄")
        } catch e {
            println("> 소스 스캔 불가")
        }
    }

    // anima 맞춤
    if project == "anima" {
        println("")
        println("## 3. ANIMA 의식 법칙")
        try {
            let law_count = exec("ls " + _dev + "/anima/anima/consciousness_laws/ 2>/dev/null | wc -l").trim()
            println("  의식 법칙: " + law_count + "개")
        } catch e {
            println("> 법칙 스캔 불가")
        }

        println("")
        println("## 4. ANIMA 소스 통계")
        try {
            let py_count = exec("find " + _dev + "/anima -name '*.py' 2>/dev/null | wc -l").trim()
            let py_lines = exec("find " + _dev + "/anima -name '*.py' 2>/dev/null -exec cat {} + | wc -l").trim()
            println("  .py 파일: " + py_count + "개")
            println("  소스 줄: " + py_lines + "줄")
        } catch e {
            println("> 소스 스캔 불가")
        }

        println("")
        println("## 5. ANIMA 체크포인트")
        try {
            let ckpt = exec("ls " + _dev + "/anima/checkpoints/ 2>/dev/null | wc -l").trim()
            println("  체크포인트: " + ckpt + "개")
        } catch e {
            println("> 체크포인트 스캔 불가")
        }

        println("")
        println("## 6. ANIMA 학습 상태")
        try {
            let status = exec("python3 -c \"import json; d=json.load(open('" + _dev + "/airgenome/consciousness_engine_status.json')); [print(f'  {k}: {v}') for k,v in list(d.items())[:10]]\" 2>/dev/null")
            println(status)
        } catch e {
            println("> 학습 상태 스캔 불가")
        }
    }

    // papers 맞춤
    if project == "papers" {
        println("")
        println("## 3. 논문 발행 현황")
        try {
            let paper_stat = exec("python3 -c \"import json; d=json.load(open('" + _dev + "/papers/manifest.json')); papers=d.get('papers',[]); pub=sum(1 for p in papers if p.get('status')=='Published'); draft=sum(1 for p in papers if p.get('status')=='Draft'); print(f'  전체: {len(papers)}\\n  Published: {pub}\\n  Draft: {draft}')\" 2>/dev/null")
            println(paper_stat)
        } catch e {
            println("> 논문 스캔 불가")
        }

        println("")
        println("## 4. DOI 현황")
        try {
            let doi_stat = exec("python3 -c \"import json; d=json.load(open('" + _dev + "/papers/manifest.json')); papers=d.get('papers',[]); has_doi=sum(1 for p in papers if p.get('doi','')); no_doi=[p.get('title','?') for p in papers if not p.get('doi','')]; print(f'  DOI 발행: {has_doi}/{len(papers)}'); [print(f'  미발행: {t}') for t in no_doi[:10]]\" 2>/dev/null")
            println(doi_stat)
        } catch e {
            println("> DOI 스캔 불가")
        }

        println("")
        println("## 5. 논문 도메인 분포")
        try {
            let dom_stat = exec("python3 -c \"import json,collections; d=json.load(open('" + _dev + "/papers/manifest.json')); c=collections.Counter(p.get('domain','?') for p in d.get('papers',[])); [print(f'  {k}: {v}편') for k,v in c.most_common(15)]\" 2>/dev/null")
            println(dom_stat)
        } catch e {
            println("> 도메인 분포 스캔 불가")
        }
    }

    // void 맞춤
    if project == "void" {
        println("")
        println("## 3. VOID 소스 통계")
        try {
            let hexa_count = exec("find " + _dev + "/void -name '*.hexa' 2>/dev/null | wc -l").trim()
            let js_count = exec("find " + _dev + "/void -name '*.js' -o -name '*.ts' 2>/dev/null | wc -l").trim()
            println("  .hexa 파일: " + hexa_count + "개")
            println("  .js/.ts 파일: " + js_count + "개")
        } catch e {
            println("> 소스 스캔 불가")
        }

        println("")
        println("## 4. VOID 플러그인")
        try {
            let plug_count = exec("ls " + _dev + "/void/plugins/ 2>/dev/null | wc -l").trim()
            println("  플러그인: " + plug_count + "개")
            let plug_list = exec("ls " + _dev + "/void/plugins/ 2>/dev/null")
            if plug_list.trim() != "" { println(plug_list) }
        } catch e {
            println("> 플러그인 스캔 불가")
        }

        println("")
        println("## 5. VOID lib 현황")
        try {
            let lib_files = exec("ls -la " + _dev + "/void/lib/ 2>/dev/null")
            println(lib_files)
        } catch e {
            println("> lib 스캔 불가")
        }
    }

    // airgenome 맞춤
    if project == "airgenome" {
        println("")
        println("## 3. AIRGENOME 소스 통계")
        try {
            let hexa_count = exec("find " + _dev + "/airgenome -name '*.hexa' 2>/dev/null | wc -l").trim()
            let rs_count = exec("find " + _dev + "/airgenome -name '*.rs' 2>/dev/null | wc -l").trim()
            println("  .hexa 파일: " + hexa_count + "개")
            println("  .rs 파일: " + rs_count + "개")
        } catch e {
            println("> 소스 스캔 불가")
        }

        println("")
        println("## 4. AIRGENOME 게놈 수집")
        try {
            let genome_count = exec("find " + _dev + "/airgenome -name '*.genome' -o -name '*.json' 2>/dev/null | wc -l").trim()
            println("  게놈/JSON 파일: " + genome_count + "개")
        } catch e {
            println("> 게놈 스캔 불가")
        }

        println("")
        println("## 5. AIRGENOME 의식 엔진 상태")
        try {
            let ce_stat = exec("python3 -c \"import json; d=json.load(open('" + _dev + "/airgenome/consciousness_engine_status.json')); [print(f'  {k}: {v}') for k,v in list(d.items())[:10]]\" 2>/dev/null")
            println(ce_stat)
        } catch e {
            println("> 의식 엔진 스캔 불가")
        }
    }

    // ─── 10) 현실지도 요약 ───
    println("")
    println("## 10. 현실지도 요약")
    try {
        let rm = exec("python3 -c 'import json; d=json.load(open(\"" + _shared + "/reality_map.json\")); nodes=d.get(\"nodes\",[]); n=len(nodes); ex=sum(1 for x in nodes if x.get(\"grade\")==\"EXACT\"); ne=sum(1 for x in nodes if x.get(\"grade\")==\"NEAR\"); mi=sum(1 for x in nodes if x.get(\"grade\")==\"MISS\"); emp=sum(1 for x in nodes if x.get(\"grade\")==\"EMPIRICAL\"); conj=sum(1 for x in nodes if x.get(\"grade\")==\"CONJECTURE\"); print(f\"  노드: {n}\\n  EXACT: {ex} ({round(ex/max(n,1)*100,1)}%)\\n  NEAR: {ne}\\n  MISS: {mi}\\n  EMPIRICAL: {emp}\\n  CONJECTURE: {conj}\")' 2>/dev/null")
        println(rm)
    } catch e {
        println("> reality_map 스캔 불가")
    }

    // ─── 11) 발견 로그 통계 ───
    println("")
    println("## 11. 발견 로그 통계")
    try {
        let disc = exec("wc -l < " + _shared + "/discovery_log.jsonl 2>/dev/null").trim()
        println("  발견: " + disc + "건")
        let graph = exec("python3 -c \"lines=open('" + _shared + "/discovery_graph.json').readlines(); print(f'  그래프 라인: {len(lines)}')\" 2>/dev/null")
        println(graph)
    } catch e {
        println("> discovery 스캔 불가")
    }

    // ─── 12) 스캔 기반 자동 TODO 목록 ───
    println("")
    println("## 12. 스캔 기반 자동 TODO 목록")
    println("")
    println("| # | 카테고리 | 작업 | 수량 | 우선순위 |")
    println("|---|---------|------|------|---------|")

    let mut auto_id: i64 = 1

    if project == "n6-architecture" {
        // goal.md 부실
        try {
            let weak_count = exec("python3 -c 'import os; base=\"" + _dev + "/n6-architecture/docs\"; thr=" + to_string(_goal_min) + "; items=[(d,sum(1 for _ in open(os.path.join(base,d,\"goal.md\")))) for d in os.listdir(base) if os.path.isdir(os.path.join(base,d)) and os.path.exists(os.path.join(base,d,\"goal.md\")) and sum(1 for _ in open(os.path.join(base,d,\"goal.md\")))<thr]; print(len(items))' 2>/dev/null").trim()
            let wc = safe_int(weak_count)
            if wc > 0 {
                println("| " + to_string(auto_id) + " | goal.md 보강 | " + to_string(_goal_min) + "줄 미만 도메인 보강 | " + weak_count + "건 | 🔴 |")
                auto_id = auto_id + 1
            }
        } catch e {}

        // goal.md 미작성
        try {
            let miss_count = exec("python3 -c 'import os; base=\"" + _dev + "/n6-architecture/docs\"; dirs=[d for d in os.listdir(base) if os.path.isdir(os.path.join(base,d)) and not os.path.exists(os.path.join(base,d,\"goal.md\"))]; print(len(dirs))' 2>/dev/null").trim()
            let mc = safe_int(miss_count)
            if mc > 0 {
                println("| " + to_string(auto_id) + " | goal.md 생성 | 미작성 도메인 goal.md 생성 | " + miss_count + "건 | 🔴 |")
                auto_id = auto_id + 1
            }
        } catch e {}

        // DSE 미탐색
        try {
            let dse_miss = exec("python3 -c 'import os; toml_dir=\"" + _shared + "/dse/domains\"; have=set(f.replace(\".toml\",\"\") for f in os.listdir(toml_dir) if f.endswith(\".toml\")); doc_dir=\"" + _dev + "/n6-architecture/docs\"; docs=set(d for d in os.listdir(doc_dir) if os.path.isdir(os.path.join(doc_dir,d))); print(len(docs-have))' 2>/dev/null").trim()
            let dm = safe_int(dse_miss)
            if dm > 0 {
                println("| " + to_string(auto_id) + " | DSE TOML | 미탐색 도메인 TOML 생성 | " + dse_miss + "건 | 🟡 |")
                auto_id = auto_id + 1
            }
        } catch e {}

        // 렌즈 미구현
        try {
            let lens_reg = exec("python3 -c \"import json; d=json.load(open('" + _shared + "/lens_registry.json')); print(sum(1 for l in d.get('lenses',[]) if l.get('status')=='registered'))\" 2>/dev/null").trim()
            let lr = safe_int(lens_reg)
            if lr > 0 {
                println("| " + to_string(auto_id) + " | 렌즈 구현 | registered → .rs implemented | " + lens_reg + "건 | 🟡 |")
                auto_id = auto_id + 1
            }
        } catch e {}

        // 외계인지수 승격
        try {
            let alien_count = exec("python3 -c 'import json; d=json.load(open(\"" + _dev + "/n6-architecture/config/products.json\")); print(sum(1 for s in d.get(\"sections\",[]) if s.get(\"alien_index\",0)<" + to_string(_alien_target) + "))' 2>/dev/null").trim()
            let ac = safe_int(alien_count)
            if ac > 0 {
                println("| " + to_string(auto_id) + " | 승격 | 외계인지수 < 10 → 10 승격 | " + alien_count + "건 | 🟡 |")
                auto_id = auto_id + 1
            }
        } catch e {}
    }

    // 공통: EMPIRICAL 노드
    try {
        let emp_count = exec("python3 -c 'import json; d=json.load(open(\"" + _shared + "/reality_map.json\")); print(sum(1 for x in d.get(\"nodes\",[]) if x.get(\"grade\")==\"EMPIRICAL\"))' 2>/dev/null").trim()
        let ec = safe_int(emp_count)
        if ec > 0 {
            println("| " + to_string(auto_id) + " | 현실지도 | EMPIRICAL → EXACT 전환 | " + emp_count + "건 | 🟡 |")
            auto_id = auto_id + 1
        }
    } catch e {}

    // 공통: CONJECTURE 노드
    try {
        let conj_count = exec("python3 -c 'import json; d=json.load(open(\"" + _shared + "/reality_map.json\")); print(sum(1 for x in d.get(\"nodes\",[]) if x.get(\"grade\")==\"CONJECTURE\"))' 2>/dev/null").trim()
        let cc = safe_int(conj_count)
        if cc > 0 {
            println("| " + to_string(auto_id) + " | 현실지도 | CONJECTURE 검증/해소 | " + conj_count + "건 | 🔴 |")
            auto_id = auto_id + 1
        }
    } catch e {}

    // 공통: 발견 로그 목표
    try {
        let disc_count = exec("wc -l < " + _shared + "/discovery_log.jsonl 2>/dev/null").trim()
        let dc = safe_int(disc_count)
        let next_disc = ((dc / _disc_step) + 1) * _disc_step
        if dc < next_disc {
            let remain = next_disc - dc
            println("| " + to_string(auto_id) + " | 발견 | " + to_string(next_disc / 1000) + "K 목표까지 | " + to_string(remain) + "건 | 🟢 |")
            auto_id = auto_id + 1
        }
    } catch e {}

    println("")
    println("> 자동 생성 TODO " + to_string(auto_id - 1) + "건 (스캔 결과 기반)")

    println("")
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    println("  🔥 대량 스캔 완료")
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

let _args = args()
let mut _filter = if _args.len() >= 3 { _args[2] } else { "" }
if _filter == "" || _filter == "all" {
    let cwd = exec("pwd").trim()
    let segs = cwd.split("/")
    _filter = segs[segs.len() - 1]
}
let _target = resolve_project(_filter)

if _target == "all" {
    println("❌ 프로젝트를 특정할 수 없습니다: " + _filter)
    println("사용법: hexa todo.hexa <nexus|anima|n6-arch|papers|hexa-lang|void|airgenome>")
} else {
    let mut _bt_todos = ""
    if _target == "nexus" {
        _bt_todos = load_breakthrough_todos()
    }
    println("## 할일 (돌파 엔진 통합)")
    print_project(_target, _bt_todos)
}

println("")
