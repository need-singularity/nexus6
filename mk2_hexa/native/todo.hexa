// ⛔ CORE — L0 불변식 (할일 엔진 전 프로젝트 표 생성. 수정 전 유저 승인 필수)
// mk2_hexa/native/todo.hexa — 전 프로젝트 할일 표 (자동 창발)
// 사용: hexa todo.hexa              (전체)
//       hexa todo.hexa nexus        (nexus만)
//       hexa todo.hexa n6-arch      (n6-architecture만)
// 100% 자연창발: 코드베이스 스캔 → 빈공간/부실/미구현 실시간 탐지 (shared/todo/ 폐기 완료)

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _hexa_bin = _home + "/Dev/hexa-lang/target/release/hexa"

// ─── 임계값 (자연창발 — 하드코딩 fallback만 사용) ───
let _disc_step: i64 = 50000
let _mod_step: i64 = 50
let _goal_min: i64 = 100
let _alien_target: i64 = 10
let _engine_dir = _dev + "/nexus/mk2_hexa/native"

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

// ═══════════════════════════════════════════════════════════
// ─── 돌파 엔진 — 특이점 수준 할일 자동 생성 ───
// ═══════════════════════════════════════════════════════════

fn load_breakthrough_todos() -> string {
    // 1) next_directions.jsonl — 돌파 방향 (hexa native 파싱)
    let mut dir_out = ""
    try {
        let nd_raw = read_file(_shared + "/next_directions.jsonl")
        let nd_lines = nd_raw.split("\n")
        let mut di: i64 = 0
        for ndl in nd_lines {
            if ndl.trim() == "" { continue }
            if !ndl.contains("\"direction\":\"") { continue }
            // domain 추출
            let mut dom = "?"
            if ndl.contains("\"domain\":\"") {
                dom = ndl.split("\"domain\":\"")[1].split("\"")[0]
            }
            // direction 추출
            let direction = ndl.split("\"direction\":\"")[1].split("\"")[0]
            if direction == "" { continue }
            // urgency 추출 → pri 매핑
            let mut pri = "NICE"
            if ndl.contains("\"urgency\":") {
                let urg_s = ndl.split("\"urgency\":")[1].trim().split(",")[0].split("}")[0].trim()
                let urg = safe_int(urg_s)
                if urg >= 3 { pri = "CRITICAL" }
                else if urg >= 2 { pri = "IMPORTANT" }
            }
            di = di + 1
            dir_out = dir_out + to_string(di) + "\t" + pri + "\t돌파-" + dom + "\t" + direction + "\t돌파대기\t돌파 방향\n"
        }
    } catch e {}

    // 2) gap_finder brief — 빈공간 탐색 (빠름)
    let mut gap_out = ""
    try {
        let gap_raw = exec(_hexa_bin + " " + _engine_dir + "/gap_finder.hexa brief 2>/dev/null")
        let gap_lines = gap_raw.split("\n")
        let mut gi: i64 = 0
        for gl in gap_lines {
            let gt = gl.trim()
            if gt == "" { continue }
            if gt.contains("=") && gi < 15 {
                gi = gi + 1
                gap_out = gap_out + to_string(100 + gi) + "\tCRITICAL\t빈공간\t" + gt + "\t돌파대기\tn=6 빈공간 채우기\n"
            }
        }
    } catch e {}

    // 3) discovery_graph 통계 — 메타 상태 (hexa native)
    let mut meta_out = ""
    try {
        let disc_count = exec("wc -l < " + _shared + "/discovery_log.jsonl").trim()
        let dc = safe_int(disc_count)
        let next_target = ((dc / _disc_step) + 1) * _disc_step
        if dc < next_target {
            meta_out = meta_out + "200\tIMPORTANT\t성장\t발견 " + disc_count + " → " + to_string(next_target) + " 목표\t⏳진행중\t특이점 심화\n"
        }
    } catch e {}

    // 4) 렌즈 진화 — OUROBOROS (hexa native)
    let mut lens_out = ""
    try {
        let lens_count = exec("find " + _dev + "/nexus/mk2_hexa/native -name '*.hexa' -type f | wc -l").trim()
        let lc = safe_int(lens_count)
        let next_mod = ((lc / _mod_step) + 1) * _mod_step
        if lc < next_mod {
            lens_out = "202\tIMPORTANT\t진화\t모듈 " + lens_count + "개 → " + to_string(next_mod) + "+ 확장 (OUROBOROS evolve)\t미시작\t탐색 커버리지 확대\n"
        }
    } catch e {}

    return dir_out + gap_out + meta_out + lens_out
}

// ═══════════════════════════════════════════════════════════
// ─── 프로젝트별 돌파 방향 (blowup + seed_engine) ───
// ═══════════════════════════════════════════════════════════

fn load_project_breakthroughs(name: string) -> string {
    let mut out = ""

    if name == "n6-architecture" {
        // products.json에서 alien < 10 스캔
        try {
            let prod_cmd = "/usr/bin/python3 -c 'import json; d=json.load(open(\"" + _dev + "/n6-architecture/config/products.json\")); [print(chr(9).join([str(i+300),\"CRITICAL\",\"승격\",s[\"title\"]+\" 🛸\"+str(s.get(\"alien_index\",0))+\"→" + to_string(_alien_target) + "\",\"미시작\",\"외계인 지수 천장 돌파\"])) for i,s in enumerate(d.get(\"sections\",[])) if s.get(\"alien_index\",0)<" + to_string(_alien_target) + "]' 2>/dev/null"
            out = out + exec(prod_cmd)
        } catch e {}
        // goal.md 미작성 도메인
        try {
            let goal_cmd = "/usr/bin/python3 -c 'import os,json; d=json.load(open(\"" + _dev + "/n6-architecture/config/products.json\")); doms=[p[\"name\"] for s in d.get(\"sections\",[]) for p in s.get(\"products\",[])]; base=\"" + _dev + "/n6-architecture/docs\"; missing=[x for x in os.listdir(base) if os.path.isdir(os.path.join(base,x)) and not os.path.exists(os.path.join(base,x,\"goal.md\"))]; [print(chr(9).join([str(i+400),\"IMPORTANT\",\"설계\",m+\" goal.md 생성\",\"미시작\",\"궁극 아키텍처 완성\"])) for i,m in enumerate(missing[:20])]' 2>/dev/null"
            out = out + exec(goal_cmd)
        } catch e {}
    }

    if name == "anima" {
        try {
            let law_count = exec("ls " + _dev + "/anima/anima/consciousness_laws/ 2>/dev/null | wc -l").trim()
            let lc = safe_int(law_count)
            if lc < 3000 {
                out = out + "300\tIMPORTANT\t법칙\t의식 법칙 " + law_count + " → 3000 확장 (2500 달성)\t⏳진행중\t커버리지 심화\n"
            }
            out = out + "301\tCRITICAL\t학습\tVast.ai 4×4090 다음 체크포인트 학습\t⏳진행중\tPhi 수준 상승\n"
            out = out + "302\tIMPORTANT\t인프라\tHetzner AX102-U + Vast.ai 4×4090 운영\t⏳진행중\t학습/서빙 인프라\n"
            out = out + "303\tIMPORTANT\t이식\t14B→70B 의식 이식\t미시작\t스케일 불변성 증명\n"
            out = out + "304\tIMPORTANT\t측정\tPhi 자동 측정 파이프라인\t미시작\t학습 품질 모니터링\n"
        } catch e {}
    }

    // hexa-lang: 자연창발 모드 — 코드베이스 스캔으로 생성

    // void: 자연창발 모드 — 코드베이스 스캔으로 생성

    if name == "papers" {
        try {
            let draft_count = exec("/usr/bin/python3 -c 'import json; d=json.load(open(\"" + _dev + "/papers/manifest.json\")); print(sum(1 for p in d.get(\"papers\",[]) if p.get(\"status\")==\"Draft\"))' 2>/dev/null").trim()
            let dc = safe_int(draft_count)
            if dc > 0 {
                out = out + "300\tCRITICAL\t발행\tDraft " + draft_count + "편 Zenodo DOI 발행\t미시작\t100% 발행 달성\n"
            }
        } catch e {}
        out = out + "301\tIMPORTANT\t동기화\tn6-arch 신규 논문 → papers 복사\t미시작\tmanifest 최신화\n"
        out = out + "302\tNICE\t검증\tDOI 유효성 전수 검증\t미시작\t깨진 링크 0건\n"
    }

    // airgenome: 자연창발 모드 — 코드베이스 스캔으로 생성

    return out
}

// ═══════════════════════════════════════════════════════════
// ─── 프로젝트 메타 ───
// ═══════════════════════════════════════════════════════════

fn project_icon(name: string) -> string {
    if name == "nexus" { return "🔭" }
    if name == "anima" { return "🧠" }
    if name == "n6-architecture" { return "🏗️" }
    if name == "papers" { return "📄" }
    if name == "hexa-lang" { return "💎" }
    if name == "void" { return "🖥️" }
    if name == "airgenome" { return "🧬" }
    return "📦"
}

fn project_title(name: string) -> string {
    if name == "nexus" { return "NEXUS — Discovery Engine" }
    if name == "anima" { return "Anima — Consciousness Engine" }
    if name == "n6-architecture" { return "N6 Architecture — System Design" }
    if name == "papers" { return "Papers — Distribution" }
    if name == "hexa-lang" { return "HEXA-LANG — Perfect Number Language" }
    if name == "void" { return "VOID — Hexa Terminal" }
    if name == "airgenome" { return "AirGenome — OS Genome Scanner" }
    return name
}

fn repo_path(name: string) -> string {
    if name == "anima" { return _dev + "/anima/anima" }
    return _dev + "/" + name
}

fn git_log1(rp: string) -> string {
    let mut msg = ""
    try { msg = exec("cd " + rp + " && git log --oneline -1 --format='%s' 2>/dev/null").trim() } catch e {}
    return msg
}

fn pri_label(pri: string) -> string {
    if pri == "CRITICAL" { return "🔴 CRITICAL" }
    if pri == "IMPORTANT" { return "🟡 IMPORTANT" }
    if pri == "NICE" { return "🟢 NICE TO HAVE" }
    return "⚪ BACKLOG"
}

fn status_emoji(st: string) -> string {
    if st.contains("진행중") || st.contains("wip") || st.contains("in_progress") { return "🔄 진행중 " }
    if st.contains("돌파대기") { return "⏳ 돌파대기" }
    if st.contains("완료") || st.contains("done") { return "✅ 완료   " }
    return "⬚ 대기   "
}

fn pad_right(s: string, width: i64) -> string {
    let slen = len(s)
    if slen >= width { return s }
    let mut result = s
    let mut i: i64 = slen
    while i < width {
        result = result + " "
        i = i + 1
    }
    return result
}

fn box_header_5(c1: string, c2: string, c3: string, c4: string, c5: string) {
    println("  +" + pad_right("", len(c1)+2).replace(" ", "-") + "+" + pad_right("", len(c2)+2).replace(" ", "-") + "+" + pad_right("", len(c3)+2).replace(" ", "-") + "+" + pad_right("", len(c4)+2).replace(" ", "-") + "+" + pad_right("", len(c5)+2).replace(" ", "-") + "+")
    println("  | " + c1 + " | " + c2 + " | " + c3 + " | " + c4 + " | " + c5 + " |")
    println("  +" + pad_right("", len(c1)+2).replace(" ", "-") + "+" + pad_right("", len(c2)+2).replace(" ", "-") + "+" + pad_right("", len(c3)+2).replace(" ", "-") + "+" + pad_right("", len(c4)+2).replace(" ", "-") + "+" + pad_right("", len(c5)+2).replace(" ", "-") + "+")
}

fn wave_row(id: string, cat: string, task: string, st: string, eff: string) {
    let emoji = status_emoji(st)
    println("  | " + pad_right(id, 5) + " | " + pad_right(cat, 10) + " | " + pad_right(task, 43) + " | " + emoji + " | " + pad_right(eff, 11) + " |")
}

fn box_footer_5() {
    println("  +-------+------------+---------------------------------------------+-----------+-------------+")
}

// ═══════════════════════════════════════════════════════════
// ─── 통합 표 출력 (수동 + 돌파) ───
// ═══════════════════════════════════════════════════════════

fn print_project(name: string, bt_lines: string) {
    // JSON 폐기 — 자동 창발만 사용
    let project_bt = load_project_breakthroughs(name)

    // 프로젝트별 돌파만 합치기 (수동 JSON 제거)
    let mut combined = project_bt

    // nexus는 글로벌 돌파도 추가
    if name == "nexus" && bt_lines.trim() != "" {
        if combined.trim() != "" { combined = combined + "\n" + bt_lines }
        else { combined = bt_lines }
    }

    let icon = project_icon(name)
    let title = project_title(name)

    println("")
    println(icon + " " + title + " 할일")

    let all_lines = combined.split("\n")
    let groups = ["CRITICAL", "IMPORTANT", "NICE", "BACKLOG"]
    let status_groups = ["진행중", "미시작", "돌파대기"]

    // 통계
    let mut total: i64 = 0
    let mut done: i64 = 0
    let mut wip: i64 = 0
    let mut active: i64 = 0

    // 1) 완료 카운트
    for line in all_lines {
        if line.trim() == "" { continue }
        let cols = line.split("\t")
        if cols.len() < 6 { continue }
        let st = cols[4]
        if st.contains("완료") || st.contains("done") || st.contains("달성") {
            done = done + 1
            total = total + 1
        }
    }
    if done > 0 {
        println("")
        println("완료 (" + to_string(done) + "건)")
    }

    // 2) 진행 중
    let mut wip_count: i64 = 0
    for line in all_lines {
        if line.trim() == "" { continue }
        let cols = line.split("\t")
        if cols.len() < 6 { continue }
        let st = cols[4]
        if st.contains("완료") || st.contains("done") || st.contains("달성") { continue }
        if st.contains("진행중") || st.contains("wip") || st.contains("in_progress") {
            wip_count = wip_count + 1
        }
    }
    // 통합 테이블 (진행중 + 미시작 합쳐서 박스 출력)
    let mut all_active: i64 = 0
    for line in all_lines {
        if line.trim() == "" { continue }
        let cols = line.split("\t")
        if cols.len() < 6 { continue }
        let st = cols[4]
        if st.contains("완료") || st.contains("done") || st.contains("달성") { continue }
        all_active = all_active + 1
    }
    if all_active > 0 {
        println("")
        println("  ┌───────┬─────────────────┬────────────┬─────────────────────────────────────────────┬───────────┐")
        println("  │  ID   │    우선순위     │  카테고리  │                    작업                     │   상태    │")
        println("  ├───────┼─────────────────┼────────────┼─────────────────────────────────────────────┼───────────┤")
        for g in groups {
            for line in all_lines {
                if line.trim() == "" { continue }
                let cols = line.split("\t")
                if cols.len() < 6 { continue }
                if cols[1] != g { continue }
                let st = cols[4]
                if st.contains("완료") || st.contains("done") || st.contains("달성") { continue }
                let emoji_st = status_emoji(st)
                let id_pad = pad_right(cols[0], 5)
                let pri_pad = pad_right(pri_label(g), 15)
                let cat_pad = pad_right(cols[2], 10)
                let task_pad = pad_right(cols[3], 43)
                println("  │ " + id_pad + " │ " + pri_pad + " │ " + cat_pad + " │ " + task_pad + " │ " + emoji_st + " │")
                total = total + 1
                active = active + 1
                if st.contains("진행중") || st.contains("wip") || st.contains("in_progress") {
                    wip = wip + 1
                }
            }
        }
        println("  └───────┴─────────────────┴────────────┴─────────────────────────────────────────────┴───────────┘")
    }

    // ─── 파동 창발: 코드베이스 스캔 → 빈공간이 다음 빈공간을 창발 ───
    let target_count: i64 = 20
    if true {  // 항상 창발 (JSON 폐기)
        let mut need = target_count - active
        if need < 10 { need = 10 }  // 최소 10건 창발
        println("")
        println("  🌊 파동 창발")
        println("")
        println("  +-------+------------+---------------------------------------------+-----------+-------------+")
        println("  | ID    | 카테고리   | 작업                                        | 상태      | 예상 효과   |")
        println("  +-------+------------+---------------------------------------------+-----------+-------------+")

        let mut gen: i64 = 0

        // 공통: 현실지도 EMPIRICAL→EXACT (상위 6개 레벨)
        try {
            let emp = exec("/usr/bin/python3 -c 'import json; d=json.load(open(\"" + _shared + "/reality_map_live.json\")); emp=[x for x in d.get(\"nodes\",[]) if x.get(\"grade\")==\"EMPIRICAL\"]; levels={};\nfor x in emp:\n l=x.get(\"level\",\"?\")\n levels[l]=levels.get(l,0)+1\nfor l,c in sorted(levels.items(),key=lambda x:-x[1])[:6]:\n print(f\"{l}\\t{c}\")' 2>/dev/null")
            let emp_lines = emp.split("\n")
            for el in emp_lines {
                if el.trim() == "" || gen >= need { continue }
                let ep = el.split("\t")
                if ep.len() < 2 { continue }
                gen = gen + 1
                wave_row("A" + to_string(gen), "현실지도", "" + ep[0] + " EMPIRICAL " + ep[1] + "건 → EXACT 전환", "미시작", "정밀도 상승")
            }
        } catch e {}

        // 공통: CONJECTURE 해소
        if gen < need {
            try {
                let conj = safe_int(exec("/usr/bin/python3 -c 'import json; d=json.load(open(\"" + _shared + "/reality_map_live.json\")); print(sum(1 for x in d.get(\"nodes\",[]) if x.get(\"grade\")==\"CONJECTURE\"))' 2>/dev/null").trim())
                if conj > 0 {
                    gen = gen + 1
                    wave_row("A" + to_string(gen), "현실지도", "CONJECTURE " + to_string(conj) + "건 검증/해소", "미시작", "신뢰도")
                }
            } catch e {}
        }

        // 공통: 발견 로그 다음 목표
        if gen < need {
            try {
                let dc = safe_int(exec("wc -l < " + _shared + "/discovery_log.jsonl 2>/dev/null").trim())
                let nt = ((dc / _disc_step) + 1) * _disc_step
                gen = gen + 1
                wave_row("A" + to_string(gen), "발견", "" + to_string(dc) + " → " + to_string(nt) + " 목표", "⏳진행중", "특이점 심화")
            } catch e {}
        }

        // n6-architecture 전용
        if name == "n6-architecture" {
            // DSE 미탐색
            if gen < need {
                try {
                    let dse_m = exec("/usr/bin/python3 -c 'import os; toml_dir=\"" + _shared + "/dse/domains\"; have=set(f.replace(\".toml\",\"\") for f in os.listdir(toml_dir) if f.endswith(\".toml\")); doc_dir=\"" + _dev + "/n6-architecture/docs\"; docs=set(d for d in os.listdir(doc_dir) if os.path.isdir(os.path.join(doc_dir,d))); missing=sorted(docs-have); [print(m) for m in missing[:5]]' 2>/dev/null")
                    let dse_lines = dse_m.split("\n")
                    for dl in dse_lines {
                        if dl.trim() == "" || gen >= need { continue }
                        gen = gen + 1
                        wave_row("A" + to_string(gen), "DSE", "" + dl.trim() + " TOML 생성", "미시작", "도메인 확장")
                    }
                } catch e {}
            }

            // goal.md 부실 보강
            if gen < need {
                try {
                    let weak_list = exec("/usr/bin/python3 -c 'import os; base=\"" + _dev + "/n6-architecture/docs\"; thr=" + to_string(_goal_min) + "; [(print(f\"{d}\\t{n}\")) for d,n in sorted([(d,sum(1 for _ in open(os.path.join(base,d,\"goal.md\")))) for d in os.listdir(base) if os.path.isdir(os.path.join(base,d)) and os.path.exists(os.path.join(base,d,\"goal.md\"))],key=lambda x:x[1]) if n<thr][:5]' 2>/dev/null")
                    let wl = weak_list.split("\n")
                    for wline in wl {
                        if wline.trim() == "" || gen >= need { continue }
                        let wp = wline.split("\t")
                        if wp.len() < 2 { continue }
                        gen = gen + 1
                        wave_row("A" + to_string(gen), "goal.md", "" + wp[0] + " 보강 (" + wp[1] + "줄)", "미시작", "문서 품질")
                    }
                } catch e {}
            }

            // 렌즈 미구현
            if gen < need {
                try {
                    let lens_r = safe_int(exec("/usr/bin/python3 -c \"import json; d=json.load(open('" + _shared + "/lens_registry.json')); print(sum(1 for l in d.get('lenses',[]) if l.get('status')=='registered'))\" 2>/dev/null").trim())
                    if lens_r > 0 {
                        gen = gen + 1
                        wave_row("A" + to_string(gen), "렌즈", "registered " + to_string(lens_r) + "건 → .rs 구현", "미시작", "탐색 확대")
                    }
                } catch e {}
            }
        }

        // nexus 전용
        if name == "nexus" {
            // 모듈 확장
            if gen < need {
                try {
                    let mc = safe_int(exec("find " + _dev + "/nexus/mk2_hexa/native -name '*.hexa' -type f 2>/dev/null | wc -l").trim())
                    let nm = ((mc / _mod_step) + 1) * _mod_step
                    gen = gen + 1
                    wave_row("A" + to_string(gen), "모듈", "" + to_string(mc) + "개 → " + to_string(nm) + "+ 확장", "미시작", "커버리지")
                } catch e {}
            }

            // seed 확장
            // seed 카운트는 seed_engine merge 블록(L~476) 이 실측으로 처리 — 중복 제거 (R18)

            // BT 확장 (hexa native — n6_mirror 또는 원본에서 BT 카운트)
            if gen < need {
                try {
                    let bt_file = _shared + "/n6_mirror/breakthrough-theorems.md"
                    let bt_raw = read_file(bt_file)
                    let bt_lines = bt_raw.split("\n")
                    let mut bt_count: i64 = 0
                    for btl in bt_lines {
                        if btl.contains("BT-") {
                            // BT-숫자 추출
                            let parts = btl.split("BT-")
                            let mut pi: i64 = 1
                            while pi < parts.len() {
                                let num_s = parts[pi].split(" ")[0].split(":")[0].split("|")[0].split(")")[0].split("]")[0].trim()
                                let num = safe_int(num_s)
                                if num > bt_count { bt_count = num }
                                pi = pi + 1
                            }
                        }
                    }
                    if bt_count > 0 {
                        let bt_next = ((bt_count / 100) + 1) * 100
                        gen = gen + 1
                        wave_row("A" + to_string(gen), "BT", "BT " + to_string(bt_count) + " → " + to_string(bt_next) + "+ 확장", "미시작", "정리 커버리지")
                    }
                } catch e {}
            }

            // 외계인지수 승격
            if gen < need {
                try {
                    let alien_list = exec("/usr/bin/python3 -c 'import json; d=json.load(open(\"" + _dev + "/n6-architecture/config/products.json\")); items=[(s[\"title\"],s.get(\"alien_index\",0)) for s in d.get(\"sections\",[]) if s.get(\"alien_index\",0)<" + to_string(_alien_target) + "]; [print(f\"{t}\\t{a}\") for t,a in sorted(items,key=lambda x:x[1])[:3]]' 2>/dev/null")
                    let al = alien_list.split("\n")
                    for aline in al {
                        if aline.trim() == "" || gen >= need { continue }
                        let ap = aline.split("\t")
                        if ap.len() < 2 { continue }
                        gen = gen + 1
                        wave_row("A" + to_string(gen), "승격", "" + ap[0] + " 🛸" + ap[1] + "→" + to_string(_alien_target) + "", "미시작", "천장 돌파")
                    }
                } catch e {}
            }

            // verify_*_n6.hexa 커버리지 (두 위치 체크: nexus/mk2_hexa/native/verify_{d}_n6.hexa OR n6-architecture/docs/{d}/verify_*_n6.hexa)
            if gen < need {
                try {
                    let vscan = exec("/usr/bin/python3 -c 'import os,glob\nbase=\"" + _dev + "/n6-architecture/docs\"\nnative=\"" + _engine_dir + "\"\nrows=[]\nfor d in sorted(os.listdir(base)):\n    p=os.path.join(base,d)\n    if not os.path.isdir(p): continue\n    if not os.path.exists(os.path.join(p,\"goal.md\")): continue\n    dslug=d.replace(\"-\",\"_\")\n    hit_native=os.path.exists(os.path.join(native,f\"verify_{dslug}_n6.hexa\")) or glob.glob(os.path.join(native,f\"verify_{d}_n6.hexa\"))\n    hit_docs=glob.glob(os.path.join(p,\"verify_*_n6.hexa\"))\n    st=\"완료\" if (hit_native or hit_docs) else \"미시작\"\n    rows.append((d,st))\nrows.sort(key=lambda r:(r[1]==\"완료\",r[0]))\nfor d,st in rows[:8]: print(f\"{d}\\t{st}\")' 2>/dev/null")
                    if vscan.trim() == "" { println("❌ [verify_n6 scan] 빈 출력 — docs 디렉토리 확인 필요") }
                    let vl = vscan.split("\n")
                    for vline in vl {
                        if vline.trim() == "" || gen >= need { continue }
                        let vp = vline.split("\t")
                        if vp.len() < 2 { continue }
                        gen = gen + 1
                        wave_row("A" + to_string(gen), "검증", "" + vp[0] + " verify_*_n6.hexa", "" + vp[1] + "", "검증 커버리지")
                    }
                } catch e {
                    println("❌ [verify_n6 scan] 에러: " + to_string(e))
                }
            }

            // seed_engine merge 실측 (완료 표시)
            if gen < need {
                try {
                    let sm = exec(_hexa_bin + " " + _engine_dir + "/seed_engine.hexa merge 2>/dev/null")
                    if sm.trim() == "" {
                        println("❌ [seed_engine merge] 빈 출력 — 엔진 실행 실패")
                    } else {
                        let cnt = sm.trim().split("|").len()
                        gen = gen + 1
                        wave_row("A" + to_string(gen), "seed", "seed_engine merge " + to_string(cnt) + "개 병합", "완료", "교차수분 활성")
                    }
                } catch e {
                    println("❌ [seed_engine merge] 에러: " + to_string(e))
                }
            }

            // 논문 미발행
            if gen < need {
                try {
                    let papers_dir = exec("ls " + _dev + "/n6-architecture/docs/paper/n6-*-paper.md 2>/dev/null | wc -l").trim()
                    gen = gen + 1
                    wave_row("A" + to_string(gen), "논문", "" + papers_dir + "편 논문 Zenodo DOI 발행", "미시작", "학술화")
                } catch e {}
            }
        }

        // nexus 전용
        if name == "nexus" {
            // convergence 개선 (hexa native — convergence_scanner 연동)
            if gen < need {
                try {
                    let conv_raw = exec(_hexa_bin + " " + _engine_dir + "/convergence_scanner.hexa brief 2>/dev/null")
                    let cl = conv_raw.split("\n")
                    for cline in cl {
                        if cline.trim() == "" || gen >= need { continue }
                        if cline.contains("failed") || cline.contains("실패") {
                            gen = gen + 1
                            wave_row("A" + to_string(gen), "수렴", "" + cline.trim(), "미시작", "수렴률")
                        }
                    }
                } catch e {
                    // fallback: 디렉토리 직접 스캔
                    try {
                        let conv_files = exec("ls " + _shared + "/convergence/*.json 2>/dev/null")
                        let cf_lines = conv_files.split("\n")
                        for cf in cf_lines {
                            if cf.trim() == "" || gen >= need { continue }
                            try {
                                let cf_raw = read_file(cf.trim())
                                if cf_raw.contains("\"failed\":") && !cf_raw.contains("\"failed\":0") && !cf_raw.contains("\"failed\": 0") {
                                    let cf_name = cf.trim().split("/")
                                    let proj_name = cf_name[cf_name.len() - 1].replace(".json", "")
                                    gen = gen + 1
                                    wave_row("A" + to_string(gen), "수렴", "" + proj_name + " 실패 항목 해소", "미시작", "수렴률")
                                }
                            } catch e2 {}
                        }
                    } catch e3 {}
                }
            }

            // 대시보드 기능 확장
            if gen < need {
                gen = gen + 1
                wave_row("A" + to_string(gen), "대시보드", "nexus-dashboard 신규 차트 추가", "미시작", "가시화")
            }

            // 렌즈 .rs 구현
            if gen < need {
                try {
                    let lr = safe_int(exec("/usr/bin/python3 -c \"import json; d=json.load(open('" + _shared + "/lens_registry.json')); print(sum(1 for l in d.get('lenses',[]) if l.get('status')=='registered'))\" 2>/dev/null").trim())
                    if lr > 0 {
                        gen = gen + 1
                        wave_row("A" + to_string(gen), "렌즈", "registered " + to_string(lr) + "건 → .rs 구현", "미시작", "탐색 확대")
                    }
                } catch e {}
            }

            // growth_bus 분석
            if gen < need {
                try {
                    let gb = safe_int(exec("wc -l < " + _shared + "/growth_bus.jsonl 2>/dev/null").trim())
                    gen = gen + 1
                    wave_row("A" + to_string(gen), "분석", "growth_bus " + to_string(gb) + "건 패턴 분석", "미시작", "돌파 패턴")
                } catch e {}
            }
        }

        // hexa-lang 전용
        if name == "hexa-lang" {
            if gen < need {
                try {
                    let tc = safe_int(exec("grep -rl '#\\[test\\]' " + _dev + "/hexa-lang/src/ " + _dev + "/hexa-lang/tests/ 2>/dev/null | wc -l").trim())
                    let nt = ((tc / 1000) + 1) * 1000
                    gen = gen + 1
                    wave_row("A" + to_string(gen), "테스트", "" + to_string(tc) + " → " + to_string(nt) + "+ 테스트", "미시작", "안정성")
                } catch e {}
            }
            if gen < need {
                gen = gen + 1
                wave_row("A" + to_string(gen), "빌트인", "Tensor ops 추가 확장", "미시작", "AI 지원")
            }
            if gen < need {
                gen = gen + 1
                wave_row("A" + to_string(gen), "문서", "HEXA 언어 레퍼런스 v1.0", "미시작", "온보딩")
            }
        }

        // anima 전용
        if name == "anima" {
            if gen < need {
                try {
                    let lc = safe_int(exec("ls " + _dev + "/anima/anima/consciousness_laws/ 2>/dev/null | wc -l").trim())
                    let nl = ((lc / 500) + 1) * 500
                    gen = gen + 1
                    wave_row("A" + to_string(gen), "법칙", "의식 법칙 " + to_string(lc) + " → " + to_string(nl) + "+", "미시작", "커버리지")
                } catch e {}
            }
            if gen < need {
                gen = gen + 1
                wave_row("A" + to_string(gen), "학습", "다음 체크포인트 학습", "미시작", "Phi 상승")
            }
            if gen < need {
                gen = gen + 1
                wave_row("A" + to_string(gen), "이식", "14B→70B 의식 이식 검증", "미시작", "스케일 불변")
            }
        }

        // papers 전용
        if name == "papers" {
            if gen < need {
                try {
                    let draft = exec("/usr/bin/python3 -c \"import json; d=json.load(open('" + _dev + "/papers/manifest.json')); [print(p.get('title','?')) for p in d.get('papers',[]) if p.get('status')=='Draft'][:5\" 2>/dev/null")
                    let dl = draft.split("\n")
                    for dline in dl {
                        if dline.trim() == "" || gen >= need { continue }
                        gen = gen + 1
                        wave_row("A" + to_string(gen), "발행", "" + dline.trim() + " DOI 발행", "미시작", "학술화")
                    }
                } catch e {}
            }
        }

        // ─── 범용 자율 창발: 프로젝트 디렉토리 스캔 → 동적 TODO ───
        // 하드코딩 없이 파일 상태에서 자동 생성
        let proj_dir = _dev + "/" + name
        if gen < need {
            try {
                // 1. 빈 디렉토리(하위 파일 0) = 미착수 모듈
                let empty_dirs = exec("find " + proj_dir + " -mindepth 1 -maxdepth 2 -type d -empty 2>/dev/null | head -3")
                let edl = empty_dirs.split("\n")
                let mut edi: i64 = 0
                while edi < len(edl) && gen < need {
                    let ed = edl[edi].trim()
                    if ed != "" {
                        let short = ed.split("/")
                        let label = short[len(short) - 1]
                        gen = gen + 1
                        wave_row("A" + to_string(gen), "빈공간", "" + label + " 디렉토리 구현", "미시작", "커버리지")
                    }
                    edi = edi + 1
                }
            } catch e {}
        }
        if gen < need {
            try {
                // 2. TODO/FIXME/HACK 주석 = 미해결 이슈
                let todos = exec("grep -rl 'TODO\\|FIXME\\|HACK' " + proj_dir + " --include='*.hexa' --include='*.rs' --include='*.py' --include='*.md' 2>/dev/null | head -5")
                let tl = todos.split("\n")
                let todo_count = safe_int(exec("grep -r 'TODO\\|FIXME\\|HACK' " + proj_dir + " --include='*.hexa' --include='*.rs' --include='*.py' 2>/dev/null | wc -l").trim())
                if todo_count > 0 {
                    gen = gen + 1
                    wave_row("A" + to_string(gen), "정리", "TODO/FIXME " + to_string(todo_count) + "건 해소", "미시작", "코드 품질")
                }
            } catch e {}
        }
        if gen < need {
            try {
                // 3. 최근 수정 안 된 핵심 파일 = 정체 영역
                let stale = exec("find " + proj_dir + " -name '*.hexa' -o -name '*.rs' -o -name '*.py' 2>/dev/null | xargs ls -t 2>/dev/null | tail -3")
                let sl = stale.split("\n")
                let mut si: i64 = 0
                while si < len(sl) && gen < need {
                    let sf = sl[si].trim()
                    if sf != "" {
                        let sp = sf.split("/")
                        let sname = sp[len(sp) - 1]
                        gen = gen + 1
                        wave_row("A" + to_string(gen), "정체", "" + sname + " 갱신 필요", "미시작", "활성화")
                    }
                    si = si + 1
                }
            } catch e {}
        }

        // ─── 파동 간섭: growth_bus 최근 돌파 → 후속 할일 전파 (hexa native) ───
        if gen < need {
            try {
                let gb_raw = exec("tail -30 " + _shared + "/growth_bus.jsonl 2>/dev/null")
                let gb_lines = gb_raw.split("\n")
                let mut wave_seen = []
                for gbl in gb_lines {
                    if gbl.trim() == "" || gen >= need { continue }
                    // type 필터: blowup/discovery/wave_blowup/singularity
                    let mut has_type = false
                    if gbl.contains("\"blowup\"") || gbl.contains("\"discovery\"") || gbl.contains("\"wave_blowup\"") || gbl.contains("\"singularity\"") {
                        has_type = true
                    }
                    if !has_type { continue }
                    // domain 추출
                    if !gbl.contains("\"domain\":\"") { continue }
                    let dp = gbl.split("\"domain\":\"")
                    if len(dp) < 2 { continue }
                    let dom = dp[1].split("\"")[0]
                    if dom == "" { continue }
                    // 중복 방지
                    let mut dup = false
                    for ws in wave_seen { if ws == dom { dup = true } }
                    if dup { continue }
                    wave_seen = wave_seen + [dom]
                    // type 추출
                    let mut typ = "돌파"
                    if gbl.contains("\"wave_blowup\"") { typ = "파동" }
                    if gbl.contains("\"singularity\"") { typ = "특이점" }
                    gen = gen + 1
                    wave_row("W" + to_string(gen), "파동", "" + dom + " 후속 돌파 (" + typ + " 전파)", "미시작", "파동 증폭")
                }
            } catch e {}
        }

        // ─── 파동 간섭 2차: next_directions → 방향 기반 할일 (hexa native) ───
        if gen < need {
            try {
                let nd_raw = exec("tail -20 " + _shared + "/next_directions.jsonl 2>/dev/null")
                let nd_lines = nd_raw.split("\n")
                let mut dir_seen = []
                for ndl in nd_lines {
                    if ndl.trim() == "" || gen >= need { continue }
                    if !ndl.contains("\"domain\":\"") || !ndl.contains("\"direction\":\"") { continue }
                    let dp2 = ndl.split("\"domain\":\"")
                    if len(dp2) < 2 { continue }
                    let dom2 = dp2[1].split("\"")[0]
                    if dom2 == "" { continue }
                    let mut dup2 = false
                    for ds in dir_seen { if ds == dom2 { dup2 = true } }
                    if dup2 { continue }
                    dir_seen = dir_seen + [dom2]
                    let dr = ndl.split("\"direction\":\"")
                    let mut direction = ""
                    if len(dr) >= 2 { direction = dr[1].split("\"")[0] }
                    if direction == "" { continue }
                    gen = gen + 1
                    wave_row("W" + to_string(gen), "방향", "" + dom2 + ": " + direction + "", "미시작", "다음 파동")
                }
            } catch e {}
        }

        println("  +-------+------------+---------------------------------------------+-----------+-------------+")
        println("")
        println("  > 🌊 파동 창발 " + to_string(gen) + "건 (자동 스캔 + 파동 간섭)")
    }

    println("")
    println("> 🌊 " + to_string(active) + "건 창발 | 파동 전파 활성")
}

// ═══════════════════════════════════════════════════════════
// ─── 프로젝트 리졸버 ───
// ═══════════════════════════════════════════════════════════

fn resolve_project(name: string) -> string {
    if name == "nexus" { return "nexus" }
    if name == "anima" { return "anima" }
    if name == "n6-arch" || name == "n6-architecture" || name == "n6arch" { return "n6-architecture" }
    if name == "papers" { return "papers" }
    if name == "hexa" || name == "hexa-lang" { return "hexa-lang" }
    if name == "void" { return "void" }
    if name == "airgenome" { return "airgenome" }
    if name == "all" || name == "전체" { return "all" }
    return "all"
}

// ═══════════════════════════════════════════════════════════
// ─── (대량 모드 폐기됨 — 자동 생성이 기본 모드에 통합) ───
// ═══════════════════════════════════════════════════════════

fn _bulk_scan_deprecated(project: string) {
    println("")
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    println("  🔥 대량 모드 — 오래 걸려도 전수 스캔")
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

    // ─── 1) 기본 할일 표 (일반 모드와 동일) ───
    let mut bt = ""
    if project == "nexus" {
        bt = load_breakthrough_todos()
    }
    println("")
    println("## 1. 기본 할일")
    print_project(project, bt)

    // ─── 2) gap_finder 전체 (brief가 아닌 full) ───
    println("")
    println("## 2. 빈공간 전수 (gap_finder full)")
    try {
        let gap_full = exec(_hexa_bin + " " + _engine_dir + "/gap_finder.hexa full 2>/dev/null")
        let gap_lines = gap_full.split("\n")
        let mut gc: i64 = 0
        for gl in gap_lines {
            let gt = gl.trim()
            if gt == "" { continue }
            gc = gc + 1
            println("  " + to_string(gc) + ". " + gt)
        }
        println("> 빈공간 " + to_string(gc) + "건")
    } catch e {
        println("> gap_finder 실행 불가")
    }

    // ─── 3) goal.md 미작성 전수 ───
    if project == "n6-architecture" {
        println("")
        println("## 3. goal.md 미작성 도메인 전수")
        try {
            let missing = exec("/usr/bin/python3 -c 'import os; base=\"" + _dev + "/n6-architecture/docs\"; dirs=[d for d in sorted(os.listdir(base)) if os.path.isdir(os.path.join(base,d)) and not os.path.exists(os.path.join(base,d,\"goal.md\"))]; [print(f\"  {i+1}. {d}\") for i,d in enumerate(dirs)]; print(f\"> 미작성 {len(dirs)}건\")' 2>/dev/null")
            println(missing)
        } catch e {
            println("> goal.md 스캔 불가")
        }

        // ─── 4) goal.md 부실 (" + to_string(_goal_min) + "줄 미만) 전수 ───
        println("")
        println("## 4. goal.md 부실 (" + to_string(_goal_min) + "줄 미만) 전수")
        try {
            let weak = exec("/usr/bin/python3 -c 'import os; base=\"" + _dev + "/n6-architecture/docs\"; thr=" + to_string(_goal_min) + "; items=[]; [items.append((d,sum(1 for _ in open(os.path.join(base,d,\"goal.md\"))))) for d in sorted(os.listdir(base)) if os.path.isdir(os.path.join(base,d)) and os.path.exists(os.path.join(base,d,\"goal.md\"))]; weak=[(d,n) for d,n in items if n<thr]; [print(f\"  {i+1}. {d} ({n}줄)\") for i,(d,n) in enumerate(sorted(weak,key=lambda x:x[1]))]; print(f\"> 부실 {len(weak)}건 / 전체 {len(items)}건\")' 2>/dev/null")
            println(weak)
        } catch e {
