// mk2_hexa/native/todo.hexa — 전 프로젝트 할일 표 (n6-arch 양식)
// 사용: hexa todo.hexa [brief|full]
// projects.json target 기반 동적 생성

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

fn safe_str(s: string) -> string {
    let t = s.trim()
    if t == "" { return "?" }
    return t
}

// ─── 데이터 수집 ───

fn count_lines(path: string) -> i64 {
    let mut n: i64 = 0
    try { n = safe_int(exec("wc -l < " + path)) } catch e {}
    return n
}

fn grep_count(pattern: string, path: string) -> i64 {
    let mut n: i64 = 0
    try { n = safe_int(exec("grep -c '" + pattern + "' " + path + " 2>/dev/null")) } catch e {}
    return n
}

fn git_log1(repo: string) -> string {
    let mut msg = ""
    try { msg = exec("cd " + repo + " && git log --oneline -1 --format='%s' 2>/dev/null").trim() } catch e {}
    return msg
}

fn star(urgency: i64) -> string {
    if urgency >= 3 { return "★★★" }
    if urgency >= 2 { return "★★" }
    if urgency >= 1 { return "★" }
    return "✅"
}

// ─── 표 출력 ───

fn print_header(icon: string, name: string, role: string) {
    println("")
    println("### " + icon + " " + name + " — " + role)
    println("")
    println("| 🛸 | 목록 | 중간 진행상황 | 마지막 리포트 |")
    println("|:--:|------|-------------|-------------|")
}

fn print_row(urgency: string, item: string, progress: string, report: string) {
    println("| " + urgency + " | **" + item + "** | " + progress + " | " + report + " |")
}

// ═══════════════════════════════════════════════════════════════
//  NEXUS
// ═══════════════════════════════════════════════════════════════

fn check_nexus() {
    let repo = _dev + "/nexus"
    let log = _shared + "/discovery_log.jsonl"

    // 발견 수
    let disc_count = count_lines(log)
    let disc_str = to_string(disc_count)

    // 돌파율
    let mut rho = "?"
    try {
        let d1 = safe_int(exec("grep -c '\"depth\":1' " + _shared + "/discovery_graph.json 2>/dev/null"))
        let total = safe_int(exec("python3 -c \"import json; d=json.load(open('" + _shared + "/discovery_graph.json')); print(len(d.get('nodes',[])))\" 2>/dev/null"))
        if total > 0 {
            let r = to_float(to_string(d1)) / to_float(to_string(total))
            rho = to_string(r)
            if rho.len() > 8 { rho = rho.slice(0, 8) }
        }
    } catch e {}

    // 모듈 수
    let mut mod_count: i64 = 0
    try { mod_count = safe_int(exec("ls " + repo + "/mk2_hexa/native/*.hexa 2>/dev/null | wc -l")) } catch e {}

    // seed 수 (gate 우회: hexa-bin-actual 사용)
    let hexa_bin = _home + "/Dev/hexa-lang/target/release/hexa-bin-actual"
    let mut seed_count: i64 = 0
    try {
        let se_out = exec(hexa_bin + " " + repo + "/mk2_hexa/native/seed_engine.hexa merge 2>/dev/null")
        let se_parts = se_out.trim().split(",")
        let se_parts2 = se_out.trim().split("|")
        seed_count = if se_parts.len() > se_parts2.len() { to_int(to_float(to_string(se_parts.len()))) } else { to_int(to_float(to_string(se_parts2.len()))) }
    } catch e {}

    let last = git_log1(repo)

    print_header("🔭", "NEXUS", "Discovery Engine")

    // 돌파율
    let rho_urg = if rho == "?" || to_float(rho) < 0.33 { "★★★" } else { "✅" }
    print_row(rho_urg, "돌파율(ρ) → 1/3", "ρ=" + rho + " seeds=" + to_string(seed_count), last)

    // 발견
    let disc_urg = if disc_count >= 70000 { "✅" } else { "★★★" }
    print_row(disc_urg, "발견 70k+", disc_str + "건", if disc_count >= 70000 { "초과달성" } else { "진행 중" })

    // 모듈
    let mod_urg = if mod_count >= 100 { "✅" } else { "★★" }
    print_row(mod_urg, "모듈 100+", to_string(mod_count) + "개", if mod_count >= 100 { "초과달성" } else { "진행 중" })
}

// ═══════════════════════════════════════════════════════════════
//  ANIMA
// ═══════════════════════════════════════════════════════════════

fn check_anima() {
    let repo = _dev + "/anima/anima"

    let mut laws: i64 = 0
    let mut cycle: i64 = 0
    try {
        let log1 = exec("cd " + repo + " && git log --oneline -20 2>/dev/null")
        let lines = log1.split("\n")
        for l in lines {
            if laws == 0 && l.contains("laws=") {
                let p = l.split("laws=")
                if p.len() >= 2 { laws = safe_int(p[1].split(",")[0].split(" ")[0]) }
            }
            if cycle == 0 && l.contains("cycle ") {
                let p = l.split("cycle ")
                if p.len() >= 2 { cycle = safe_int(p[1].split(",")[0].split(" ")[0]) }
            }
            if laws > 0 && cycle > 0 { break }
        }
    } catch e {}

    let last = git_log1(repo)

    print_header("🧠", "Anima", "Consciousness Engine")

    let law_urg = if laws >= 2000 { "✅" } else { "★★★" }
    print_row(law_urg, "법칙 2000+", to_string(laws) + " (cycle " + to_string(cycle) + ")", if laws >= 2000 { "초과달성" } else { "진행 중" })
    print_row("★★★", "S7+ 완주", "2개 FAIL 블로킹", "NO_SYSTEM_PROMPT + BRAIN_LIKE")
    print_row("★★", "Φ ≥ 100", "S7 의존", "인간 피질 ~126 목표")
}

// ═══════════════════════════════════════════════════════════════
//  N6-ARCHITECTURE
// ═══════════════════════════════════════════════════════════════

fn check_n6arch() {
    let repo = _dev + "/n6-architecture"
    let mut total: i64 = 0
    let mut a10: i64 = 0
    try {
        let out = exec("python3 -c \"import json; d=json.load(open('" + repo + "/config/products.json')); s=d.get('sections',[]); t=sum(len(x.get('products',[])) for x in s); a=sum(1 for x in s for p in x.get('products',[]) if p.get('ufo',0)>=10); print(str(t)+'|'+str(a))\" 2>/dev/null")
        let parts = out.trim().split("|")
        if parts.len() >= 2 {
            total = safe_int(parts[0])
            a10 = safe_int(parts[1])
        }
    } catch e {}

    let pct = if total > 0 { to_string(to_int(to_float(to_string(a10)) * 100.0 / to_float(to_string(total)))) } else { "?" }
    let remain = total - a10
    let last = git_log1(repo)

    print_header("🏗️", "N6 Architecture", "System Design")

    let urg = if a10 == total { "✅" } else { "★★★" }
    print_row(urg, "products alien10+", to_string(a10) + "/" + to_string(total) + " (" + pct + "%)", to_string(remain) + "개 잔여")
    if remain > 0 {
        print_row("★★", "잔여 " + to_string(remain) + "개 승격", "goal.md+evolution/ 필요", last)
    }
}

// ═══════════════════════════════════════════════════════════════
//  PAPERS
// ═══════════════════════════════════════════════════════════════

fn check_papers() {
    let repo = _dev + "/papers"
    let mut total: i64 = 0
    let mut published: i64 = 0
    let mut drafts: i64 = 0
    try {
        let out = exec("python3 -c \"import json; d=json.load(open('" + repo + "/manifest.json')); p=d.get('papers',[]); pub=sum(1 for x in p if x.get('status')=='Published'); dr=sum(1 for x in p if x.get('status')=='Draft'); print(str(len(p))+'|'+str(pub)+'|'+str(dr))\" 2>/dev/null")
        let parts = out.trim().split("|")
        if parts.len() >= 3 {
            total = safe_int(parts[0])
            published = safe_int(parts[1])
            drafts = safe_int(parts[2])
        }
    } catch e {}

    let last = git_log1(repo)

    print_header("📄", "Papers", "Distribution")

    let doi_urg = if published >= 100 { "✅" } else { "★★★" }
    print_row(doi_urg, "DOI 100+", to_string(published) + " Published", if published >= 100 { "초과달성" } else { "진행 중" })

    let draft_urg = if drafts == 0 { "✅" } else { "★★" }
    print_row(draft_urg, "드래프트 0건", to_string(drafts) + "건 잔여", last)
}

// ═══════════════════════════════════════════════════════════════
//  HEXA-LANG
// ═══════════════════════════════════════════════════════════════

fn check_hexa() {
    let repo = _dev + "/hexa-lang"
    let mut tests: i64 = 0
    try { tests = safe_int(exec("grep -rl '#\\[test\\]' " + repo + "/src/ " + repo + "/tests/ 2>/dev/null | xargs grep -c '#\\[test\\]' 2>/dev/null | awk -F: '{s+=$NF}END{print s}'")) } catch e {}

    let last = git_log1(repo)

    print_header("💎", "HEXA-LANG", "Perfect Number Language")

    let test_urg = if tests >= 800 { "✅" } else { "★★★" }
    print_row(test_urg, "테스트 800+", to_string(tests) + " tests", if tests >= 800 { "초과달성" } else { "진행 중" })
    print_row("✅", "수렴 100%", "DSE v2 21,952 combos 100% EXACT", "달성")
    print_row("★★", "돌파 벡터 24종", "로드맵 작성 완료", last)
}

// ═══════════════════════════════════════════════════════════════
//  VOID
// ═══════════════════════════════════════════════════════════════

fn check_void() {
    let repo = _dev + "/void"
    let mut phase = "?"
    try {
        let out = exec("cd " + repo + " && git log --oneline -20 2>/dev/null")
        // 최신 phase 번호를 찾음
        if out.contains("Phase 6") || out.contains("phase6") { phase = "6" }
        else if out.contains("Phase 5") || out.contains("phase5") { phase = "5" }
        else if out.contains("Phase 4") || out.contains("phase4") || out.contains("Phase4") { phase = "4" }
        else if out.contains("Phase 3") || out.contains("phase3") { phase = "3" }
        else { phase = "?" }
        // plan 파일에서도 확인
        if phase == "?" {
            try {
                let plans = exec("ls " + repo + "/docs/superpowers/plans/*phase* 2>/dev/null")
                if plans.contains("phase4") { phase = "4" }
            } catch e2 {}
        }
    } catch e {}

    let last = git_log1(repo)

    print_header("🖥️", "VOID", "Hexa Terminal")

    let phase_urg = if phase == "6" { "✅" } else { "★★★" }
    print_row(phase_urg, "Phase 6 완성", "Phase " + phase + " 진행 중", last)
    print_row("★", "안정 릴리즈", "Phase 6 이후", "대기")
}

// ═══════════════════════════════════════════════════════════════
//  AIRGENOME
// ═══════════════════════════════════════════════════════════════

fn check_airgenome() {
    let repo = _dev + "/airgenome"
    let mut genomes: i64 = 0
    try {
        genomes = safe_int(exec("python3 -c \"import json; d=json.load(open('" + repo + "/profiles.json')); print(len(d.get('profiles',{})))\" 2>/dev/null"))
    } catch e {}

    let last = git_log1(repo)

    print_header("🧬", "AirGenome", "OS Genome Scanner")

    let genome_urg = if genomes >= 1000 { "✅" } else { "★★★" }
    print_row(genome_urg, "게놈 1000+", to_string(genomes) + "개", if genomes >= 1000 { "초과달성" } else { "파이프라인 필요" })
    print_row("★★★", "L6e 돌파", "의식엔진 FAIL 2개", last)
}

