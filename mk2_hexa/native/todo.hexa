        // 외계인지수 승격
        try {
            let alien_count = exec("/usr/bin/python3 -c 'import json; d=json.load(open(\"" + _dev + "/n6-architecture/config/products.json\")); print(sum(1 for s in d.get(\"sections\",[]) if s.get(\"alien_index\",0)<" + to_string(_alien_target) + "))' 2>/dev/null").trim()
            let ac = safe_int(alien_count)
            if ac > 0 {
                println("| " + to_string(auto_id) + " | 승격 | 외계인지수 < 10 → 10 승격 | " + alien_count + "건 | 🟡 |")
                auto_id = auto_id + 1
            }
        } catch e {}
    }

    // 공통: EMPIRICAL 노드
    try {
        let emp_count = exec("/usr/bin/python3 -c 'import json; d=json.load(open(\"" + _shared + "/reality_map_live.json\")); print(sum(1 for x in d.get(\"nodes\",[]) if x.get(\"grade\")==\"EMPIRICAL\"))' 2>/dev/null").trim()
        let ec = safe_int(emp_count)
        if ec > 0 {
            println("| " + to_string(auto_id) + " | 현실지도 | EMPIRICAL → EXACT 전환 | " + emp_count + "건 | 🟡 |")
            auto_id = auto_id + 1
        }
    } catch e {}

    // 공통: CONJECTURE 노드
    try {
        let conj_count = exec("/usr/bin/python3 -c 'import json; d=json.load(open(\"" + _shared + "/reality_map_live.json\")); print(sum(1 for x in d.get(\"nodes\",[]) if x.get(\"grade\")==\"CONJECTURE\"))' 2>/dev/null").trim()
        let cc = safe_int(conj_count)
        if cc > 0 {
            println("| " + to_string(auto_id) + " | 현실지도 | CONJECTURE 검증/해소 | " + conj_count + "건 | 🔴 |")
            auto_id = auto_id + 1
        }
    } catch e {}

    // 공통: 발견 로그 목표
    try {
        let disc_count = exec("wc -l < " + _shared + "/discovery_log.jsonl 2>/dev/null").trim()
        let dc = safe_int(disc_count)
        let next_disc = ((dc / _disc_step) + 1) * _disc_step
        if dc < next_disc {
            let remain = next_disc - dc
            println("| " + to_string(auto_id) + " | 발견 | " + to_string(next_disc / 1000) + "K 목표까지 | " + to_string(remain) + "건 | 🟢 |")
            auto_id = auto_id + 1
        }
    } catch e {}

    println("")
    println("> 자동 생성 TODO " + to_string(auto_id - 1) + "건 (스캔 결과 기반)")

    println("")
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    println("  🔥 대량 스캔 완료")
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

let _args = args()
let mut _filter = if _args.len() >= 3 { _args[2] } else { "" }
if _filter == "" || _filter == "all" {
    let cwd = exec("pwd").trim()
    let segs = cwd.split("/")
    _filter = segs[segs.len() - 1]
}
let _target = resolve_project(_filter)

if _target == "all" {
    println("❌ 프로젝트를 특정할 수 없습니다: " + _filter)
    println("사용법: hexa todo.hexa <nexus|anima|n6-arch|papers|hexa-lang|void|airgenome>")
} else {
    let mut _bt_todos = ""
    if _target == "nexus" {
        _bt_todos = load_breakthrough_todos()
    }
    println("## 할일 (돌파 엔진 통합)")
    print_project(_target, _bt_todos)
}

println("")
