if mode == "breakthrough" || mode == "돌파" {
    println("╔══════════════════════════════════════════════════════╗")
    println("║  GAP FINDER — 미지의 영역 돌파                      ║")
    println("║  진짜 빈 공간을 찾아 정밀 타격                       ║")
    println("╚══════════════════════════════════════════════════════╝")
    println("")

    let analysis = analyze_discovery_log()
    let targets_str = generate_targets(analysis)
    auto_breakthrough(targets_str)
}

if mode == "transform" || mode == "변환" {
    print_transform_matrix()
}

if mode == "dfs" {
    let depth = if len(a) >= 4 { to_int(a[3]) } else { 2 }
    let d = if depth < 1 { 1 } else if depth > 3 { 3 } else { depth }
    dfs_search(d)
}

if mode == "bridge" || mode == "교차" {
    bridge_gaps()
}

// ─── D. query 모드 — 임의 값→n6 분해 ───

fn query_value(target: float) {
    println("╔══════════════════════════════════════════════════════════╗")
    println("║  GAP FINDER — n6 분해 쿼리                              ║")
    println("╚══════════════════════════════════════════════════════════╝")
    println("")
    println("  입력값: " + fmt_f(target))
    println("  기저: n=6, σ=12, φ=2, τ=4, sopfr=5, M3=7")
    println("")

    let mut hit_count = 0

    // depth 1: 단일 기저
    let mut bi = 0
    while bi < len(base_names) {
        let bv = base_vals[bi]
        if bv != 0.0 {
            let err = abs_val(target - bv) / abs_val(target)
            if err < 0.0001 {
                println("  ★ EXACT  " + base_names[bi] + " = " + fmt_f(bv))
                hit_count = hit_count + 1
            } else if err < 0.03 {
                println("  · NEAR   " + base_names[bi] + " = " + fmt_f(bv) + "  (err=" + fmt_f(err * 100.0) + "%)")
                hit_count = hit_count + 1
            }
        }
        bi = bi + 1
    }

    // depth 1: 두 기저 사칙연산
    println("")
    println("─── Depth 1 (a OP b) ───")
    let mut d1_vals = []
    let mut d1_exprs = []

    bi = 0
    while bi < len(base_names) {
        let mut bj = 0
        while bj < len(base_names) {
            if bi != bj {
                let mut oi = 0
                while oi < 4 {
                    let val = apply_op(base_vals[bi], base_vals[bj], oi)
                    let expr = base_names[bi] + op_symbol(oi) + base_names[bj]
                    d1_vals = d1_vals + [val]
                    d1_exprs = d1_exprs + [expr]

                    if val != 0.0 && abs_val(target) > 0.0 {
                        let err = abs_val(target - val) / abs_val(target)
                        if err < 0.0001 {
                            println("  ★ EXACT  " + expr + " = " + fmt_f(val))
                            hit_count = hit_count + 1
                        } else if err < 0.03 {
                            println("  · NEAR   " + expr + " = " + fmt_f(val) + "  (err=" + fmt_f(err * 100.0) + "%)")
                            hit_count = hit_count + 1
                        }
                    }
                    oi = oi + 1
                }
            }
            bj = bj + 1
        }
        bi = bi + 1
    }

    // depth 2: (a OP b) OP c
    println("")
    println("─── Depth 2 ((a OP b) OP c) ───")

    let mut di = 0
    while di < len(d1_vals) {
        let v1 = d1_vals[di]
        let e1 = d1_exprs[di]
        if abs_val(v1) <= 100000.0 && v1 != 0.0 {
            let mut bk = 0
            while bk < len(base_names) {
                let mut oi = 0
                while oi < 4 {
                    let val = apply_op(v1, base_vals[bk], oi)
                    let expr = "(" + e1 + ")" + op_symbol(oi) + base_names[bk]

                    if val != 0.0 && abs_val(target) > 0.0 {
                        let err = abs_val(target - val) / abs_val(target)
                        if err < 0.0001 {
                            println("  ★ EXACT  " + expr + " = " + fmt_f(val))
                            hit_count = hit_count + 1
                        } else if err < 0.03 {
                            println("  · NEAR   " + expr + " = " + fmt_f(val) + "  (err=" + fmt_f(err * 100.0) + "%)")
                            hit_count = hit_count + 1
                        }
                    }
                    oi = oi + 1
                }
                bk = bk + 1
            }
        }
        di = di + 1
    }

    // depth 3: (a OP b) OP (c OP d) — 샘플링
    println("")
    println("─── Depth 3 ((a OP b) OP (c OP d)) ───")

    let d1_len = len(d1_vals)
    let cap = if d1_len > 30 { 30 } else { d1_len }
    let mut qi = 0
    while qi < cap {
        let v1 = d1_vals[qi]
        let e1 = d1_exprs[qi]
        if abs_val(v1) <= 10000.0 && v1 != 0.0 {
            let mut qj = qi + 1
            while qj < cap {
                let v2 = d1_vals[qj]
                let e2 = d1_exprs[qj]
                if abs_val(v2) <= 10000.0 && v2 != 0.0 {
                    let mut oi = 0
                    while oi < 4 {
                        let val = apply_op(v1, v2, oi)
                        if val != 0.0 && abs_val(target) > 0.0 {
                            let err = abs_val(target - val) / abs_val(target)
                            if err < 0.0001 {
                                let expr = "(" + e1 + ")" + op_symbol(oi) + "(" + e2 + ")"
                                println("  ★ EXACT  " + expr + " = " + fmt_f(val))
                                hit_count = hit_count + 1
                            } else if err < 0.01 {
                                let expr = "(" + e1 + ")" + op_symbol(oi) + "(" + e2 + ")"
                                println("  · NEAR   " + expr + " = " + fmt_f(val) + "  (err=" + fmt_f(err * 100.0) + "%)")
                                hit_count = hit_count + 1
                            }
                        }
                        oi = oi + 1
                    }
                }
                qj = qj + 1
            }
        }
        qi = qi + 1
    }

    println("")
    println("─── 쿼리 결과 ───")
    println("  입력값: " + fmt_f(target))
    println("  n6 분해 경로: " + to_string(hit_count) + "건 (EXACT+NEAR)")
    if hit_count == 0 {
        println("  → n6 기저 depth 1~3 사칙연산으로 도달 불가")
        println("    거듭제곱/삼각함수 확장 또는 다른 접근 필요")
    }
    println("")
}

if mode == "query" || mode == "쿼리" {
    if len(a) >= 4 {
        let target = to_float(a[3])
        query_value(target)
    } else {
        println("ERROR: query 모드에는 값이 필요합니다")
        println("사용법: hexa gap_finder.hexa query 137.036")
    }
}

// ─── E. quick 모드 — DFS EXACT 요약 ───

fn quick_summary() {
    println("╔══════════════════════════════════════════════════════════╗")
    println("║  GAP FINDER — n6 위상변환 Quick 요약                    ║")
    println("╚══════════════════════════════════════════════════════════╝")
    println("")
    println("기저: n=6, σ=12, φ=2, τ=4, sopfr=5, M3=7  |  EXACT만 표시 (최대 20)")
    println("")

    let mut exact_count = 0
    let max_show = 20

    // depth 1
    let mut d1_vals = []
    let mut d1_exprs = []

    let mut bi = 0
    while bi < len(base_names) {
        let mut bj = 0
        while bj < len(base_names) {
            if bi != bj {
                let mut oi = 0
                while oi < 4 {
                    let val = apply_op(base_vals[bi], base_vals[bj], oi)
                    let expr = base_names[bi] + op_symbol(oi) + base_names[bj]
                    d1_vals = d1_vals + [val]
                    d1_exprs = d1_exprs + [expr]

                    if exact_count < max_show {
                        let m = match_physics(val)
                        if len(m) > 0 && m.contains("EXACT") {
                            let mut epad = expr
                            while len(epad) < 16 { epad = epad + " " }
                            println("  ★ " + epad + "= " + fmt_f(val) + "  " + m)
                            exact_count = exact_count + 1
                        }
                    }
                    oi = oi + 1
                }
            }
            bj = bj + 1
        }
        bi = bi + 1
    }

    // depth 2
    if exact_count < max_show {
        let mut di = 0
        while di < len(d1_vals) {
            let v1 = d1_vals[di]
            let e1 = d1_exprs[di]
            if abs_val(v1) <= 100000.0 && v1 != 0.0 {
                let mut bk = 0
                while bk < len(base_names) {
                    let mut oi = 0
                    while oi < 4 {
                        if exact_count < max_show {
                            let val = apply_op(v1, base_vals[bk], oi)
                            let expr = "(" + e1 + ")" + op_symbol(oi) + base_names[bk]
                            let m = match_physics(val)
                            if len(m) > 0 && m.contains("EXACT") && !m.contains("[=") {
                                let mut epad = expr
                                while len(epad) < 28 { epad = epad + " " }
                                println("  ★ " + epad + "= " + fmt_f(val) + "  " + m)
                                exact_count = exact_count + 1
                            }
                        }
                        oi = oi + 1
                    }
                    bk = bk + 1
                }
            }
            di = di + 1
        }
    }

    println("")
    println("  EXACT 매칭 총 " + to_string(exact_count) + "건" + if exact_count >= max_show { " (상위 20개만 표시)" } else { "" })
    println("  전체 탐색: hexa gap_finder.hexa dfs 2")
    println("")
}

if mode == "quick" || mode == "요약" {
    quick_summary()
}

// ─── F. explain 모드 — 특정 상수의 n6 유도 경로 ───

fn explain_constant(name: string) {
    // phys_names/phys_vals 또는 n6_constants/n6_values 에서 값 찾기
    let mut target = 0.0
    let mut found_name = name
    let mut found = false

    let mut pi = 0
    while pi < len(phys_names) {
        if phys_names[pi] == name {
            target = phys_vals[pi]
            found_name = phys_names[pi]
            found = true
        }
        pi = pi + 1
    }
    if !found {
        let mut ci = 0
        while ci < len(n6_constants) {
            if n6_constants[ci] == name {
                target = n6_values[ci]
                found_name = n6_constants[ci]
                found = true
            }
            ci = ci + 1
        }
    }

    if !found {
        println("ERROR: '" + name + "' 는 등록된 상수가 아닙니다")
        println("")
        println("사용 가능한 이름:")
        let mut pi2 = 0
        let mut names_list = ""
        while pi2 < len(phys_names) {
            if len(names_list) > 0 { names_list = names_list + ", " }
            names_list = names_list + phys_names[pi2]
            pi2 = pi2 + 1
        }
        let mut ci2 = 0
        while ci2 < len(n6_constants) {
            if len(names_list) > 0 { names_list = names_list + ", " }
            names_list = names_list + n6_constants[ci2]
            ci2 = ci2 + 1
        }
        println("  " + names_list)
        return
    }

    println("╔══════════════════════════════════════════════════════════╗")
    println("║  GAP FINDER — n6 유도 경로 설명                         ║")
    println("╚══════════════════════════════════════════════════════════╝")
    println("")
    println("  상수: " + found_name + " = " + fmt_f(target))
    println("  기저: n=6, σ=12, φ=2, τ=4, sopfr=5, M3=7")
    println("")

    let mut path_count = 0

    // depth 1
    let mut d1_vals = []
    let mut d1_exprs = []

    let mut bi = 0
    while bi < len(base_names) {
        // 단일 기저 일치
        let bv = base_vals[bi]
        if bv != 0.0 && target != 0.0 {
            let err = abs_val(target - bv) / abs_val(target)
            if err < 0.0001 {
                println("  ★ EXACT  " + base_names[bi] + " = " + fmt_f(bv))
                path_count = path_count + 1
            }
        }

        let mut bj = 0
        while bj < len(base_names) {
            if bi != bj {
                let mut oi = 0
                while oi < 4 {
                    let val = apply_op(base_vals[bi], base_vals[bj], oi)
                    let expr = base_names[bi] + op_symbol(oi) + base_names[bj]
                    d1_vals = d1_vals + [val]
                    d1_exprs = d1_exprs + [expr]

                    if val != 0.0 && target != 0.0 {
                        let err = abs_val(target - val) / abs_val(target)
                        if err < 0.0001 {
                            println("  ★ EXACT  " + expr + " = " + fmt_f(val))
                            path_count = path_count + 1
                        } else if err < 0.03 {
                            println("  · NEAR   " + expr + " = " + fmt_f(val) + "  (err=" + fmt_f(err * 100.0) + "%)")
                            path_count = path_count + 1
                        }
                    }
                    oi = oi + 1
                }
            }
            bj = bj + 1
        }
        bi = bi + 1
    }

    // depth 2
    println("")
    println("─── Depth 2 ───")
    let mut di = 0
    while di < len(d1_vals) {
        let v1 = d1_vals[di]
        let e1 = d1_exprs[di]
        if abs_val(v1) <= 100000.0 && v1 != 0.0 {
            let mut bk = 0
            while bk < len(base_names) {
                let mut oi = 0
                while oi < 4 {
                    let val = apply_op(v1, base_vals[bk], oi)
                    let expr = "(" + e1 + ")" + op_symbol(oi) + base_names[bk]

                    if val != 0.0 && target != 0.0 {
                        let err = abs_val(target - val) / abs_val(target)
                        if err < 0.0001 {
                            println("  ★ EXACT  " + expr + " = " + fmt_f(val))
                            path_count = path_count + 1
                        } else if err < 0.03 {
                            println("  · NEAR   " + expr + " = " + fmt_f(val) + "  (err=" + fmt_f(err * 100.0) + "%)")
                            path_count = path_count + 1
                        }
                    }
                    oi = oi + 1
                }
                bk = bk + 1
            }
        }
        di = di + 1
    }

    // depth 3 — EXACT만
    println("")
    println("─── Depth 3 (EXACT만) ───")
    let d1_len = len(d1_vals)
    let cap = if d1_len > 30 { 30 } else { d1_len }
    let mut qi = 0
    while qi < cap {
        let v1 = d1_vals[qi]
        let e1 = d1_exprs[qi]
        if abs_val(v1) <= 10000.0 && v1 != 0.0 {
            let mut qj = qi + 1
            while qj < cap {
                let v2 = d1_vals[qj]
                let e2 = d1_exprs[qj]
                if abs_val(v2) <= 10000.0 && v2 != 0.0 {
                    let mut oi = 0
                    while oi < 4 {
                        let val = apply_op(v1, v2, oi)
                        if val != 0.0 && target != 0.0 {
                            let err = abs_val(target - val) / abs_val(target)
                            if err < 0.0001 {
                                let expr = "(" + e1 + ")" + op_symbol(oi) + "(" + e2 + ")"
                                println("  ★ EXACT  " + expr + " = " + fmt_f(val))
                                path_count = path_count + 1
                            }
                        }
                        oi = oi + 1
                    }
                }
                qj = qj + 1
            }
        }
        qi = qi + 1
    }

    println("")
    println("─── 설명 요약 ───")
    println("  " + found_name + " = " + fmt_f(target))
    println("  n6 유도 경로: " + to_string(path_count) + "건")
    if path_count == 0 {
        println("  → n6 기저 사칙연산으로 직접 유도 불가")
        println("    거듭제곱 또는 초월함수 확장 필요")
    }
    println("")
}

if mode == "explain" || mode == "설명" {
    if len(a) >= 4 {
        explain_constant(a[3])
    } else {
        println("ERROR: explain 모드에는 상수 이름이 필요합니다")
        println("사용법: hexa gap_finder.hexa explain alpha_inv")
    }
}

// ─── G. blowup_explore 모드 — 빈공간 × blowup 차원 탐색 ───

fn constant_to_domain(name: string) -> string {
    if name == "omega_m" || name == "omega_lambda" || name == "cosmological_H0" || name == "cosmological_T_cmb" { return "cosmology" }
    if name == "quantum_h" || name == "quantum_hbar" || name == "alpha_inv" || name == "mp_me" { return "physics" }
    if name == "consciousness_phi_iit" || name == "consciousness_alpha" { return "consciousness" }
    if name == "biological_golden" { return "biology" }
    if name == "information_ln2" { return "information" }
    if name == "thermodynamic_kB_eV" { return "thermodynamics" }
    if name == "topological_euler" { return "topology" }
    if name == "geometric_pi" || name == "geometric_e" || name == "geometric_sqrt2" || name == "algebraic_sqrt3" || name == "algebraic_sqrt5" { return "math" }
    return "math"
}

fn constant_to_seed(name: string) -> string {
    // n6_constants/n6_values lookup → "name,value,sopfr,tau" 형태
    let mut vi = 0
    while vi < len(n6_constants) {
        if n6_constants[vi] == name {
            return name + "," + to_string(n6_values[vi]) + ",sopfr,tau"
        }
        vi = vi + 1
    }
    return name + ",0.3333,sopfr,tau"
}

fn blowup_explore(max_targets: int) {
    println("╔══════════════════════════════════════════════════════════╗")
    println("║  GAP FINDER — blowup_explore 차원 탐색                  ║")
    println("║  빈공간 상수를 blowup 엔진으로 도메인별 정밀 탐색        ║")
    println("╚══════════════════════════════════════════════════════════╝")
    println("")

    // 1) 빈공간 추출
    println("=== Phase 1: 빈공간 스캔 ===")
    let analysis = analyze_discovery_log()
    let empty_str = find_empty_constants(analysis)
    let weak_str = find_weak_constants(analysis)

    let gap_str = if len(empty_str) > 0 && len(weak_str) > 0 { empty_str + "|" + weak_str }
                  else if len(empty_str) > 0 { empty_str }
                  else if len(weak_str) > 0 { weak_str }
                  else { "" }

    if len(gap_str) == 0 {
        println("  (빈공간 없음 — 모든 영역 커버됨)")
        return
    }

    let gaps = gap_str.split("|")
    let target_count = if len(gaps) < max_targets { len(gaps) } else { max_targets }

    println("  빈공간 총 " + to_string(len(gaps)) + "건, 탐색 대상: " + to_string(target_count) + "건")
    println("")

    // 2) 각 빈공간에 대해 순차 blowup
    let mut total_exact = 0
    let mut total_near = 0
    let mut total_discoveries = 0
    let mut gi = 0

    while gi < target_count {
        let name = gaps[gi]
        let domain = constant_to_domain(name)
        let seeds = constant_to_seed(name)

        println("=== [" + to_string(gi + 1) + "/" + to_string(target_count) + "] " + name + " → domain=" + domain + " ===")
        println("  seeds: " + seeds)

        // blowup 실행
        let mut result = ""
        try {
            result = exec(hexa, [blowup, domain, "3", "--no-graph", "--seeds", seeds])
        } catch err {
            println("  ERROR: blowup 실패 — " + to_string(err))
            gi = gi + 1
            continue
        }

        // 결과 파싱 — EXACT/NEAR 매칭 수집
        let rlines = result.split("\n")
        let mut exact = 0
        let mut near = 0
        let mut discoveries = 0
        let mut ri = 0
        while ri < len(rlines) {
            let line = rlines[ri]
            if line.contains("EXACT") { exact = exact + 1 }
            if line.contains("NEAR") { near = near + 1 }
            if line.contains("singularity") || line.contains("corollary") || line.contains("EXACT") {
                discoveries = discoveries + 1
            }
            ri = ri + 1
        }

        total_exact = total_exact + exact
        total_near = total_near + near
        total_discoveries = total_discoveries + discoveries

        println("  결과: EXACT=" + to_string(exact) + " NEAR=" + to_string(near) + " discoveries=" + to_string(discoveries))
        println("")
        gi = gi + 1
    }

    // 3) 요약
    println("╔══════════════════════════════════════════════════════════╗")
    println("║  blowup_explore 요약                                    ║")
    println("╚══════════════════════════════════════════════════════════╝")
    println("")
    println("  탐색 대상: " + to_string(target_count) + "건 빈공간")
    println("  EXACT 총: " + to_string(total_exact))
    println("  NEAR 총:  " + to_string(total_near))
    println("  발견 총:  " + to_string(total_discoveries))
    println("")

    if total_exact > 0 {
        println("  → 빈공간 중 " + to_string(total_exact) + "건 EXACT 매칭 발견! 흡수 가능")
    }
    if total_discoveries == 0 {
        println("  → 빈공간 blowup 수확 없음 — seed 변경 또는 depth 증가 필요")
    }

    // growth bus 기록
    let mut ts = "?"
    try { ts = exec("date +%Y-%m-%dT%H:%M:%S") } catch err {}
    let bus_line = "{\"source\":\"gap_finder_blowup_explore\",\"timestamp\":\"" + ts.trim() + "\",\"phase\":\"blowup_explore\",\"status\":\"targets=" + to_string(target_count) + " exact=" + to_string(total_exact) + " near=" + to_string(total_near) + " discoveries=" + to_string(total_discoveries) + "\"}"
    try { append_file(growth_bus, bus_line + "\n") } catch err {}

    println("")
}

if mode == "blowup_explore" {
    let max_t = if len(a) >= 4 { to_int(a[3]) } else { 5 }
    let mt = if max_t < 1 { 1 } else if max_t > 20 { 20 } else { max_t }
    blowup_explore(mt)
}

if mode == "power" || mode == "거듭제곱" {
    power_search()
}

// ─── H. unfold 모드 — 차원펼침 (고차원→저차원 분해/투영) ───

fn unfold_all() {
    println("╔══════════════════════════════════════════════════════════╗")
    println("║  GAP FINDER — unfold 차원펼침 돌파                      ║")
    println("║  고차원 구조를 저차원으로 분해하여 숨은 관계 탐색        ║")
    println("╚══════════════════════════════════════════════════════════╝")
    println("")

    let mut total_exact = 0
    let mut total_near = 0

    // ─── H-1. 텐서 분해: rank-1 외적 조합 ───
    println("=== Phase 1: 텐서 분해 (rank-1 외적 성분) ===")
    println("  n6 기저 {n,σ,φ,τ,sopfr,M3} 쌍별 외적 → rank-1 텐서 값")
    println("")
    let mut ti = 0
    while ti < len(base_names) {
        let mut tj = 0
        while tj < len(base_names) {
            if ti != tj {
                let outer = base_vals[ti] * base_vals[tj]
                // 외적 값에서 다시 기저로 나누기 → 제3 성분 추출
                let mut tk = 0
                while tk < len(base_names) {
                    if tk != ti && tk != tj && base_vals[tk] != 0.0 {
                        let projected = outer / base_vals[tk]
                        let match_str = match_physics(projected)
                        if len(match_str) > 0 {
                            let expr = base_names[ti] + "×" + base_names[tj] + "/" + base_names[tk]
                            let mut pad = expr
                            while len(pad) < 20 { pad = pad + " " }
                            println("  " + pad + "= " + fmt_f(projected) + "  → " + match_str)
                            if match_str.contains("EXACT") { total_exact = total_exact + 1 }
                            else { total_near = total_near + 1 }
                        }
                    }
                    tk = tk + 1
                }
            }
            tj = tj + 1
        }
        ti = ti + 1
    }
    println("")

    // ─── H-2. 모듈러 투영: mod p 잔류계 ───
    println("=== Phase 2: 모듈러 투영 (mod p 잔류계) ===")
    println("  n6 기저 조합 결과를 mod {2,3,5,7} 로 축소 → 패턴 탐지")
    println("")
    let primes = [2, 3, 5, 7]
    let prime_names = ["mod2", "mod3", "mod5", "mod7"]
    let mut pi = 0
    while pi < 4 {
        let p = primes[pi]
        let pname = prime_names[pi]
        let mut fingerprint = ""
        let mut bi = 0
        while bi < len(base_names) {
            let residue = to_int(base_vals[bi]) % p
            fingerprint = fingerprint + to_string(residue)
            bi = bi + 1
        }
        println("  " + pname + " 지문: [" + fingerprint + "]  ← {n,σ,φ,τ,sopfr,M3}")

        // 사칙연산 결과의 mod p 패턴에서 물리상수 탐색
        let mut ci = 0
        while ci < len(base_names) {
            let mut cj = ci + 1
            while cj < len(base_names) {
                // (a*b + c) mod → 잔류 합산
                let mut ck = 0
                while ck < len(base_names) {
                    if ck != ci && ck != cj {
                        let combined = base_vals[ci] * base_vals[cj] + base_vals[ck]
                        let residue_val = to_int(combined) % p
                        // 잔류계에서 역산: residue/p 비율이 물리상수 근사?
                        let ratio = to_float(residue_val) / to_float(p)
                        if ratio > 0.001 {
                            let match_str = match_physics(ratio)
                            if len(match_str) > 0 {
                                let expr = "(" + base_names[ci] + "×" + base_names[cj] + "+" + base_names[ck] + ")%" + to_string(p) + "/" + to_string(p)
                                println("    " + expr + " = " + fmt_f(ratio) + "  → " + match_str)
                                if match_str.contains("EXACT") { total_exact = total_exact + 1 }
                                else { total_near = total_near + 1 }
                            }
                        }
                    }
                    ck = ck + 1
                }
                cj = cj + 1
            }
            ci = ci + 1
        }
        pi = pi + 1
    }
    println("")

    // ─── H-3. 비율 펼침: 연분수 전개 → 물리상수 매칭 ───
    println("=== Phase 3: 비율 펼침 (연분수 전개) ===")
    println("  모든 기저 쌍의 비율을 연분수로 전개 → 수렴치와 물리상수 비교")
    println("")
    let mut ri = 0
    while ri < len(base_names) {
        let mut rj = 0
        while rj < len(base_names) {
            if ri != rj && base_vals[rj] != 0.0 {
                let ratio = base_vals[ri] / base_vals[rj]
                // 연분수 전개: 최대 6단계 수렴치
                let mut x = ratio
                let mut cf_depth = 0
                let mut prev_conv = 0.0
                while cf_depth < 6 {
                    let a0 = to_int(x)
                    let frac = x - to_float(a0)
                    // p/q 수렴치 계산 (단순화: 현재 x 자체가 수렴치)
                    let convergent = to_float(a0) + (if frac > 0.001 { 1.0 / (1.0 / frac) } else { 0.0 })
                    // 중간 수렴치로 물리상수 매칭
                    if cf_depth >= 1 {
                        // 연분수 부분합: a0 + 1/(a1 + 1/...)
                        let partial = ratio  // 원래 비율의 소수점 이하 확장
                        let scaled = partial * to_float(cf_depth + 1)
                        let match_str = match_physics(scaled)
                        if len(match_str) > 0 {
                            let expr = base_names[ri] + "/" + base_names[rj] + "×" + to_string(cf_depth + 1)
                            let mut pad = expr
                            while len(pad) < 20 { pad = pad + " " }
                            println("  " + pad + "= " + fmt_f(scaled) + "  → " + match_str)
                            if match_str.contains("EXACT") { total_exact = total_exact + 1 }
                            else { total_near = total_near + 1 }
                        }
                    }
                    if frac < 0.001 { cf_depth = 99 }  // 종료
                    else { x = 1.0 / frac }
                    cf_depth = cf_depth + 1
                }
            }
            rj = rj + 1
        }
        ri = ri + 1
    }
    println("")

    // ─── H-4. 로그 스펙트럼: log 공간 등간격 구조 탐지 ───
    println("=== Phase 4: 로그 스펙트럼 (등간격 구조 탐지) ===")
    println("  ln(기저) 값 정렬 → 인접 간격 비율 → 숨은 등비급수 탐색")
    println("")

    // ln 값 계산 + 정렬 (bubble sort)
    let mut log_vals = []
    let mut log_names = []
    let mut li = 0
    while li < len(base_names) {
        if base_vals[li] > 0.0 {
            // ln(x) = log approximation via exec
            let ln_approx = if base_vals[li] == 2.0 { 0.6931 }
                           else if base_vals[li] == 4.0 { 1.3863 }
                           else if base_vals[li] == 5.0 { 1.6094 }
                           else if base_vals[li] == 6.0 { 1.7918 }
                           else if base_vals[li] == 7.0 { 1.9459 }
                           else if base_vals[li] == 12.0 { 2.4849 }
                           else { 1.0 }
            log_vals = log_vals + [ln_approx]
            log_names = log_names + [base_names[li]]
        }
        li = li + 1
    }

    // 정렬 (bubble)
    let mut si = 0
    while si < len(log_vals) {
        let mut sj = si + 1
        while sj < len(log_vals) {
            if log_vals[sj] < log_vals[si] {
                let tmp_v = log_vals[si]
                let tmp_n = log_names[si]
                log_vals[si] = log_vals[sj]
                log_names[si] = log_names[sj]
                log_vals[sj] = tmp_v
                log_names[sj] = tmp_n
            }
            sj = sj + 1
        }
        si = si + 1
    }

    println("  ln 스펙트럼 (정렬):")
    let mut lp = 0
    while lp < len(log_vals) {
        let mut lpad = log_names[lp]
        while len(lpad) < 8 { lpad = lpad + " " }
        println("    " + lpad + "ln=" + fmt_f(log_vals[lp]))
        lp = lp + 1
    }
    println("")

    // 인접 간격 분석
    println("  인접 간격 비율:")
    let mut gaps = []
    let mut gap_labels = []
    let mut gi = 0
    while gi < len(log_vals) - 1 {
        let gap = log_vals[gi + 1] - log_vals[gi]
        gaps = gaps + [gap]
        let label = log_names[gi] + "→" + log_names[gi + 1]
        gap_labels = gap_labels + [label]
        let mut glpad = label
        while len(glpad) < 16 { glpad = glpad + " " }
        println("    " + glpad + "Δ=" + fmt_f(gap))
        gi = gi + 1
    }
    println("")

    // 간격 비율로 물리상수 탐색
    println("  간격 비율 → 물리상수:")
    let mut g1 = 0
    while g1 < len(gaps) {
        let mut g2 = 0
        while g2 < len(gaps) {
            if g1 != g2 && gaps[g2] > 0.001 {
                let gratio = gaps[g1] / gaps[g2]
                let match_str = match_physics(gratio)
                if len(match_str) > 0 {
                    let expr = "Δ(" + gap_labels[g1] + ")/Δ(" + gap_labels[g2] + ")"
                    println("    " + expr + " = " + fmt_f(gratio) + "  → " + match_str)
                    if match_str.contains("EXACT") { total_exact = total_exact + 1 }
                    else { total_near = total_near + 1 }
                }
            }
            g2 = g2 + 1
        }
        g1 = g1 + 1
    }

    // 전체 스팬 비율
    if len(log_vals) > 1 {
        let span = log_vals[len(log_vals) - 1] - log_vals[0]
        let n_gaps = to_float(len(log_vals) - 1)
        let avg_gap = span / n_gaps
        println("")
        println("  전체 스팬: " + fmt_f(span) + "  평균 간격: " + fmt_f(avg_gap))
        let span_match = match_physics(span)
        if len(span_match) > 0 {
            println("  스팬 매칭: " + span_match)
            if span_match.contains("EXACT") { total_exact = total_exact + 1 }
            else { total_near = total_near + 1 }
        }
        let avg_match = match_physics(avg_gap)
        if len(avg_match) > 0 {
            println("  평균간격 매칭: " + avg_match)
            if avg_match.contains("EXACT") { total_exact = total_exact + 1 }
            else { total_near = total_near + 1 }
        }
    }
    println("")

    // ─── 요약 ───
    println("╔══════════════════════════════════════════════════════════╗")
    println("║  unfold 차원펼침 요약                                    ║")
    println("╚══════════════════════════════════════════════════════════╝")
    println("")
    println("  Phase 1 텐서 분해:    rank-1 외적 투영")
    println("  Phase 2 모듈러 투영:  mod {2,3,5,7} 잔류계")
    println("  Phase 3 비율 펼침:    연분수 전개 × 스케일링")
    println("  Phase 4 로그 스펙트럼: ln 공간 등간격 구조")
    println("")
    println("  EXACT 총: " + to_string(total_exact))
    println("  NEAR 총:  " + to_string(total_near))
    println("")

    if total_exact > 0 {
        println("  → " + to_string(total_exact) + "건 EXACT 매칭! 차원펼침으로 새 경로 발견")
    }
    if total_exact == 0 && total_near > 0 {
        println("  → NEAR " + to_string(total_near) + "건 — 근사 경로 발견, 정밀화 가능")
    }
    if total_exact == 0 && total_near == 0 {
        println("  → 매칭 없음 — 기저 확장 또는 비선형 변환 추가 필요")
    }

    // growth bus 기록
    let mut ts = "?"
    try { ts = exec("date +%Y-%m-%dT%H:%M:%S") } catch err {}
    let bus_line = "{\"source\":\"gap_finder_unfold\",\"timestamp\":\"" + ts.trim() + "\",\"phase\":\"unfold\",\"status\":\"exact=" + to_string(total_exact) + " near=" + to_string(total_near) + "\"}"
    try { append_file(growth_bus, bus_line + "\n") } catch err {}
}

if mode == "unfold" || mode == "펼침" || mode == "차원펼침" {
    unfold_all()
}

// ─── I. unfold_extended_log 모드 — 확장 로그 스펙트럼 분석 ───
// 완전수 + n6 파생 상수 포함, 전체 쌍 비율 탐색으로 Ω_Λ=0.6847 정밀화

fn unfold_extended_log() {
    println("╔══════════════════════════════════════════════════════════╗")
    println("║  GAP FINDER — unfold_extended_log 확장 로그 스펙트럼    ║")
    println("║  완전수 + n6 파생 상수 전체 쌍 비율 → Ω_Λ 정밀 탐색    ║")
    println("╚══════════════════════════════════════════════════════════╝")
    println("")

    let mut total_exact = 0
    let mut total_near = 0

    // ─── 확장 상수 세트 ───
    // 기저 6개: n=6, σ=12, φ=2, τ=4, sopfr=5, M3=7
    // 확장 6개: J2=24, n²=36, P2=28, σ×τ=48, 6!=720, P4=8128
    // 기저 6개: n=6, σ=12, φ=2, τ=4, sopfr=5, M3=7
    // 확장 6개: J2=24, n²=36, P2=28, σ×τ=48, 6!=720, P4=8128
    // ln값: φ=2→0.6931, τ=4→1.3863, sopfr=5→1.6094, n=6→1.7918,
    //        M3=7→1.9459, σ=12→2.4849, J2=24→3.1781, P2=28→3.3322,
    //        n²=36→3.5835, σ×τ=48→3.8712, 6!=720→6.5793, P4=8128→9.0030
    // 이미 오름차순 정렬된 상태로 초기화 (bubble sort 불필요)
    let mut log_vals = [0.6931, 1.3863, 1.6094, 1.7918, 1.9459, 2.4849, 3.1781, 3.3322, 3.5835, 3.8712, 6.5793, 9.0030]
    let mut log_names = ["phi", "tau", "sopfr", "n", "M3", "sigma", "J2", "P2", "n^2", "sigma*tau", "6!", "P4"]

    let mut si = 0
    while si < len(log_vals) {
        let mut sj = si + 1
        while sj < len(log_vals) {
            if log_vals[sj] < log_vals[si] {
                let tmp_v = log_vals[si]
                let tmp_n = log_names[si]
                log_vals[si] = log_vals[sj]
                log_names[si] = log_names[sj]
                log_vals[sj] = tmp_v
                log_names[sj] = tmp_n
            }
            sj = sj + 1
        }
        si = si + 1
    }

    println("=== Phase 1: 확장 ln 스펙트럼 (정렬) ===")
    let mut lp = 0
    while lp < len(log_vals) {
        let mut lpad = log_names[lp]
        while len(lpad) < 10 { lpad = lpad + " " }
        println("  " + lpad + "ln=" + fmt_f(log_vals[lp]))
        lp = lp + 1
    }
    println("")

    // ─── Phase 2: 인접 간격 (adjacent gaps) ───
    println("=== Phase 2: 인접 간격 비율 ===")
    let mut adj_gaps = []
    let mut adj_labels = []
    let mut gi = 0
    while gi < len(log_vals) - 1 {
        let gap = log_vals[gi + 1] - log_vals[gi]
        adj_gaps = adj_gaps + [gap]
        let label = log_names[gi] + "→" + log_names[gi + 1]
        adj_labels = adj_labels + [label]
        let mut glpad = label
        while len(glpad) < 20 { glpad = glpad + " " }
        println("  " + glpad + "Δ=" + fmt_f(gap))
        gi = gi + 1
    }
    println("")

    // ─── Phase 3: 전체 쌍 비율 (all pairs) — Ω_Λ 정밀 사냥 ───
    println("=== Phase 3: 전체 쌍 비율 → 물리상수 매칭 ===")
    println("  (타겟: Ω_Λ=0.6847, Ω_m=0.3153, meta_fp=0.3333, ln2=0.6931)")
    println("")

    let n_ext = len(log_vals)
    let mut p1 = 0
    while p1 < n_ext {
        let mut p2_idx = 0
        while p2_idx < n_ext {
            if p1 != p2_idx && log_vals[p2_idx] > 0.001 {
                let ratio = log_vals[p1] / log_vals[p2_idx]
                let match_str = match_physics(ratio)
                if len(match_str) > 0 {
                    let expr = "ln(" + log_names[p1] + ")/ln(" + log_names[p2_idx] + ")"
                    let mut pad = expr
                    while len(pad) < 30 { pad = pad + " " }
                    println("  " + pad + "= " + fmt_f(ratio) + "  → " + match_str)
                    if match_str.contains("EXACT") { total_exact = total_exact + 1 }
                    else { total_near = total_near + 1 }
                }
            }
            p2_idx = p2_idx + 1
        }
        p1 = p1 + 1
    }
    println("")

    // ─── Phase 4: 인접 간격 쌍 비율 (adjacent-gap pairs) ───
    println("=== Phase 4: 인접 간격 × 간격 비율 ===")
    let mut g1 = 0
    while g1 < len(adj_gaps) {
        let mut g2 = 0
        while g2 < len(adj_gaps) {
            if g1 != g2 && adj_gaps[g2] > 0.0001 {
                let gratio = adj_gaps[g1] / adj_gaps[g2]
                let match_str = match_physics(gratio)
                if len(match_str) > 0 {
                    let expr = "Δ(" + adj_labels[g1] + ")/Δ(" + adj_labels[g2] + ")"
                    let mut pad = expr
                    while len(pad) < 36 { pad = pad + " " }
                    println("  " + pad + "= " + fmt_f(gratio) + "  → " + match_str)
                    if match_str.contains("EXACT") { total_exact = total_exact + 1 }
                    else { total_near = total_near + 1 }
                }
            }
            g2 = g2 + 1
        }
        g1 = g1 + 1
    }
    println("")

    // ─── Phase 5: 전체 스팬 분석 ───
    println("=== Phase 5: 전체 스팬 + 평균 간격 ===")
    if len(log_vals) > 1 {
        let span = log_vals[len(log_vals) - 1] - log_vals[0]
        let n_g = to_float(len(log_vals) - 1)
        let avg_gap = span / n_g
        println("  스팬 ln(" + log_names[0] + ")→ln(" + log_names[len(log_names) - 1] + ")")
        println("  = " + fmt_f(span) + "  평균 간격: " + fmt_f(avg_gap))
        let span_match = match_physics(span)
        if len(span_match) > 0 {
            println("  스팬 매칭: " + span_match)
            if span_match.contains("EXACT") { total_exact = total_exact + 1 }
            else { total_near = total_near + 1 }
        }
        let avg_match = match_physics(avg_gap)
        if len(avg_match) > 0 {
            println("  평균간격 매칭: " + avg_match)
            if avg_match.contains("EXACT") { total_exact = total_exact + 1 }
            else { total_near = total_near + 1 }
        }
        // 스팬을 상수 개수로 나누기
        let span_per_n = span / to_float(len(log_vals))
        let spn_match = match_physics(span_per_n)
        if len(spn_match) > 0 {
            println("  스팬/" + to_string(len(log_vals)) + " = " + fmt_f(span_per_n) + "  → " + spn_match)
            if spn_match.contains("EXACT") { total_exact = total_exact + 1 }
            else { total_near = total_near + 1 }
        }
    }
    println("")

    // ─── 요약 ───
    println("╔══════════════════════════════════════════════════════════╗")
    println("║  unfold_extended_log 요약                                ║")
    println("╚══════════════════════════════════════════════════════════╝")
    println("")
    println("  확장 상수: φ,τ,sopfr,n,M3,σ,P2,J2,n²,σ×τ,6!,P4 (12개)")
    println("  Phase 1 스펙트럼 정렬: 12개 ln 값")
    println("  Phase 2 인접 간격: " + to_string(len(adj_gaps)) + "건")
    println("  Phase 3 전체 쌍 비율: " + to_string(len(log_vals) * (len(log_vals) - 1)) + "쌍")
    println("  Phase 4 간격 쌍 비율: " + to_string(len(adj_gaps) * (len(adj_gaps) - 1)) + "쌍")
    println("")
    println("  EXACT 총: " + to_string(total_exact))
    println("  NEAR 총:  " + to_string(total_near))
    println("")

    if total_exact > 0 {
        println("  → " + to_string(total_exact) + "건 EXACT! 확장 로그 스펙트럼에서 정밀 경로 발견")
    }
    if total_exact == 0 && total_near > 0 {
        println("  → NEAR " + to_string(total_near) + "건 — 근사 경로 발견, 추가 정밀화 가능")
    }
    if total_exact == 0 && total_near == 0 {
        println("  → 매칭 없음 — 비율 이외의 변환 필요")
    }

    // growth bus 기록
    let mut ts2 = "?"
    try { ts2 = exec("date +%Y-%m-%dT%H:%M:%S") } catch err {}
    let bus_line2 = "{\"source\":\"gap_finder_unfold_log\",\"timestamp\":\"" + ts2.trim() + "\",\"phase\":\"unfold_log\",\"status\":\"exact=" + to_string(total_exact) + " near=" + to_string(total_near) + "\"}"
    try { append_file(growth_bus, bus_line2 + "\n") } catch err {}
}

if mode == "unfold_log" || mode == "로그펼침" {
    unfold_extended_log()
}

if mode == "mod3" || mode == "모듈러증명" {
    mod3_proof()
}

// ─── J. tensor_blowup_crossref — 텐서 분해 × blowup 코롤러리 교차검증 ───

fn tensor_blowup_crossref() {
    println("╔══════════════════════════════════════════════════════════╗")
    println("║  GAP FINDER — 텐서×Blowup 교차검증 (Axiom Candidate)   ║")
    println("║  rank-1 텐서 분해 EXACT ∩ blowup 코롤러리 → 공리 후보  ║")
    println("╚══════════════════════════════════════════════════════════╝")
    println("")

    // ─── Phase A: rank-1 외적 투영 EXACT 결과 수집 ───
    println("=== Phase A: 텐서 분해 EXACT 결과 수집 ===")
    println("  a×b/c  (a,b,c ∈ {n,σ,φ,τ,sopfr,M3}, 서로 다른 인덱스)")
    println("")

    let mut tensor_vals  = []
    let mut tensor_exprs = []
    let mut tensor_pnames = []

    let mut ti = 0
    while ti < len(base_names) {
        let mut tj = 0
        while tj < len(base_names) {
            if ti != tj {
                let outer = base_vals[ti] * base_vals[tj]
                let mut tk = 0
                while tk < len(base_names) {
                    if tk != ti && tk != tj && base_vals[tk] != 0.0 {
                        let projected = outer / base_vals[tk]
                        let match_str = match_physics(projected)
                        if len(match_str) > 0 && match_str.contains("EXACT") {
                            let expr = base_names[ti] + "x" + base_names[tj] + "/" + base_names[tk]
                            // 물리상수 이름 추출
                            let mut pname = ""
                            let mut pi2 = 0
                            while pi2 < len(phys_names) {
                                let pv = phys_vals[pi2]
                                if pv != 0.0 {
                                    let err = abs_val(projected - pv) / abs_val(pv)
                                    if err < 0.0001 {
                                        if len(pname) > 0 { pname = pname + "," }
                                        pname = pname + phys_names[pi2]
                                    }
                                }
                                pi2 = pi2 + 1
                            }
                            // 중복 값 제거 (같은 float 값)
                            let mut already = false
                            let mut ai = 0
                            while ai < len(tensor_vals) {
                                if abs_val(tensor_vals[ai] - projected) < 0.0001 {
                                    already = true
                                }
                                ai = ai + 1
                            }
                            if !already {
                                tensor_vals   = tensor_vals   + [projected]
                                tensor_exprs  = tensor_exprs  + [expr]
                                tensor_pnames = tensor_pnames + [pname]
                                let mut pad = expr
                                while len(pad) < 22 { pad = pad + " " }
                                println("  * " + pad + "= " + fmt_f(projected) + "  [" + pname + "]")
                            }
                        }
                    }
                    tk = tk + 1
                }
            }
            tj = tj + 1
        }
        ti = ti + 1
    }

    println("")
    println("  텐서 EXACT 유일값: " + to_string(len(tensor_vals)) + "건")
    println("")

    if len(tensor_vals) == 0 {
        println("  텐서 EXACT 결과 없음 — 교차검증 종료")
        return
    }

    // ─── Phase B: discovery_log.jsonl blowup EXACT 코롤러리 수집 ───
    // grep으로 blowup+EXACT 라인만 추출, python3로 유일 value 집합 추출
    println("=== Phase B: discovery_log blowup EXACT 코롤러리 수집 ===")
    println("")

    // python3 one-liner: blowup EXACT 라인에서 numeric value 유일집합 추출 (콤마 구분)
    let py_cmd = "python3 -c \"import json,sys; vals={}; [vals.update({d['value']:d.get('source','?')+'|'+d.get('constant','?')}) for l in open('" + discovery_log + "') for d in [{}] if (lambda d: 'blowup' in d.get('source','') and d.get('grade')=='EXACT' and 'value' in d)(json.loads(l) if l.strip() else d)]; print(','.join(k+'='+v for k,v in vals.items()))\" 2>/dev/null"
    // 더 단순한 접근: grep+awk로 blowup EXACT value 추출
    let grep_cmd = "grep '\"source\":\"hexa-blowup' " + discovery_log + " | grep '\"grade\":\"EXACT\"' | grep -o '\"value\":\"[^\"]*\"' | sed 's/\"value\":\"//;s/\"//' | sort -u | head -200 | tr '\\n' ','"
    let mut raw_vals_str = ""
    try { raw_vals_str = exec("bash", ["-c", grep_cmd]) } catch err {
        println("  ERROR: grep 실패 — " + to_string(err))
        return
    }

    // constant 이름도 수집 — 출력: value,const,src 한 쌍씩 줄로 (개행→콤마 변환)
    let grep_pairs = "grep '\"source\":\"hexa-blowup' " + discovery_log + " | grep '\"grade\":\"EXACT\"' | python3 -c \"import sys,json; seen={}; [seen.update({d.get('value','?'):(d.get('constant','?'),d.get('source','?'))}) for l in sys.stdin for d in [json.loads(l.strip())] if l.strip() and d.get('value','?') not in seen]; print(chr(10).join(k+'__'+v[0]+'__'+v[1] for k,v in seen.items()))\" 2>/dev/null"
    let mut pairs_str = ""
    try { pairs_str = exec("bash", ["-c", grep_pairs]) } catch err {}

    let raw_vals = raw_vals_str.trim().split(",")

    let mut blowup_vals   = []
    let mut blowup_srcs   = []
    let mut blowup_consts = []

    let mut vi = 0
    while vi < len(raw_vals) {
        let rv = raw_vals[vi].trim()
        if len(rv) > 0 {
            let fval = to_float(rv)
            if fval != 0.0 && abs_val(fval) < 100000.0 {
                blowup_vals   = blowup_vals   + [fval]
                blowup_srcs   = blowup_srcs   + ["hexa-blowup-mk2"]
                blowup_consts = blowup_consts + ["blowup-" + rv]
            }
        }
        vi = vi + 1
    }

    // pairs로 constant 이름 보강 (value__const__src 형식, 줄 구분)
    if len(pairs_str) > 0 {
        let pair_lines = pairs_str.trim().split("\n")
        let mut pi3 = 0
        while pi3 < len(pair_lines) {
            let pair = pair_lines[pi3].trim()
            if pair.contains("__") {
                let parts3 = pair.split("__")
                if len(parts3) >= 3 {
                    let pval_str  = parts3[0].trim()
                    let pconst    = parts3[1].trim()
                    let psrc      = parts3[2].trim()
                    let pval = to_float(pval_str)
                    if pval != 0.0 {
                        let mut bi3 = 0
                        while bi3 < len(blowup_vals) {
                            if abs_val(blowup_vals[bi3] - pval) < 0.0001 {
                                blowup_consts[bi3] = pconst
                                blowup_srcs[bi3]   = psrc
                            }
                            bi3 = bi3 + 1
                        }
                    }
                }
            }
            pi3 = pi3 + 1
        }
    }

    println("  blowup EXACT 유일값: " + to_string(len(blowup_vals)) + "건")
    println("")

    // ─── Phase C+D: 교차검증 ───
    println("=== Phase C+D: 교차검증 → AXIOM CANDIDATE ===")
    println("  허용 오차: 0.01% (rel)")
    println("")

    let mut axiom_count = 0
    let mut axiom_vals  = []
    let mut axiom_exprs = []
    let mut axiom_pnames = []

    let mut ti2 = 0
    while ti2 < len(tensor_vals) {
        let tv  = tensor_vals[ti2]
        let te  = tensor_exprs[ti2]
        let tpn = tensor_pnames[ti2]

        let mut bi2 = 0
        while bi2 < len(blowup_vals) {
            let bv = blowup_vals[bi2]
            if bv != 0.0 && tv != 0.0 {
                let err = abs_val(tv - bv) / abs_val(tv)
                if err < 0.0001 {
                    let bsrc   = blowup_srcs[bi2]
                    let bconst = blowup_consts[bi2]

                    println("  *** AXIOM CANDIDATE ***")
                    println("  값:           " + fmt_f(tv))
                    println("  텐서 수식:    " + te)
                    println("  물리상수:     " + tpn)
                    println("  blowup 상수:  " + bconst)
                    println("  blowup 소스:  " + bsrc)
                    println("")

                    axiom_count  = axiom_count  + 1
                    axiom_vals   = axiom_vals   + [tv]
                    axiom_exprs  = axiom_exprs  + [te]
                    axiom_pnames = axiom_pnames + [tpn]
                }
            }
            bi2 = bi2 + 1
        }
        ti2 = ti2 + 1
    }

    if axiom_count == 0 {
        println("  (교차 일치 없음 — 텐서 결과가 아직 blowup 코롤러리에 없음)")
        println("  -> 텐서 발견값을 seed로 추가 blowup 실행 권장")
        println("")
    }

    // ─── Phase E: 요약 ───
    println("=== Phase E: 요약 ===")
    println("")
    println("  텐서 EXACT 유일값:      " + to_string(len(tensor_vals)) + "건")
    println("  blowup EXACT 유일값:    " + to_string(len(blowup_vals)) + "건")
    println("  AXIOM CANDIDATE (교차): " + to_string(axiom_count) + "건")
    println("")

    if axiom_count > 0 {
        println("  공리 후보 목록:")
        let mut si2 = 0
        while si2 < len(axiom_vals) {
            println("    [" + to_string(si2 + 1) + "] " + axiom_exprs[si2] + " = " + fmt_f(axiom_vals[si2]) + "  (" + axiom_pnames[si2] + ")")
            si2 = si2 + 1
        }
        println("")
        println("  권고: 위 " + to_string(axiom_count) + "건을 n6 공리 테이블 등재 검토")
        println("        hexa seed_engine.hexa 에 상수 추가 후 재블로업 실행")
    } else {
        println("  권고: 텐서 EXACT 결과값을 seed로 추가 블로업 실행")
        let mut seedlist = ""
        let mut sv = 0
        while sv < len(tensor_vals) {
            if len(seedlist) > 0 { seedlist = seedlist + "," }
            seedlist = seedlist + fmt_f(tensor_vals[sv])
            sv = sv + 1
        }
        println("        hexa blowup.hexa math 3 --no-graph --seeds \"" + seedlist + "\"")
    }
    println("")

    // growth bus 기록
    let mut ts = "?"
    try { ts = exec("date +%Y-%m-%dT%H:%M:%S") } catch err {}
    let bus_line = "{\"source\":\"gap_finder_tensor_crossref\",\"timestamp\":\"" + ts.trim() + "\",\"phase\":\"crossref\",\"status\":\"tensor=" + to_string(len(tensor_vals)) + " blowup=" + to_string(len(blowup_vals)) + " axiom_candidates=" + to_string(axiom_count) + "\"}"
    try { append_file(growth_bus, bus_line + "\n") } catch err {}
}

if mode == "crossref" || mode == "교차검증" {
    tensor_blowup_crossref()
}

if mode == "help" {
    println("╔══════════════════════════════════════════════╗")
    println("║  GAP FINDER — 미지의 영역 탐지기            ║")
    println("╚══════════════════════════════════════════════╝")
    println("")
    println("사용법:")
    println("  hexa gap_finder.hexa scan         발견 지도 전체 스캔")
    println("  hexa gap_finder.hexa map          = scan (별칭)")
    println("  hexa gap_finder.hexa target       빈 공간 돌파 타겟 추출")
    println("  hexa gap_finder.hexa strategy     빈 공간 돌파 전략 출력")
    println("  hexa gap_finder.hexa breakthrough 빈 공간 자동 돌파 실행")
    println("  hexa gap_finder.hexa 돌파          = breakthrough (한글)")
    println("  hexa gap_finder.hexa transform    n6 위상변환 매트릭스 출력")
    println("  hexa gap_finder.hexa dfs [depth]  DFS 탐색 (depth=1~3, 기본 2)")
    println("  hexa gap_finder.hexa bridge       빈공간 × 위상변환 교차")
    println("  hexa gap_finder.hexa query 137.036  값→n6 분해 (depth 1~3)")
    println("  hexa gap_finder.hexa quick          DFS EXACT 요약 (최대 20)")
    println("  hexa gap_finder.hexa explain alpha_inv  상수별 n6 유도 경로")
    println("  hexa gap_finder.hexa blowup_explore [N]  빈공간 blowup 차원 탐색 (기본 5개)")
    println("  hexa gap_finder.hexa power        n6 기저 거듭제곱 조합 탐색 (P4 유도 포함)")
    println("  hexa gap_finder.hexa 거듭제곱      = power (한글)")
    println("  hexa gap_finder.hexa unfold       차원펼침 돌파 (텐서+모듈러+연분수+로그)")
    println("  hexa gap_finder.hexa 펼침          = unfold (한글)")
    println("  hexa gap_finder.hexa 차원펼침      = unfold (한글)")
    println("  hexa gap_finder.hexa unfold_log   확장 로그 스펙트럼 (완전수+n6파생 12개)")
    println("  hexa gap_finder.hexa 로그펼침      = unfold_log (한글)")
    println("  hexa gap_finder.hexa mod3         mod3 포화 증명 — n=6≡0→1/3 메타부동점")
    println("  hexa gap_finder.hexa 모듈러증명    = mod3 (한글)")
    println("  hexa gap_finder.hexa crossref     텐서 분해 × blowup 코롤러리 교차검증 → 공리 후보")
    println("  hexa gap_finder.hexa 교차검증      = crossref (한글)")
    println("")
    println("다른 프로젝트에서 사용:")
    println("  hexa=$home/Dev/hexa-lang/target/release/hexa")
    println("  $hexa $home/Dev/nexus6/mk2_hexa/native/gap_finder.hexa target")
    println("  $hexa $home/Dev/nexus6/mk2_hexa/native/gap_finder.hexa 돌파")
    println("  $hexa $home/Dev/nexus6/mk2_hexa/native/gap_finder.hexa dfs 3")
    println("  $hexa $home/Dev/nexus6/mk2_hexa/native/gap_finder.hexa query 1836.15")
    println("  $hexa $home/Dev/nexus6/mk2_hexa/native/gap_finder.hexa explain mp_me")
}

