// Ported from tecs-l/docs/hypotheses/verify_hcx428.py
// H-CX-428: PureField = Functor (Category Theory)
// Track A: the two functor laws as symbolic predicates applied to the
// two-pole PureField model (engine_a - engine_g). We encode
//   F(id_A) = id_{F(A)}                     — identity law
//   F(g o f) = F(g) o F(f)                  — composition law
// as boolean checks over a single-neuron linear PureField surrogate
// (pure scalar math). The full sklearn MLP training run stays in
// .hexanoport.

// One-pole linear surrogate: forward(x) = a*x + b. This inherits the
// "engine_a - engine_g" structure when a,b are differences of the two
// engines' parameters.
pure fn forward(a: float, b: float, x: float) -> float { a * x + b }

// Identity on the domain
pure fn id_float(x: float) -> float { x }

// Composition of two linears: (a2*x + b2) composed with (a1*x + b1)
// equals (a2*a1)*x + (a2*b1 + b2).
pure fn compose_ab(a1: float, b1: float, a2: float, b2: float, x: float) -> float {
    forward(a2, b2, forward(a1, b1, x))
}
pure fn compose_ab_closed(a1: float, b1: float, a2: float, b2: float, x: float) -> float {
    forward(a2 * a1, a2 * b1 + b2, x)
}

pure fn near(a: float, b: float) -> bool {
    let d = a - b;
    let ad = if d < 0.0 { -d } else { d };
    ad < 0.000001
}

// F(id) = id: plugging a=1, b=0 leaves x unchanged.
pure fn functor_identity_law(x: float) -> bool {
    near(forward(1.0, 0.0, x), id_float(x))
}

// F(g o f) = F(g) o F(f)
pure fn functor_composition_law(a1: float, b1: float, a2: float, b2: float, x: float) -> bool {
    near(compose_ab(a1, b1, a2, b2, x), compose_ab_closed(a1, b1, a2, b2, x))
}

fn main() {
    print("identity law @ 0.7: ");
    print(functor_identity_law(0.7)); print("\n");
    print("composition law @ (2,1,3,-4,5): ");
    print(functor_composition_law(2.0, 1.0, 3.0, -4.0, 5.0)); print("\n");
    print("composition law @ (0.5,0.2,-1.3,0.7,0.9): ");
    print(functor_composition_law(0.5, 0.2, -1.3, 0.7, 0.9)); print("\n");
}
