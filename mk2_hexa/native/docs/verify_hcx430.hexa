// Ported from tecs-l/docs/hypotheses/verify_hcx430.py
// H-CX-430: Mitosis = Coproduct (Category Theory)
// Track A: N=2 = sigma_{-1}(6) = 2 optimality check (pure integer math,
// plus closed-form efficiency = accuracy / N). The MLP PureField model
// used to measure empirical accuracy stays in .hexanoport.

const PN_N: int = 6

pure fn sigma(n: int) -> int {
    let mut s = 0; let mut d = 1;
    while d <= n { if n % d == 0 { s = s + d; } d = d + 1; }
    s
}

// sigma_{-1}(6) = sigma(6) / 6 = 12 / 6 = 2, exact.
pure fn sigma_neg1_int_times_n(n: int) -> int { sigma(n) }
pure fn sigma_neg1_6_eq_2() -> bool {
    sigma_neg1_int_times_n(PN_N) == 2 * PN_N
}

// Efficiency model: eff(N) = acc(N) / N.
// With fixed accuracies from the source run, N=2 maximises eff.
// We encode only the closed-form winner check: given a monotone-
// decreasing or flat accuracy sequence, the argmax of acc/N is N=2 iff
// acc(2)/2 >= acc(3)/3 and acc(2)/2 >= acc(4)/4.
pure fn n2_optimal(acc2: float, acc3: float, acc4: float) -> bool {
    let e2 = acc2 / 2.0;
    let e3 = acc3 / 3.0;
    let e4 = acc4 / 4.0;
    e2 >= e3 && e2 >= e4
}

fn main() {
    print("sigma(6)=");           print(sigma(6));              print("\n");
    print("sigma_-1(6)==2: ");    print(sigma_neg1_6_eq_2());   print("\n");
    // Source results.json shows acc ~ 0.96, 0.94, 0.91 for N=2,3,4 → N=2 best.
    print("N=2 optimal (0.96/0.94/0.91): ");
    print(n2_optimal(0.96, 0.94, 0.91)); print("\n");
}
