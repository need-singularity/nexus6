// Ported from tecs-l/docs/hypotheses/verify_hcx432.py
// H-CX-432: Tension = Payoff in Game Theory
// Track A: payoff-matrix primitives and the "tension = 1 - max softmax"
// identity expressed in closed form for the degenerate 2-outcome case.
// The sklearn digits MLP tension trajectory stays in .hexanoport.

const R: int = 3
const T: int = 5
const S: int = 0
const P: int = 1

// 2x2 PD payoff as a flat array indexed [my_action * 2 + opp_action],
// 0 = cooperate, 1 = defect.
pure fn my_payoff(my_act: int, opp_act: int) -> int {
    if my_act == 0 && opp_act == 0 { R }
    else if my_act == 0 && opp_act == 1 { S }
    else if my_act == 1 && opp_act == 0 { T }
    else { P }
}

// Sum of payoffs for a symmetric outcome (both do the same action).
pure fn symmetric_sum(act: int) -> int {
    my_payoff(act, act) + my_payoff(act, act)
}

// Tension in a two-outcome softmax: 1 - max(p, 1-p) = min(p, 1-p).
// Monotone in distance from p=0.5, peaks at 0.5.
pure fn tension_binary(p: float) -> float {
    let q = 1.0 - p;
    if p > q { q } else { p }
}

// Max tension at p=0.5 equals 0.5.
pure fn tension_max_is_half() -> bool {
    let t = tension_binary(0.5);
    let d = t - 0.5;
    let ad = if d < 0.0 { -d } else { d };
    ad < 0.0001
}

fn main() {
    print("payoff(C,C)="); print(my_payoff(0, 0)); print("\n");
    print("payoff(C,D)="); print(my_payoff(0, 1)); print("\n");
    print("payoff(D,C)="); print(my_payoff(1, 0)); print("\n");
    print("payoff(D,D)="); print(my_payoff(1, 1)); print("\n");
    print("2R=");          print(symmetric_sum(0)); print("\n");
    print("2P=");          print(symmetric_sum(1)); print("\n");
    print("tension(0.1)="); print(tension_binary(0.1)); print("\n");
    print("tension(0.5)="); print(tension_binary(0.5)); print("\n");
    print("tension(0.9)="); print(tension_binary(0.9)); print("\n");
    print("max tension = 0.5: "); print(tension_max_is_half()); print("\n");
}
