// Ported from tecs-l/docs/hypotheses/verify_h_rob_3.py
// H-ROB-3: Golden Zone = Stable Walking Region
// Linear Inverted Pendulum Model (LIPM) verification — Froude + step length
// sweep across 0.1..2.0 m/s. Pure math (no numpy dependency).

const G: float           = 9.81
const FOOT_LENGTH: float = 0.26
const LEG_LENGTH: float  = 0.85
const H_COM: float       = 0.85

// Golden Zone constants
//   lower = 0.5 - ln(4/3) ≈ 0.2123
//   center = 1/e           ≈ 0.3679
//   upper = 0.5
pure fn gz_lower() -> float { 0.5 - ln(4.0 / 3.0) }
pure fn gz_upper() -> float { 0.5 }
pure fn gz_center() -> float { 1.0 / 2.71828182845904523536 }

pure fn lipm_omega() -> float { sqrt(G / H_COM) }
pure fn lipm_tc() -> float    { 1.0 / lipm_omega() }

// Froude number Fr = v^2 / (g * L)
pure fn froude(v: float, leg: float) -> float {
    (v * v) / (G * leg)
}

// Step length from Fr: empirical Grieve-Gear-style fit.
pure fn step_length(v: float) -> float {
    let fr = froude(v, LEG_LENGTH);
    let raw = if fr < 0.5 { LEG_LENGTH * 0.75 * sqrt(fr / 0.25) } else { LEG_LENGTH * 0.9 };
    if raw > LEG_LENGTH { LEG_LENGTH } else { raw }
}

// In-band test: is Froude inside golden zone?
pure fn fr_in_gz(v: float) -> bool {
    let fr = froude(v, LEG_LENGTH);
    fr >= gz_lower() && fr <= gz_upper()
}

fn main() {
    let mut i = 1;
    while i <= 20 {
        let v  = to_float(i) / 10.0;
        let fr = froude(v, LEG_LENGTH);
        let sl = step_length(v);
        print(v); print(" fr="); print(fr);
        print(" sl="); print(sl);
        print(" gz="); print(fr_in_gz(v));
        print("\n");
        i = i + 1;
    }
}
