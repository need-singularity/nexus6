// Ported from tecs-l/docs/hypotheses/exp_hcx423.py
// H-CX-423: Dream State = Field Hyperactivation
// Track A: hyperactivation metric as closed form. Dream-state tension
// is modelled as tension_dream = k * tension_awake where k > 1
// (hyperactivation factor). The sklearn digits PureField training run
// used to measure empirical tensions stays in .hexanoport.

// Hyperactivation factor: ratio of dream to awake tension.
pure fn hyperactivation(tension_dream: float, tension_awake: float) -> float {
    tension_dream / tension_awake
}

// Dream hypothesis predicate: k > 1.
pure fn is_hyperactivated(k: float) -> bool { k > 1.0 }

// Exponential amplification model: tension_dream = tension_awake * exp(lambda*t).
pure fn exp_amplification(t0: float, lam: float, t: float) -> float {
    t0 * exp(lam * t)
}

// Time-to-double under rate lambda: ln(2) / lambda.
pure fn doubling_time(lam: float) -> float {
    ln(2.0) / lam
}

fn main() {
    let k = hyperactivation(0.8, 0.3);
    print("k=");                print(k);                 print("\n");
    print("hyperactivated: ");  print(is_hyperactivated(k)); print("\n");
    print("amp(0.3, 0.5, 2)=");  print(exp_amplification(0.3, 0.5, 2.0)); print("\n");
    print("doubling(0.5)=");     print(doubling_time(0.5)); print("\n");
}
