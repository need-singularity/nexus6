// Ported from tecs-l/docs/hypotheses/verify_hcx442.py
// H-CX-442: 12-tone scale = sigma(6). Shows 12 semitones per octave
// emerges from sigma(6)=12, 4 divisors = tau(6), 7+5 decomposition.

pure fn gcd(a: int, b: int) -> int {
    if b == 0 { a } else { gcd(b, a % b) }
}

pure fn sigma(n: int) -> int {
    let mut s = 0; let mut d = 1;
    while d <= n { if n % d == 0 { s = s + d; } d = d + 1; }
    s
}

pure fn tau(n: int) -> int {
    let mut c = 0; let mut d = 1;
    while d <= n { if n % d == 0 { c = c + 1; } d = d + 1; }
    c
}

pure fn phi(n: int) -> int {
    let mut c = 0; let mut k = 1;
    while k <= n { if gcd(k, n) == 1 { c = c + 1; } k = k + 1; }
    c
}

// sum of reciprocals of divisors; for n=6 yields 2.
pure fn sigma_neg1(n: int) -> float {
    let mut s = 0.0; let mut d = 1;
    while d <= n {
        if n % d == 0 { s = s + 1.0 / to_float(d); }
        d = d + 1;
    }
    s
}

// 12-tone identity: 7 naturals + 5 accidentals = sigma(6).
pure fn twelve_tone_identity() -> bool {
    7 + 5 == sigma(6)
}

// Octave ratio: sigma_neg1(6) == 2.
pure fn octave_ratio_ok() -> bool {
    let s = sigma_neg1(6);
    let d = s - 2.0;
    let ad = if d < 0.0 { -d } else { d };
    ad < 0.0001
}

fn main() {
    print("sigma(6)="); print(sigma(6)); print("\n");
    print("tau(6)="); print(tau(6)); print("\n");
    print("phi(6)="); print(phi(6)); print("\n");
    print("sigma_-1(6)="); print(sigma_neg1(6)); print("\n");
    print("12-tone identity: "); print(twelve_tone_identity()); print("\n");
    print("octave ratio OK: "); print(octave_ratio_ok()); print("\n");
}
