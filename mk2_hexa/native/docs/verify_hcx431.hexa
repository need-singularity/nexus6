// Ported from tecs-l/docs/hypotheses/verify_hcx431.py
// H-CX-431: Nash Equilibrium = Silent Consensus
// Track A: analytic pieces — Golden Zone center = 1/e, best-response
// analysis for 2x2 PD (always-defect is the unique Nash equilibrium),
// and a distance-from-1/e metric. The numpy MLP consensus experiment
// across N = {2,3,4,6} remains in .hexanoport.

// Golden Zone center = 1/e ≈ 0.36788
pure fn gz_center() -> float { 1.0 / 2.71828182845904523536 }

// Distance of x from gz_center
pure fn dist_from_gz_center(x: float) -> float {
    let d = x - gz_center();
    if d < 0.0 { -d } else { d }
}

// PD payoffs (same as 433).
const R: int = 3
const T: int = 5
const S: int = 0
const P: int = 1

// Best response to opponent cooperating: defect if T>R (true by PD)
pure fn br_to_coop_is_defect() -> bool { T > R }
// Best response to opponent defecting: defect if P>S (true by PD)
pure fn br_to_defect_is_defect() -> bool { P > S }

// Nash equilibrium: both defect (unique pure NE in one-shot PD).
pure fn nash_is_dd() -> bool {
    br_to_coop_is_defect() && br_to_defect_is_defect()
}

// Nash tightness proxy: |R - P| / (T - S) — how much the cooperative
// payoff improvement is worth relative to unilateral temptation span.
pure fn nash_tightness() -> float {
    let num = to_float(R - P);
    let den = to_float(T - S);
    num / den
}

fn main() {
    print("gz_center=1/e="); print(gz_center()); print("\n");
    print("BR(C)=D: ");       print(br_to_coop_is_defect());    print("\n");
    print("BR(D)=D: ");       print(br_to_defect_is_defect());  print("\n");
    print("Nash is (D,D): "); print(nash_is_dd());              print("\n");
    print("nash tightness="); print(nash_tightness());          print("\n");
    print("dist(0.4, 1/e)="); print(dist_from_gz_center(0.4));  print("\n");
}
