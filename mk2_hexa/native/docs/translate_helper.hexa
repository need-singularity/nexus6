// Ported from tecs-l/docs/hypotheses/translate_helper.py
// Helper that scans docs/hypotheses/*.md and flags files containing Hangul
// (Korean) codepoints so bilingual content can be located. Pure regex + FS
// in the original; here we keep the predicate (Hangul range test) only —
// the actual directory walk is host runtime, not hexa.

// Unicode Hangul syllable range: U+AC00 .. U+D7A3
const HANGUL_LO: int = 44032   // 0xAC00
const HANGUL_HI: int = 55203   // 0xD7A3

pure fn is_hangul(codepoint: int) -> bool {
    codepoint >= HANGUL_LO && codepoint <= HANGUL_HI
}

// Given a string, returns true if any character is Hangul.
pure fn contains_hangul(s: string) -> bool {
    let n = string_len(s);
    let mut i = 0;
    while i < n {
        if is_hangul(char_at(s, i)) { return true; }
        i = i + 1;
    }
    false
}

// Filename predicate for target hypothesis files: matches ^0[01][0-9]- or
// ^1[0-9][0-9]- prefix, extension .md.
pure fn is_target_filename(name: string) -> bool {
    let n = string_len(name);
    if n < 5 { return false; }
    // Check last 3 chars are ".md"
    if char_at(name, n - 3) != 46 { return false; }   // '.'
    if char_at(name, n - 2) != 109 { return false; }  // 'm'
    if char_at(name, n - 1) != 100 { return false; }  // 'd'
    // Prefix: 3-digit then '-'
    let c0 = char_at(name, 0);
    let c1 = char_at(name, 1);
    let c2 = char_at(name, 2);
    let c3 = char_at(name, 3);
    if c3 != 45 { return false; }   // '-'
    // c0 in {'0','1'}; if '0' then c1 in {'0','1'}; if '1' then any digit.
    if c0 == 48 {
        (c1 == 48 || c1 == 49) && (c2 >= 48 && c2 <= 57)
    } else if c0 == 49 {
        (c1 >= 48 && c1 <= 57) && (c2 >= 48 && c2 <= 57)
    } else {
        false
    }
}

fn main() {
    print("is_target(005-foo.md): "); print(is_target_filename("005-foo.md")); print("\n");
    print("is_target(199-bar.md): "); print(is_target_filename("199-bar.md")); print("\n");
    print("hangul? 0xAC00: "); print(is_hangul(HANGUL_LO)); print("\n");
}
