// Ported from tecs-l/docs/hypotheses/verify_443.py
// H-CX-443: Small World Coefficient in Golden Zone
// Track A: closed-form Golden Zone bounds + the small-world sigma
// statistic formula. The networkx/sklearn MLP weight-graph analysis
// stays in .hexanoport.

// Golden Zone constants:
//   upper  = 1/2
//   lower  = 1/2 - ln(4/3) ≈ 0.2123
//   center = 1/e           ≈ 0.3679
//   width  = ln(4/3)       ≈ 0.2877
pure fn gz_upper()  -> float { 0.5 }
pure fn gz_lower()  -> float { 0.5 - ln(4.0 / 3.0) }
pure fn gz_center() -> float { 1.0 / 2.71828182845904523536 }
pure fn gz_width()  -> float { ln(4.0 / 3.0) }

pure fn in_gz(x: float) -> bool {
    x >= gz_lower() && x <= gz_upper()
}

// Small-world sigma: sigma = (C / C_rand) / (L / L_rand).
// sigma > 1 indicates small-world.
pure fn small_world_sigma(c: float, c_rand: float, l: float, l_rand: float) -> float {
    (c / c_rand) / (l / l_rand)
}

// Normalised small-world coefficient omega = L_rand/L - C/C_latt.
// omega in [-1, 1]; 0 means small-world.
pure fn small_world_omega(l: float, l_rand: float, c: float, c_latt: float) -> float {
    l_rand / l - c / c_latt
}

// Erdos-Renyi theoretical values:
//   C_rand = p, L_rand ~ ln(n) / ln(n*p) for n*p > 1
pure fn er_clustering(p: float) -> float { p }
pure fn er_path_length(n: float, p: float) -> float {
    ln(n) / ln(n * p)
}

fn main() {
    print("gz_lower=");  print(gz_lower());  print("\n");
    print("gz_upper=");  print(gz_upper());  print("\n");
    print("gz_center="); print(gz_center()); print("\n");
    print("gz_width=");  print(gz_width());  print("\n");
    print("0.3 in GZ: "); print(in_gz(0.3)); print("\n");
    print("0.6 in GZ: "); print(in_gz(0.6)); print("\n");
    // Toy small-world check: C=0.4, C_rand=0.05, L=2.5, L_rand=2.2
    let s = small_world_sigma(0.4, 0.05, 2.5, 2.2);
    print("sigma=");     print(s);           print("\n");
    print("sigma>1: ");  print(s > 1.0);     print("\n");
    print("ER clustering p=0.1: "); print(er_clustering(0.1)); print("\n");
    print("ER path length n=100 p=0.1: ");
    print(er_path_length(100.0, 0.1)); print("\n");
}
