// Ported from tecs-l/docs/hypotheses/verify_hcx441.py
// H-CX-441: Dissonance = Inter-tension
// Musical-interval dissonance measures (Euler gradus, Plomp-Levelt surrogate)
// and Golden-Zone check around ln(4/3). Pure math — numpy is only used for
// seed/log in the original source.

pure fn gcd(a: int, b: int) -> int {
    if b == 0 { a } else { gcd(b, a % b) }
}

// Euler's gradus-suavitatis variant: D = a*b / gcd(a,b)^2
pure fn euler_gradus(a: int, b: int) -> float {
    let g = gcd(a, b);
    to_float(a * b) / to_float(g * g)
}

// Plomp-Levelt surrogate based on ratio complexity.
pure fn plomp_levelt(a: int, b: int) -> float {
    to_float(a + b) / to_float(2 * gcd(a, b))
}

// Golden-Zone width = ln(4/3).
pure fn gz_width() -> float { ln(4.0 / 3.0) }

// Interval membership in GZ: |ln(a/b) - ln(4/3)| < 0.05 or |ln(a/b)| < 0.01.
pure fn in_gz(a: int, b: int) -> bool {
    let r  = ln(to_float(a) / to_float(b));
    let d1 = r - gz_width();
    let d2 = r;
    let ad1 = if d1 < 0.0 { -d1 } else { d1 };
    let ad2 = if d2 < 0.0 { -d2 } else { d2 };
    ad1 < 0.05 || ad2 < 0.01
}

struct Interval { name: string, a: int, b: int }

fn main() {
    // Perfect 4th (4:3) should land exactly at GZ width.
    print("P4 in GZ: "); print(in_gz(4, 3)); print("\n");
    print("Unison in GZ: "); print(in_gz(1, 1)); print("\n");
    print("P5 Euler: "); print(euler_gradus(3, 2)); print("\n");
    print("Tritone PL: "); print(plomp_levelt(45, 32)); print("\n");
}
