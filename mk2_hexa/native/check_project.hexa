// mk2_hexa/native/check_project.hexa — 프로젝트 화이트리스트 체크 (Python 대체)
// 사용: hexa check_project.hexa <repo_name>
// 종료 코드: 0 = 등록됨, 1 = 미등록
// nexus-projects.json의 projects 키에서 repo_name 존재 여부 확인

let a = args()
if a.len() < 3 {
    // 프로젝트명 없으면 실패
    exit(1)
}

let repo_name = a[2]
let proj_path = exec("printenv HOME") + "/Dev/nexus/shared/config/nexus-projects.json"

let content = read_file(proj_path)
if content == "" {
    exit(1)
}

// "projects" 블록에서 repo_name 키 존재 여부 확인
// 대소문자 무시 비교: 소문자로 변환하여 비교
if !content.contains("projects") {
    exit(1)
}

let after_proj = content.split("projects")[1]

// 원본 이름과 소문자 버전 모두 검색
let key_exact = "\"" + repo_name + "\""
let key_lower = "\"" + repo_name.to_lower() + "\""

if after_proj.contains(key_exact) || after_proj.contains(key_lower) {
    exit(0)
} else {
    exit(1)
}
