// 포팅 원본: tecs-l/math/zeta_n6_deep.py (374 LOC)
// Deep follow-up: verify new zeta identities, Ramanujan tau, and grading for n=6
// zeta(-3), zeta(-7), zeta(-9), tau_R, functional equation, Texas sharpshooter

fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

fn fmt10(x: float) -> string {
    let r = to_float(to_int(x * 10000000000.0)) / 10000000000.0
    to_string(r)
}
fn fmt6(x: float) -> string {
    let r = to_float(to_int(x * 1000000.0)) / 1000000.0
    to_string(r)
}

// @pure — integer power
fn ipow(b: int, k: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < k {
        r = r * b
        i = i + 1
    }
    r
}

// @pure — float power (integer exponent)
fn fpow(b: float, k: int) -> float {
    let mut r = 1.0
    let mut i = 0
    while i < k {
        r = r * b
        i = i + 1
    }
    r
}

// @pure — trial division primality
fn is_prime(n: int) -> bool {
    if n < 2 { return false }
    if n == 2 { return true }
    if n % 2 == 0 { return false }
    let mut i = 3
    while i * i <= n {
        if n % i == 0 { return false }
        i = i + 2
    }
    true
}

// @pure — divisor_sigma_k: sum of d^k for d|n
fn divisor_sigma_k(n: int, k: int) -> int {
    let mut s = 0
    let mut d = 1
    while d * d <= n {
        if n % d == 0 {
            s = s + ipow(d, k)
            let other = n / d
            if other != d {
                s = s + ipow(other, k)
            }
        }
        d = d + 1
    }
    s
}

// @pure — Bernoulli numbers (rational as float) for even indices 0..20
// Hardcoding small Bernoulli for zeta verification (no mpmath available)
fn bernoulli_even(k: int) -> float {
    // B_0=1, B_2=1/6, B_4=-1/30, B_6=1/42, B_8=-1/30, B_10=5/66
    if k == 0 { return 1.0 }
    if k == 2 { return 1.0 / 6.0 }
    if k == 4 { return 0.0 - 1.0 / 30.0 }
    if k == 6 { return 1.0 / 42.0 }
    if k == 8 { return 0.0 - 1.0 / 30.0 }
    if k == 10 { return 5.0 / 66.0 }
    0.0
}

// @pure — zeta at negative odd integers: zeta(-(2k-1)) = -B_{2k}/(2k)
fn zeta_neg_odd(k: int) -> float {
    let b = bernoulli_even(2 * k)
    (0.0 - b) / to_float(2 * k)
}

// @pure — factorial
fn fact(n: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= n {
        r = r * i
        i = i + 1
    }
    r
}

