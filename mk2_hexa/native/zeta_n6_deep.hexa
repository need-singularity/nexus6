let lhs_val = pi6 / 945.0 * to_float(sigma3)
let rhs_val = pi6 * to_float(tau_n) / to_float(sopfr * (n / phi_n))
println("  LHS = zeta(6) * sigma_3(6) = " + fmt6(lhs_val))
println("  RHS = pi^6 * tau/(sopfr*(n/phi)) = " + fmt6(rhs_val))
