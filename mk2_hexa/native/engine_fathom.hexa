// engine_fathom.hexa — "Oracle" (오라클) 엔진
// 프로젝트: fathom — 6-layer terminal dashboard
// 목표: 22렌즈 실시간 대시보드 완성
// 사용: hexa engine_fathom.hexa status|tick|report

// ═══════════════════════════════════════════════════════════
// ─── CONSTANTS ───
// ═══════════════════════════════════════════════════════════

comptime const version = "1.0.0"
comptime const name = "fathom"
comptime const personality = "Oracle"
let home = exec("printenv HOME")
let dev = home + "/Dev"
let project_dir = dev + "/fathom"
let lens_rs = project_dir + "/src/lens.rs"
let shared_link = project_dir + "/.shared"
let bus_file = dev + "/nexus6/shared/growth_bus.jsonl"
let state_file = dev + "/nexus6/shared/engine_fathom_state.json"
let nexus6_shared = dev + "/nexus6/shared"

comptime const goal_lenses = 22
comptime const stagnant_threshold = 0.40
comptime const build_history_max = 20
comptime const data_fresh_seconds = 3600  // 1 hour

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {}
    return v
}

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(s.trim()) } catch e {}
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

fn min_f(a: f64, b: f64) -> f64 {
    if a < b { return a }
    return b
}

fn clamp01(x: f64) -> f64 {
    if x < 0.0 { return 0.0 }
    if x > 1.0 { return 1.0 }
    return x
}

fn timestamp() -> string {
    let r = exec("date +%Y-%m-%dT%H:%M:%S")
    r.trim()
}

fn epoch_now() -> i64 {
    let r = exec("date +%s")
    return safe_int(r.trim())
}

fn file_exists(path: string) -> bool {
    let r = exec("test", ["-f", path, "&&", "echo", "1"])
    r.trim() == "1"
}

fn dir_exists(path: string) -> bool {
    let r = exec("test", ["-d", path, "&&", "echo", "1"])
    r.trim() == "1"
}

fn link_exists(path: string) -> bool {
    let r = exec("test", ["-L", path, "&&", "echo", "1"])
    r.trim() == "1"
}

fn read_file_safe(path: string) -> string {
    try {
        return read_file(path)
    } catch e {
        return ""
    }
}

// ─── Growth Bus ───

fn append_bus(phase: string, status: string, detail: string) {
    let ts = timestamp()
    let line = "{\"source\":\"" + name + "\",\"personality\":\"" + personality + "\",\"timestamp\":\"" + ts + "\",\"phase\":\"" + phase + "\",\"status\":\"" + status + "\",\"detail\":\"" + detail + "\"}"
    try {
        append_file(bus_file, line + "\n")
    } catch e {}
}

// ═══════════════════════════════════════════════════════════
// ─── DATA COLLECTION ───
// ═══════════════════════════════════════════════════════════

// Count lens definitions in lens.rs
fn count_lenses() -> i64 {
    if !file_exists(lens_rs) {
        // fallback: search for lens definitions across src/
        let mut r = "0"
        try {
            r = exec("bash -c grep -c 'struct.*Lens\\|impl.*Lens\\|fn.*lens\\|pub fn new_lens\\|LensConfig' " + project_dir + "/src/*.rs 2>/dev/null || echo 0")
        } catch e {}
        return safe_int(r.trim())
    }

    let content = read_file_safe(lens_rs)
    if content == "" { return 0 }

    // Count struct definitions that look like lens types
    let mut r = "0"
    try {
        r = exec("bash -c grep -cE '(struct\\s+\\w*Lens|impl\\s+\\w*Lens|pub\\s+fn\\s+new|LensKind::\\w+)' " + lens_rs + " 2>/dev/null || echo 0")
    } catch e {}

    let count = safe_int(r.trim())
    // Also check for lens enum variants if count is low
    if count < 5 {
        let mut r2 = "0"
        try {
            r2 = exec("bash -c grep -cE '^\\s+(\\w+Lens|\\w+),?\\s*//.*lens' " + lens_rs + " 2>/dev/null || echo 0")
        } catch e {}
        return count + safe_int(r2.trim())
    }
    return count
}

// Run cargo build and return success + output
struct BuildResult {
    success: bool,
    output: string,
    warnings: i64,
    errors: i64
}

fn cargo_build(release: bool) -> BuildResult {
    if !file_exists(project_dir + "/Cargo.toml") {
        return BuildResult { success: false, output: "Cargo.toml not found", warnings: 0, errors: 0 }
    }

    let flag = if release { "--release" } else { "" }
    let mut r = "0"
    try {
        r = exec("bash -c cd " + project_dir + " && cargo build " + flag + " 2>&1 | tail -30")
    } catch e {
        r = "build error: " + to_string(e)
    }

    let success = !r.contains("error[") && !r.contains("could not compile")

    // Count warnings
    let mut warn_r = ""
    try {
        r = exec("bash -c echo '" + r + "' | grep -c 'warning\\[' 2>/dev/null || echo 0")
    } catch e {}
    let warnings = safe_int(warn_r.trim())

    // Count errors
    let mut err_r = "0"
    try {
        err_r = exec("bash -c echo '" + r + "' | grep -c 'error\\[' 2>/dev/null || echo 0")
    } catch e {}
    let errors = safe_int(err_r.trim())

    return BuildResult { success: success, output: r, warnings: warnings, errors: errors }
}

// Check .shared symlink data freshness
struct FreshnessResult {
    linked: bool,
    fresh: bool,
    age_seconds: i64,
    detail: string
}

fn check_shared_freshness() -> FreshnessResult {
    if !link_exists(shared_link) && !dir_exists(shared_link) {
        return FreshnessResult { linked: false, fresh: false, age_seconds: -1, detail: ".shared not found" }
    }

    // Check if symlink target is valid
    let mut target_r = ""
    try {
        target_r = exec("bash -c readlink -f " + shared_link + " 2>/dev/null")
    } catch e {}

    if target_r.trim() == "" || !dir_exists(target_r.trim()) {
        return FreshnessResult { linked: true, fresh: false, age_seconds: -1, detail: "symlink broken" }
    }

    // Find most recent file modification in .shared/
    let mut age_r = "0"
    try {
        age_r = exec("bash -c find " + shared_link + " -type f -printf '%T@\\n' 2>/dev/null | sort -nr | head -1 || stat -f '%m' " + shared_link + " 2>/dev/null")
    } catch e {}

    let file_epoch = safe_int(age_r.split(".")[0].trim())
    let now = epoch_now()
    let age = if file_epoch > 0 { now - file_epoch } else { 99999 }
    let fresh = age < data_fresh_seconds

    return FreshnessResult {
        linked: true,
        fresh: fresh,
        age_seconds: age,
        detail: if fresh { "data fresh (" + to_string(age) + "s ago)" } else { "data stale (" + to_string(age) + "s old)" }
    }
}

// ═══════════════════════════════════════════════════════════
// ─── STATE PERSISTENCE ───
// ═══════════════════════════════════════════════════════════

struct EngineState {
    lens_count: i64,
    build_ok: bool,
    build_history: str,   // last N build results
    data_fresh: bool,
    tick_count: i64,
    last_tick: string,
    error_log: str      // recent build errors
}

fn load_state() -> EngineState {
    let content = read_file_safe(state_file)
    let mut state = EngineState {
        lens_count: 0,
        build_ok: false,
        build_history: [],
        data_fresh: false,
        tick_count: 0,
        last_tick: "",
        error_log: []
    }

    if content == "" { return state }

    if content.contains("\"lens_count\"") {
        let parts = content.split("\"lens_count\":")
        if parts.len() >= 2 {
            state.lens_count = safe_int(parts[1].split(",")[0].split("}")[0].trim())
        }
    }
    if content.contains("\"build_ok\"") {
        state.build_ok = content.contains("\"build_ok\":true") || content.contains("\"build_ok\": true")
    }
    if content.contains("\"tick_count\"") {
        let parts = content.split("\"tick_count\":")
        if parts.len() >= 2 {
            state.tick_count = safe_int(parts[1].split(",")[0].split("}")[0].trim())
        }
    }
    if content.contains("\"last_tick\"") {
        let parts = content.split("\"last_tick\":\"")
        if parts.len() >= 2 {
            state.last_tick = parts[1].split("\"")[0]
        }
    }

    return state
}

fn save_state(state: EngineState) {
    let build_hist_str = "[" + build_history_to_json(st.build_history) + ""
//         let mut s = ""
        let mut i = 0
        while i < state.build_history.len() {
            if i > 0 { s = s + "," }
            s = s + if state.build_history[i] { "true" } else { "false" }
            i = i + 1
        }
        s
    } + "]"

    let err_str = "[" + {
        let mut s = ""
        let mut i = 0
        while i < state.error_log.len() {
            if i > 0 { s = s + "," }
            s = s + "\"" + state.error_log[i] + "\""
            i = i + 1
        }
        s
    } + "]"

    let json = "{\n  \"lens_count\": " + to_string(state.lens_count) + ",\n  \"build_ok\": " + if state.build_ok { "true" } else { "false" } + ",\n  \"data_fresh\": " + if state.data_fresh { "true" } else { "false" } + ",\n  \"tick_count\": " + to_string(state.tick_count) + ",\n  \"last_tick\": \"" + state.last_tick + "\",\n  \"build_history\": " + build_hist_str + ",\n  \"error_log\": " + err_str + "\n}\n"
    try {
        write_file(state_file, json)
    } catch e {}
}

// ═══════════════════════════════════════════════════════════
// ─── HEALTH CALCULATION ───
// ═══════════════════════════════════════════════════════════

fn compute_health(lens_count: i64, build_ok: bool, data_fresh: bool, build_history) -> f64 {
    // 40% lens progress, 30% build success, 20% data freshness, 10% build stability
    let lens_score = clamp01(to_float(lens_count) / to_float(goal_lenses))
    let build_score = if build_ok { 1.0 } else { 0.0 }
    let fresh_score = if data_fresh { 1.0 } else { 0.3 }

    // Build stability: ratio of successes in history
    let mut success_count = 0
    let mut i = 0
    while i < build_history.len() {
        if build_history[i] { success_count = success_count + 1 }
        i = i + 1
    }
    let stability = if build_history.len() > 0 {
        to_float(success_count) / to_float(build_history.len())
    } else { 0.5 }

    let health = lens_score * 0.4 + build_score * 0.3 + fresh_score * 0.2 + stability * 0.1
    return clamp01(health)
}

fn classify_status(lens_count: i64, build_ok: bool, health: f64, prev_lenses: i64) -> string {
    // Build failure is top priority
    if !build_ok { return "STAGNANT" }

    // Goal reached
    if lens_count >= goal_lenses { return "GOAL_NEAR" }

    // New lenses detected = breakthrough
    if prev_lenses > 0 && lens_count > prev_lenses { return "BREAKTHROUGH" }

    // Low health
    if health < stagnant_threshold { return "STAGNANT" }

    return "HEALTHY"
}

// ─── Evolve: recurring failure analysis ───

fn analyze_build_failures(error_log) -> string {
    // Look for patterns in errors
    let mut pattern_counts = []  // pairs of [pattern, count]
    let patterns = ["lifetime", "borrow", "type mismatch", "unresolved", "trait", "missing field", "unused"]

    let mut pi = 0
    while pi < patterns.len() {
        let pat = patterns[pi]
        let mut count = 0
        let mut ei = 0
        while ei < error_log.len() {
            if error_log[ei].contains(pat) { count = count + 1 }
            ei = ei + 1
        }
        if count > 0 {
            pattern_counts = pattern_counts + [[pat, to_string(count)]]
        }
        pi = pi + 1
    }

    if pattern_counts.len() == 0 { return "no recurring patterns" }

    let mut result = ""
    let mut i = 0
    while i < pattern_counts.len() {
        if i > 0 { result = result + ", " }
        result = result + pattern_counts[i][0] + "(" + pattern_counts[i][1] + "x)"
        i = i + 1
    }
    return result
}

// ═══════════════════════════════════════════════════════════
// ─── MODE: STATUS ───
// ═══════════════════════════════════════════════════════════

fn mode_status() {
    println("╔═══════════════════════════════════════════════╗")
    println("║  ENGINE: fathom [Oracle] v" + version + "             ║")
    println("║  " + timestamp() + "                            ║")
    println("╚═══════════════════════════════════════════════╝")

    let lenses = count_lenses()
    let state = load_state()
    let freshness = check_shared_freshness()
    let health = compute_health(lenses, state.build_ok, freshness.fresh, state.build_history)
    let status = classify_status(lenses, state.build_ok, health, state.lens_count)

    println("")
    println("  lenses:     " + to_string(lenses) + "/" + to_string(goal_lenses))
    println("  build:      " + if state.build_ok { "OK" } else { "FAIL" })
    println("  shared:     " + freshness.detail)
    println("  ticks:      " + to_string(state.tick_count))
    println("  last_tick:  " + state.last_tick)
    println("")
    println("health:" + to_string(health))
    println(status)
}

// ═══════════════════════════════════════════════════════════
// ─── MODE: TICK ───
// ═══════════════════════════════════════════════════════════

fn mode_tick() {
    println("─── fathom [Oracle] tick ───")
    append_bus("tick", "start", "fathom tick begin")

    let mut state = load_state()
    let prev_lenses = state.lens_count

    // 1. Count lenses
    let lenses = count_lenses()
    println("  [1/4] lenses: " + to_string(lenses) + "/" + to_string(goal_lenses))

    let lens_changed = prev_lenses > 0 && lenses != prev_lenses
    if lens_changed {
        let delta = lenses - prev_lenses
        let sign = if delta > 0 { "+" } else { "" }
        println("        ⚡ lens count changed: " + sign + to_string(delta))
    }

    // 2. Build
    let build_mode = if lens_changed { "release (lens change triggered)" } else { "debug" }
    println("  [2/4] cargo build (" + build_mode + ") ...")
    let build = cargo_build(lens_changed)  // release only if lenses changed
    println("        result: " + if build.success { "OK" } else { "FAIL" })
    if build.warnings > 0 { println("        warnings: " + to_string(build.warnings)) }
    if build.errors > 0 { println("        errors: " + to_string(build.errors)) }

    // 3. Check shared data freshness
    let freshness = check_shared_freshness()
    println("  [3/4] shared data: " + freshness.detail)

    // 4. Build history + error tracking
    let mut build_history = state.build_history + [build.success]
    if build_history.len() > build_history_max {
        let mut trimmed = []
        let start = build_history.len() - build_history_max
        let mut i = start
        while i < build_history.len() {
            trimmed = trimmed + [build_history[i]]
            i = i + 1
        }
        build_history = trimmed
    }

    let mut error_log = state.error_log
    if !build.success {
        // Extract first error line
        let err_line = build.output.split("error")[1].split("\n")[0]
        let clean_err = err_line.split("\"")[0].trim()
        error_log = error_log + [clean_err]
        if error_log.len() > 10 {
            error_log = error_log[error_log.len() - 10..]
        }
    }

    println("  [4/4] build stability check ...")
    let mut recent_fails = 0
    let check_start = if build_history.len() > 5 { build_history.len() - 5 } else { 0 }
    let mut ci = check_start
    while ci < build_history.len() {
        if !build_history[ci] { recent_fails = recent_fails + 1 }
        ci = ci + 1
    }
    println("        recent 5 builds: " + to_string(5 - recent_fails) + "/5 pass")

    // Compute health and status
    let health = compute_health(lenses, build.success, freshness.fresh, build_history)
    let status = classify_status(lenses, build.success, health, prev_lenses)

    println("")
    println("  health:" + to_string(health))
    println("  status: " + status)

    // Evolve: track recurring build failures
    if !build.success && error_log.len() >= 2 {
        println("")
        println("  ─── evolve: failure pattern analysis ───")
        let patterns = analyze_build_failures(error_log)
        println("  recurring: " + patterns)
        println("  → recommend: prioritize fix for most frequent error type")
        append_bus("evolve", "build_pattern", patterns)
    }

    // Priority build fix if failing
    if !build.success {
        println("  ⚠ BUILD FAIL — priority fix needed")
        println("  first error: " + build.output.split("error[")[0])
        append_bus("tick", "build_fail", "errors=" + to_string(build.errors))
    }

    // Lens change triggers
    if lens_changed && lenses > prev_lenses {
        println("  🔭 New lenses detected — dashboard rebuild triggered")
        append_bus("tick", "lens_added", "count=" + to_string(lenses) + " prev=" + to_string(prev_lenses))
    }

    // Stale data warning
    if !freshness.fresh && freshness.linked {
        println("  📡 Shared data stale — nexus6 sync may be needed")
        append_bus("tick", "data_stale", "age=" + to_string(freshness.age_seconds) + "s")
    }

    // Status-specific actions
    if status == "GOAL_NEAR" {
        println("  🎯 GOAL_NEAR — 22렌즈 대시보드 거의 완성!")
        append_bus("tick", "goal_near", "lenses=" + to_string(lenses))
    }
    if status == "BREAKTHROUGH" {
        println("  🔥 BREAKTHROUGH — 새 렌즈 추가 감지!")
        append_bus("tick", "breakthrough", "lenses=" + to_string(lenses))
    }

    // Save state
    state.lens_count = lenses
    state.build_ok = build.success
    state.build_history = build_history
    state.data_fresh = freshness.fresh
    state.tick_count = state.tick_count + 1
    state.last_tick = timestamp()
    state.error_log = error_log
    save_state(state)

    println("")
    println("health:" + to_string(health))
    println(status)

    append_bus("tick", "complete", "health=" + to_string(health) + " status=" + status)
}

// ═══════════════════════════════════════════════════════════
// ─── MODE: REPORT ───
// ═══════════════════════════════════════════════════════════

fn mode_report() {
    let state = load_state()
    let lenses = count_lenses()
    let freshness = check_shared_freshness()
    let health = compute_health(lenses, state.build_ok, freshness.fresh, state.build_history)
    let status = classify_status(lenses, state.build_ok, health, state.lens_count)

    println("# fathom [Oracle] Report — " + timestamp())
    println("")
    println("## Overview")
    println("- Personality: Oracle (오라클)")
    println("- Goal: 22렌즈 실시간 대시보드 완성")
    println("- Version: " + version)
    println("")
    println("## Metrics")
    println("- Lens count: " + to_string(lenses) + "/" + to_string(goal_lenses))
    println("- Build: " + if state.build_ok { "OK" } else { "FAIL" })
    println("- Shared data: " + freshness.detail)
    println("- Health: " + to_string(health))
    println("- Status: " + status)
    println("- Total ticks: " + to_string(state.tick_count))
    println("- Last tick: " + state.last_tick)
    println("")

    // Build history visualization
    if state.build_history.len() > 0 {
        println("## Build History")
        let mut bar = "  "
        let mut i = 0
        while i < state.build_history.len() {
            bar = bar + if state.build_history[i] { "█" } else { "░" }
            i = i + 1
        }
        println(bar + "  (" + to_string(state.build_history.len()) + " builds)")
        println("")
    }

    // Error patterns
    if state.error_log.len() > 0 {
        println("## Recent Build Errors")
        let mut i = 0
        while i < state.error_log.len() {
            println("  " + to_string(i + 1) + ". " + state.error_log[i])
            i = i + 1
        }
        let patterns = analyze_build_failures(state.error_log)
        println("  Patterns: " + patterns)
        println("")
    }

    // Lens progress bar
    println("## Lens Progress")
    let filled = to_int(to_float(lenses) / to_float(goal_lenses) * 30.0)
    let mut pbar = "  ["
    let mut i = 0
    while i < 30 {
        if i < filled { pbar = pbar + "█" } else { pbar = pbar + "░" }
        i = i + 1
    }
    pbar = pbar + "] " + to_string(lenses) + "/" + to_string(goal_lenses)
    println(pbar)
    let remaining = goal_lenses - lenses
    if remaining > 0 {
        println("  " + to_string(remaining) + " lenses remaining")
    } else {
        println("  🎯 ALL LENSES COMPLETE")
    }
}

// ═══════════════════════════════════════════════════════════
// ─── CLI ENTRY ───
// ═══════════════════════════════════════════════════════════

let a = args()
let mode = if a.len() >= 2 { a[1] } else { "help" }

if mode == "status" { mode_status() }
if mode == "tick" { mode_tick() }
if mode == "report" { mode_report() }

if mode == "help" {
    println("engine_fathom.hexa [Oracle] v" + version)
    println("  6-layer terminal dashboard engine")
    println("")
    println("Usage:")
    println("  hexa engine_fathom.hexa status   — 현재 상태 조회")
    println("  hexa engine_fathom.hexa tick      — 빌드 + 렌즈 카운트 + 상태 갱신")
    println("  hexa engine_fathom.hexa report    — 상세 리포트")
}
