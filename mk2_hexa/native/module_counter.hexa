// module_counter.hexa — NEXUS 모듈 카운터: .hexa 파일 수 + core.json 동기화
// 흐름: native/ 스캔 → 카운트 → core.json total_files 비교 → 불일치 시 리포트
//
// 사용:
//   hexa module_counter.hexa                카운트 + 요약
//   hexa module_counter.hexa --detail       파일별 상세
//   hexa module_counter.hexa --sync         core.json 숫자 갱신
//   hexa module_counter.hexa --missing      core.json에 없는 모듈
//   hexa module_counter.hexa --help         사용법

// ═══════════════════════════════════════════════════════════════
// 공통 설정
// ═══════════════════════════════════════════════════════════════

let home = exec("printenv HOME").trim()
let dev = home + "/Dev"
let nexus_dir = dev + "/nexus"
let native_dir = nexus_dir + "/mk2_hexa/native"
let shared = nexus_dir + "/shared"
let core_json_path = shared + "/core.json"

let a = args()
let mode = if a.len() >= 3 { a[2] } else { "" }

// ═══════════════════════════════════════════════════════════════
// 유틸리티
// ═══════════════════════════════════════════════════════════════

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s)) } catch e {}
    v
}

fn ts_now() -> string {
    exec("date -u +%Y-%m-%dT%H:%M:%S").trim()
}

// ═══════════════════════════════════════════════════════════════
// 스캔
// ═══════════════════════════════════════════════════════════════

fn scan_hexa_files() -> list {
    let home = exec("printenv HOME").trim()
    let dir = home + "/Dev/nexus/mk2_hexa/native"
    let raw = exec("find " + dir + " -name '*.hexa' -type f 2>/dev/null").trim()
    if raw == "" { return [] }
    raw.split("\n")
}

fn get_core_json_count() -> i64 {
    let home = exec("printenv HOME").trim()
    let cp = home + "/Dev/nexus/shared/core.json"
    let mut count: i64 = 0
    try {
        let raw = read_file(cp)
        if raw.contains("\"total_files\"") {
            let parts = raw.split("\"total_files\"")[1].split(",")[0]
            let num = parts.replace(":", "").replace(" ", "").trim()
            count = safe_int(num)
        }
    } catch e {}
    count
}

fn categorize(files: list) -> map {
    let mut engines: i64 = 0
    let mut verifiers: i64 = 0
    let mut tools: i64 = 0
    let mut frontier: i64 = 0
    let mut bridges: i64 = 0
    let mut lenses: i64 = 0
    let mut other: i64 = 0

    for f in files {
        let name = f.split("/")[f.split("/").len() - 1]
        if name.starts_with("engine_") { engines = engines + 1 }
        else if name.starts_with("verify_") || name.starts_with("verifier") { verifiers = verifiers + 1 }
        else if name.starts_with("frontier_") { frontier = frontier + 1 }
        else if name.contains("consciousness_bridge") { bridges = bridges + 1 }
        else if name.starts_with("lens") || name.starts_with("lenses") { lenses = lenses + 1 }
        else if name.contains("todo") || name.contains("config") || name.contains("paths") || name.contains("template") { tools = tools + 1 }
        else { other = other + 1 }
    }

    #{
        "engines": engines,
        "verifiers": verifiers,
        "frontier": frontier,
        "bridges": bridges,
        "lenses": lenses,
        "tools": tools,
        "other": other
    }
}

// ═══════════════════════════════════════════════════════════════
// 메인
// ═══════════════════════════════════════════════════════════════

fn main() {
    if mode == "--help" || mode == "help" {
        println("module_counter.hexa — NEXUS 모듈 카운터")
        println("")
        println("사용법:")
        println("  hexa module_counter.hexa                카운트 + 요약")
        println("  hexa module_counter.hexa --detail       카테고리별 상세")
        println("  hexa module_counter.hexa --sync         core.json 갱신")
        println("  hexa module_counter.hexa --missing      미등록 모듈")
        return
    }

    let files = scan_hexa_files()
    let actual = files.len()
    let registered = get_core_json_count()

    println("═══════════════════════════════════════════════════")
    println("  module_counter — NEXUS 모듈 현황")
    println("═══════════════════════════════════════════════════")
    println("")
    println("실제 .hexa 파일:   " + to_string(actual) + "개")
    println("core.json 등록:   " + to_string(registered) + "개")

    if actual != registered {
        println("⚠ 불일치: diff = " + to_string(actual - registered))
    } else {
        println("✓ 동기화 상태 정상")
    }

    // 카테고리별 분류
    let cats = categorize(files)
    println("")
    println("═══ 카테고리 ═══")
    println("  엔진 (engine_*):     " + to_string(cats["engines"]))
    println("  검증 (verify_*):     " + to_string(cats["verifiers"]))
    println("  프론티어 (frontier_*): " + to_string(cats["frontier"]))
    println("  의식 브리지:          " + to_string(cats["bridges"]))
    println("  렌즈:                " + to_string(cats["lenses"]))
    println("  도구:                " + to_string(cats["tools"]))
    println("  기타:                " + to_string(cats["other"]))

    if mode == "--detail" {
        println("")
        println("═══ 전체 파일 목록 ═══")
        for i in range(0, actual) {
            let name = files[i].split("/")[files[i].split("/").len() - 1]
            println("  " + to_string(i + 1) + ". " + name)
        }
    }

    if mode == "--sync" {
        println("")
        println("═══ core.json 동기화 ═══")
        let home2 = exec("printenv HOME").trim()
        let cp2 = home2 + "/Dev/nexus/shared/core.json"
        try {
            let raw = read_file(cp2)
            let updated = raw.replace("\"total_files\": " + to_string(registered), "\"total_files\": " + to_string(actual))
            write_file(cp2, updated)
            println("core.json total_files 갱신: " + to_string(registered) + " → " + to_string(actual))
        } catch e {
            println("[ERROR] core.json 갱신 실패: " + e.to_string())
        }
    }

    // 250 마일스톤 체크
    println("")
    if actual >= 250 {
        println("🎯 250+ 모듈 달성! (" + to_string(actual) + "개)")
    } else {
        println("목표 250까지: " + to_string(250 - actual) + "개 부족")
    }
}

main()
