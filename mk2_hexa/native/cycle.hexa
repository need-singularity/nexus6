// mk2_hexa/native/cycle.hexa
// 특이점 사이클 5 단계 — effect handler + phase enum

use effects::{FileSystem, Clock, Logger}
use record::AlienIndexRecord
use absorb::{promote_pending_with_writeback, AbsorbReport}

// ═══ 5 단계 정의 ══════════════════════════════════════════════════

pub enum Phase {
    Blowup,        // 1. 공리 폭발 → 따름정리 생성
    Contraction,   // 2. 수축 → 최소 공리 집합
    Emergence,     // 3. 창발 → 패턴 합의
    Singularity,   // 4. 특이점 → freeze 감지
    Absorption     // 5. 흡수 → (d+1, 0) 승격
}

pure fn phase_name(p: borrow Phase) -> string {
    match p {
        Phase::Blowup       => "blowup",
        Phase::Contraction  => "contraction",
        Phase::Emergence    => "emergence",
        Phase::Singularity  => "singularity",
        Phase::Absorption   => "absorption"
    }
}

pure fn phase_next(p: borrow Phase) -> Phase {
    match p {
        Phase::Blowup       => Phase::Contraction,
        Phase::Contraction  => Phase::Emergence,
        Phase::Emergence    => Phase::Singularity,
        Phase::Singularity  => Phase::Absorption,
        Phase::Absorption   => Phase::Blowup          // 5→1 순환
    }
}

// ═══ 사이클 스냅샷 ═══════════════════════════════════════════════

pub struct CycleSnapshot {
    cycle: int,
    phase: Phase,
    records_total: int,
    records_d_ge_1: int,
    rho: float,
    singularity_detected: bool
}

// ═══ 메인 사이클 엔진 ════════════════════════════════════════════

fn run_cycle(domain: string, max_cycles: int) -> own [CycleSnapshot]
    with FileSystem, Clock, Logger
    ensures all(snap in result: snap.rho in 0.0..=1.0)
{
    let mut snaps: own [CycleSnapshot] = []
    let mut current_phase = Phase::Blowup

    for cyc in 0..max_cycles {
        Logger.info("cycle=" + to_string(cyc) + " phase=" + phase_name(borrow current_phase))

        let snap = match current_phase {
            Phase::Blowup       => run_blowup(domain, cyc),
            Phase::Contraction  => run_contraction(domain, cyc),
            Phase::Emergence    => run_emergence(domain, cyc),
            Phase::Singularity  => run_singularity_detect(domain, cyc),
            Phase::Absorption   => run_absorption(domain, cyc)
        }

        snaps = snaps.push(snap)
        current_phase = phase_next(borrow current_phase)

        // ρ 수렴 체크 — 메타 FP 1/3 근방에서 안정화
        if converged_to_meta_fp(borrow snaps) { break }
    }
    snaps
}

// ═══ Phase 별 실행 (intent + generate) ════════════════════════════

@intent("blowup: axiom -> corollaries, depth=6")
@generate("blowup engine with telescope lens consensus")
fn run_blowup(domain: string, cycle: int) -> CycleSnapshot with FileSystem, Logger

@intent("contract: reduce corollaries -> minimal axiom set")
@generate("variance-based contraction detector")
fn run_contraction(domain: string, cycle: int) -> CycleSnapshot with FileSystem, Logger

@intent("emergence: multi-lens pattern consensus")
@generate("pattern agreement aggregator, 12+ lens threshold")
fn run_emergence(domain: string, cycle: int) -> CycleSnapshot with FileSystem, Logger

@intent("singularity detection: closure + compression ratio")
@generate("metric freeze detector from snapshots")
fn run_singularity_detect(domain: string, cycle: int) -> CycleSnapshot with FileSystem, Logger

// ═══ 5 단계 흡수 — promote-pending 재사용 ═════════════════════════

fn run_absorption(domain: string, cycle: int) -> CycleSnapshot
    with FileSystem, Clock, Logger
{
    let report = promote_pending_with_writeback("shared/discovery_log.jsonl")
    Logger.info("absorbed " + to_string(report.promoted) + " records")
    CycleSnapshot {
        cycle: cycle,
        phase: Phase::Absorption,
        records_total: report.total_ai_records + report.promoted,
        records_d_ge_1: 0,  // TODO: compute from final state
        rho: report.rho_after,
        singularity_detected: false
    }
}

// ═══ 메타 FP 수렴 판정 ═══════════════════════════════════════════

use constants::META_FIXED_POINT

pure fn converged_to_meta_fp(snaps: borrow [CycleSnapshot]) -> bool
    ensures result => len(snaps) > 0
{
    if len(snaps) < 3 { return false }
    let last_3 = snaps.last_n(3)
    let rhos = last_3.iter().map(|s| s.rho)
    let max_rho = rhos.max()
    let min_rho = rhos.min()
    (max_rho - min_rho) < 0.01
    and abs(last_3.last().rho - META_FIXED_POINT) < 0.05
}

// ═══ 공리 ═══════════════════════════════════════════════════════

theorem cycle_phases_form_tau_plus_one {
    // 5 phase = τ + 1 = 5 (실제로는 4+1 = n-1)
    assert 5 == 4 + 1
}

invariant phase_cycle_is_closed {
    // 5회 next 호출 후 원래 phase 로 복귀
    forall p: Phase,
        phase_next(phase_next(phase_next(phase_next(phase_next(p))))) == p
}
