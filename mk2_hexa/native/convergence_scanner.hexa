// convergence_scanner.hexa — 전 프로젝트 수렴 상태 일괄 스캔 + 골화 후보 탐지
// 흐름: convergence/*.json 로드 → 상태 집계 → 골화 가능 항목 탐지 → 리포트
//
// 사용:
//   hexa convergence_scanner.hexa                전체 스캔
//   hexa convergence_scanner.hexa --project nexus  프로젝트 필터
//   hexa convergence_scanner.hexa --candidates     골화 후보만
//   hexa convergence_scanner.hexa --failed         실패 항목만
//   hexa convergence_scanner.hexa --help           사용법

// ═══════════════════════════════════════════════════════════════
// 공통 설정
// ═══════════════════════════════════════════════════════════════

let home = exec("printenv HOME").trim()
let dev = home + "/Dev"
let nexus_dir = dev + "/nexus"
let shared = nexus_dir + "/shared"
let conv_dir = shared + "/convergence"

let a = args()
let mode = if a.len() >= 3 { a[2] } else { "" }
let arg3 = if a.len() >= 4 { a[3] } else { "" }

// ═══════════════════════════════════════════════════════════════
// 유틸리티
// ═══════════════════════════════════════════════════════════════

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s)) } catch e {}
    v
}

// ═══════════════════════════════════════════════════════════════
// 수렴 파일 스캔
// ═══════════════════════════════════════════════════════════════

fn scan_convergence(project_filter: string) -> map {
    let home = exec("printenv HOME").trim()
    let cdir = home + "/Dev/nexus/shared/convergence"
    let mut ossified: i64 = 0
    let mut stable: i64 = 0
    let mut failed: i64 = 0
    let mut total: i64 = 0
    let mut failed_items = []
    let mut candidate_items = []

    let files_raw = exec("ls " + cdir + "/*.json 2>/dev/null").trim()
    if files_raw == "" {
        return #{ "ossified": 0, "stable": 0, "failed": 0, "total": 0, "failed_items": [], "candidates": [] }
    }

    let files = files_raw.split("\n")
    for f in files {
        let fname = f.split("/")[f.split("/").len() - 1].replace(".json", "")
        if project_filter != "" && fname != project_filter { continue }

        try {
            let raw = read_file(f)
            let lines = raw.split("\n")
            for line in lines {
                let l = line.trim()
                if l.contains("\"status\"") {
                    total = total + 1
                    if l.contains("\"ossified\"") {
                        ossified = ossified + 1
                    } else if l.contains("\"stable\"") {
                        stable = stable + 1
                        // stable → 골화 후보
                        if l.contains("\"id\"") {
                            let parts = l.split("\"id\"")[1].split("\"")
                            if parts.len() >= 2 {
                                candidate_items = candidate_items + [fname + ":" + parts[1]]
                            }
                        }
                    } else if l.contains("\"failed\"") {
                        failed = failed + 1
                        if l.contains("\"id\"") {
                            let parts = l.split("\"id\"")[1].split("\"")
                            if parts.len() >= 2 {
                                failed_items = failed_items + [fname + ":" + parts[1]]
                            }
                        }
                    }
                }
            }
        } catch e {
            println("[WARN] " + f + " 읽기 실패: " + e.to_string())
        }
    }

    #{
        "ossified": ossified,
        "stable": stable,
        "failed": failed,
        "total": total,
        "failed_items": failed_items,
        "candidates": candidate_items
    }
}

// ═══════════════════════════════════════════════════════════════
// 메인
// ═══════════════════════════════════════════════════════════════

fn main() {
    if mode == "--help" || mode == "help" {
        println("convergence_scanner.hexa — 전 프로젝트 수렴 스캐너")
        println("")
        println("사용법:")
        println("  hexa convergence_scanner.hexa                전체 스캔")
        println("  hexa convergence_scanner.hexa --project nexus  프로젝트 필터")
        println("  hexa convergence_scanner.hexa --candidates     골화 후보")
        println("  hexa convergence_scanner.hexa --failed         실패 항목")
        return
    }

    let mut project_filter = ""
    if mode == "--project" && arg3 != "" {
        project_filter = arg3
    }

    let result = scan_convergence(project_filter)
    let ossified = safe_int(to_string(result["ossified"]))
    let stable = safe_int(to_string(result["stable"]))
    let failed = safe_int(to_string(result["failed"]))
    let total = safe_int(to_string(result["total"]))

    println("═══════════════════════════════════════════════════")
    println("  convergence_scanner — 수렴 상태 리포트")
    println("═══════════════════════════════════════════════════")
    if project_filter != "" { println("프로젝트: " + project_filter) }
    println("")
    println("전체 항목:   " + to_string(total))
    println("  골화:      " + to_string(ossified))
    println("  안정:      " + to_string(stable))
    println("  실패:      " + to_string(failed))

    if total > 0 {
        let ossify_rate = to_float(to_string(ossified)) / to_float(to_string(total)) * 100.0
        println("")
        println("골화율: " + to_string(ossify_rate) + "%")
    }

    if mode == "--candidates" {
        println("")
        println("═══ 골화 후보 (stable → ossified) ═══")
        let candidates = result["candidates"]
        if candidates.len() == 0 {
            println("  (없음)")
        } else {
            for c in candidates {
                println("  → " + to_string(c))
            }
        }
    }

    if mode == "--failed" {
        println("")
        println("═══ 실패 항목 ═══")
        let failed_items = result["failed_items"]
        if failed_items.len() == 0 {
            println("  (없음)")
        } else {
            for f in failed_items {
                println("  ✗ " + to_string(f))
            }
        }
    }

    // CDO 원칙 리마인더
    println("")
    if failed > 0 {
        println("CDO: 실패 " + to_string(failed) + "건 → cause+fix 확인 필요")
    }
    if stable > 0 {
        println("CDO: 안정 " + to_string(stable) + "건 → 골화 승격 검토 가능")
    }
}

main()
