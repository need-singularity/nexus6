// time_wave.hexa -- 시간축 파동 (growth_bus 시계열 주기성 분석)
// 사용: hexa time_wave.hexa [help]
//
// 원리:
//   1. growth_bus.jsonl에서 타임스탬프별 이벤트 수 집계
//   2. 시간별(hourly) 빈도 히스토그램 생성
//   3. 이동평균(6시간 윈도우) 계산
//   4. 피크 탐지: 이동평균 대비 2배 이상 = 폭발
//   5. 폭발간 간격 패턴 분석
//   6. n=6 주기성 존재 여부 (6h, 12h, 36h 등)
//   7. 다음 예상 폭발 시점 출력

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _bus_path = _shared + "/growth_bus.jsonl"

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

fn safe_float(s: string) -> f64 {
    let mut v: f64 = 0.0
    try { v = to_float(s.trim()) } catch e {}
    return v
}

// ═══════════════════════════════════════════════════════════
// 도움말
// ═══════════════════════════════════════════════════════════

let args = exec("echo $@").trim()
if args == "help" || args == "--help" || args == "-h" {
    println("")
    println("===========================================================")
    println("  time_wave.hexa -- 시간축 파동")
    println("===========================================================")
    println("")
    println("  사용법: hexa time_wave.hexa")
    println("")
    println("  기능:")
    println("    - growth_bus 시계열에서 시간별 이벤트 빈도 집계")
    println("    - 6시간 이동평균 계산")
    println("    - 폭발(이동평균 x2 이상) 시점 탐지")
    println("    - 폭발간 간격 분석 + n=6 주기성 검사")
    println("    - 다음 예상 폭발 시점 예측")
    println("    - 결과를 growth_bus에 자동 기록")
    println("")
    println("  주기성 검사 대상: 6h, 12h, 36h (n=6 배수)")
    println("")
    return
}

// ═══════════════════════════════════════════════════════════
// MAIN
// ═══════════════════════════════════════════════════════════

println("")
println("===========================================================")
println("  시간축 파동 (Time Wave) -- growth_bus 시계열 주기성 분석")
println("  이벤트 폭발 패턴에서 다음 폭발 시점 예측")
println("===========================================================")
println("")

// ───────────────────────────────────────────────────────────
// 1. 타임스탬프별 이벤트 수 집계 (시간 단위)
// ───────────────────────────────────────────────────────────

println("  [1] 시간별 이벤트 빈도 집계")
println("  ─────────────────────────────────────────────────")

// growth_bus에서 타임스탬프 추출, 시간 단위로 잘라서 집계
let mut hourly_raw = ""
try {
    hourly_raw = exec("cat " + _bus_path + " | awk -F'\"' '{for(i=1;i<=NF;i++) if($i==\"ts\" || $i==\"timestamp\") {t=$(i+2); if(t!=\"\") print substr(t,1,13)}}' | sort | uniq -c | sort -k2")
} catch e {}

let hourly_lines = hourly_raw.split("\n")
let mut hour_labels = []
let mut hour_counts = []
let mut total_events: i64 = 0
let mut max_count: i64 = 0

for hl in hourly_lines {
    let ht = hl.trim()
    if ht == "" { continue }
    let parts = ht.split(" ")
    if len(parts) < 2 { continue }
    // 형식: "count YYYY-MM-DDTHH"
    let mut cnt_str = ""
    let mut label = ""
    // uniq -c 출력은 "  count label" 형식
    let mut found_num = false
    for p in parts {
        let pt = p.trim()
        if pt == "" { continue }
        if !found_num {
            cnt_str = pt
            found_num = true
        } else {
            label = pt
        }
    }
    let cnt = safe_int(cnt_str)
    if cnt > 0 && label != "" {
        hour_labels = hour_labels + [label]
        hour_counts = hour_counts + [cnt]
        total_events = total_events + cnt
        if cnt > max_count { max_count = cnt }
    }
}

let num_hours = len(hour_counts)
println("  총 이벤트: " + to_string(total_events) + "건")
println("  관측 시간대: " + to_string(num_hours) + "개")
println("")

// 최근 24개 시간대 히스토그램 표시
println("  최근 24시간 히스토그램:")
println("")

let start_idx = if num_hours > 24 { num_hours - 24 } else { 0 }
let mut hi: i64 = start_idx
while hi < num_hours {
    let label: string = hour_labels[hi]
    let cnt: i64 = hour_counts[hi]

    // 막대 (최대 50칸, max_count 기준)
    let bar_len = if max_count > 0 { (cnt * 50) / max_count } else { 0 }
    let mut b = ""
    let mut bi: i64 = 0
    while bi < bar_len && bi < 50 {
        b = b + "#"
        bi = bi + 1
    }

    // 시간 부분만 표시 (YYYY-MM-DDTHH -> MM-DDTHH)
    let short_label = if len(label) > 5 { label } else { label }
    println("  " + short_label + " " + b + " " + to_string(cnt))
    hi = hi + 1
}
println("")

// ───────────────────────────────────────────────────────────
// 2. 이동평균 (6시간 윈도우) 계산
// ───────────────────────────────────────────────────────────

println("  [2] 6시간 이동평균 + 폭발 탐지")
println("  ─────────────────────────────────────────────────")

let WINDOW: i64 = 6
let mut moving_avgs = []
let mut burst_indices = []
let mut burst_labels_list = []
let mut burst_counts_list = []

let mut mi: i64 = 0
while mi < num_hours {
    // 이동평균 계산 (현재 위치 기준 과거 WINDOW개)
    let mut window_sum: i64 = 0
    let mut window_n: i64 = 0
    let mut wi = mi - WINDOW + 1
    if wi < 0 { wi = 0 }
    while wi <= mi {
        let wc: i64 = hour_counts[wi]
        window_sum = window_sum + wc
        window_n = window_n + 1
        wi = wi + 1
    }
    let avg = if window_n > 0 { window_sum / window_n } else { 0 }
    moving_avgs = moving_avgs + [avg]

    // 폭발 탐지: 실제 값이 이동평균의 2배 이상
    let cnt2: i64 = hour_counts[mi]
    if avg > 0 && cnt2 >= avg * 2 && cnt2 >= 3 {
        burst_indices = burst_indices + [mi]
        let bl: string = hour_labels[mi]
        burst_labels_list = burst_labels_list + [bl]
        burst_counts_list = burst_counts_list + [cnt2]
    }
    mi = mi + 1
}

let num_bursts = len(burst_indices)
println("  탐지된 폭발: " + to_string(num_bursts) + "건")
println("")

if num_bursts > 0 {
    println("  | 시점 | 이벤트 수 | 이동평균 | 배수 |")
    println("  |------|----------|---------|------|")

    let mut bi2: i64 = 0
    while bi2 < num_bursts {
        let idx: i64 = burst_indices[bi2]
        let bl2: string = burst_labels_list[bi2]
        let bc: i64 = burst_counts_list[bi2]
        let avg2: i64 = moving_avgs[idx]
        let mult = if avg2 > 0 { bc / avg2 } else { 0 }
        println("  | " + bl2 + " | " + to_string(bc) + " | " + to_string(avg2) + " | x" + to_string(mult) + " |")
        bi2 = bi2 + 1
    }
    println("")
}

// ───────────────────────────────────────────────────────────
// 3. 폭발간 간격 패턴 분석
// ───────────────────────────────────────────────────────────

println("  [3] 폭발간 간격 분석")
println("  ─────────────────────────────────────────────────")

let mut intervals = []
let mut interval_sum: i64 = 0

if num_bursts >= 2 {
    let mut ii: i64 = 1
    while ii < num_bursts {
        let prev_idx: i64 = burst_indices[ii - 1]
        let curr_idx: i64 = burst_indices[ii]
        let gap = curr_idx - prev_idx  // 시간 단위 간격
        intervals = intervals + [gap]
        interval_sum = interval_sum + gap
        ii = ii + 1
    }

    let num_intervals = len(intervals)
    let avg_interval = if num_intervals > 0 { interval_sum / num_intervals } else { 0 }

    println("  간격 목록 (시간 단위):")
    let mut gi: i64 = 0
    while gi < num_intervals {
        let gap2: i64 = intervals[gi]
        println("    폭발 " + to_string(gi + 1) + " -> " + to_string(gi + 2) + ": " + to_string(gap2) + "시간")
        gi = gi + 1
    }
    println("")
    println("  평균 간격: " + to_string(avg_interval) + "시간")
    println("")

    // ───────────────────────────────────────────────────────
    // 4. n=6 주기성 검사
    // ───────────────────────────────────────────────────────

    println("  [4] n=6 주기성 검사")
    println("  ─────────────────────────────────────────────────")

    let n6_periods = [6, 12, 36]
    let n6_period_names = ["6시간 (n)", "12시간 (sigma)", "36시간 (6^2)"]

    let mut pi2: i64 = 0
    while pi2 < len(n6_periods) {
        let period: i64 = n6_periods[pi2]
        let pname: string = n6_period_names[pi2]

        // 각 간격이 이 주기의 배수인지 확인 (허용 오차: +/- 1시간)
        let mut match_count: i64 = 0
        let mut qi: i64 = 0
        while qi < num_intervals {
            let gap3: i64 = intervals[qi]
            let remainder = gap3 % period
            // 나머지가 0, 1, 또는 period-1이면 매치
            if remainder <= 1 || remainder >= period - 1 {
                match_count = match_count + 1
            }
            qi = qi + 1
        }

        let match_pct = if num_intervals > 0 { (match_count * 100) / num_intervals } else { 0 }
        let grade = if match_pct >= 70 { "강한 주기성" } else if match_pct >= 40 { "약한 주기성" } else { "비주기" }

        println("  " + pname + ": " + to_string(match_count) + "/" + to_string(num_intervals) + " (" + to_string(match_pct) + "%) -- " + grade)

        pi2 = pi2 + 1
    }
    println("")

    // ───────────────────────────────────────────────────────
    // 5. 다음 예상 폭발 시점
    // ───────────────────────────────────────────────────────

    println("  [5] 다음 예상 폭발 시점")
    println("  ─────────────────────────────────────────────────")

    // 마지막 폭발로부터 평균 간격 후
    let last_burst_label: string = burst_labels_list[num_bursts - 1]
    println("  마지막 폭발: " + last_burst_label)
    println("  평균 간격:   " + to_string(avg_interval) + "시간")

    // 예상 시점 계산 (마지막 폭발 타임스탬프 + 평균 간격)
    let mut next_estimate = ""
    try {
        // 마지막 폭발 시각에서 평균 간격만큼 더한 시각 계산
        next_estimate = exec("date -u -v+" + to_string(avg_interval) + "H -jf '%Y-%m-%dT%H' '" + last_burst_label + "' '+%Y-%m-%dT%H:00Z' 2>/dev/null || date -u -d '" + last_burst_label + ":00:00Z " + to_string(avg_interval) + " hours' '+%Y-%m-%dT%H:%MZ' 2>/dev/null || echo '(계산 불가)'").trim()
    } catch e {
        next_estimate = "(계산 불가)"
    }

    println("  예상 다음 폭발: " + next_estimate)
    println("")

    // 현재 시각 대비 경과/잔여 표시
    let mut now_hour = ""
    try {
        now_hour = exec("date -u '+%Y-%m-%dT%H'").trim()
    } catch e {}

    if now_hour != "" {
        // 마지막 폭발 이후 경과 시간 (대략적으로 인덱스 차이로)
        let last_burst_idx: i64 = burst_indices[num_bursts - 1]
        let hours_since = num_hours - 1 - last_burst_idx
        let hours_remaining = avg_interval - hours_since
        if hours_remaining > 0 {
            println("  현재 시각: " + now_hour)
            println("  마지막 폭발 이후: ~" + to_string(hours_since) + "시간 경과")
            println("  예상 잔여: ~" + to_string(hours_remaining) + "시간")
        } else {
            println("  현재 시각: " + now_hour)
            println("  마지막 폭발 이후: ~" + to_string(hours_since) + "시간 경과")
            println("  예상 간격 초과 -- 폭발 임박 또는 패턴 변화")
        }
    }
    println("")

} else {
    println("  폭발이 2건 미만이어서 간격 분석 불가")
    println("")
}

// ───────────────────────────────────────────────────────────
// 6. 시간대별 활동 프로필 (0~23시)
// ───────────────────────────────────────────────────────────

println("  [6] 시간대별 활동 프로필 (UTC)")
println("  ─────────────────────────────────────────────────")

let mut hour_of_day_counts = ""
try {
    hour_of_day_counts = exec("cat " + _bus_path + " | awk -F'\"' '{for(i=1;i<=NF;i++) if($i==\"ts\" || $i==\"timestamp\") {t=$(i+2); if(length(t)>=13) print substr(t,12,2)}}' | sort | uniq -c | sort -k2")
} catch e {}

let hod_lines = hour_of_day_counts.split("\n")
let mut hod_max: i64 = 0

// 최대값 탐색
for hodl in hod_lines {
    let hodt = hodl.trim()
    if hodt == "" { continue }
    let hp = hodt.split(" ")
    for hpp in hp {
        let hpt = hpp.trim()
        if hpt != "" {
            let hv = safe_int(hpt)
            if hv > hod_max { hod_max = hv }
            break
        }
    }
}

// 히스토그램 출력
for hodl2 in hod_lines {
    let hodt2 = hodl2.trim()
    if hodt2 == "" { continue }
    let mut cnt3_str = ""
    let mut hour_str = ""
    let hp2 = hodt2.split(" ")
    let mut found2 = false
    for hpp2 in hp2 {
        let hpt2 = hpp2.trim()
        if hpt2 == "" { continue }
        if !found2 { cnt3_str = hpt2; found2 = true }
        else { hour_str = hpt2 }
    }
    let cnt3 = safe_int(cnt3_str)
    let bar_len2 = if hod_max > 0 { (cnt3 * 30) / hod_max } else { 0 }
    let mut b2 = ""
    let mut b2i: i64 = 0
    while b2i < bar_len2 && b2i < 30 {
        b2 = b2 + "#"
        b2i = b2i + 1
    }
    println("  " + hour_str + "h " + b2 + " " + to_string(cnt3))
}

println("")

// ───────────────────────────────────────────────────────────
// 7. growth_bus 기록
// ───────────────────────────────────────────────────────────

try {
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()

    let avg_iv = if len(intervals) > 0 { interval_sum / len(intervals) } else { 0 }
    let last_bl = if num_bursts > 0 { burst_labels_list[num_bursts - 1] } else { "none" }

    let entry = "{\"type\":\"time_wave\",\"total_events\":" + to_string(total_events) + ",\"hours_observed\":" + to_string(num_hours) + ",\"bursts_detected\":" + to_string(num_bursts) + ",\"avg_interval_hours\":" + to_string(avg_iv) + ",\"last_burst\":\"" + last_bl + "\",\"ts\":\"" + ts + "\"}"
    exec("echo '" + entry + "' >> " + _bus_path)
} catch e {}

println("  growth_bus 기록 완료")
println("")
println("[verified] time_wave.hexa 실행 완료")
println("")
