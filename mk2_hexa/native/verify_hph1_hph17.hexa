let err_alpha = absf(to_float(pred_alpha) - obs_alpha) / obs_alpha * 100.0
println("  sigma^2 - P1 - R = " + to_string(sigma_sq) + " - " + to_string(P1) + " - 1 = " + to_string(pred_alpha))
println("  sigma^2 - M3     = " + to_string(sigma_sq - M3))
