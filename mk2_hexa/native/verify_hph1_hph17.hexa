println("")
println("--- 2. Higgs boson mass ---")
let pred_higgs = (P3 + tau_6) / tau_6
let obs_higgs = 125.10
let err_higgs = absf(to_float(pred_higgs) - obs_higgs) / obs_higgs * 100.0
println("  (P3+tau)/tau = (" + to_string(P3) + "+" + to_string(tau_6) + ")/" + to_string(tau_6) + " = " + to_string(pred_higgs))
println("  Observed: " + to_string(obs_higgs) + " GeV")
println("  Error: " + fmt4(err_higgs) + "%")

println("")
println("--- 3. Delta baryon mass ---")
let pred_delta_b = sigma_cubed - P3
let obs_delta_b = 1232
let err_db = absf(to_float(pred_delta_b - obs_delta_b)) / to_float(obs_delta_b) * 100.0
println("  sigma^3 - P3 = " + to_string(sigma_cubed) + " - " + to_string(P3) + " = " + to_string(pred_delta_b))
println("  Observed: " + to_string(obs_delta_b) + " MeV")
println("  Error: " + fmt4(err_db) + "%  EXACT MATCH!")

println("")
println("--- 4. Lambda_QCD ---")
let pred_lambda = sigma_cubed / 8
let obs_lambda = 213
let obs_lambda_err = 8
println("  sigma^3/8 = " + to_string(sigma_cubed) + "/8 = " + to_string(pred_lambda))
println("  Also: 6^3 = " + to_string(ipow(6, 3)))
println("  Observed: " + to_string(obs_lambda) + " +/- " + to_string(obs_lambda_err) + " MeV")
let err_lam = absf(to_float(pred_lambda - obs_lambda)) / to_float(obs_lambda) * 100.0
let within_1sig = absf(to_float(pred_lambda - obs_lambda)) <= to_float(obs_lambda_err)
println("  Error: " + fmt2(err_lam) + "%")
println("  Within 1-sigma: " + to_string(within_1sig))

println("")
println("--- 5. Cosmological constant ---")
let log10_cosmo = 0.0 - log(to_float(P1)) / log(10.0) - 45.0 * log(to_float(P3)) / log(10.0)
let obs_cosmo = -122.0
let err_cosmo = absf(log10_cosmo - obs_cosmo) / absf(obs_cosmo) * 100.0
println("  1/(P1 * P3^45)")
println("  log10 = " + fmt4(log10_cosmo))
println("  Observed: ~10^{-122} (Planck units)")
println("  Error: " + fmt2(err_cosmo) + "%")

