let mut cnt_star = 0
let mut cnt_green = 0
let mut cnt_orange = 0
let mut cnt_white = 0
let mut cnt_miss = 0

let mut tid = 0
while tid < 100 {
    let sols = scan(tid)
    let g = grade_of(sols, false)
    let icon = grade_icon(g)
    if g == "STAR" { cnt_star = cnt_star + 1 }
    if g == "GREEN" { cnt_green = cnt_green + 1 }
    if g == "ORANGE" { cnt_orange = cnt_orange + 1 }
    if g == "WHITE" { cnt_white = cnt_white + 1 }
    if g == "MISS" { cnt_miss = cnt_miss + 1 }
    let h28 = if arr_contains(sols, 28) { "28Y" } else { "28N" }
    let mut show = sols
    if len(sols) > 10 {
        let mut cut = []
        let mut j = 0
        while j < 10 {
            cut = cut + [sols[j]]
            j = j + 1
        }
        show = cut
    }
    println(icon + " " + ids[tid] + " [" + domains[tid] + "] sols(" + to_string(len(sols)) + "): " + to_string(show) + " | " + h28)
    tid = tid + 1
}

