// 포팅 원본: tecs-l/math/frontier_1600_verify.py (416 LOC)
// Frontier 1400: 100 hypotheses across 10 domains
// Domains: MultOrder, QuadRes, Matrix, Music, Chemistry,
//          InfoTheory, Evolution, Telepathy, ProbNT, Topology
//
// Reduced LIMIT for interpreter speed. Fraction → integer cross-multiply.

let LIMIT = 60

// ═══ Core Arithmetic Helpers ═══

fn divs(n: int) -> list {
    let mut d = []
    let mut i = 1
    while i * i <= n {
        if n % i == 0 {
            d = d + [i]
            if i * i != n { d = d + [n / i] }
        }
        i = i + 1
    }
    d.sort()
}

fn sopfr(n: int) -> int {
    let mut s = 0
    let mut t = n
    let mut p = 2
    while p * p <= t {
        while t % p == 0 {
            s = s + p
            t = t / p
        }
        p = p + 1
    }
    if t > 1 { s = s + t }
    s
}

fn omega(n: int) -> int {
    let mut c = 0
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { c = c + 1 }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { c = c + 1 }
    c
}

fn big_omega(n: int) -> int {
    let mut c = 0
    let mut t = n
    let mut p = 2
    while p * p <= t {
        while t % p == 0 {
            c = c + 1
            t = t / p
        }
        p = p + 1
    }
    if t > 1 { c = c + 1 }
    c
}

fn rad(n: int) -> int {
    let mut r = 1
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { r = r * p }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { r = r * t }
    r
}

fn mobius(n: int) -> int {
    if n == 1 { return 1 }
    let mut t = n
    let mut p = 2
    let mut c = 0
    while p * p <= t {
        if t % p == 0 {
            c = c + 1
            t = t / p
        }
        if t % p == 0 { return 0 }
        p = p + 1
    }
    if t > 1 { c = c + 1 }
    if c % 2 == 0 { 1 } else { -1 }
}

fn psi_fn(n: int) -> int {
    let mut r = n
    let mut t = n
    let mut ps = []
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { ps = ps + [p] }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { ps = ps + [t] }
    let mut i = 0
    while i < len(ps) {
        r = r * (ps[i] + 1) / ps[i]
        i = i + 1
    }
    r
}

fn is_prime(n: int) -> bool {
    if n < 2 { return false }
    if n < 4 { return true }
    if n % 2 == 0 || n % 3 == 0 { return false }
    let mut i = 5
    while i * i <= n {
        if n % i == 0 || n % (i + 2) == 0 { return false }
        i = i + 6
    }
    true
}

fn prime_factors(n: int) -> list {
    let mut fs = []
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % p == 0 { fs = fs + [p] }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    if t > 1 { fs = fs + [t] }
    fs
}

fn is_squarefree(n: int) -> bool {
    let mut t = n
    let mut p = 2
    while p * p <= t {
        if t % (p * p) == 0 { return false }
        while t % p == 0 { t = t / p }
        p = p + 1
    }
    true
}

fn ord_mod(a: int, m: int) -> int {
    if m <= 1 { return 0 }
    if gcd(a, m) != 1 { return 0 }
    let mut o = 1
    let mut x = a % m
    while x != 1 {
        x = (x * a) % m
        o = o + 1
        if o > m { return 0 }
    }
    o
}

fn legendre(a: int, p: int) -> int {
    let mut aa = a % p
    if aa < 0 { aa = aa + p }
    if aa == 0 { return 0 }
    let e = (p - 1) / 2
    let r = pow(aa, e) % p
    if r <= 1 { return r }
    r - p
}

fn sigma_k(n: int, k: int) -> int {
    let ds = divs(n)
    let mut s = 0
    let mut i = 0
    while i < len(ds) {
        s = s + pow(ds[i], k)
        i = i + 1
    }
    s
}

fn fact(n: int) -> int {
    let mut r = 1
    let mut i = 2
    while i <= n {
        r = r * i
        i = i + 1
    }
    r
}

fn arr_contains(arr: list, v: int) -> bool {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == v { return true }
        i = i + 1
    }
    false
}

fn int_log2(x: int) -> float {
    log(to_float(x)) / log(2.0)
}

fn phi_chain(n: int) -> int {
    let mut c = 0
    let mut v = n
    while v > 1 {
        v = phi(v)
        c = c + 1
    }
    c
}

fn my_lcm(a: int, b: int) -> int {
    a * b / gcd(a, b)
}

// ═══ Grade function ═══

fn grade_of(sols: list, ad_hoc: bool) -> string {
    let ns = len(sols)
    let h6 = arr_contains(sols, 6)
    let uniq = ns == 1 && h6
    if !h6 { return "MISS" }
    if uniq && !ad_hoc { return "STAR" }
    if uniq && ad_hoc { return "GREEN" }
    if ns <= 3 && h6 { return "GREEN" }
    if ns <= 10 && h6 { return "ORANGE" }
    "WHITE"
}

fn grade_icon(g: string) -> string {
    if g == "STAR" { return "⭐" }
    if g == "GREEN" { return "🟩" }
    if g == "ORANGE" { return "🟧" }
    if g == "WHITE" { return "⚪" }
    "⬛"
}

// ═══ Test functions — 100 hypotheses ═══
// Each returns true/false for a given n.

// DOMAIN 1: MULTIPLICATIVE ORDERS (10)
fn t_ord01(n: int) -> bool {
    let s = sigma(n)
    if s <= 1 { return false }
    if gcd(n, s) != 1 { return false }
    ord_mod(n, s) == phi(n)
}
fn t_ord02(n: int) -> bool {
    let s = sigma(n)
    if s <= 1 { return false }
    let ph = phi(n)
    if gcd(ph, s) != 1 { return false }
    ord_mod(ph, s) == omega(n)
}
fn t_ord03(n: int) -> bool {
    if n <= 2 || n % 2 == 0 { return false }
    ord_mod(2, n) == sopfr(n) - 1
}
fn t_ord04(n: int) -> bool {
    let s = sigma(n)
    let t = tau(n)
    if s % t != 0 || n <= 1 { return false }
    let q = s / t
    if gcd(q, n) != 1 { return false }
    ord_mod(q, n) == phi(n)
}
fn t_ord05(n: int) -> bool {
    if !is_prime(n) || n <= 2 { return false }
    let mut a = 2
    while a < n {
        if ord_mod(a, n) == n - 1 { return a == omega(n) }
        a = a + 1
    }
    false
}
fn t_ord06(n: int) -> bool {
    let s = sigma(n)
    if s <= 1 { return false }
    is_prime(s) && s - 1 == n
}
fn t_ord07(n: int) -> bool {
    let s = sigma(n)
    let t = tau(n)
    if s <= 1 || t <= 1 { return false }
    if gcd(n, s) != 1 || gcd(n, t) != 1 { return false }
    ord_mod(n, s) * ord_mod(n, t) == n
}
fn t_ord08(n: int) -> bool {
    phi(n) == 2 && sigma(n) == 2 * n
}
fn t_ord09(n: int) -> bool {
    let np1 = n + 1
    is_prime(np1) && sigma(n) == 2 * n && ord_mod(2, np1) == n
}
fn t_ord10(n: int) -> bool {
    let sf = sopfr(n)
    if sf <= 1 { return false }
    let s = sigma(n)
    if gcd(s, sf) != 1 { return false }
    ord_mod(s, sf) == phi(n)
}

// DOMAIN 2: QUADRATIC RESIDUES (10)
fn t_quad01(n: int) -> bool {
    let np1 = n + 1
    is_prime(np1) && legendre(n, np1) == -1 && sigma(n) == 2 * n
}
fn t_quad02(n: int) -> bool {
    sigma(n) % n == 0 && sigma(n) / n == 2
}
fn t_quad03(n: int) -> bool {
    let s = sigma(n)
    let t = tau(n)
    if s % t != 0 { return false }
    let q = s / t
    if !is_prime(q) { return false }
    let nm = n % q
    legendre(nm, q) == 1
}
fn t_quad04(n: int) -> bool {
    if omega(n) != 2 || !is_squarefree(n) { return false }
    let ps = prime_factors(n)
    if len(ps) != 2 { return false }
    let p0 = ps[0]
    let p1 = ps[1]
    if !is_prime(p0) || !is_prime(p1) { return false }
    let l01 = legendre(p0, p1)
    let l10 = legendre(p1, p0)
    let exp = (p0 - 1) * (p1 - 1) / 4
    let rhs = if exp % 2 == 0 { 1 } else { -1 }
    l01 * l10 == rhs
}
fn t_quad05(n: int) -> bool {
    if !is_prime(n) { return false }
    let mut qr_count = 0
    let mut a = 1
    while a < n {
        let mut found = false
        let mut x = 0
        while x < n {
            if (x * x) % n == a { found = true }
            x = x + 1
        }
        if found { qr_count = qr_count + 1 }
        a = a + 1
    }
    qr_count == (n - 1) / 2
}
fn t_quad06(n: int) -> bool {
    n % 2 == 0 && n % 3 == 0 && sigma(n) == 2 * n
}
fn t_quad07(n: int) -> bool {
    let np1 = n + 1
    let heeg = [1, 2, 3, 7, 11, 19, 43, 67, 163]
    arr_contains(heeg, np1) && sigma(n) == 2 * n
}
fn t_quad08(n: int) -> bool {
    let np1 = n + 1
    if !is_prime(np1) || n % 2 != 0 { return false }
    let aa = (np1 - 1) % np1
    let lhs = legendre(aa, np1)
    let exp = n / 2
    let rhs = if exp % 2 == 0 { 1 } else { -1 }
    lhs == rhs
}
fn t_quad09(n: int) -> bool {
    let s = sigma(n)
    let t = tau(n)
    if s % t != 0 { return false }
    let q = s / t
    if q == 0 { return false }
    // Fraction(phi*tau, sigma*n) == Fraction(1, sigma/tau)
    // phi*tau / (sigma*n) == tau/sigma  →  phi*tau*sigma == tau*sigma*n  →  phi == n
    // Actually: 1/q = tau/(sigma), so phi*tau/(s*n) == 1/q means phi*tau*q == s*n
    phi(n) * t * q == s * n
}
fn t_quad10(n: int) -> bool {
    is_prime(n + 1) && sigma(n) == 2 * n
}

// DOMAIN 3: MATRIX/OPERATOR (10)
fn t_mat01(n: int) -> bool {
    if sigma(n) != 2 * n { return false }
    let mut mert = 0
    let mut k = 1
    while k <= n {
        mert = mert + mobius(k)
        k = k + 1
    }
    mert == -1
}
fn t_mat02(n: int) -> bool {
    let ds = divs(n)
    let mut s = 0
    let mut i = 0
    while i < len(ds) {
        s = s + gcd(ds[i], ds[i])
        i = i + 1
    }
    s == sigma(n)
}
fn t_mat03(n: int) -> bool {
    sigma_k(n, 2) == sigma_k(n, 2)
}
fn t_mat04(n: int) -> bool {
    let s = sigma(n)
    if s == 0 { return false }
    let s2 = sigma_k(n, 2)
    if s2 % s != 0 { return false }
    s2 / s == sopfr(n) + phi(n) - 1
}
fn t_mat05(n: int) -> bool {
    sigma(n) + tau(n) + phi(n) + omega(n) == 20
}
fn t_mat06(n: int) -> bool {
    tau(n) % 4 == 0 && sigma(n) == 2 * n
}
fn t_mat07(n: int) -> bool {
    if omega(n) != 2 || !is_squarefree(n) { return false }
    let ds = divs(n)
    let mut prod = 1
    let mut i = 0
    while i < len(ds) {
        prod = prod * phi(ds[i])
        i = i + 1
    }
    prod == pow(phi(n), omega(n))
}
fn t_mat08(n: int) -> bool {
    let sf = sopfr(n)
    if sf == 0 { return false }
    let s2 = sigma_k(n, 2)
    let s3 = sigma_k(n, 3)
    let s = sigma(n)
    let t = tau(n)
    s3 * sf == s2 * (s + t)
}
fn t_mat09(n: int) -> bool {
    sigma_k(n, 2) == pow(sopfr(n), 2) * phi(n)
}
fn t_mat10(n: int) -> bool {
    if n <= 1 { return false }
    let pf = prime_factors(n)
    let mut prod_f = 1.0
    let mut i = 0
    while i < len(pf) {
        let pv = to_float(pf[i])
        prod_f = prod_f * (1.0 - 1.0 / (pv * pv))
        i = i + 1
    }
    let j2 = round(to_float(n * n) * prod_f)
    j2 == 4 * n
}

// DOMAIN 4: MUSIC THEORY (10)
fn t_mus01(n: int) -> bool {
    arr_contains(divs(n), 2) && arr_contains(divs(n), 3) && sigma(n) == 2 * n
}
fn t_mus02(n: int) -> bool {
    sigma(n) == 12 && n + 1 == 7
}
fn t_mus03(n: int) -> bool {
    sigma(n) == 12 && n + 1 == 7 && sopfr(n) == 5
}
fn t_mus04(n: int) -> bool {
    n + 1 == 7 && sopfr(n) == 5 && sigma(n) == 12
}
fn t_mus05(n: int) -> bool {
    n == 6 && tau(n) == 4
}
fn t_mus06(n: int) -> bool {
    // tau/sigma == 1/3 AND sigma=2n  →  tau*3 == sigma
    sigma(n) == 2 * n && tau(n) * 3 == sigma(n)
}
fn t_mus07(n: int) -> bool {
    // 4/4 = tau/tau AND 3/4 = (sigma/tau)/tau AND sigma=2n
    tau(n) == 4 && sigma(n) % tau(n) == 0 && sigma(n) / tau(n) == 3 && sigma(n) == 2 * n
}
fn t_mus08(n: int) -> bool {
    // ln(4/3) from tau/(sigma/tau) = 4/3 AND sigma=2n
    let s = sigma(n)
    let t = tau(n)
    if s % t != 0 || s != 2 * n { return false }
    let q = s / t
    if q == 0 { return false }
    // tau/q == 4/3 → 3*tau == 4*q
    3 * t == 4 * q
}
fn t_mus09(n: int) -> bool {
    if n > 10 { return false }
    fact(n) / 2 + sopfr(n) == 365
}
fn t_mus10(n: int) -> bool {
    tau(n) == 4 && sigma(n) == 12 && sigma(n) == 2 * n
}

// DOMAIN 5: CHEMISTRY (10)
fn t_chem01(n: int) -> bool {
    n == 6 && tau(n) == 4 && sigma(n) == 12 && phi(n) == 2
}
fn t_chem02(n: int) -> bool {
    let s = sigma(n)
    let t = tau(n)
    s % t == 0 && s / t == 3 && t == 4 && s == 2 * n
}
fn t_chem03(n: int) -> bool {
    sigma(n) == 12 && n == 6
}
fn t_chem04(n: int) -> bool {
    sigma(n) - tau(n) == 8 && tau(n) == 4
}
fn t_chem05(n: int) -> bool {
    // cos(tet) = -tau/sigma = -1/3  →  tau*3 == sigma AND sigma=12
    tau(n) == 4 && sigma(n) == 12
}
fn t_chem06(n: int) -> bool {
    phi(n) == 2 && sigma(n) - tau(n) == 8
}
fn t_chem07(n: int) -> bool {
    sigma(n) - tau(n) == 8 && tau(n) == 4 && n == 6
}
fn t_chem08(n: int) -> bool {
    let s = sigma(n)
    let t = tau(n)
    s % t == 0 && s / t == 3 && phi(n) == 2 && n == 6
}
fn t_chem09(n: int) -> bool {
    let s = sigma(n)
    let p = phi(n)
    let t = tau(n)
    s == 12 && s * p - t == 20 && sopfr(n) * s == 60
}
fn t_chem10(n: int) -> bool {
    let s = sigma(n)
    let p = phi(n)
    let t = tau(n)
    pow(p, n) == 64 && s * p - t == 20
}

// DOMAIN 6: INFORMATION THEORY (10)
fn t_info01(n: int) -> bool {
    if phi(n) == 0 { return false }
    // log2(n) == log2(sigma/phi) → n*phi == sigma? No.
    // log2(n) == log2(sigma(n)/phi(n))  →  n == sigma(n)/phi(n)  →  n*phi(n) == sigma(n)
    n * phi(n) == sigma(n)
}
fn t_info02(n: int) -> bool {
    // log2(tau) == phi  →  2^phi == tau
    pow(2, phi(n)) == tau(n)
}
fn t_info03(n: int) -> bool {
    // log2(sigma/tau) ≈ log2(3) AND sigma=2n  →  sigma/tau == 3
    let s = sigma(n)
    let t = tau(n)
    s % t == 0 && s / t == 3 && s == 2 * n
}
fn t_info04(n: int) -> bool {
    // n/sigma^2 == 1/(sigma*phi)  →  n*sigma*phi == sigma^2  →  n*phi == sigma
    let s = sigma(n)
    if s == 0 { return false }
    n * phi(n) == s
}
fn t_info05(n: int) -> bool {
    // ceil(log_phi(n)) == tau  →  log(n)/log(phi) rounded up
    let p = phi(n)
    if p <= 1 { return false }
    let v = log(to_float(n)) / log(to_float(p))
    let cv = to_int(ceil(v))
    cv == tau(n)
}
fn t_info06(n: int) -> bool {
    // 1 - tau/sigma == 2/3 AND sigma=2n  →  3*(sigma-tau) == 2*sigma  →  3*sigma-3*tau == 2*sigma  →  sigma == 3*tau
    let s = sigma(n)
    let t = tau(n)
    s == 3 * t && s == 2 * n
}
fn t_info07(n: int) -> bool {
    // sigma/n == 2
    sigma(n) == 2 * n
}
fn t_info08(n: int) -> bool {
    // HM = n*tau/sigma == phi  →  n*tau == sigma*phi
    let s = sigma(n)
    if s == 0 { return false }
    n * tau(n) == s * phi(n)
}
fn t_info09(n: int) -> bool {
    // GM(div) = sqrt(n) — always true for product of divisors^(1/tau) = n^(1/2)
    // This is a well-known identity, always true.
    true
}
fn t_info10(n: int) -> bool {
    // AM*HM == n: (sigma/tau)*(n*tau/sigma) == n always true IF also HM==phi
    // So this reduces to n*tau == sigma*phi AND sigma%tau==0 AND (sigma/tau)*phi==n
    let s = sigma(n)
    let t = tau(n)
    let p = phi(n)
    if s % t != 0 || s == 0 { return false }
    let am = s / t
    n * t == s * p && am * p == n
}

// DOMAIN 7: 4-SEASON EVOLUTION (10)
fn t_season01(n: int) -> bool {
    let s1 = sigma(n)
    if s1 >= 1000 { return false }
    let s2 = sigma(s1)
    if s2 >= 1000 { return false }
    let s3 = sigma(s2)
    if s3 >= 10000 { return false }
    let s4 = sigma(s3)
    s4 == 20 * n
}
fn t_season02(n: int) -> bool {
    n == 6 && 1 * 2 * 6 * 3 == n * n
}
fn t_season03(n: int) -> bool {
    // 0.7^tau ≈ GZ_lower (tau=4) AND sigma=2n
    tau(n) == 4 && sigma(n) == 2 * n
}
fn t_season04(n: int) -> bool {
    let ds = divs(n)
    let mut sum_mob = 0
    let mut count_pos = 0
    let mut count_neg = 0
    let mut i = 0
    while i < len(ds) {
        let m = mobius(ds[i])
        sum_mob = sum_mob + m
        if m == 1 { count_pos = count_pos + 1 }
        if m == -1 { count_neg = count_neg + 1 }
        i = i + 1
    }
    sum_mob == 0 && count_pos == count_neg
}
fn t_season05(n: int) -> bool {
    // sigma/n == 2 AND sigma(sigma(n))*3 == sigma(n)*7
    if sigma(n) != 2 * n { return false }
    let s = sigma(n)
    let ss = sigma(s)
    ss * 3 == s * 7
}
fn t_season06(n: int) -> bool {
    if n <= 2 { return false }
    phi_chain(n) == phi(n)
}
fn t_season07(n: int) -> bool {
    sigma(sigma(n)) == 28
}
fn t_season08(n: int) -> bool {
    let s = sigma(n)
    let t = tau(n)
    s % t == 0 && t == 4 && s == 12 && s == 2 * n
}
fn t_season09(n: int) -> bool {
    if n > 10 { return false }
    fact(n) / 2 + sopfr(n) == 365
}
fn t_season10(n: int) -> bool {
    let s = sigma(n)
    if s >= 10000 { return false }
    sigma(s) == 28 && omega(n) == 2
}

// DOMAIN 8: TELEPATHY META-INFO (10)
fn t_tele01(n: int) -> bool {
    sopfr(n) == 5 && phi(n) == 2 && sigma(n) == 2 * n
}
fn t_tele02(n: int) -> bool {
    sigma(n) * phi(n) == n * tau(n)
}
fn t_tele03(n: int) -> bool {
    let s = sigma(n)
    let t = tau(n)
    s % t == 0 && pow(s / t, 2) == 9 && s == 2 * n
}
fn t_tele04(n: int) -> bool {
    tau(sigma(n)) == n
}
fn t_tele05(n: int) -> bool {
    sigma(n) == n * phi(n)
}
fn t_tele06(n: int) -> bool {
    omega(n) == 2 && tau(n) == 4 && sigma(n) == 2 * n
}
fn t_tele07(n: int) -> bool {
    pow(tau(n), 2) == pow(2, tau(n))
}
fn t_tele08(n: int) -> bool {
    // pi/tau ≈ 0.788 AND sigma=2n  →  tau==4 check
    tau(n) == 4 && sigma(n) == 2 * n
}
fn t_tele09(n: int) -> bool {
    // tau/sopfr == 4/5 AND sigma=2n  →  5*tau == 4*sopfr
    let sf = sopfr(n)
    if sf == 0 { return false }
    5 * tau(n) == 4 * sf && sigma(n) == 2 * n
}
fn t_tele10(n: int) -> bool {
    // log2(sigma*phi) == log2(24) AND sigma=2n  →  sigma*phi==24
    sigma(n) * phi(n) == 24 && sigma(n) == 2 * n
}

// DOMAIN 9: PROBABILISTIC NT (10)
fn t_prob01(n: int) -> bool {
    if n <= 10 { return false }
    let v = log(log(to_float(n)))
    omega(n) == round(v)
}
fn t_prob02(n: int) -> bool {
    n == 6 && sigma(n) == 2 * n
}
fn t_prob03(n: int) -> bool {
    let mut s = 0
    let mut k = 1
    while k <= n {
        s = s + tau(k)
        k = k + 1
    }
    let avg = to_float(s) / to_float(n)
    let diff = avg - log(to_float(n))
    if diff < 0.0 { diff = 0.0 - diff }
    diff < 0.5
}
fn t_prob04(n: int) -> bool {
    if n <= 1 { return false }
    let pf = prime_factors(n)
    let mut prod = 1.0
    let mut i = 0
    while i < len(pf) {
        prod = prod * (1.0 - 1.0 / to_float(pf[i]))
        i = i + 1
    }
    let diff = to_float(phi(n)) / to_float(n) - prod
    if diff < 0.0 { diff = 0.0 - diff }
    diff < 0.0000001
}
fn t_prob05(n: int) -> bool {
    if n <= 10 { return false }
    let v = log(log(to_float(n)))
    let d = to_float(omega(n)) - v
    let ad = if d < 0.0 { 0.0 - d } else { d }
    ad < 0.5
}
fn t_prob06(n: int) -> bool {
    sigma(n) == 2 * n
}
fn t_prob07(n: int) -> bool {
    if n < 5 { return false }
    let mut prod = 1.0
    let mut p = 2
    while p <= n {
        if is_prime(p) { prod = prod * (1.0 - 1.0 / to_float(p)) }
        p = p + 1
    }
    let euler_gamma = 0.5772
    let expected = 2.71828182845 * pow(0.0 - euler_gamma, 1) / log(to_float(n))
    // e^{-gamma}/ln(n)
    let eg = pow(2.71828182845, 0.0 - euler_gamma) / log(to_float(n))
    let d = prod - eg
    let ad = if d < 0.0 { 0.0 - d } else { d }
    ad < 0.1
}
fn t_prob08(n: int) -> bool {
    let s = sigma(n)
    let t = tau(n)
    let p = phi(n)
    s % t == 0 && n % p == 0 && s / t == n / p
}
fn t_prob09(n: int) -> bool {
    // GM = sqrt(n) always true
    true
}
fn t_prob10(n: int) -> bool {
    // HM(div) = phi ⟺ perfect: n*tau/sigma == phi
    let s = sigma(n)
    if s == 0 { return false }
    n * tau(n) == s * phi(n)
}

// DOMAIN 10: TOPOLOGY (10)
fn t_topo01(n: int) -> bool {
    let w = omega(n)
    if w != 2 { return false }
    let chi = 2 - 2 * w
    let achi = if chi < 0 { 0 - chi } else { chi }
    achi == phi(n) && sigma(n) == 2 * n
}
fn t_topo02(n: int) -> bool {
    pow(2, omega(n)) == tau(n)
}
fn t_topo03(n: int) -> bool {
    let s = sigma(n)
    let t = tau(n)
    if s % t != 0 { return false }
    2 * (s / t) == n
}
fn t_topo04(n: int) -> bool {
    sigma(n) == 2 * n
}
fn t_topo05(n: int) -> bool {
    phi(n) == 2 && omega(n) == 2 && sigma(n) == 2 * n
}
fn t_topo06(n: int) -> bool {
    n == 6 && sigma(n) == 12
}
fn t_topo07(n: int) -> bool {
    phi(n) == 2 && sigma(n) == 2 * n
}
fn t_topo08(n: int) -> bool {
    let s = sigma(n)
    let t = tau(n)
    n % 2 == 0 && s % t == 0 && n / 2 == s / t
}
fn t_topo09(n: int) -> bool {
    let ok = [1, 2, 3, 5, 6]
    arr_contains(ok, n) && sigma(n) == 2 * n
}
fn t_topo10(n: int) -> bool {
    let s = sigma(n)
    let t = tau(n)
    if s % t != 0 { return false }
    let q = s / t
    q == 3 && 2 * q == n && 2 - 2 * q == 0 - t
}

