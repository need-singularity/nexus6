// mk2_hexa/native/auto_register.hexa — 자동 발견 분류 + 등록 파이프라인
// 실행: hexa mk2_hexa/native/auto_register.hexa <command> [args...]
// 명령:
//   classify <text> [source]   — 텍스트를 분류하여 유형 판정
//   register <text> [source]   — 분류 후 등록 대상 결정
//   pipeline <file> [source]   — JSONL 파일의 발견들을 전체 파이프라인 실행
//   sync <file> [source]       — 파이프라인 실행 + sync 명령 출력
//   help                       — 사용법

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {}
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

fn min_f(a: f64, b: f64) -> f64 {
    if a < b { return a }
    return b
}

fn str_lower(s: string) -> string {
    // hexa does not have built-in lowercase; exec fallback
    let mut result = ""
    try {
        let out = exec("printf", ["%s", s])
        result = out
    } catch e {
        result = s
    }
    return s
}

fn list_contains(lst: list, item: string) -> bool {
    let mut i: i64 = 0
    while i < lst.len() {
        if to_string(lst[i]) == item { return true }
        i = i + 1
    }
    return false
}

fn str_take(s: string, n: i64) -> string {
    let chars = s.split("")
    let mut result = ""
    let mut i: i64 = 0
    let limit = min_f(to_float(n), to_float(chars.len()))
    while i < to_int(limit) {
        result = result + to_string(chars[i])
        i = i + 1
    }
    return result
}

// ═══════════════════════════════════════════════════════════
// ─── n=6 CONSTANTS (dynamic load from shared/n6_constants.jsonl) ───
// ═══════════════════════════════════════════════════════════

fn load_n6_consts() -> list {
    let home = exec("printenv HOME")
    let path = home + "/Dev/nexus6/shared/n6_constants.jsonl"
    let raw = try { read_file(path) } catch e { return [[], []] }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let trimmed = line.trim()
        if trimmed == "" { continue }
        let mut name = ""
        let mut value = 0.0
        if trimmed.contains("\"name\":\"") {
            let p = trimmed.split("\"name\":\"")
            if p.len() >= 2 { name = p[1].split("\"")[0] }
        }
        if trimmed.contains("\"value\":") {
            let p = trimmed.split("\"value\":")
            if p.len() >= 2 {
                let num_str = p[1].split(",")[0].split("}")[0].trim()
                value = to_float(num_str)
            }
        }
        if name != "" {
            names = names + [name]
            values = values + [value]
        }
    }
    [names, values]
}

fn n6_const(consts: list, name: string) -> f64 {
    let names = consts[0]
    let values = consts[1]
    let mut i = 0
    while i < names.len() {
        if names[i] == name { return to_float(values[i]) }
        i = i + 1
    }
    0.0
}

fn n6_values(consts: list) -> list {
    consts[1]
}

fn n6_names_list(consts: list) -> list {
    consts[0]
}

let _n6 = load_n6_consts()
let n6 = n6_const(_n6, "n")
let sigma = n6_const(_n6, "sigma")
let phi = n6_const(_n6, "phi")
let tau_n = n6_const(_n6, "tau")
let j2 = n6_const(_n6, "j2")
let sopfr = n6_const(_n6, "sopfr")

// n6_match: check if value is close to any n=6 constant
// Returns [name, quality] as list
fn n6_match(val: f64) -> list {
    let names = n6_names_list(_n6)
    let vals = n6_values(_n6)
    let mut best_name = "unknown"
    let mut best_quality = 0.0
    let mut i: i64 = 0
    while i < vals.len() {
        let c = to_float(vals[i])
        let denom = max_f(abs_f(c), 1.0)
        let dist = abs_f(val - c) / denom
        let q = 1.0 - dist
        if q > best_quality {
            best_quality = q
            best_name = to_string(names[i])
        }
        i = i + 1
    }
    return [best_name, best_quality]
}

// ═══════════════════════════════════════════════════════════
// ─── KEYWORD HINTS ───
// ═══════════════════════════════════════════════════════════

fn keyword_hits(text: string, keywords: list) -> i64 {
    let mut count: i64 = 0
    let mut i: i64 = 0
    while i < keywords.len() {
        if text.contains(to_string(keywords[i])) {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

fn load_dse_domain_names() -> list {
    let home = exec("printenv HOME")
    let path = home + "/Dev/nexus6/shared/dse_domains.jsonl"
    let raw = try { read_file(path) } catch e { return [] }
    let lines = raw.split("\n")
    let mut result = []
    for line in lines {
        let trimmed = line.trim()
        if trimmed == "" { continue }
        if trimmed.contains("\"domain\":\"") {
            let p = trimmed.split("\"domain\":\"")
            if p.len() >= 2 {
                let domain = p[1].split("\"")[0]
                if domain != "" { result = result + [domain] }
            }
        }
    }
    result
}

fn extract_domains(text: string) -> list {
    let known = load_dse_domain_names()
    let mut found = []
    let mut i: i64 = 0
    while i < known.len() {
        if text.contains(to_string(known[i])) {
            found = found + [known[i]]
        }
        i = i + 1
    }
    return found
}

fn extract_variables(text: string) -> list {
    let vars = ["sigma", "phi", "tau", "n", "j2", "sopfr", "mu"]
    let mut found = []
    let mut i: i64 = 0
    while i < vars.len() {
        if text.contains(to_string(vars[i])) {
            found = found + [vars[i]]
        }
        i = i + 1
    }
    return found
}

fn try_parse_value(text: string) -> f64 {
    let tokens = text.split(" ")
    let mut i: i64 = 0
    while i < tokens.len() {
        let tok = to_string(tokens[i]).trim()
        let mut v = 0.0
        let mut ok = false
        try {
            v = to_float(tok)
            ok = true
        } catch e {}
        if ok { return v }
        i = i + 1
    }
    return 0.0 - 999999.0
}

// ═══════════════════════════════════════════════════════════
// ─── CLASSIFIER ───
// ═══════════════════════════════════════════════════════════

// Returns: [type, confidence, detail1, detail2, ...]
fn classify(raw: string, n6_score: f64, source: string) -> list {
    let formula_hints = ["=", "+", "-", "*", "/", "^", "sigma", "phi", "tau"]
    let pattern_hints = ["repeats", "periodic", "cycle", "ladder", "chain", "sequence"]
    let law_hints = ["universality", "law", "conservation", "invariant", "bridge"]
    let bt_hints = ["BT-", "breakthrough", "cross-domain", "resonance", "convergence"]
    let lens_hints = ["lens", "perspective", "viewpoint", "gap", "blind spot"]

    // 1. Try constant match
    let val = try_parse_value(raw)
    if val > 0.0 - 999998.0 {
        let match_result = n6_match(val)
        let quality = to_float(match_result[1])
        if quality >= 0.8 {
            return ["constant", quality, to_string(match_result[0]), to_string(val)]
        }
    }

    // 2. BT candidate
    let bt_h = keyword_hits(raw, bt_hints)
    let domains = extract_domains(raw)
    if bt_h >= 1 {
        if domains.len() >= 2 {
            let conf = min_f(to_float(bt_h) * 0.25, 1.0)
            return ["bt_candidate", conf, str_take(raw, 120), to_string(domains.len())]
        }
    }

    // 3. Lens candidate
    let lens_h = keyword_hits(raw, lens_hints)
    if lens_h >= 1 {
        let conf = min_f(to_float(lens_h) * 0.3, 1.0)
        return ["lens_candidate", conf, str_take(raw, 60), raw]
    }

    // 4. Formula
    let formula_h = keyword_hits(raw, formula_hints)
    if formula_h >= 2 {
        let vars = extract_variables(raw)
        let conf = min_f(to_float(formula_h) * 0.15, 1.0)
        return ["formula", conf, raw, to_string(vars.len())]
    }

    // 5. Law (multi-domain + law keyword)
    let law_h = keyword_hits(raw, law_hints)
    if law_h >= 1 {
        if domains.len() >= 2 {
            let conf = min_f(to_float(law_h) * 0.2, 1.0)
            return ["law", conf, raw, to_string(domains.len())]
        }
    }

    // 6. Pattern (default)
    let pattern_h = keyword_hits(raw, pattern_hints)
    if pattern_h > 0 {
        return ["pattern", min_f(to_float(pattern_h) * 0.2, 1.0), "structural", raw]
    }
    return ["pattern", 0.1, "unknown", raw]
}

// ═══════════════════════════════════════════════════════════
// ─── REGISTRAR ───
// ═══════════════════════════════════════════════════════════

// Returns: [targets_csv, success, details]
fn register(classified: list) -> list {
    let dtype = to_string(classified[0])
    let conf = to_float(classified[1])

    if dtype == "constant" {
        return ["math_atlas,graph", true, "Constant '" + to_string(classified[2]) + "' = " + to_string(classified[3])]
    }
    if dtype == "formula" {
        return ["math_atlas,graph", true, "Formula: " + to_string(classified[2])]
    }
    if dtype == "bt_candidate" {
        return ["bt_list,graph,hypotheses", true, "BT candidate: " + to_string(classified[2])]
    }
    if dtype == "lens_candidate" {
        return ["lens_forge,graph", true, "Lens candidate: " + to_string(classified[2])]
    }
    if dtype == "law" {
        let targets = "hypotheses,graph"
        let n_domains = safe_float(to_string(classified[3]))
        if n_domains >= 3.0 {
            return ["hypotheses,graph,bt_candidates", true, "Law across " + to_string(classified[3]) + " domains"]
        }
        return [targets, true, "Law: " + str_take(to_string(classified[2]), 80)]
    }
    // pattern (default)
    return ["graph", true, "Pattern [" + to_string(classified[2]) + "]: " + str_take(to_string(classified[3]), 80)]
}

// ═══════════════════════════════════════════════════════════
// ─── SYNC TRIGGER ───
// ═══════════════════════════════════════════════════════════

// Determine sync commands from a list of registration target strings
// Returns list of [target, command, description]
fn determine_sync(target_lists: list) -> list {
    let mut commands = []
    let mut seen = []
    let mut i: i64 = 0
    while i < target_lists.len() {
        let targets_csv = to_string(target_lists[i])
        let targets = targets_csv.split(",")
        let mut j: i64 = 0
        while j < targets.len() {
            let t = to_string(targets[j]).trim()
            if list_contains(seen, t) == false {
                seen = seen + [t]
                if t == "math_atlas" {
                    commands = commands + [["math_atlas", "python3 shared/scan_math_atlas.py --save --summary", "Sync math atlas"]]
                }
                if t == "bt_list" {
                    if list_contains(seen, "bt_sync") == false {
                        seen = seen + ["bt_sync"]
                        commands = commands + [["bt_list", "# Update docs/breakthrough-theorems.md", "Register BT candidate"]]
                    }
                }
                if t == "bt_candidates" {
                    if list_contains(seen, "bt_sync") == false {
                        seen = seen + ["bt_sync"]
                        commands = commands + [["bt_candidates", "# Update docs/breakthrough-theorems.md", "Register BT candidate"]]
                    }
                }
                if t == "lens_forge" {
                    commands = commands + [["lens_forge", "# Run lens forge validation", "Validate lens candidate"]]
                }
                if t == "graph" {
                    if list_contains(seen, "graph_sync") == false {
                        seen = seen + ["graph_sync"]
                        commands = commands + [["graph", "# Save updated discovery graph", "Persist graph changes"]]
                    }
                }
                if t == "hypotheses" {
                    commands = commands + [["hypotheses", "# Update hypotheses docs", "Register new hypothesis"]]
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    return commands
}

// ═══════════════════════════════════════════════════════════
// ─── NOTIFIER ───
// ═══════════════════════════════════════════════════════════

fn determine_level(targets_csv: string) -> string {
    if targets_csv.contains("bt_list") { return "breakthrough" }
    if targets_csv.contains("bt_candidates") { return "breakthrough" }
    if targets_csv.contains("math_atlas") { return "discovery" }
    if targets_csv.contains("hypotheses") { return "discovery" }
    if targets_csv.contains("lens_forge") { return "discovery" }
    return "info"
}

fn format_notification(level: string, disc_id: string, details: string) -> string {
    let mut prefix = "*   "
    if level == "breakthrough" { prefix = "*** " }
    if level == "discovery" { prefix = "**  " }
    let mut label = "[INFO]"
    if level == "breakthrough" { label = "[BT]" }
    if level == "discovery" { label = "[DISCOVERY]" }
    return prefix + label + " " + disc_id + ": " + details
}

// ═══════════════════════════════════════════════════════════
// ─── PIPELINE ───
// ═══════════════════════════════════════════════════════════

fn run_pipeline(discoveries: list, scores: list, source: string) -> list {
    let mut results = []
    let mut target_lists = []
    let mut notifications = []
    let mut i: i64 = 0
    while i < discoveries.len() {
        let raw = to_string(discoveries[i])
        let score = to_float(scores[i])
        let classified = classify(raw, score, source)
        let reg = register(classified)
        let targets_csv = to_string(reg[0])
        target_lists = target_lists + [targets_csv]
        let level = determine_level(targets_csv)
        let note = format_notification(level, "disc-" + to_string(i), to_string(reg[2]))
        notifications = notifications + [note]
        results = results + [[classified, reg]]
        i = i + 1
    }
    let sync_cmds = determine_sync(target_lists)
    return [results, notifications, sync_cmds]
}

// ═══════════════════════════════════════════════════════════
// ─── CLI ───
// ═══════════════════════════════════════════════════════════

fn show_help() {
    println("auto_register.hexa — 자동 발견 분류 + 등록 파이프라인 (mk2 hexa)")
    println("")
    println("Usage:")
    println("  hexa auto_register.hexa classify <text> [source]")
    println("  hexa auto_register.hexa register <text> [source]")
    println("  hexa auto_register.hexa pipeline <file.jsonl> [source]")
    println("  hexa auto_register.hexa sync <file.jsonl> [source]")
    println("  hexa auto_register.hexa help")
    println("")
    println("Classification types: constant, formula, pattern, law, bt_candidate, lens_candidate")
    println("Registration targets: math_atlas, graph, hypotheses, bt_list, lens_forge")
}

let cli_args = args()
let mut cmd = "help"
if cli_args.len() > 2 {
    cmd = to_string(cli_args[2])
}

if cmd == "help" {
    show_help()
}

if cmd == "classify" {
    if cli_args.len() < 4 {
        println("Error: classify requires <text> argument")
    } else {
        let text = to_string(cli_args[3])
        let mut source = "cli"
        if cli_args.len() > 4 { source = to_string(cli_args[4]) }
        let result = classify(text, 1.0, source)
        println("Type:       " + to_string(result[0]))
        println("Confidence: " + to_string(result[1]))
        println("Detail:     " + to_string(result[2]))
    }
}

if cmd == "register" {
    if cli_args.len() < 4 {
        println("Error: register requires <text> argument")
    } else {
        let text = to_string(cli_args[3])
        let mut source = "cli"
        if cli_args.len() > 4 { source = to_string(cli_args[4]) }
        let classified = classify(text, 1.0, source)
        let reg = register(classified)
        println("Targets: " + to_string(reg[0]))
        println("Success: " + to_string(reg[1]))
        println("Details: " + to_string(reg[2]))
    }
}

if cmd == "pipeline" {
    if cli_args.len() < 4 {
        println("Error: pipeline requires <file.jsonl> argument")
    } else {
        let fpath = to_string(cli_args[3])
        let mut source = "file"
        if cli_args.len() > 4 { source = to_string(cli_args[4]) }
        let mut content = ""
        try { content = read_file(fpath) } catch e {
            println("Error reading file: " + fpath)
        }
        if content.len() > 0 {
            let lines = content.split("\n")
            let mut discoveries = []
            let mut scores = []
            let mut i: i64 = 0
            while i < lines.len() {
                let line = to_string(lines[i]).trim()
                if line.len() > 0 {
                    discoveries = discoveries + [line]
                    scores = scores + [1.0]
                }
                i = i + 1
            }
            let result = run_pipeline(discoveries, scores, source)
            let notifications = result[1]
            println("=== Pipeline Results (" + to_string(discoveries.len()) + " discoveries) ===")
            let notes = notifications
            let mut j: i64 = 0
            while j < to_int(to_float(notes.len())) {
                println(to_string(notes[j]))
                j = j + 1
            }
        }
    }
}

if cmd == "sync" {
    if cli_args.len() < 4 {
        println("Error: sync requires <file.jsonl> argument")
    } else {
        let fpath = to_string(cli_args[3])
        let mut source = "file"
        if cli_args.len() > 4 { source = to_string(cli_args[4]) }
        let mut content = ""
        try { content = read_file(fpath) } catch e {
            println("Error reading file: " + fpath)
        }
        if content.len() > 0 {
            let lines = content.split("\n")
            let mut discoveries = []
            let mut scores = []
            let mut i: i64 = 0
            while i < lines.len() {
                let line = to_string(lines[i]).trim()
                if line.len() > 0 {
                    discoveries = discoveries + [line]
                    scores = scores + [1.0]
                }
                i = i + 1
            }
            let result = run_pipeline(discoveries, scores, source)
            let sync_cmds = result[2]
            println("=== Sync Commands ===")
            let mut j: i64 = 0
            while j < to_int(to_float(sync_cmds.len())) {
                let entry = sync_cmds[j]
                println("[" + to_string(entry[0]) + "] " + to_string(entry[1]))
                j = j + 1
            }
        }
    }
}
