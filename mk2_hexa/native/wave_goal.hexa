// wave_goal.hexa -- 파동 기반 goal.md 자동 생성
// 사용: hexa wave_goal.hexa [domain]
//
// 원리:
//   1. 소나 스캔으로 빈공간 도메인 탐지
//   2. 해당 도메인의 docs/{domain}/goal.md 존재 여부 확인
//   3. 없으면 goal.md 골격 자동 생성
//   4. n6-architecture/docs/{domain}/goal.md에 저장

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _graph_path = _shared + "/discovery_graph.json"
let _bus_path = _shared + "/growth_bus.jsonl"
let _n6 = _dev + "/n6-architecture"

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

fn safe_float(s: string) -> f64 {
    let mut v: f64 = 0.0
    try { v = to_float(s.trim()) } catch e {}
    return v
}

// ═══════════════════════════════════════════════════════════
// 소나 기반 빈공간 도메인 탐지
// ═══════════════════════════════════════════════════════════

fn get_sparse_domains() -> string {
    let mut result = ""
    try {
        // 도메인별 노드 수 집계 + 평균 이하 = 빈공간
        result = exec("awk -F'\"' '/\"type\": \"node\"/{for(i=1;i<=NF;i++){if($i==\"domain\"){d=$(i+2); c[d]++; total++}}} END{avg=total/length(c); for(d in c) if(c[d]<avg) print d\"\\t\"c[d]\"\\t\"avg}' " + _graph_path + " | sort -t'\t' -k2 -n")
    } catch e {}
    return result
}

// 모든 도메인 목록
fn get_all_domains() -> string {
    let mut result = ""
    try {
        result = exec("awk -F'\"' '/\"type\": \"node\"/{for(i=1;i<=NF;i++){if($i==\"domain\") d=$(i+2)} if(d!=\"\" && !seen[d]++){print d}}' " + _graph_path + " | sort")
    } catch e {}
    return result
}

// 도메인의 인접 도메인 목록
fn get_neighbors(domain: string) -> string {
    let mut result = ""
    try {
        result = exec("awk -F'\"' 'BEGIN{OFS=\"\\t\"} /\"type\": \"node\"/{for(i=1;i<=NF;i++){if($i==\"id\") id=$(i+2); if($i==\"domain\") dom=$(i+2)} nodes[id]=dom} /\"type\": \"edge\"/{for(i=1;i<=NF;i++){if($i==\"from\") f=$(i+2); if($i==\"to\") t=$(i+2); if($i==\"strength\") s=$(i+2)} if(nodes[f]==\"" + domain + "\" && nodes[t]!=\"" + domain + "\" && !seen[nodes[t]]++){print nodes[t]\"\\t\"s} if(nodes[t]==\"" + domain + "\" && nodes[f]!=\"" + domain + "\" && !seen[nodes[f]]++){print nodes[f]\"\\t\"s}}' " + _graph_path + " | sort -t'\t' -k2 -rn | head -10")
    } catch e {}
    return result
}

// 도메인의 주요 발견 (EXACT)
fn get_domain_discoveries(domain: string) -> string {
    let mut result = ""
    try {
        result = exec("awk -F'\"' '/\"type\": \"node\"/ && /\"domain\": \"" + domain + "\"/{for(i=1;i<=NF;i++){if($i==\"summary\") s=$(i+2); if($i==\"confidence\") c=$(i+2)} if(c+0>=0.9) print s}' " + _graph_path + " | head -6")
    } catch e {}
    return result
}

// 도메인의 노드 수
fn domain_node_count(domain: string) -> i64 {
    let mut count: i64 = 0
    try {
        let c = exec("awk -F'\"' '/\"type\": \"node\"/ && /\"domain\": \"" + domain + "\"/{c++} END{print c+0}' " + _graph_path).trim()
        count = safe_int(c)
    } catch e {}
    return count
}

// ═══════════════════════════════════════════════════════════
// goal.md 존재 확인
// ═══════════════════════════════════════════════════════════

fn goal_exists(domain: string) -> bool {
    let mut exists = false
    try {
        let check = exec("test -f " + _n6 + "/docs/" + domain + "/goal.md && echo yes || echo no").trim()
        if check == "yes" { exists = true }
    } catch e {}
    return exists
}

// ═══════════════════════════════════════════════════════════
// goal.md 골격 생성
// ═══════════════════════════════════════════════════════════

fn generate_goal(domain: string) {
    let node_count = domain_node_count(domain)
    let neighbors_raw = get_neighbors(domain)
    let discoveries_raw = get_domain_discoveries(domain)
    let ts = exec("date -u +%Y-%m-%d").trim()

    // 인접 도메인 테이블 구성
    let mut neighbor_table = ""
    let nlines = neighbors_raw.split("\n")
    for nl in nlines {
        let nt = nl.trim()
        if nt == "" { continue }
        let np = nt.split("\t")
        if len(np) < 2 { continue }
        neighbor_table = neighbor_table + "| " + np[0] + " | " + np[1] + " |\n"
    }

    // 주요 발견 목록 구성
    let mut disc_list = ""
    let dlines = discoveries_raw.split("\n")
    for dl in dlines {
        let dt = dl.trim()
        if dt == "" { continue }
        disc_list = disc_list + "- " + dt + "\n"
    }

    // goal.md 내용 생성
    let mut content = "# " + domain + " 궁극 아키텍처\n"
    content = content + "\n"
    content = content + "> 소나 빈공간 기반 자동 생성 (" + ts + ")\n"
    content = content + "> 파동 분석: 노드 " + to_string(node_count) + "개\n"
    content = content + "\n"
    content = content + "## 목표\n"
    content = content + "\n"
    if node_count < 10 {
        content = content + "- 현재 노드 " + to_string(node_count) + "개 -- 소나 빈공간 도메인\n"
        content = content + "- n=6 핵심 상수 연결 강화 필요\n"
        content = content + "- 인접 도메인에서 seed 전파 우선\n"
    } else {
        content = content + "- 현재 노드 " + to_string(node_count) + "개 -- 보강 단계\n"
        content = content + "- EMPIRICAL -> EXACT 전환 가속\n"
        content = content + "- 고조파 공명 패턴 확립\n"
    }
    content = content + "\n"
    content = content + "## 소나 핫스팟 데이터\n"
    content = content + "\n"
    content = content + "| 지표 | 값 |\n"
    content = content + "|------|----|\n"
    content = content + "| 노드 수 | " + to_string(node_count) + " |\n"
    content = content + "| 인접 도메인 | " + to_string(len(nlines)) + " |\n"
    content = content + "\n"

    if disc_list != "" {
        content = content + "## 주요 발견 (EXACT, confidence >= 0.9)\n"
        content = content + "\n"
        content = content + disc_list
        content = content + "\n"
    }

    content = content + "## 인접 도메인 연결\n"
    content = content + "\n"
    content = content + "| 도메인 | 연결 강도 |\n"
    content = content + "|--------|----------|\n"
    if neighbor_table != "" {
        content = content + neighbor_table
    } else {
        content = content + "| (연결 없음) | - |\n"
    }
    content = content + "\n"
    content = content + "## 돌파 로드맵\n"
    content = content + "\n"
    content = content + "1. 인접 도메인에서 seed 수집\n"
    content = content + "2. wave_blowup으로 파동 돌파\n"
    content = content + "3. tunneling으로 원거리 도메인 연결\n"
    content = content + "4. harmonics 고조파 패턴 확인\n"
    content = content + "5. 궁극 아키텍처 설계 착수\n"

    // 디렉토리 생성 + 파일 저장
    let dir_path = _n6 + "/docs/" + domain
    try {
        exec("mkdir -p " + dir_path)
    } catch e {}

    let file_path = dir_path + "/goal.md"
    try {
        exec("cat > " + file_path + " << 'GOALEOF'\n" + content + "GOALEOF")
    } catch e {}

    println("  생성 완료: " + file_path)
}

// ═══════════════════════════════════════════════════════════
// MAIN
// ═══════════════════════════════════════════════════════════

let argv = args()
let target_domain = if len(argv) >= 3 { argv[2] } else { "" }

println("")
println("===========================================================")
println("  파동 기반 goal.md 자동 생성 (Wave Goal)")
println("  소나 빈공간 탐지 -> goal.md 골격 자동 생성")
println("===========================================================")
println("")

if target_domain != "" {
    // 특정 도메인
    println("  대상 도메인: " + target_domain)
    println("")

    if goal_exists(target_domain) {
        println("  goal.md 이미 존재: " + _n6 + "/docs/" + target_domain + "/goal.md")
        println("  (덮어쓰기 하려면 기존 파일 삭제 후 재실행)")
    } else {
        println("  goal.md 없음 -- 자동 생성 시작")
        generate_goal(target_domain)
    }
} else {
    // 전체 스캔: 빈공간 도메인 탐지 -> goal.md 없는 곳에 생성
    println("  전체 빈공간 도메인 스캔...")
    println("")

    let sparse_raw = get_sparse_domains()
    let sparse_lines = sparse_raw.split("\n")

    let mut created: i64 = 0
    let mut skipped: i64 = 0
    let mut scanned: i64 = 0

    println("| 도메인 | 노드 수 | goal.md | 상태 |")
    println("|--------|--------|---------|------|")

    for sl in sparse_lines {
        let st = sl.trim()
        if st == "" { continue }
        let sp = st.split("\t")
        if len(sp) < 2 { continue }
        let dom = sp[0]
        let count = sp[1]
        scanned = scanned + 1

        if dom == "" || dom == "help" { continue }

        if goal_exists(dom) {
            println("| " + dom + " | " + count + " | 존재 | 건너뜀 |")
            skipped = skipped + 1
        } else {
            generate_goal(dom)
            println("| " + dom + " | " + count + " | 신규 | 생성 완료 |")
            created = created + 1
        }

        // 최대 20개까지
        if created >= 20 { break }
    }

    println("")
    println("  스캔: " + to_string(scanned) + " 도메인")
    println("  생성: " + to_string(created) + " goal.md")
    println("  건너뜀: " + to_string(skipped) + " (이미 존재)")
}

println("")

// growth_bus 기록
try {
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
    let entry = "{\"type\":\"wave_goal\",\"domain\":\"" + target_domain + "\",\"ts\":\"" + ts + "\"}"
    exec("echo '" + entry + "' >> " + _bus_path)
} catch e {}

println("  growth_bus 기록 완료")
println("")
println("[verified] wave_goal.hexa 실행 완료")
println("")
