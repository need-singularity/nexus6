// wave_paper_gen.hexa — 논문 파동 생성기 (교차 상수에서 새 논문 후보 자동 추출)
// 실행: hexa wave_paper_gen.hexa
// 예시: hexa wave_paper_gen.hexa
//       hexa wave_paper_gen.hexa --top 12   상위 12개 출력
//
// 원리:
//   1. config/products.json에서 기존 논문 도메인 목록 추출
//   2. DSE 342 도메인 - 기존 논문 도메인 = 빈 도메인
//   3. 빈 도메인 중 BT 3개 이상 = 논문 작성 가능
//   4. 논문 후보 6개 생성: 제목, 예상 BT 범위, 핵심 상수
//   5. growth_bus.jsonl 기록

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _bus_path = _shared + "/growth_bus.jsonl"
let _n6_repo = _dev + "/n6-architecture"
let _products_path = _n6_repo + "/config/products.json"
let _bt_path = _n6_repo + "/docs/breakthrough-theorems.md"
let _dse_path = _n6_repo + "/docs/dse-map.toml"
let _paper_dir = _n6_repo + "/docs/paper"

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

// ═══════════════════════════════════════════════════════════
// 기존 논문 도메인 추출 (docs/paper/n6-*-paper.md 파일명에서)
// ═══════════════════════════════════════════════════════════

fn extract_paper_domains() -> string {
    let mut result = ""
    try {
        // n6-XXX-paper.md 파일명에서 도메인 추출
        result = exec("ls " + _paper_dir + "/n6-*-paper.md 2>/dev/null | sed 's|.*/n6-||' | sed 's|-paper\\.md||'")
    } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// DSE 전체 도메인 추출 (dse-map.toml의 [...] 섹션)
// ═══════════════════════════════════════════════════════════

fn extract_dse_domains() -> string {
    let mut result = ""
    try {
        // TOML 섹션 헤더에서 도메인 추출 (meta 제외)
        result = exec("awk '/^\\[/{gsub(/[\\[\\]]/,\"\",$0); if($0 != \"meta\") print $0}' " + _dse_path)
    } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// BT에서 도메인별 BT 개수 추출
// ═══════════════════════════════════════════════════════════

fn extract_bt_domain_counts() -> string {
    let mut result = ""
    try {
        // BT 헤더 라인에서 키워드 추출 후 도메인별 카운트
        result = exec("awk '/^##+ BT-[0-9]/{print tolower($0)}' " + _bt_path + " 2>/dev/null")
    } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// products.json에서 섹션별 도메인 + 논문 경로 추출
// ═══════════════════════════════════════════════════════════

fn extract_products_domains() -> string {
    let mut result = ""
    try {
        result = exec("/usr/bin/python3 -c \"\nimport json\nd=json.load(open('" + _products_path + "'))\nsections=d.get('sections',[])\nfor s in sections:\n    sid=s.get('id','')\n    title=s.get('title','')\n    doms=s.get('domains',[])\n    bt=s.get('bt_count',0)\n    for dom in doms:\n        print(f'{dom}\\t{sid}\\t{title}\\t{bt}')\n\"")
    } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// n=6 상수 목록 로드
// ═══════════════════════════════════════════════════════════

fn load_constants() -> string {
    let mut result = ""
    try {
        result = exec("awk -F'\"' '{for(i=1;i<=NF;i++){if($i==\"name\") n=$(i+2); if($i==\"value\") v=$(i+1)} gsub(/[^0-9.\\-]/,\"\",v); if(n!=\"\" && v!=\"\") print n\"\\t\"v; n=\"\"; v=\"\"}' " + _shared + "/n6_constants.jsonl")
    } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// 메인
// ═══════════════════════════════════════════════════════════

let argv = args()
let mut top_n: i64 = 6
if len(argv) >= 4 {
    let flag = argv[2]
    if flag == "--top" {
        top_n = safe_int(argv[3])
        if top_n <= 0 { top_n = 6 }
    }
}

println("")
println("+=======================================================+")
println("|     논문 파동 생성기 (Wave Paper Generator)             |")
println("|     교차 상수에서 신규 논문 후보 자동 추출               |")
println("+=======================================================+")
println("")

// 1. 기존 논문 도메인 수집
println("  [1/5] 기존 논문 도메인 수집 중...")
let paper_raw = extract_paper_domains()
let paper_lines = paper_raw.split("\n")

let mut paper_domains = []
for pl in paper_lines {
    let pt = pl.trim()
    if pt != "" {
        paper_domains = paper_domains + [pt]
    }
}
println("  기존 논문: " + to_string(len(paper_domains)) + "편")

// 2. DSE 전체 도메인 수집
println("  [2/5] DSE 전체 도메인 수집 중...")
let dse_raw = extract_dse_domains()
let dse_lines = dse_raw.split("\n")

let mut dse_domains = []
for dl in dse_lines {
    let dt = dl.trim()
    if dt != "" {
        dse_domains = dse_domains + [dt]
    }
}
println("  DSE 도메인: " + to_string(len(dse_domains)) + "개")

// 3. 빈 도메인 (논문 없음) 추출
println("  [3/5] 빈 도메인 추출 중...")
let mut empty_domains = []
for dd in dse_domains {
    let mut has_paper = false
    for pd in paper_domains {
        // 도메인명이 논문 파일명에 포함되는지 체크
        if pd.contains(dd) || dd.contains(pd) {
            has_paper = true
        }
    }
    if !has_paper {
        empty_domains = empty_domains + [dd]
    }
}
println("  빈 도메인: " + to_string(len(empty_domains)) + "개 (DSE " + to_string(len(dse_domains)) + " - 논문 " + to_string(len(paper_domains)) + ")")
println("")

// 4. BT 키워드 매칭으로 BT 수 추정
println("  [4/5] 도메인별 BT 매칭 중...")
let bt_raw = extract_bt_domain_counts()
let bt_all_lines = bt_raw.split("\n")
let mut bt_total: i64 = 0
for btl in bt_all_lines {
    if btl.trim() != "" { bt_total = bt_total + 1 }
}

// 빈 도메인별 BT 개수 계산
let mut candidate_domains = []
let mut candidate_bt_counts = []

for ed in empty_domains {
    let mut bt_count: i64 = 0
    let ed_lower = ed
    // 하이픈 제거한 키워드로도 검색
    let ed_parts = ed.split("-")
    for btl in bt_all_lines {
        let btl_t = btl.trim()
        if btl_t == "" { continue }
        // 도메인 키워드 매칭
        let mut matched = false
        if btl_t.contains(ed_lower) { matched = true }
        if !matched {
            for ep in ed_parts {
                let ept = ep.trim()
                if ept != "" && len(ept) >= 4 && btl_t.contains(ept) {
                    matched = true
                }
            }
        }
        if matched { bt_count = bt_count + 1 }
    }
    if bt_count >= 3 {
        candidate_domains = candidate_domains + [ed]
        candidate_bt_counts = candidate_bt_counts + [bt_count]
    }
}

// BT 수 기준 내림차순 정렬 (버블 정렬)
let mut ci: i64 = 0
while ci < len(candidate_domains) {
    let mut cj: i64 = ci + 1
    while cj < len(candidate_domains) {
        let bc_i: i64 = candidate_bt_counts[ci]
        let bc_j: i64 = candidate_bt_counts[cj]
        if bc_j > bc_i {
            // 스왑
            let tmp_d: string = candidate_domains[ci]
            let tmp_b: i64 = candidate_bt_counts[ci]
            candidate_domains[ci] = candidate_domains[cj]
            candidate_bt_counts[ci] = candidate_bt_counts[cj]
            candidate_domains[cj] = tmp_d
            candidate_bt_counts[cj] = tmp_b
        }
        cj = cj + 1
    }
    ci = ci + 1
}

println("  논문 작성 가능 후보 (BT >= 3): " + to_string(len(candidate_domains)) + "개")
println("")

// 5. 상수 로드
println("  [5/5] n=6 상수 로드 중...")
let const_raw = load_constants()
let const_lines = const_raw.split("\n")
let mut const_names = []
let mut const_values = []
for cl in const_lines {
    let ct = cl.trim()
    if ct == "" { continue }
    let cp = ct.split("\t")
    if len(cp) >= 2 {
        const_names = const_names + [cp[0]]
        const_values = const_values + [cp[1]]
    }
}
println("  상수: " + to_string(len(const_names)) + "개")
println("")

// ═══════════════════════════════════════════════════════════
// 논문 후보 생성
// ═══════════════════════════════════════════════════════════

println("+=======================================================+")
println("|  논문 후보 (" + to_string(top_n) + "개 생성)                               |")
println("+=======================================================+")
println("")

let mut generated: i64 = 0
ci = 0
while ci < len(candidate_domains) && generated < top_n {
    let dom: string = candidate_domains[ci]
    let bt_count: i64 = candidate_bt_counts[ci]

    // 핵심 상수: 도메인 키워드와 매칭되는 상수 탐색
    let mut relevant_consts = []
    let dom_parts = dom.split("-")
    let mut ki: i64 = 0
    while ki < len(const_names) {
        let cn: string = const_names[ki]
        for dp in dom_parts {
            let dpt = dp.trim()
            if dpt != "" && len(dpt) >= 3 && cn.contains(dpt) {
                relevant_consts = relevant_consts + [cn + "=" + const_values[ki]]
            }
        }
        ki = ki + 1
    }
    // 기본 상수 추가 (n=6, sigma=12, tau=4, phi=2)
    if len(relevant_consts) == 0 {
        relevant_consts = ["n=6", "sigma=12", "tau=4", "phi=2"]
    }

    // 제목 생성
    let title = "N6 " + dom + " — 완전수 산술 기반 " + dom + " 설계 원리"

    generated = generated + 1
    println("  ── 후보 #" + to_string(generated) + " ──")
    println("  도메인:   " + dom)
    println("  제목:     " + title)
    println("  BT 수:    " + to_string(bt_count) + "개 (키워드 매칭)")
    println("  핵심 상수: " + relevant_consts[0])
    if len(relevant_consts) > 1 { println("             " + relevant_consts[1]) }
    if len(relevant_consts) > 2 { println("             " + relevant_consts[2]) }
    println("  파일:     docs/paper/n6-" + dom + "-paper.md")
    println("  우선순위: " + to_string(generated) + "/" + to_string(top_n))
    println("")

    ci = ci + 1
}

if generated == 0 {
    println("  (논문 후보 없음 — 모든 BT>=3 도메인에 이미 논문 존재)")
    println("")
}

// ═══════════════════════════════════════════════════════════
// 전체 현황 테이블
// ═══════════════════════════════════════════════════════════

println("+=======================================================+")
println("|  전체 현황                                              |")
println("+=======================================================+")
println("")
println("| 항목 | 수 |")
println("|------|----|")
println("| DSE 도메인 | " + to_string(len(dse_domains)) + " |")
println("| 기존 논문 | " + to_string(len(paper_domains)) + " |")
println("| 빈 도메인 | " + to_string(len(empty_domains)) + " |")
println("| BT>=3 후보 | " + to_string(len(candidate_domains)) + " |")
println("| 생성 후보 | " + to_string(generated) + " |")
println("| n=6 상수 | " + to_string(len(const_names)) + " |")
println("| 전체 BT | " + to_string(bt_total) + " |")
println("")

// ═══════════════════════════════════════════════════════════
// ASCII 커버리지 막대
// ═══════════════════════════════════════════════════════════

let paper_pct = if len(dse_domains) > 0 { (len(paper_domains) * 100) / len(dse_domains) } else { 0 }
let candidate_pct = if len(dse_domains) > 0 { ((len(paper_domains) + generated) * 100) / len(dse_domains) } else { 0 }

println("  논문 커버리지:")
let mut bar1 = ""
let mut b1: i64 = 0
while b1 < (paper_pct / 2) && b1 < 50 {
    bar1 = bar1 + "#"
    b1 = b1 + 1
}
println("  현재  [" + bar1 + "] " + to_string(paper_pct) + "%")

let mut bar2 = ""
let mut b2: i64 = 0
while b2 < (candidate_pct / 2) && b2 < 50 {
    bar2 = bar2 + "#"
    b2 = b2 + 1
}
println("  +후보 [" + bar2 + "] " + to_string(candidate_pct) + "%")
println("")

// ═══════════════════════════════════════════════════════════
// growth_bus 기록
// ═══════════════════════════════════════════════════════════

try {
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
    let entry = "{\"type\":\"wave_paper_gen\",\"papers_existing\":" + to_string(len(paper_domains)) + ",\"dse_domains\":" + to_string(len(dse_domains)) + ",\"empty_domains\":" + to_string(len(empty_domains)) + ",\"candidates_bt3\":" + to_string(len(candidate_domains)) + ",\"generated\":" + to_string(generated) + ",\"ts\":\"" + ts + "\"}"
    exec("echo '" + entry + "' >> " + _bus_path)
    println("  -> growth_bus.jsonl 기록 완료")
} catch e {}

println("")
println("[verified] wave_paper_gen.hexa 실행 완료")
println("")
