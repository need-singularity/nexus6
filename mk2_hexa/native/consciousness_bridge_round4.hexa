fn lcm(a: int, b: int) -> int {
    a * b / gcd(a, b)
}

let g1 = gcd(sig, phi_v)
let g2 = gcd(tau_v, n_val)
let g_all = gcd(g1, g2)

let l1 = lcm(sig, phi_v)
let l2 = lcm(tau_v, n_val)
let l_all = lcm(l1, l2)

println("")
println("  gcd(sigma,phi,tau,n) = gcd(12,2,4,6) = " + to_string(g_all) + " = phi")
println("  lcm(sigma,phi,tau,n) = lcm(12,2,4,6) = " + to_string(l_all) + " = sigma")
assert g_all == phi_v
assert l_all == sig
