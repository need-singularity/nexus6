// Dedekind psi function
fn psi(k: int) -> int {
    let mut r = k
    let mut t = k
    let mut p = 2
    while p * p <= t {
        if t % p == 0 {
            r = r * (p + 1) / p
        }
        while t % p == 0 {
            t = t / p
        }
        p = p + 1
    }
    if t > 1 {
        r = r * (t + 1) / t
    }
    r
}

// naive sigma for verification
fn sigma_naive(k: int) -> int {
    let mut s = 0
    let mut d = 1
    while d <= k {
        if k % d == 0 {
            s = s + d
        }
        d = d + 1
    }
    s
}

let psi6 = psi(6)
let psi_psi6 = psi(psi6)

println("")
println("  Dedekind psi cascade for perfect numbers:")
println("  " + "   n  |   psi(n) | psi(psi(n)) |  ratio | =sigma/n?")
println("  " + "------+----------+-------------+--------+----------")

let perfects = [6, 28, 496]
let mut pi = 0
while pi < len(perfects) {
    let pn = perfects[pi]
    let p1 = psi(pn)
    let p2 = psi(p1)
    let sig_n = sigma_naive(pn)
    // ratio = p2/p1, sigma/n = sig_n/pn  (integer check: p2*pn == p1*sig_n)
    let ratio_num = p2
    let ratio_den = p1
    let sn_num = sig_n
    let sn_den = pn
    let match_str = if ratio_num * sn_den == ratio_den * sn_num { "Y" } else { "N" }
    let ratio_str = to_string(ratio_num) + "/" + to_string(ratio_den)
    println("  " + to_string(pn) + "\t| " + to_string(p1) + "\t| " + to_string(p2) + "\t| " + ratio_str + "\t| " + match_str)
    pi = pi + 1
}

