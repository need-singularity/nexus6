// factorial
fn factorial(k: int) -> int {
    let mut r = 1
    let mut i = 1
    while i <= k {
        r = r * i
        i = i + 1
    }
    r
}

let fact = factorial(n_val)
let product = n_val * sig * sopfr_v * phi_v

