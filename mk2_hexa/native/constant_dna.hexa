// constant_dna.hexa -- 상수 DNA 시퀀싱
// 사용: hexa constant_dna.hexa sequence
//       hexa constant_dna.hexa cluster
//       hexa constant_dna.hexa family
//       hexa constant_dna.hexa help
//
// 원리:
//   1. shared/n6/n6_constants.jsonl + discovery_log.jsonl에서 상수 로드
//   2. 각 상수의 정수부를 소인수분해 → 소수 시퀀스 변환
//   3. 소수 시퀀스 간 편집거리(해밍 근사) 계산
//   4. 가까운 상수쌍 = "같은 유전자 족" → 클러스터링
//   5. n=6 핵심 상수(σ=12, τ=4, φ=2, 28, 496)의 족 소속 분석
//   6. growth_bus.jsonl에 결과 기록

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _const_path = _shared + "/n6_constants.jsonl"
let _log_path = _shared + "/discovery_log.jsonl"
let _bus_path = _shared + "/growth_bus.jsonl"

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

fn safe_float(s: string) -> f64 {
    let mut v: f64 = 0.0
    try { v = to_float(s.trim()) } catch e {}
    return v
}

fn abs_i(a: i64) -> i64 {
    if a < 0 { return 0 - a }
    return a
}

fn min_i(a: i64, b: i64) -> i64 {
    if a < b { return a }
    return b
}

fn max_i(a: i64, b: i64) -> i64 {
    if a > b { return a }
    return b
}

// ═══════════════════════════════════════════════════════════
// 소인수분해 → 소수 시퀀스 (문자열로 반환: "2,3" 등)
// ═══════════════════════════════════════════════════════════

fn factorize(n: i64) -> string {
    if n <= 1 { return "" }
    let mut val = n
    let mut factors = ""

    // 2로 나누기
    while val % 2 == 0 {
        if factors != "" { factors = factors + "," }
        factors = factors + "2"
        val = val / 2
    }

    // 홀수 소인수
    let mut d: i64 = 3
    while d * d <= val {
        while val % d == 0 {
            if factors != "" { factors = factors + "," }
            factors = factors + to_string(d)
            val = val / d
        }
        d = d + 2
    }

    if val > 1 {
        if factors != "" { factors = factors + "," }
        factors = factors + to_string(val)
    }

    return factors
}

// ═══════════════════════════════════════════════════════════
// 소수 시퀀스 간 편집거리 (해밍 근사)
// 두 시퀀스를 쉼표로 분리, 위치별 비교 + 길이 차이 패널티
// ═══════════════════════════════════════════════════════════

fn sequence_distance(seq_a: string, seq_b: string) -> i64 {
    if seq_a == "" && seq_b == "" { return 0 }
    if seq_a == "" { return len(seq_b.split(",")) }
    if seq_b == "" { return len(seq_a.split(",")) }

    let parts_a = seq_a.split(",")
    let parts_b = seq_b.split(",")
    let len_a: i64 = len(parts_a)
    let len_b: i64 = len(parts_b)
    let min_len = min_i(len_a, len_b)
    let max_len = max_i(len_a, len_b)

    // 위치별 불일치 카운트
    let mut mismatch: i64 = 0
    let mut idx: i64 = 0
    while idx < min_len {
        let va: string = parts_a[idx]
        let vb: string = parts_b[idx]
        if va != vb {
            mismatch = mismatch + 1
        }
        idx = idx + 1
    }

    // 길이 차이 추가
    let dist = mismatch + (max_len - min_len)
    return dist
}

// ═══════════════════════════════════════════════════════════
// 상수 로드
// ═══════════════════════════════════════════════════════════

fn load_constants() -> string {
    // n6_constants.jsonl에서 name, value 추출
    let mut result = ""
    try {
        result = exec("cat '" + _const_path + "' 2>/dev/null | awk -F'\"' '{name=\"\"; val=\"\"; for(i=1;i<=NF;i++){if($i==\"name\") name=$(i+2); if($i==\"value\") {v=$(i+1); gsub(/[^0-9.\\-]/,\"\",v); val=v}} if(name!=\"\" && val+0>0) print name\"\\t\"val}' | head -200")
    } catch e {}

    // discovery_log에서 EXACT 값도 추가 (상위 50건, 중복 방지)
    try {
        let extras = exec("tail -5000 '" + _log_path + "' | awk -F'\"' '/\"grade\":\"EXACT\"/ || /\"grade\": \"EXACT\"/{name=\"\"; val=\"\"; for(i=1;i<=NF;i++){if($i==\"constant\" || $i==\"name\") name=$(i+2); if($i==\"value\") {v=$(i+1); gsub(/[^0-9.\\-]/,\"\",v); val=v}} if(name!=\"\" && val+0>0) print name\"\\t\"val}' | sort -u | head -50")
        if extras.trim() != "" {
            result = result + "\n" + extras
        }
    } catch e {}

    return result
}

// ═══════════════════════════════════════════════════════════
// n=6 핵심 상수 정의
// ═══════════════════════════════════════════════════════════
let n6_core_values = [6, 12, 4, 2, 28, 496, 720, 120, 72, 36]
let n6_core_names = ["n", "sigma", "tau", "phi", "P2", "P3", "6!", "5!", "sigma*n", "n^2"]

// ═══════════════════════════════════════════════════════════
// 도움말
// ═══════════════════════════════════════════════════════════

fn show_help() {
    println("")
    println("===========================================================")
    println("  상수 DNA 시퀀싱 (Constant DNA Sequencing)")
    println("  1100+ 상수를 소인수 DNA 서열로 분석")
    println("===========================================================")
    println("")
    println("  사용법:")
    println("    hexa constant_dna.hexa sequence")
    println("      모든 상수를 소인수분해 → DNA 서열 출력")
    println("")
    println("    hexa constant_dna.hexa cluster")
    println("      편집거리 기반 유전자 족 클러스터링")
    println("")
    println("    hexa constant_dna.hexa family")
    println("      n=6 핵심 상수의 족 소속 분석")
    println("")
    println("    hexa constant_dna.hexa help")
    println("      이 도움말 출력")
    println("")
    println("  DNA 서열 = 소인수분해 결과")
    println("    예: 12 → [2,2,3]  28 → [2,2,7]  496 → [2,2,2,2,31]")
    println("  편집거리 = 서열 간 해밍 근사 (위치별 불일치 + 길이 차이)")
    println("  유전자 족 = 편집거리 <= 2인 상수 클러스터")
    println("")
}

// ═══════════════════════════════════════════════════════════
// sequence 서브커맨드: 모든 상수의 DNA 서열 출력
// ═══════════════════════════════════════════════════════════

fn cmd_sequence() {
    println("")
    println("===========================================================")
    println("  상수 DNA 시퀀싱 -- 소인수분해 서열")
    println("===========================================================")
    println("")
    println("  상수 로드 중...")

    let raw = load_constants()
    let lines = raw.split("\n")

    let mut names = []
    let mut values = []
    let mut sequences = []
    let mut count: i64 = 0

    for line in lines {
        let lt = line.trim()
        if lt == "" { continue }
        let parts = lt.split("\t")
        if len(parts) < 2 { continue }
        let name = parts[0]
        let val = safe_int(parts[1])
        if val <= 0 { continue }

        let seq = factorize(val)
        names = names + [name]
        values = values + [val]
        sequences = sequences + [seq]
        count = count + 1
    }

    println("  상수 " + to_string(count) + "개 로드 완료")
    println("")

    // n=6 핵심 상수 DNA 먼저 표시
    println("  --- n=6 핵심 상수 DNA ---")
    println("")
    println("  | 상수 | 값 | DNA 서열 | 길이 |")
    println("  |------|-----|----------|------|")

    let mut ci: i64 = 0
    while ci < len(n6_core_values) {
        let cv: i64 = n6_core_values[ci]
        let cn: string = n6_core_names[ci]
        let cseq = factorize(cv)
        let clen: i64 = if cseq == "" { 0 } else { len(cseq.split(",")) }
        println("  | " + cn + " | " + to_string(cv) + " | [" + cseq + "] | " + to_string(clen) + " |")
        ci = ci + 1
    }

    println("")

    // 전체 상수 DNA 테이블
    println("  --- 전체 상수 DNA (상위 100개) ---")
    println("")
    println("  | # | 이름 | 값 | DNA 서열 | 길이 |")
    println("  |---|------|-----|----------|------|")

    let mut idx: i64 = 0
    let mut display_limit: i64 = 100
    while idx < count && idx < display_limit {
        let n: string = names[idx]
        let v: i64 = values[idx]
        let s: string = sequences[idx]
        let slen: i64 = if s == "" { 0 } else { len(s.split(",")) }
        println("  | " + to_string(idx + 1) + " | " + n + " | " + to_string(v) + " | [" + s + "] | " + to_string(slen) + " |")
        idx = idx + 1
    }

    println("")
    println("  총 상수: " + to_string(count) + "개")
    println("")
}

// ═══════════════════════════════════════════════════════════
// cluster 서브커맨드: 편집거리 기반 유전자 족 클러스터링
// ═══════════════════════════════════════════════════════════

fn cmd_cluster() {
    println("")
    println("===========================================================")
    println("  상수 DNA 시퀀싱 -- 유전자 족 클러스터링")
    println("===========================================================")
    println("")
    println("  상수 로드 중...")

    let raw = load_constants()
    let lines = raw.split("\n")

    let mut names = []
    let mut values = []
    let mut sequences = []
    let mut count: i64 = 0

    for line in lines {
        let lt = line.trim()
        if lt == "" { continue }
        let parts = lt.split("\t")
        if len(parts) < 2 { continue }
        let name = parts[0]
        let val = safe_int(parts[1])
        if val <= 0 { continue }

        let seq = factorize(val)
        names = names + [name]
        values = values + [val]
        sequences = sequences + [seq]
        count = count + 1
    }

    println("  상수 " + to_string(count) + "개 로드 완료")
    println("")

    // 편집거리 <= 2인 쌍 찾기
    let THRESHOLD: i64 = 2

    println("  --- 같은 유전자 족 (편집거리 <= " + to_string(THRESHOLD) + ") ---")
    println("")
    println("  | 상수A | 상수B | 값A | 값B | DNA(A) | DNA(B) | 거리 |")
    println("  |-------|-------|------|------|--------|--------|------|")

    let mut pair_count: i64 = 0
    // 성능을 위해 상위 80개만 비교
    let limit = min_i(count, 80)
    let mut i: i64 = 0
    while i < limit {
        let mut j: i64 = i + 1
        while j < limit {
            let seq_i: string = sequences[i]
            let seq_j: string = sequences[j]
            let dist = sequence_distance(seq_i, seq_j)

            if dist <= THRESHOLD && dist > 0 {
                let ni: string = names[i]
                let nj: string = names[j]
                let vi: i64 = values[i]
                let vj: i64 = values[j]
                println("  | " + ni + " | " + nj + " | " + to_string(vi) + " | " + to_string(vj) + " | [" + seq_i + "] | [" + seq_j + "] | " + to_string(dist) + " |")
                pair_count = pair_count + 1
            }
            j = j + 1
        }
        i = i + 1
    }

    println("")
    println("  유전자 족 쌍: " + to_string(pair_count) + "개 (임계값=" + to_string(THRESHOLD) + ")")
    println("")

    // 가장 많은 족 연결을 가진 상수 (허브 유전자)
    println("  --- 허브 유전자 (연결 수 상위) ---")
    println("")

    let mut conn_counts = []
    let mut ci: i64 = 0
    while ci < limit {
        let mut cc: i64 = 0
        let mut cj: i64 = 0
        while cj < limit {
            if ci != cj {
                let si: string = sequences[ci]
                let sj: string = sequences[cj]
                let d = sequence_distance(si, sj)
                if d <= THRESHOLD && d > 0 { cc = cc + 1 }
            }
            cj = cj + 1
        }
        conn_counts = conn_counts + [cc]
        ci = ci + 1
    }

    // 상위 10개 출력 (단순 정렬 대신 반복 탐색)
    let mut shown: i64 = 0
    let mut used = []
    while shown < 10 && shown < limit {
        let mut best_idx: i64 = -1
        let mut best_cc: i64 = -1
        let mut bi: i64 = 0
        while bi < limit {
            let cci: i64 = conn_counts[bi]
            if cci > best_cc {
                let mut is_used = false
                for u in used { if u == bi { is_used = true } }
                if !is_used {
                    best_cc = cci
                    best_idx = bi
                }
            }
            bi = bi + 1
        }
        if best_idx < 0 || best_cc <= 0 { break }

        let bn: string = names[best_idx]
        let bv: i64 = values[best_idx]
        let bs: string = sequences[best_idx]
        println("  " + to_string(shown + 1) + ". " + bn + " (값=" + to_string(bv) + ", DNA=[" + bs + "]) -- 연결 " + to_string(best_cc) + "개")

        used = used + [best_idx]
        shown = shown + 1
    }

    println("")
}

// ═══════════════════════════════════════════════════════════
// family 서브커맨드: n=6 핵심 상수의 족 소속
// ═══════════════════════════════════════════════════════════

fn cmd_family() {
    println("")
    println("===========================================================")
    println("  상수 DNA 시퀀싱 -- n=6 핵심 상수 족 분석")
    println("===========================================================")
    println("")
    println("  상수 로드 중...")

    let raw = load_constants()
    let lines = raw.split("\n")

    let mut names = []
    let mut values = []
    let mut sequences = []
    let mut count: i64 = 0

    for line in lines {
        let lt = line.trim()
        if lt == "" { continue }
        let parts = lt.split("\t")
        if len(parts) < 2 { continue }
        let name = parts[0]
        let val = safe_int(parts[1])
        if val <= 0 { continue }

        let seq = factorize(val)
        names = names + [name]
        values = values + [val]
        sequences = sequences + [seq]
        count = count + 1
    }

    println("  상수 " + to_string(count) + "개 로드 완료")
    println("")

    let THRESHOLD: i64 = 2

    // 각 핵심 상수에 대해 가장 가까운 상수 찾기
    let mut ci: i64 = 0
    while ci < len(n6_core_values) {
        let cv: i64 = n6_core_values[ci]
        let cn: string = n6_core_names[ci]
        let cseq = factorize(cv)

        println("  -------------------------------------------------------")
        println("  " + cn + " = " + to_string(cv) + "  DNA = [" + cseq + "]")
        println("  -------------------------------------------------------")

        // 같은 족 (거리 <= THRESHOLD) 찾기
        let mut family_count: i64 = 0
        let mut fi: i64 = 0
        while fi < count {
            let fseq: string = sequences[fi]
            let dist = sequence_distance(cseq, fseq)
            if dist <= THRESHOLD {
                let fn_name: string = names[fi]
                let fv: i64 = values[fi]
                let tag = if dist == 0 { "동일" } else { "거리=" + to_string(dist) }
                println("    " + fn_name + " = " + to_string(fv) + " [" + fseq + "] (" + tag + ")")
                family_count = family_count + 1
            }
            fi = fi + 1
        }

        if family_count == 0 {
            println("    (같은 족 없음)")
        } else {
            println("    -> 족 크기: " + to_string(family_count))
        }
        println("")

        ci = ci + 1
    }

    // 핵심 상수 간 상호 거리 매트릭스
    println("  --- n=6 핵심 상수 상호 거리 ---")
    println("")

    // 헤더
    let mut header = "  |       "
    let mut hi: i64 = 0
    while hi < len(n6_core_names) {
        let hn: string = n6_core_names[hi]
        header = header + "| " + hn + " "
        hi = hi + 1
    }
    header = header + "|"
    println(header)

    // 구분선
    let mut sep = "  |-------"
    hi = 0
    while hi < len(n6_core_names) {
        sep = sep + "|-----"
        hi = hi + 1
    }
    sep = sep + "|"
    println(sep)

    // 행
    let mut ri: i64 = 0
    while ri < len(n6_core_values) {
        let rn: string = n6_core_names[ri]
        let rv: i64 = n6_core_values[ri]
        let rseq = factorize(rv)

        let mut row = "  | " + rn + "\t"
        let mut rj: i64 = 0
        while rj < len(n6_core_values) {
            let cjv: i64 = n6_core_values[rj]
            let cjseq = factorize(cjv)
            let dist = sequence_distance(rseq, cjseq)
            row = row + "| " + to_string(dist) + "   "
            rj = rj + 1
        }
        row = row + "|"
        println(row)

        ri = ri + 1
    }

    println("")

    // n=6 = [2,3] 을 중심으로 거리 순 정렬
    println("  --- n=6 중심 거리 순위 (모든 상수) ---")
    println("")

    let n6_seq = factorize(6)  // "2,3"

    // 거리 계산 후 상위 20개 출력
    let mut shown: i64 = 0
    let mut used = []
    while shown < 20 {
        let mut best_idx: i64 = -1
        let mut best_dist: i64 = 999
        let mut bi: i64 = 0
        while bi < count {
            let bseq: string = sequences[bi]
            let d = sequence_distance(n6_seq, bseq)
            if d < best_dist {
                let mut is_used = false
                for u in used { if u == bi { is_used = true } }
                if !is_used {
                    best_dist = d
                    best_idx = bi
                }
            }
            bi = bi + 1
        }
        if best_idx < 0 { break }

        let bn: string = names[best_idx]
        let bv: i64 = values[best_idx]
        let bs: string = sequences[best_idx]
        println("  " + to_string(shown + 1) + ". " + bn + " = " + to_string(bv) + " [" + bs + "] 거리=" + to_string(best_dist))

        used = used + [best_idx]
        shown = shown + 1
    }

    println("")
}

// ═══════════════════════════════════════════════════════════
// MAIN
// ═══════════════════════════════════════════════════════════

let args = exec("echo $@").trim().split(" ")

if len(args) < 2 {
    show_help()
} else {
    let cmd = args[1]

    if cmd == "help" || cmd == "--help" || cmd == "-h" {
        show_help()
    } else if cmd == "sequence" {
        cmd_sequence()

        // growth_bus 기록
        try {
            let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
            let entry = "{\"type\":\"constant_dna\",\"mode\":\"sequence\",\"ts\":\"" + ts + "\"}"
            exec("echo '" + entry + "' >> " + _bus_path)
            println("  growth_bus 기록 완료")
        } catch e {}

        println("[verified] constant_dna.hexa sequence 완료")
        println("")
    } else if cmd == "cluster" {
        cmd_cluster()

        // growth_bus 기록
        try {
            let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
            let entry = "{\"type\":\"constant_dna\",\"mode\":\"cluster\",\"ts\":\"" + ts + "\"}"
            exec("echo '" + entry + "' >> " + _bus_path)
            println("  growth_bus 기록 완료")
        } catch e {}

        println("[verified] constant_dna.hexa cluster 완료")
        println("")
    } else if cmd == "family" {
        cmd_family()

        // growth_bus 기록
        try {
            let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
            let entry = "{\"type\":\"constant_dna\",\"mode\":\"family\",\"ts\":\"" + ts + "\"}"
            exec("echo '" + entry + "' >> " + _bus_path)
            println("  growth_bus 기록 완료")
        } catch e {}

        println("[verified] constant_dna.hexa family 완료")
        println("")
    } else {
        println("  알 수 없는 명령: " + cmd)
        show_help()
    }
}
