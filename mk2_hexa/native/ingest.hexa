// mk2_hexa/native/ingest.hexa — 프로젝트 데이터 수집 (ingest)
// Rust src/ingest/ 포팅: crawl, md_parser, json_parser, txt_parser

// ─── 상수 ─────────────────────────────────────────────────────────
comptime const skip_dirs = ".git,node_modules,target,__pycache__,venv,.venv"
comptime const supported_exts = "md,json,txt"

// ─── 데이터 구조 ──────────────────────────────────────────────────

struct ProbeData {
    domain: string,
    source_file: string,
    named_keys: list,      // ["key1","key2",...]
    named_vals: list,      // ["1.0","2.0",...]
    raw_vals: list          // ["3.0","4.0",...]
}

struct IngestResult {
    probes: list,           // ProbeData 리스트 (직렬화)
    files_scanned: int,
    files_skipped: int,
    errors: list
}

struct ProjectSource {
    path: string,
    domain: string,
    extensions: list        // ["md","json","txt"]
}

// ─── 숫자 파싱 유틸 ────────────────────────────────────────────────

// 문자열에서 숫자 파싱 (분수, ≈ 접두어, 일반 숫자)
pure fn parse_numeric(s: string) -> float {
    let trimmed = s.trim()
    if trimmed.len() == 0 {
        return -999999.0
    }
    // ≈ 또는 ~ 제거
    let mut clean = trimmed
    if clean.starts_with("≈") {
        clean = clean.slice(1, clean.len()).trim()
    }
    if clean.starts_with("~") {
        clean = clean.slice(1, clean.len()).trim()
    }
    // 직접 파싱 시도
    let direct = to_float(clean)
    if direct != 0.0 || clean == "0" || clean == "0.0" {
        return direct
    }
    // 분수 시도: 첫 토큰에서 a/b
    let tokens = clean.split(" ")
    let mut i = 0
    while i < tokens.len() {
        let tok = tokens[i].trim()
        if tok.contains("/") {
            let parts = tok.split("/")
            if parts.len() == 2 {
                let num = to_float(parts[0])
                let den = to_float(parts[1])
                if den != 0.0 {
                    return num / den
                }
            }
        }
        // 일반 숫자 토큰
        let v = to_float(tok)
        if v != 0.0 {
            return v
        }
        i = i + 1
    }
    -999999.0
}

// 파싱 성공 여부
pure fn is_valid_number(v: float) -> bool {
    v != -999999.0
}

// ─── txt 파서: 정규식 없이 숫자/KV 추출 ─────────────────────────

// 텍스트에서 모든 숫자 추출
fn txt_extract_numbers(text: string) -> list {
    let mut result = []
    let lines = text.split("\n")
    let mut li = 0
    while li < lines.len() {
        let tokens = lines[li].split(" ")
        let mut ti = 0
        while ti < tokens.len() {
            let tok = tokens[ti].trim()
            if tok.len() > 0 {
                let v = to_float(tok)
                if v != 0.0 || tok == "0" || tok == "0.0" {
                    result = result + [to_string(v)]
                }
            }
            ti = ti + 1
        }
        li = li + 1
    }
    result
}

// 텍스트에서 key=value 또는 key: value 추출
fn txt_extract_kv(text: string) -> list {
    let mut keys = []
    let mut vals = []
    let lines = text.split("\n")
    let mut li = 0
    while li < lines.len() {
        let line = lines[li].trim()
        if line.len() > 0 {
            // "=" 구분자 시도
            if line.contains("=") {
                let parts = line.split("=")
                if parts.len() >= 2 {
                    let key = parts[0].trim()
                    let rhs = parts[1].trim()
                    // rhs 첫 토큰만
                    let rhs_tokens = rhs.split(" ")
                    if rhs_tokens.len() > 0 {
                        let v = to_float(rhs_tokens[0].trim())
                        if v != 0.0 || rhs_tokens[0].trim() == "0" {
                            keys = keys + [key]
                            vals = vals + [to_string(v)]
                        }
                    }
                }
            }
            // ":" 구분자 시도 (= 없을 때)
            if !line.contains("=") && line.contains(":") {
                let parts = line.split(":")
                if parts.len() >= 2 {
                    let key = parts[0].trim()
                    let rhs = parts[1].trim()
                    let rhs_tokens = rhs.split(" ")
                    if rhs_tokens.len() > 0 {
                        let v = to_float(rhs_tokens[0].trim())
                        if v != 0.0 || rhs_tokens[0].trim() == "0" {
                            keys = keys + [key]
                            vals = vals + [to_string(v)]
                        }
                    }
                }
            }
        }
        li = li + 1
    }
    [keys, vals]
}

// ─── json 파서: 경량 숫자/KV 추출 ───────────────────────────────

// JSON에서 모든 숫자값 추출 (문자열 키 건너뜀)
fn json_extract_values(content: string) -> list {
    let mut result = []
    let chars = content.split("")
    let len = chars.len()
    let mut i = 0
    let mut in_string = false

    while i < len {
        let ch = chars[i]
        // 문자열 건너뛰기
        if ch == "\"" && !in_string {
            in_string = true
            i = i + 1
            while i < len {
                if chars[i] == "\\" {
                    i = i + 2
                } else if chars[i] == "\"" {
                    in_string = false
                    i = i + 1
                    // ":" 이후 값 위치로 스킵 — KV 파서에서 처리
                    i = i  // nop
                    // 다음 반복으로
                    i = i - 1  // while 끝에서 +1 되므로
                    in_string = false
                    i = i + 1
                    // 이 위치 탈출
                    i = i - 1
                    // break 없으므로 플래그 사용
                    i = len + 1  // 내부 루프 종료 신호
                } else {
                    i = i + 1
                }
            }
            if i > len { i = i - len }
            i = i + 1
            // skip
        } else if ch == "-" || (ch >= "0" && ch <= "9") {
            // 숫자 시작점
            let start = i
            let mut num_str = ""
            while i < len {
                let c = chars[i]
                if (c >= "0" && c <= "9") || c == "." || c == "-" || c == "e" || c == "E" || c == "+" {
                    num_str = num_str + c
                    i = i + 1
                } else {
                    i = i - 1
                    // 내부 루프 탈출
                    i = len + 1
                }
            }
            if i > len { i = i - len }
            if num_str.len() > 0 {
                let v = to_float(num_str)
                if v != 0.0 || num_str == "0" || num_str == "0.0" {
                    result = result + [to_string(v)]
                }
            }
            i = i + 1
        } else {
            i = i + 1
        }
    }
    result
}

// JSON에서 "key": number 형태 추출 (간이 파서)
fn json_extract_kv(content: string) -> list {
    let mut keys = []
    let mut vals = []
    // 줄 단위로 "key": number 패턴 탐색
    let lines = content.split("\n")
    let mut li = 0
    while li < lines.len() {
        let line = lines[li].trim()
        // "key": 숫자 패턴 — 간이 매칭
        if line.contains("\"") && line.contains(":") {
            let colon_parts = line.split(":")
            if colon_parts.len() >= 2 {
                let lhs = colon_parts[0].trim()
                let rhs = colon_parts[1].trim()
                // lhs에서 따옴표 제거
                if lhs.starts_with("\"") && lhs.ends_with("\"") {
                    let key = lhs.slice(1, lhs.len() - 1)
                    // rhs 끝 콤마 제거
                    let mut val_str = rhs
                    if val_str.ends_with(",") {
                        val_str = val_str.slice(0, val_str.len() - 1)
                    }
                    let v = to_float(val_str.trim())
                    if v != 0.0 || val_str.trim() == "0" {
                        keys = keys + [key]
                        vals = vals + [to_string(v)]
                    }
                }
            }
        }
        li = li + 1
    }
    [keys, vals]
}

// ─── md 파서: 섹션, 테이블, 상수 추출 ──────────────────────────

// 마크다운 테이블 구분자 행 확인
pure fn is_separator_row(line: string) -> bool {
    if !line.starts_with("|") {
        return false
    }
    let chars = line.split("")
    let mut ok = true
    let mut ci = 0
    while ci < chars.len() {
        let c = chars[ci]
        if c != "|" && c != "-" && c != ":" && c != " " {
            ok = false
        }
        ci = ci + 1
    }
    ok
}

// 파이프 구분 테이블 행 → 셀 리스트
pure fn split_table_row(line: string) -> list {
    let trimmed = line.trim()
    // 앞뒤 | 제거
    let mut inner = trimmed
    if inner.starts_with("|") {
        inner = inner.slice(1, inner.len())
    }
    if inner.ends_with("|") {
        inner = inner.slice(0, inner.len() - 1)
    }
    let cells = inner.split("|")
    let mut result = []
    let mut ci = 0
    while ci < cells.len() {
        result = result + [cells[ci].trim()]
        ci = ci + 1
    }
    result
}

// 마크다운 볼드(**text**) 제거
pure fn clean_bold(s: string) -> string {
    let mut result = s
    while result.contains("**") {
        let parts = result.split("**")
        result = ""
        let mut pi = 0
        while pi < parts.len() {
            result = result + parts[pi]
            pi = pi + 1
        }
    }
    result
}

// 컬럼 헤더에서 키워드 포함 인덱스 찾기
pure fn find_column(headers: list, keywords: list) -> int {
    let mut hi = 0
    while hi < headers.len() {
        let h = headers[hi]
        let h_lower = h  // hexa는 대소문자 구분 없을 수 있음
        let mut ki = 0
        while ki < keywords.len() {
            if h_lower.contains(keywords[ki]) {
                return hi
            }
            ki = ki + 1
        }
        hi = hi + 1
    }
    -1
}

// 마크다운 파일에서 테이블 상수 추출 (symbol, value 컬럼)
fn md_extract_constants(content: string) -> list {
    let mut keys = []
    let mut vals = []
    let lines = content.split("\n")
    let len = lines.len()
    let mut i = 0

    while i < len {
        let trimmed = lines[i].trim()
        // 테이블 시작: | 로 시작하고 | 로 끝남
        if trimmed.starts_with("|") && trimmed.ends_with("|") {
            let headers = split_table_row(trimmed)
            // 다음 줄이 구분자인지 확인
            if i + 1 < len && is_separator_row(lines[i + 1].trim()) {
                // symbol/expression 컬럼 찾기
                let sym_col = find_column(headers, ["symbol", "Symbol", "expression", "Expression", "ID", "id"])
                // value 컬럼 찾기
                let val_col = find_column(headers, ["value", "Value"])

                if sym_col >= 0 && val_col >= 0 {
                    i = i + 2  // 헤더 + 구분자 건너뜀
                    // 데이터 행 수집
                    while i < len {
                        let row_line = lines[i].trim()
                        if row_line.starts_with("|") && row_line.ends_with("|") {
                            let cells = split_table_row(row_line)
                            if sym_col < cells.len() && val_col < cells.len() {
                                let sym = clean_bold(cells[sym_col])
                                let val_str = cells[val_col]
                                if sym.len() > 0 && val_str.len() > 0 {
                                    let v = parse_numeric(val_str)
                                    if is_valid_number(v) {
                                        keys = keys + [sym]
                                        vals = vals + [to_string(v)]
                                    }
                                }
                            }
                            i = i + 1
                        } else {
                            // 테이블 끝
                            i = i - 1
                            i = len + 1  // 내부 루프 탈출
                        }
                    }
                    if i > len { i = i - len }
                } else {
                    // symbol/value 컬럼 없는 테이블 → 모든 셀에서 숫자 추출
                    i = i + 2
                    while i < len {
                        let row_line = lines[i].trim()
                        if row_line.starts_with("|") && row_line.ends_with("|") {
                            let cells = split_table_row(row_line)
                            let mut ci = 0
                            while ci < cells.len() {
                                let v = parse_numeric(cells[ci])
                                if is_valid_number(v) {
                                    keys = keys + ["_cell"]
                                    vals = vals + [to_string(v)]
                                }
                                ci = ci + 1
                            }
                            i = i + 1
                        } else {
                            i = i - 1
                            i = len + 1
                        }
                    }
                    if i > len { i = i - len }
                }
            }
        }
        i = i + 1
    }
    [keys, vals]
}

// 마크다운 코드블록에서 key=value 추출
fn md_extract_code_constants(content: string) -> list {
    let mut keys = []
    let mut vals = []
    let lines = content.split("\n")
    let len = lines.len()
    let mut i = 0
    let mut in_block = false

    while i < len {
        let trimmed = lines[i].trim()
        if trimmed.starts_with("```") {
            if in_block {
                in_block = false
            } else {
                in_block = true
            }
            i = i + 1
            // 다음 줄로
            i = i - 1  // while 끝에서 +1
        } else if in_block && trimmed.contains("=") {
            let parts = trimmed.split("=")
            if parts.len() >= 2 {
                let lhs = parts[0].trim()
                let rhs = parts[1].trim()
                if lhs.len() > 0 && lhs.len() < 40 && rhs.len() > 0 {
                    let v = parse_numeric(rhs)
                    if is_valid_number(v) {
                        keys = keys + [lhs]
                        vals = vals + [to_string(v)]
                    }
                }
            }
        }
        i = i + 1
    }
    [keys, vals]
}

// ─── 파일 단위 파싱 라우터 ─────────────────────────────────────

// 확장자 추출
pure fn file_extension(path: string) -> string {
    let parts = path.split(".")
    if parts.len() > 1 {
        return parts[parts.len() - 1]
    }
    ""
}

// 단일 파일 파싱 → [keys_list, vals_list, raw_list]
fn parse_file(path: string) -> list {
    let ext = file_extension(path)
    let content = read_file(path)
    if content.len() == 0 {
        return [[], [], []]
    }

    match ext {
        "md" -> {
            let table_kv = md_extract_constants(content)
            let code_kv = md_extract_code_constants(content)
            let keys = table_kv[0] + code_kv[0]
            let vals = table_kv[1] + code_kv[1]
            [keys, vals, []]
        },
        "json" -> {
            let kv = json_extract_kv(content)
            let raw = json_extract_values(content)
            [kv[0], kv[1], raw]
        },
        "txt" -> {
            let kv = txt_extract_kv(content)
            let raw = txt_extract_numbers(content)
            [kv[0], kv[1], raw]
        },
        _ -> [[], [], []]
    }
}

// ─── 디렉토리 재귀 탐색 ────────────────────────────────────────

// 스킵 대상 디렉토리인지
pure fn should_skip_dir(name: string) -> bool {
    let skips = skip_dirs.split(",")
    let mut si = 0
    while si < skips.len() {
        if name == skips[si] {
            return true
        }
        si = si + 1
    }
    name.starts_with(".")
}

// 확장자가 지원 대상인지
pure fn is_supported_ext(ext: string, extensions: list) -> bool {
    let mut ei = 0
    while ei < extensions.len() {
        if ext == extensions[ei] {
            return true
        }
        ei = ei + 1
    }
    false
}

// 디렉토리 재귀 탐색 → 파일 경로 리스트
fn collect_files(dir: string, extensions: list) -> list {
    let mut result = []
    let entries = list_dir(dir)
    let mut ei = 0
    while ei < entries.len() {
        let entry = entries[ei]
        let full_path = dir + "/" + entry
        if is_dir(full_path) {
            if !should_skip_dir(entry) {
                let sub = collect_files(full_path, extensions)
                result = result + sub
            }
        } else {
            let ext = file_extension(entry)
            if is_supported_ext(ext, extensions) {
                result = result + [full_path]
            }
        }
        ei = ei + 1
    }
    result
}

// ─── projects.json 로더 ────────────────────────────────────────

// scan_patterns에서 확장자 추출 (예: "**/*.py" → "py")
fn extensions_from_patterns(patterns: list) -> list {
    let mut exts = []
    let mut pi = 0
    while pi < patterns.len() {
        let pat = patterns[pi]
        let dot_parts = pat.split(".")
        if dot_parts.len() > 1 {
            let ext = dot_parts[dot_parts.len() - 1]
            // 중복 제거
            let mut dup = false
            let mut ei = 0
            while ei < exts.len() {
                if exts[ei] == ext { dup = true }
                ei = ei + 1
            }
            if !dup {
                exts = exts + [ext]
            }
        }
        pi = pi + 1
    }
    exts
}

// projects.json 파일에서 소스 설정 로드
fn load_projects(json_path: string) -> list {
    let content = read_file(json_path)
    if content.len() == 0 {
        println("[ingest] projects.json 읽기 실패:", json_path)
        return []
    }
    // 간이 JSON 파싱 — base_path와 projects 배열 추출
    // hexa에 JSON 라이브러리 없으므로 줄 단위 파싱
    let lines = content.split("\n")
    let mut base_path = ""
    let mut sources = []
    let mut current_domain = ""
    let mut current_path = ""
    let mut current_patterns = []

    let mut li = 0
    while li < lines.len() {
        let line = lines[li].trim()
        // base_path 추출
        if line.contains("\"base_path\"") && line.contains(":") {
            let parts = line.split(":")
            if parts.len() >= 2 {
                let val = parts[1].trim()
                // 따옴표와 콤마 제거
                let mut cleaned = val
                if cleaned.starts_with("\"") {
                    cleaned = cleaned.slice(1, cleaned.len())
                }
                if cleaned.ends_with(",") {
                    cleaned = cleaned.slice(0, cleaned.len() - 1)
                }
                if cleaned.ends_with("\"") {
                    cleaned = cleaned.slice(0, cleaned.len() - 1)
                }
                base_path = cleaned
            }
        }
        // domain 추출
        if line.contains("\"domain\"") && line.contains(":") {
            let parts = line.split(":")
            if parts.len() >= 2 {
                let val = parts[1].trim()
                let mut cleaned = val
                if cleaned.starts_with("\"") { cleaned = cleaned.slice(1, cleaned.len()) }
                if cleaned.ends_with(",") { cleaned = cleaned.slice(0, cleaned.len() - 1) }
                if cleaned.ends_with("\"") { cleaned = cleaned.slice(0, cleaned.len() - 1) }
                current_domain = cleaned
            }
        }
        // path 추출
        if line.contains("\"path\"") && line.contains(":") && !line.contains("base_path") {
            let parts = line.split(":")
            if parts.len() >= 2 {
                let val = parts[1].trim()
                let mut cleaned = val
                if cleaned.starts_with("\"") { cleaned = cleaned.slice(1, cleaned.len()) }
                if cleaned.ends_with(",") { cleaned = cleaned.slice(0, cleaned.len() - 1) }
                if cleaned.ends_with("\"") { cleaned = cleaned.slice(0, cleaned.len() - 1) }
                current_path = cleaned
            }
        }
        // 프로젝트 블록 끝 감지 (}로 끝나는 줄)
        if (line == "}" || line == "},") && current_domain.len() > 0 && current_path.len() > 0 {
            let full_path = base_path + "/" + current_path
            // extensions: 지원 확장자만 사용
            sources = sources + [full_path + "|" + current_domain]
            current_domain = ""
            current_path = ""
        }
        li = li + 1
    }
    sources
}

// ─── 크롤러 메인 ───────────────────────────────────────────────

// 단일 프로젝트 소스 크롤링
fn crawl_source(source_path: string, domain: string, extensions: list) -> list {
    let mut probes = []
    let mut scanned = 0
    let mut skipped = 0
    let mut errors = []

    if !file_exists(source_path) {
        errors = errors + ["[" + domain + "] 경로 없음: " + source_path]
        return [probes, to_string(scanned), to_string(skipped), errors]
    }

    let files = collect_files(source_path, extensions)
    let mut fi = 0
    while fi < files.len() {
        let file_path = files[fi]
        let parsed = parse_file(file_path)
        let keys = parsed[0]
        let vals = parsed[1]
        let raw = parsed[2]

        if keys.len() == 0 && raw.len() == 0 {
            skipped = skipped + 1
        } else {
            // 상대 경로 계산
            let mut rel = file_path
            if file_path.starts_with(source_path) {
                rel = file_path.slice(source_path.len() + 1, file_path.len())
            }
            // probe 직렬화: domain|file|keys_csv|vals_csv|raw_csv
            let probe_str = domain + "|" + rel + "|" + join_list(keys, ",") + "|" + join_list(vals, ",") + "|" + join_list(raw, ",")
            probes = probes + [probe_str]
            scanned = scanned + 1
        }
        fi = fi + 1
    }
    [probes, to_string(scanned), to_string(skipped), errors]
}

// 리스트를 구분자로 결합
pure fn join_list(lst: list, sep: string) -> string {
    let mut result = ""
    let mut i = 0
    while i < lst.len() {
        if i > 0 { result = result + sep }
        result = result + lst[i]
        i = i + 1
    }
    result
}

// 전체 크롤 실행 (프로젝트 디렉토리 직접 지정)
fn crawl(root_path: string, domain: string) -> IngestResult {
    let extensions = supported_exts.split(",")
    let result = crawl_source(root_path, domain, extensions)
    let probes = result[0]
    let scanned = to_int(result[1])
    let skipped = to_int(result[2])
    let errors = result[3]

    IngestResult {
        probes: probes,
        files_scanned: scanned,
        files_skipped: skipped,
        errors: errors
    }
}

// projects.json 기반 전체 크롤
fn crawl_from_projects(json_path: string) -> IngestResult {
    let sources = load_projects(json_path)
    let extensions = supported_exts.split(",")
    let mut all_probes = []
    let mut total_scanned = 0
    let mut total_skipped = 0
    let mut all_errors = []

    let mut si = 0
    while si < sources.len() {
        let parts = sources[si].split("|")
        let src_path = parts[0]
        let src_domain = parts[1]
        let result = crawl_source(src_path, src_domain, extensions)
        all_probes = all_probes + result[0]
        total_scanned = total_scanned + to_int(result[1])
        total_skipped = total_skipped + to_int(result[2])
        all_errors = all_errors + result[3]
        si = si + 1
    }

    IngestResult {
        probes: all_probes,
        files_scanned: total_scanned,
        files_skipped: total_skipped,
        errors: all_errors
    }
}

// ─── 리포트 출력 ───────────────────────────────────────────────

fn print_ingest_report(r: IngestResult) {
    println("┌──────────────────────────────────────────────┐")
    println("│         NEXUS-6 Ingest Report                │")
    println("├──────────────────────────────────────────────┤")
    println("│  스캔 파일:     " + to_string(r.files_scanned))
    println("│  스킵 파일:     " + to_string(r.files_skipped))
    println("│  프로브 수:     " + to_string(r.probes.len()))
    println("│  에러 수:       " + to_string(r.errors.len()))
    println("├──────────────────────────────────────────────┤")

    // 프로브 요약 (최대 10개)
    let max_show = 10
    let mut pi = 0
    while pi < r.probes.len() && pi < max_show {
        let parts = r.probes[pi].split("|")
        let domain = parts[0]
        let file = parts[1]
        let nkeys = parts[2].split(",").len()
        println("│  [" + domain + "] " + file + " (" + to_string(nkeys) + " 값)")
        pi = pi + 1
    }
    if r.probes.len() > max_show {
        println("│  ... 외 " + to_string(r.probes.len() - max_show) + "개")
    }

    // 에러
    if r.errors.len() > 0 {
        println("├──────────────────────────────────────────────┤")
        let mut ei = 0
        while ei < r.errors.len() {
            println("│  ⚠ " + r.errors[ei])
            ei = ei + 1
        }
    }
    println("└──────────────────────────────────────────────┘")
}

// 단일 파일 스캔 리포트
fn scan_file_report(path: string) {
    println("┌──────────────────────────────────────────────┐")
    println("│  파일 스캔: " + path)
    println("├──────────────────────────────────────────────┤")

    let parsed = parse_file(path)
    let keys = parsed[0]
    let vals = parsed[1]
    let raw = parsed[2]

    println("│  명명된 값: " + to_string(keys.len()) + "개")
    let mut ki = 0
    while ki < keys.len() {
        println("│    " + keys[ki] + " = " + vals[ki])
        ki = ki + 1
    }

    if raw.len() > 0 {
        println("│  원시 숫자: " + to_string(raw.len()) + "개")
        println("│    [" + join_list(raw, ", ") + "]")
    }
    println("└──────────────────────────────────────────────┘")
}

// ─── CLI 진입점 ────────────────────────────────────────────────

fn main() {
    let args = env_args()

    if args.len() < 2 {
        println("사용법:")
        println("  hexa ingest.hexa crawl <디렉토리>        # 디렉토리 크롤링")
        println("  hexa ingest.hexa crawl-projects <json>   # projects.json 기반")
        println("  hexa ingest.hexa scan-file <파일경로>     # 단일 파일 스캔")
        return
    }

    let cmd = args[1]

    match cmd {
        "crawl" -> {
            if args.len() < 3 {
                println("에러: 크롤 대상 디렉토리를 지정하세요")
                return
            }
            let target = args[2]
            // 도메인 이름은 경로 마지막 요소
            let path_parts = target.split("/")
            let domain = path_parts[path_parts.len() - 1]
            println("[ingest] 크롤 시작: " + target + " (도메인: " + domain + ")")
            let result = crawl(target, domain)
            print_ingest_report(result)
        },
        "crawl-projects" -> {
            let json_path = if args.len() >= 3 {
                args[2]
            } else {
                "shared/config/projects.json"
            }
            println("[ingest] projects.json 기반 크롤: " + json_path)
            let result = crawl_from_projects(json_path)
            print_ingest_report(result)
        },
        "scan-file" -> {
            if args.len() < 3 {
                println("에러: 스캔할 파일 경로를 지정하세요")
                return
            }
            scan_file_report(args[2])
        },
        _ -> {
            println("알 수 없는 명령: " + cmd)
            println("사용 가능: crawl, crawl-projects, scan-file")
        }
    }
}

// ─── 검증 ──────────────────────────────────────────────────────

assert is_separator_row("|---|---|---|")
assert !is_separator_row("| a | b |")
assert split_table_row("| a | b | c |").len() == 3
assert clean_bold("**THM-1**") == "THM-1"
assert is_valid_number(parse_numeric("12.0"))
assert is_valid_number(parse_numeric("4/3"))
assert !is_valid_number(parse_numeric(""))

let test_ext = file_extension("docs/test.md")
assert test_ext == "md"
assert file_extension("no_ext") == ""

assert find_column(["Symbol", "Value", "Desc"], ["Value"]) == 1
assert find_column(["a", "b"], ["x", "y"]) == -1

assert join_list(["a", "b", "c"], ",") == "a,b,c"
assert join_list([], ",") == ""

let exts = extensions_from_patterns(["**/*.py", "docs/**/*.md", "**/*.py"])
assert exts.len() == 2

println("=== ingest verified ===")
