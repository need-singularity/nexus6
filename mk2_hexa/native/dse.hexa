        header = header + "," + to_string(names[i])
        i = i + 1
    }
    header = header + ",n6_pct,perf,power,cost,pareto"
    println(header)

    i = 0
    while i < to_int(combos.len()) {
        let combo: list = combos[i]
        let indices: list = combo_indices(combo)
        let mut row = to_string(i + 1)
        let mut j: i64 = 0
        while j < num_levels {
            let ci = to_int(indices[j])
            row = row + "," + dom_cand_id_at(d, j, ci)
            j = j + 1
        }
        row = row + "," + fmt1(combo_n6(combo) * 100.0) + "," + fmt3(combo_perf(combo)) + "," + fmt3(combo_power(combo)) + "," + fmt3(combo_cost(combo)) + "," + fmt4(combo_pareto(combo))
        println(row)
        i = i + 1
    }
}

// ═══════════════════════════════════════════════════════════
// ─── CROSS-DSE ───
// ═══════════════════════════════════════════════════════════

fn combo_short(d: list, combo: list) -> string {
    let indices: list = combo_indices(combo)
    if to_int(indices.len()) == 0 { return "-" }
    let first = dom_cand_id_at(d, 0, to_int(indices[0]))
    return substr(first, 0, 6)
}

fn cross_dse(domains: list, domain_names: list, top_k: i64) {
    let bar = repeat_str("=", 66)
    println("")
    println(bar)
    println("  Cross-DSE: " + to_string(to_int(domains.len())) + " domains")
    let mut di: i64 = 0
    while di < to_int(domains.len()) {
        let d: list = domains[di]
        println("    - " + dom_name(d))
        di = di + 1
    }
    println(bar)
    println("")

    // Run each domain, take top-K
    let mut domain_tops: list = []
    di = 0
    while di < to_int(domains.len()) {
        let d: list = domains[di]
        let combos = enumerate_domain(d)
        let take = min_i(top_k, to_int(combos.len()))
        let mut top_combos: list = []
        let mut ti: i64 = 0
        while ti < take {
            top_combos = top_combos + [combos[ti]]
            ti = ti + 1
        }
        domain_tops = domain_tops + [top_combos]
        di = di + 1
    }

    // Pairwise cross-combination
    let nd = to_int(domains.len())
    if nd >= 2 {
        let mut i: i64 = 0
        while i < nd {
            let mut j = i + 1
            while j < nd {
                let da: list = domains[i]
                let db: list = domains[j]
                let tops_a: list = domain_tops[i]
                let tops_b: list = domain_tops[j]
                println("--- Cross: " + dom_name(da) + " x " + dom_name(db) + " ---")
                println("")

                // compute cross results: [ai, bi, cn6, cperf, cpow, ccost, cscore]
                let mut cross_results: list = []
                let mut ai: i64 = 0
                while ai < to_int(tops_a.len()) {
                    let mut bi: i64 = 0
                    while bi < to_int(tops_b.len()) {
                        let ca: list = tops_a[ai]
                        let cb: list = tops_b[bi]
                        let cn6 = (combo_n6(ca) + combo_n6(cb)) / 2.0
                        let cp = (combo_perf(ca) + combo_perf(cb)) / 2.0
                        let cpw = (combo_power(ca) + combo_power(cb)) / 2.0
                        let cc = (combo_cost(ca) + combo_cost(cb)) / 2.0
                        let cs = 0.40 * cn6 + 0.30 * cp + 0.20 * cpw + 0.10 * cc
                        cross_results = cross_results + [[ai, bi, cn6, cp, cpw, cc, cs]]
                        bi = bi + 1
                    }
                    ai = ai + 1
                }

                // sort by score desc
                let mut si: i64 = 1
                while si < to_int(cross_results.len()) {
                    let mut sk = si
                    let mut sdone2 = false
                    while sk > 0 {
                        if sdone2 == false {
                            let cur: list = cross_results[sk]
                            let prev: list = cross_results[sk - 1]
                            if to_float(cur[6]) > to_float(prev[6]) {
                                cross_results[sk] = prev
                                cross_results[sk - 1] = cur
                                sk = sk - 1
                            } else {
                                sdone2 = true
                            }
                        } else {
                            sk = 0
                        }
                    }
                    si = si + 1
                }

                let show = min_i(10, to_int(cross_results.len()))
                println("  " + pad_left("Rank", 4) + " | " + pad_left(substr(dom_name(da), 0, 6), 6) + " | " + pad_left(substr(dom_name(db), 0, 6), 6) + " |  n6%  | Perf  | Power | Cost  | Score")
                println("  " + repeat_str("-", 70))

                let mut r: i64 = 0
                while r < show {
                    let cr: list = cross_results[r]
                    let cai = to_int(cr[0])
                    let cbi = to_int(cr[1])
                    let pa = combo_short(da, tops_a[cai])
                    let pb = combo_short(db, tops_b[cbi])
                    println("  " + pad_left(to_string(r + 1), 4) + " | " + pad_left(pa, 6) + " | " + pad_left(pb, 6) + " | " + pad_left(fmt1(to_float(cr[2]) * 100.0), 4) + " | " + fmt3(to_float(cr[3])) + " | " + fmt3(to_float(cr[4])) + " | " + fmt3(to_float(cr[5])) + " | " + fmt4(to_float(cr[6])))
                    r = r + 1
                }
                println("")
                j = j + 1
            }
            i = i + 1
        }
    }
}

// ═══════════════════════════════════════════════════════════
// ─── BATCH ALL ───
// ═══════════════════════════════════════════════════════════

fn load_all_domains(dir: string) -> list {
    // returns [domains_list, names_list]
    // Use exec("ls ...") to list .toml files
    let mut domains: list = []
    let mut names: list = []

    let ls_result = exec("ls " + dir + "/*.toml 2>/dev/null")
    let files = ls_result.split("\n")
    let mut fi: i64 = 0
    while fi < to_int(files.len()) {
        let fpath = files[fi].trim()
        let mut skip = false
        if fpath == "" { skip = true }
        if skip == false {
            if fpath.ends_with(".toml") == false { skip = true }
        }
        if skip == false {
            let mut content = ""
            let mut read_ok = true
            try {
                content = read_file(fpath)
            } catch e {
                read_ok = false
            }
            if read_ok {
                let domain = parse_toml(content)
                if dom_num_levels(domain) > 0 {
                    let path_parts = fpath.split("/")
                    let fname = to_string(path_parts[to_int(path_parts.len()) - 1])
                    let name_parts = fname.split(".toml")
                    let name = to_string(name_parts[0])
                    domains = domains + [domain]
                    names = names + [name]
                }
            }
        }
        fi = fi + 1
    }
    return [domains, names]
}

fn run_batch_all(dir: string) {
    let result = load_all_domains(dir)
    let domains: list = result[0]
    let names: list = result[1]
    let nd = to_int(domains.len())

    if nd == 0 {
        println("No valid domains found in " + dir)
        return
    }

    let bar = repeat_str("=", 90)
    println("")
    println(bar)
    println("  Universal DSE -- Batch All (" + to_string(nd) + " domains)")
    println(bar)
    println("")

    println("  " + pad_left("Domain", 20) + " | " + pad_left("Combos", 8) + " | " + pad_left("Compat", 8) + " | " + pad_left("n6%", 6) + " | " + pad_left("Perf", 6) + " | " + pad_left("Power", 6) + " | " + pad_left("Cost", 6) + " | " + pad_left("Pareto", 7))
    println("  " + repeat_str("-", 85))

    let mut total_combos: i64 = 0
    let mut total_compat: i64 = 0
    let mut pareto_sum = 0.0
    let mut n6_sum = 0.0

    let mut i: i64 = 0
    while i < nd {
        let d: list = domains[i]
        let total = dom_total_combos(d)
        let combos = enumerate_domain(d)
        let compat = to_int(combos.len())
        total_combos = total_combos + total
        total_compat = total_compat + compat

        if compat > 0 {
            let best: list = combos[0]
            pareto_sum = pareto_sum + combo_pareto(best)
            n6_sum = n6_sum + combo_n6(best)
            println("  " + pad_left(to_string(names[i]), 20) + " | " + pad_left(to_string(total), 8) + " | " + pad_left(to_string(compat), 8) + " | " + pad_left(fmt1(combo_n6(best) * 100.0), 5) + " | " + fmt3(combo_perf(best)) + " | " + fmt3(combo_power(best)) + " | " + fmt3(combo_cost(best)) + " | " + fmt4(combo_pareto(best)))
        }
        i = i + 1
    }

    let nf = to_float(nd)
    println("  " + repeat_str("-", 85))
    println("  " + pad_left("TOTAL/AVG", 20) + " | " + pad_left(to_string(total_combos), 8) + " | " + pad_left(to_string(total_compat), 8) + " | " + pad_left(fmt1(n6_sum / nf * 100.0), 5) + " |        |        |        | " + fmt4(pareto_sum / nf))
    println("")
}

// ═══════════════════════════════════════════════════════════
// ─── CROSS-ALL ───
// ═══════════════════════════════════════════════════════════

fn run_cross_all(dir: string, top_n: i64) {
    let result = load_all_domains(dir)
    let domains: list = result[0]
    let names: list = result[1]
    let nd = to_int(domains.len())

    if nd < 2 {
        println("Need at least 2 domains for cross-all")
        return
    }

    let bar = repeat_str("=", 90)
    println("")
    println(bar)
    println("  Cross-DSE All Pairs: " + to_string(nd) + "C2 = " + to_string(nd * (nd - 1) / 2) + " pairs")
    println(bar)
    println("")

    // Pre-compute top combos
    let mut domain_tops: list = []
    let mut di: i64 = 0
    while di < nd {
        let d: list = domains[di]
        let combos = enumerate_domain(d)
        let take = min_i(5, to_int(combos.len()))
        let mut top_combos: list = []
        let mut ti: i64 = 0
        while ti < take {
            top_combos = top_combos + [combos[ti]]
            ti = ti + 1
        }
        domain_tops = domain_tops + [top_combos]
        di = di + 1
    }

    // All pairs
    let mut all_results: list = []
    let mut i: i64 = 0
    while i < nd {
        let mut j = i + 1
        while j < nd {
            let tops_i: list = domain_tops[i]
            let tops_j: list = domain_tops[j]
            let mut best_score = 0.0
            let mut best_n6 = 0.0
            let mut best_perf = 0.0
            let mut best_pow = 0.0
            let mut best_cost = 0.0
            let mut ai: i64 = 0
            while ai < to_int(tops_i.len()) {
                let mut bi: i64 = 0
                while bi < to_int(tops_j.len()) {
                    let ca: list = tops_i[ai]
                    let cb: list = tops_j[bi]
                    let cn6 = (combo_n6(ca) + combo_n6(cb)) / 2.0
                    let cp = (combo_perf(ca) + combo_perf(cb)) / 2.0
                    let cpw = (combo_power(ca) + combo_power(cb)) / 2.0
                    let cc = (combo_cost(ca) + combo_cost(cb)) / 2.0
                    let cs = 0.40 * cn6 + 0.30 * cp + 0.20 * cpw + 0.10 * cc
                    if cs > best_score {
                        best_score = cs
                        best_n6 = cn6
                        best_perf = cp
                        best_pow = cpw
                        best_cost = cc
                    }
                    bi = bi + 1
                }
                ai = ai + 1
            }
            all_results = all_results + [[names[i], names[j], best_n6, best_perf, best_pow, best_cost, best_score]]
            j = j + 1
        }
        i = i + 1
    }

    // sort by score desc
    let mut si: i64 = 1
    while si < to_int(all_results.len()) {
        let mut sk = si
        let mut sdone3 = false
        while sk > 0 {
            if sdone3 == false {
                let cur: list = all_results[sk]
                let prev: list = all_results[sk - 1]
                if to_float(cur[6]) > to_float(prev[6]) {
                    all_results[sk] = prev
                    all_results[sk - 1] = cur
                    sk = sk - 1
                } else {
                    sdone3 = true
                }
            } else {
                sk = 0
            }
        }
        si = si + 1
    }

    let show = min_i(top_n, to_int(all_results.len()))
    println("  " + pad_left("Rank", 4) + " | " + pad_left("Domain A", 18) + " | " + pad_left("Domain B", 18) + " |  n6%  | Perf  | Power | Cost  | Score")
    println("  " + repeat_str("-", 90))

    let mut r: i64 = 0
    while r < show {
        let cr: list = all_results[r]
        println("  " + pad_left(to_string(r + 1), 4) + " | " + pad_left(to_string(cr[0]), 18) + " | " + pad_left(to_string(cr[1]), 18) + " | " + pad_left(fmt1(to_float(cr[2]) * 100.0), 4) + " | " + fmt3(to_float(cr[3])) + " | " + fmt3(to_float(cr[4])) + " | " + fmt3(to_float(cr[5])) + " | " + fmt4(to_float(cr[6])))
        r = r + 1
    }

    // Domain frequency in top-20
    let freq_n = min_i(20, to_int(all_results.len()))
    // Simple frequency count using parallel lists
    let mut freq_names: list = []
    let mut freq_counts: list = []
    let mut fi: i64 = 0
    while fi < freq_n {
        let cr: list = all_results[fi]
        let na = to_string(cr[0])
        let nb = to_string(cr[1])

        // count name a
        let mut found_a = false
        let mut fj: i64 = 0
        while fj < to_int(freq_names.len()) {
            if to_string(freq_names[fj]) == na {
                freq_counts[fj] = to_int(freq_counts[fj]) + 1
                found_a = true
                fj = to_int(freq_names.len())
            }
            fj = fj + 1
        }
        if found_a == false {
            freq_names = freq_names + [na]
            freq_counts = freq_counts + [1]
        }

        // count name b
        let mut found_b = false
        fj = 0
        while fj < to_int(freq_names.len()) {
            if to_string(freq_names[fj]) == nb {
                freq_counts[fj] = to_int(freq_counts[fj]) + 1
                found_b = true
                fj = to_int(freq_names.len())
            }
            fj = fj + 1
        }
        if found_b == false {
            freq_names = freq_names + [nb]
            freq_counts = freq_counts + [1]
        }
        fi = fi + 1
    }

    // sort freq by count desc
    si = 1
    while si < to_int(freq_names.len()) {
        let mut sk = si
        let mut sdone4 = false
        while sk > 0 {
            if sdone4 == false {
                let cur_c = to_int(freq_counts[sk])
                let prev_c = to_int(freq_counts[sk - 1])
                if cur_c > prev_c {
                    let tmp_n = freq_names[sk]
                    freq_names[sk] = freq_names[sk - 1]
                    freq_names[sk - 1] = tmp_n
                    let tmp_c = freq_counts[sk]
                    freq_counts[sk] = freq_counts[sk - 1]
                    freq_counts[sk - 1] = tmp_c
                    sk = sk - 1
                } else {
                    sdone4 = true
                }
            } else {
                sk = 0
            }
        }
        si = si + 1
    }

    println("")
    println("  === Domain Frequency in Top-" + to_string(freq_n) + " ===")
    println("")
    fi = 0
    while fi < to_int(freq_names.len()) {
        let cnt = to_int(freq_counts[fi])
        let bar_str = repeat_str("#", cnt * 3)
        println("  " + pad_left(to_string(freq_names[fi]), 18) + " " + pad_left(to_string(cnt), 2) + " " + bar_str)
        fi = fi + 1
    }

    println("")
    println("  Total pairs: " + to_string(to_int(all_results.len())))
    let mut score_sum = 0.0
    let mut si2: i64 = 0
    while si2 < to_int(all_results.len()) {
        let cr: list = all_results[si2]
        score_sum = score_sum + to_float(cr[6])
        si2 = si2 + 1
    }
    println("  Avg score: " + fmt4(score_sum / to_float(to_int(all_results.len()))))
    println("")
}

// ═══════════════════════════════════════════════════════════
// ─── VALIDATE ───
// ═══════════════════════════════════════════════════════════

fn validate_domain(path: string) {
    let mut content = ""
    try {
        content = read_file(path)
    } catch e {
        println("Error: " + path + ": " + to_string(e))
        return
    }
    let domain = parse_toml(content)

    // extract name from path
    let path_parts = path.split("/")
    let fname = to_string(path_parts[to_int(path_parts.len()) - 1])
    let name_parts = fname.split(".toml")
    let name = to_string(name_parts[0])

    println("")
    println("=== Validation: " + name + " ===")
    println("")

    let mut warnings: i64 = 0
    let mut errors: i64 = 0
    let num_levels = dom_num_levels(domain)

    // Check levels
    if num_levels == 0 {
        println("  ERROR: No levels defined")
        errors = errors + 1
    } else {
        if num_levels != 5 {
            println("  WARN: " + to_string(num_levels) + " levels (standard is 5)")
            warnings = warnings + 1
        }
    }

    // Check scoring weights
    let w_sum = dom_w_n6(domain) + dom_w_perf(domain) + dom_w_power(domain) + dom_w_cost(domain)
    if abs_f(w_sum - 1.0) > 0.05 {
        println("  WARN: Scoring weights sum to " + fmt3(w_sum) + " (should be ~1.0)")
        warnings = warnings + 1
    }

    // Check candidates
    let mut li: i64 = 0
    while li < num_levels {
        let count = dom_level_count(domain, li)
        let names: list = dom_level_names(domain)
        if count == 0 {
            println("  ERROR: Level " + to_string(li) + " '" + to_string(names[li]) + "' has no candidates")
            errors = errors + 1
        }
        if count > 0 {
        let mut ci: i64 = 0
        while ci < count {
            let cid = dom_cand_id_at(domain, li, ci)
            let cn6 = dom_cand_n6_at(domain, li, ci)
            let cperf = dom_cand_perf_at(domain, li, ci)
            let clabel = dom_cand_label_at(domain, li, ci)

            if cid == "" {
                println("  ERROR: L" + to_string(li) + " candidate missing id")
                errors = errors + 1
            }
            if cn6 < 0.0 {
                println("  ERROR: L" + to_string(li) + " '" + cid + "' n6=" + fmt3(cn6) + " out of range [0,1]")
                errors = errors + 1
            }
            if cn6 > 1.0 {
                println("  ERROR: L" + to_string(li) + " '" + cid + "' n6=" + fmt3(cn6) + " out of range [0,1]")
                errors = errors + 1
            }
            if cperf < 0.0 {
                println("  WARN: L" + to_string(li) + " '" + cid + "' perf=" + fmt3(cperf) + " out of range")
                warnings = warnings + 1
            }
            if cperf > 1.0 {
                println("  WARN: L" + to_string(li) + " '" + cid + "' perf=" + fmt3(cperf) + " out of range")
                warnings = warnings + 1
            }
            if cn6 >= 0.9 {
                let label_len = str_len(clabel)
                if label_len < 10 {
                    println("  WARN: L" + to_string(li) + " '" + cid + "' n6=" + fmt3(cn6) + " but label is minimal")
                    warnings = warnings + 1
                }
            }
            ci = ci + 1
        }
        } // end if count > 0
        li = li + 1
    }

    // Check rules reference valid levels
    let rtypes: list = dom_rule_types(domain)
    let rif_levels: list = dom_rule_if_levels(domain)
    let rthen_levels: list = dom_rule_then_levels(domain)
    let mut ri: i64 = 0
    while ri < to_int(rtypes.len()) {
        if to_int(rif_levels[ri]) >= num_levels {
            println("  ERROR: Rule " + to_string(ri) + " if_level=" + to_string(rif_levels[ri]) + " exceeds level count")
            errors = errors + 1
        }
        if to_int(rthen_levels[ri]) >= num_levels {
            println("  ERROR: Rule " + to_string(ri) + " then_level=" + to_string(rthen_levels[ri]) + " exceeds level count")
            errors = errors + 1
        }
        ri = ri + 1
    }

    // Summary
    let combos = enumerate_domain(domain)
    let total = dom_total_combos(domain)
    let compat = to_int(combos.len())
    let mut filter_pct = 0.0
    if total > 0 {
        filter_pct = to_float(total - compat) / to_float(total) * 100.0
    }

    // sizes
    let mut sizes_str = "["
    li = 0
    while li < num_levels {
        if li > 0 { sizes_str = sizes_str + ", " }
        sizes_str = sizes_str + to_string(dom_level_count(domain, li))
        li = li + 1
    }
    sizes_str = sizes_str + "]"

    println("")
    println("  Summary:")
    println("    Levels: " + to_string(num_levels))
    println("    Candidates per level: " + sizes_str)
    println("    Total combos: " + to_string(total) + " -> " + to_string(compat) + " compatible (" + fmt1(filter_pct) + "% filtered)")
    println("    Rules: " + to_string(to_int(rtypes.len())))
    println("    Errors: " + to_string(errors) + ", Warnings: " + to_string(warnings))

    if errors == 0 {
        if warnings == 0 {
            println("    Status: PASS")
        } else {
            println("    Status: PASS with " + to_string(warnings) + " warnings")
        }
    } else {
        println("    Status: FAIL (" + to_string(errors) + " errors)")
    }
    println("")
}

// ═══════════════════════════════════════════════════════════
// ─── RANDOM BASELINE (Monte Carlo) ───
// ═══════════════════════════════════════════════════════════

fn run_random_baseline(n_trials: i64, path: string) {
    let mut content = ""
    try {
        content = read_file(path)
    } catch e {
        println("Error: " + path + ": " + to_string(e))
        return
    }
    let domain = parse_toml(content)

    let path_parts = path.split("/")
    let fname = to_string(path_parts[to_int(path_parts.len()) - 1])
    let name_parts = fname.split(".toml")
    let name = to_string(name_parts[0])

    let combos = enumerate_domain(domain)
    if to_int(combos.len()) == 0 {
        println("No compatible combinations")
        return
    }

    let best: list = combos[0]
    let actual_best_n6 = combo_n6(best)
    let actual_best_pareto = combo_pareto(best)

    // LCG PRNG
    let mut seed: i64 = 42

    // Collect all n6 scores
    let mut n6_scores: list = []
    let num_levels = dom_num_levels(domain)
    let mut li: i64 = 0
    while li < num_levels {
        let count = dom_level_count(domain, li)
        let mut ci: i64 = 0
        while ci < count {
            n6_scores = n6_scores + [dom_cand_n6_at(domain, li, ci)]
            ci = ci + 1
        }
        li = li + 1
    }

    let mut random_beat_n6: i64 = 0
    let mut random_beat_pareto: i64 = 0
    let mut random_n6_sum = 0.0
    let mut random_pareto_sum = 0.0

    let bar = repeat_str("=", 66)
    println("")
    println(bar)
    println("  Random Baseline Test -- " + name)
    println("  " + to_string(n_trials) + " trials, shuffling n6 scores across candidates")
    println(bar)
    println("")

    let mut trial: i64 = 0
    while trial < n_trials {
        // Fisher-Yates shuffle
        let mut shuffled: list = []
        let mut si: i64 = 0
        while si < to_int(n6_scores.len()) {
            shuffled = shuffled + [n6_scores[si]]
            si = si + 1
        }

        let slen = to_int(shuffled.len())
        let mut fi = slen - 1
        while fi > 0 {
            // LCG step
            seed = seed * 6364136223846793005 + 1442695040888963407
            let mut rval = seed
            if rval < 0 { rval = 0 - rval }
            let j = rval - (rval / (fi + 1)) * (fi + 1)
            // swap
            let tmp = shuffled[fi]
            shuffled[fi] = shuffled[j]
            shuffled[j] = tmp
            fi = fi - 1
        }

        // Assign shuffled n6 and find best per level
        let mut best_n6 = 0.0
        let mut idx: i64 = 0
        li = 0
        while li < num_levels {
            let count = dom_level_count(domain, li)
            let mut level_max_n6 = 0.0
            let mut ci: i64 = 0
            while ci < count {
                if idx < slen {
                    let val = to_float(shuffled[idx])
                    if val > level_max_n6 { level_max_n6 = val }
                    idx = idx + 1
                }
                ci = ci + 1
            }
            best_n6 = best_n6 + level_max_n6
            li = li + 1
        }
        best_n6 = best_n6 / to_float(num_levels)

        let approx_pareto = dom_w_n6(domain) * best_n6 + dom_w_perf(domain) * combo_perf(best) + dom_w_power(domain) * combo_power(best) + dom_w_cost(domain) * combo_cost(best)

        random_n6_sum = random_n6_sum + best_n6
        random_pareto_sum = random_pareto_sum + approx_pareto

        if best_n6 >= actual_best_n6 { random_beat_n6 = random_beat_n6 + 1 }
        if approx_pareto >= actual_best_pareto { random_beat_pareto = random_beat_pareto + 1 }

        trial = trial + 1
    }

    let avg_random_n6 = random_n6_sum / to_float(n_trials)
    let avg_random_pareto = random_pareto_sum / to_float(n_trials)
    let p_n6 = to_float(random_beat_n6) / to_float(n_trials)
    let p_pareto = to_float(random_beat_pareto) / to_float(n_trials)

    println("  Actual best n6:    " + fmt1(actual_best_n6 * 100.0) + "%")
    println("  Random avg n6:     " + fmt1(avg_random_n6 * 100.0) + "%")
    println("  p-value (n6):      " + fmt6(p_n6) + " (" + to_string(random_beat_n6) + "/" + to_string(n_trials) + " trials beat actual)")
    println("")
    println("  Actual Pareto:     " + fmt4(actual_best_pareto))
    println("  Random avg Pareto: " + fmt4(avg_random_pareto))
    println("  p-value (Pareto):  " + fmt6(p_pareto) + " (" + to_string(random_beat_pareto) + "/" + to_string(n_trials) + " trials beat actual)")
    println("")

    let delta_n6 = (actual_best_n6 - avg_random_n6) * 100.0
    println("  n6 advantage:      +" + fmt1(delta_n6) + "% over random")

    if p_n6 < 0.01 {
        println("  Significance:      p < 0.01 -- HIGHLY SIGNIFICANT")
    } else {
        if p_n6 < 0.05 {
            println("  Significance:      p < 0.05 -- SIGNIFICANT")
        } else {
            println("  Significance:      p >= 0.05 -- NOT SIGNIFICANT")
        }
    }
    println("")
}

// ═══════════════════════════════════════════════════════════
// ─── SINGLE DOMAIN RUN ───
// ═══════════════════════════════════════════════════════════

fn run_single(d: list, top_n: i64) {
    let total = dom_total_combos(d)
    let combos = enumerate_domain(d)
    let compatible = to_int(combos.len())

    print_header(d, total, compatible)
    print_candidates(d)
    print_top(d, combos, top_n)
    print_best_by_category(d, combos)

    // Pareto frontier (limit to top 500 for O(n^2))
    let mut pareto_input: list = combos
    if to_int(combos.len()) > 500 {
        pareto_input = []
        let mut pi: i64 = 0
        while pi < 500 {
            pareto_input = pareto_input + [combos[pi]]
            pi = pi + 1
        }
    }
    let frontier = pareto_frontier(pareto_input)
    print_pareto(d, combos, frontier)
    print_stats(combos)

    if to_int(combos.len()) > 0 {
        print_ascii_path(d, combos[0])
    }
}

// ═══════════════════════════════════════════════════════════
// ─── HELP ───
// ═══════════════════════════════════════════════════════════

fn print_help() {
    println("Universal DSE Explorer -- n6-architecture (mk2 hexa)")
    println("")
    println("Usage:")
    println("  hexa dse.hexa help                               Show this help")
    println("  hexa dse.hexa search <domain.toml>               Single domain DSE")
    println("  hexa dse.hexa search <d1.toml> <d2.toml> [...]   Cross-DSE")
    println("  hexa dse.hexa search <domain.toml> --top 30      Custom top-N")
    println("  hexa dse.hexa search <domain.toml> --csv         CSV output")
    println("  hexa dse.hexa explore --all <domains_dir/>       Batch all domains")
    println("  hexa dse.hexa explore --cross-all <dir/> [--top N]  All pairs cross-DSE")
    println("  hexa dse.hexa validate <domain.toml>             Validate TOML")
    println("  hexa dse.hexa baseline <N> <domain.toml>         Monte Carlo random baseline")
    println("")
    println("TOML Format:")
    println("  [meta]           name, desc")
    println("  [scoring]        n6, perf, power, cost weights (sum=1.0)")
    println("  [[level]]        name of each level")
    println("  [[candidate]]    id, label, n6, perf, power, cost (0.0-1.0)")
    println("  [[rule]]         type=require|exclude, if_level, if_id, then_level, then_ids")
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

let cli_args = args()
// args()[0]=hexa binary, [1]=script, user args start at [2]
let argc = to_int(cli_args.len())

if argc < 3 {
    print_help()
    return
}

let command = to_string(cli_args[2])

if command == "help" {
    print_help()
    return
}

if command == "search" {
    if argc < 4 {
        println("Error: search requires at least one TOML file")
        return
    }

    let mut toml_files: list = []
    let mut top_n: i64 = 20
    let mut csv_mode = false
    let mut i: i64 = 3
    while i < argc {
        let arg = to_string(cli_args[i])
        let mut consumed = false
        if arg == "--top" {
            if i + 1 < argc {
                top_n = to_int(safe_float(to_string(cli_args[i + 1])))
                i = i + 2
                consumed = true
            }
        }
        if consumed == false {
            if arg == "--csv" {
                csv_mode = true
                i = i + 1
                consumed = true
            }
        }
        if consumed == false {
            toml_files = toml_files + [arg]
            i = i + 1
        }
    }

    if to_int(toml_files.len()) == 0 {
        println("Error: no TOML files specified")
        return
    }

    // Load domains
    let mut domains: list = []
    let mut domain_names: list = []
    let mut fi: i64 = 0
    while fi < to_int(toml_files.len()) {
        let path = to_string(toml_files[fi])
        let mut content = ""
        try {
            content = read_file(path)
        } catch e {
            println("Error reading " + path + ": " + to_string(e))
            return
        }
        let domain = parse_toml(content)
        if dom_num_levels(domain) == 0 {
            println("Warning: " + path + " has no levels defined")
        }
        if dom_num_levels(domain) > 0 {
            domains = domains + [domain]
            domain_names = domain_names + [dom_name(domain)]
        }
        fi = fi + 1
    }

    if to_int(domains.len()) == 0 {
        println("Error: no valid domains loaded")
        return
    }

    // Cross-DSE mode
    if to_int(domains.len()) > 1 {
        let mut di: i64 = 0
        while di < to_int(domains.len()) {
            let d: list = domains[di]
            run_single(d, top_n)
            di = di + 1
        }
        cross_dse(domains, domain_names, 5)
        return
    }

    // Single domain
    if csv_mode {
        let d: list = domains[0]
        let combos = enumerate_domain(d)
        print_csv(d, combos)
    } else {
        let d: list = domains[0]
        run_single(d, top_n)
    }
    return
}

if command == "explore" {
    if argc < 5 {
        println("Error: explore requires --all or --cross-all <dir>")
        return
    }
    let mode = to_string(cli_args[3])
    let dir = to_string(cli_args[4])

    if mode == "--all" {
        run_batch_all(dir)
        return
    }
    if mode == "--cross-all" {
        let mut top_n: i64 = 20
        if argc >= 7 {
            if to_string(cli_args[5]) == "--top" {
                top_n = to_int(safe_float(to_string(cli_args[6])))
            }
        }
        run_cross_all(dir, top_n)
        return
    }

    println("Error: unknown explore mode: " + mode)
    return
}

if command == "validate" {
    if argc < 4 {
        println("Error: validate requires a TOML file path")
        return
    }
    let path = to_string(cli_args[3])
    validate_domain(path)
    return
}

if command == "baseline" {
    if argc < 5 {
        println("Error: baseline requires <N> <domain.toml>")
        return
    }
    let n_trials = to_int(safe_float(to_string(cli_args[3])))
    let path = to_string(cli_args[4])
    run_random_baseline(n_trials, path)
    return
}

println("Unknown command: " + command)
println("Run 'hexa dse.hexa help' for usage")
