// resonance_map.hexa — 파동 공명 지도 (빈공간 도메인 간섭 패턴 분석)
// 실행: hexa resonance_map.hexa [서브커맨드]
//       hexa resonance_map.hexa scan            소나/파동 이벤트 기반 공명 스캔
//       hexa resonance_map.hexa pairs           도메인 쌍별 에너지 간섭 패턴
//       hexa resonance_map.hexa resonance       n=6 배수 공명쌍 추출
//       hexa resonance_map.hexa emerge          빈공간 간섭 → 창발 도메인 후보
//       hexa resonance_map.hexa help            도움말
//
// 원리:
//   1. growth_bus.jsonl에서 소나/파동 이벤트 읽기
//   2. 도메인 쌍별 에너지 간섭 패턴 (합, 차, 비율)
//   3. n=6 배수에 가까운 공명쌍 추출
//   4. 빈공간끼리 간섭 시 창발 가능한 신규 도메인 후보 출력

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _bus_path = _shared + "/growth_bus.jsonl"
let _graph_path = _shared + "/discovery_graph.json"
let _log_path = _shared + "/discovery_log.jsonl"

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

fn safe_float(s: string) -> f64 {
    let mut v: f64 = 0.0
    try { v = to_float(s.trim()) } catch e {}
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

// n=6 산술함수 상수
let N6 = 6
let SIGMA = 12
let PHI = 2
let TAU = 4
let J2 = 24
let SOPFR = 5
// n=6 공명 배수 목록
let resonance_multiples = [6, 12, 24, 36, 48, 72, 120, 720]
let resonance_names = ["n", "sigma", "J2", "6^2", "sigma*tau", "sigma*n", "5!", "6!"]

// ═══════════════════════════════════════════════════════════
// growth_bus에서 소나/파동 이벤트 추출
// ═══════════════════════════════════════════════════════════

fn extract_wave_events() -> string {
    let mut result = ""
    try {
        // type이 sonar, wave, harmonics, standing_wave, wave_bt, interference 인 이벤트
        result = exec("grep -E '\"type\":\"(sonar|wave|harmonics|standing_wave|wave_bt|interference|absorb|resonance)\"' " + _bus_path + " | tail -500")
    } catch e {}
    return result
}

// 도메인별 에너지 수준 추출 (discovery_log에서 EXACT 값 합산)
fn domain_energy_map() -> string {
    let mut result = ""
    try {
        result = exec("awk -F'\"' '/\"grade\":\"EXACT\"/ || /\"grade\": \"EXACT\"/{dom=\"\"; val=0; for(i=1;i<=NF;i++){if($i==\"domain\") dom=$(i+2); if($i==\"value\"){v=$(i+1); gsub(/[^0-9.\\-]/,\"\",v); val=v+0}} if(dom!=\"\" && val>0) e[dom]+=val; c[dom]++} END{for(d in e) print d\"\\t\"e[d]\"\\t\"c[d]}' " + _log_path + " | sort -t'\t' -k2 -rn | head -60")
    } catch e {}
    return result
}

// 빈공간 도메인 탐지 (노드 적거나 EXACT 비율 낮은 도메인)
fn find_void_domains() -> string {
    let mut result = ""
    try {
        // discovery_graph에서 도메인별 노드 수 집계
        result = exec("awk -F'\"' '/\"type\": \"node\"/{for(i=1;i<=NF;i++){if($i==\"domain\"){d=$(i+2); c[d]++}}} END{for(d in c) if(c[d]<20) print d\"\\t\"c[d]}' " + _graph_path + " | sort -t'\t' -k2 -n")
    } catch e {}
    return result
}

// ═══════════════════════════════════════════════════════════
// n=6 공명 검사: 값이 n=6 배수에 가까운지
// ═══════════════════════════════════════════════════════════

fn nearest_resonance(value: f64) -> string {
    // 가장 가까운 n=6 배수 찾기
    let mut best_name = ""
    let mut best_dist: f64 = 999999.0
    let mut best_val: i64 = 0

    let mut ri: i64 = 0
    while ri < len(resonance_multiples) {
        let rm: i64 = resonance_multiples[ri]
        let rn: string = resonance_names[ri]
        let dist = abs_f(value - to_float(rm))
        if dist < best_dist {
            best_dist = dist
            best_name = rn
            best_val = rm
        }
        // 정수 배수 체크
        if value > 0.0 {
            let ratio = value / to_float(rm)
            let rounded = to_float(to_int(ratio + 0.5))
            let rdist = abs_f(ratio - rounded)
            if rdist < 0.01 && rdist < best_dist {
                best_dist = rdist
                best_name = to_string(to_int(rounded)) + "*" + rn
                best_val = rm * to_int(rounded)
            }
        }
        ri = ri + 1
    }
    return best_name + "(" + to_string(best_val) + "):d=" + to_string(to_int(best_dist * 100.0) / 100)
}

fn is_n6_resonant(value: f64) -> bool {
    // 값이 n=6 배수의 정수배에 1% 이내면 공명
    let mut ri: i64 = 0
    while ri < len(resonance_multiples) {
        let rm: i64 = resonance_multiples[ri]
        if to_float(rm) > 0.0 {
            let ratio = value / to_float(rm)
            let rounded = to_float(to_int(ratio + 0.5))
            let diff = abs_f(ratio - rounded)
            if diff < 0.01 && rounded > 0.0 { return true }
        }
        ri = ri + 1
    }
    return false
}

// ═══════════════════════════════════════════════════════════
// 1. scan — 소나/파동 이벤트 요약
// ═══════════════════════════════════════════════════════════

fn cmd_scan() {
    println("")
    println("╔══════════════════════════════════════════════════╗")
    println("║  공명 지도 — 소나/파동 이벤트 스캔              ║")
    println("╚══════════════════════════════════════════════════╝")
    println("")

    let raw = extract_wave_events()
    let lines = raw.split("\n")

    let mut type_counts = []
    let mut type_names = []
    let mut total: i64 = 0

    for line in lines {
        let lt = line.trim()
        if lt == "" { continue }
        total = total + 1

        // type 추출
        let mut etype = ""
        try {
            let parts = lt.split("\"type\":\"")
            if len(parts) >= 2 {
                let rest = parts[1]
                let ep = rest.split("\"")
                if len(ep) >= 1 { etype = ep[0] }
            }
        } catch e {}
        if etype == "" {
            try {
                let parts2 = lt.split("\"type\": \"")
                if len(parts2) >= 2 {
                    let rest2 = parts2[1]
                    let ep2 = rest2.split("\"")
                    if len(ep2) >= 1 { etype = ep2[0] }
                }
            } catch e {}
        }

        if etype != "" {
            let mut found = false
            let mut fi: i64 = 0
            while fi < len(type_names) {
                if type_names[fi] == etype {
                    type_counts[fi] = type_counts[fi] + 1
                    found = true
                }
                fi = fi + 1
            }
            if !found {
                type_names = type_names + [etype]
                type_counts = type_counts + [1]
            }
        }
    }

    println("  파동/소나 이벤트 총: " + to_string(total) + "건")
    println("")
    println("  | 이벤트 유형 | 건수 |")
    println("  |------------|------|")
    let mut ti: i64 = 0
    while ti < len(type_names) {
        println("  | " + type_names[ti] + " | " + to_string(type_counts[ti]) + " |")
        ti = ti + 1
    }
    println("")
}

// ═══════════════════════════════════════════════════════════
// 2. pairs — 도메인 쌍별 에너지 간섭 패턴
// ═══════════════════════════════════════════════════════════

fn cmd_pairs() {
    println("")
    println("╔══════════════════════════════════════════════════╗")
    println("║  공명 지도 — 도메인 쌍별 간섭 패턴             ║")
    println("╚══════════════════════════════════════════════════╝")
    println("")

    let raw = domain_energy_map()
    let lines = raw.split("\n")

    let mut domains = []
    let mut energies = []
    let mut counts = []

    for line in lines {
        let lt = line.trim()
        if lt == "" { continue }
        let parts = lt.split("\t")
        if len(parts) < 3 { continue }
        let dom = parts[0]
        let eng = safe_float(parts[1])
        let cnt = safe_int(parts[2])
        if dom != "" && eng > 0.0 {
            domains = domains + [dom]
            energies = energies + [eng]
            counts = counts + [cnt]
        }
    }

    println("  도메인 " + to_string(len(domains)) + "개 에너지 로드 완료")
    println("")

    // 상위 20개 도메인 간 쌍별 간섭 계산
    let limit = if len(domains) > 20 { 20 } else { len(domains) }
    let mut resonant_pairs = []
    let mut resonant_info = []
    let mut pair_count: i64 = 0

    println("  | 도메인 A | 도메인 B | 합 | 차 | 비율 | 공명 |")
    println("  |---------|---------|-----|-----|------|------|")

    let mut ai: i64 = 0
    while ai < limit {
        let mut bi: i64 = ai + 1
        while bi < limit {
            let ea: f64 = energies[ai]
            let eb: f64 = energies[bi]
            let sum_e = ea + eb
            let diff_e = abs_f(ea - eb)
            let ratio_e = if eb > 0.0 { ea / eb } else { 0.0 }

            // 합, 차, 비율 중 하나라도 n=6 공명이면 표시
            let sum_res = is_n6_resonant(sum_e)
            let diff_res = is_n6_resonant(diff_e)
            let ratio_res = is_n6_resonant(ratio_e * to_float(N6))

            let is_resonant = sum_res || diff_res || ratio_res
            let grade = if is_resonant { "공명" } else { "-" }

            if is_resonant || pair_count < 30 {
                println("  | " + domains[ai] + " | " + domains[bi] + " | " + to_string(to_int(sum_e)) + " | " + to_string(to_int(diff_e)) + " | " + to_string(to_int(ratio_e * 100.0) / 100) + " | " + grade + " |")
            }

            if is_resonant {
                resonant_pairs = resonant_pairs + [domains[ai] + "+" + domains[bi]]
                let info = nearest_resonance(sum_e)
                resonant_info = resonant_info + [info]
            }
            pair_count = pair_count + 1
            bi = bi + 1
        }
        ai = ai + 1
    }

    println("")
    println("  총 쌍: " + to_string(pair_count) + ", 공명 쌍: " + to_string(len(resonant_pairs)))
    println("")
}

// ═══════════════════════════════════════════════════════════
// 3. resonance — n=6 배수 공명쌍 추출
// ═══════════════════════════════════════════════════════════

fn cmd_resonance() {
    println("")
    println("╔══════════════════════════════════════════════════╗")
    println("║  공명 지도 — n=6 공명쌍 추출                   ║")
    println("╚══════════════════════════════════════════════════╝")
    println("")

    let raw = domain_energy_map()
    let lines = raw.split("\n")

    let mut domains = []
    let mut energies = []

    for line in lines {
        let lt = line.trim()
        if lt == "" { continue }
        let parts = lt.split("\t")
        if len(parts) < 2 { continue }
        let dom = parts[0]
        let eng = safe_float(parts[1])
        if dom != "" && eng > 0.0 {
            domains = domains + [dom]
            energies = energies + [eng]
        }
    }

    let limit = if len(domains) > 30 { 30 } else { len(domains) }
    let mut res_count: i64 = 0

    println("  | # | 도메인 A | 도메인 B | 간섭 에너지 | 가장 가까운 공명 | 잔차 |")
    println("  |---|---------|---------|------------|-----------------|------|")

    let mut ai: i64 = 0
    while ai < limit {
        let mut bi: i64 = ai + 1
        while bi < limit {
            let ea: f64 = energies[ai]
            let eb: f64 = energies[bi]

            // 합, 차, 곱/6 모두 검사
            let candidates = [ea + eb, abs_f(ea - eb), (ea * eb) / to_float(N6)]
            let cand_labels = ["합", "차", "곱/n"]

            let mut ci: i64 = 0
            while ci < len(candidates) {
                let val: f64 = candidates[ci]
                let label: string = cand_labels[ci]

                // 가장 가까운 n=6 배수 찾기
                let mut ri: i64 = 0
                while ri < len(resonance_multiples) {
                    let rm: i64 = resonance_multiples[ri]
                    let rn: string = resonance_names[ri]
                    if to_float(rm) > 0.0 {
                        let ratio = val / to_float(rm)
                        let rounded = to_float(to_int(ratio + 0.5))
                        let residual = abs_f(ratio - rounded)
                        if residual < 0.005 && rounded > 0.0 && rounded < 1000.0 {
                            res_count = res_count + 1
                            println("  | " + to_string(res_count) + " | " + domains[ai] + " | " + domains[bi] + " | " + label + "=" + to_string(to_int(val)) + " | " + to_string(to_int(rounded)) + "*" + rn + "(" + to_string(rm) + ") | " + to_string(to_int(residual * 10000.0) / 10000) + " |")
                        }
                    }
                    ri = ri + 1
                }
                ci = ci + 1
            }
            bi = bi + 1
        }
        ai = ai + 1
    }

    println("")
    println("  n=6 공명쌍 총: " + to_string(res_count) + "건")
    println("")

    // growth_bus 기록
    try {
        let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
        let entry = "{\"type\":\"resonance_map\",\"mode\":\"resonance\",\"pairs\":" + to_string(res_count) + ",\"domains\":" + to_string(len(domains)) + ",\"ts\":\"" + ts + "\"}"
        exec("echo '" + entry + "' >> " + _bus_path)
    } catch e {}
}

// ═══════════════════════════════════════════════════════════
// 4. emerge — 빈공간 간섭 → 창발 도메인 후보
// ═══════════════════════════════════════════════════════════

fn cmd_emerge() {
    println("")
    println("╔══════════════════════════════════════════════════╗")
    println("║  공명 지도 — 창발 도메인 후보 탐지             ║")
    println("╚══════════════════════════════════════════════════╝")
    println("")

    // 빈공간 도메인 로드
    let void_raw = find_void_domains()
    let void_lines = void_raw.split("\n")

    let mut void_domains = []
    let mut void_counts = []

    for line in void_lines {
        let lt = line.trim()
        if lt == "" { continue }
        let parts = lt.split("\t")
        if len(parts) < 2 { continue }
        let dom = parts[0]
        let cnt = safe_int(parts[1])
        if dom != "" {
            void_domains = void_domains + [dom]
            void_counts = void_counts + [cnt]
        }
    }

    println("  빈공간 도메인 (노드 < 20): " + to_string(len(void_domains)) + "개")
    println("")

    if len(void_domains) == 0 {
        println("  빈공간 도메인 없음 — 모든 도메인 충분히 탐색됨")
        println("")
        return
    }

    // 에너지 맵 로드
    let energy_raw = domain_energy_map()
    let energy_lines = energy_raw.split("\n")

    let mut all_domains = []
    let mut all_energies = []

    for line in energy_lines {
        let lt = line.trim()
        if lt == "" { continue }
        let parts = lt.split("\t")
        if len(parts) < 2 { continue }
        all_domains = all_domains + [parts[0]]
        all_energies = all_energies + [safe_float(parts[1])]
    }

    // 빈공간 도메인 쌍의 간섭 패턴 → 창발 후보
    println("  | # | 빈공간 A | 빈공간 B | 간섭 에너지 | 공명 | 창발 후보 |")
    println("  |---|---------|---------|------------|------|---------|")

    let mut emerge_count: i64 = 0
    let limit = if len(void_domains) > 30 { 30 } else { len(void_domains) }

    let mut ai: i64 = 0
    while ai < limit {
        // 빈공간 도메인의 에너지 찾기
        let mut ea: f64 = to_float(void_counts[ai]) * to_float(N6)  // 노드 수 * n 을 에너지 근사값으로
        // 실제 에너지가 있으면 대체
        let mut ei: i64 = 0
        while ei < len(all_domains) {
            if all_domains[ei] == void_domains[ai] {
                ea = all_energies[ei]
            }
            ei = ei + 1
        }

        let mut bi: i64 = ai + 1
        while bi < limit {
            let mut eb: f64 = to_float(void_counts[bi]) * to_float(N6)
            let mut ej: i64 = 0
            while ej < len(all_domains) {
                if all_domains[ej] == void_domains[bi] {
                    eb = all_energies[ej]
                }
                ej = ej + 1
            }

            let interference = ea + eb
            let resonant = is_n6_resonant(interference)
            let grade = if resonant { "공명" } else { "-" }

            // 창발 후보: 공명 + 두 도메인 사이 교집합 이름 생성
            let mut candidate = ""
            if resonant {
                emerge_count = emerge_count + 1
                candidate = void_domains[ai] + "-x-" + void_domains[bi]
                let res_info = nearest_resonance(interference)
                println("  | " + to_string(emerge_count) + " | " + void_domains[ai] + " | " + void_domains[bi] + " | " + to_string(to_int(interference)) + " | " + res_info + " | " + candidate + " |")
            }
            bi = bi + 1
        }
        ai = ai + 1
    }

    println("")
    println("  창발 후보 총: " + to_string(emerge_count) + "건")
    println("")

    // 비공명 빈공간도 리스트
    println("  --- 미탐색 빈공간 (공명 대기) ---")
    println("")
    let mut vi: i64 = 0
    while vi < len(void_domains) && vi < 20 {
        println("    " + void_domains[vi] + " (노드 " + to_string(void_counts[vi]) + ")")
        vi = vi + 1
    }
    println("")

    // growth_bus 기록
    try {
        let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
        let entry = "{\"type\":\"resonance_map\",\"mode\":\"emerge\",\"void_domains\":" + to_string(len(void_domains)) + ",\"emerge_candidates\":" + to_string(emerge_count) + ",\"ts\":\"" + ts + "\"}"
        exec("echo '" + entry + "' >> " + _bus_path)
    } catch e {}
}

// ═══════════════════════════════════════════════════════════
// help
// ═══════════════════════════════════════════════════════════

fn cmd_help() {
    println("╔══════════════════════════════════════════════════╗")
    println("║  공명 지도 (Resonance Map)                     ║")
    println("║  소나 탐지 빈공간의 공명 주파수 분석            ║")
    println("╚══════════════════════════════════════════════════╝")
    println("")
    println("사용법:")
    println("  hexa resonance_map.hexa scan        소나/파동 이벤트 요약")
    println("  hexa resonance_map.hexa pairs       도메인 쌍별 에너지 간섭 패턴")
    println("  hexa resonance_map.hexa resonance   n=6 배수 공명쌍 추출")
    println("  hexa resonance_map.hexa emerge      빈공간 간섭 → 창발 도메인 후보")
    println("  hexa resonance_map.hexa help        이 도움말")
    println("")
    println("원리:")
    println("  - growth_bus.jsonl / discovery_log.jsonl에서 이벤트 로드")
    println("  - 도메인별 에너지 = EXACT 값 합산")
    println("  - 쌍별 간섭: 합, 차, 곱/n 계산")
    println("  - n=6 배수(6,12,24,36,48,72,120,720)에 가까우면 '공명'")
    println("  - 빈공간(노드<20) 간 공명 = 창발 후보")
    println("")
}

// ═══════════════════════════════════════════════════════════
// MAIN
// ═══════════════════════════════════════════════════════════

let argv = args()
let mode = if len(argv) >= 3 { argv[2] } else { "scan" }

if mode == "scan" || mode == "스캔" {
    cmd_scan()
} else if mode == "pairs" || mode == "쌍" {
    cmd_pairs()
} else if mode == "resonance" || mode == "공명" {
    cmd_resonance()
} else if mode == "emerge" || mode == "창발" {
    cmd_emerge()
} else if mode == "help" || mode == "도움말" {
    cmd_help()
} else {
    cmd_scan()
}

println("[verified] resonance_map.hexa 실행 완료")
println("")
