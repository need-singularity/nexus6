    entries = entries + [ScanEntry { lens_name: "relativistic_barrier", lens_category: "quantum", result: scan_relativistic_barrier(data) }]
    entries = entries + [ScanEntry { lens_name: "renormalization", lens_category: "quantum", result: scan_renormalization(data) }]
    entries = entries + [ScanEntry { lens_name: "resolution_tree", lens_category: "quantum", result: scan_resolution_tree(data) }]
    entries = entries + [ScanEntry { lens_name: "resource_competition", lens_category: "quantum", result: scan_resource_competition(data) }]
    entries = entries + [ScanEntry { lens_name: "robotics", lens_category: "quantum", result: scan_robotics(data) }]
    entries = entries + [ScanEntry { lens_name: "ruler", lens_category: "quantum", result: scan_ruler(data) }]
    entries = entries + [ScanEntry { lens_name: "running_coupling", lens_category: "quantum", result: scan_running_coupling(data) }]
    entries = entries + [ScanEntry { lens_name: "scalar_curvature", lens_category: "quantum", result: scan_scalar_curvature(data) }]
    entries = entries + [ScanEntry { lens_name: "scale", lens_category: "quantum", result: scan_scale(data) }]
    entries = entries + [ScanEntry { lens_name: "schur_functor", lens_category: "quantum", result: scan_schur_functor(data) }]
    entries = entries + [ScanEntry { lens_name: "simulation", lens_category: "quantum", result: scan_simulation(data) }]
    entries = entries + [ScanEntry { lens_name: "singularity_cycle", lens_category: "quantum", result: scan_singularity_cycle(data) }]
    entries = entries + [ScanEntry { lens_name: "singularity", lens_category: "quantum", result: scan_singularity(data) }]

    entries
