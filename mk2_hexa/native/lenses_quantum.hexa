    entries = entries + [ScanEntry { lens_name: "rademacher_complexity", lens_category: "quantum", result: scan_rademacher_complexity(data) }]
    entries = entries + [ScanEntry { lens_name: "rate_code", lens_category: "quantum", result: scan_rate_code(data) }]
    entries = entries + [ScanEntry { lens_name: "ratio", lens_category: "quantum", result: scan_ratio(data) }]
    entries = entries + [ScanEntry { lens_name: "reconnection", lens_category: "quantum", result: scan_reconnection(data) }]
    entries = entries + [ScanEntry { lens_name: "recursion", lens_category: "quantum", result: scan_recursion(data) }]
