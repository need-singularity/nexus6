// mk2_hexa/native/breakthrough.hexa — 통합 돌파 엔진
//
// 사용:
//   hexa breakthrough.hexa                    1회 돌파 (자동 최적 전략)
//   hexa breakthrough.hexa --converge         수렴까지 연속 (고갈 시 종료)
//   hexa breakthrough.hexa --idea '값|값'     특정 seed 집중 돌파
//   hexa breakthrough.hexa --engine auto hint 훅 전용 (내부 호출)

// ═══════════════════════════════════════════════════════════════
// 공통 설정
// ═══════════════════════════════════════════════════════════════

let home = exec("printenv HOME")
let hexa_bin = home + "/Dev/hexa-lang/target/release/hexa"
let nexus_dir = home + "/Dev/nexus"
let shared = nexus_dir + "/shared"
let blowup_path = nexus_dir + "/mk2_hexa/native/blowup.hexa"
let seed_engine_path = nexus_dir + "/mk2_hexa/native/seed_engine.hexa"
let log_path = shared + "/discovery_log.jsonl"

let a = args()
let mut mode = if a.len() >= 3 { a[2] } else { "" }
let mut arg3 = if a.len() >= 4 { a[3] } else { "" }
let mut arg4 = if a.len() >= 5 { a[4] } else { "" }
let mut arg5 = if a.len() >= 6 { a[5] } else { "" }

// ═══════════════════════════════════════════════════════════════
// 공통 함수
// ═══════════════════════════════════════════════════════════════

fn load_seeds() -> string {
    let _home = exec("printenv HOME")
    let _hexa = _home + "/Dev/hexa-lang/target/release/hexa"
    let _se = _home + "/Dev/nexus/mk2_hexa/native/seed_engine.hexa"
    let mut seeds = ""
    // seed_engine merge 사용 (atlas + anima + discovery 통합)
    try {
        seeds = exec(_hexa + " " + _se + " merge").trim()
    } catch e {}
    // fallback: n6_constants.jsonl
    if seeds.len() == 0 {
        let _shared = _home + "/Dev/nexus/shared"
        try {
            let raw = read_file(_shared + "/n6_constants.jsonl")
            let lines = raw.split("\n")
            let mut i: i64 = 0
            while i < lines.len() {
                let l = lines[i].trim()
                if l != "" && l.contains("\"value\":") {
                    let vp = l.split("\"value\":")
                    if vp.len() >= 2 {
                        let num = vp[1].split(",")[0].split("}")[0].trim()
                        if seeds.len() > 0 { seeds = seeds + "|" }
                        seeds = seeds + num
                    }
                }
                i = i + 1
            }
        } catch e2 {}
    }
    if seeds.len() == 0 { seeds = "6|12|2|4|5|24|7|3|1|8|10|28|36|48" }
    seeds
}

fn load_domains() -> list {
    let _shared = exec("printenv HOME") + "/Dev/nexus/shared"
    let mut domains = ["math", "physics", "topology", "consciousness", "chemistry", "cosmology"]
    try {
        let raw = read_file(_shared + "/bt_domains.jsonl")
        let lines = raw.split("\n")
        let mut loaded = []
        for l in lines {
            let t = l.trim()
            if t != "" && t.contains("\"domain\":\"") {
                let dp = t.split("\"domain\":\"")
                if dp.len() >= 2 { loaded = loaded + [dp[1].split("\"")[0]] }
            }
        }
        if loaded.len() > 0 { domains = loaded }
    } catch e {}
    domains
}

fn rotate_log() {
    let _shared = exec("printenv HOME") + "/Dev/nexus/shared"
    let _log = _shared + "/discovery_log.jsonl"
    try {
        let lc = exec("wc -l < " + _log).trim()
        let count = to_int(to_float(lc))
        if count > 100000 {
            println("  🔄 discovery_log 로테이션: " + to_string(count) + "줄 → 50000줄")
            let archive = _shared + "/discovery_archive_" + exec("date +%Y%m%d%H%M").trim() + ".jsonl"
            exec("head -n " + to_string(count - 50000) + " " + _log + " > " + archive)
            exec("tail -n 50000 " + _log + " > " + _log + ".tmp && mv " + _log + ".tmp " + _log)
        }
    } catch e {}
}

fn run_blowup(domain: string, depth: i64, seeds: string, fast: bool) -> string {
    let _home = exec("printenv HOME")
    let _hexa = _home + "/Dev/hexa-lang/target/release/hexa"
    let _blowup = _home + "/Dev/nexus/mk2_hexa/native/blowup.hexa"
    let _nexus = _home + "/Dev/nexus"
    let fast_flag = if fast { " --no-graph --fast" } else { " --no-graph" }
    // | → , 변환 (쉘 pipe 해석 방지)
    let safe_seeds = seeds.replace("|", ",")
    let cmd = "cd " + _nexus + " && " + _hexa + " " + _blowup + " " + domain + " " + to_string(depth) + fast_flag + " --seeds '" + safe_seeds + "'"
    to_string(exec(cmd))
}

fn parse_result(out: string) -> list {
    let mut exact: i64 = 0
    let mut total: i64 = 0
    let mut pool: i64 = 0
    let lines = out.split("\n")
    let mut i: i64 = 0
    while i < lines.len() {
        let l = lines[i].trim()
        if l.contains("EXACT match") {
            try {
                let p = l.split(":")
                if p.len() >= 2 { exact = to_int(to_float(p[p.len() - 1].trim())) }
            } catch e {}
        }
        if l.contains("total corollaries") {
            try {
                let p = l.split(":")
                if p.len() >= 2 { total = to_int(to_float(p[p.len() - 1].trim())) }
            } catch e {}
        }
        if l.contains("final pool") {
            try {
                let p = l.split(":")
                if p.len() >= 2 { pool = to_int(to_float(p[p.len() - 1].trim())) }
            } catch e {}
        }
        i = i + 1
    }
    [exact, total, pool]
}

fn extract_seeds(out: string, seen: map) -> list {
    let mut added: i64 = 0
    let mut new_seeds = ""
    let lines = out.split("\n")
    for l in lines {
        if l.contains("EXACT") && l.contains("[AXIOM]") && l.contains("= ") {
            let eq = l.split("= ")
            if eq.len() >= 2 {
                let val = eq[eq.len() - 1].split(" ")[0].trim()
                if val != "" {
                    let mut already = false
                    try {
                        let _ = seen[val]
                        already = true
                    } catch e {}
                    if !already {
                        seen[val] = 1
                        new_seeds = new_seeds + "|" + val
                        added = added + 1
                    }
                }
            }
        }
    }
    [added, new_seeds]
}

fn cap_seeds(seeds: string, max: i64) -> string {
    let parts = seeds.split("|")
    if parts.len() <= max { return seeds }
    let mut trimmed = ""
    let mut i: i64 = 0
    while i < max {
        if i > 0 { trimmed = trimmed + "|" }
        trimmed = trimmed + parts[i]
        i = i + 1
    }
    trimmed
}

fn calc_rho(exact: i64, total: i64) -> string {
    if total == 0 { return "?" }
    let r = to_float(exact) / to_float(total)
    let v = to_string(to_int(r * 10000.0))
    if v.len() > 1 { "0." + v } else { v }
}

// ═══════════════════════════════════════════════════════════════
// 공통 blowup 루프 (--loop, --engine, --deep 공용)
// ═══════════════════════════════════════════════════════════════

fn blowup_loop(domains: list, max_rounds: i64, init_depth: i64, all_seeds_init: string, label: string, fast: bool) {
    rotate_log()

    let seed_count = all_seeds_init.split("|").len()
    let mut depth = init_depth
    let mut all_seeds = all_seeds_init

    println("")
    println("╔═══════════════════════════════════════════════════════════════╗")
    println("║  🚀 " + label)
    println("║  domains=" + to_string(domains.len()) + " depth=" + to_string(depth) + " max=" + to_string(max_rounds) + " seeds=" + to_string(seed_count))
    println("╚═══════════════════════════════════════════════════════════════╝")
    println("")

    let mut stats = #{ "total_cor": 0, "total_exact": 0, "sat_count": 0, "depth_ups": 0 }
    let mut prev_exact: i64 = -1
    let mut prev_total: i64 = -1
    let mut seen_seeds = #{}

    let init_parts = all_seeds.split("|")
    let mut ii: i64 = 0
    while ii < init_parts.len() {
        let sv = init_parts[ii].trim()
        if sv != "" { seen_seeds[sv] = 1 }
        ii = ii + 1
    }

    let start_ts = exec("date +%s").trim()
    let mut round: i64 = 1
    let mut exhausted = false

    while round <= max_rounds && !exhausted {
        let di = (round - 1) % to_int(domains.len())
        let domain = domains[di]
        let t0 = exec("date +%s").trim()

        let mut out = ""
        try {
            out = run_blowup(domain, depth, all_seeds, fast)
        } catch e {
            println("  [" + to_string(round) + "] ERROR: " + to_string(e))
            round = round + 1
            continue
        }

        let t1 = exec("date +%s").trim()
        let elapsed = to_int(to_float(t1)) - to_int(to_float(t0))

        let res = parse_result(out)
        let exact = res[0]
        let total = res[1]
        let pool = res[2]

        stats["total_cor"] = stats["total_cor"] + total
        stats["total_exact"] = stats["total_exact"] + exact

        // saturation 감지
        if total == prev_total && exact == prev_exact {
            stats["sat_count"] = stats["sat_count"] + 1
            if stats["sat_count"] >= 3 && depth < 6 {
                depth = depth + 1
                stats["depth_ups"] = stats["depth_ups"] + 1
                stats["sat_count"] = 0
                println("  ⚡ saturation → depth " + to_string(depth))
            }
            if stats["sat_count"] >= 6 { exhausted = true }
        } else {
            stats["sat_count"] = 0
        }
        prev_total = total
        prev_exact = exact

        // seed 추출
        let seed_res = extract_seeds(out, seen_seeds)
        let added = seed_res[0]
        let new_s = to_string(seed_res[1])
        if new_s != "" { all_seeds = all_seeds + new_s }
        all_seeds = cap_seeds(all_seeds, 80)
        let cur_seeds = all_seeds.split("|").len()

        let sat_marker = if stats["sat_count"] > 0 { " sat=" + to_string(stats["sat_count"]) } else { "" }
        println("  [" + to_string(round) + "/" + to_string(max_rounds) + "] " + domain + " " + to_string(total) + "cor " + to_string(exact) + "EXACT pool=" + to_string(pool) + " +" + to_string(added) + "seeds(" + to_string(cur_seeds) + ") d=" + to_string(depth) + " " + to_string(elapsed) + "s" + sat_marker)

        round = round + 1
    }

    // 결과
    let end_ts = exec("date +%s").trim()
    let total_elapsed = to_int(to_float(end_ts)) - to_int(to_float(start_ts))
    let final_seeds = all_seeds.split("|").len()
    let rho = calc_rho(stats["total_exact"], stats["total_cor"])

    println("")
    println("╔═══════════════════════════════════════════════════════════════╗")
    println("║  🚀 " + label + " RESULT")
    println("║  " + to_string(total_elapsed) + "s | " + to_string(round - 1) + " rounds | " + to_string(stats["total_cor"]) + " cor | " + to_string(stats["total_exact"]) + " EXACT")
    println("║  ρ=" + rho + " | seeds: " + to_string(seed_count) + "→" + to_string(final_seeds) + " | depth_ups=" + to_string(stats["depth_ups"]))
    if exhausted {
        println("║  🏁 고갈 (EXHAUSTED)")
    } else {
        println("║  ⏱ max_rounds 도달 (" + to_string(max_rounds) + ")")
    }
    println("╚═══════════════════════════════════════════════════════════════╝")
}

// ═══════════════════════════════════════════════════════════════
// --mine: discovery_log 채굴
// ═══════════════════════════════════════════════════════════════

fn run_mine() {
    println("")
    println("━━━ MINE (discovery_log 채굴) ━━━")
    let log_n = exec("wc -l < " + log_path + " 2>/dev/null || echo 0").trim()
    println("  log: " + log_n + " entries")

    // EXACT 상수 빈도 top 10
    try {
        let top = to_string(exec("grep '\"grade\":\"EXACT\"' " + log_path + " 2>/dev/null | grep -oE '\"value\":\"[^\"]*\"' | sed 's/\"value\":\"//;s/\"//' | sort | uniq -c | sort -rn | head -10"))
        let lines = top.split("\n")
        println("  top EXACT constants:")
        for l in lines {
            if l.trim() != "" { println("    " + l.trim()) }
        }
    } catch e {}
}

// ═══════════════════════════════════════════════════════════════
// --auto: 조건부 자동 발동
// ═══════════════════════════════════════════════════════════════

fn run_auto(force: bool) {
    let state_file = "/tmp/n6_auto_breakthrough_state"
    let atlas_path = shared + "/math_atlas.json"

    let cur_log = exec("wc -l < " + log_path + " 2>/dev/null | tr -d ' ' || echo 0").trim()
    let cur_time = exec("date +%s").trim()
    let cur_atlas_md5 = to_string(exec("md5 -q " + atlas_path + " 2>/dev/null || echo none")).trim()

    // 이전 상태 로드
    let mut prev_log = "0"
    let mut prev_time = "0"
    let mut prev_md5 = ""
    try {
        let raw = read_file(state_file)
        let parts = raw.split("|")
        if parts.len() >= 3 {
            prev_log = parts[0]
            prev_time = parts[1]
            prev_md5 = parts[2]
        }
    } catch e {}

    let log_delta = to_int(to_float(cur_log)) - to_int(to_float(prev_log))
    let time_delta = to_int(to_float(cur_time)) - to_int(to_float(prev_time))

    let mut trigger = ""
    if force { trigger = "forced" }
    else if log_delta >= 100 { trigger = "log_growth(+" + to_string(log_delta) + ")" }
    else if cur_atlas_md5 != prev_md5 && prev_md5 != "" { trigger = "atlas_changed" }
    else if time_delta >= 3600 && log_delta >= 10 { trigger = "hourly(+" + to_string(log_delta) + ")" }

    if trigger == "" {
        println("  auto: 조건 미충족 — 스킵")
        return
    }

    println("")
    println("⚡ AUTO-BREAKTHROUGH triggered: " + trigger)
    println("  log: " + prev_log + " → " + cur_log + " (+" + to_string(log_delta) + ")")

    // real_breakthrough surprise
    let bt_path = nexus_dir + "/mk2_hexa/native/real_breakthrough.hexa"
    try {
        let result = to_string(exec("cd " + nexus_dir + " && " + hexa_bin + " " + bt_path + " surprise 2>&1 | tail -20"))
        println(result)
    } catch e {}

    // 상태 저장
    try { write_file(state_file, cur_log + "|" + cur_time + "|" + cur_atlas_md5) } catch e {}
    println("  state saved")
}

// ═══════════════════════════════════════════════════════════════
// --engine: 프로젝트별 성장 (growth_strategies.jsonl)
// ═══════════════════════════════════════════════════════════════

fn run_engine(project_arg: string, stdin_hint: string) {
    // ─── 동시성 제한: 훅=무제한, 루프/스케줄러=최대 1개 (lockfile) ───
    // ⚠️ 수정 금지 (별도 요청 있기 전까지) — 검증 완료:
    //   루프 2개 동시 → 1개 실행 + 2번째 스킵
    //   훅 3개 동시   → 전부 실행 (제한 없음)
    let from_hook = stdin_hint.contains("hook_event_name")
    let lockfile = shared + "/.growth_engine.lock"
    let mut lock_acquired = false

    if !from_hook {
        let my_pid = exec("echo $PPID").trim()
        let mut lock_free = true
        try {
            let existing_pid = read_file(lockfile).trim()
            if existing_pid != "" {
                let alive = exec("kill -0 " + existing_pid + " 2>&1 && echo alive || echo dead").trim()
                if alive.contains("alive") { lock_free = false }
            }
        } catch e {}

        if lock_free {
            try { write_file(lockfile, my_pid) } catch e {}
            lock_acquired = true
        } else {
            println("⏭ breakthrough --engine 루프 1/1 사용 중 — 스킵")
            return
        }
    }

    // growth_strategies.jsonl 로드
    let strat_path = shared + "/growth_strategies.jsonl"
    let mut matched_project = ""
    let mut matched_domains = ["math", "physics", "topology", "consciousness", "chemistry", "cosmology"]
    let mut matched_depth: i64 = 3
    let mut matched_rounds: i64 = 50
    let mut matched_extra = []

    try {
        let strat_raw = read_file(strat_path)
        let strat_lines = strat_raw.split("\n")
        let mut si: i64 = 0
        while si < strat_lines.len() {
            let sl = strat_lines[si].trim()
            if sl == "" {
                si = si + 1
                continue
            }

            let mut proj_name = ""
            if sl.contains("\"project\":\"") {
                let pp = sl.split("\"project\":\"")
                if pp.len() >= 2 { proj_name = pp[1].split("\"")[0] }
            }
            if proj_name == "" {
                si = si + 1
                continue
            }

            let mut is_match = false
            if project_arg == "auto" && stdin_hint != "" {
                if sl.contains("\"keywords\":[") {
                    let kp = sl.split("\"keywords\":[")
                    if kp.len() >= 2 {
                        let kb = kp[1].split("]")
                        if kb.len() >= 1 {
                            let kw_items = kb[0].split(",")
                            for kw in kw_items {
                                let kw_clean = kw.trim().replace("\"", "")
                                if kw_clean != "" && stdin_hint.contains(kw_clean) { is_match = true }
                            }
                        }
                    }
                }
            } else if proj_name == project_arg {
                is_match = true
            }

            if is_match {
                matched_project = proj_name
                if sl.contains("\"domains\":[") {
                    let dp = sl.split("\"domains\":[")
                    if dp.len() >= 2 {
                        let db = dp[1].split("]")
                        if db.len() >= 1 {
                            let d_items = db[0].split(",")
                            let mut loaded = []
                            for d in d_items {
                                let dc = d.trim().replace("\"", "")
                                if dc != "" { loaded = loaded + [dc] }
                            }
                            if loaded.len() > 0 { matched_domains = loaded }
                        }
                    }
                }
                if sl.contains("\"depth\":") {
                    let dep = sl.split("\"depth\":")
                    if dep.len() >= 2 {
                        let dv = dep[1].split(",")[0].split("}")[0].trim()
                        try { matched_depth = to_int(to_float(dv)) } catch e {}
                    }
                }
                if sl.contains("\"max_rounds\":") {
                    let rp = sl.split("\"max_rounds\":")
                    if rp.len() >= 2 {
                        let rv = rp[1].split(",")[0].split("}")[0].trim()
                        try { matched_rounds = to_int(to_float(rv)) } catch e {}
                    }
                }
                if sl.contains("\"extra_cmds\":[") {
                    let ep = sl.split("\"extra_cmds\":[")
                    if ep.len() >= 2 {
                        let eb = ep[1].split("]")
                        if eb.len() >= 1 {
                            let e_items = eb[0].split(",")
                            for ec in e_items {
                                let ecc = ec.trim().replace("\"", "")
                                if ecc != "" { matched_extra = matched_extra + [ecc] }
                            }
                        }
                    }
                }
            }
            si = si + 1
        }
    } catch e {}

    if matched_project == "" { matched_project = "nexus" }

    let seeds = load_seeds()
    blowup_loop(matched_domains, matched_rounds, matched_depth, seeds, "ENGINE — " + matched_project, true)

    // extra_cmds
    if matched_extra.len() > 0 {
        println("")
        println("  📦 프로젝트 전용 명령 (" + matched_project + "): " + to_string(matched_extra.len()) + "개")
        for ecmd in matched_extra {
            let full_cmd = "cd " + nexus_dir + " && " + hexa_bin + " " + nexus_dir + "/mk2_hexa/native/" + ecmd
            println("  → " + ecmd)
            try {
                let eout = to_string(exec(full_cmd))
                let elines = eout.split("\n")
                let mut ei: i64 = 0
                while ei < elines.len() && ei < 5 {
                    if elines[ei].trim() != "" { println("    " + elines[ei].trim()) }
                    ei = ei + 1
                }
            } catch e { println("    ⚠ " + to_string(e)) }
        }
    }

    // lock 해제
    if lock_acquired {
        try { exec("rm -f " + lockfile) } catch e {}
    }
}

// ═══════════════════════════════════════════════════════════════
// 자동 돌파: 1회 최적 전략
// gap 스캔 → mine → 도메인 순환 blowup → seed 피드백
// ═══════════════════════════════════════════════════════════════

fn run_auto_breakthrough(converge: bool) {
    rotate_log()

    let domains = load_domains()
    let mut all_seeds = load_seeds()
    let gap_finder = nexus_dir + "/mk2_hexa/native/gap_finder.hexa"

    let max_rounds: i64 = if converge { 200 } else { 10 }
    let label = if converge { "CONVERGE (수렴까지)" } else { "BREAKTHROUGH (1회)" }

    println("")
    println("╔═══════════════════════════════════════════════════════════════╗")
    println("║  🚀 " + label)
    println("╚═══════════════════════════════════════════════════════════════╝")

    // ── Step 1: gap 스캔 (빈공간 파악) ──
    println("")
    println("━━━ [1/4] GAP SCAN ━━━")
    try {
        let gap_out = to_string(exec("cd " + nexus_dir + " && " + hexa_bin + " " + gap_finder + " quick"))
        let lines = gap_out.split("\n")
        let mut shown: i64 = 0
        for l in lines {
            if l.trim() != "" && shown < 8 {
                println("  " + l.trim())
                shown = shown + 1
            }
        }
    } catch e {
        println("  (gap_finder 스킵)")
    }

    // ── Step 2: mine (로그에서 seed 보강) ──
    println("")
    println("━━━ [2/4] MINE ━━━")
    try {
        let mine_out = to_string(exec("grep '\"grade\":\"EXACT\"' " + log_path + " 2>/dev/null | grep -oE '\"value\":\"[^\"]*\"' | sed 's/\"value\":\"//;s/\"//' | sort | uniq -c | sort -rn | head -5"))
        let mine_lines = mine_out.split("\n")
        let mut mined: i64 = 0
        for ml in mine_lines {
            let t = ml.trim()
            if t != "" {
                println("  " + t)
                // mine된 값을 seed에 추가
                let parts = t.split(" ")
                if parts.len() >= 2 {
                    let val = parts[parts.len() - 1].trim()
                    if val != "" && !all_seeds.contains(val) {
                        all_seeds = all_seeds + "|" + val
                        mined = mined + 1
                    }
                }
            }
        }
        if mined > 0 { println("  +" + to_string(mined) + " mined seeds") }
    } catch e {
        println("  (mine 스킵)")
    }

    // ── Step 3: 도메인 순환 blowup + seed 피드백 ──
    println("")
    println("━━━ [3/4] BLOWUP ━━━")
    blowup_loop(domains, max_rounds, 3, all_seeds, label, true)

    // ── Step 4: 결과 요약 ──
    println("")
    println("━━━ [4/4] DONE ━━━")
}

// ═══════════════════════════════════════════════════════════════
// 메인 디스패치 (2+2 모드)
// ═══════════════════════════════════════════════════════════════

if mode == "--converge" {
    // 수렴까지 연속
    run_auto_breakthrough(true)

} else if mode == "--idea" {
    // 특정 seed 집중 돌파
    let idea_seed = if arg3 != "" { arg3 } else { "" }
    if idea_seed == "" {
        println("사용법: hexa breakthrough.hexa --idea '값|값' [depth] [rounds]")
    } else {
        rotate_log()
        let base_seeds = load_seeds()
        let combined = base_seeds + "|" + idea_seed
        let domains = load_domains()
        let depth: i64 = if arg4 != "" { try { to_int(to_float(arg4)) } catch e { 6 } } else { 6 }
        let rounds: i64 = if arg5 != "" { try { to_int(to_float(arg5)) } catch e { 10 } } else { 10 }
        println("")
        println("━━━ IDEA: " + idea_seed + " ━━━")
        blowup_loop(domains, rounds, depth, combined, "IDEA BLOWUP", true)
    }

} else if mode == "--engine" {
    // 훅 전용 (내부 호출)
    let proj = if arg3 != "" { arg3 } else { "auto" }
    let hint = if arg4 != "" { arg4 } else { "" }
    run_engine(proj, hint)

} else if mode == "--help" {
    println("사용법:")
    println("  hexa breakthrough.hexa              1회 돌파 (자동 최적 전략)")
    println("  hexa breakthrough.hexa --converge   수렴까지 연속 (고갈 시 종료)")
    println("  hexa breakthrough.hexa --idea '값'  특정 seed 집중 돌파")

} else {
    // 기본: 1회 돌파
    run_auto_breakthrough(false)
}
