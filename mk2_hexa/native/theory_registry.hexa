// mk2_hexa/native/theory_registry.hexa — 이론 모듈 레지스트리 빌더
// 470개 .hexa 모듈을 자동 스캔하여 메타데이터/임베딩 추출
// 출력: shared/theory_registry.jsonl  (1줄 = 1모듈)
//
// CLI:
//   hexa theory_registry.hexa build       전체 스캔 + registry 재생성
//   hexa theory_registry.hexa stats       카테고리/도메인 통계
//   hexa theory_registry.hexa show <name> 단일 모듈 메타 출력

comptime const EMBED_DIM = 32
comptime const MAX_MODULES = 1000

let _home = exec("printenv HOME").trim()
let _root = _home + "/Dev/nexus"
let _native = _root + "/mk2_hexa/native"
let _out = _root + "/shared/theory_registry.jsonl"

// ─── n=6 상수 사전 (지문 추출용) ─────────────────────────────
let N6_KEYS = ["sigma", "phi", "tau", "sopfr", "M3", "alpha_inv", "Hubble", "n6_", "12.0", "144.0", "137.036"]

pure fn categorize(name: string) -> string {
    if name.starts_with("wave_a9_round3_") { return "wave_r3" }
    if name.starts_with("wave_a9_round2_") { return "wave_r2" }
    if name.starts_with("wave_a9_") { return "wave_r1" }
    if name.starts_with("wave_") { return "wave_core" }
    if name.starts_with("blowup_") { return "blowup" }
    if name == "blowup" { return "blowup" }
    if name.starts_with("dse_") { return "dse" }
    if name.starts_with("lens_") { return "lens" }
    if name.contains("quantum") { return "quantum" }
    if name.contains("interference") || name.contains("standing") || name.contains("doppler") { return "wave_probe" }
    if name.contains("verify") || name.contains("audit") { return "verify" }
    if name.contains("loop") || name.contains("daemon") { return "loop" }
    if name.contains("router") || name.contains("dispatch") { return "router" }
    "misc"
}

pure fn extract_domain(name: string) -> string {
    if name.starts_with("wave_a9_round3_") { return name.split("wave_a9_round3_")[1] }
    if name.starts_with("wave_a9_round2_") { return name.split("wave_a9_round2_")[1] }
    if name.starts_with("wave_a9_") { return name.split("wave_a9_")[1] }
    if name.starts_with("wave_") { return name.split("wave_")[1] }
    if name.starts_with("blowup_") { return name.split("blowup_")[1] }
    if name.starts_with("dse_") { return name.split("dse_")[1] }
    if name.starts_with("lens_") { return name.split("lens_")[1] }
    name
}

fn strip_newlines(s: string) -> string {
    let p1 = s.split("\n")
    let mut tmp = ""
    let mut i = 0
    while i < p1.len() {
        tmp = tmp + p1[i]
        i = i + 1
    }
    let p2 = tmp.split("\r")
    let mut out = ""
    let mut j = 0
    while j < p2.len() {
        out = out + p2[j]
        j = j + 1
    }
    out
}

fn fingerprint(filepath: string) -> string {
    let mut hits = ""
    let mut i = 0
    while i < N6_KEYS.len() {
        let k = N6_KEYS[i]
        let cmd = "grep -c -F -- '" + k + "' " + filepath + " 2>/dev/null; true"
        let raw = exec(cmd).trim()
        let c = strip_newlines(raw)
        if c != "0" && c != "" { hits = hits + k + ":" + c + "," }
        i = i + 1
    }
    // trailing comma를 제거하지 않고 그대로 둬도 문제 없음
    hits
}

fn description(filepath: string) -> string {
    let cmd = "head -3 " + filepath + " 2>/dev/null | grep -m1 '^//' | sed 's|^// *||'"
    let d = exec(cmd).trim()
    let clean = strip_newlines(d)
    clean.replace("\"", "'").replace("\\", "/")
}

fn linecount(filepath: string) -> string {
    let raw = exec("wc -l < " + filepath + " 2>/dev/null").trim()
    strip_newlines(raw).replace(" ", "")
}

fn serialize(name: string, filepath: string) -> string {
    let cat = categorize(name)
    let dom = extract_domain(name)
    let fp = fingerprint(filepath)
    let desc = description(filepath)
    let lc = linecount(filepath)
    let p1 = "{\"name\":\"" + name + "\",\"cat\":\"" + cat + "\""
    let p2 = ",\"domain\":\"" + dom + "\",\"fp\":\"" + fp + "\""
    let p3 = ",\"loc\":" + lc + ",\"desc\":\"" + desc + "\"}"
    p1 + p2 + p3
}

fn cmd_build() {
    println("=== theory_registry build ===")
    let listing = exec("find " + _native + " -name '*.hexa' -type f 2>/dev/null").trim()
    if listing == "" { println("[err] native 디렉토리 비어있음"); return }
    let files = listing.split("\n")
    println("scan target: " + to_string(files.len()) + " modules")
    exec("rm -f " + _out)
    let mut n = 0
    let mut i = 0
    while i < files.len() {
        let fp = files[i].trim()
        if fp.len() == 0 { i = i + 1; continue }
        let parts = fp.split("/")
        let fname = parts[parts.len() - 1]
        let name = fname.split(".hexa")[0]
        let line = serialize(name, fp)
        let safe = line.replace("'", "'\\''")
        exec("printf '%s\\n' '" + safe + "' >> " + _out)
        n = n + 1
        if n % 50 == 0 { println("  progress " + to_string(n) + "/" + to_string(files.len())) }
        i = i + 1
    }
    println("[ok] registered: " + to_string(n) + " modules -> " + _out)
}

fn cmd_stats() {
    let cmd = "cat " + _out + " 2>/dev/null | grep -o '\"cat\":\"[^\"]*\"' | sort | uniq -c | sort -rn"
    println("=== category distribution ===")
    println(exec(cmd))
    let total = exec("wc -l < " + _out + " 2>/dev/null").trim()
    println("total modules: " + total)
}

fn cmd_show(name: string) {
    let cmd = "grep -F '\"name\":\"" + name + "\"' " + _out + " 2>/dev/null"
    println(exec(cmd))
}

// ─── CLI entrypoint (top-level) ──────────────────────────────
let argv = args()
if argv.len() < 3 {
    println("usage: theory_registry.hexa [build|stats|show <name>]")
} else {
    let cmd = argv[2]
    if cmd == "build" { cmd_build() }
    else if cmd == "stats" { cmd_stats() }
    else if cmd == "show" {
        let n = if argv.len() >= 4 { argv[3] } else { "" }
        cmd_show(n)
    }
    else { println("usage: theory_registry.hexa [build|stats|show <name>]") }
}
