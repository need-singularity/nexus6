// mk2_hexa/native/compass.hexa
// 포팅 원본: tecs-l/compass.py (788 LOC)
// 범위: 핵심 3모델 (Our/Cusp/Boltzmann) + compass_direction 합성.
// 제외: scipy argrelextrema, numpy linspace/RNG → Python shell-out 또는 수치 근사
// Pitfalls: exp 부재 → pow(E,x), log → python shell-out, 모든 배열 param = any

let E_CONST = 2.718281828459045

fn expf(x: float) -> float { return pow(E_CONST, x) }

fn lnf(x: float) -> float {
    let mut s = "0"
    try { s = exec("python3 -c \"import math; print(math.log(" + to_string(x) + "))\"").trim() } catch e { s = "0" }
    return to_float(s)
}

fn fabs(x: float) -> float { if x < 0.0 { return 0.0 - x } return x }
fn fmax(a: float, b: float) -> float { if a > b { return a } return b }
fn fmin(a: float, b: float) -> float { if a < b { return a } return b }
fn clamp(x: float, lo: float, hi: float) -> float { return fmin(fmax(x, lo), hi) }

// ─── Model 1: Our Model — "How much?" ───
fn genius_score(d: float, p: float, i: float) -> float {
    return d * p / i
}

// 단순 z-score: pop_mean/std는 대표값 (d=0.286, p=0.714, i=0.714 → m≈0.286)
// 정밀 RNG는 python shell-out로 위임 가능
fn population_zscore(score: float) -> float {
    let mean = 0.40
    let std = 0.55
    return (score - mean) / std
}

// ─── Model 2: Cusp Catastrophe — "When?" ───
// cusp_analysis → Map 반환
fn cusp_analysis(deficit: float, inhibition: float) -> any {
    let a = 2.0 * deficit - 1.0
    let b = 1.0 - 2.0 * inhibition

    // 분기 판별식: 8a³ + 27b²
    let bifurcation = 8.0 * a * a * a + 27.0 * b * b
    let cusp_disc = fabs(bifurcation)
    let max_possible = 8.0 + 27.0   // 최대값
    let distance_to_critical = cusp_disc / max_possible

    let mut direction = "Downward (Functional decline)"
    let mut direction_sign = 0.0 - 1.0
    if b > 0.0 {
        direction = "Upward (Compensatory genius)"
        direction_sign = 1.0
    }

    // 평형점 개수: dV/dx = 4x³ + 2ax + b = 0 부호변화 카운트
    // 구간 [-2,2], 200샘플로 근사
    let steps = 200
    let mut prev_sign = 0
    let mut n_equilibria = 0
    let mut k = 0
    while k <= steps {
        let x = -2.0 + 4.0 * (to_float(k) / to_float(steps))
        let dv = 4.0 * x * x * x + 2.0 * a * x + b
        let mut sg = 0
        if dv > 0.0 { sg = 1 }
        if dv < 0.0 { sg = 0 - 1 }
        if k > 0 && sg != 0 && prev_sign != 0 && sg != prev_sign {
            n_equilibria = n_equilibria + 1
        }
        if sg != 0 { prev_sign = sg }
        k = k + 1
    }
    let is_bistable = n_equilibria >= 2

    return #{
        "a": a,
        "b": b,
        "bifurcation": bifurcation,
        "distance_to_critical": distance_to_critical,
        "direction": direction,
        "direction_sign": direction_sign,
        "n_equilibria": n_equilibria,
        "is_bistable": is_bistable
    }
}

// ─── Model 3: Boltzmann — "Where to?" ───
fn boltzmann_analysis(deficit: float, plasticity: float, inhibition: float) -> any {
    let temperature = 1.0 / fmax(inhibition, 0.01)

    let e_normal = 0.0
    let e_genius = 0.0 - (deficit * plasticity)
    let e_decline = deficit * (1.0 - plasticity)

    let t0 = expf(0.0 - e_normal / temperature)
    let t1 = expf(0.0 - e_genius / temperature)
    let t2 = expf(0.0 - e_decline / temperature)
    let Z = t0 + t1 + t2
    let p_normal = t0 / Z
    let p_genius = t1 / Z
    let p_decline = t2 / Z

    let free_energy = 0.0 - temperature * lnf(Z)

    let eps = 0.0000000001
    let s0 = p_normal * lnf(p_normal + eps)
    let s1 = p_genius * lnf(p_genius + eps)
    let s2 = p_decline * lnf(p_decline + eps)
    let entropy = 0.0 - (s0 + s1 + s2)

    return #{
        "temperature": temperature,
        "p_normal": p_normal,
        "p_genius": p_genius,
        "p_decline": p_decline,
        "free_energy": free_energy,
        "entropy": entropy
    }
}

// ─── Compass: 3모델 합성 ───
fn compass_direction(z: float, cusp: any, boltz: any) -> any {
    let mut recs = []
    let mut warns = []

    // Dropout
    if z > 5.0 {
        recs = recs + ["Dropout: Maintain — Extreme singularity (★★★)"]
    } else {
        if z > 2.0 {
            recs = recs + ["Dropout: Slight increase (★★☆)"]
        } else {
            recs = recs + ["Dropout: Significant increase needed (★☆☆)"]
        }
    }

    // Temperature
    let pg = boltz["p_genius"]
    if pg > 0.6 {
        recs = recs + ["Temperature: Maintain — Genius dominant (★★★)"]
    } else {
        if pg > 0.3 {
            recs = recs + ["Temperature: Slight increase (★★☆)"]
        } else {
            recs = recs + ["Temperature: Significant increase needed (★☆☆)"]
        }
    }

    // Structure
    let is_bi = cusp["is_bistable"]
    let ds = cusp["direction_sign"]
    let dc = cusp["distance_to_critical"]
    if is_bi {
        if ds > 0.0 {
            recs = recs + ["Structure: Bistable + upward — Performance jump (★★★)"]
        } else {
            warns = warns + ["Bistable + downward — Crash risk!"]
            recs = recs + ["Structure: Hold (☆☆☆)"]
        }
    } else {
        if dc < 0.3 {
            recs = recs + ["Structure: Near critical — small adjustments (★★☆)"]
        } else {
            recs = recs + ["Structure: Far from critical — gradual (★☆☆)"]
        }
    }

    // Phase (entropy)
    let en = boltz["entropy"]
    if en > 1.0 {
        recs = recs + ["Phase: Exploration (high entropy)"]
    } else {
        if en > 0.5 {
            recs = recs + ["Phase: Transition"]
        } else {
            recs = recs + ["Phase: Convergence (low entropy)"]
        }
    }

    // Expert ratio
    let active_ratio = clamp(pg, 0.05, 0.5)
    if active_ratio < 0.15 {
        recs = recs + ["MoE: Savant type — extreme focus"]
    } else {
        if active_ratio < 0.35 {
            recs = recs + ["MoE: Einstein type — moderate distribution"]
        } else {
            recs = recs + ["MoE: General purpose — broad activation"]
        }
    }

    // Composite score
    let cs_raw = z / 10.0 * 0.3 + (1.0 - dc) * 0.3 + pg * 0.4
    let compass_score = clamp(cs_raw, 0.0, 1.0)

    return #{
        "recommendations": recs,
        "warnings": warns,
        "compass_score": compass_score,
        "optimal_active_ratio": active_ratio
    }
}

fn draw_needle(compass_score: float, direction_sign: float) -> string {
    if compass_score > 0.7 {
        return "UP  SINGULARITY"
    }
    if compass_score > 0.4 {
        if direction_sign > 0.0 { return "NE  TRANSITION-UP" }
        return "SE  TRANSITION-DOWN"
    }
    return "--  STABLE"
}

// ─── 자가검증 ───
print("=== compass.hexa (port of compass.py core) ===")

let d = 0.8
let p = 0.9
let i = 0.3

let score = genius_score(d, p, i)
let z = population_zscore(score)
print("genius_score = " + to_string(score) + "  z = " + to_string(z))

let cusp = cusp_analysis(d, i)
print("cusp.bifurcation = " + to_string(cusp["bifurcation"]))
print("cusp.distance_to_critical = " + to_string(cusp["distance_to_critical"]))
print("cusp.n_equilibria = " + to_string(cusp["n_equilibria"]))
print("cusp.direction = " + cusp["direction"])

let boltz = boltzmann_analysis(d, p, i)
print("boltz.p_genius = " + to_string(boltz["p_genius"]))
print("boltz.entropy = " + to_string(boltz["entropy"]))

let comp = compass_direction(z, cusp, boltz)
print("compass_score = " + to_string(comp["compass_score"]))
print("optimal_active_ratio = " + to_string(comp["optimal_active_ratio"]))
print("needle = " + draw_needle(comp["compass_score"], cusp["direction_sign"]))

print("-- recommendations --")
let recs = comp["recommendations"]
let mut ri = 0
while ri < recs.len() { print("  * " + recs[ri])  ri = ri + 1 }

let warns = comp["warnings"]
if warns.len() > 0 {
    print("-- warnings --")
    let mut wi = 0
    while wi < warns.len() { print("  ! " + warns[wi])  wi = wi + 1 }
}

print("=== done ===")
