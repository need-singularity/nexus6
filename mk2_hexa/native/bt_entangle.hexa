    println("    hexa bt_entangle.hexa collapse    Trigger auto-proofs from proven BTs")
    println("    hexa bt_entangle.hexa bell        Run Bell inequality test on all pairs")
    println("    hexa bt_entangle.hexa help        This help message")
    println("")
    println("  ENTANGLEMENT CRITERIA:")
    println("    - Same constant value within tolerance " + to_string(TOLERANCE))
    println("    - Different domains (cross-domain only)")
    println("    - Bell inequality: correlation > " + to_string(BELL_THRESHOLD) + " (classical limit " + to_string(CLASSICAL_LIMIT) + ")")
    println("")
    println("  CASCADE:")
    println("    Auto-proven BTs may themselves be entangled with others,")
    println("    triggering chain reactions up to depth " + to_string(MAX_CASCADE_DEPTH) + ".")
    println("")
    println("  DATA SOURCES:")
    println("    - shared/n6/n6_constants.jsonl  (BTs with bt field)")
    println("    - shared/discovery/growth_bus.jsonl    (BT- entries from absorb/blowup)")
    println("")
    println("  THEOREM: bt_entanglement_transitivity")
    println("    If A<->B and B<->C are entangled, proving A cascades to C via B.")
    println("")
}

// ═══════════════════════════════════════════════════════════
// Main dispatch
// ═══════════════════════════════════════════════════════════

if mode == "help" || mode == "--help" || mode == "-h" {
    print_help()
} else if mode == "scan" {
    println("")
    println("  === EPR-BT: Entanglement Scan ===")
    println("")
    let bts = load_all_bts()
    let pairs = find_entangled_pairs(bts)
    let epr = build_epr_registry(pairs)
    print_scan_report(bts, pairs, epr)
    // Verify transitivity theorem
    println("")
    let _ok = verify_transitivity(bts, epr)
    // Log
    log_entangle_event("scan", "{\"bts\":" + to_string(bts.len()) + ",\"pairs\":" + to_string(pairs.len()) + ",\"epr\":" + to_string(epr.len()) + "}")
} else if mode == "collapse" {
    println("")
    println("  === EPR-BT: Auto-Collapse ===")
    println("")
    let bts = load_all_bts()
    let pairs = find_entangled_pairs(bts)
    let epr = build_epr_registry(pairs)
    let proven_map = find_proven_bts(bts)
    let collapses = attempt_collapse(epr, proven_map, bts)
    print_collapse_report(collapses)
    // Log collapses
    let mut ci: i64 = 0
    while ci < collapses.len() {
        let c = collapses[ci]
        log_entangle_event("collapse", "{\"source\":\"" + c["source_bt"] + "\",\"target\":\"" + c["target_bt"] + "\",\"value\":" + to_string(c["value"]) + ",\"depth\":" + to_string(c["cascade_depth"]) + "}")
        ci = ci + 1
    }
    // Also log to growth_bus
    let mut gi: i64 = 0
    while gi < collapses.len() {
        let c = collapses[gi]
        let bus_entry = "{\"type\":\"bt_entangle\",\"phase\":\"7.0\",\"id\":\"" + c["target_bt"] + "\",\"value\":" + to_string(c["value"]) + ",\"grade\":\"EXACT\",\"domain\":\"" + c["domain_to"] + "\",\"source\":\"epr-collapse:" + c["source_bt"] + "\",\"cascade_depth\":" + to_string(c["cascade_depth"]) + ",\"timestamp\":\"" + timestamp + "\"}"
        try {
            append_file(growth_bus_path, bus_entry + "\n")
        } catch e {}
        gi = gi + 1
    }
    if collapses.len() > 0 {
        println("")
        println("  Logged " + to_string(collapses.len()) + " collapses to growth_bus + bt_entangle_log")
    }
} else if mode == "bell" {
    println("")
    println("  === EPR-BT: Bell Inequality Test ===")
    println("")
    let bts = load_all_bts()
    let pairs = find_entangled_pairs(bts)
    let results = run_bell_test(pairs)
    // Log
    let mut genuine: i64 = 0
    for r in results {
        if r["verdict"] == "ENTANGLED" { genuine = genuine + 1 }
    }
    log_entangle_event("bell_test", "{\"total\":" + to_string(results.len()) + ",\"genuine\":" + to_string(genuine) + "}")
} else {
    println("  [ERROR] Unknown mode: " + mode)
    println("  Run: hexa bt_entangle.hexa help")
}
