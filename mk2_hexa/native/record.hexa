// mk2_hexa/native/record.hexa
// AlienIndexRecord — own/borrow/move 소유권 + invariants

use effects::Clock

// ═══ AlienIndex(d, r) ════════════════════════════════════════════

pub struct AlienIndex {
    d: int,    // 사이클 깊이
    r: int     // 검증 등급, 0..=10
}

invariant alien_index_bounds {
    forall ai: AlienIndex, ai.d >= 0 and 0 <= ai.r <= 10
}

pure fn alien_new(d: int, r: int) -> AlienIndex
    where d >= 0, 0 <= r <= 10
{
    AlienIndex { d: d, r: r }
}

pure fn can_promote(ai: borrow AlienIndex) -> bool {
    ai.r == 10
}

pure fn breakthrough(ai: borrow AlienIndex) -> option<AlienIndex>
    ensures result.is_some() <=> ai.r == 10
{
    match ai.r {
        10 => Some(alien_new(ai.d + 1, 0)),
        _  => None
    }
}

// ═══ HistoryEntry ════════════════════════════════════════════════

pub struct HistoryEntry {
    timestamp_unix: int,
    d: int,
    r: int,
    reason: string
}

// ═══ AlienIndexRecord — 소유 관계 명시 ═══════════════════════════

pub struct AlienIndexRecord {
    id: string,
    current: AlienIndex,
    history: own [HistoryEntry],              // record 가 소유
    promotion_candidate: bool,
    promoted_from: option<string>
}

invariant record_d_monotonic {
    // 히스토리 d 는 단조 비감소
    forall rec: AlienIndexRecord,
        forall i: int where 0 < i < len(rec.history),
            rec.history[i].d >= rec.history[i-1].d
}

invariant record_candidate_matches_r {
    forall rec: AlienIndexRecord,
        rec.promotion_candidate == (rec.current.r == 10)
}

// ═══ 생성자 (Clock effect 필요) ══════════════════════════════════

fn record_new(id: string, initial: AlienIndex) -> AlienIndexRecord
    with Clock
    ensures result.current == initial, len(result.history) == 1
{
    let now = Clock.now_unix()
    AlienIndexRecord {
        id: id,
        current: initial,
        history: [HistoryEntry {
            timestamp_unix: now,
            d: initial.d,
            r: initial.r,
            reason: "initial"
        }],
        promotion_candidate: initial.r == 10,
        promoted_from: None
    }
}

// ═══ update: d 단조 보장 ═════════════════════════════════════════

pub enum RecordError {
    DepthRegression { from: int, to: int }
}

fn record_update(rec: own AlienIndexRecord, next: AlienIndex, reason: string)
    -> result<AlienIndexRecord, RecordError>
    with Clock
    ensures result is Ok(r) => r.current.d >= rec.current.d
{
    if next.d < rec.current.d {
        return Err(RecordError::DepthRegression { from: rec.current.d, to: next.d })
    }
    let now = Clock.now_unix()
    let mut updated = move rec
    updated.history = updated.history.push(HistoryEntry {
        timestamp_unix: now, d: next.d, r: next.r, reason: reason
    })
    updated.current = next
    updated.promotion_candidate = (next.r == 10)
    Ok(updated)
}

// ═══ promote: 자기유사 승격 (d,10) → (d+1,0) ══════════════════════

fn record_promote(rec: own AlienIndexRecord)
    -> (own AlienIndexRecord, option<AlienIndexRecord>)
    with Clock
    ensures result.1.is_some() <=> rec.current.r == 10
{
    let child_ai = breakthrough(borrow rec.current)
    match child_ai {
        None => (move rec, None),
        Some(ai) => {
            let child_id = rec.id + "→d" + to_string(ai.d)
            let mut child = record_new(child_id, ai)
            child.promoted_from = Some(rec.id.clone())
            let mut parent = move rec
            parent.promotion_candidate = false
            (parent, Some(child))
        }
    }
}

// ═══ 정리 증명 ═════════════════════════════════════════════════════

theorem promote_preserves_parent {
    forall rec: AlienIndexRecord where rec.current.r == 10,
        let (parent, child) = record_promote(move rec)
        parent.current == rec.current
        and child.unwrap().current == alien_new(rec.current.d + 1, 0)
        and child.unwrap().promoted_from == Some(rec.id)
}
