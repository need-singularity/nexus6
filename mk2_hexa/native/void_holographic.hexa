    println("")
    println("╔══════════════════════════════════════════════════════════════╗")
    println("║  VOID v3 — Holographic UI Engine                           ║")
    println("║  Version: " + VERSION + "    n=6 AdS/CFT Architecture           ║")
    println("╠══════════════════════════════════════════════════════════════╣")
    println("║                                                              ║")
    println("║  Commands:                                                   ║")
    println("║    dashboard     n=6 대시보드 (6 panels × 6 metrics)        ║")
    println("║    infer <text>  부분 입력 → 의도 추론 (AdS/CFT)            ║")
    println("║    compress      시스템 → 6 핵심 메트릭 압축                ║")
    println("║    reconstruct   경계 측정 → 벌크 상태 복원                 ║")
    println("║    help          이 도움말                                   ║")
    println("║                                                              ║")
    println("║  Holographic Principle:                                      ║")
    println("║    6 boundary measurements encode the entire system state.  ║")
    println("║    Any 6 surface observables → full interior reconstruction.║")
    println("║    Dashboard shows 6 panels × 6 metrics = 36 bulk values   ║")
    println("║    derived from just 6 boundary readings. n=6 everywhere.  ║")
    println("║                                                              ║")
    println("╚══════════════════════════════════════════════════════════════╝")
    println("")
}

// ═══════════════════════════════════════════════════════════
// main 엔트리
// ═══════════════════════════════════════════════════════════

fn main() -> void {
    let argv = args()
    let argc = argv.len()

    if argc < 3 {
        cmd_help()
        return
    }

    let cmd = argv[2]

    if cmd == "dashboard" { cmd_dashboard() }
    else if cmd == "infer" {
        if argc < 4 {
            println("[ERROR] 사용법: hexa void_holographic.hexa infer <partial_input>")
            return
        }
        let partial = argv[3]
        cmd_infer(partial)
    }
    else if cmd == "compress" { cmd_compress() }
    else if cmd == "reconstruct" { cmd_reconstruct() }
    else if cmd == "help" { cmd_help() }
    else {
        // 자동 추론 시도
        println("[VOID/Holographic] 알 수 없는 명령 '" + cmd + "' → 자동 추론...")
        cmd_infer(cmd)
    }
}

main()
