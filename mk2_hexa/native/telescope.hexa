    println("  Confirmed  — 12+ 렌즈 동의")
}

// ─── 검증 ───

assert consensus_level_name(3) == "Candidate"
assert consensus_level_name(7) == "High"
assert consensus_level_name(12) == "Confirmed"
assert consensus_level_name(2) == "None"
assert abs_f(sanitize(999999999.0) - LENS_OUTPUT_MAX) < 0.01
assert result_nonempty(result_add(empty_result(), "test", [1.0]))
assert !result_nonempty(empty_result())

println("")
println("=== telescope verified ===")

theorem telescope_consensus_monotonic {
    // 렌즈 수 증가 → 합의 수준 단조 증가
    assert consensus_level_name(3) == "Candidate"
    assert consensus_level_name(7) == "High"
    assert consensus_level_name(12) == "Confirmed"
}

proof telescope_invariants {
    invariant sanitize_bounded()
    invariant consensus_min_3()
}
