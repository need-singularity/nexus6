// Ported from tecs-l/n6-replication/tests/tier1/test_euler_product.py
// H092: Model = zeta Euler product at primes {2, 3}.
// zeta_{2,3}(1) = 1/((1-1/2)(1-1/3)) = 3
// sigma_{-1} product (1+1/2)(1+1/3) = 2
// Only {2,3} gives sigma_{-1} = 2.

// zeta_partial for primes 2,3:
// (1-1/2)(1-1/3) = (1/2)(2/3) = 2/6 = 1/3
// 1/(1/3) = 3
// scaled: num=1, den=3 -> inverse num=3, den=1
let zeta_num = 1 * 2  // numerators (1)(2)
let zeta_den = 2 * 3  // denominators (2)(3)
// zeta_den / zeta_num = 6/2 = 3
let zeta_check = zeta_den == 3 * zeta_num

// sigma_{-1}(p)=1+1/p. For p=2,3: (3/2)(4/3) = 12/6 = 2
// LCD rep: num = 3*4 = 12, den = 2*3 = 6 -> ratio 2
let sig_num_23 = 3 * 4
let sig_den_23 = 2 * 3
let sig_23_eq_2 = sig_num_23 == 2 * sig_den_23

// p=2 only: 1+1/2 = 3/2
let sig_num_2 = 3
let sig_den_2 = 2
let sig_2_eq_3half = sig_num_2 == 3 && sig_den_2 == 2

// p=2,3,5: (3/2)(4/3)(6/5) = 72/30 = 12/5 > 2
let sig_num_235 = 3 * 4 * 6  // 72
let sig_den_235 = 2 * 3 * 5  // 30
// 72/30 > 2 iff 72 > 60
let sig_235_gt2 = sig_num_235 > 2 * sig_den_235

// Other two-prime combos do not equal 2:
// (2,5): (3/2)(6/5) = 18/10 = 9/5 != 2
// (2,7): (3/2)(8/7) = 24/14 != 2
// (3,5): (4/3)(6/5) = 24/15 != 2
// (3,7): (4/3)(8/7) = 32/21 != 2
// (5,7): (6/5)(8/7) = 48/35 != 2
let c25_n = 3 * 6
let c25_d = 2 * 5
let c27_n = 3 * 8
let c27_d = 2 * 7
let c35_n = 4 * 6
let c35_d = 3 * 5
let c37_n = 4 * 8
let c37_d = 3 * 7
let c57_n = 6 * 8
let c57_d = 5 * 7

let ne25 = c25_n != 2 * c25_d
let ne27 = c27_n != 2 * c27_d
let ne35 = c35_n != 2 * c35_d
let ne37 = c37_n != 2 * c37_d
let ne57 = c57_n != 2 * c57_d
let others_ne_2 = ne25 && ne27 && ne35 && ne37 && ne57

let ids = ["H092-01","H092-02","H092-03","H092-04","H092-05"]
let checks = [
    zeta_check,
    sig_23_eq_2,
    sig_2_eq_3half,
    sig_235_gt2,
    others_ne_2
]

println("======================================================================")
println("H092 Euler Product: zeta_{2,3}(1)=3, sigma_{-1} product=2 (unique at p=2,3)")
println("======================================================================")
println("(3/2)(4/3) = " + to_string(sig_num_23) + "/" + to_string(sig_den_23))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
