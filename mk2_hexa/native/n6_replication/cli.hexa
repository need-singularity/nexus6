// Ported from tecs-l/n6-replication/src/n6_replication/cli.py
// CLI dispatcher: run / fetch / report / list subcommands.
// Tier 2+3 orchestration delegates to runner.hexa (full port of runner.py,
// Round #7). run_all.hexa is DEPRECATED (kept for reference, superseded).

fn version() { return "0.1.0" }

fn n6rep_dir() {
    let home = env_var("HOME")
    return home + "/Dev/nexus/mk2_hexa/native/n6_replication"
}

fn hexa_bin() {
    let home = env_var("HOME")
    return home + "/Dev/hexa-lang/target/release/hexa"
}

fn print_help() {
    println("n6-replicate v" + version() + " — Independent replication of n=6 math")
    println("")
    println("Usage: hexa cli.hexa <command> [options]")
    println("")
    println("Commands:")
    println("  list [--tier N ...]       List registered verification scripts")
    println("  run  [--tier1] [--tier N ...] [--parallel N] [--gpu] [--verbose] [--save]")
    println("                             Run Tier 1/2/3 scripts (delegates to runner.hexa)")
    println("  fetch [--update]          Fetch Tier 3 external repos (delegates to fetcher.hexa)")
    println("  report [--format md]      Print latest result summary (delegates to reporter.hexa)")
    println("  version                   Show version")
    println("  help                      This message")
}

fn cmd_list(rest_args) {
    // Parse --tier N [N ...]
    let mut tiers = [2, 3]
    let mut i = 0
    while i < len(rest_args) {
        if rest_args[i] == "--tier" {
            tiers = []
            let mut j = i + 1
            while j < len(rest_args) {
                let a = rest_args[j]
                if a.starts_with("--") { break }
                tiers = tiers.push(to_int(a))
                j = j + 1
            }
            i = j
        } else {
            i = i + 1
        }
    }

    // Load tiers directly
    let home = env_var("HOME")
    let reg_dir = home + "/Dev/nexus/tecs-l/n6-replication/registry"
    let mut scripts = []
    let mut ti = 0
    while ti < len(tiers) {
        let path = reg_dir + "/tier" + to_string(tiers[ti]) + ".json"
        if file_exists(path) {
            let mut parsed = []
            try { parsed = json_parse(read_file(path)) } catch e {}
            let mut k = 0
            while k < len(parsed) {
                scripts = scripts.push(parsed[k])
                k = k + 1
            }
        }
        ti = ti + 1
    }

    if len(scripts) == 0 {
        println("No scripts registered for the requested tiers.")
        return 0
    }

    println("ID                                              Tier   GPU  Timeout")
    println("----------------------------------------------------------------------")
    let mut si = 0
    while si < len(scripts) {
        let s = scripts[si]
        let id = if has_key(s, "id") { to_string(s["id"]) } else { "?" }
        let tier = if has_key(s, "tier") { to_string(s["tier"]) } else { "?" }
        let gpu = if has_key(s, "requires_gpu") { if s["requires_gpu"] == true { "yes" } else { "" } } else { "" }
        let to_s = if has_key(s, "timeout") { to_string(s["timeout"]) } else { "" }
        println(id + "  " + tier + "  " + gpu + "  " + to_s)
        si = si + 1
    }
    println("")
    println("Total: " + to_string(len(scripts)) + " scripts")
    return 0
}

fn cmd_run(rest_args) {
    let mut pass_args = ""
    let mut i = 0
    while i < len(rest_args) {
        pass_args = pass_args + " " + rest_args[i]
        i = i + 1
    }
    let cmd = hexa_bin() + " " + n6rep_dir() + "/runner.hexa" + pass_args
    let mut out = ""
    try { out = to_string(exec(cmd)) } catch e {}
    println(out)
    return 0
}

fn cmd_fetch(rest_args) {
    // Not directly invoked (fetcher smoke test does not call fetch_all).
    // Delegate by running fetcher.hexa which will be extended when fetch is needed.
    println("fetch: delegating to fetcher.hexa (stub; update/fetch_all callable from fetcher module)")
    let cmd = hexa_bin() + " " + n6rep_dir() + "/fetcher.hexa"
    let mut out = ""
    try { out = to_string(exec(cmd)) } catch e {}
    println(out)
    return 0
}

fn cmd_report(rest_args) {
    let cmd = hexa_bin() + " " + n6rep_dir() + "/reporter.hexa"
    let mut out = ""
    try { out = to_string(exec(cmd)) } catch e {}
    println(out)
    return 0
}

// Main dispatch -----------------------------------------------------------
// args()[0]=hexa_bin args()[1]=script path; user args start at index 2
let raw_args = args()
let mut cli_args = []
let mut ri = 2
while ri < len(raw_args) {
    cli_args = cli_args.push(raw_args[ri])
    ri = ri + 1
}

if len(cli_args) == 0 {
    print_help()
    exit(0)
}

let cmd = cli_args[0]
let mut rest = []
let mut i = 1
while i < len(cli_args) {
    rest = rest.push(cli_args[i])
    i = i + 1
}

if cmd == "list" { exit(cmd_list(rest)) }
if cmd == "run" { exit(cmd_run(rest)) }
if cmd == "fetch" { exit(cmd_fetch(rest)) }
if cmd == "report" { exit(cmd_report(rest)) }
if cmd == "version" || cmd == "--version" { println("n6-replicate " + version()) exit(0) }
if cmd == "help" || cmd == "--help" || cmd == "-h" { print_help() exit(0) }

println("Unknown command: " + cmd)
print_help()
exit(1)
