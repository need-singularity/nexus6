// Ported from tecs-l/n6-replication/tests/tier1/test_uniqueness.py
// H098: Only n=6 has {2,3,n} Egyptian-fraction decomposition giving 1.
// Non-trivial proper-divisor reciprocal sum excluding 1.

// For n=6: proper divs excl 1 = {2,3}. 1/2 + 1/3 = 5/6. +1/6 = 1.
// All arithmetic over LCD.

// n=6 case: scaled by 6
// 1/2 + 1/3 = 3 + 2 = 5, den=6  -> 5/6
let n6_prop_num = 3 + 2
let n6_prop_den = 6
// +1/6 = 1
let n6_complete = (n6_prop_num + 1) == n6_prop_den

// 1/2 + 1/3 + 1/6 = 1 directly
let egyptian_ok = (3 + 2 + 1) == 6

// n=28: proper divs excl 1 = {2,4,7,14}. LCD=28: 14+7+4+2 = 27, +1 = 28 -> 28/28=1
let n28_prop_sum = 14 + 7 + 4 + 2
let n28_prop_ok = n28_prop_sum == 27
let n28_complete = (n28_prop_sum + 1) == 28

// Count non-trivial proper divisors (d in 2..n-1 with n%d==0)
fn nontrivial_count(n) {
    let mut count = 0
    let mut d = 2
    while d < n {
        if n % d == 0 { count = count + 1 }
        d = d + 1
    }
    return count
}

let count_6 = nontrivial_count(6)
let count_28 = nontrivial_count(28)
let count_496 = nontrivial_count(496)
let count_8128 = nontrivial_count(8128)

// Only 6 has exactly 2
let unique_6_has_2 = count_6 == 2 && count_28 > 2 && count_496 > 2 && count_8128 > 2

// Egyptian fraction 1/a+1/b+1/c=1, 2<=a<b<c. Search.
// Common denom = a*b*c. Equation: bc + ac + ab = abc.
let mut solutions_count = 0
let mut sol_a = 0
let mut sol_b = 0
let mut sol_c = 0
let mut a = 2
while a <= 10 {
    let mut b = a + 1
    while b <= 50 {
        let mut c = b + 1
        while c <= 100 {
            if b * c + a * c + a * b == a * b * c {
                solutions_count = solutions_count + 1
                sol_a = a
                sol_b = b
                sol_c = c
            }
            c = c + 1
        }
        b = b + 1
    }
    a = a + 1
}
let egypt_unique = solutions_count == 1 && sol_a == 2 && sol_b == 3 && sol_c == 6

let ids = [
    "H098-01","H098-02","H098-03","H098-04",
    "H098-05","H098-06","H098-07"
]
let checks = [
    n6_prop_num == 5 && n6_prop_den == 6,  // 1/2+1/3=5/6
    n6_complete,                           // +1/6 = 1
    egyptian_ok,
    n28_prop_ok && n28_complete,           // 28 has 4 terms
    unique_6_has_2,                        // only 6 has 2 nontrivial divs
    count_6 == 2,
    egypt_unique
]

println("======================================================================")
println("H098 Uniqueness: only n=6 has {2,3,n} Egyptian-fraction decomposition")
println("======================================================================")
println("count nontrivial(6)=" + to_string(count_6) + " (28)=" + to_string(count_28) + " (496)=" + to_string(count_496) + " (8128)=" + to_string(count_8128))
println("Egyptian (a,b,c) solutions=" + to_string(solutions_count) + " found=(" + to_string(sol_a) + "," + to_string(sol_b) + "," + to_string(sol_c) + ")")

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
