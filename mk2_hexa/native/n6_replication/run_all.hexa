// DEPRECATED (2026-04-10): superseded by runner.hexa (full runner.py port).
// cli.hexa cmd_run now delegates to runner.hexa. This file is retained for
// historical reference only — do NOT extend. New orchestration work goes in
// runner.hexa. Deletion deferred per absorption policy.
//
// Ported from tecs-l/n6-replication/scripts/run_all.py
// Minimal replication entrypoint — runs Tier 2 verify/*.py via subprocess.
// Tier 1 pytest integration NOT ported (hexa has no pytest bridge).

fn repo_root() {
    let home = env_var("HOME")
    return home + "/Dev/nexus/tecs-l"
}

fn run_tier2(timeout_s) {
    let root = repo_root()
    let verify_dir = root + "/verify"
    if !file_exists(verify_dir) {
        println("SKIP  Tier 2 -- " + verify_dir + " not found")
        return #{"pass": 0, "fail": 0, "timeout": 0, "skip": 0}
    }

    let mut ls_out = ""
    try { ls_out = to_string(exec("ls -1 " + verify_dir + "/*.py 2>/dev/null")) } catch e {}
    let files_raw = ls_out.trim().split("\n")
    let mut files = []
    let mut i = 0
    while i < len(files_raw) {
        let p = files_raw[i].trim()
        if p != "" { files = files.push(p) }
        i = i + 1
    }

    if len(files) == 0 {
        println("SKIP  Tier 2 -- no scripts in " + verify_dir)
        return #{"pass": 0, "fail": 0, "timeout": 0, "skip": 0}
    }

    println("============================================================")
    println("TIER 2: Verification scripts (" + to_string(len(files)) + " files, timeout=" + to_string(timeout_s) + "s)")
    println("============================================================")

    let mut pass_n = 0
    let mut fail_n = 0
    let mut timeout_n = 0

    let mut j = 0
    while j < len(files) {
        let script = files[j]
        let parts = script.split("/")
        let name = parts[len(parts) - 1]
        let t0 = clock()
        // Use /usr/bin/python3 to avoid PATH wrapper silent-fail (P8)
        let cmd = "cd " + repo_root() + " && PYTHONPATH=" + repo_root() + " timeout " + to_string(timeout_s) + " /usr/bin/python3 " + script + " > /tmp/n6_rep_out.txt 2>&1 ; echo RC=$?"
        let mut out = ""
        try { out = to_string(exec(cmd)) } catch e {}
        let elapsed = clock() - t0

        let mut status = "FAIL"
        if out.contains("RC=0") {
            status = "PASS"
            pass_n = pass_n + 1
        } else {
            if out.contains("RC=124") {
                status = "TIMEOUT"
                timeout_n = timeout_n + 1
            } else {
                fail_n = fail_n + 1
            }
        }
        println("  " + status + "  " + to_string(elapsed) + "s  " + name)
        j = j + 1
    }

    println("")
    let total = pass_n + fail_n + timeout_n
    println("TIER 2: " + to_string(pass_n) + "/" + to_string(total) + " passed, " + to_string(fail_n) + " failed, " + to_string(timeout_n) + " timeout")
    println("")
    return #{"pass": pass_n, "fail": fail_n, "timeout": timeout_n, "skip": 0}
}

// CLI: run_all.hexa [--timeout N] [--dry-run]
let cli_args = args()
let mut timeout_s = 120
let mut dry_run = false
let mut ai = 0
while ai < len(cli_args) {
    let a = cli_args[ai]
    if a == "--timeout" && ai + 1 < len(cli_args) {
        timeout_s = to_int(cli_args[ai + 1])
        ai = ai + 1
    }
    if a == "--dry-run" { dry_run = true }
    ai = ai + 1
}

println("Repo root: " + repo_root())
println("")

if dry_run {
    let vd = repo_root() + "/verify"
    let mut ls_out = ""
    try { ls_out = to_string(exec("ls -1 " + vd + "/*.py 2>/dev/null | wc -l")) } catch e {}
    println("Dry run: would execute " + ls_out.trim() + " scripts")
} else {
    let results = run_tier2(timeout_s)
    println("============================================================")
    println("SUMMARY")
    println("============================================================")
    let total = results["pass"] + results["fail"] + results["timeout"]
    println("  Tier 2 (verify):  " + to_string(results["pass"]) + "/" + to_string(total) + " passed")
    if results["fail"] == 0 && results["timeout"] == 0 {
        println("ALL PASSED")
    } else {
        println("SOME FAILURES -- see above for details")
    }
}
