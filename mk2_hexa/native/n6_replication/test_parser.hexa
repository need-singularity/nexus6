// Ported from tecs-l/n6-replication/tests/test_parser.py
// Tests for output parser (inlined; hexa does not import .hexa files).

// Parser inlined (subset of parser.hexa) -----------------------------------
fn parse_output(stdout) {
    let lines = stdout.split("\n")

    let mut pass_count = 0
    let mut fail_count = 0

    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        if line.contains("✅") || line.contains("PASS") || line.contains("Pass") || line.contains("pass") {
            pass_count = pass_count + 1
        }
        if line.contains("❌") || line.contains("FAIL") || line.contains("Fail") || line.contains("fail") {
            fail_count = fail_count + 1
        }
        i = i + 1
    }

    let green = len(stdout.split("🟩")) - 1
    let orange = len(stdout.split("🟧")) - 1
    let white = len(stdout.split("⚪")) - 1
    let black = len(stdout.split("⬛")) - 1
    let star1 = len(stdout.split("⭐")) - 1
    let star2 = len(stdout.split("★")) - 1
    let stars = star1 + star2

    // Simple p-value scan
    let mut p_values = []
    let mut j = 0
    while j < len(lines) {
        let ln = lines[j]
        let idx1 = ln.index_of("p=")
        if idx1 >= 0 {
            let rest = ln.substring(idx1 + 2, len(ln))
            let pv = parse_leading_float(rest)
            if pv >= 0.0 { p_values = p_values.push(pv) }
        } else {
            let idx2 = ln.index_of("p-value")
            if idx2 >= 0 {
                let mut k = idx2 + 7
                while k < len(ln) {
                    let c = ln.substring(k, k + 1)
                    if c == ":" || c == " " || c == "=" {
                        k = k + 1
                    } else {
                        break
                    }
                }
                let rest2 = ln.substring(k, len(ln))
                let pv2 = parse_leading_float(rest2)
                if pv2 >= 0.0 { p_values = p_values.push(pv2) }
            }
        }
        j = j + 1
    }

    let total = pass_count + fail_count + green + orange + white + black
    let mut status = "pass"
    if total == 0 {
        status = "parse_error"
    } else {
        if fail_count > 0 { status = "fail" }
    }

    return #{
        "pass_count": pass_count,
        "fail_count": fail_count,
        "green": green,
        "orange": orange,
        "white": white,
        "black": black,
        "p_values": p_values,
        "stars": stars,
        "status": status
    }
}

fn parse_leading_float(s) {
    let mut buf = ""
    let mut i = 0
    let mut seen_digit = false
    while i < len(s) {
        let c = s.substring(i, i + 1)
        let is_digit = c == "0" || c == "1" || c == "2" || c == "3" || c == "4" || c == "5" || c == "6" || c == "7" || c == "8" || c == "9"
        let is_dot = c == "."
        let is_neg = c == "-" && i == 0
        let is_e = (c == "e" || c == "E") && seen_digit
        let is_sign = (c == "+" || c == "-") && i > 0 && (s.substring(i - 1, i) == "e" || s.substring(i - 1, i) == "E")
        if is_digit || is_dot || is_neg || is_e || is_sign {
            buf = buf + c
            if is_digit { seen_digit = true }
            i = i + 1
        } else {
            break
        }
    }
    if !seen_digit { return -1.0 }
    let mut v = -1.0
    try { v = to_float(buf) } catch e {}
    return v
}

// Tests --------------------------------------------------------------------

let t1 = parse_output("Check 1: ✅ Pass\nCheck 2: ❌ Fail\nCheck 3: ✅ Pass\n")
let t1_ok = t1["pass_count"] == 2 && t1["fail_count"] == 1

let t2 = parse_output("🟩 H001 proven\n🟩 H002 proven\n🟧 H003 structural\n⚪ H004 coincidence\n⬛ H005 refuted\n")
let t2_ok = t2["green"] == 2 && t2["orange"] == 1 && t2["white"] == 1 && t2["black"] == 1

let t3 = parse_output("Texas Sharpshooter: p=0.0001\nAnother: p-value: 0.05\n")
let t3_ok = len(t3["p_values"]) == 2 && t3["p_values"][0] < 0.001

let t4 = parse_output("")
let t4_ok = t4["pass_count"] == 0 && t4["fail_count"] == 0 && t4["status"] == "parse_error"

let t5 = parse_output("⭐ Major discovery: H090\n★ H067 confirmed\n")
let t5_ok = t5["stars"] == 2

let ids = ["PARSE-01","PARSE-02","PARSE-03","PARSE-04","PARSE-05"]
let checks = [t1_ok, t2_ok, t3_ok, t4_ok, t5_ok]

println("======================================================================")
println("n6-replication parser unit tests")
println("======================================================================")
println("t1: pass=" + to_string(t1["pass_count"]) + " fail=" + to_string(t1["fail_count"]))
println("t2: grades green=" + to_string(t2["green"]) + " orange=" + to_string(t2["orange"]))
println("t3: p_values=" + to_string(len(t3["p_values"])) + " first=" + to_string(t3["p_values"][0]))
println("t4: status=" + t4["status"])
println("t5: stars=" + to_string(t5["stars"]))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
