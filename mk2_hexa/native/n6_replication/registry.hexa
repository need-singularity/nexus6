// Ported from tecs-l/n6-replication/src/n6_replication/registry.py
// Load tier2.json / tier3.json registry of verification scripts.
// Path is env-configurable to avoid hardcoding.

fn registry_dir() {
    let home = env_var("HOME")
    return home + "/Dev/nexus/tecs-l/n6-replication/registry"
}

fn load_tier(tier_num) {
    let path = registry_dir() + "/tier" + to_string(tier_num) + ".json"
    if !file_exists(path) { return [] }
    let content = read_file(path)
    let mut parsed = []
    try { parsed = json_parse(content) } catch e {}
    return parsed
}

fn load_tier2() { return load_tier(2) }
fn load_tier3() { return load_tier(3) }

fn load_all(tiers) {
    let mut scripts = []
    let mut i = 0
    while i < len(tiers) {
        let t = tiers[i]
        let loaded = load_tier(t)
        let mut j = 0
        while j < len(loaded) {
            scripts = scripts.push(loaded[j])
            j = j + 1
        }
        i = i + 1
    }
    return scripts
}

fn filter_scripts(scripts, gpu) {
    if gpu { return scripts }
    let mut out = []
    let mut i = 0
    while i < len(scripts) {
        let s = scripts[i]
        let req = false
        if has_key(s, "requires_gpu") { if s["requires_gpu"] == true { } else { out = out.push(s) } }
        else { out = out.push(s) }
        i = i + 1
    }
    return out
}

// Smoke test when run directly
let t2 = load_tier2()
let t3 = load_tier3()
println("registry: tier2=" + to_string(len(t2)) + " tier3=" + to_string(len(t3)))
let all_both = load_all([2, 3])
println("registry: load_all([2,3])=" + to_string(len(all_both)))
