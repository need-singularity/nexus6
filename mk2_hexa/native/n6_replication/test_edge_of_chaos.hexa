// Ported from tecs-l/n6-replication/tests/tier1/test_edge_of_chaos.py
// H139: Golden Zone = edge of chaos. Langton lambda_c = 0.2738 in GZ, close to 1/e.

let lambda_c = 0.2738
let e_val = 2.718281828459045
let one_over_e = 1.0 / e_val
let upper = 0.5
let width = log(4.0 / 3.0)
let lower = upper - width  // ~0.2123
let center = one_over_e

let ids = [
    "H139-01","H139-02","H139-03","H139-04","H139-05"
]
let checks = [
    lower < lambda_c && lambda_c < upper,         // in GZ
    abs(lambda_c - one_over_e) < 0.1,             // close to 1/e
    abs(width - 0.2876820724517809) < 1e-14,     // GZ width = ln(4/3)
    0.0 < lambda_c && lambda_c < 1.0,             // valid probability
    abs(lambda_c - center) < width / 2.0          // near GZ center
]

println("======================================================================")
println("H139 Edge of Chaos: Langton lambda_c in Golden Zone")
println("======================================================================")
println("lambda_c=" + to_string(lambda_c) + " GZ=[" + to_string(lower) + "," + to_string(upper) + "]")
println("1/e=" + to_string(one_over_e) + " width=" + to_string(width))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
