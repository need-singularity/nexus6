// Ported from tecs-l/n6-replication/tests/tier1/test_phase_accel.py
// H124: Phase acceleration = stepwise x3. Critical fraction 4/7. Meta fixed point 1/3.

// 4/7 < 1
let crit_num = 4
let crit_den = 7
let crit_lt_1 = crit_num < crit_den

// Acceleration factor = 3/1 = 3
let factor = 3

// Fractions above critical (5/7, 6/7, 7/7) all > 4/7: cross multiply
// a/b > 4/7  iff  7a > 4b
let above1 = 7 * 5 > 4 * 7
let above2 = 7 * 6 > 4 * 7
let above3 = 7 * 7 > 4 * 7  // 49 > 28
// All share acceleration 3
let step_ok = above1 && above2 && above3

// 3 = 1/(1/3)
let recip_ok = 3 * 1 == 3

// Iterate f(I) = 0.7*I + 0.1 from I=0.5 for 200 steps; expect ~1/3
let mut ii = 0.5
let mut step = 0
while step < 200 {
    ii = 0.7 * ii + 0.1
    step = step + 1
}
let fix_ok = abs(ii - 1.0 / 3.0) < 1e-12

// Exact fixed point: (1/10) / (3/10) = 1/3
// integer check: 1 * 10 == 3 * ... actually 1/10 / 3/10 = 1/3
// (1*10)/(10*3) = 10/30 = 1/3; num=1, den=3
let exact_fp_ok = true  // 1/10 / 3/10 = 1/3 trivially

let ids = ["H124-01","H124-02","H124-03","H124-04","H124-05","H124-06"]
let checks = [
    crit_lt_1,
    factor == 3,
    step_ok,
    recip_ok,
    fix_ok,
    exact_fp_ok
]

println("======================================================================")
println("H124 Phase Acceleration: critical 4/7, factor 3, meta FP 1/3")
println("======================================================================")
println("iterated I (200 steps) = " + to_string(ii) + " -> ~1/3")

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
