// Ported from tecs-l/n6-replication/tests/tier1/test_bridge_theorem.py
// H-CX-501: I^I minimization gives GZ center 1/e.
// d/dI[I^I] = I^I * (ln I + 1) = 0 at I = 1/e.

let e_val = 2.718281828459045
let I_star = 1.0 / e_val

// Derivative at 1/e: I^I * (ln I + 1) should be ~0
// pow(a, b) — may not accept float exponent? Use exp(b*log(a)) instead for safety.
// Actually pow in hexa works with floats.
let ln_I = log(I_star)
let I_pow_I = pow(I_star, I_star)
let deriv = I_pow_I * (ln_I + 1.0)

// Second derivative: I^I * ((lnI+1)^2 + 1/I) > 0
let t1 = (ln_I + 1.0) * (ln_I + 1.0)
let d2 = I_pow_I * (t1 + 1.0 / I_star)

// 1/e in golden zone [0.5 - ln(4/3), 0.5]
let gz_lower = 0.5 - log(4.0 / 3.0)
let gz_upper = 0.5

// K-independence: neighbors have higher energy
let delta1 = -0.01
let delta2 = 0.01
let I_m = I_star + delta1
let I_p = I_star + delta2
let E_star = I_pow_I
let E_m = pow(I_m, I_m)
let E_p = pow(I_p, I_p)

// 1/e matches known constant
let one_over_e_const = 0.36787944117144233
let const_match = abs(I_star - one_over_e_const) < 1e-14

let ids = [
    "HCX501-01","HCX501-02","HCX501-03","HCX501-04",
    "HCX501-05","HCX501-06"
]
let checks = [
    abs(deriv) < 1e-14,                         // derivative ~ 0
    d2 > 0.0,                                   // 2nd deriv positive
    gz_lower < I_star && I_star < gz_upper,     // 1/e in GZ
    E_m > E_star && E_p > E_star,               // neighbors higher
    const_match,                                // 1/e value
    pow(I_star, I_star) > 0.0                   // I^I defined
]

println("======================================================================")
println("H-CX-501 Bridge Theorem: I^I minimum at I=1/e")
println("======================================================================")
println("I* = 1/e = " + to_string(I_star))
println("deriv = " + to_string(deriv))
println("d2 = " + to_string(d2))
println("GZ = [" + to_string(gz_lower) + ", " + to_string(gz_upper) + "]")

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
