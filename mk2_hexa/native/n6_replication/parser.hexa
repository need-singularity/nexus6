// Ported from tecs-l/n6-replication/src/n6_replication/parser.py
// Parse verification script output to extract pass/fail counts, grades, stars, p-values.
// Regex replaced with substring scans. Emoji markers: ✅ ❌ 🟩 🟧 ⚪ ⬛ ⭐ ★

fn parse_output(stdout) {
    let lines = stdout.split("\n")

    let mut pass_count = 0
    let mut fail_count = 0
    let mut green = 0
    let mut orange = 0
    let mut white = 0
    let mut black = 0
    let mut stars = 0

    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        // pass markers
        if line.contains("✅") || line.contains("PASS") || line.contains("Pass") || line.contains("pass") {
            pass_count = pass_count + 1
        }
        // fail markers
        if line.contains("❌") || line.contains("FAIL") || line.contains("Fail") || line.contains("fail") {
            fail_count = fail_count + 1
        }
        i = i + 1
    }

    // Count grade/star occurrences across full stdout
    let g_tokens = ["🟩"]
    let o_tokens = ["🟧"]
    let w_tokens = ["⚪"]
    let b_tokens = ["⬛"]

    // Simple occurrence counter via split-length
    green = len(stdout.split("🟩")) - 1
    orange = len(stdout.split("🟧")) - 1
    white = len(stdout.split("⚪")) - 1
    black = len(stdout.split("⬛")) - 1
    let star1 = len(stdout.split("⭐")) - 1
    let star2 = len(stdout.split("★")) - 1
    stars = star1 + star2

    // p-value extraction: scan for 'p=' or 'p-value' and capture next float
    let mut p_values = []
    let tokens = ["p=", "p=", "p-value:", "p-value=", "p =", "P="]
    // Look for 'p=' and 'p-value' with simple scan
    let mut j = 0
    while j < len(lines) {
        let ln = lines[j]
        // Try 'p=' marker
        let idx1 = ln.index_of("p=")
        if idx1 >= 0 {
            let rest = ln.substring(idx1 + 2, len(ln))
            let pv = parse_leading_float(rest)
            if pv >= 0.0 { p_values = p_values.push(pv) }
        } else {
            let idx2 = ln.index_of("p-value")
            if idx2 >= 0 {
                // Skip past 'p-value' and any ':' ' ' '='
                let mut k = idx2 + 7
                while k < len(ln) {
                    let c = ln.substring(k, k + 1)
                    if c == ":" || c == " " || c == "=" {
                        k = k + 1
                    } else {
                        break
                    }
                }
                let rest2 = ln.substring(k, len(ln))
                let pv2 = parse_leading_float(rest2)
                if pv2 >= 0.0 { p_values = p_values.push(pv2) }
            }
        }
        j = j + 1
    }

    let total = pass_count + fail_count + green + orange + white + black
    let mut status = "pass"
    if total == 0 {
        status = "parse_error"
    } else {
        if fail_count > 0 { status = "fail" }
    }

    return #{
        "pass_count": pass_count,
        "fail_count": fail_count,
        "grades": #{
            "green": green,
            "orange": orange,
            "white": white,
            "black": black
        },
        "p_values": p_values,
        "stars": stars,
        "status": status
    }
}

// Parse leading float from a string. Returns -1.0 if no float found.
fn parse_leading_float(s) {
    let mut buf = ""
    let mut i = 0
    let mut seen_digit = false
    while i < len(s) {
        let c = s.substring(i, i + 1)
        let is_digit = c == "0" || c == "1" || c == "2" || c == "3" || c == "4" || c == "5" || c == "6" || c == "7" || c == "8" || c == "9"
        let is_dot = c == "."
        let is_neg = c == "-" && i == 0
        let is_e = (c == "e" || c == "E") && seen_digit
        let is_sign = (c == "+" || c == "-") && i > 0 && (s.substring(i - 1, i) == "e" || s.substring(i - 1, i) == "E")
        if is_digit || is_dot || is_neg || is_e || is_sign {
            buf = buf + c
            if is_digit { seen_digit = true }
            i = i + 1
        } else {
            break
        }
    }
    if !seen_digit { return -1.0 }
    let mut v = -1.0
    try { v = to_float(buf) } catch e {}
    return v
}
