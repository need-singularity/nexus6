// Ported from tecs-l/n6-replication/tests/tier1/test_uniqueness_theorem.py
// H-CX-502: phi(n)*sigma(n) = n*tau(n) uniquely at n=6.
// Uses hexa builtins: phi(n), sigma(n), tau(n).

let phi_6 = phi(6)
let sig_6 = sigma(6)
let tau_6 = tau(6)
let lhs_6 = phi_6 * sig_6
let rhs_6 = 6 * tau_6

// Exhaustive n in [2,1000]
let mut solutions = 0
let mut first_sol = 0
let mut n = 2
while n <= 1000 {
    if phi(n) * sigma(n) == n * tau(n) {
        solutions = solutions + 1
        if first_sol == 0 { first_sol = n }
    }
    n = n + 1
}

// n=28 fails
let n28_fails = phi(28) * sigma(28) != 28 * tau(28)
// n=496 fails
let n496_fails = phi(496) * sigma(496) != 496 * tau(496)

// Primes fail
let primes = [2, 3, 5, 7, 11, 13, 17, 19, 23]
let mut primes_fail = true
let mut pi = 0
while pi < len(primes) {
    let p = primes[pi]
    if phi(p) * sigma(p) == p * tau(p) { primes_fail = false }
    pi = pi + 1
}

// Powers of 2 fail
let mut pow2_fail = true
let mut k = 1
let mut pw = 2
while k < 10 {
    if phi(pw) * sigma(pw) == pw * tau(pw) { pow2_fail = false }
    pw = pw * 2
    k = k + 1
}

// Neighbors 5,7 gap > 0
let gap5 = abs(phi(5) * sigma(5) - 5 * tau(5))
let gap7 = abs(phi(7) * sigma(7) - 7 * tau(7))

let ids = [
    "HCX502-01","HCX502-02","HCX502-03","HCX502-04",
    "HCX502-05","HCX502-06","HCX502-07","HCX502-08"
]
let checks = [
    lhs_6 == rhs_6,                          // phi*sigma = n*tau at n=6
    phi_6 == 2 && sig_6 == 12 && tau_6 == 4, // individual values
    solutions == 1 && first_sol == 6,        // unique in [2,1000]
    n28_fails,
    n496_fails,
    primes_fail,
    pow2_fail,
    gap5 > 0 && gap7 > 0
]

println("======================================================================")
println("H-CX-502 Uniqueness Theorem: phi(n)*sigma(n)=n*tau(n) at n=6")
println("======================================================================")
println("phi(6)=" + to_string(phi_6) + " sigma(6)=" + to_string(sig_6) + " tau(6)=" + to_string(tau_6))
println("lhs=" + to_string(lhs_6) + " rhs=" + to_string(rhs_6))
println("solutions in [2,1000]: " + to_string(solutions) + " first=" + to_string(first_sol))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
