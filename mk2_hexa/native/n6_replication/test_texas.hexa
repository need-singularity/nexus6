// Ported from tecs-l/n6-replication/tests/tier1/test_texas.py
// Texas Sharpshooter: 10 claims, 8+ must match, p < 0.001.

// CLAIMS: value, target, tol
let values = [
    0.3679,              // GZ center
    1.0 / 3.0,           // meta FP
    5.0 / 6.0,           // compass upper
    2.0,                 // sigma_{-1}(6)
    2.0,                 // Euler product
    1.0,                 // 1/2+1/3+1/6
    0.2877,              // GZ width
    0.6321,              // P!=NP gap
    0.2738,              // Langton
    3.0                  // accel factor
]
let targets = [
    1.0 / 2.71828,
    0.3333,
    0.8333,
    2.0,
    2.0,
    1.0,
    0.2877,
    1.0 - 1.0 / 2.71828,
    0.2738,
    3.0
]
let tols = [0.01, 0.01, 0.01, 0.001, 0.001, 0.001, 0.01, 0.01, 0.05, 0.1]

fn count_matches(vals, tgts, tls) {
    let mut m = 0
    let mut i = 0
    while i < len(vals) {
        if abs(vals[i] - tgts[i]) <= tls[i] { m = m + 1 }
        i = i + 1
    }
    return m
}

let actual = count_matches(values, targets, tols)

// Monte Carlo with LCG (seed=42) to estimate p-value
// Count trials where random >= actual matches
let n_claims = 10
let n_trials = 5000
let mut beats = 0
let mut total = 0
let mut lcg = 42
let mut t = 0
while t < n_trials {
    let mut rm = 0
    let mut ci = 0
    while ci < n_claims {
        lcg = (lcg * 1103515245 + 12345) % 2147483648
        // uniform in [0, 5)
        let rv = (to_float(lcg % 100000) / 100000.0) * 5.0
        if abs(rv - targets[ci]) <= tols[ci] { rm = rm + 1 }
        ci = ci + 1
    }
    if rm >= actual { beats = beats + 1 }
    total = total + rm
    t = t + 1
}
let p_value = to_float(beats) / to_float(n_trials)
let avg_random = to_float(total) / to_float(n_trials)

// Claim structural fields
let n_fields = 4  // name, value, target, tol (verified by parallel arrays having same length)
let struct_ok = len(values) == 10 && len(targets) == 10 && len(tols) == 10

let ids = ["TEXAS-01","TEXAS-02","TEXAS-03","TEXAS-04"]
let checks = [
    actual >= 8,
    p_value < 0.001,
    avg_random < 3.0,
    struct_ok
]

println("======================================================================")
println("Texas Sharpshooter: 10 claims, 8+ match required, p<0.001")
println("======================================================================")
println("actual matches = " + to_string(actual))
println("p_value ~ " + to_string(p_value))
println("random avg matches = " + to_string(avg_random))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
