// Ported from tecs-l/n6-replication/tests/tier1/test_perfect_six.py
// H090: Master formula = perfect number 6.
// sigma_{-1}(6) = 2, Euler product connection, perfect number properties.
// sigma_{-1}(n) = sigma(n)/n -> integer check: sigma(n) == 2*n iff n is perfect.

let ids = [
    "H090-01","H090-02","H090-03","H090-04","H090-05",
    "H090-06","H090-07","H090-08"
]

// sigma_{-1}(6)=2 : sigma(6) = 12 = 2*6
let s6 = sigma(6)
let s28 = sigma(28)
let s496 = sigma(496)
let s8128 = sigma(8128)

// 1 + 1/2 + 1/3 + 1/6 = 2  -> scaled by 6: 6 + 3 + 2 + 1 = 12 = 2*6
let divsum_scaled = 6 + 3 + 2 + 1

// Euler product (1+1/2)(1+1/3) = (3/2)(4/3) = 12/6 = 2
// scaled: (3*4)/(2*3) = 12/6, numerator=12 denom=6 -> ratio 2
let euler_num = 3 * 4
let euler_den = 2 * 3

// Perfect number: proper divisors of 6 = {1,2,3} sum = 6
let sum_proper_6 = 1 + 2 + 3
// Proper divisors of 28 = {1,2,4,7,14} sum = 28
let sum_proper_28 = 1 + 2 + 4 + 7 + 14

let checks = [
    s6 == 12,                  // sigma(6)=12 -> sigma_{-1}(6)=2
    divsum_scaled == 12,       // 1+1/2+1/3+1/6 = 2
    s28 == 56,                 // sigma_{-1}(28)=2
    euler_num == 2 * euler_den,// Euler product p=2,3 = 2
    sum_proper_6 == 6,         // 6 is perfect
    sum_proper_28 == 28,       // 28 is perfect
    s496 == 2 * 496,           // sigma_{-1}(496)=2
    s8128 == 2 * 8128          // sigma_{-1}(8128)=2
]

println("======================================================================")
println("H090 Perfect Six verification (sigma_{-1}, Euler product, perfect numbers)")
println("======================================================================")
println("sigma(6)=" + to_string(s6) + " sigma(28)=" + to_string(s28) + " sigma(496)=" + to_string(s496) + " sigma(8128)=" + to_string(s8128))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
