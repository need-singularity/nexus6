// Ported from tecs-l/n6-replication/tests/tier1/test_conservation.py
// H172: G*I = D*P conservation. G = D*P/I algebraic identity.

// Basic identity
let d1 = 0.7
let p1 = 0.8
let i1 = 0.15
let g1 = d1 * p1 / i1
let basic_ok = abs(g1 * i1 - d1 * p1) < 1e-14

// Inhibition range I in {0.1..0.5}
let mut range_ok = true
let d2 = 0.6
let p2 = 0.7
let mut k = 1
while k <= 5 {
    let ii = to_float(k) / 10.0
    let gg = d2 * p2 / ii
    if abs(gg * ii - d2 * p2) >= 1e-13 { range_ok = false }
    k = k + 1
}

// 100 pseudo-random values using deterministic LCG seeded to 42
let mut lcg = 42
let mut rand_ok = true
let mut n = 0
while n < 100 {
    lcg = (lcg * 1103515245 + 12345) % 2147483648
    let d = 0.01 + (to_float(lcg % 100000) / 100000.0) * 0.99
    lcg = (lcg * 1103515245 + 12345) % 2147483648
    let p = 0.01 + (to_float(lcg % 100000) / 100000.0) * 0.99
    lcg = (lcg * 1103515245 + 12345) % 2147483648
    let ii = 0.01 + (to_float(lcg % 100000) / 100000.0) * 0.99
    let g = d * p / ii
    if abs(g * ii - d * p) >= 1e-12 { rand_ok = false }
    n = n + 1
}

// Edge cases
let d3 = 0.5
let p3 = 0.5
let hi = 0.99
let lo = 0.01
let ghi = d3 * p3 / hi
let glo = d3 * p3 / lo
let high_ok = abs(ghi * hi - d3 * p3) < 1e-14
let low_ok = abs(glo * lo - d3 * p3) < 1e-12

// Equal values
let v = 0.42
let geq = v * v / v
let eq_ok = abs(geq * v - v * v) < 1e-14

let ids = ["H172-01","H172-02","H172-03","H172-04","H172-05","H172-06"]
let checks = [basic_ok, range_ok, rand_ok, high_ok, low_ok, eq_ok]

println("======================================================================")
println("H172 Conservation Law: G*I = D*P")
println("======================================================================")

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
