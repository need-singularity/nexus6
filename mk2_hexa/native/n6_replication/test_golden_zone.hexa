// Ported from tecs-l/n6-replication/tests/tier1/test_golden_zone.py
// H067: 1/2 + 1/3 = 5/6 (constant relationship)
// H072: 1/2 + 1/3 + 1/6 = 1 (curiosity creates completeness)
// Golden Zone: upper=1/2, width=ln(4/3), center=1/e

// Integer-scale tests (LCD = 6)
// 1/2 + 1/3 = 3/6 + 2/6 = 5/6  -> num=5, den=6
let h067_num = 3 + 2
let h067_den = 6

// 1/2 - 1/3 = 1/6 = 1/2 * 1/3
let diff_scaled = 3 - 2          // over 6
let prod_num = 1 * 1             // 1/6
let prod_den = 2 * 3

// 1/2 + 1/3 + 1/6 = 1  -> (3+2+1)/6 = 6/6 = 1
let h072_sum = 3 + 2 + 1

// Golden Zone floating values
let e_val = 2.718281828459045
let center = 1.0 / e_val
let width = log(4.0 / 3.0)
let upper = 0.5
let lower = upper - width
let computed_lower = upper - width

let ids = [
    "H067-01","H067-02","H067-03","H072-01","H072-02",
    "GZ-01","GZ-02","GZ-03","GZ-04"
]

let checks = [
    h067_num == 5 && h067_den == 6,            // 1/2+1/3 = 5/6
    diff_scaled == 1,                          // diff = 1/6
    prod_num == 1 && prod_den == 6,            // product = 1/6
    h072_sum == 6,                             // 1/2+1/3+1/6 = 1
    h072_sum * 1 == 6 * 1,                     // completeness
    abs(center - 0.36787944117144233) < 1e-14, // center ~ 1/e
    abs(width - 0.2876820724517809) < 1e-14,   // width = ln(4/3)
    abs(computed_lower - lower) < 1e-12,       // upper - width = lower
    upper == 0.5                               // upper = 1/2
]

println("======================================================================")
println("H067 + H072 Golden Zone verification")
println("======================================================================")
println("1/2+1/3 = 5/6  1/2+1/3+1/6 = 1  center=1/e width=ln(4/3)")
println("center=" + to_string(center) + " width=" + to_string(width))

let mut pass_c = 0
let mut fail_c = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { pass_c = pass_c + 1 } else { fail_c = fail_c + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(pass_c + fail_c) + " PASS: " + to_string(pass_c) + " FAIL: " + to_string(fail_c))
if fail_c == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
