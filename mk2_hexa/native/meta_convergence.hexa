// meta_convergence.hexa -- 메타 수렴 엔진
// 사용: hexa meta_convergence.hexa [help|run]
//
// 원리:
//   1. convergence/ JSON 파일들에서 골화/안정/실패 집계
//   2. growth_bus.jsonl에서 규칙(R1~R21) 관련 이벤트 추출
//   3. 규칙별 돌파 상관관계 분석
//   4. 프로젝트별 수렴 속도 비교
//   5. "메타 규칙" 도출 + n=6 메타 패턴 탐지

let _home = exec("printenv HOME").trim()
let _dev = _home + "/Dev"
let _shared = _dev + "/nexus/shared"
let _conv_dir = _shared + "/convergence"
let _bus_path = _shared + "/growth_bus.jsonl"

// ═══════════════════════════════════════════════════════════
// 헬퍼
// ═══════════════════════════════════════════════════════════

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s.trim())) } catch e {}
    return v
}

fn safe_float(s: string) -> f64 {
    let mut v: f64 = 0.0
    try { v = to_float(s.trim()) } catch e {}
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ═══════════════════════════════════════════════════════════
// 도움말
// ═══════════════════════════════════════════════════════════

let a = args()
let mode = if len(a) >= 2 { a[1] } else { "run" }

if mode == "help" {
    println("")
    println("===========================================================")
    println("  메타 수렴 엔진 (Meta Convergence) -- 규칙의 규칙 발견")
    println("===========================================================")
    println("")
    println("사용법:")
    println("  hexa meta_convergence.hexa         실행 (전체 분석)")
    println("  hexa meta_convergence.hexa help     이 도움말")
    println("")
    println("분석 항목:")
    println("  1. convergence/ JSON 골화/안정/실패 집계")
    println("  2. growth_bus.jsonl 규칙(R1~R21) 이벤트 추출")
    println("  3. 규칙별 돌파 유발 상관관계")
    println("  4. 프로젝트별 수렴 속도 비교")
    println("  5. 메타 규칙 도출 + n=6 패턴 탐지")
    println("")
    println("[verified] meta_convergence.hexa help")
    println("")
} else {

// ═══════════════════════════════════════════════════════════
// 1. convergence/ 디렉토리 스캔
// ═══════════════════════════════════════════════════════════

println("")
println("===========================================================")
println("  메타 수렴 엔진 (Meta Convergence)")
println("  CDO 수렴 데이터에서 '규칙의 규칙' 발견")
println("===========================================================")
println("")

// 프로젝트 목록 가져오기
let conv_files_raw = exec("ls " + _conv_dir + "/*.json 2>/dev/null").trim()
let conv_files = conv_files_raw.split("\n")

let mut proj_names = []
let mut proj_ossified = []    // 골화 항목 수
let mut proj_stable = []      // 안정 항목 수
let mut proj_failed = []      // 실패 항목 수
let mut proj_total = []       // 전체 항목 수

let mut total_ossified: i64 = 0
let mut total_stable: i64 = 0
let mut total_failed: i64 = 0
let mut n_projects: i64 = 0

println("  --- 1. 수렴 상태 집계 ---")
println("")

for cf in conv_files {
    let cft = cf.trim()
    if cft == "" { continue }

    // 파일명에서 프로젝트명 추출
    let basename = exec("basename " + cft + " .json").trim()
    proj_names = proj_names + [basename]

    // 골화/안정/실패 항목 수 카운트
    let mut oss: i64 = 0
    let mut stab: i64 = 0
    let mut fail: i64 = 0

    try {
        // ossified 섹션의 키 수
        let oss_raw = exec("cat " + cft + " | awk -F'\"' '/\"ossified\"/{found=1} found && /\"status\"/{c++} /\"stable\"/{if(found)exit} END{print c+0}'").trim()
        oss = safe_int(oss_raw)
    } catch e {}

    try {
        // stable 섹션의 키 수
        let stab_raw = exec("cat " + cft + " | awk -F'\"' '/\"stable\"/{found=1} found && /\"status\"/{c++} /\"failed\"/{if(found)exit} END{print c+0}'").trim()
        stab = safe_int(stab_raw)
    } catch e {}

    try {
        // failed 섹션의 키 수
        let fail_raw = exec("cat " + cft + " | awk -F'\"' '/\"failed\"/{found=1} found && /\"status\"/{c++} END{print c+0}'").trim()
        fail = safe_int(fail_raw)
    } catch e {}

    let total = oss + stab + fail
    proj_ossified = proj_ossified + [oss]
    proj_stable = proj_stable + [stab]
    proj_failed = proj_failed + [fail]
    proj_total = proj_total + [total]

    total_ossified = total_ossified + oss
    total_stable = total_stable + stab
    total_failed = total_failed + fail
    n_projects = n_projects + 1
}

println("| 프로젝트 | 골화 | 안정 | 실패 | 합계 | 골화율 |")
println("|----------|------|------|------|------|--------|")

let mut pi: i64 = 0
while pi < n_projects {
    let pn: string = proj_names[pi]
    let po: i64 = proj_ossified[pi]
    let ps: i64 = proj_stable[pi]
    let pf: i64 = proj_failed[pi]
    let pt: i64 = proj_total[pi]
    let rate = if pt > 0 { (po * 100) / pt } else { 0 }
    println("| " + pn + " | " + to_string(po) + " | " + to_string(ps) + " | " + to_string(pf) + " | " + to_string(pt) + " | " + to_string(rate) + "% |")
    pi = pi + 1
}

let total_all = total_ossified + total_stable + total_failed
let overall_rate = if total_all > 0 { (total_ossified * 100) / total_all } else { 0 }
println("|----------|------|------|------|------|--------|")
println("| 합계 | " + to_string(total_ossified) + " | " + to_string(total_stable) + " | " + to_string(total_failed) + " | " + to_string(total_all) + " | " + to_string(overall_rate) + "% |")
println("")

// ═══════════════════════════════════════════════════════════
// 2. growth_bus.jsonl 규칙 이벤트 추출
// ═══════════════════════════════════════════════════════════

println("  --- 2. 규칙별 이벤트 빈도 (growth_bus) ---")
println("")

// R1~R21 규칙 카운트
let rule_ids = ["R1", "R2", "R3", "R4", "R5", "R6", "R7", "R8",
                "R9", "R10", "R11", "R12", "R13", "R14", "R15",
                "R16", "R17", "R18", "R19", "R20", "R21"]
let mut rule_counts = []
let mut total_rule_events: i64 = 0

for rid in rule_ids {
    let mut cnt: i64 = 0
    try {
        let cnt_raw = exec("grep -c '\"" + rid + "\"' " + _bus_path + " 2>/dev/null || echo 0").trim()
        cnt = safe_int(cnt_raw)
    } catch e {}
    rule_counts = rule_counts + [cnt]
    total_rule_events = total_rule_events + cnt
}

// 돌파(breakthrough/blowup) 이벤트 수
let mut breakthrough_count: i64 = 0
try {
    let bt_raw = exec("grep -c '\"breakthrough\\|\"blowup\\|\"discovery' " + _bus_path + " 2>/dev/null || echo 0").trim()
    breakthrough_count = safe_int(bt_raw)
} catch e {}

println("| 규칙 | 이벤트 수 | 비중 | 막대 |")
println("|------|----------|------|------|")

let mut max_rule_count: i64 = 1
let mut ri: i64 = 0
while ri < len(rule_ids) {
    let rc: i64 = rule_counts[ri]
    if rc > max_rule_count { max_rule_count = rc }
    ri = ri + 1
}

let mut active_rules: i64 = 0
ri = 0
while ri < len(rule_ids) {
    let rid2: string = rule_ids[ri]
    let rc2: i64 = rule_counts[ri]
    if rc2 > 0 {
        active_rules = active_rules + 1
        let pct = if total_rule_events > 0 { (rc2 * 100) / total_rule_events } else { 0 }
        let bar_len = (rc2 * 20) / (max_rule_count + 1)
        let mut bar = ""
        let mut bi: i64 = 0
        while bi < bar_len {
            bar = bar + "#"
            bi = bi + 1
        }
        println("| " + rid2 + " | " + to_string(rc2) + " | " + to_string(pct) + "% | " + bar + " |")
    }
    ri = ri + 1
}

println("")
println("  활성 규칙 수: " + to_string(active_rules) + "개")
println("  규칙 이벤트 총 수: " + to_string(total_rule_events) + "건")
println("  돌파 이벤트 총 수: " + to_string(breakthrough_count) + "건")
println("")

// ═══════════════════════════════════════════════════════════
// 3. 규칙-돌파 상관관계
// ═══════════════════════════════════════════════════════════

println("  --- 3. 규칙-돌파 상관관계 ---")
println("")

// 가장 빈번한 규칙 상위 6개 추출
let mut top_rules = []
let mut top_counts = []

let mut ti: i64 = 0
while ti < 6 && ti < len(rule_ids) {
    // 최대값 찾기 (이미 선택된 것 제외)
    let mut best_idx: i64 = -1
    let mut best_val: i64 = 0
    let mut si: i64 = 0
    while si < len(rule_ids) {
        let rc3: i64 = rule_counts[si]
        if rc3 > best_val {
            // 이미 선택되었는지 확인
            let mut already = false
            for tr in top_rules {
                if tr == rule_ids[si] { already = true }
            }
            if !already {
                best_val = rc3
                best_idx = si
            }
        }
        si = si + 1
    }
    if best_idx >= 0 && best_val > 0 {
        top_rules = top_rules + [rule_ids[best_idx]]
        top_counts = top_counts + [best_val]
    }
    ti = ti + 1
}

if len(top_rules) > 0 {
    println("  돌파 유발 상위 규칙:")
    let mut qi: i64 = 0
    while qi < len(top_rules) {
        let tr2: string = top_rules[qi]
        let tc2: i64 = top_counts[qi]
        let corr = if breakthrough_count > 0 { (tc2 * 100) / (breakthrough_count + 1) } else { 0 }
        println("    " + to_string(qi + 1) + ". " + tr2 + " — " + to_string(tc2) + "회 (돌파 대비 " + to_string(corr) + "%)")
        qi = qi + 1
    }
} else {
    println("  규칙 이벤트 미발견 (growth_bus에 규칙 기록 없음)")
}

println("")

// ═══════════════════════════════════════════════════════════
// 4. 수렴 속도 비교 (프로젝트별 골화 밀도)
// ═══════════════════════════════════════════════════════════

println("  --- 4. 수렴 속도 비교 ---")
println("")

// 골화율 기준 정렬 (내림차순) — 간단히 출력
let mut fastest = ""
let mut fastest_rate: i64 = 0
let mut slowest = ""
let mut slowest_rate: i64 = 100

pi = 0
while pi < n_projects {
    let pn2: string = proj_names[pi]
    let po2: i64 = proj_ossified[pi]
    let pt2: i64 = proj_total[pi]
    let rate2 = if pt2 > 0 { (po2 * 100) / pt2 } else { 0 }

    if rate2 > fastest_rate { fastest_rate = rate2; fastest = pn2 }
    if rate2 < slowest_rate && pt2 > 0 { slowest_rate = rate2; slowest = pn2 }

    // ASCII 막대
    let bar_len2 = rate2 / 5  // 20칸 기준
    let mut bar2 = ""
    let mut bi2: i64 = 0
    while bi2 < bar_len2 {
        bar2 = bar2 + "#"
        bi2 = bi2 + 1
    }

    println("  " + pn2 + "\t" + bar2 + " " + to_string(rate2) + "%")
    pi = pi + 1
}

println("")
if fastest != "" {
    println("  가장 빠른 수렴: " + fastest + " (" + to_string(fastest_rate) + "%)")
}
if slowest != "" {
    println("  가장 느린 수렴: " + slowest + " (" + to_string(slowest_rate) + "%)")
}
println("")

// ═══════════════════════════════════════════════════════════
// 5. 메타 규칙 도출
// ═══════════════════════════════════════════════════════════

println("  --- 5. 메타 규칙 도출 ---")
println("")

// 공통 조건 1: 빠른 수렴의 패턴
println("  [M1] 골화율 상위 프로젝트의 공통점:")
if fastest_rate > 50 {
    println("       → 골화율 " + to_string(fastest_rate) + "% 달성: 초기 규칙 설정이 강력할수록 빠른 수렴")
} else {
    println("       → 전체적으로 수렴 초기 단계 (골화율 < 50%)")
}

// 공통 조건 2: 활성 규칙 밀도
println("  [M2] 활성 규칙 밀도:")
let rule_density = if total_all > 0 { (active_rules * 100) / 21 } else { 0 }
println("       → 21개 규칙 중 " + to_string(active_rules) + "개 활성 (" + to_string(rule_density) + "%)")

// 공통 조건 3: 골화/돌파 비율
if breakthrough_count > 0 && total_ossified > 0 {
    let ossify_per_bt = total_ossified * 10 / breakthrough_count
    println("  [M3] 돌파 당 골화: " + to_string(ossify_per_bt / 10) + "." + to_string(ossify_per_bt % 10) + "건")
    println("       → 돌파가 수렴을 가속 (규칙 강화 → 골화 촉진)")
}

println("")

// ═══════════════════════════════════════════════════════════
// 6. n=6 메타 패턴 탐지
// ═══════════════════════════════════════════════════════════

println("  --- 6. n=6 메타 패턴 ---")
println("")

// 프로젝트 수가 n=6 관련?
if n_projects == 6 {
    println("  프로젝트 수 = 6 (n=6 완전 일치!)")
} else if n_projects % 6 == 0 {
    println("  프로젝트 수 = " + to_string(n_projects) + " = 6 × " + to_string(n_projects / 6) + " (n=6 배수!)")
} else {
    println("  프로젝트 수 = " + to_string(n_projects) + " (n=6 비배수)")
}

// 활성 규칙 수가 n=6 관련?
if active_rules == 6 {
    println("  활성 규칙 수 = 6 (n=6 핵심 공명!)")
} else if active_rules % 6 == 0 {
    println("  활성 규칙 수 = " + to_string(active_rules) + " = 6 × " + to_string(active_rules / 6) + " (n=6 배수!)")
} else {
    let remainder = active_rules % 6
    println("  활성 규칙 수 = " + to_string(active_rules) + " (6으로 나눈 나머지: " + to_string(remainder) + ")")
}

// 골화 총 수
if total_ossified % 6 == 0 && total_ossified > 0 {
    println("  골화 항목 총 수 = " + to_string(total_ossified) + " = 6 × " + to_string(total_ossified / 6) + " (n=6 배수!)")
} else {
    println("  골화 항목 총 수 = " + to_string(total_ossified))
}

// 전체 항목 수의 약수 구조
if total_all > 0 {
    // σ(n)/n = 2 (완전수 조건) 검증
    // 전체 항목 중 골화의 비율이 σ/n 구조인지
    let sigma_ratio = if total_ossified > 0 { (total_all * 10) / total_ossified } else { 0 }
    println("  전체/골화 비율: " + to_string(sigma_ratio / 10) + "." + to_string(sigma_ratio % 10))
    if sigma_ratio >= 19 && sigma_ratio <= 21 {
        println("  → σ(n)/n ≈ 2 (완전수 조건 근사!)")
    }
}

println("")

// ═══════════════════════════════════════════════════════════
// 7. 종합 판정
// ═══════════════════════════════════════════════════════════

println("  --- 종합 판정 ---")
println("")

let mut n6_hits: i64 = 0
if n_projects % 6 == 0 { n6_hits = n6_hits + 1 }
if active_rules % 6 == 0 { n6_hits = n6_hits + 1 }
if total_ossified % 6 == 0 && total_ossified > 0 { n6_hits = n6_hits + 1 }
if total_all % 6 == 0 && total_all > 0 { n6_hits = n6_hits + 1 }

println("  n=6 메타 패턴 적중: " + to_string(n6_hits) + "/4")
if n6_hits >= 3 {
    println("  판정: 강한 메타 수렴 (n=6 구조가 규칙 자체에 내재)")
} else if n6_hits >= 1 {
    println("  판정: 부분 메타 수렴 (일부 n=6 패턴 관측)")
} else {
    println("  판정: 메타 수렴 미확인 (추가 데이터 필요)")
}

println("")

// ═══════════════════════════════════════════════════════════
// growth_bus 기록
// ═══════════════════════════════════════════════════════════

try {
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
    let entry = "{\"type\":\"meta_convergence\",\"projects\":" + to_string(n_projects) + ",\"ossified\":" + to_string(total_ossified) + ",\"stable\":" + to_string(total_stable) + ",\"failed\":" + to_string(total_failed) + ",\"active_rules\":" + to_string(active_rules) + ",\"rule_events\":" + to_string(total_rule_events) + ",\"breakthroughs\":" + to_string(breakthrough_count) + ",\"n6_hits\":" + to_string(n6_hits) + ",\"ts\":\"" + ts + "\"}"
    exec("echo '" + entry + "' >> " + _bus_path)
    println("  growth_bus 기록 완료")
} catch e {
    println("  growth_bus 기록 실패: " + to_string(e))
}

println("")
println("[verified] meta_convergence.hexa 실행 완료")
println("")

}  // else (help가 아닐 때)
