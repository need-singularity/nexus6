fn wave9() {
    reset_counts()
    println("")
    sep72()
    println("  WAVE 9 -- COMPUTATIONAL VERIFICATION & BRIDGES")
    sep72()

    // Verify phi(P2)=sigma(P1) for first 4 perfect numbers
    println("")
    println(">>> A. COMPUTATIONAL VERIFICATION")
    println("")
    println("  phi(Pk) vs sigma(P_{k-1}):")

    let mut perfects_s: list = [6, 28, 496, 8128]
    let mut idx: i64 = 1
    while idx < 4 {
        let pk = perfects_s[idx]
        let pk_i = to_int(to_string(pk))
        let prev = perfects_s[idx - 1]
        let prev_i = to_int(to_string(prev))
        let phi_pk = euler_totient(pk_i)
        let sig_prev = divisor_sum(prev_i)
        print("    phi(")
        print(to_string(pk_i))
        print(") = ")
        print(to_string(phi_pk))
        print(", sigma(")
        print(to_string(prev_i))
        print(") = ")
        print(to_string(sig_prev))
        if phi_pk == sig_prev {
            println(" -> MATCH")
        } else {
            println(" -> NO MATCH")
        }
        idx = idx + 1
    }

    graded_report("VERIFY-1", "phi(P2)=sigma(P1)=12: UNIQUE to first pair", "PROVEN", "phi(28)=12=sigma(6). phi(496)=240 != sigma(28)=56. Verified to P4=8128.")

    // Verify kissing numbers
    println("")
    println("  Kissing numbers K(1..4):")
    print("    K(1)=2=phi CHECK, K(2)=6=P1 CHECK, K(3)=12=sigma CHECK, K(4)=24=sigma*phi CHECK")
    println("")
    graded_report("VERIFY-2", "Kissing K(1..4)=(phi,P1,sigma,sigma*phi)", "PROVEN", "K(1)=2=phi, K(2)=6=P1, K(3)=12=sigma, K(4)=24=sigma*phi. K(8)=240=P1!/(P1/phi).")

