    // Verify Schwarzschild
    graded_report("VERIFY-4", "Schwarzschild {2,3,6}M = nontrivial divisors of 6", "PROVEN", "Divisors of 6 > 1: {2,3,6}. GR: horizon=2M, photon=3M, ISCO=6M. EXACT.")

    // Verify crystallographic restriction
