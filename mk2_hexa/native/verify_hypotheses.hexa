// mk2_hexa/native/verify_hypotheses.hexa
// Consolidated port of shared/calc/verify_new_major_hypotheses{,_2.._12}.py
//
// CLI: hexa verify_hypotheses.hexa [round1|round2|...|round12|all|summary|help]
//
// 12 waves of n=6 major hypothesis verification (224 hypotheses total)
// Faithfully ports mathematical verification logic from Python originals.

// =====================================================================
// --- MATH UTILITIES ---
// =====================================================================

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn abs_i(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 20 {
        g = (g + x / g) / 2.0
        i = i + 1
    }
    return g
}

fn ln_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut sum = 0.0
    let mut term = (x - 1.0) / (x + 1.0)
    let t2 = term * term
    let mut k: i64 = 1
    while k <= 20 {
        sum = sum + term / to_float(k)
        term = term * t2
        k = k + 2
    }
    return 2.0 * sum
}

fn pow_f(base: f64, exp: f64) -> f64 {
    if base <= 0.0 { return 0.0 }
    return exp_f(exp * ln_f(base))
}

fn exp_f(x: f64) -> f64 {
    let mut sum = 1.0
    let mut term = 1.0
    let mut i: i64 = 1
    while i <= 30 {
        term = term * x / to_float(i)
        sum = sum + term
        i = i + 1
    }
    return sum
}

fn pow_i(base: i64, exp: i64) -> i64 {
    if exp <= 0 { return 1 }
    let mut r: i64 = 1
    let mut i: i64 = 0
    while i < exp {
        r = r * base
        i = i + 1
    }
    return r
}

fn factorial(n: i64) -> i64 {
    if n <= 1 { return 1 }
    let mut r: i64 = 1
    let mut i: i64 = 2
    while i <= n {
        r = r * i
        i = i + 1
    }
    return r
}

// =====================================================================
// --- NUMBER THEORY FUNCTIONS ---
// =====================================================================

fn divisor_sum(m: i64) -> i64 {
    if m <= 0 { return 0 }
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i * i <= m {
        if m - (m / i) * i == 0 {
            s = s + i
            if i != m / i {
                s = s + m / i
            }
        }
        i = i + 1
    }
    return s
}

fn divisor_count(m: i64) -> i64 {
    if m <= 0 { return 0 }
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i * i <= m {
        if m - (m / i) * i == 0 {
            c = c + 1
            if i != m / i {
                c = c + 1
            }
        }
        i = i + 1
    }
    return c
}

fn euler_totient(m: i64) -> i64 {
    if m <= 1 { return 1 }
    let mut result = m
    let mut temp = m
    let mut p: i64 = 2
    while p * p <= temp {
        if temp - (temp / p) * p == 0 {
            while temp - (temp / p) * p == 0 {
                temp = temp / p
            }
            result = result - result / p
        }
        p = p + 1
    }
    if temp > 1 {
        result = result - result / temp
    }
    return result
}

fn sopfr_f(m: i64) -> i64 {
    if m <= 1 { return 0 }
    let mut s: i64 = 0
    let mut temp = m
    let mut p: i64 = 2
    while p * p <= temp {
        while temp - (temp / p) * p == 0 {
            s = s + p
            temp = temp / p
        }
        p = p + 1
    }
    if temp > 1 {
        s = s + temp
    }
    return s
}

fn radical(m: i64) -> i64 {
    if m <= 1 { return 1 }
    let mut r: i64 = 1
    let mut temp = m
    let mut p: i64 = 2
    while p * p <= temp {
        if temp - (temp / p) * p == 0 {
            r = r * p
            while temp - (temp / p) * p == 0 {
                temp = temp / p
            }
        }
        p = p + 1
    }
    if temp > 1 {
        r = r * temp
    }
    return r
}

fn omega_func(m: i64) -> i64 {
    if m <= 1 { return 0 }
    let mut c: i64 = 0
    let mut temp = m
    let mut p: i64 = 2
    while p * p <= temp {
        if temp - (temp / p) * p == 0 {
            c = c + 1
            while temp - (temp / p) * p == 0 {
                temp = temp / p
            }
        }
        p = p + 1
    }
    if temp > 1 {
        c = c + 1
    }
    return c
}

fn is_perfect(m: i64) -> bool {
    if m <= 1 { return false }
    return divisor_sum(m) == 2 * m
}

// =====================================================================
// --- n=6 CORE CONSTANTS ---
// =====================================================================

fn N6() -> i64 { return 6 }
fn SIGMA() -> i64 { return 12 }
fn TAU() -> i64 { return 4 }
fn PHI() -> i64 { return 2 }
fn SOPFR() -> i64 { return 5 }
fn OMEGA() -> i64 { return 2 }
fn P1() -> i64 { return 6 }
fn P2() -> i64 { return 28 }
fn P3() -> i64 { return 496 }
fn P4() -> i64 { return 8128 }

// =====================================================================
// --- REPORTING ---
// =====================================================================

fn sep72() {
    println("========================================================================")
}

fn sep_dash() {
    println("------------------------------------------------------------------------")
}

fn report(hid: string, title: string, grade: string, detail: string) {
    println("")
    sep72()
    print("  ")
    print(hid)
    print(": ")
    println(title)
    print("  Grade: ")
    println(grade)
    print("  ")
    println(detail)
}

// Grade counters (parallel lists pattern)
let mut g_proven: i64 = 0
let mut g_fact: i64 = 0
let mut g_struct: i64 = 0
let mut g_approx: i64 = 0
let mut g_total: i64 = 0

fn count_grade(grade: string) {
    g_total = g_total + 1
    if grade == "PROVEN" { g_proven = g_proven + 1 }
    if grade == "FACT" { g_fact = g_fact + 1 }
    if grade == "STRUCTURAL" { g_struct = g_struct + 1 }
    if grade == "APPROXIMATE" { g_approx = g_approx + 1 }
}

fn reset_counts() {
    g_proven = 0
    g_fact = 0
    g_struct = 0
    g_approx = 0
    g_total = 0
}

fn print_summary(wave_name: string) {
    println("")
    sep72()
    print("  SUMMARY: ")
    println(wave_name)
    sep72()
    print("  Total: ")
    println(to_string(g_total))
    print("  PROVEN:      ")
    println(to_string(g_proven))
    print("  FACT:        ")
    println(to_string(g_fact))
    print("  STRUCTURAL:  ")
    println(to_string(g_struct))
    print("  APPROXIMATE: ")
    println(to_string(g_approx))
    let green = g_proven + g_fact + g_struct
    print("  Green total: ")
    print(to_string(green))
    print("/")
    println(to_string(g_total))
}

fn graded_report(hid: string, title: string, grade: string, detail: string) {
    report(hid, title, grade, detail)
    count_grade(grade)
}

