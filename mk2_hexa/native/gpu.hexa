// mk2_hexa/native/gpu.hexa — GPU 아키텍처 n=6 검증
// Rust 원본: src/gpu/ (mod.rs, buffer_pool.rs, fallback.rs)
// 실행: hexa gpu.hexa verify <arch_params>
//
// CLI:
//   hexa gpu.hexa verify <n> <d>         — n점 d차원 데이터로 거리/MI/KNN 검증
//   hexa gpu.hexa distance <data> <n> <d> — 유클리드 거리 행렬 (하삼각)
//   hexa gpu.hexa mi <data> <n> <d> <bins> — 상호 정보량 행렬
//   hexa gpu.hexa knn <n> <k>             — K-최근접 이웃 인덱스

// ─── comptime 상수 ───
comptime const N = 6
comptime const sigma = 12
comptime const phi = 2
comptime const tau = 4
comptime const j2 = 24
comptime const sigma_sq = 144

// ────────────────────────────────────────────────────────────────
//  버퍼 풀 (buffer_pool.rs 포팅)
// ────────────────────────────────────────────────────────────────

struct BufferPool {
    pool: str,
    default_capacity: int
}

fn bufpool_new(cap: int) -> BufferPool {
    BufferPool { pool: [], default_capacity: cap }
}

fn bufpool_get(bp: BufferPool) {
    if len(bp.pool) > 0 {
        // 마지막 버퍼 반환 (pool에서 pop은 불가 — 새 빈 배열 반환)
        []
    } else {
        []
    }
}

fn bufpool_available(bp: BufferPool) -> int {
    len(bp.pool)
}

// ────────────────────────────────────────────────────────────────
//  유클리드 거리 행렬 — 하삼각 (fallback.rs 포팅)
//  data: n*d 평탄 배열, 반환: n*(n-1)/2 거리
// ────────────────────────────────────────────────────────────────

fn distance_matrix(data, n: int, d: int) {
    let pair_count = n * (n - 1) / 2
    let mut result = []
    // (i,j) with i > j
    let mut i = 1
    while i < n {
        let mut j = 0
        while j < i {
            let mut sum_sq = 0.0
            let mut k = 0
            while k < d {
                let diff = data[i * d + k] - data[j * d + k]
                sum_sq = sum_sq + diff * diff
                k = k + 1
            }
            result = result.push(sqrt(sum_sq))
            j = j + 1
        }
        i = i + 1
    }
    result
}

fn sqrt(x: float) -> float {
    // 뉴턴법 sqrt
    if x <= 0.0 { return 0.0 }
    let mut guess = x / 2.0
    if guess < 1.0 { guess = 1.0 }
    let mut iter = 0
    while iter < 20 {
        let next = (guess + x / guess) / 2.0
        let diff = next - guess
        let abs_diff = if diff < 0.0 { 0.0 - diff } else { diff }
        if abs_diff < 0.0000001 { return next }
        guess = next
        iter = iter + 1
    }
    guess
}

// ────────────────────────────────────────────────────────────────
//  상호 정보량 행렬 (fallback.rs mutual_info_cpu 포팅)
//  data: n*d, n_bins: 히스토그램 빈 수, 반환: d*d MI 행렬
// ────────────────────────────────────────────────────────────────

fn mutual_info(data, n: int, d: int, n_bins: int) {
    // 1) 차원별 min/max
    let mut mins = []
    let mut maxs = []
    let mut dim = 0
    while dim < d {
        let mut mn = 999999999.0
        let mut mx = -999999999.0
        let mut s = 0
        while s < n {
            let v = data[s * d + dim]
            if v < mn { mn = v }
            if v > mx { mx = v }
            s = s + 1
        }
        mins = mins.push(mn)
        maxs = maxs.push(mx)
        dim = dim + 1
    }

    // 2) 빈 인덱스 사전 계산: bins[s*d+dim]
    let mut bins = []
    let mut s = 0
    while s < n {
        let mut dim2 = 0
        while dim2 < d {
            let range = maxs[dim2] - mins[dim2]
            let b = if range <= 0.0 {
                0
            } else {
                let raw = to_int((data[s * d + dim2] - mins[dim2]) / range * n_bins)
                if raw >= n_bins { n_bins - 1 } else { raw }
            }
            bins = bins.push(b)
            dim2 = dim2 + 1
        }
        s = s + 1
    }

    // 3) MI 행렬 d*d
    let nb = n_bins
    let mut mi = []
    let mut di = 0
    while di < d {
        let mut dj = 0
        while dj < d {
            if di == dj {
                mi = mi.push(0.0)
                dj = dj + 1
                continue
            }
            // 결합 히스토그램
            let mut joint = []
            let mut init_k = 0
            while init_k < nb * nb {
                joint = joint.push(0)
                init_k = init_k + 1
            }
            let mut s2 = 0
            while s2 < n {
                let bi = bins[s2 * d + di]
                let bj = bins[s2 * d + dj]
                joint[bi * nb + bj] = joint[bi * nb + bj] + 1
                s2 = s2 + 1
            }
            // 주변 분포
            let mut margin_i = []
            let mut margin_j = []
            let mut m_init = 0
            while m_init < nb {
                margin_i = margin_i.push(0)
                margin_j = margin_j.push(0)
                m_init = m_init + 1
            }
            let mut bi2 = 0
            while bi2 < nb {
                let mut bj2 = 0
                while bj2 < nb {
                    let cnt = joint[bi2 * nb + bj2]
                    margin_i[bi2] = margin_i[bi2] + cnt
                    margin_j[bj2] = margin_j[bj2] + cnt
                    bj2 = bj2 + 1
                }
                bi2 = bi2 + 1
            }
            // MI 계산
            let n_f = to_float(n)
            let mut mi_val = 0.0
            let mut bi3 = 0
            while bi3 < nb {
                let pi = margin_i[bi3] / n_f
                if pi > 0.0 {
                    let mut bj3 = 0
                    while bj3 < nb {
                        let pj = margin_j[bj3] / n_f
                        let pij = joint[bi3 * nb + bj3] / n_f
                        if pij > 0.0 && pj > 0.0 {
                            mi_val = mi_val + pij * ln(pij / (pi * pj))
                        }
                        bj3 = bj3 + 1
                    }
                }
                bi3 = bi3 + 1
            }
            let clamped = if mi_val < 0.0 { 0.0 } else { mi_val }
            mi = mi.push(clamped)
            dj = dj + 1
        }
        di = di + 1
    }
    mi
}

fn ln(x: float) -> float {
    // 자연 로그 근사 (x > 0)
    if x <= 0.0 { return -999999.0 }
    // ln(x) via Newton: y = ln(x) => e^y = x
    // 거듭 축소: x = m * 2^k, ln(x) = ln(m) + k*ln2
    let ln2 = 0.6931471805599453
    let mut val = x
    let mut k = 0
    while val > 2.0 {
        val = val / 2.0
        k = k + 1
    }
    while val < 1.0 {
        val = val * 2.0
        k = k - 1
    }
    // ln(val) where val in [1,2): series ln(1+u) = u - u^2/2 + u^3/3 - ...
    let u = val - 1.0
    let mut result = 0.0
    let mut term = u
    let mut sign = 1.0
    let mut i = 1
    while i <= 20 {
        result = result + sign * term / i
        term = term * u
        sign = 0.0 - sign
        i = i + 1
    }
    result + k * ln2
}

// ────────────────────────────────────────────────────────────────
//  K-최근접 이웃 (fallback.rs knn_cpu 포팅)
// ────────────────────────────────────────────────────────────────

fn knn(dist, n: int, k: int) {
    // dist: 하삼각 n*(n-1)/2, 반환: n*k 인덱스
    let mut result = []
    let mut i = 0
    while i < n {
        // i번째 점에서 모든 다른 점까지 거리 수집
        let mut dists = []
        let mut j = 0
        while j < n {
            if j == i {
                j = j + 1
                continue
            }
            let big = if i > j { i } else { j }
            let small = if i > j { j } else { i }
            let flat_idx = big * (big - 1) / 2 + small
            dists = dists.push([j, dist[flat_idx]])
            j = j + 1
        }
        // 선택 정렬로 상위 k개
        let mut s = 0
        while s < k && s < len(dists) {
            let mut min_pos = s
            let mut t = s + 1
            while t < len(dists) {
                if dists[t].d < dists[min_pos].d {
                    min_pos = t
                }
                t = t + 1
            }
            if min_pos != s {
                let tmp = dists[s]
                dists[s] = dists[min_pos]
                dists[min_pos] = tmp
            }
            result = result.push(dists[s].idx)
            s = s + 1
        }
        i = i + 1
    }
    result
}

// ────────────────────────────────────────────────────────────────
//  n=6 아키텍처 검증
// ────────────────────────────────────────────────────────────────

fn verify_n6_architecture(n_points: int, dims: int) -> bool {
    // n=6 대칭 검증: n점 d차원 데이터 생성 후 거리 행렬의 패턴 확인
    let mut data = []
    let mut i = 0
    while i < n_points * dims {
        // 결정론적 의사 난수
        let val = to_float((i * 7 + 3) % 100) / 100.0
        data = data.push(val)
        i = i + 1
    }
    let dist = distance_matrix(data, n_points, dims)
    let expected_pairs = n_points * (n_points - 1) / 2
    len(dist) == expected_pairs
}

// ────────────────────────────────────────────────────────────────
//  검증
// ────────────────────────────────────────────────────────────────

// 거리 테스트: (0,0) and (3,4) -> distance = 5
let test_data = [0.0, 0.0, 3.0, 4.0]
let test_dist = distance_matrix(test_data, 2, 2)
assert len(test_dist) == 1
let dist_err = test_dist[0] - 5.0
let abs_err = if dist_err < 0.0 { 0.0 - dist_err } else { dist_err }
assert abs_err < 0.001

// sqrt 테스트
let s25 = sqrt(25.0)
let s_err = s25 - 5.0
let abs_s = if s_err < 0.0 { 0.0 - s_err } else { s_err }
assert abs_s < 0.001

// 아키텍처 검증
assert verify_n6_architecture(N, phi)

// 버퍼 풀 테스트
let bp = bufpool_new(1024)
assert bufpool_available(bp) == 0

println("=== gpu verified ===")
println("distance(0,0)-(3,4):", test_dist[0])
println("sqrt(25):", s25)
println("n6_arch_verify(6,2):", verify_n6_architecture(N, phi))

