// mk2_hexa/native/history.hexa — 스캔 히스토리 기록 + 렌즈 성능 통계 (mk2 hexa)
// 실행: hexa mk2_hexa/native/history.hexa <command> [args...]
// 명령:
//   record <domain> <lenses_csv> <discoveries_csv>  — 스캔 레코드 기록
//   load <domain>                                    — 도메인 레코드 로드
//   stats <domain>                                   — 도메인 통계 계산
//   affinity <domain>                                — 렌즈 친화도 분석
//   recommend <domain> [serendipity_ratio]            — 렌즈 추천
//   help                                             — 사용법

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {}
    return v
}

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(to_float(s)) } catch e {}
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

fn min_f(a: f64, b: f64) -> f64 {
    if a < b { return a }
    return b
}

fn list_contains(lst: list, item: string) -> bool {
    let mut i: i64 = 0
    while i < lst.len() {
        if to_string(lst[i]) == item { return true }
        i = i + 1
    }
    return false
}

fn timestamp_now() -> string {
    let mut ts = "0"
    try {
        ts = exec("date", ["+%s"])
        ts = ts.trim()
    } catch e {}
    return ts
}

// ═══════════════════════════════════════════════════════════
// ─── CONSTANTS ───
// ═══════════════════════════════════════════════════════════

let HISTORY_DIR = "shared/history"
let MIN_LENSES: i64 = 4
let MAX_LENSES: i64 = 40

let COLD_START_LENSES = ["consciousness", "topology", "void", "thermo", "evolution", "network", "boundary", "triangle"]

// ═══════════════════════════════════════════════════════════
// ─── RECORDER ───
// ═══════════════════════════════════════════════════════════

// Record format: id|timestamp|domain|lenses_csv|discoveries_csv|consensus
fn format_record(domain: string, lenses: list, discoveries: list) -> string {
    let ts = timestamp_now()
    let id = domain + "-" + ts

    let mut lenses_str = ""
    let mut i: i64 = 0
    while i < lenses.len() {
        if i > 0 { lenses_str = lenses_str + "," }
        lenses_str = lenses_str + to_string(lenses[i])
        i = i + 1
    }

    let mut disc_str = ""
    let mut j: i64 = 0
    while j < discoveries.len() {
        if j > 0 { disc_str = disc_str + "," }
        disc_str = disc_str + to_string(discoveries[j])
        j = j + 1
    }

    return id + "|" + ts + "|" + domain + "|" + lenses_str + "|" + disc_str + "|6"
}

fn append_record(domain: string, lenses: list, discoveries: list) {
    try { exec("mkdir", ["-p", HISTORY_DIR]) } catch e {}
    let fpath = HISTORY_DIR + "/" + domain + ".log"
    let line = format_record(domain, lenses, discoveries)
    let mut existing = ""
    try { existing = read_file(fpath) } catch e {}
    write_file(fpath, existing + line + "\n")
}

fn load_records(domain: string) -> list {
    let fpath = HISTORY_DIR + "/" + domain + ".log"
    if file_exists(fpath) == false { return [] }
    let content = read_file(fpath)
    if content.trim().len() == 0 { return [] }
    let lines = content.split("\n")
    let mut records = []
    let mut i: i64 = 0
    while i < lines.len() {
        let line = to_string(lines[i]).trim()
        if line.len() > 0 {
            let parts = line.split("|")
            if parts.len() >= 6 {
                let id = to_string(parts[0])
                let ts = to_string(parts[1])
                let dom = to_string(parts[2])
                let lenses_csv = to_string(parts[3])
                let disc_csv = to_string(parts[4])
                let consensus = to_string(parts[5])
                let lenses = lenses_csv.split(",")
                let mut discs = []
                if disc_csv.len() > 0 {
                    discs = disc_csv.split(",")
                }
                records = records + [[id, ts, dom, lenses, discs, consensus]]
            }
        }
        i = i + 1
    }
    return records
}

// ═══════════════════════════════════════════════════════════
// ─── STATS ───
// ═══════════════════════════════════════════════════════════

// Compute domain stats from records
// Returns: [total_scans, total_discoveries, lens_stats_list]
// lens_stats_list: [[lens_name, used_count, contributed_count, hit_rate], ...]
fn compute_stats(records: list) -> list {
    let total_scans = records.len()
    let mut total_disc: i64 = 0
    // Parallel lists for lens tracking
    let mut lens_names = []
    let mut lens_used = []
    let mut lens_contributed = []

    let mut i: i64 = 0
    while i < to_int(to_float(records.len())) {
        let rec = records[i]
        let lenses = rec[3]
        let discs = rec[4]
        let n_disc = to_int(to_float(discs.len()))
        // Check if discovery list has actual content (not just empty string)
        let mut has_disc = false
        if n_disc > 0 {
            if to_string(discs[0]).trim().len() > 0 {
                has_disc = true
                total_disc = total_disc + n_disc
            }
        }

        let mut li: i64 = 0
        while li < to_int(to_float(lenses.len())) {
            let lens = to_string(lenses[li]).trim()
            if lens.len() > 0 {
                // Find or add lens
                let mut idx: i64 = 0 - 1
                let mut si: i64 = 0
                while si < lens_names.len() {
                    if to_string(lens_names[si]) == lens { idx = si }
                    si = si + 1
                }
                if idx < 0 {
                    lens_names = lens_names + [lens]
                    lens_used = lens_used + [1]
                    if has_disc {
                        lens_contributed = lens_contributed + [1]
                    } else {
                        lens_contributed = lens_contributed + [0]
                    }
                } else {
                    lens_used[idx] = to_int(to_float(lens_used[idx])) + 1
                    if has_disc {
                        lens_contributed[idx] = to_int(to_float(lens_contributed[idx])) + 1
                    }
                }
            }
            li = li + 1
        }
        i = i + 1
    }

    // Build stats list
    let mut stats = []
    let mut si: i64 = 0
    while si < lens_names.len() {
        let name = to_string(lens_names[si])
        let used = to_int(to_float(lens_used[si]))
        let contrib = to_int(to_float(lens_contributed[si]))
        let hr = if used > 0 { to_float(contrib) / to_float(used) } else { 0.0 }
        stats = stats + [[name, used, contrib, hr]]
        si = si + 1
    }

    return [total_scans, total_disc, stats]
}

// ═══════════════════════════════════════════════════════════
// ─── AFFINITY ───
// ═══════════════════════════════════════════════════════════

// Compute lens co-occurrence in discovery-producing scans
// Returns: [[lens_a, lens_b, affinity], ...]
fn compute_affinity(records: list) -> list {
    // Filter to discovery-producing records
    let mut disc_records = []
    let mut i: i64 = 0
    while i < to_int(to_float(records.len())) {
        let rec = records[i]
        let discs = rec[4]
        if to_int(to_float(discs.len())) > 0 {
            if to_string(discs[0]).trim().len() > 0 {
                disc_records = disc_records + [rec]
            }
        }
        i = i + 1
    }
    let total = to_int(to_float(disc_records.len()))
    if total == 0 { return [] }

    // Count pairs
    let mut pair_keys = []
    let mut pair_counts = []
    let mut ri: i64 = 0
    while ri < total {
        let rec = disc_records[ri]
        let lenses = rec[3]
        let mut ai: i64 = 0
        while ai < to_int(to_float(lenses.len())) {
            let mut bi: i64 = ai + 1
            while bi < to_int(to_float(lenses.len())) {
                let a = to_string(lenses[ai]).trim()
                let b = to_string(lenses[bi]).trim()
                // Canonical order
                let mut key = a + "," + b
                if a > b { key = b + "," + a }
                // Find or add
                let mut found: i64 = 0 - 1
                let mut ki: i64 = 0
                while ki < pair_keys.len() {
                    if to_string(pair_keys[ki]) == key { found = ki }
                    ki = ki + 1
                }
                if found < 0 {
                    pair_keys = pair_keys + [key]
                    pair_counts = pair_counts + [1]
                } else {
                    pair_counts[found] = to_int(to_float(pair_counts[found])) + 1
                }
                bi = bi + 1
            }
            ai = ai + 1
        }
        ri = ri + 1
    }

    // Build result
    let mut result = []
    let mut pi: i64 = 0
    while pi < pair_keys.len() {
        let key = to_string(pair_keys[pi])
        let parts = key.split(",")
        let aff = to_float(pair_counts[pi]) / to_float(total)
        result = result + [[to_string(parts[0]), to_string(parts[1]), aff]]
        pi = pi + 1
    }
    return result
}

// ═══════════════════════════════════════════════════════════
// ─── RECOMMENDER ───
// ═══════════════════════════════════════════════════════════

fn add_serendipity(sel: list, domain: string, ratio: f64) -> list {
    let mut result = sel
    let seed_bytes = domain.split("")
    let mut seed: i64 = 0
    let mut sb: i64 = 0
    while sb < seed_bytes.len() {
        seed = seed + sb + 1
        sb = sb + 1
    }
    let count = to_int(to_float(sel.len()) * ratio + 1.0)
    let mut added: i64 = 0
    let mut sdi: i64 = 0
    while sdi < COLD_START_LENSES.len() {
        if added < count {
            let idx = (seed + sdi) % COLD_START_LENSES.len()
            let lens = to_string(COLD_START_LENSES[idx])
            if list_contains(result, lens) == false {
                result = result + [lens]
                added = added + 1
            }
        }
        sdi = sdi + 1
    }
    return result
}

fn enforce_bounds(sel: list) -> list {
    let mut result = sel
    // Min: pad from cold start
    let mut p: i64 = 0
    while result.len() < 4 {
        let c = to_string(COLD_START_LENSES[p])
        if list_contains(result, c) == false {
            result = result + [c]
        }
        p = p + 1
        if p >= COLD_START_LENSES.len() { return result }
    }
    // Max: truncate
    if result.len() > 40 {
        let mut tr = []
        let mut i: i64 = 0
        while i < 40 {
            tr = tr + [result[i]]
            i = i + 1
        }
        return tr
    }
    return result
}

fn select_from_stats(records: list) -> list {
    let stats_result = compute_stats(records)
    let lens_stats = stats_result[2]
    let mut candidates = []
    let mut ci: i64 = 0
    while ci < to_int(to_float(lens_stats.len())) {
        let ls = lens_stats[ci]
        let hr = to_float(ls[3])
        if hr > 0.05 {
            candidates = candidates + [to_string(ls[0])]
        }
        ci = ci + 1
    }
    return candidates
}

fn recommend_lenses(domain: string, serendipity_ratio: f64) -> list {
    let records = load_records(domain)
    let mut selected = []
    let mut reason = ""

    if to_int(to_float(records.len())) > 0 {
        selected = select_from_stats(records)
        reason = "domain '" + domain + "': " + to_string(selected.len()) + " lenses with hit_rate>0.05"
    } else {
        let mut ci3: i64 = 0
        while ci3 < COLD_START_LENSES.len() {
            selected = selected + [to_string(COLD_START_LENSES[ci3])]
            ci3 = ci3 + 1
        }
        reason = "cold start for '" + domain + "': using default 8 lenses"
    }

    selected = add_serendipity(selected, domain, serendipity_ratio)
    selected = enforce_bounds(selected)

    return [selected, reason]
}

// ═══════════════════════════════════════════════════════════
// ─── CLI ───
// ═══════════════════════════════════════════════════════════

fn show_help() {
    println("history.hexa — 스캔 히스토리 + 렌즈 성능 통계 (mk2 hexa)")
    println("")
    println("Usage:")
    println("  hexa history.hexa record <domain> <lenses_csv> <disc_csv>")
    println("  hexa history.hexa load <domain>")
    println("  hexa history.hexa stats <domain>")
    println("  hexa history.hexa affinity <domain>")
    println("  hexa history.hexa recommend <domain> [serendipity_ratio]")
    println("  hexa history.hexa help")
    println("")
    println("Records stored in: " + HISTORY_DIR + "/<domain>.log")
}

let cli_args = args()
let mut cmd = "help"
if cli_args.len() > 2 {
    cmd = to_string(cli_args[2])
}

if cmd == "help" {
    show_help()
}

if cmd == "record" {
    if cli_args.len() < 6 {
        println("Error: record requires <domain> <lenses_csv> <disc_csv>")
    } else {
        let domain = to_string(cli_args[3])
        let lenses = to_string(cli_args[4]).split(",")
        let discs = to_string(cli_args[5]).split(",")
        append_record(domain, lenses, discs)
        println("Recorded scan for domain '" + domain + "' (" + to_string(lenses.len()) + " lenses, " + to_string(discs.len()) + " discoveries)")
    }
}

if cmd == "load" {
    if cli_args.len() < 4 {
        println("Error: load requires <domain>")
    } else {
        let domain = to_string(cli_args[3])
        let records = load_records(domain)
        println("=== History for '" + domain + "' (" + to_string(to_int(to_float(records.len()))) + " records) ===")
        let mut i: i64 = 0
        while i < to_int(to_float(records.len())) {
            let rec = records[i]
            println(to_string(rec[0]) + " | lenses=" + to_string(to_int(to_float(rec[3].len()))) + " disc=" + to_string(to_int(to_float(rec[4].len()))))
            i = i + 1
        }
    }
}

if cmd == "stats" {
    if cli_args.len() < 4 {
        println("Error: stats requires <domain>")
    } else {
        let domain = to_string(cli_args[3])
        let records = load_records(domain)
        let stats_result = compute_stats(records)
        println("=== Stats for '" + domain + "' ===")
        println("Total scans:      " + to_string(stats_result[0]))
        println("Total discoveries: " + to_string(stats_result[1]))
        let lens_stats = stats_result[2]
        println("Lens performance:")
        let mut i: i64 = 0
        while i < to_int(to_float(lens_stats.len())) {
            let ls = lens_stats[i]
            println("  " + to_string(ls[0]) + ": used=" + to_string(ls[1]) + " contrib=" + to_string(ls[2]) + " hit_rate=" + to_string(ls[3]))
            i = i + 1
        }
    }
}

if cmd == "affinity" {
    if cli_args.len() < 4 {
        println("Error: affinity requires <domain>")
    } else {
        let domain = to_string(cli_args[3])
        let records = load_records(domain)
        let affinities = compute_affinity(records)
        println("=== Lens Affinity for '" + domain + "' ===")
        let mut i: i64 = 0
        while i < to_int(to_float(affinities.len())) {
            let aff = affinities[i]
            println("  " + to_string(aff[0]) + " <-> " + to_string(aff[1]) + ": " + to_string(aff[2]))
            i = i + 1
        }
    }
}

if cmd == "recommend" {
    if cli_args.len() < 4 {
        println("Error: recommend requires <domain>")
    } else {
        let domain = to_string(cli_args[3])
        let mut ser_ratio = 0.2
        if cli_args.len() > 4 {
            ser_ratio = safe_float(to_string(cli_args[4]))
        }
        let result = recommend_lenses(domain, ser_ratio)
        let lenses = result[0]
        let reason = to_string(result[1])
        println("=== Lens Recommendation for '" + domain + "' ===")
        println("Reason: " + reason)
        println("Lenses (" + to_string(to_int(to_float(lenses.len()))) + "):")
        let mut i: i64 = 0
        while i < to_int(to_float(lenses.len())) {
            println("  " + to_string(i + 1) + ". " + to_string(lenses[i]))
            i = i + 1
        }
    }
}
