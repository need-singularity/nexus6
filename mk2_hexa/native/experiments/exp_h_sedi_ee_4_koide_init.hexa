// Ported from tecs-l/experiments/experiment_h_sedi_ee_4_koide_init.py — 2026-04-10
// H-SEDI-EE-4: Koide ratio (m1+m2+m3)/(sqrt(m1)+sqrt(m2)+sqrt(m3))^2 = 2/3 for leptons.
// Torch MoE training skipped (Track B).
// Verification: confirm the Koide formula yields ≈2/3 for empirical lepton masses.

println("======================================================================")
println("  H-SEDI-EE-4: Koide lepton-mass ratio (arith-only port)")
println("======================================================================")

fn koide(m1: float, m2: float, m3: float) -> float {
    let num = m1 + m2 + m3
    let s = sqrt(m1) + sqrt(m2) + sqrt(m3)
    num / (s * s)
}

// PDG 2020 values (MeV/c^2)
let m_e   = 0.5109989461
let m_mu  = 105.6583745
let m_tau = 1776.86

let k_leptons = koide(m_e, m_mu, m_tau)
println("")
println("  m_e   = " + to_string(m_e)   + " MeV")
println("  m_mu  = " + to_string(m_mu)  + " MeV")
println("  m_tau = " + to_string(m_tau) + " MeV")
println("  Koide(e, mu, tau) = " + to_string(k_leptons))
println("  target 2/3        = " + to_string(2.0 / 3.0))

let delta = k_leptons - (2.0 / 3.0)
let abs_delta = if delta < 0.0 { 0.0 - delta } else { delta }
println("  |delta|            = " + to_string(abs_delta))

// Also verify trivial bounds: min 1/3 (equal masses), max 1 (one mass dominant)
let k_equal = koide(1.0, 1.0, 1.0)
let k_dominant = koide(1.0, 1.0e-10, 1.0e-10)
println("")
println("  Koide(1,1,1)     = " + to_string(k_equal)    + "  (expect 1/3)")
println("  Koide(1,eps,eps) = " + to_string(k_dominant) + "  (expect →1)")

println("")
println("======================================================================")
let h1 = abs_delta < 0.001              // Koide holds to ~3 decimals
let h2_delta = k_equal - (1.0 / 3.0)
let h2_abs = if h2_delta < 0.0 { 0.0 - h2_delta } else { h2_delta }
let h2 = h2_abs < 1.0e-9                 // equal masses → exactly 1/3
let h3 = k_dominant > 0.99               // dominant → ≈1
println("  |Koide_lepton - 2/3| < 0.001 : " + to_string(h1))
println("  Koide(1,1,1) == 1/3          : " + to_string(h2))
println("  Koide dominant > 0.99        : " + to_string(h3))
if h1 && h2 && h3 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
