// Ported from tecs-l/experiments/experiment_why_half_third_sixth.py — 2026-04-10
// Arithmetic core of the H-{1/2,1/3,1/6} hypothesis:
//   "These are the reciprocals of divisors of the perfect number 6; sum = 1."
// The torch MLP / MNIST / CIFAR weight-sweep training loops are .hexanoport (Track B).
//
// CORRECTION vs the original docstring:
//   The docstring says "reciprocals of divisors of 6, sum = 1".
//   Strictly, divisors of 6 are {1,2,3,6} and 1+1/2+1/3+1/6 = 2, not 1.
//   The identity that actually holds is:
//     sum_{d | n, d > 1} 1/d  =  1   for every perfect number n.
//   Equivalent form (from sigma(n) = 2n): sum_{d | n} 1/d = 2, minus 1/1 = 1.
//   This explains why {1/2, 1/3, 1/6} sum to 1 — the divisor d=1 is dropped.
//
// We verify the identity exactly (rational arithmetic via lcm denominator)
// for the first four perfect numbers: 6, 28, 496, 8128.

fn all_divisors_sum(n: int) -> int {
    let mut s = 0
    let mut d = 1
    while d * d <= n {
        if n % d == 0 {
            s = s + d
            if d != n / d { s = s + n / d }
        }
        d = d + 1
    }
    s
}

fn is_perfect(n: int) -> bool {
    all_divisors_sum(n) == 2 * n
}

// Compute sum_{d | n, d > 1} 1/d  as a rational (num, den).
// We use lcm-style accumulation: keep (num, den) in lowest terms is not strictly
// needed — we just compare num == den for the identity sum == 1.
fn gcd(a: int, b: int) -> int {
    let mut x = a  let mut y = b
    while y != 0 { let t = y  y = x % y  x = t }
    if x < 0 { -x } else { x }
}

fn reciprocal_sum_excl_one(n: int) -> [int] {
    // returns [num, den] for sum_{d | n, d > 1} 1/d
    let mut num = 0
    let mut den = 1
    let mut d = 2
    while d <= n {
        if n % d == 0 {
            // add 1/d :  num/den + 1/d = (num*d + den)/(den*d)
            let new_num = num * d + den
            let new_den = den * d
            let g = gcd(new_num, new_den)
            num = new_num / g
            den = new_den / g
        }
        d = d + 1
    }
    [num, den]
}

let perfects = [6, 28, 496, 8128]

println("======================================================================")
println("  Perfect-number reciprocal identity:  sum_{d|n, d>1} 1/d = 1")
println("======================================================================")

let mut all_ok = true
let mut i = 0
while i < len(perfects) {
    let n = perfects[i]
    let is_p = is_perfect(n)
    let r = reciprocal_sum_excl_one(n)
    let num = r[0]
    let den = r[1]
    let eq_one = num == den && num != 0
    let st = if is_p && eq_one { "PASS" } else { "FAIL" }
    let line = "  n=" + to_string(n) + "  perfect=" + to_string(is_p) + "  sum=" + to_string(num) + "/" + to_string(den) + "  " + st
    println(line)
    if !(is_p && eq_one) { all_ok = false }
    i = i + 1
}

// Spot-check a NON-perfect number: n=12 (abundant). Expect sum != 1.
let r12 = reciprocal_sum_excl_one(12)
// divisors of 12 >1: {2,3,4,6,12}  sum = 1/2+1/3+1/4+1/6+1/12 = 6/12+4/12+3/12+2/12+1/12 = 16/12 = 4/3
let twelve_expected_num = 4
let twelve_expected_den = 3
let twelve_ok = r12[0] == twelve_expected_num && r12[1] == twelve_expected_den
let tw_tag = if twelve_ok { "PASS" } else { "FAIL" }
let tw_line = "  n=12 (abundant) sum=" + to_string(r12[0]) + "/" + to_string(r12[1]) + "  expected 4/3  " + tw_tag
println(tw_line)
if !twelve_ok { all_ok = false }

// Spot-check n=10 (deficient): divisors >1: {2,5,10} → 1/2+1/5+1/10 = 5/10+2/10+1/10 = 8/10 = 4/5
let r10 = reciprocal_sum_excl_one(10)
let ten_ok = r10[0] == 4 && r10[1] == 5
let ten_tag = if ten_ok { "PASS" } else { "FAIL" }
let ten_line = "  n=10 (deficient) sum=" + to_string(r10[0]) + "/" + to_string(r10[1]) + "  expected 4/5  " + ten_tag
println(ten_line)
if !ten_ok { all_ok = false }

println("")
if all_ok { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
