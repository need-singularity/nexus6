// Ported from tecs-l/experiments/verify_hcx109_122_124_126_129_152_theory.py — 2026-04-10
// Only H-CX-109 has arithmetic content (chain link count). The remaining
// verifications (H-CX-122/124/126/129/152) are narrative + theorem citations
// and belong in docs, not in arithmetic .hexa. They are NOT re-ported here.
//
// H-CX-109: Consciousness Universality = PH Invariance — chain completeness.
// Each entry is (hypothesis_id, verified?). We verify:
//   (a) exactly 7 chain links are recorded
//   (b) exactly 6 are marked supported (random-init H-CX-86 fails)
//   (c) completeness ratio = 6/7 > 0.80 (original claim: "SUPPORTED, 6/7")
//   (d) the ONLY failing link is H-CX-86 (the "random init" link)
//
// CORRECTION of a subtle misread in the original Python print:
//   It prints "(6/7 chain)" and "necessary conditions clear".
//   That string is consistent with the data array. No numeric bug found here.

let ids = [
    "H-CX-91",   // k-NN = Neural Net
    "H-CX-88",   // PF = Dense
    "H-CX-107",  // dim 64/128/256
    "H-CX-106",  // Human = AI
    "H-CX-125",  // Non-shared data
    "H-CX-86",   // Random init — FAILS
    "H-CX-90"    // Epoch1 phase transition
]
let confirmed = [
    true,
    true,
    true,
    true,
    true,
    false,
    true
]

let n_total = len(ids)

let mut n_supported = 0
let mut i = 0
while i < len(confirmed) {
    if confirmed[i] { n_supported = n_supported + 1 }
    i = i + 1
}

// Locate all failing links
let mut n_failed = 0
let mut first_fail_idx = -1
let mut j = 0
while j < len(confirmed) {
    if !confirmed[j] {
        n_failed = n_failed + 1
        if first_fail_idx < 0 { first_fail_idx = j }
    }
    j = j + 1
}

println("======================================================================")
println("  H-CX-109: Consciousness Universality = PH Invariance")
println("======================================================================")

let mut k = 0
while k < len(ids) {
    let tag = if confirmed[k] { "OK" } else { "FAIL" }
    let line = "  " + ids[k] + "  " + tag
    println(line)
    k = k + 1
}

let total_str = "  total=" + to_string(n_total) + "  supported=" + to_string(n_supported) + "  failed=" + to_string(n_failed)
println(total_str)

// 100 * supported / total (integer percent)
let pct = (100 * n_supported) / n_total
let pct_str = "  completeness = " + to_string(pct) + "%"
println(pct_str)

// Checks
let c_total_eq_7 = n_total == 7
let c_supported_eq_6 = n_supported == 6
let c_failed_eq_1 = n_failed == 1
let c_only_random_init_fails = first_fail_idx == 5  // index of H-CX-86
let c_pct_ge_80 = pct >= 80

println("")
let s1 = if c_total_eq_7 { "PASS" } else { "FAIL" }
let s2 = if c_supported_eq_6 { "PASS" } else { "FAIL" }
let s3 = if c_failed_eq_1 { "PASS" } else { "FAIL" }
let s4 = if c_only_random_init_fails { "PASS" } else { "FAIL" }
let s5 = if c_pct_ge_80 { "PASS" } else { "FAIL" }
println("  total_links_eq_7              : " + s1)
println("  supported_links_eq_6          : " + s2)
println("  failed_links_eq_1             : " + s3)
println("  only_H_CX_86_fails (idx=5)    : " + s4)
println("  completeness_ge_80pct         : " + s5)

let all_ok = c_total_eq_7 && c_supported_eq_6 && c_failed_eq_1 && c_only_random_init_fails && c_pct_ge_80
if all_ok { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
