// Ported from tecs-l/experiments/experiment_h_ee_11_combined_architecture.py — 2026-04-10
// H-EE-11: d=120 (HCN) + 4/3x FFN + 8 heads → >40% savings vs d=128 + 4x FFN.
// Torch training skipped (Track B).
// Arithmetic-only: compute FFN+attn parameter counts for configs A/B/C/D and
// verify the savings claim holds purely from the parameter arithmetic.

println("======================================================================")
println("  H-EE-11: combined arch param savings (arith-only port)")
println("======================================================================")

let VOCAB = 60
let SEQ = 64
let N_LAYERS = 4
let N_HEADS = 8

// Simplified per-layer params (no LN/bias): 4*d^2 (attn) + 2*d*d_ff (ffn)
// + head: d*VOCAB, + embed: (VOCAB+SEQ)*d
fn count(d: int, ff_ratio_num: int, ff_ratio_den: int) -> int {
    let d_ff = d * ff_ratio_num / ff_ratio_den
    let embed = (VOCAB + SEQ) * d
    let attn = 4 * d * d
    let ffn = 2 * d * d_ff
    let per_layer = attn + ffn
    let head = d * VOCAB
    embed + N_LAYERS * per_layer + head
}

// A. d=128, 4x FFN   (standard)
// B. d=120, 4/3 FFN  (combined)
// C. d=120, 4x FFN   (HCN only)
// D. d=128, 4/3 FFN  (activation/bottleneck only)
let pA = count(128, 4, 1)
let pB = count(120, 4, 3)
let pC = count(120, 4, 1)
let pD = count(128, 4, 3)

println("")
println("  A. d=128, 4x   : " + to_string(pA))
println("  B. d=120, 4/3x : " + to_string(pB))
println("  C. d=120, 4x   : " + to_string(pC))
println("  D. d=128, 4/3x : " + to_string(pD))

let savings_B = to_float(pA - pB) / to_float(pA) * 100.0
let savings_C = to_float(pA - pC) / to_float(pA) * 100.0
let savings_D = to_float(pA - pD) / to_float(pA) * 100.0

println("")
println("  B vs A savings: " + to_string(savings_B) + "%")
println("  C vs A savings: " + to_string(savings_C) + "%")
println("  D vs A savings: " + to_string(savings_D) + "%")

// Head dim constraints: 128 must be divisible by N_HEADS=8 → head_dim=16
// 120 must be divisible by N_HEADS=8 → head_dim=15
let head_dim_128 = 128 / 8
let head_dim_120 = 120 / 8
let h128_ok = 128 % 8 == 0
let h120_ok = 120 % 8 == 0

println("")
println("  head_dim d=128 : " + to_string(head_dim_128) + "  (128 div 8: " + to_string(h128_ok) + ")")
println("  head_dim d=120 : " + to_string(head_dim_120) + "  (120 div 8: " + to_string(h120_ok) + ")")

println("")
println("======================================================================")
let h1 = savings_B > 40.0                 // "combined >40% savings" claim
let h2 = savings_B > savings_C            // combined beats HCN-only
let h3 = savings_B > savings_D            // combined beats bottleneck-only
let h4 = h128_ok && h120_ok
println("  combined savings > 40%          : " + to_string(h1))
println("  combined > HCN-only             : " + to_string(h2))
println("  combined > bottleneck-only      : " + to_string(h3))
println("  both head_dim integer           : " + to_string(h4))
if h1 && h2 && h3 && h4 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
