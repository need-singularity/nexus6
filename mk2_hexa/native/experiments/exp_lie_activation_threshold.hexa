// Ported from tecs-l/experiments/experiment_lie_activation_threshold.py — 2026-04-10
// H-LIE-2: Candidate activation thresholds derived from Lie/n=6 structure.
// Torch MoE training skipped (Track B).
// Arithmetic-only: verify all four candidate thresholds and their anchor identities.

println("======================================================================")
println("  H-LIE-2: activation threshold anchors (arith-only port)")
println("======================================================================")

let e_const = 2.718281828459045
let inv_e = 1.0 / e_const
let one_minus_inv_e = 1.0 - inv_e
let one_third = 1.0 / 3.0
let one_half = 0.5

println("")
println("  1/e        = " + to_string(inv_e)           + "  (golden zone center)")
println("  1/3        = " + to_string(one_third)        + "  (tau(6)/sigma(6) = 4/12)")
println("  1/2        = " + to_string(one_half)         + "  (Riemann critical line)")
println("  1 - 1/e    = " + to_string(one_minus_inv_e)  + "  (P!=NP gap, H-CX-15)")

// tau(6)/sigma(6) anchor
let t6 = tau(6)
let s6 = sigma(6)
let ratio_t_s = to_float(t6) / to_float(s6)
println("")
println("  tau(6) = " + to_string(t6) + "  sigma(6) = " + to_string(s6))
println("  tau(6)/sigma(6) = " + to_string(ratio_t_s))

// ADE/G2: 12 roots, ratios of active subsets
let active_3_of_12 = 3.0 / 12.0            // 1/4
let active_4_of_12 = 4.0 / 12.0            // 1/3
let active_6_of_12 = 6.0 / 12.0            // 1/2
println("")
println("## G2 active-ratio lattice (12 roots)")
println("  3/12 = " + to_string(active_3_of_12) + " (= 1/4)")
println("  4/12 = " + to_string(active_4_of_12) + " (= 1/3 — meta fixed point)")
println("  6/12 = " + to_string(active_6_of_12) + " (= 1/2 — Riemann)")

// Checks
let h1_delta = ratio_t_s - one_third
let h1_abs = if h1_delta < 0.0 { 0.0 - h1_delta } else { h1_delta }
let h1 = h1_abs < 1.0e-9              // tau/sigma == 1/3 exactly
let h2_delta = active_4_of_12 - one_third
let h2_abs = if h2_delta < 0.0 { 0.0 - h2_delta } else { h2_delta }
let h2 = h2_abs < 1.0e-9
let h3 = active_6_of_12 == one_half
let h4 = one_minus_inv_e > 0.6 && one_minus_inv_e < 0.64

println("")
println("======================================================================")
println("  tau(6)/sigma(6) == 1/3       : " + to_string(h1))
println("  4/12 == 1/3 (meta fixed pt)  : " + to_string(h2))
println("  6/12 == 1/2 (Riemann line)   : " + to_string(h3))
println("  0.6 < 1-1/e < 0.64           : " + to_string(h4))
if h1 && h2 && h3 && h4 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
