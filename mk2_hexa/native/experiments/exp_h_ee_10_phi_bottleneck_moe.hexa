// Ported from tecs-l/experiments/experiment_h_ee_10_phi_bottleneck_moe.py — 2026-04-10
// H-EE-10: 24 small experts (d_ff=4/3x) gives same total params as 8 standard experts (d_ff=4x).
// Torch MoE training skipped (Track B).
// Arithmetic-only: verify the equal-params identity and note sigma(6)=24-related anchors.

println("======================================================================")
println("  H-EE-10: phi-bottleneck MoE (arith-only port)")
println("======================================================================")

let D_MODEL = 64
let PHI6 = 2

let d_ff_std = 4 * D_MODEL                      // 256
let d_ff_phi = (4 * D_MODEL * PHI6 + 3) / 6     // round(4*64*2/6)=round(85.33)=85 (python uses round→85)

let N_STD = 8
let N_PHI = 24

// Expert params per: 2*d*d_ff (linear up + down)
let expert_std = 2 * D_MODEL * d_ff_std
let expert_phi = 2 * D_MODEL * d_ff_phi

let total_std = N_STD * expert_std
let total_phi = N_PHI * expert_phi

println("")
println("  d_ff_std = " + to_string(d_ff_std) + "   d_ff_phi = " + to_string(d_ff_phi))
println("  experts: std=" + to_string(N_STD) + "  phi=" + to_string(N_PHI))
println("  per-expert params: std=" + to_string(expert_std) + " phi=" + to_string(expert_phi))
println("  total expert params: std=" + to_string(total_std) + " phi=" + to_string(total_phi))

let diff = if total_phi > total_std { total_phi - total_std } else { total_std - total_phi }
let ratio_pct = to_float(diff) / to_float(total_std) * 100.0
println("  total diff         : " + to_string(diff) + " (" + to_string(ratio_pct) + "%)")

// Number-theoretic anchors
// 24 = 4 * sigma(6) / 2 = 2 * sigma(6) (sigma(6)=12, so 24=2*12)
// 24 / 8 = 3 = 3x more experts (anchor: tau(24)=8, tau(8)=4 so 2x)
let n_ratio = N_PHI == 3 * N_STD
let sigma6_anchor = 24 == 2 * sigma(6)

println("")
println("## Number-theoretic anchors")
println("  N_phi == 3 * N_std (24=3*8)    : " + to_string(n_ratio))
println("  24 == 2 * sigma(6)              : " + to_string(sigma6_anchor))
println("  tau(24) = " + to_string(tau(24)) + "  tau(8) = " + to_string(tau(8)))

println("")
println("======================================================================")
// The "equal params" claim: within 5% of total
let h1 = ratio_pct < 5.0
let h2 = n_ratio && sigma6_anchor
println("  total expert params equal (<5%) : " + to_string(h1))
println("  24/8 ratio + sigma(6) anchor    : " + to_string(h2))
if h1 && h2 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
