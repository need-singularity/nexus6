// Ported from tecs-l/experiments/experiment_ppl_tension_correlation.py — 2026-04-10
// H-CX-21: PPL analog ↔ Tension correlation.
// NN training + torchvision skipped (Track B).
// Arithmetic core: PPL ↔ cross-entropy identity  PPL = exp(H),
// plus the uniform-distribution worst-case PPL = K.

fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

println("======================================================================")
println("  H-CX-21: PPL ↔ H identity (arith-only)")
println("======================================================================")

// PPL = exp(H), where H is cross-entropy in nats.
// Uniform K-class classifier: H = ln K, PPL = K.
let K = 10
let H_unif = log(to_float(K))
let PPL_unif = exp(H_unif)

// Best classifier (p → δ): H → 0, PPL → 1
let H_best = log(1.0)           // = 0
let PPL_best = exp(H_best)      // = 1

// Monotonicity: PPL is strictly increasing in H.
let h_vals = [0.0, 0.5, 1.0, 1.5, 2.0, 2.302585]
let mut prev = 0.0 - 1.0
let mut monotone = true
let mut i = 0
while i < len(h_vals) {
    let v = exp(h_vals[i])
    if v <= prev { monotone = false }
    prev = v
    i = i + 1
}

println("  K = " + to_string(K))
println("  H_unif = ln 10        ≈ " + to_string(H_unif))
println("  PPL_unif = exp(H)     ≈ " + to_string(PPL_unif))
println("  PPL_best              = " + to_string(PPL_best))
println("  PPL monotone in H     : " + to_string(monotone))

let checks = [
    abs_f(PPL_unif - to_float(K)) < 0.000001,
    abs_f(PPL_best - 1.0) < 0.000001,
    monotone
]
let ids = ["ppl_unif_eq_K", "ppl_best_eq_1", "ppl_monotone"]

println("")
let mut p = 0
let mut f = 0
let mut k = 0
while k < len(ids) {
    let ok = checks[k]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { p = p + 1 } else { f = f + 1 }
    println("  " + ids[k] + ": " + st)
    k = k + 1
}
println("Total: " + to_string(p+f) + " PASS: " + to_string(p) + " FAIL: " + to_string(f))
if f == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
