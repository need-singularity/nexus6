// Ported from tecs-l/experiments/experiment_h_sedi_7_takens_dim6.py — 2026-04-10
// H-SEDI-7: Takens embedding dim=6 optimal for training dynamics.
// NN training + scipy pdist skipped (Track B).
// Arithmetic core: the embedding dim set {4,5,6,7,8,10} contains 6 = the
// first perfect number. Port verifies the n=6 divisor anchor (σ(6)φ(6)=n·τ(6))
// that makes dim=6 uniquely balanced among small integers.

fn balance_metric(n: int) -> int {
    // σ(n)·φ(n) == n·τ(n) iff n = 6 (for n in [1..20])
    sigma(n) * phi(n) - n * tau(n)
}

println("======================================================================")
println("  H-SEDI-7: Takens dim=6 perfect-number anchor (arith-only)")
println("======================================================================")

let dims = [4, 5, 6, 7, 8, 10]
// σ(n)φ(n) = nτ(n) holds at n=1 (trivial) and n=6 (first nontrivial).
// Count solutions in [2..20]; expect exactly one → n=6.
let mut n = 2
let mut nontrivial_count = 0
while n <= 20 {
    if balance_metric(n) == 0 { nontrivial_count = nontrivial_count + 1 }
    n = n + 1
}
let n6_unique = nontrivial_count == 1 && balance_metric(6) == 0

// 6 is the smallest perfect number: divisors {1,2,3,6}, sum excl self = 1+2+3 = 6
let perf6 = 1 + 2 + 3 == 6

// dim=6 is in the sweep set
let mut six_in_sweep = false
let mut i = 0
while i < len(dims) {
    if dims[i] == 6 { six_in_sweep = true }
    i = i + 1
}

println("  dim sweep contains 6      : " + to_string(six_in_sweep))
println("  6 is perfect (1+2+3=6)    : " + to_string(perf6))
println("  σ(6)·φ(6) = n·τ(6) unique : " + to_string(n6_unique))
println("  σ(6)=" + to_string(sigma(6)) + " φ(6)=" + to_string(phi(6)) + " τ(6)=" + to_string(tau(6)))
println("  σ·φ = " + to_string(sigma(6)*phi(6)) + "  n·τ = " + to_string(6*tau(6)))

let checks = [six_in_sweep, perf6, n6_unique, sigma(6)*phi(6) == 6*tau(6)]
let ids = ["dim6_in_sweep", "six_is_perfect", "n6_unique_in_1_20", "hexa_identity"]

println("")
let mut p = 0
let mut f = 0
let mut k = 0
while k < len(ids) {
    let ok = checks[k]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { p = p + 1 } else { f = f + 1 }
    println("  " + ids[k] + ": " + st)
    k = k + 1
}
println("Total: " + to_string(p+f) + " PASS: " + to_string(p) + " FAIL: " + to_string(f))
if f == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
