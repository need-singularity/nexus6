// Ported from tecs-l/experiments/exp_h449_arch_invariance_cnn.py — 2026-04-10
// H-CX-449: Confusion topology architecture-invariant across MLP/CNN.
// NN training + scipy.stats.spearmanr/kendalltau skipped (Track B).
// Arithmetic core: Spearman ρ / Kendall τ closed-forms on a small fixed
// rank set, plus the r > 0.95 threshold arithmetic.

fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

println("======================================================================")
println("  H-CX-449: rank-correlation closed forms (arith-only)")
println("======================================================================")

// Perfect agreement on 10 items → Spearman ρ = 1.
// Reversed ranking → ρ = -1.
// Worst-case single swap on 10 items:
//   Σd_i² = 2 (one adjacent swap squared twice: 1² + 1² = 2)
//   ρ = 1 − 6·Σd² / (n(n²−1)) = 1 − 12/990 ≈ 0.98788
let n = 10
let denom = n * (n * n - 1)      // 990
let sum_d2_swap = 2
let rho_swap = 1.0 - 6.0 * to_float(sum_d2_swap) / to_float(denom)

// Kendall τ for same swap: concordant = C(10,2) - 1 = 44; discordant = 1
// τ = (44 - 1) / 45 = 43/45 ≈ 0.9556
let c10_2 = 45
let tau_swap = (to_float(c10_2 - 2) + 1.0) / to_float(c10_2)   // (43+0)/45 ... careful
// Correct: n_c - n_d  = 44 - 1 = 43. total = 45. τ = 43/45.
let tau_actual = 43.0 / 45.0

let threshold = 0.95
let rho_passes = rho_swap > threshold
let tau_passes = tau_actual > threshold

println("  n = 10, single adjacent swap")
println("  ρ = 1 − 6·2/990  ≈ " + to_string(rho_swap))
println("  τ = 43/45        ≈ " + to_string(tau_actual))
println("  threshold 0.95")
println("  ρ > 0.95 : " + to_string(rho_passes))
println("  τ > 0.95 : " + to_string(tau_passes))

let checks = [
    denom == 990,
    rho_passes,
    tau_passes,
    abs_f(rho_swap - 0.98787878787878788) < 0.000001
]
let ids = ["denom_990", "rho_gt_095", "tau_gt_095", "rho_exact_value"]

println("")
let mut p = 0
let mut f = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { p = p + 1 } else { f = f + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(p+f) + " PASS: " + to_string(p) + " FAIL: " + to_string(f))
if f == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
