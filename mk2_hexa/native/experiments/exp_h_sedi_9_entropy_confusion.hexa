// Ported from tecs-l/experiments/experiment_h_sedi_9_entropy_confusion.py — 2026-04-10
// H-SEDI-9: Shannon entropy of confusion matrix predicts generalization.
// NN training + sklearn.confusion_matrix skipped (Track B).
// Arithmetic core: closed-form Shannon entropy extremes for 10-class problem.
//   H_max = log(10)             (uniform confusion = random)
//   H_min = 0                   (perfect diagonal)
//   H_mid = log(2) at 2-class tie.
// Verifies: log(10)/log(2) ≈ 3.3219 (log2(10)) and monotone decrease property.

fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

println("======================================================================")
println("  H-SEDI-9: Shannon entropy bounds for 10-class confusion (arith-only)")
println("======================================================================")

let H_uniform_10 = log(10.0)
let H_uniform_2  = log(2.0)
let log2_10      = H_uniform_10 / H_uniform_2        // expect ≈ 3.321928
let target_l2_10 = 3.321928094887362

// Monotone: as training progresses, entropy of confusion matrix decreases.
// Verify synthetic sequence [H10 = log(10), log(9), ..., log(2), log(1)=0]
// is strictly decreasing.
let mut prev = H_uniform_10 + 1.0
let mut monotone = true
let mut k = 10
while k >= 1 {
    let H = log(to_float(k))
    if H >= prev { monotone = false }
    prev = H
    k = k - 1
}

let delta = abs_f(log2_10 - target_l2_10)
let H_min = log(1.0)    // = 0

println("  H_uniform(10) = ln 10 ≈ " + to_string(H_uniform_10))
println("  log2(10)               ≈ " + to_string(log2_10))
println("  |log2(10) - target|    = " + to_string(delta))
println("  H_min (delta peak)     = " + to_string(H_min))
println("  monotone ln(k) k=10..1 : " + to_string(monotone))

let checks = [delta < 0.000001, H_min == 0.0, monotone, H_uniform_10 > H_uniform_2]
let ids = ["log2_10_close", "h_min_zero", "entropy_monotone_decrease", "log10_gt_log2"]

println("")
let mut p = 0
let mut f = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { p = p + 1 } else { f = f + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(p+f) + " PASS: " + to_string(p) + " FAIL: " + to_string(f))
if f == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
