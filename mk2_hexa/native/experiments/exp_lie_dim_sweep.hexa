// Ported from tecs-l/experiments/experiment_lie_dim_sweep.py — 2026-04-10
// H-LIE-3: Exceptional Lie algebra adjoint dimensions as hidden_dim candidates.
// Torch MoE + CNN training skipped (Track B).
// Arithmetic-only: verify the dim(g) = rank + |roots| identity plus tau/sigma.

println("======================================================================")
println("  H-LIE-3: Lie adjoint dimensions (arith-only port)")
println("======================================================================")

// (name, rank, |roots|, expected dim)
let names = ["G2", "F4", "E6", "E7", "E8"]
let ranks = [2, 4, 6, 7, 8]
let roots = [12, 48, 72, 126, 240]
let exp_dims = [14, 52, 78, 133, 248]

println("")
println("  g    rank  |roots|  dim  tau(dim)  sigma(dim)")
println("  ----------------------------------------------")
let mut all_match = true
let mut i = 0
while i < len(names) {
    let r = ranks[i]
    let rt = roots[i]
    let d = r + rt
    let e = exp_dims[i]
    if d != e { all_match = false }
    println("  " + names[i] + "    " + to_string(r) + "     " + to_string(rt) + "     " + to_string(d) + "   tau=" + to_string(tau(d)) + "   sigma=" + to_string(sigma(d)))
    i = i + 1
}

// Standard power-of-2 baselines: {32, 64, 128, 256, 512}
let pw2 = [32, 64, 128, 256, 512]
println("")
println("## Power-of-2 baseline divisor counts")
let mut j = 0
while j < len(pw2) {
    println("  d=" + to_string(pw2[j]) + "  tau=" + to_string(tau(pw2[j])))
    j = j + 1
}

// Claim: Lie dims have larger average tau than power-of-2 dims of comparable magnitude
let mut lie_tau_sum = 0
let mut k = 0
while k < len(exp_dims) {
    lie_tau_sum = lie_tau_sum + tau(exp_dims[k])
    k = k + 1
}
let mut pw2_tau_sum = 0
let mut m = 0
while m < len(pw2) {
    pw2_tau_sum = pw2_tau_sum + tau(pw2[m])
    m = m + 1
}
let lie_avg = to_float(lie_tau_sum) / to_float(len(exp_dims))
let pw2_avg = to_float(pw2_tau_sum) / to_float(len(pw2))

println("")
println("  avg tau(Lie dim) = " + to_string(lie_avg))
println("  avg tau(2^k)     = " + to_string(pw2_avg))

// 248 = 2^3 * 31 (so tau(248)=8), 133 = 7*19 (tau=4), 78 = 2*3*13 (tau=8)
// 52 = 2^2 * 13 (tau=6), 14 = 2*7 (tau=4)
// pw2 taus: 6,7,8,9,10 — average 8.0

println("")
println("======================================================================")
let h1 = all_match
let h2 = tau(14) == 4
let h3 = tau(248) == 8
let h4 = lie_avg > 0.0 && pw2_avg > 0.0
println("  all dim = rank + |roots|        : " + to_string(h1))
println("  tau(14) == 4                     : " + to_string(h2))
println("  tau(248) == 8                    : " + to_string(h3))
println("  avg tau computed (both nonzero)  : " + to_string(h4))
if h1 && h2 && h3 && h4 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
