// Ported from tecs-l/experiments/verify_hcx14_anomaly_lens.py — 2026-04-10
// H-CX-14: Anomaly Detection ≈ Gravitational Lens (R-spectrum structural claim).
// Scipy curve_fit + numpy portions skipped (Track B).
// Arithmetic-only core: R(n) = sigma*phi/(n*tau) gap analysis around R=1.

println("======================================================================")
println("  H-CX-14: R-spectrum gap around R=1 (arith-only port)")
println("======================================================================")

fn R(n: int) -> float {
    to_float(sigma(n)) * to_float(phi(n)) / (to_float(n) * to_float(tau(n)))
}

println("")
println("## R-spectrum for n=1..100")
let mut rs = []
let mut n_i = 1
while n_i <= 100 {
    rs = rs + [R(n_i)]
    n_i = n_i + 1
}

// Perfect number 6 anchor: R(6)=1 exactly.
// Note: R(28) = 4 (not 1). Only n=1 and n=6 give R(n)=1 in 1..100.
let r6 = R(6)
let r28 = R(28)
println("  R(6)  = " + to_string(r6) + " (expected 1)")
println("  R(28) = " + to_string(r28) + " (not 1; corrects paper's claim)")

// Find max below 1 and min above 1 (exclude R==1)
let mut max_below = 0.0
let mut min_above = 1.0e10
let mut i = 0
while i < len(rs) {
    let r = rs[i]
    if r < 1.0 && r > max_below { max_below = r }
    if r > 1.0 && r < min_above { min_above = r }
    i = i + 1
}
let gap_below = 1.0 - max_below
let gap_above = min_above - 1.0
let total_gap = gap_below + gap_above

println("")
println("## Gap around R=1")
println("  max below 1 : " + to_string(max_below))
println("  min above 1 : " + to_string(min_above))
println("  gap_below   : " + to_string(gap_below))
println("  gap_above   : " + to_string(gap_above))
println("  total_gap   : " + to_string(total_gap))

// Numbers where R(n) == 1 exactly (perfect numbers)
let mut exact_ones = []
let mut j = 0
while j < len(rs) {
    if rs[j] == 1.0 { exact_ones = exact_ones + [j + 1] }
    j = j + 1
}
println("")
println("## Exact R(n)=1 in 1..100")
let mut k = 0
while k < len(exact_ones) {
    println("  n = " + to_string(exact_ones[k]))
    k = k + 1
}

println("")
println("======================================================================")
let h1 = r6 == 1.0
let h2 = r28 == 4.0                 // corrected: R(28)=4, NOT 1
let h3 = len(exact_ones) >= 2       // n=1 and n=6 in 1..100
let h4 = gap_below > 0.0 && gap_above > 0.0
let h5 = total_gap > 0.05           // measurable asymmetry gap
println("  R(6)  == 1 : " + to_string(h1))
println("  R(28) == 4 : " + to_string(h2))
println("  ≥2 exact R=1 solutions : " + to_string(h3))
println("  nonzero gap both sides  : " + to_string(h4))
println("  total_gap > 0.05        : " + to_string(h5))
if h1 && h2 && h3 && h4 && h5 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
