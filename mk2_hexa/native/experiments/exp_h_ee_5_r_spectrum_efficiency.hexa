// Ported from tecs-l/experiments/experiment_h_ee_5_r_spectrum_efficiency.py — 2026-04-10
// H-EE-5 variant: R/tau and tau/d ratios as arithmetic efficiency indicators.
// Torch MiniGPT training + Spearman correlation skipped (Track B).
// Arithmetic claim: for matched scales, HCN dims have smaller R/tau and larger tau/d.

println("======================================================================")
println("  H-EE-5b: R/tau and tau/d ratios (arith-only port)")
println("======================================================================")

fn Rval(n: int) -> float {
    to_float(sigma(n)) * to_float(phi(n)) / (to_float(n) * to_float(tau(n)))
}

let dims = [60, 64, 120, 128, 180, 240, 256, 360, 512, 720, 1024]

println("")
println("  d       tau    R(d)         R/tau        tau/d")
println("  ---------------------------------------------------")
let mut r_over_tau_list = []
let mut tau_over_d_list = []
let mut i = 0
while i < len(dims) {
    let d = dims[i]
    let t = tau(d)
    let r = Rval(d)
    let r_t = r / to_float(t)
    let t_d = to_float(t) / to_float(d)
    r_over_tau_list = r_over_tau_list + [r_t]
    tau_over_d_list = tau_over_d_list + [t_d]
    println("  " + to_string(d) + "  tau=" + to_string(t) + "  R=" + to_string(r) + "  R/tau=" + to_string(r_t) + "  tau/d=" + to_string(t_d))
    i = i + 1
}

// Compare HCN vs 2^k neighbours
// (60,64), (120,128), (240,256), (720,1024) — HCN should have smaller R/tau AND larger tau/d
let hcn_idx = [0, 2, 5, 9]
let pw2_idx = [1, 3, 6, 10]
let mut r_wins = 0
let mut td_wins = 0
let mut p = 0
while p < len(hcn_idx) {
    if r_over_tau_list[hcn_idx[p]] < r_over_tau_list[pw2_idx[p]] { r_wins = r_wins + 1 }
    if tau_over_d_list[hcn_idx[p]] > tau_over_d_list[pw2_idx[p]] { td_wins = td_wins + 1 }
    p = p + 1
}

println("")
println("## HCN vs 2^k comparison")
println("  R/tau wins (HCN smaller)  : " + to_string(r_wins) + "/" + to_string(len(hcn_idx)))
println("  tau/d wins (HCN larger)   : " + to_string(td_wins) + "/" + to_string(len(hcn_idx)))

println("")
println("======================================================================")
let ok = r_wins == len(hcn_idx) && td_wins == len(hcn_idx)
if ok { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
