// Ported from tecs-l/experiments/exp_h446_spectral_ph_bridge.py — 2026-04-10
// H-CX-446: Spectral gap ↔ PH H0 ↔ tension gap — Trinity Bridge.
// NN training + scipy.spearmanr/pearsonr skipped (Track B).
// Arithmetic core: tiny fixed-matrix spectral gap computation (2x2, 3x3)
// using closed-form eigenvalues, plus the |r| > 0.8 threshold arithmetic.

fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

println("======================================================================")
println("  H-CX-446: Spectral/PH/Tension trinity anchors (arith-only)")
println("======================================================================")

// 2x2 symmetric matrix [[a,b],[b,c]]: eigenvalues = (a+c)/2 ± sqrt(((a-c)/2)^2 + b^2)
fn eig2_gap(a: float, b: float, c: float) -> float {
    let half = (a - c) / 2.0
    2.0 * sqrt(half * half + b * b)    // λ1 − λ2
}

// Reference case: diag(2,1) → gap = 1
let gap_diag = eig2_gap(2.0, 0.0, 1.0)

// Perturbed: [[2, 0.1],[0.1, 1]] → gap = 2*sqrt(0.25 + 0.01) = 2*sqrt(0.26)
let gap_pert = eig2_gap(2.0, 0.1, 1.0)
let gap_pert_target = 2.0 * sqrt(0.26)

// Trinity threshold: |r| > 0.8 implies r² > 0.64 (variance explained)
let r_threshold = 0.8
let r2_threshold = r_threshold * r_threshold

println("  gap(diag 2,1)       = " + to_string(gap_diag))
println("  gap(off-diag 0.1)   = " + to_string(gap_pert))
println("  |r|>0.8 → r²>0.64   : " + to_string(r2_threshold))

let checks = [
    gap_diag == 1.0,
    abs_f(gap_pert - gap_pert_target) < 0.000001,
    abs_f(r2_threshold - 0.64) < 0.000001
]
let ids = ["diag_gap_1", "perturbed_gap", "r2_threshold_064"]

println("")
let mut p = 0
let mut f = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { p = p + 1 } else { f = f + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(p+f) + " PASS: " + to_string(p) + " FAIL: " + to_string(f))
if f == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
