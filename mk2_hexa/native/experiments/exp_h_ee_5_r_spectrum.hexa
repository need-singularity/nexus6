// Ported from tecs-l/experiments/experiment_h_ee_5_r_spectrum.py — 2026-04-10
// H-EE-5: R(d_model) = sigma*phi/(n*tau) as arithmetic balance measure
// Arithmetic-only portion (torch training skipped — Track B).
// Claim: HCN dimensions (60, 120, 240, 360, 720) have smaller R than 2^k neighbors.

println("======================================================================")
println("  H-EE-5: R-Spectrum for Model Dimensions (arith-only port)")
println("======================================================================")

fn R(n: int) -> float {
    let s = sigma(n)
    let p = phi(n)
    let t = tau(n)
    to_float(s) * to_float(p) / (to_float(n) * to_float(t))
}

let dims = [60, 64, 120, 128, 180, 240, 256, 360, 512, 720, 1024]

println("")
println("  d      sigma    phi    tau    R(d)")
println("  ----------------------------------------")
let mut i = 0
while i < len(dims) {
    let d = dims[i]
    let s = sigma(d)
    let p = phi(d)
    let t = tau(d)
    let r = R(d)
    println("  " + to_string(d) + "  s=" + to_string(s) + " phi=" + to_string(p) + " tau=" + to_string(t) + " R=" + to_string(r))
    i = i + 1
}

// Verify HCN-vs-2^k pairs have lower R on HCN side
// (60,64), (120,128), (240,256), (720,1024)
println("")
println("## HCN vs 2^k neighbour comparison")
let pairs = [[60, 64], [120, 128], [240, 256], [720, 1024]]
let mut hcn_wins = 0
let mut p_i = 0
while p_i < len(pairs) {
    let hcn_d = pairs[p_i][0]
    let pw2_d = pairs[p_i][1]
    let r_hcn = R(hcn_d)
    let r_pw2 = R(pw2_d)
    let winner = if r_hcn < r_pw2 { "HCN" } else { "2^k" }
    if r_hcn < r_pw2 { hcn_wins = hcn_wins + 1 }
    println("  " + to_string(hcn_d) + " vs " + to_string(pw2_d) + " : R=" + to_string(r_hcn) + " vs " + to_string(r_pw2) + " -> " + winner)
    p_i = p_i + 1
}

// Also verify tau asymmetry: HCN always has more divisors
let mut tau_wins = 0
let mut p_j = 0
while p_j < len(pairs) {
    if tau(pairs[p_j][0]) > tau(pairs[p_j][1]) { tau_wins = tau_wins + 1 }
    p_j = p_j + 1
}

println("")
println("======================================================================")
let r_all_win = hcn_wins == len(pairs)
let tau_all_win = tau_wins == len(pairs)
let s_anchor = R(6) == 1.0
println("  HCN wins R comparison : " + to_string(hcn_wins) + "/" + to_string(len(pairs)))
println("  HCN wins tau comparison: " + to_string(tau_wins) + "/" + to_string(len(pairs)))
println("  R(6) = 1.0 (anchor)    : " + to_string(s_anchor))
let ok = r_all_win && tau_all_win && s_anchor
if ok { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
