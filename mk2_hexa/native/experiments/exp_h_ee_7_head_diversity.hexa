// Ported from tecs-l/experiments/experiment_h_ee_7_head_diversity.py — 2026-04-10
// H-EE-7: d=120 allows more valid head configurations than d=128 (HCN flexibility).
// Arithmetic-only: torch TinyLM training skipped (Track B).
// Claim: divisors of 120 in [4..60] > divisors of 128 in [4..64].

println("======================================================================")
println("  H-EE-7: Head-dimension diversity (d=120 vs d=128)")
println("======================================================================")

fn divisors_in_range(d: int, lo: int, hi: int) -> [int] {
    let mut out = []
    let mut k = lo
    while k <= hi {
        if d % k == 0 { out = out + [k] }
        k = k + 1
    }
    out
}

fn divisors_up_to(d: int) -> [int] {
    let mut out = []
    let mut k = 1
    while k <= d {
        if d % k == 0 { out = out + [k] }
        k = k + 1
    }
    out
}

let div120_all = divisors_up_to(120)
let div128_all = divisors_up_to(128)
let div120 = divisors_in_range(120, 4, 60)   // valid #heads in paper
let div128 = divisors_in_range(128, 4, 64)

println("")
println("  d=120 total divisors : " + to_string(len(div120_all)) + " (tau=16)")
println("  d=128 total divisors : " + to_string(len(div128_all)) + " (tau=8)")
println("  d=120 valid heads (4..60) : " + to_string(len(div120)))
println("  d=128 valid heads (4..64) : " + to_string(len(div128)))

println("")
println("  d=120 head candidates: ")
let mut i = 0
while i < len(div120) {
    println("    nh=" + to_string(div120[i]) + " head_dim=" + to_string(120 / div120[i]))
    i = i + 1
}
println("  d=128 head candidates: ")
let mut j = 0
while j < len(div128) {
    println("    nh=" + to_string(div128[j]) + " head_dim=" + to_string(128 / div128[j]))
    j = j + 1
}

let tau120 = tau(120)
let tau128 = tau(128)

println("")
println("======================================================================")
let h_a = tau120 == 16
let h_b = tau128 == 8
let h_c = len(div120) > len(div128)
let h_d = tau120 > tau128
println("  tau(120) == 16 : " + to_string(h_a))
println("  tau(128) == 8  : " + to_string(h_b))
println("  more valid heads for d=120 : " + to_string(h_c))
println("  tau(120) > tau(128) : " + to_string(h_d))
if h_a && h_b && h_c && h_d { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
