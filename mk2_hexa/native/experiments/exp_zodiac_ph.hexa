// Ported from tecs-l/experiments/exp_zodiac_ph.py — 2026-04-10
// Zodiac PH: class-count numerology for n=10, 12, 13, 36.
// gudhi persistent-homology computation skipped (Track B).
// Arithmetic-only: verify the "n=12 is special" number-theoretic anchors.

println("======================================================================")
println("  Zodiac PH: n=10, 12, 13, 36 arithmetic anchors")
println("======================================================================")

// Claims from the paper:
//   12 = sigma(6)                  — sum of divisors of the first perfect number
//   12 = kissing number in R^3    (mathematical fact)
//   13 = Ophiuchus                 (13 prime, adjacent to 12)
//   36 = 6^2                       — square of first perfect number
//   10 = baseline (MNIST classes)

let ns = [10, 12, 13, 36]
println("")
println("  n     sigma    tau    phi    prime?")
println("  -------------------------------------")
let mut i = 0
while i < len(ns) {
    let n = ns[i]
    let is_prime_flag = sigma(n) == n + 1       // tau==2 iff prime
    println("  " + to_string(n) + "    s=" + to_string(sigma(n)) + "  t=" + to_string(tau(n)) + "  p=" + to_string(phi(n)) + "  prime=" + to_string(is_prime_flag))
    i = i + 1
}

// Anchor 1: 12 == sigma(6)
let anchor_12 = sigma(6) == 12
// Anchor 2: 36 == 6*6
let anchor_36 = 36 == 6 * 6
// Anchor 3: 13 is prime
let anchor_13_prime = tau(13) == 2
// Anchor 4: 12 has tau(12)=6 (first perfect number = 6 divisors!)
let tau12 = tau(12) == 6
// Anchor 5: 12 has highly composite status (tau(12)=6 > tau(k) for all k<12)
let mut hcn_12 = true
let mut k = 1
while k < 12 {
    if tau(k) >= 6 { hcn_12 = false }
    k = k + 1
}

println("")
println("======================================================================")
println("  12 == sigma(6)                    : " + to_string(anchor_12))
println("  36 == 6^2                         : " + to_string(anchor_36))
println("  13 is prime                       : " + to_string(anchor_13_prime))
println("  tau(12) == 6 (first perfect num)  : " + to_string(tau12))
println("  12 is HCN (tau(k<12) < 6)         : " + to_string(hcn_12))
let ok = anchor_12 && anchor_36 && anchor_13_prime && tau12 && hcn_12
if ok { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
