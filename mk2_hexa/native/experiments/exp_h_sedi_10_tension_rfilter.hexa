// Ported from tecs-l/experiments/experiment_h_sedi_10_tension_rfilter.py — 2026-04-10
// H-SEDI-10: R-filter on tension vectors, detect σ/τ, φ/τ, golden ratio.
// NN training skipped (Track B). Arithmetic core: closed-form ratio set
// derived from divisors of 6, plus golden-ratio closed form.

fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

println("======================================================================")
println("  H-SEDI-10: Tension R-filter target ratios (arith-only)")
println("======================================================================")

let s6 = to_float(sigma(6))   // 12
let p6 = to_float(phi(6))     // 2
let t6 = to_float(tau(6))     // 4

let s_over_t = s6 / t6        // 12/4 = 3
let p_over_t = p6 / t6        // 2/4  = 0.5
let sp_over_nt = (s6 * p6) / (6.0 * t6)   // 24/24 = 1 (hexa identity)

// Golden ratio φ = (1 + sqrt(5))/2 ≈ 1.6180339887
let gold = (1.0 + sqrt(5.0)) / 2.0
let gold_target = 1.6180339887498949

// Golden ratio fixed-point: φ^2 = φ + 1
let gold_sq = gold * gold
let fixed_point_err = abs_f(gold_sq - (gold + 1.0))

println("  σ(6)/τ(6)              = " + to_string(s_over_t))
println("  φ(6)/τ(6)              = " + to_string(p_over_t))
println("  σ(6)·φ(6) / (6·τ(6))   = " + to_string(sp_over_nt))
println("  golden ratio           ≈ " + to_string(gold))
println("  |φ² − (φ+1)|           = " + to_string(fixed_point_err))

let checks = [
    s_over_t == 3.0,
    p_over_t == 0.5,
    sp_over_nt == 1.0,
    abs_f(gold - gold_target) < 0.000001,
    fixed_point_err < 0.000001
]
let ids = ["sigma_over_tau_3", "phi_over_tau_half", "hexa_balance_1", "golden_value", "golden_fixed_point"]

println("")
let mut p = 0
let mut f = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { p = p + 1 } else { f = f + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(p+f) + " PASS: " + to_string(p) + " FAIL: " + to_string(f))
if f == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
