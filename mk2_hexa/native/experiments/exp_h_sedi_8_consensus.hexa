// Ported from tecs-l/experiments/experiment_h_sedi_8_consensus.py — 2026-04-10
// H-SEDI-8: Multi-engine consensus (N=5) via majority / weighted / best.
// NN training skipped (Track B). Arithmetic core: majority threshold
// T(N) = floor(N/2) + 1 and odd-N tie-freeness. Verifies N=5 case.

fn majority_threshold(n: int) -> int { n / 2 + 1 }

println("======================================================================")
println("  H-SEDI-8: 5-engine majority-vote arithmetic (arith-only)")
println("======================================================================")

let N = 5
let T = majority_threshold(N)           // 3
let is_odd = N % 2 == 1                  // odd → no ties possible
// Agreement levels k = ceil(N/2) .. N  →  {3,4,5}
let mut levels = [0]
levels[0] = T
levels = levels + [T + 1]
levels = levels + [T + 2]

// Number of distinct non-empty majorities on 2 classes for N=5: sum_{k=3..5} C(5,k)
fn c(n: int, k: int) -> int {
    if k < 0 { return 0 }
    if k > n { return 0 }
    let mut r = 1
    let mut i = 0
    while i < k {
        r = r * (n - i) / (i + 1)
        i = i + 1
    }
    r
}
let total_majority_patterns = c(5,3) + c(5,4) + c(5,5)   // 10+5+1 = 16

println("  N = " + to_string(N))
println("  majority threshold T = " + to_string(T))
println("  odd N → tie impossible: " + to_string(is_odd))
println("  agreement levels: {3,4,5}")
println("  C(5,3)+C(5,4)+C(5,5) = " + to_string(total_majority_patterns))

let checks = [T == 3, is_odd, c(5,3) == 10, c(5,4) == 5, c(5,5) == 1, total_majority_patterns == 16]
let ids = ["threshold_3", "odd_no_tie", "c53_eq_10", "c54_eq_5", "c55_eq_1", "total_16"]

println("")
let mut p = 0
let mut f = 0
let mut k = 0
while k < len(ids) {
    let ok = checks[k]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { p = p + 1 } else { f = f + 1 }
    println("  " + ids[k] + ": " + st)
    k = k + 1
}
println("Total: " + to_string(p+f) + " PASS: " + to_string(p) + " FAIL: " + to_string(f))
if f == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
