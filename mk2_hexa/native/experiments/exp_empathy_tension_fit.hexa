// Ported from tecs-l/experiments/experiment_empathy_tension_fit.py — 2026-04-10
// H266: E = k/(1+aT) empathy-tension inverse law.
// NN training + numpy.polyfit + scipy skipped (Track B).
// Arithmetic core: closed-form properties of the inverse family
//   f(T) = k/(1 + aT).
//   f(0)  = k
//   f(T)→0 as T→∞ (for a>0, k>0)
//   f is strictly monotone decreasing
//   invariant: 1/f(T) = (1/k) + (a/k) T  → linear in T

fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

fn f_inv_law(k: float, a: float, t: float) -> float {
    k / (1.0 + a * t)
}

println("======================================================================")
println("  H266: inverse-law E = k/(1+aT) closed-form (arith-only)")
println("======================================================================")

let k = 2.0
let a = 0.5

let f0 = f_inv_law(k, a, 0.0)                // = k = 2.0
let f1 = f_inv_law(k, a, 1.0)                // = 2/(1+0.5) = 4/3
let f10 = f_inv_law(k, a, 10.0)              // = 2/6 = 1/3
let f100 = f_inv_law(k, a, 100.0)            // = 2/51

// Strict monotonicity over t=0..20 step 0.5
let mut prev = f0 + 1.0
let mut monotone = true
let mut t = 0.0
while t <= 20.0 {
    let v = f_inv_law(k, a, t)
    if v >= prev { monotone = false }
    prev = v
    t = t + 0.5
}

// Linearity of 1/f: 1/f(T) − (1/k + aT/k) = 0
let lin_resid_1  = abs_f(1.0 / f1  - (1.0 / k + a * 1.0  / k))
let lin_resid_10 = abs_f(1.0 / f10 - (1.0 / k + a * 10.0 / k))

println("  f(0)   = " + to_string(f0))
println("  f(1)   = " + to_string(f1))
println("  f(10)  = " + to_string(f10))
println("  monotone decreasing        : " + to_string(monotone))
println("  |1/f(1)  − lin(1)|  < eps  : " + to_string(lin_resid_1 < 0.000001))
println("  |1/f(10) − lin(10)| < eps  : " + to_string(lin_resid_10 < 0.000001))

let checks = [
    abs_f(f0 - k) < 0.000001,
    abs_f(f1 - 4.0/3.0) < 0.000001,
    abs_f(f10 - 1.0/3.0) < 0.000001,
    f100 < f10,
    monotone,
    lin_resid_1 < 0.000001,
    lin_resid_10 < 0.000001
]
let ids = ["f0_eq_k", "f1_eq_4_3", "f10_eq_1_3", "f100_lt_f10", "monotone", "lin_1", "lin_10"]

println("")
let mut p = 0
let mut fz = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { p = p + 1 } else { fz = fz + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(p+fz) + " PASS: " + to_string(p) + " FAIL: " + to_string(fz))
if fz == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
