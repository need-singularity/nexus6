// Ported from tecs-l/experiments/experiment_h_ee_6_tensor_aligned_hcn.py — 2026-04-10
// H-EE-6: HCN dimensions that are also multiples of 8 (tensor-core aligned).
// Arithmetic-only port (torch benchmark skipped — Track B).
// Claim: HCN ∩ 8Z combines high divisor count AND hardware efficiency.

println("======================================================================")
println("  H-EE-6: Tensor-core-aligned HCN (arith-only port)")
println("======================================================================")

// Find all HCN up to 2048: n is HCN iff tau(n) > tau(k) for all k < n.
let limit = 2048
let mut max_tau = 0
let mut hcn_list = []   // list of [n, tau]
let mut n = 1
while n <= limit {
    let t = tau(n)
    if t > max_tau {
        max_tau = t
        hcn_list = hcn_list + [[n, t]]
    }
    n = n + 1
}

println("")
println("## Highly Composite Numbers up to 2048")
println("  HCN    tau    mod8   mod16  mod32")
println("  -------------------------------------")
let mut mod8_count = 0
let mut mod16_count = 0
let mut mod32_count = 0
let mut hi = 0
while hi < len(hcn_list) {
    let h = hcn_list[hi][0]
    let ht = hcn_list[hi][1]
    let m8  = h % 8  == 0
    let m16 = h % 16 == 0
    let m32 = h % 32 == 0
    if m8  { mod8_count  = mod8_count  + 1 }
    if m16 { mod16_count = mod16_count + 1 }
    if m32 { mod32_count = mod32_count + 1 }
    println("  " + to_string(h) + "  tau=" + to_string(ht) + "  m8=" + to_string(m8) + "  m16=" + to_string(m16) + "  m32=" + to_string(m32))
    hi = hi + 1
}

println("")
println("## Flexibility ratio: tau(HCN) / tau(nearest 2^k)")
// Use: HCN 120 vs 128, 240 vs 256, 720 vs 1024, 1680 vs 2048
let cmp_pairs = [[120, 128], [240, 256], [360, 512], [720, 1024], [1680, 2048]]
let mut flex_ok = 0
let mut ci = 0
while ci < len(cmp_pairs) {
    let h = cmp_pairs[ci][0]
    let p = cmp_pairs[ci][1]
    let th = tau(h)
    let tp = tau(p)
    let ratio = to_float(th) / to_float(tp)
    if th > tp { flex_ok = flex_ok + 1 }
    println("  tau(" + to_string(h) + ")=" + to_string(th) + "  tau(" + to_string(p) + ")=" + to_string(tp) + "  ratio=" + to_string(ratio))
    ci = ci + 1
}

println("")
println("======================================================================")
println("  Total HCN found      : " + to_string(len(hcn_list)))
println("  HCN divisible by 8   : " + to_string(mod8_count))
println("  HCN divisible by 16  : " + to_string(mod16_count))
println("  HCN divisible by 32  : " + to_string(mod32_count))
println("  Flexibility wins     : " + to_string(flex_ok) + "/" + to_string(len(cmp_pairs)))
let found_enough = len(hcn_list) >= 15   // measured: 17 HCN ≤ 2048
let tensor_friendly = mod8_count >= 8    // measured: 8 mod-8 HCN
let all_flex = flex_ok == len(cmp_pairs)
let ok = found_enough && tensor_friendly && all_flex
if ok { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
