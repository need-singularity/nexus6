// Ported from tecs-l/experiments/h_ee_2_gradient_properties.py — 2026-04-10
// H-EE-2: Phi6 gradient (f'(x)=2x-1) analytical moments under x~N(0,1).
// scipy integration + numpy Monte Carlo skipped (Track B).
// Analytical (closed-form) portion only — all moments are exact for normal input.

println("======================================================================")
println("  H-EE-2: Phi6 gradient analytical moments (arith-only port)")
println("======================================================================")

// For x ~ N(0,1):
//   E[x]   = 0
//   E[x^2] = 1   (Var = 1)
//
// Phi6 unclamped: f'(x) = 2x - 1
//   E[f'(x)]   = 2*0 - 1 = -1
//   E[f'(x)^2] = E[4x^2 - 4x + 1] = 4 - 0 + 1 = 5
//   Var[f'(x)] = 5 - 1 = 4
//   Std[f'(x)] = 2
//
// ReLU: f'(x) = 1 if x>0 else 0
//   P(x>0) = 0.5
//   E[f'(x)]   = 0.5
//   Var[f'(x)] = 0.5 * (1 - 0.5)^2 + 0.5 * (0 - 0.5)^2 = 0.25

let E_phi6_grad = -1.0
let Var_phi6_grad = 4.0
let Std_phi6_grad = 2.0

let E_relu_grad = 0.5
let Var_relu_grad = 0.25

println("")
println("## Phi6 unclamped: f'(x) = 2x - 1, x ~ N(0,1)")
println("  E[f'(x)]   = " + to_string(E_phi6_grad))
println("  Var[f'(x)] = " + to_string(Var_phi6_grad))
println("  Std[f'(x)] = " + to_string(Std_phi6_grad))

println("")
println("## ReLU: f'(x) = 1[x>0], x ~ N(0,1)")
println("  E[f'(x)]   = " + to_string(E_relu_grad))
println("  Var[f'(x)] = " + to_string(Var_relu_grad))

// Symbolic checks — match the Python docstring's analytical derivation exactly
let h1 = 2.0 * 0.0 - 1.0 == E_phi6_grad
let h2 = 4.0 * 1.0 - 0.0 + 1.0 - 1.0 == Var_phi6_grad    // 4 - (-1)^2 = 4
let h3 = Std_phi6_grad * Std_phi6_grad == Var_phi6_grad

// Phi6 is NOT gradient-centered (|E[f']|=1, not 0) — corrects the original hypothesis claim
let phi6_not_centered = E_phi6_grad != 0.0
// ReLU is also not centered (E=0.5) — both activations have bias
let relu_not_centered = E_relu_grad != 0.0

println("")
println("======================================================================")
println("  Phi6 E matches 2*0 - 1              : " + to_string(h1))
println("  Phi6 Var matches 4*E[x^2] - E^2     : " + to_string(h2))
println("  Phi6 Std^2 == Var                   : " + to_string(h3))
println("  Phi6 NOT zero-centered (refutation) : " + to_string(phi6_not_centered))
println("  ReLU NOT zero-centered              : " + to_string(relu_not_centered))
if h1 && h2 && h3 && phi6_not_centered && relu_not_centered { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
