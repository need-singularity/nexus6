// Ported from tecs-l/experiments/experiment_h325_fisher_tension.py — 2026-04-10
// H325: Fisher information geometry ↔ tension manifold.
// NN training + scipy.stats skipped (Track B).
// Arithmetic core: Fisher trace closed form for a categorical(p) with K=10,
// tr(F) = sum 1/p_k, verify uniform-p gives tr(F) = K²/1 = 100.
// Also the r > 0.7 prediction threshold → r² > 0.49.

fn abs_f(x: float) -> float { if x < 0.0 { 0.0 - x } else { x } }

println("======================================================================")
println("  H325: Fisher trace uniform anchor (arith-only)")
println("======================================================================")

// Categorical distribution with K classes, uniform p_k = 1/K.
// tr(F) = sum 1/p_k = K * K = K²
let K = 10
let trF_uniform = to_float(K * K)

// Max-concentration (one-hot) p = (1, 0, ..., 0): tr(F) diverges.
// Two-class equal (p=[0.5, 0.5]): tr(F) = 2 + 2 = 4.
let trF_2 = 2.0 + 2.0

// r > 0.7 threshold check
let r_threshold = 0.7
let r2_threshold = r_threshold * r_threshold
let target_r2 = 0.49

println("  K = " + to_string(K))
println("  tr(F) uniform  = K² = " + to_string(trF_uniform))
println("  tr(F) 2-class  = 4  = " + to_string(trF_2))
println("  r>0.7 → r²>0.49 : " + to_string(r2_threshold))

let checks = [
    trF_uniform == 100.0,
    trF_2 == 4.0,
    abs_f(r2_threshold - target_r2) < 0.000001
]
let ids = ["tr_F_uniform_100", "tr_F_2class_4", "r2_threshold_049"]

println("")
let mut p = 0
let mut f = 0
let mut i = 0
while i < len(ids) {
    let ok = checks[i]
    let st = if ok { "PASS" } else { "FAIL" }
    if ok { p = p + 1 } else { f = f + 1 }
    println("  " + ids[i] + ": " + st)
    i = i + 1
}
println("Total: " + to_string(p+f) + " PASS: " + to_string(p) + " FAIL: " + to_string(f))
if f == 0 { println("OVERALL: PASS") } else { println("OVERALL: FAIL") }
