// ─── auto 도메인 선택: growth_bus에서 최근 미방문 도메인 ───
fn auto_select_domain() -> string {
    try {
        let home = exec("printenv HOME").trim()
        let gb = exec("tail -200 " + home + "/Dev/nexus/shared/growth_bus.jsonl 2>/dev/null")
        let lines = gb.split("\n")
        let mut seen = []
        let mut li: i64 = len(lines) - 1
        while li >= 0 {
            let ln = lines[li].trim()
            li = li - 1
            if ln == "" || !ln.contains("\"domain\":\"") { continue }
            let dp = ln.split("\"domain\":\"")
            if len(dp) < 2 { continue }
            let dd = dp[1].split("\"")[0]
            if dd == "" { continue }
            let mut dup = false
            for s in seen { if s == dd { dup = true } }
            if dup { continue }
            seen = seen + [dd]
            if len(seen) >= 12 { break }
        }
        // 가장 오래된 것(= 최근 안 건드린 것)을 선택
        if len(seen) >= 2 {
            return seen[len(seen) - 1]
        }
        if len(seen) == 1 { return seen[0] }
    } catch e {}
    return "math"
}

let domain = if _raw_domain != "" { _raw_domain } else { auto_select_domain() }
let max_depth: i64 = _raw_depth

// ─── 내부 플래그 파싱 ───
