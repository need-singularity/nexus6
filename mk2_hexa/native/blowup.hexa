// ⛔ CORE — L0 불변식 (블로업 엔진 9-phase 특이점 파이프라인. 수정 전 유저 승인 필수)
// ⚠️ 로드맵: shared/roadmaps/blowup.json (Mk.I~VII 진화 계보)
// mk2_hexa/native/blowup.hexa — Mk.II 파동 연속돌파 엔진 (hexa-native)
//
// Mk.II 기본 동작: 파동 연속돌파 (6라운드, 자동 도메인 회전)
//   hexa blowup.hexa              → auto 도메인, depth 3, 6라운드 연속돌파
//   hexa blowup.hexa physics      → physics 도메인, depth 3, 6라운드
//   hexa blowup.hexa physics 5    → physics, depth 5, 6라운드
//   hexa blowup.hexa help         → 사용법 출력
//   (내부용) --round N --max-rounds M  → 라운드 제어
//   (내부용) --no-graph --fast --seeds → 하위 호출용
//
// 9-phase pipeline (각 라운드마다 실행):
//   Phase 1: Graph load (discovery_graph.json stats)
//   Phase 2: OUROBOROS evolution (seed -> mutate -> verify -> converge -> saturate)
//   Phase 3: Singularity detection (closure + compression, enhanced by evolution)
//   Phase 4: Blowup corollary generation (7 types)
//   Phase 5: Telescope verification (5 lens scan, consensus boost)
//   Phase 6: Graph update (add nodes + edges)
//   Phase 6.5: Dynamic recursive growth (closure-based, max 5 rounds)
//   Phase 6.7: Auto-absorb (log + graph + growth_bus + cross-ref + absorb.hexa)
//   Phase 7: Report (lens consensus + graph stats + evolution summary)
//   Phase 8: Wave Propagation (인접 도메인 병렬 파동 전파 + 간섭)

// ═══════════════════════════════════════════════════════════
// ─── n=6 CONSTANTS LOADER (shared/n6_constants.jsonl) ───
// ═══════════════════════════════════════════════════════════

fn load_n6_consts() -> list {
    let home = exec("printenv HOME")
    let path = home + "/Dev/nexus/shared/n6_constants.jsonl"
    let mut raw = ""
    try { raw = read_file(path) } catch e { return [[], []] }
    let lines = raw.split("\n")
    let mut names = []
    let mut values = []
    for line in lines {
        let trimmed = line.trim()
        if trimmed == "" { continue }
        let mut name = ""
        let mut value = 0.0
        if trimmed.contains("\"name\":\"") {
            let p = trimmed.split("\"name\":\"")
            if p.len() >= 2 { name = p[1].split("\"")[0] }
        }
        if trimmed.contains("\"value\":") {
            let p = trimmed.split("\"value\":")
            if p.len() >= 2 {
                let num_str = p[1].split(",")[0].split("}")[0].trim()
                value = to_float(num_str)
            }
        }
        if name != "" {
            names = names + [name]
            values = values + [value]
        }
    }
    [names, values]
}

fn n6_values(consts: list) -> list {
    consts[1]
}

fn n6_names_list(consts: list) -> list {
    consts[0]
}

// ─── Dynamic n6 constants (loaded ONCE from shared/n6_constants.jsonl) ───
let _n6_dyn = load_n6_consts()
let _n6_dyn_names: list = _n6_dyn[0]
let _n6_dyn_values: list = _n6_dyn[1]
let _n6_dyn_count: i64 = len(_n6_dyn_values)

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {}
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

fn min_f(a: f64, b: f64) -> f64 {
    if a < b { return a }
    return b
}

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 15 {
        g = (g + x / g) / 2.0
        i = i + 1
    }
    return g
}

fn ln_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut sum = 0.0
    let mut term = (x - 1.0) / (x + 1.0)
    let t2 = term * term
    let mut k: i64 = 1
    while k <= 15 {
        sum = sum + term / to_float(k)
        term = term * t2
        k = k + 2
    }
    return 2.0 * sum
}

fn clamp01(x: f64) -> f64 {
    if x < 0.0 { return 0.0 }
    if x > 1.0 { return 1.0 }
    return x
}

// ═══════════════════════════════════════════════════════════
// ─── n=6 CONSTANTS + PROXIMITY ───
// ═══════════════════════════════════════════════════════════

fn n6_dist_one(value: f64, constant: f64) -> f64 {
    let denom = max_f(abs_f(constant), 1.0)
    return abs_f(value - constant) / denom
}

fn n6_distance(value: f64) -> f64 {
    if value != value { return 1.0 }
    if value > 999999999.0 { return 1.0 }
    if value < 0.0 - 999999999.0 { return 1.0 }
    let mut d = 1.0
    // Dynamic: 모든 n6_constants.jsonl 상수 대상 거리 계산
    let mut i: i64 = 0
    while i < _n6_dyn_count {
        let cv = to_float(_n6_dyn_values[i])
        d = min_f(d, n6_dist_one(value, cv))
        i = i + 1
    }
    return min_f(d, 1.0)
}

fn n6_conf(value: f64) -> f64 {
    return max_f(1.0 - n6_distance(value), 0.0)
}

// ─── n6_match ───

fn match_name(value: f64) -> string {
    // Dynamic: n6_constants.jsonl 전체 상수 대상 매칭
    let mut i: i64 = 0
    while i < _n6_dyn_count {
        let cv = to_float(_n6_dyn_values[i])
        // 값 크기에 따른 적응적 threshold
        let threshold = if abs_f(cv) >= 100.0 { 0.01 } else { if abs_f(cv) >= 1.0 { 0.0001 } else { if abs_f(cv) >= 0.01 { 0.001 } else { 0.005 } } }
        if abs_f(value - cv) < threshold { return to_string(_n6_dyn_names[i]) }
        i = i + 1
    }
    return ""
}

fn match_grade(value: f64) -> string {
    if match_name(value) != "" { return "EXACT" }
    let d = n6_distance(value)
    if d < 0.01 { return "NEAR" }
    if d < 0.05 { return "CLOSE" }
    return "MISS"
}

fn sector_of(text: string) -> string {
    if text.contains("omega") || text.contains("dark") || text.contains("cosmolog") { return "cosmology" }
    if text.contains("alpha") || text.contains("137") || text.contains("electroweak") { return "quantum" }
    if text.contains("sigma") || text.contains("sopfr") || text.contains("tau") { return "n6" }
    if text.contains("phi") || text.contains("mu") || text.contains("M3") { return "n6" }
    if text.contains("J2") || text.contains("P1") || text.contains("P2") || text.contains("P3") || text.contains("P4") { return "n6" }
    if text.contains("meta_fp") || text.contains("transcend") { return "n6" }
    if text.contains("ded_") || text.contains("sym_") || text.contains("bif_") || text.contains("comp_") { return "n6" }
    if text.contains("blowup") || text.contains("d0_") || text.contains("d1_") || text.contains("d2_") { return "n6" }
    if text.contains("sqrt") || text.contains("proj") || text.contains("geom") { return "geometric" }
    return "unknown"
}

// ═══════════════════════════════════════════════════════════
// ─── METRIC TABLES (domain-dependent) ───
