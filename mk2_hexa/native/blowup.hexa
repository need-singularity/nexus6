    }
    if a[ai] == "--pool-cap" && ai + 1 < len(a) {
        ext_pool_cap = to_int(a[ai + 1])
        ai = ai + 1
    }
    if a[ai] == "--round" && ai + 1 < len(a) {
        wave_round = to_int(a[ai + 1])
        ai = ai + 1
    }
    if a[ai] == "--max-rounds" && ai + 1 < len(a) {
        wave_max_rounds = to_int(a[ai + 1])
        ai = ai + 1
    }
    ai = ai + 1
}
