// mk2_hexa/lattice.hexa — LRU divisibility lattice (draft)
// Rust 원본: src/mk2/lattice.rs
// 목적: n → divisors+multiples 노드 캐시. cross-layer edge (n|m) 로 독립 경로 탐색.
// 참고: HEXA 에 HashMap 없으므로 (key, value) 배열 페어로 선형 캐시. MK.II stdlib 시 교체.

struct LatticeNode {
    n: int,
    divisors: [int],     // sorted ascending
    multiples: [int]     // 제한된 집합 (상한 제한)
}

struct Lattice {
    keys: [int],              // LRU 순 (가장 오래된 = index 0)
    values: [LatticeNode],    // keys[i] 에 대응
    capacity: int
}

fn lattice_new(capacity) {
    return Lattice {
        keys: [],
        values: [],
        capacity: capacity
    }
}

// 분해: 1..√n 범위 시도 분할 → divisors.
fn compute_divisors(n) {
    let mut lo = []
    let mut hi = []
    let mut i = 1
    while i * i <= n {
        if n % i == 0 {
            lo = lo.push(i)
            let j = n / i
            if j != i { hi = hi.push(j) }
        }
        i = i + 1
    }
    // concat lo ++ reverse(hi) 로 오름차순 유지
    let mut out = lo
    let mut k = len(hi) - 1
    while k >= 0 {
        out = out.push(hi[k])
        k = k - 1
    }
    return out
}

// n 의 배수들 중 limit 이하만.
fn compute_multiples(n, limit) {
    let mut out = []
    let mut m = n
    while m <= limit {
        out = out.push(m)
        m = m + n
    }
    return out
}

fn node_for(n, multiples_limit) {
    return LatticeNode {
        n: n,
        divisors: compute_divisors(n),
        multiples: compute_multiples(n, multiples_limit)
    }
}

// 선형 검색 — HEXA dict 도입 전까지의 임시.
fn lattice_find_index(lat, n) {
    let mut i = 0
    while i < len(lat.keys) {
        if lat.keys[i] == n { return i }
        i = i + 1
    }
    return -1
}

// 캐시 조회 + 없으면 계산 + LRU 갱신.
// HEXA 에서 mut 필드 재대입 허용 가정.
fn lattice_get(lat, n, multiples_limit) {
    let idx = lattice_find_index(lat, n)
    if idx >= 0 {
        // LRU 꼬리로 이동: 제거 후 재삽입
        let node = lat.values[idx]
        // 재삽입 — (k/v) 둘다 이동
        let mut new_keys = []
        let mut new_vals = []
        let mut i = 0
        while i < len(lat.keys) {
            if i != idx {
                new_keys = new_keys.push(lat.keys[i])
                new_vals = new_vals.push(lat.values[i])
            }
            i = i + 1
        }
        new_keys = new_keys.push(n)
        new_vals = new_vals.push(node)
        return (Lattice { keys: new_keys, values: new_vals, capacity: lat.capacity }, node)
    }
    // miss → 계산
    let node = node_for(n, multiples_limit)
    let mut keys2 = lat.keys
    let mut vals2 = lat.values
    if len(keys2) >= lat.capacity {
        // evict oldest (index 0)
        let mut nk = []
        let mut nv = []
        let mut j = 1
        while j < len(keys2) {
            nk = nk.push(keys2[j])
            nv = nv.push(vals2[j])
            j = j + 1
        }
        keys2 = nk
        vals2 = nv
    }
    keys2 = keys2.push(n)
    vals2 = vals2.push(node)
    return (Lattice { keys: keys2, values: vals2, capacity: lat.capacity }, node)
}

// n | m 판정.
fn divides(n, m) {
    if n <= 0 { return false }
    return m % n == 0
}

// layer-up edge: m == k·n (k > 1).
fn is_layer_up_edge(n, m) {
    if n <= 0 || m <= n { return false }
    return m % n == 0
}

// 특정 layer (같은 k 배수) 전체 열거.
fn enumerate_layer(k, start, stop) {
    let mut out = []
    let mut m = start
    while m <= stop {
        if m % k == 0 { out = out.push(m) }
        m = m + 1
    }
    return out
}
