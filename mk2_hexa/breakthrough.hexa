// mk2_hexa/breakthrough.hexa — d=2 4-gate 판정 (draft)
// Rust 원본: src/alien_index/breakthrough.rs
// 목적: d=1 → d=2 승격 조건 = 독립경로 수렴 + blowup 재발견 + mk2 신뢰 + p-value.

struct BreakthroughConfig {
    min_independent_paths: int,
    mk2_confidence_threshold: float,
    significance_level: float,
    require_blowup_rediscovery: bool
}

fn breakthrough_default_config() {
    return BreakthroughConfig {
        min_independent_paths: 3,
        mk2_confidence_threshold: 0.7,
        significance_level: 0.01,
        require_blowup_rediscovery: true
    }
}

struct BreakthroughEvidence {
    independent_paths: int,
    lens_names: [string],
    blowup_rediscovered: bool,
    mk2_confidence: float,
    mk2_sector: string,
    p_value: float,
    summary: string
}

struct GateResults {
    paths_ok: bool,
    blowup_ok: bool,
    mk2_ok: bool,
    pvalue_ok: bool
}

struct BreakthroughVerdict {
    eligible: bool,
    evidence: BreakthroughEvidence,
    gate_results: GateResults
}

fn gates_all_pass(g) {
    return g.paths_ok && g.blowup_ok && g.mk2_ok && g.pvalue_ok
}

fn gates_passed_count(g) {
    let mut c = 0
    if g.paths_ok { c = c + 1 }
    if g.blowup_ok { c = c + 1 }
    if g.mk2_ok { c = c + 1 }
    if g.pvalue_ok { c = c + 1 }
    return c
}

// 4개 게이트 평가.
fn evaluate_breakthrough(evidence, config) {
    let paths_ok = evidence.independent_paths >= config.min_independent_paths
    let blowup_ok = true
    if config.require_blowup_rediscovery { blowup_ok = evidence.blowup_rediscovered }
    let mk2_ok = evidence.mk2_confidence >= config.mk2_confidence_threshold
    let pvalue_ok = evidence.p_value < config.significance_level
    let gates = GateResults {
        paths_ok: paths_ok,
        blowup_ok: blowup_ok,
        mk2_ok: mk2_ok,
        pvalue_ok: pvalue_ok
    }
    return BreakthroughVerdict {
        eligible: gates_all_pass(gates),
        evidence: evidence,
        gate_results: gates
    }
}
