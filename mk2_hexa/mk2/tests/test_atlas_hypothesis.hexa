// ═══════════════════════════════════════════════════════════
// test_atlas_hypothesis.hexa — atlas hypothesis 셀렉터 검증
//
// 검증:
//   1) `--grade=🟥★★★★` → 정확히 1건 (BL Voyager 1, SEDI:H-AF-009)
//   2) `--domain=AF`     → ≥10건 (실제 12건)
//   3) 존재하지 않는 ID  → exit 0, matches=0
//   4) `<id>` 정확 매칭   → SEDI:H-AF-009 1건
//
// 실행: HEXA_LOCAL=1 hexa test mk2_hexa/mk2/tests/test_atlas_hypothesis.hexa
// ═══════════════════════════════════════════════════════════

let _MOD = "mk2_hexa/mk2/src/atlas/hypothesis.hexa"

fn _shq(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

// 출력 + stderr 합본 + rc trailer
fn _run(arg: string) -> [string] {
    let cmd = "HEXA_LOCAL=1 HEXA_NO_LAUNCHD=1 hexa run " + _shq(_MOD) + " " + arg
        + " 2>&1; echo \"__RC=$?\""
    let raw = to_string(exec(cmd))   // @allow-bare-exec
    let marker = "__RC="
    let idx = raw.index_of(marker)
    if idx < 0 { return [raw, ""] }
    let body = raw.substring(0, idx)
    let tail = raw.substring(idx + len(marker), len(raw)).trim()
    return [body, tail]
}

// stdout-only 라인 수 카운트 (NDJSON meta + resolver 헤더 제외)
fn _count_data_lines(out: string) -> i64 {
    let lines = out.split("\n")
    let mut c: i64 = 0
    let n = len(lines)
    let mut i: i64 = 0
    while i < n {
        let ln = lines[i]
        // 결과 라인은 TAB 포함된 4-칼럼 TSV. NDJSON/resolver 라인은 TAB 없음.
        if ln.contains("\t") && !ln.starts_with("hexa-resolver") && !ln.starts_with("{") {
            c = c + 1
        }
        i = i + 1
    }
    return c
}

// stderr NDJSON 의 matches 추출 (단순 정규식)
fn _extract_matches(out: string) -> i64 {
    let mut r: i64 = -1
    let key = "\"matches\":"
    let idx = out.index_of(key)
    if idx < 0 { return r }
    let after = out.substring(idx + len(key), len(out))
    // digit 까지만
    let mut j: i64 = 0
    let n = len(after)
    while j < n {
        let ch = after.substring(j, j + 1)
        if ch < "0" || ch > "9" { break }
        j = j + 1
    }
    if j < 1 { return r }
    try { r = to_int(after.substring(0, j)) } catch e {}   // @allow-silent-catch
    return r
}

@test
fn test_grade_red_4star_returns_exactly_one() {
    let r = _run("--grade=🟥★★★★")
    let out = r[0]
    let rc = r[1]
    assert(rc == "0")
    let matches = _extract_matches(out)
    assert(matches == 1)
    // BL Voyager 1 (SEDI:H-AF-009)
    assert(out.contains("SEDI:H-AF-009"))
    assert(out.contains("BL Voyager 1"))
}

@test
fn test_domain_AF_returns_at_least_ten() {
    let r = _run("--domain=AF")
    let out = r[0]
    let rc = r[1]
    assert(rc == "0")
    let matches = _extract_matches(out)
    // ≥10건 (실제 12건)
    assert(matches > 9)
    assert(out.contains("SEDI:H-AF-001"))
    assert(out.contains("SEDI:H-AF-009"))
}

@test
fn test_nonexistent_id_returns_zero_matches_exit_zero() {
    let r = _run("NOSUCH:ID-DOES-NOT-EXIST")
    let out = r[0]
    let rc = r[1]
    assert(rc == "0")
    let matches = _extract_matches(out)
    assert(matches == 0)
}

@test
fn test_exact_id_match() {
    let r = _run("SEDI:H-AF-009")
    let out = r[0]
    let rc = r[1]
    assert(rc == "0")
    let matches = _extract_matches(out)
    assert(matches == 1)
    assert(out.contains("BL Voyager 1"))
    assert(out.contains("AF"))
}
