// ═══════════════════════════════════════════════════════════
// test_atlas_recall.hexa — sanity tests for atlas recall module
//
// Strategy: invoke the recall.hexa script via `hexa run` and grep
// stdout for expected substrings. Module is single-file with stdlib
// only, so we don't import — we shell out and check exit + output.
//
// 규칙: hexa `>=`/`<=` 금지 — `<` / `>` 만 사용.
// ═══════════════════════════════════════════════════════════

let _RECALL = "mk2_hexa/mk2/src/atlas/recall.hexa"

fn _run_recall(arg: string) -> string {
    let cmd = "HEXA_LOCAL=1 hexa run --no-sentinel " + _RECALL + " " + arg + " 2>&1"
    let mut out = ""
    try { out = to_string(exec(cmd)) } catch e {}  // @allow-silent-catch @allow-bare-exec
    return out
}

proof test_sin2_theta_W {
    let out = _run_recall("0.231")
    assert out.index_of("sin2_theta_W") > -1
    assert out.index_of("8/35") > -1
}

proof test_omega_m_one_third {
    let out = _run_recall("0.3333")
    assert out.index_of("1/3") > -1
}

proof test_alpha_inv {
    let out = _run_recall("137.036")
    assert out.index_of("alpha_inv") > -1
}

proof test_no_match_exit_ok {
    // 999999 has no physics mapping near it — best_err is large for the
    // known mappings (alpha_inv=137, mp_me=1836). The rational path
    // returns the trivial integer 999999/1; what matters per spec is
    // exit 0 and the meta NDJSON is emitted.
    let out = _run_recall("999999")
    assert out.index_of("\"stage\":\"recall\"") > -1
    assert out.index_of("\"value\":999999") > -1
}
