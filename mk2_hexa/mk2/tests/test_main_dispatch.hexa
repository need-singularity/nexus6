// ═══════════════════════════════════════════════════════════
// test_main_dispatch.hexa — main.hexa + atlas/mod.hexa 디스패치 검증
//
// 본 테스트는 "디스패치 분기" 만 검증. 실제 모듈 실행은 통합 단계에서
// 다른 에이전트가 작성하는 atlas/{lookup,hypothesis,recall,distribution}.hexa
// 가 모이면 검증함.
//
// 검증 케이스:
//   1) `mk2` (인자 없음)         → exit 1, --help 메시지
//   2) `mk2 --help`              → exit 0
//   3) `mk2 atlas` (subcmd 없음) → exit 2, atlas usage 출력
//   4) `mk2 atlas --help`        → exit 0
//   5) `mk2 atlas unknown`       → exit 2, "unknown subcommand"
//   6) `mk2 unknown`             → exit 1
//
// 실행: HEXA_LOCAL=1 hexa test mk2_hexa/mk2/tests/test_main_dispatch.hexa
// ═══════════════════════════════════════════════════════════

let _MAIN = "mk2_hexa/mk2/src/main.hexa"
let _ATLAS_MOD = "mk2_hexa/mk2/src/atlas/mod.hexa"

fn _shq(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

// 통합 실행 helper — stdout+stderr 합본, rc trailer 반환
fn _run_main(rest: string) -> [string] {
    // returns [combined_output, rc_string]
    let cmd = "HEXA_LOCAL=1 hexa run " + _shq(_MAIN) + " " + rest
        + " 2>&1; echo \"__RC=$?\""
    let raw = to_string(exec(cmd))   // @allow-bare-exec
    let marker = "__RC="
    let idx = raw.index_of(marker)
    if idx < 0 { return [raw, ""] }
    let body = raw.substring(0, idx)
    let tail = raw.substring(idx + len(marker), len(raw)).trim()
    return [body, tail]
}

fn _run_atlas(rest: string) -> [string] {
    let cmd = "HEXA_LOCAL=1 hexa run " + _shq(_ATLAS_MOD) + " atlas " + rest
        + " 2>&1; echo \"__RC=$?\""
    let raw = to_string(exec(cmd))   // @allow-bare-exec
    let marker = "__RC="
    let idx = raw.index_of(marker)
    if idx < 0 { return [raw, ""] }
    let body = raw.substring(0, idx)
    let tail = raw.substring(idx + len(marker), len(raw)).trim()
    return [body, tail]
}

@test
fn test_no_args_shows_help_exit_1() {
    let r = _run_main("")
    let out = r[0]
    let rc = r[1]
    // exit 1 (per spec: 인자 없음 → exit 1)
    assert(rc == "1")
    // --help 메시지에 5 핵심 토큰 모두 포함
    assert(out.contains("atlas"))
    assert(out.contains("classify"))
    assert(out.contains("lattice"))
    assert(out.contains("sector"))
    assert(out.contains("usage"))
}

@test
fn test_help_flag_exit_0() {
    let r = _run_main("--help")
    let rc = r[1]
    assert(rc == "0")
    let out = r[0]
    assert(out.contains("atlas"))
}

@test
fn test_h_short_flag_exit_0() {
    let r = _run_main("-h")
    let rc = r[1]
    assert(rc == "0")
}

@test
fn test_unknown_top_command_exit_1() {
    let r = _run_main("frobnicate")
    let rc = r[1]
    let out = r[0]
    assert(rc == "1")
    assert(out.contains("unknown"))
}

@test
fn test_classify_stub_exit_1() {
    // classify 는 stub — 미구현 메시지 + exit 1
    let r = _run_main("classify 7")
    let rc = r[1]
    let out = r[0]
    assert(rc == "1")
    assert(out.contains("not implemented") || out.contains("stub"))
}

@test
fn test_atlas_no_subcmd_exit_2() {
    // atlas/mod.hexa 직접 호출 (lookup.hexa 등 존재 여부 무관 — usage path)
    let r = _run_atlas("")
    let rc = r[1]
    let out = r[0]
    assert(rc == "2")
    // 4 서브커맨드 모두 usage 에 등장
    assert(out.contains("lookup"))
    assert(out.contains("hypothesis"))
    assert(out.contains("recall"))
    assert(out.contains("distribution"))
}

@test
fn test_atlas_help_flag_exit_0() {
    let r = _run_atlas("--help")
    let rc = r[1]
    assert(rc == "0")
    let out = r[0]
    assert(out.contains("subcommand"))
}

@test
fn test_atlas_unknown_subcmd_exit_2() {
    let r = _run_atlas("frobulate")
    let rc = r[1]
    let out = r[0]
    assert(rc == "2")
    assert(out.contains("unknown"))
}

@test
fn test_atlas_help_lists_all_five_subcmds_in_usage() {
    let r = _run_atlas("--help")
    let out = r[0]
    assert(out.contains("lookup"))
    assert(out.contains("hypothesis"))
    assert(out.contains("recall"))
    assert(out.contains("distribution"))
    assert(out.contains("validate"))
}
