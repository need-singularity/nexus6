// ═══════════════════════════════════════════════════════════
// test_atlas_lookup.hexa — proof tests for atlas/lookup.hexa
//
// 검증 케이스:
//   1) `lookup alpha_inv` → matches > 0, exit 0, NDJSON stage 라인 emit
//   2) `lookup nonsense_xyz_42` → matches == 0, exit 0
//
// Strategy: hexa run 으로 lookup.hexa 호출 → stdout+stderr 합본,
// rc trailer 로 exit code 회수. NDJSON meta 도 stderr 에 포함.
//
// 규칙: hexa `>=`/`<=` 금지 — `<` / `>` 만 사용.
// ═══════════════════════════════════════════════════════════

let _LOOKUP = "mk2_hexa/mk2/src/atlas/lookup.hexa"

fn _run_lookup(arg: string) -> [string] {
    // returns [combined_output, rc_string]
    let cmd = "HEXA_LOCAL=1 hexa run " + _LOOKUP + " " + arg
        + " 2>&1; echo \"__RC=$?\""
    let raw = to_string(exec(cmd))   // @allow-bare-exec
    let marker = "__RC="
    let idx = raw.index_of(marker)
    if idx < 0 { return [raw, ""] }
    let body = raw.substring(0, idx)
    let tail = raw.substring(idx + len(marker), len(raw)).trim()
    return [body, tail]
}

// extract `"matches":N` from NDJSON meta line
fn _extract_matches(out: string) -> i64 {
    let needle = "\"matches\":"
    let p = out.index_of(needle)
    if p < 0 { return -1 }
    let rest = out.substring(p + len(needle), len(out))
    // read until non-digit
    let mut i: i64 = 0
    let nl = len(rest)
    let mut digits: [string] = []
    while i < nl {
        let c = rest.substring(i, i + 1)
        let isd = c == "0" || c == "1" || c == "2" || c == "3" || c == "4"
            || c == "5" || c == "6" || c == "7" || c == "8" || c == "9"
        if !isd {
            // stop at first non-digit
            i = nl
        } else {
            digits.push(c)
            i = i + 1
        }
    }
    if len(digits) < 1 { return -1 }
    let mut v: i64 = -1
    try { v = to_int(digits.join("")) } catch e {}   // @allow-silent-catch
    return v
}

proof test_lookup_alpha_inv_has_matches {
    let r = _run_lookup("alpha_inv")
    let out = r[0]
    let rc = r[1]
    assert rc == "0"
    // alpha_inv is a known constant → header must include name
    assert out.index_of("alpha_inv") > -1
    // matches > 0 (atlas.n6 has alpha_inv mentions)
    let m = _extract_matches(out)
    assert m > 0
    // NDJSON meta emitted
    assert out.index_of("\"stage\":") > -1
}

proof test_lookup_no_match_exit_ok {
    let r = _run_lookup("nonsense_xyz_42")
    let out = r[0]
    let rc = r[1]
    // spec: 매칭 0 건이어도 exit 0 (정상 답변, 단지 비어 있음)
    assert rc == "0"
    let m = _extract_matches(out)
    assert m == 0
    // human-readable miss line
    assert out.index_of("(no entries)") > -1 || out.index_of("matches:  0") > -1
}
