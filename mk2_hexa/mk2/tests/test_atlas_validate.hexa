// ═══════════════════════════════════════════════════════════
// test_atlas_validate.hexa — proof tests for atlas/validate.hexa
//
// 검증 케이스:
//   1) `validate n6/atlas.n6 --quiet` → exit 0, errors=0
//   2) `validate /tmp/nonexistent_atlas_xyz.n6 --quiet` → exit > 0
//   3) `validate --strict n6/atlas.n6 --quiet` → exit 1 (warnings > 0 baseline)
//   4) `validate --help` → exit 0, help text contains "validate"
//
// Strategy: hexa run 으로 validate.hexa 호출 → stdout+stderr 합본,
// rc trailer 로 exit code 회수. NDJSON `NEXUS_MK2_ATLAS_VALIDATE` 도
// stderr 에 emit 되므로 합본 안에 포함.
//
// 실행: HEXA_LOCAL=1 hexa test mk2_hexa/mk2/tests/test_atlas_validate.hexa
//
// 규칙: hexa `>=`/`<=` 금지 — `<` / `>` 만 사용.
// ═══════════════════════════════════════════════════════════

let _VALIDATE = "mk2_hexa/mk2/src/atlas/validate.hexa"

fn _shq(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _run_validate(arg_str: string) -> [string] {
    // returns [combined_output, rc_string]
    let cmd = "HEXA_LOCAL=1 HEXA_RESOLVER_NO_REROUTE=1 hexa run "
        + _shq(_VALIDATE) + " " + arg_str + " 2>&1; echo \"__RC=$?\""
    let raw = to_string(exec(cmd))   // @allow-bare-exec
    let marker = "__RC="
    let idx = raw.index_of(marker)
    if idx < 0 { return [raw, ""] }
    let body = raw.substring(0, idx)
    let tail = raw.substring(idx + len(marker), len(raw)).trim()
    return [body, tail]
}

// extract integer value of `"<key>":N` from output
fn _extract_int_after(out: string, key: string) -> i64 {
    let needle = "\"" + key + "\":"
    let p = out.index_of(needle)
    if p < 0 { return -1 }
    let rest = out.substring(p + len(needle), len(out))
    let mut i: i64 = 0
    let nl = len(rest)
    let mut digits: [string] = []
    while i < nl {
        let c = rest.substring(i, i + 1)
        let isd = c == "0" || c == "1" || c == "2" || c == "3" || c == "4"
            || c == "5" || c == "6" || c == "7" || c == "8" || c == "9"
        if !isd { i = nl }
        else { digits.push(c); i = i + 1 }
    }
    if len(digits) < 1 { return -1 }
    let mut v: i64 = -1
    try { v = to_int(digits.join("")) } catch e {}   // @allow-silent-catch
    return v
}

@test
fn test_validate_default_path_clean() {
    // n6/atlas.n6 — baseline: errors=0
    let r = _run_validate("n6/atlas.n6 --quiet")
    let out = r[0]
    let rc = r[1]
    assert(rc == "0")
    // own meta emitted
    assert(out.contains("NEXUS_MK2_ATLAS_VALIDATE"))
    // errors=0 in our meta
    let meta_idx = out.index_of("NEXUS_MK2_ATLAS_VALIDATE")
    let meta = out.substring(meta_idx, len(out))
    let errs = _extract_int_after(meta, "errors")
    assert(errs == 0)
    // total > 14000 (baseline atlas.n6 has 14,609 records — drift tolerant)
    let total = _extract_int_after(meta, "total")
    assert(total > 14000)
}

@test
fn test_validate_nonexistent_file_exits_nonzero() {
    let r = _run_validate("/tmp/nonexistent_atlas_xyz_test.n6 --quiet")
    let out = r[0]
    let rc = r[1]
    // exit > 0 expected (file not found by standalone tool → exit 2)
    assert(rc != "0")
    // standalone tool 의 'file not found' 메시지가 forward 되어야 함
    assert(out.contains("not found"))
}

@test
fn test_validate_strict_warnings_fail() {
    // baseline: warnings > 0 (1,508). --strict → exit 1
    let r = _run_validate("--strict n6/atlas.n6 --quiet")
    let out = r[0]
    let rc = r[1]
    // exit 1 because warnings > 0 in --strict mode
    assert(rc == "1")
    // own meta still emitted
    assert(out.contains("NEXUS_MK2_ATLAS_VALIDATE"))
    let meta_idx = out.index_of("NEXUS_MK2_ATLAS_VALIDATE")
    let meta = out.substring(meta_idx, len(out))
    let warns = _extract_int_after(meta, "warnings")
    assert(warns > 0)
}

@test
fn test_validate_help_text() {
    let r = _run_validate("--help")
    let out = r[0]
    let rc = r[1]
    assert(rc == "0")
    // help text mentions key tokens
    assert(out.contains("usage"))
    assert(out.contains("validate"))
    assert(out.contains("--strict"))
}
