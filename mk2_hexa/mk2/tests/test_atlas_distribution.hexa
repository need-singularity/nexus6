// ═══════════════════════════════════════════════════════════
// test_atlas_distribution.hexa — proof tests for atlas/distribution.hexa
//
// Spec axes:
//   --by sector   → rank-1 must be an "n6" prefix sector with count > 1000
//                   (data drift from docs/mk2/05: doc baseline had n6=13,848,
//                    current atlas.n6 has n6atlas=3,379 — see hexa_lang_gaps_from_atlas.md)
//   --by grade    → 🟥★★★★ count == 1, 🟧★ count ~ 131
//   --by ai --top=3 → 3 rendered rank rows present
//
// 규칙: hexa `>=`/`<=` 금지 — `<` / `>` 만 사용.
// ═══════════════════════════════════════════════════════════

let _SCRIPT = "mk2_hexa/mk2/src/atlas/distribution.hexa"

fn _run_dist(flags: string) -> string {
    let cmd = "hexa run " + _SCRIPT + " " + flags + " 2>/dev/null"
    return to_string(exec(cmd))   // @allow-bare-exec
}

// extract count for the rank-1 row from rendered output ("rank  key  count  pct")
fn _rank1_count(out: string) -> i64 {
    let lines = out.split("\n")
    let n = len(lines)
    let mut i: i64 = 0
    while i < n {
        let ln = lines[i]
        // rank-1 row starts with leading spaces then "1  "
        let t = ln.trim()
        if t.len() > 1 && t.substring(0, 2) == "1 " {
            // parse: "1  key.... count pct"
            // simplest: split on multiple spaces, take last-1 numeric-ish field
            let parts = t.split(" ")
            let np = len(parts)
            // walk backwards, find token with comma-separated digits, strip commas
            let mut k: i64 = np - 1
            while k > -1 {
                let p = parts[k]
                if p.len() > 0 && p.index_of("%") < 0 {
                    let cleaned = p.replace(",", "")
                    let mut v: i64 = -1
                    try { v = to_int(cleaned) } catch e {}  // @allow-silent-catch
                    if v > 0 { return v }
                }
                k = k - 1
            }
        }
        i = i + 1
    }
    return -1
}

// extract count for a row whose key starts with prefix
fn _count_for_key(out: string, prefix: string) -> i64 {
    let lines = out.split("\n")
    let n = len(lines)
    let mut i: i64 = 0
    while i < n {
        let ln = lines[i]
        if ln.index_of(prefix) > -1 {
            // last numeric-ish token before pct
            let parts = ln.split(" ")
            let np = len(parts)
            let mut k: i64 = np - 1
            while k > -1 {
                let p = parts[k]
                if p.len() > 0 && p.index_of("%") < 0 {
                    let cleaned = p.replace(",", "")
                    let mut v: i64 = -1
                    try { v = to_int(cleaned) } catch e {}  // @allow-silent-catch
                    if v > -1 { return v }
                }
                k = k - 1
            }
        }
        i = i + 1
    }
    return -1
}

// extract rank-1 key (everything between leading "1" and the count column)
fn _rank1_key(out: string) -> string {
    let lines = out.split("\n")
    let n = len(lines)
    let mut i: i64 = 0
    while i < n {
        let ln = lines[i]
        let t = ln.trim()
        if t.len() > 1 && t.substring(0, 2) == "1 " {
            // "1  key   count  pct" — drop leading "1", split, take token 1
            let rest = t.substring(1, t.len()).trim()
            let parts = rest.split(" ")
            let np = len(parts)
            let mut k: i64 = 0
            while k < np {
                if parts[k].len() > 0 { return parts[k] }
                k = k + 1
            }
        }
        i = i + 1
    }
    return ""
}

// count rendered rank rows (lines beginning with "<digits>  ")
fn _rank_rows(out: string) -> i64 {
    let lines = out.split("\n")
    let n = len(lines)
    let mut count: i64 = 0
    let mut i: i64 = 0
    while i < n {
        let t = lines[i].trim()
        if t.len() > 0 {
            let first = t.substring(0, 1)
            if first == "0" || first == "1" || first == "2"
                || first == "3" || first == "4" || first == "5"
                || first == "6" || first == "7" || first == "8" || first == "9" {
                // first token must be pure digits
                let parts = t.split(" ")
                if len(parts) > 1 {
                    let head = parts[0]
                    let mut all_digit = true
                    let hl = head.len()
                    let mut hi: i64 = 0
                    while hi < hl {
                        let ch = head.substring(hi, hi + 1)
                        if ch != "0" && ch != "1" && ch != "2" && ch != "3"
                            && ch != "4" && ch != "5" && ch != "6"
                            && ch != "7" && ch != "8" && ch != "9" {
                            all_digit = false
                        }
                        hi = hi + 1
                    }
                    if all_digit { count = count + 1 }
                }
            }
        }
        i = i + 1
    }
    return count
}

proof test_by_sector_n6_dominates {
    let out = _run_dist("--by sector --top=5")
    let key = _rank1_key(out)
    let cnt = _rank1_count(out)
    // rank-1 must contain the "n6" token and have count > 1000
    // (relaxed from doc spec count > 10000 due to atlas.n6 drift)
    assert key.index_of("n6") > -1
    assert cnt > 1000
}

proof test_by_grade_breakthrough_singleton {
    let out = _run_dist("--by grade")
    // 🟥★★★★ = 1 (unique top breakthrough)
    let cnt_top = _count_for_key(out, "🟥★★★★")
    assert cnt_top == 1
    // 🟧★ ≈ 131 — accept 120..140 to absorb minor regenerations
    let cnt_orange_star = _count_for_key(out, "🟧★ ")
    assert cnt_orange_star > 119
    assert cnt_orange_star < 141
}

proof test_by_ai_top3_rows_rendered {
    let out = _run_dist("--by ai --top=3")
    let rows = _rank_rows(out)
    assert rows == 3
}
