// mk2_hexa/record.hexa — AlienIndexRecord (draft)
// Rust 원본: src/alien_index/record.rs
// 목적: 한 레코드의 현재 등급 + 히스토리 + 승격 관계.

struct HistoryEntry {
    timestamp_unix: int,
    d: int,
    r: int,
    reason: string
}

struct AlienIndexRecord {
    id: string,
    current: AlienIndex,
    history: [HistoryEntry],
    promotion_candidate: bool,
    promoted_from: string       // "" 이면 root, 아니면 부모 id
}

fn record_new(id, initial, now_unix) {
    let e = HistoryEntry {
        timestamp_unix: now_unix,
        d: initial.d,
        r: initial.r,
        reason: "initial"
    }
    return AlienIndexRecord {
        id: id,
        current: initial,
        history: [e],
        promotion_candidate: initial.r == 10,
        promoted_from: ""
    }
}

// Returns child record if self was (d, 10); original rec is mutated: flag cleared.
// child.promoted_from = rec.id. If not eligible, returns sentinel (id="").
fn record_promote(rec, now_unix) {
    let child_ai = alien_breakthrough(rec.current)
    if alien_is_sentinel(child_ai) {
        return (rec, AlienIndexRecord {
            id: "",
            current: alien_index_new(-1, 0),
            history: [],
            promotion_candidate: false,
            promoted_from: ""
        })
    }
    let child_id = rec.id + "→d" + to_string(child_ai.d)
    let mut child = record_new(child_id, child_ai, now_unix)
    child.promoted_from = rec.id

    // Clear promotion flag on parent (caller must reassign since HEXA copies).
    let mut parent = rec
    parent.promotion_candidate = false
    return (parent, child)
}

// History append after external grade update.
fn record_update(rec, next_ai, reason, now_unix) {
    // Guard: d monotonic non-decreasing.
    if next_ai.d < rec.current.d {
        // regression — caller should handle error; here just refuse.
        return rec
    }
    let e = HistoryEntry {
        timestamp_unix: now_unix,
        d: next_ai.d,
        r: next_ai.r,
        reason: reason
    }
    let mut updated = rec
    updated.current = next_ai
    updated.promotion_candidate = next_ai.r == 10
    updated.history = updated.history.push(e)
    return updated
}
