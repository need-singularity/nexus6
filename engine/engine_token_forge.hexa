// engine_token_forge.hexa — "Sculptor" (조각가)
// LLM compression engine: r<=0.4 L<=0.05 고정점 달성
// 사용: hexa engine_token_forge.hexa status|tick|report
//
// State:
//   $home/Dev/token-forge/bench/runs/ — latest report.json (r, L)
//   $home/Dev/token-forge/dictionary/ — symbol dictionary entries
// Growth bus:
//   $home/core/nexus/discovery/growth_bus.jsonl

// ═══════════════════════════════════════════════════════════
// ─── CONSTANTS ───
// ═══════════════════════════════════════════════════════════

comptime const version = "1.0.0"
comptime const name = "token_forge"
comptime const personality = "Sculptor"

let home = exec("printenv HOME")
let dev = home + "/Dev"
let project_dir = dev + "/token-forge"
let bench_dir = project_dir + "/bench/runs"
let dict_dir = project_dir + "/dictionary"
let bus_file = dev + "/nexus/discovery/growth_bus.jsonl"
let history_file = dev + "/nexus/token_forge_history.jsonl"

comptime const goal_r = 0.4
comptime const goal_l = 0.05
comptime const aggressive_r = 0.5

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {}
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn clamp01(x: f64) -> f64 {
    if x < 0.0 { return 0.0 }
    if x > 1.0 { return 1.0 }
    return x
}

fn timestamp() -> string {
    let r = exec("date +%Y-%m-%dT%H:%M:%S")
    r.trim()
}

fn read_file_safe(path: string) -> string {
    try {
        return read_file(path)
    } catch e {
        return ""
    }
}

fn dir_exists(path: string) -> bool {
    let mut r = ""
    try { r = to_string(exec("test -d " + path + " && echo 1")) } catch e {}
    r.trim() == "1"
}

fn file_exists(path: string) -> bool {
    let mut r = ""
    try { r = to_string(exec("test -f " + path + " && echo 1")) } catch e {}
    r.trim() == "1"
}

fn append_bus(phase: string, status: string, detail: string) {
    let ts = timestamp()
    let line = "{\"source\":\"" + name + "\",\"timestamp\":\"" + ts + "\",\"phase\":\"" + phase + "\",\"status\":\"" + status + "\",\"detail\":\"" + detail + "\"}"
    try {
        append_file(bus_file, line + "\n")
    } catch e {}
}

fn append_history(r: f64, l: f64, dict_count: int, label: string) {
    let ts = timestamp()
    let line = "{\"ts\":\"" + ts + "\",\"r\":" + to_string(r) + ",\"L\":" + to_string(l) + ",\"dict\":" + to_string(dict_count) + ",\"label\":\"" + label + "\"}"
    try {
        append_file(history_file, line + "\n")
    } catch e {}
}

// ═══════════════════════════════════════════════════════════
// ─── JSON FIELD EXTRACTION ───
// ═══════════════════════════════════════════════════════════

fn extract_json_float(content: string, key: string) -> f64 {
    // 간이 JSON 파서: "key": 0.123 패턴 추출
    if !content.contains(key) { return -1.0 }
    let parts = content.split("\"" + key + "\"")
    if parts.len() < 2 { return -1.0 }
    let after = parts[1]
    // ": VALUE" 패턴
    if !after.contains(":") { return -1.0 }
    let val_str = after.split(":")[1].trim()
    // 숫자 끝 찾기
    let mut clean = val_str
    if clean.contains(",") { clean = clean.split(",")[0] }
    if clean.contains("}") { clean = clean.split("}")[0] }
    if clean.contains("\n") { clean = clean.split("\n")[0] }
    return safe_float(clean.trim())
}

fn extract_json_int(content: string, key: string) -> int {
    let v = extract_json_float(content, key)
    if v < 0.0 { return -1 }
    return to_int(v)
}

// ═══════════════════════════════════════════════════════════
// ─── STATE READERS ───
// ═══════════════════════════════════════════════════════════

struct BenchReport {
    r: f64,           // compression ratio
    l: f64,           // loss
    found: bool,      // report.json 존재 여부
    path: string      // report 경로
}

fn find_latest_report() -> BenchReport {
    // bench/runs/ 하위에서 가장 최근 report.json 찾기
    let mut result = ""
    try {
        result = exec("bash -c ls -t " + bench_dir + "/*/report.json 2>/dev/null | head -1")
    } catch e {}

    let path = result.trim()
    if path == "" {
        // 단일 report.json 시도
        let fallback = bench_dir + "/report.json"
        if file_exists(fallback) {
            let content = read_file_safe(fallback)
            let r = extract_json_float(content, "r")
            let l = extract_json_float(content, "L")
            // L 대소문자 fallback
            let l2 = if l < 0.0 { extract_json_float(content, "loss") } else { l }
            let r2 = if r < 0.0 { extract_json_float(content, "compression_ratio") } else { r }
            return BenchReport { r: r2, l: l2, found: true, path: fallback }
        }
        return BenchReport { r: -1.0, l: -1.0, found: false, path: "" }
    }

    let content = read_file_safe(path)
    let r = extract_json_float(content, "r")
    let l = extract_json_float(content, "L")
    let l2 = if l < 0.0 { extract_json_float(content, "loss") } else { l }
    let r2 = if r < 0.0 { extract_json_float(content, "compression_ratio") } else { r }
    return BenchReport { r: r2, l: l2, found: true, path: path }
}

fn count_dictionary_entries() -> int {
    if !dir_exists(dict_dir) { return 0 }
    let mut result = "0"
    try {
        result = exec("bash -c find " + dict_dir + " -type f | wc -l")
    } catch e {}
    let mut count = 0
    try { count = to_int(result.trim()) } catch e {}
    return count
}

fn dict_changed_recently() -> bool {
    // 최근 1시간 이내 dictionary 변경 여부
    let mut result = ""
    try {
        result = exec("bash -c find " + dict_dir + " -type f -mmin -60 | head -1")
    } catch e {}
    return result.trim() != ""
}

// ═══════════════════════════════════════════════════════════
// ─── HEALTH CALCULATION ───
// ═══════════════════════════════════════════════════════════

struct HealthResult {
    score: f64,
    label: string,   // HEALTHY|STAGNANT|BREAKTHROUGH|GOAL_NEAR
    detail: string
}

fn compute_health(report: BenchReport, dict_count: int) -> HealthResult {
    if !report.found {
        return HealthResult {
            score: 0.1,
            label: "STAGNANT",
            detail: "벤치 리포트 없음 — 초기 상태"
        }
    }

    let r = report.r
    let l = report.l

    // 목표 달성 판정
    if r >= 0.0 && r <= goal_r && l >= 0.0 && l <= goal_l {
        return HealthResult {
            score: 0.99,
            label: "GOAL_NEAR",
            detail: "고정점 달성! r=" + to_string(r) + " L=" + to_string(l)
        }
    }

    // 돌파 근접 (r <= 0.42 AND L <= 0.06)
    if r >= 0.0 && r <= 0.42 && l >= 0.0 && l <= 0.06 {
        return HealthResult {
            score: 0.92,
            label: "BREAKTHROUGH",
            detail: "돌파 근접 r=" + to_string(r) + " L=" + to_string(l)
        }
    }

    // 건강도 계산: r 기여 50%, L 기여 30%, dict 기여 20%
    let mut score = 0.0
    if r >= 0.0 {
        // r: 낮을수록 좋음. 1.0→0.0, 0.4→1.0
        let r_score = clamp01((1.0 - r) / 0.6)
        score = score + r_score * 0.5
    }
    if l >= 0.0 {
        // L: 낮을수록 좋음. 1.0→0.0, 0.05→1.0
        let l_score = clamp01((1.0 - l) / 0.95)
        score = score + l_score * 0.3
    }
    // dict: 100+ = 만점
    let dict_score = clamp01(to_float(dict_count) / 100.0)
    score = score + dict_score * 0.2

    // 정체 판정: dict 변화 없고 r > 0.5
    let stagnant = r > aggressive_r && !dict_changed_recently()
    if stagnant {
        return HealthResult {
            score: score,
            label: "STAGNANT",
            detail: "r=" + to_string(r) + " 높고 dict 정체 — 공격적 압축 필요"
        }
    }

    return HealthResult {
        score: score,
        label: "HEALTHY",
        detail: "r=" + to_string(r) + " L=" + to_string(l) + " dict=" + to_string(dict_count)
    }
}

// ═══════════════════════════════════════════════════════════
// ─── CONVERGENCE TRACKER (Evolve) ───
// ═══════════════════════════════════════════════════════════

fn predict_rounds_to_goal(report: BenchReport) -> string {
    // 히스토리에서 r 수렴 곡선 읽기 → 단순 선형 외삽
    let hist = read_file_safe(history_file)
    if hist == "" { return "데이터 부족 — 예측 불가" }

    let lines = hist.split("\n")
    let mut r_values = []
    let mut count = 0
    // 최근 10개 수집
    let mut i = lines.len() - 1
    while i >= 0 && count < 10 {
        let line = lines[i]
        if line.contains("\"r\":") {
            let rv = extract_json_float(line, "r")
            if rv >= 0.0 {
                r_values = [rv] + r_values
                count = count + 1
            }
        }
        i = i - 1
    }

    if count < 3 { return "포인트 " + to_string(count) + "개 — 3개 이상 필요" }

    // 평균 델타 계산
    let mut delta_sum = 0.0
    let mut di = 1
    while di < r_values.len() {
        delta_sum = delta_sum + (r_values[di] - r_values[di - 1])
        di = di + 1
    }
    let avg_delta = delta_sum / to_float(r_values.len() - 1)

    if avg_delta >= 0.0 {
        return "r 감소 추세 없음 (avg_delta=" + to_string(avg_delta) + ") — 전략 변경 필요"
    }

    let current_r = r_values[r_values.len() - 1]
    let gap = current_r - goal_r
    if gap <= 0.0 { return "이미 목표 달성!" }

    let rounds = gap / abs_f(avg_delta)
    return "예상 " + to_string(to_int(rounds) + 1) + "라운드 후 r<=" + to_string(goal_r) + " 도달 (avg_delta=" + to_string(avg_delta) + ")"
}

// ═══════════════════════════════════════════════════════════
// ─── MODES ───
// ═══════════════════════════════════════════════════════════

fn mode_status() {
    println("═══ " + name + " [" + personality + "] v" + version + " ═══")

    let report = find_latest_report()
    let dict_count = count_dictionary_entries()
    let h = compute_health(report, dict_count)

    println("project: " + project_dir)
    if report.found {
        println("bench: " + report.path)
        println("r: " + to_string(report.r))
        println("L: " + to_string(report.l))
    } else {
        println("bench: (not found)")
    }
    println("dictionary: " + to_string(dict_count) + " entries")
    println("health:" + to_string(h.score))
    println(h.label)
    println("detail: " + h.detail)

    // evolve 예측
    let pred = predict_rounds_to_goal(report)
    println("convergence: " + pred)
}

fn mode_tick() {
    println("═══ " + name + " tick ═══")
    append_bus("tick", "start", "sculptor tick begin")

    if !dir_exists(project_dir) {
        println("ERROR: project dir not found: " + project_dir)
        append_bus("tick", "error", "project dir missing")
        return
    }

    let report = find_latest_report()
    let dict_count = count_dictionary_entries()
    let h = compute_health(report, dict_count)

    println("pre-tick health:" + to_string(h.score) + " " + h.label)

    // ─── 틱 로직 ───
    if h.label == "GOAL_NEAR" {
        // 고정점 달성 — 축하 + 기록만
        println("GOAL_NEAR: 고정점 r<=" + to_string(goal_r) + " L<=" + to_string(goal_l) + " 달성!")
        println("  유지 모드 — 추가 압축 불필요")
        append_bus("tick", "goal_near", "fixed point achieved r=" + to_string(report.r) + " L=" + to_string(report.l))
        append_history(report.r, report.l, dict_count, "goal_near")
        return
    }

    if h.label == "BREAKTHROUGH" {
        // 돌파 근접 — 신중한 1라운드
        println("BREAKTHROUGH: 돌파 근접 — 정밀 압축 1라운드")
        // R37/AN13/L3-PY violation — python3 forge/compress.py invocation stubbed 2026-04-18
        // Original: exec("bash -c cd ... && /usr/bin/python3 forge/compress.py [--careful] 2>&1 | tail -5")
        // No-op: return sentinel — caller logs result string. Research module (token forge).
        eprintln("[R37] engine_token_forge.BREAKTHROUGH: python3 forge/compress.py disabled; skipping compress round.")
        let result = "[R37-STUB] compress skipped (python3 blocked)"
        println("  result: " + result)
        append_bus("tick", "breakthrough", "careful compress [R37-STUB]")
        append_history(report.r, report.l, dict_count, "breakthrough_tick")
        return
    }

    if report.found && report.r > aggressive_r {
        // r > 0.5: 공격적 압축 (2라운드)
        println("AGGRESSIVE: r=" + to_string(report.r) + " > " + to_string(aggressive_r) + " — 공격적 압축 2라운드")
        // R37/AN13/L3-PY violation — python3 forge/compress.py invocation stubbed 2026-04-18
        // Original: (loop x2) exec("bash -c cd ... && /usr/bin/python3 forge/compress.py 2>&1 | tail -3")
        eprintln("[R37] engine_token_forge.AGGRESSIVE: python3 forge/compress.py disabled; skipping 2-round compress.")
        let mut round = 1
        while round <= 2 {
            println("  round " + to_string(round) + "/2 ... [R37-STUB] skipped")
            round = round + 1
        }
        append_bus("tick", "aggressive", "2-round compress r=" + to_string(report.r) + " [R37-STUB]")
        append_history(report.r, report.l, dict_count, "aggressive")
        return
    }

    if !dict_changed_recently() && dict_count > 0 {
        // dictionary 정체 → 새 심볼 패턴 탐색
        println("DICT_STAGNANT: dictionary 정체 — 새 심볼 패턴 탐색")
        // R37/AN13/L3-PY violation — python3 forge/compress.py invocation stubbed 2026-04-18
        // Original: exec("bash -c cd ... && /usr/bin/python3 forge/compress.py [--explore] 2>&1 | tail -5")
        eprintln("[R37] engine_token_forge.DICT_STAGNANT: python3 forge/compress.py --explore disabled.")
        let result = "[R37-STUB] explore skipped (python3 blocked)"
        println("  result: " + result)
        append_bus("tick", "explore", "dict stagnant, exploring new symbols [R37-STUB]")
        append_history(report.r, report.l, dict_count, "explore")
        return
    }

    // DEFAULT: 1라운드 압축
    println("DEFAULT: 표준 압축 1라운드")
    // R37/AN13/L3-PY violation — python3 forge/compress.py invocation stubbed 2026-04-18
    // Original: exec("bash -c cd ... && /usr/bin/python3 forge/compress.py 2>&1 | tail -5")
    eprintln("[R37] engine_token_forge.DEFAULT: python3 forge/compress.py disabled; skipping compress round.")
    let result = "[R37-STUB] compress skipped (python3 blocked)"
    println("  result: " + result)

    // 후처리: 새 벤치 결과 기록
    let post_report = find_latest_report()
    if post_report.found {
        append_history(post_report.r, post_report.l, count_dictionary_entries(), "default_tick")
    }
    append_bus("tick", "complete", "default compress round")
}

fn mode_report() {
    println("╔═══════════════════════════════════════════════╗")
    println("║  TOKEN FORGE — Sculptor Report               ║")
    println("╚═══════════════════════════════════════════════╝")
    println("")

    let report = find_latest_report()
    let dict_count = count_dictionary_entries()
    let h = compute_health(report, dict_count)

    println("── Metrics ──")
    if report.found {
        println("  compression ratio (r): " + to_string(report.r))
        println("  loss (L):              " + to_string(report.l))
        println("  goal r:                <= " + to_string(goal_r))
        println("  goal L:                <= " + to_string(goal_l))
        if report.r >= 0.0 {
            let r_gap = report.r - goal_r
            println("  r gap:                 " + to_string(r_gap))
        }
        if report.l >= 0.0 {
            let l_gap = report.l - goal_l
            println("  L gap:                 " + to_string(l_gap))
        }
    } else {
        println("  (no bench report found)")
    }

    println("")
    println("── Dictionary ──")
    println("  entries: " + to_string(dict_count))
    println("  active:  " + if dict_changed_recently() { "yes (changed <1h)" } else { "no (stagnant)" })

    println("")
    println("── Health ──")
    println("  health:" + to_string(h.score))
    println("  " + h.label)
    println("  " + h.detail)

    println("")
    println("── Convergence ──")
    let pred = predict_rounds_to_goal(report)
    println("  " + pred)

    // 히스토리 최근 5개 출력
    let hist = read_file_safe(history_file)
    if hist != "" {
        println("")
        println("── Recent History (last 5) ──")
        let lines = hist.split("\n")
        let mut shown = 0
        let mut idx = lines.len() - 1
        while idx >= 0 && shown < 5 {
            let line = lines[idx]
            if line.trim() != "" {
                println("  " + line.trim())
                shown = shown + 1
            }
            idx = idx - 1
        }
    }

    println("")
    append_bus("report", "complete", "sculptor report generated")
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only a[2] 가정 → Linux 에서 a[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut a: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        a = a + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && a.len() >= 3 {
        if a[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < a.len() {
                _a2 = _a2 + [a[_j2]]
                _j2 = _j2 + 1
            }
            a = _a2
        }
    }
    let mode = if a.len() >= 3 { a[2] } else { "status" }

    if mode == "status" {
        mode_status()
    } else if mode == "tick" {
        mode_tick()
    } else if mode == "report" {
        mode_report()
    } else {
        println("engine_token_forge.hexa v" + version + " — Sculptor")
        println("usage: hexa engine_token_forge.hexa status|tick|report")
    }
}
