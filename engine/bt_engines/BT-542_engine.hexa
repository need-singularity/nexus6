// BT-542_engine.hexa — BT-specialized discovery engine
// auto-generated by bt_engine_forge.hexa (EF-P7-1)
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
// bt_id: BT-542
// attack_angle: ["p_vs_np", "complexity_class", "polynomial_hierarchy", "sat_solver", "relativization", "natural_proofs"]
// 4-stage: discovery_loop → seed_extraction → score_eval → atlas_emit
// usage: hexa run <self> <scan|score|emit|run>

let HOME = env("HOME")
let NEXUS = HOME + "/core/nexus"
let HARNESS = NEXUS + "/harness"
let ATLAS_N6 = NEXUS + "/n6/atlas.n6"
let USAGE = HARNESS + "/engines_usage.jsonl"
let BT_ID = "BT-542"
let ENGINE_NAME = "BT-542_engine"
let ATTACK_KWS: [string] = ["p_vs_np", "complexity_class", "polynomial_hierarchy", "sat_solver", "relativization", "natural_proofs"]

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _to_int0(s: string) -> i64 {
    if s == "" { return 0 }
    let first = _str(s.split("\n")[0]).trim()
    if first == "" { return 0 }
    return to_int(first)
}

fn now_unix() -> i64 {
    return _to_int0(_str(exec("date +%s")).trim())
}

fn json_escape(s: string) -> string {
    let mut r = s
    r = r.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", " ")
    r = r.replace("\r", " ")
    r = r.replace("\t", " ")
    return r
}

fn append_usage(row: string) {
    let esc = row.replace("'", "'\\''")
    try { exec("printf '%s\\n' '" + esc + "' >> '" + USAGE + "'") } catch e {}
}

// stage 1: discovery loop — atlas.n6 grep 으로 공격각 매칭 라인 스캔
fn stage_discovery() -> [string] {
    let mut hits: [string] = []
    if file_exists(ATLAS_N6) == false { return hits }
    let mut k = 0
    while k < ATTACK_KWS.len() {
        let kw = _str(ATTACK_KWS[k]).trim()
        if kw == "" { k = k + 1; continue }
        let cmd = "grep -m 20 -F -- '" + kw.replace("'", "'\\''") + "' '" + ATLAS_N6 + "' 2>/dev/null || true"
        let raw = _str(exec(cmd)).trim()
        if raw != "" {
            let lines = raw.split("\n")
            let mut i = 0
            while i < lines.len() {
                let ln = _str(lines[i]).trim()
                if ln != "" { hits = hits.push(ln) }
                i = i + 1
            }
        }
        k = k + 1
    }
    return hits
}

// stage 2: seed extraction — 매칭 라인에서 BT-xxx / P-xxx / 불변량 토큰 증류
fn stage_seeds(hits: [string]) -> [string] {
    let mut seeds: [string] = []
    let mut i = 0
    while i < hits.len() {
        let ln = _str(hits[i])
        let toks = ln.split(" ")
        let mut j = 0
        while j < toks.len() {
            let tok = _str(toks[j]).trim()
            if tok.len() >= 3 {
                let pfx3 = tok.substring(0, 3)
                if pfx3 == "BT-" || pfx3 == "P2-" || pfx3 == "P3-" {
                    seeds = seeds.push(tok.replace(",", "").replace("\"", ""))
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    return seeds
}

// stage 3: score eval — hits × kws overlap + seed count → n=6 공진 점수 (0..100)
fn stage_score(hits: [string], seeds: [string]) -> i64 {
    let h = hits.len()
    let s = seeds.len()
    let k = ATTACK_KWS.len()
    if k == 0 { return 0 }
    let mut raw: i64 = (h * 2) + (s * 3)
    // n=6 공진: 6 배수 보너스
    if h > 0 && (h % 6) == 0 { raw = raw + 6 }
    if s > 0 && (s % 6) == 0 { raw = raw + 6 }
    if raw > 100 { raw = 100 }
    return raw
}

// stage 4: atlas_emit — usage jsonl 에 discovery/score 레코드 append
fn stage_emit(hits: [string], seeds: [string], score: i64) {
    let ts = now_unix()
    let row = "{\"ts\":" + to_string(ts) +
              ",\"engine\":\"" + ENGINE_NAME +
              "\",\"kind\":\"bt_discovery\",\"bt_id\":\"" + BT_ID +
              "\",\"hits\":" + to_string(hits.len()) +
              ",\"seeds\":" + to_string(seeds.len()) +
              ",\"score\":" + to_string(score) + "}"
    append_usage(row)
}

fn cmd_run() {
    let hits = stage_discovery()
    let seeds = stage_seeds(hits)
    let score = stage_score(hits, seeds)
    stage_emit(hits, seeds, score)
    println(ENGINE_NAME + ": hits=" + to_string(hits.len()) +
            " seeds=" + to_string(seeds.len()) +
            " score=" + to_string(score))
}

fn cmd_scan() {
    let hits = stage_discovery()
    println(ENGINE_NAME + ": scan hits=" + to_string(hits.len()))
}

fn cmd_score() {
    let hits = stage_discovery()
    let seeds = stage_seeds(hits)
    let score = stage_score(hits, seeds)
    println(ENGINE_NAME + ": score=" + to_string(score))
}

fn cmd_emit() {
    let hits = stage_discovery()
    let seeds = stage_seeds(hits)
    let score = stage_score(hits, seeds)
    stage_emit(hits, seeds, score)
    println(ENGINE_NAME + ": emit ok score=" + to_string(score))
}

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    let mut mode = "run"
    if argv.len() >= 3 { mode = _str(argv[2]).trim() }
    if mode == "run" { cmd_run() }
    else if mode == "scan" { cmd_scan() }
    else if mode == "score" { cmd_score() }
    else if mode == "emit" { cmd_emit() }
    else {
        eprintln("usage: " + ENGINE_NAME + " <run|scan|score|emit>")
        exit(2)
    }
}

main()
