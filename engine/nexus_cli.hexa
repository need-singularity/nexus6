// ─── subcommand: qmirror (delegates to cli/qmirror.hexa router) ───
// Pure delegation — qmirror.hexa owns all 6 subcmd dispatch + audit + caveats.
// Forward all args after `qmirror` verbatim.

fn cmd_qmirror(a: [str]) {
    let n = len(a)
    let mut fwd: [str] = []
    let mut i: i64 = 3   // skip [argv0, script, "qmirror"]
    while i < n {
        fwd = fwd + [a[i]]
        i = i + 1
    }
    // If file missing, fail-fast with diagnostic.
    let exists = exec("[ -f " + shq(QMIRROR_CLI) + " ] && echo Y || echo N").trim()
    if exists != "Y" {
        eprintln("nexus-cli qmirror: router not found: " + QMIRROR_CLI)
        eprintln("reason: io-error: cli/qmirror.hexa absent")
        exit(1)
    }
    let raw = run_hexa(QMIRROR_CLI, fwd)
    print(raw)
}

