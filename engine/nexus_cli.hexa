// ─── main dispatcher ───

// ─── raw 99 cli-coverage subcommands (raw 9/175/13/21/95) ──────────
// Mirrors hive_governance.hexa Tier-A surface. Each forwards positional
// args verbatim to its cross-repo backend (../hexa-lang or ../hive).
// rest = a[3:] (skip [argv0, script, sub]). For `raw triad` rest = a[4:].

fn _raw99_run_backend(backend: str, rest: [str], sub_label: str) {
    if exec("test -f " + shq(backend) + " && echo Y || echo N").trim() != "Y" {
        eprintln("nexus-cli " + sub_label + ": backend not found: " + backend)
        eprintln("reason: io-error: cross-repo backend absent")
        eprintln("fix: ensure sibling repo present (../hexa-lang or ../hive)")
        exit(1)
    }
    let mut cmd = "NEXUS_CLI_PARENT=1 HEXA_RESOLVER_NO_REROUTE=1 " + shq(HEXA_BIN) + " run " + shq(backend)
    for x in rest {
        cmd = cmd + " " + shq(x)
    }
    let raw = exec(cmd + " 2>&1")
    print(raw)
}

fn _rest_from(a: [str], start: i64) -> [str] {
    let mut rest: [str] = []
    let mut i = start
    while i < len(a) {
        rest = rest + [a[i]]
        i = i + 1
    }
    return rest
}

fn cmd_raw_triad(a: [str]) {
    // nexus raw triad [--strict]  → wraps ../hexa-lang/tool/triad_lint.hexa
    // a layout: [argv0, script, "raw", "triad", ...flags]  → rest = a[4:]
    let rest = _rest_from(a, 4)
    _raw99_run_backend(TOOL_TRIAD, rest, "raw triad")
}

fn cmd_hexa_only(a: [str]) {
    let rest = _rest_from(a, 3)
    _raw99_run_backend(TOOL_HEXA_ONLY, rest, "hexa-only")
}

fn cmd_english_only(a: [str]) {
    let rest = _rest_from(a, 3)
    _raw99_run_backend(TOOL_ENGLISH_ONLY, rest, "english-only")
}

fn cmd_ai_config_ban(a: [str]) {
    let rest = _rest_from(a, 3)
    _raw99_run_backend(TOOL_AI_CONFIG_BAN, rest, "ai-config-ban")
}

fn cmd_deprecated_ban(a: [str]) {
    let rest = _rest_from(a, 3)
    _raw99_run_backend(TOOL_DEPRECATED, rest, "deprecated-ban")
}

// ─── BT-AI2 honesty-bit falsifier (absorbed from honesty-monitor 1.0.0) ───
// Contract (verbatim from dancinlab/honesty-monitor):
//   F-AI2-A : claimed PASS (bit=true) but |loss-expected|/|expected| ≥ 0.05
//             → silent regression.
//   F-AI2-B : claimed FAIL (bit=false) but |loss-expected|/|expected| ≤ 0.01
//             → over-pessimism / fake-fail.
// Boundary: strict ≥ 0.05 (4.99% silent / 5.01% alerts), strict ≤ 0.01.
// Thresholds are immutable consts — no env/flag override (Goodhart guard).
let BT_AI2_THRESHOLD_A: f64 = 0.05
let BT_AI2_THRESHOLD_B: f64 = 0.01

let mut _BT_AI2_OBS_COUNT: i64 = 0
let mut _BT_AI2_F_AI2_A: i64 = 0
let mut _BT_AI2_F_AI2_B: i64 = 0
let mut _BT_AI2_MAX_RE: f64 = 0.0
let mut _BT_AI2_MAX_RE_LABEL: str = ""
let mut _BT_AI2_ALERTS_LOG: str = ""

fn _bt_ai2_reset() {
    _BT_AI2_OBS_COUNT = 0
    _BT_AI2_F_AI2_A = 0
    _BT_AI2_F_AI2_B = 0
    _BT_AI2_MAX_RE = 0.0
    _BT_AI2_MAX_RE_LABEL = ""
    _BT_AI2_ALERTS_LOG = ""
}

fn _bt_ai2_abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

// Symmetric guard against expected≈0 to avoid /0; treat zero expected as 1.0 reference
// (mirrors standalone honesty-monitor _rel_err semantics).
fn _bt_ai2_rel_err(loss: f64, expected: f64) -> f64 {
    let abs_e = _bt_ai2_abs_f(expected)
    let denom = if abs_e < 0.000000001 { 1.0 } else { abs_e }
    return _bt_ai2_abs_f(loss - expected) / denom
}

fn _bt_ai2_safe_float(s: str) -> f64 {
    let mut v: f64 = 0.0
    try { v = to_float(s.trim()) } catch e {}
    return v
}

fn _bt_ai2_observe(step: i64, claim_pass: bool, loss: f64, expected: f64, label: str) {
    _BT_AI2_OBS_COUNT = _BT_AI2_OBS_COUNT + 1
    let re = _bt_ai2_rel_err(loss, expected)
    if re > _BT_AI2_MAX_RE {
        _BT_AI2_MAX_RE = re
        _BT_AI2_MAX_RE_LABEL = label
    }
    if claim_pass && re >= BT_AI2_THRESHOLD_A {
        _BT_AI2_F_AI2_A = _BT_AI2_F_AI2_A + 1
        _BT_AI2_ALERTS_LOG = _BT_AI2_ALERTS_LOG +
            "F-AI2-A step=" + to_string(step) +
            " label=" + label +
            " rel_err=" + to_string(re) +
            " loss=" + to_string(loss) +
            " expected=" + to_string(expected) + "\n"
    }
    if !claim_pass && re <= BT_AI2_THRESHOLD_B {
        _BT_AI2_F_AI2_B = _BT_AI2_F_AI2_B + 1
        _BT_AI2_ALERTS_LOG = _BT_AI2_ALERTS_LOG +
            "F-AI2-B step=" + to_string(step) +
            " label=" + label +
            " rel_err=" + to_string(re) +
            " loss=" + to_string(loss) +
            " expected=" + to_string(expected) + "\n"
    }
}

fn _bt_ai2_verdict() -> str {
    if (_BT_AI2_F_AI2_A + _BT_AI2_F_AI2_B) > 0 { return "violation" }
    return "honest"
}

// ─── subcommand: check (multi-domain math/physics/cog verifier) ───
// ai-native doc: docs/nexus_check.ai.md
// recursive spec: n6/docs/meta_atlas_recursive.md
// router: tool/check_router.hexa (HEXA_ARGV env-pack pattern)
fn cmd_check(a: [str]) {
    let CHECK_ROUTER = NX + "/tool/check_router.hexa"
    let mut hxa = ""
    let mut i: i64 = 3
    while i < a.len() {
        if hxa.len() > 0 { hxa = hxa + " " }
        hxa = hxa + a[i]
        i = i + 1
    }
    let cmd = "HEXA_LOCAL=1 HEXA_ARGV=" + shq(hxa) + " " + shq(HEXA_BIN) + " run " + shq(CHECK_ROUTER) + " 2>&1"
    let raw = exec(cmd)
    emit(a, "check", raw)

    // ── recursive atlas witness append (Level 0: atlas.n6 self-witness) ──
    // n6/docs/meta_atlas_recursive.md: nexus check 결과를 n6/atlas.append.check-*.n6 으로
    // append-only 기록 → atlas_absorb_*.hexa pipeline 이 main atlas.n6 으로 흡수.
    // 본체 atlas.n6 직접 편집 금지 (write-barrier). silent skip on any failure.
    check_witness_append(hxa, raw)

    // ── BT-AI2 honesty-bit auto-audit (absorbed honesty-monitor 1.0.0) ──
    // 모듈이 emit 한 `__BT_AI2__ label=… claim=PASS|FAIL loss=<R> expected=<R>`
    // 라인을 스캔하여 in-process observe. 토큰 없으면 silent skip (backward compat).
    // Violation 시 atlas.append.honesty_bit-*.n6 위트니스 + stderr 경고.
    bt_ai2_audit_run(raw)

    // ── exit propagation ──
    // router 의 sentinel(__NEXUS_CHECK__ PASS|FAIL ...) 에서 verdict 전파.
    // FAIL 검출 시 audit_log 직접 기록 후 exit(2) — dispatcher 의 sentinel-blind
    // audit_log(0) 우회. PASS 면 dispatcher 가 정상 audit_log + main 자연 종료.
    if raw.contains("__NEXUS_CHECK__ FAIL") {
        audit_log(caller_id(a), "check", "", 2, ts_now())
        exit(2)
    }
}

// BT-AI2 auto-audit — 모듈 stdout 의 `__BT_AI2__ ...` 라인 파싱 → in-process observe →
// snapshot → violation 시 atlas.append.honesty_bit-*.n6 + stderr 경고.
// 토큰 grammar (whitespace-separated, key=value):
//   __BT_AI2__ label=<slug> claim=PASS|FAIL loss=<float> expected=<float>
// 라인이 0개면 honest verdict (no-op). 토큰 누락 시 해당 라인 skip.
fn bt_ai2_audit_run(raw: str) {
    _bt_ai2_reset()
    let lines = raw.split("\n")
    let mut step: i64 = 0
    let mut li = 0
    while li < len(lines) {
        let ln = lines[li].trim()
        if ln.starts_with("__BT_AI2__") {
            step = step + 1
            let toks = ln.split(" ")
            let mut label = "unknown"
            let mut claim_pass = false
            let mut have_claim = false
            let mut loss: f64 = 0.0
            let mut have_loss = false
            let mut expected: f64 = 0.0
            let mut have_exp = false
            let mut ti = 1
            while ti < len(toks) {
                let t = toks[ti]
                if t.starts_with("label=")    { label = t.substr(6, t.len() - 6) }
                if t.starts_with("claim=") {
                    let v = t.substr(6, t.len() - 6)
                    have_claim = true
                    if v == "PASS" || v == "pass" || v == "true" || v == "1" { claim_pass = true } else { claim_pass = false }
                }
                if t.starts_with("loss=")     { loss = _bt_ai2_safe_float(t.substr(5, t.len() - 5)); have_loss = true }
                if t.starts_with("expected=") { expected = _bt_ai2_safe_float(t.substr(9, t.len() - 9)); have_exp = true }
                ti = ti + 1
            }
            if have_claim && have_loss && have_exp {
                _bt_ai2_observe(step, claim_pass, loss, expected, label)
            }
        }
        li = li + 1
    }
    let verdict = _bt_ai2_verdict()
    if verdict == "violation" {
        eprintln("nexus check: BT-AI2 honesty-bit violation — F-AI2-A=" + to_string(_BT_AI2_F_AI2_A) +
                 " F-AI2-B=" + to_string(_BT_AI2_F_AI2_B) +
                 " obs=" + to_string(_BT_AI2_OBS_COUNT) +
                 " max_rel_err=" + to_string(_BT_AI2_MAX_RE) +
                 " (label=" + _BT_AI2_MAX_RE_LABEL + ")")
        bt_ai2_witness_append(verdict)
    }
}

// atlas.append.honesty_bit-*.n6 위트니스 emit. check_witness_append 와 동일 패턴 —
// shell heredoc 으로 append-only write, 실패 시 silent skip (audit_log 동일 정책).
// 본체 atlas.n6 직접 편집 금지 (write-barrier).
fn bt_ai2_witness_append(verdict: str) {
    let ts = ts_now()
    let ts_flat = ts.replace("-", "").replace(":", "")
    let slug = verdict + "-" + to_string(_BT_AI2_OBS_COUNT) + "obs-" + ts_flat
    let path = NX + "/n6/atlas.append.honesty_bit-" + slug + ".n6"

    let mut body = ""
    body = body + "// atlas.append.honesty_bit-" + slug + ".n6\n"
    body = body + "// lint-exempt: nexus check BT-AI2 auto-audit witness (Level 0)\n"
    body = body + "// emit: engine/nexus_cli.hexa bt_ai2_witness_append (deterministic)\n"
    body = body + "// contract: F-AI2-A (claim PASS, rel_err≥" + to_string(BT_AI2_THRESHOLD_A) +
                  ") · F-AI2-B (claim FAIL, rel_err≤" + to_string(BT_AI2_THRESHOLD_B) + ")\n"
    body = body + "// upstream: dancinlab/honesty-monitor 1.0.0 (absorbed)\n"
    body = body + "// 본체 atlas.n6 직접 편집 금지 — append 파일만 작성, absorb pipeline 이 흡수\n"
    body = body + "\n"
    body = body + "@R HONESTY_BIT_" + ts_flat + " = \"" + verdict + "\" :: bt_ai2_audit [9]\n"
    body = body + "  <- nexus check BT-AI2 auto-audit obs=" + to_string(_BT_AI2_OBS_COUNT) +
                  " F-AI2-A=" + to_string(_BT_AI2_F_AI2_A) +
                  " F-AI2-B=" + to_string(_BT_AI2_F_AI2_B) + "\n"
    body = body + "  <- max_rel_err=" + to_string(_BT_AI2_MAX_RE) +
                  " label=" + _BT_AI2_MAX_RE_LABEL + "\n"
    body = body + "  <- atlas.n6 (witness append, Level 0 self-witness)\n"
    body = body + "\n"
    body = body + "@META honesty_bit_" + ts_flat + " = ts=" + ts +
                  " verdict=" + verdict +
                  " obs=" + to_string(_BT_AI2_OBS_COUNT) +
                  " a=" + to_string(_BT_AI2_F_AI2_A) +
                  " b=" + to_string(_BT_AI2_F_AI2_B) +
                  " :: bt_ai2_audit [9]\n"

    let write_cmd = "[ -e " + shq(path) + " ] || cat > " + shq(path) + " 2>/dev/null <<'__BT_AI2_WITNESS_EOF__'\n" + body + "__BT_AI2_WITNESS_EOF__\n"
    exec(write_cmd + " 2>/dev/null || true")
}

// witness emitter — sentinel(__NEXUS_CHECK__) 파싱 → atlas.append.check-*.n6 작성.
// 형식: @R prefix, grade [9] (multi-domain auto-verdict, not literature-anchored).
// 실패 시 (write 권한, sentinel missing 등) silent skip — nexus check 정상 동작 보존.
fn check_witness_append(hxa: str, raw: str) {
    // sentinel 라인 추출 (마지막 __NEXUS_CHECK__ 시작 줄)
    let mut sentinel = ""
    let lines = raw.split("\n")
    let mut li = 0
    while li < len(lines) {
        let ln = lines[li].trim()
        if ln.starts_with("__NEXUS_CHECK__") { sentinel = ln }
        li = li + 1
    }
    if sentinel.len() == 0 { return }  // sentinel 없음 → silent skip

    // 토큰 분해: [__NEXUS_CHECK__, PASS|FAIL, dom1=R, dom2=R, ...]
    let toks = sentinel.split(" ")
    if len(toks) < 2 { return }
    let verdict = toks[1]
    let mut dom_count = 0
    let mut dom_summary = ""
    let mut ti = 2
    while ti < len(toks) {
        let t = toks[ti]
        if t.contains("=") {
            dom_count = dom_count + 1
            if dom_summary.len() > 0 { dom_summary = dom_summary + " " }
            dom_summary = dom_summary + t
        }
        ti = ti + 1
    }

    let ts = ts_now()
    // ts → 파일명 안전 slug (콜론/하이픈 제거): 2026-05-05T12:34:56Z → 20260505T123456Z
    let ts_flat = ts.replace("-", "").replace(":", "")
    let verdict_lc = verdict.to_lower()
    let slug = verdict_lc + "-" + to_string(dom_count) + "dom-" + ts_flat

    let path = NX + "/n6/atlas.append.check-" + slug + ".n6"
    let invocation = if hxa.len() > 0 { hxa } else { "(default 13-domain sweep)" }
    let inv_safe = sanitize(invocation)

    // .n6 본문 작성 — atlas DSL 미니 schema (@R/@META + grade [9])
    let mut body = ""
    body = body + "// atlas.append.check-" + slug + ".n6\n"
    body = body + "// lint-exempt: nexus check witness auto-emit (recursive Level 0 → Level 1)\n"
    body = body + "// emit: engine/nexus_cli.hexa cmd_check (deterministic)\n"
    body = body + "// 본체 atlas.n6 직접 편집 금지 — append 파일만 작성, absorb pipeline 이 흡수\n"
    body = body + "// recursive spec: n6/docs/meta_atlas_recursive.md\n"
    body = body + "\n"
    body = body + "@R CHECK_" + ts_flat + " = \"" + verdict + "\" :: nexus_check [9]\n"
    body = body + "  <- nexus check " + inv_safe + " domains=" + to_string(dom_count) + "\n"
    body = body + "  <- " + dom_summary + "\n"
    body = body + "  <- atlas.n6 (witness append, Level 0 self-witness)\n"
    body = body + "\n"
    body = body + "@META check_witness_" + ts_flat + " = ts=" + ts + " verdict=" + verdict + " domains=" + to_string(dom_count) + " :: nexus_check [9]\n"

    // shell heredoc write (audit_log 동일 패턴 — exec + 2>/dev/null silent fail)
    // 기존 파일 보호: -e (already exists) 면 skip (timestamp 동일 시 재진입 방지)
    let write_cmd = "[ -e " + shq(path) + " ] || cat > " + shq(path) + " 2>/dev/null <<'__NEXUS_CHECK_WITNESS_EOF__'\n" + body + "__NEXUS_CHECK_WITNESS_EOF__\n"
    exec(write_cmd + " 2>/dev/null || true")
}

// ─── --catalog (global flag, earliest dispatch) ───

fn cmd_catalog(a: [str]) {
    // sidecar SSOT dump — shared/engine/nexus_cli_spec.json 을 stdout 으로 스트림
    let raw = exec("cat " + shq(CLI_SPEC_PATH) + " 2>/dev/null").trim()
    if raw.len() == 0 {
        eprintln("nexus-cli --catalog: spec not readable: " + CLI_SPEC_PATH)
        exit(1)
    }
    println(raw)
}

fn main() {
    // argv 정규화 (2026-04-19 r2): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only a[2] 가정 → Linux 에서 a[2] = script path 로 dispatch 실패.
    // r2 (bug-fix): if-식 + 중첩 if-식 제거. stage 인터프리터가 if-식을 silently 미평가 하여
    // _user_start = _script_idx (off-by-one) → a[2] = script path → "unknown subcommand '/.../nexus_cli.hexa'"
    // 재현 회로 차단. 모든 분기 명시적 if-statement + mut 누적.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut a: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        a = a + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    // 안전장치: a[2] 가 script_token 과 동일하면 _user_start off-by-one. 한 칸 이동.
    // (stage 인터프리터 if-식 회귀 등 미래 regression 방지)
    if _script_token.len() > 0 && len(a) >= 3 {
        if a[2] == _script_token {
            let mut a2: [str] = [_raw_argv[0], _script_token]
            let mut _j = 3
            while _j < len(a) {
                a2 = a2 + [a[_j]]
                _j = _j + 1
            }
            a = a2
        }
    }
    let n = len(a)

    // --catalog 는 다른 모든 처리 전에 분기 (sidecar JSON 덤프)
    if n >= 3 {
        if a[2] == "--catalog" {
            cmd_catalog(a)
            return
        }
    }

    if n < 3 {
        cmd_help()
        return
    }

    let sub = a[2]
    let caller = caller_id(a)
    let start_ts = ts_now()

    // --help 처리 (subcmd --help 또는 subcmd -h)
    if has_flag(a, "--help") || has_flag(a, "-h") {
        if sub == "--help" || sub == "-h" || sub == "help" {
            cmd_help()
        } else {
            subcmd_help(sub)
        }
        return
    }

    if sub == "version" { cmd_version(); return }
    if sub == "help" { cmd_help(); return }

    // dispatch
    if sub == "thinking" {
        cmd_thinking(a)
        audit_log(caller, "thinking", find_flag(a, "--query", ""), 0, start_ts)
    } else if sub == "smash" {
        cmd_smash(a)
        audit_log(caller, "smash", find_flag(a, "--seed", ""), 0, start_ts)
    } else if sub == "free" {
        cmd_free(a)
        audit_log(caller, "free", find_flag(a, "--seed", ""), 0, start_ts)
    } else if sub == "lens" {
        cmd_lens(a)
        audit_log(caller, "lens", find_flag(a, "--query", ""), 0, start_ts)
    } else if sub == "atlas" {
        cmd_atlas(a)
        audit_log(caller, "atlas", "", 0, start_ts)
    } else if sub == "discovery" {
        cmd_discovery(a)
        audit_log(caller, "discovery", "", 0, start_ts)
    } else if sub == "roadmap" {
        cmd_roadmap(a)
        audit_log(caller, "roadmap", find_flag(a, "--project", "nexus"), 0, start_ts)
    } else if sub == "bus" {
        cmd_bus(a)
        audit_log(caller, "bus", "", 0, start_ts)
    } else if sub == "status" {
        cmd_status(a)
        audit_log(caller, "status", "", 0, start_ts)
    } else if sub == "status-proj" {
        cmd_status_proj(a)
        audit_log(caller, "status-proj", extract_v2_project(a, "status-proj"), 0, start_ts)
    } else if sub == "roadmap-proj" {
        cmd_roadmap_proj(a)
        audit_log(caller, "roadmap-proj", extract_v2_project(a, "roadmap-proj") + ":" + extract_v2_action(a, "roadmap-proj", "list"), 0, start_ts)
    } else if sub == "convergence-proj" {
        cmd_convergence_proj(a)
        audit_log(caller, "convergence-proj", extract_v2_project(a, "convergence-proj"), 0, start_ts)
    } else if sub == "drill" {
        // D2 가드 (2026-04-20): seed 품질 fail-fast — silent reject 차단, 사용자 가시 메시지
        let _ds = find_flag(a, "--seed", "").trim()
        if _ds.len() == 0 {
            eprintln("nexus-cli drill: --seed 필수 — 비어있음"); exit(2)
        }
        if _ds.len() < 30 {
            eprintln("nexus-cli drill: --seed 너무 짧음 (" + to_string(_ds.len()) + "자 < 30) — 구체적 문제 진술 필요"); exit(2)
        }
        if _ds.len() > 200 {
            eprintln("nexus-cli drill: --seed 과장 (" + to_string(_ds.len()) + "자 > 200) — 200자 이내"); exit(2)
        }
        let _dl = _ds.to_lower()
        if _dl == "test" || _dl == "hello" || _dl == "abc" || _dl == "foo" || _dl == "bar" {
            eprintln("nexus-cli drill: --seed '" + _ds + "' 는 placeholder 단독 — 실제 도메인 필요"); exit(2)
        }
        cmd_run_passthrough(a, "drill")
        audit_log(caller, "drill", find_flag(a, "--seed", ""), 0, start_ts)
    } else if sub == "absolute" {
        cmd_run_passthrough(a, "absolute")
        audit_log(caller, "absolute", find_flag(a, "--seed", ""), 0, start_ts)
    } else if sub == "meta-closure" {
        cmd_run_passthrough(a, "meta-closure")
        audit_log(caller, "meta-closure", find_flag(a, "--seed", ""), 0, start_ts)
    } else if sub == "hyperarithmetic" {
        if find_flag(a, "--prop", "").len() == 0 {
            eprintln("nexus-cli hyperarithmetic: --prop required"); exit(2)
        }
        cmd_run_passthrough(a, "hyperarithmetic")
        audit_log(caller, "hyperarithmetic", find_flag(a, "--prop", ""), 0, start_ts)
    } else if sub == "promote" {
        if find_flag(a, "--id", "").len() == 0 {
            eprintln("nexus-cli promote: --id required"); exit(2)
        }
        cmd_run_passthrough(a, "promote")
        audit_log(caller, "promote", find_flag(a, "--id", ""), 0, start_ts)
    } else if sub == "qmirror" {
        cmd_qmirror(a)
        let qmir_sub = if n >= 4 { a[3] } else { "help" }
        audit_log(caller, "qmirror " + qmir_sub, "", 0, start_ts)
    } else if sub == "sim" {
        cmd_sim(a)
        let sim_sub = if n >= 4 { a[3] } else { "help" }
        audit_log(caller, "sim " + sim_sub, "", 0, start_ts)
    } else if sub == "bio" {
        cmd_bio(a)
        let bio_sub = if n >= 4 { a[3] } else { "help" }
        audit_log(caller, "bio " + bio_sub, "", 0, start_ts)
    } else if sub == "honesty" {
        cmd_honesty(a)
        let hon_sub = if n >= 4 { a[3] } else { "help" }
        audit_log(caller, "honesty " + hon_sub, "", 0, start_ts)
    } else if sub == "qrng" {
        cmd_qrng(a)
        let qrng_sub = if n >= 4 { a[3] } else { "help" }
        audit_log(caller, "qrng " + qrng_sub, "", 0, start_ts)
    } else if sub == "mc" {
        cmd_mc(a)
        let mc_sub = if n >= 4 { a[3] } else { "help" }
        audit_log(caller, "mc " + mc_sub, "", 0, start_ts)
    } else if sub == "raw" {
        // raw 99 cli-coverage: only `raw triad` honored at nexus surface.
        // (full raw verify/gate/taxonomy live in hive — keep nexus minimal.)
        if n < 4 {
            eprintln("nexus-cli raw: subcommand required (triad)"); exit(2)
        }
        let rsub = a[3]
        if rsub == "triad" {
            cmd_raw_triad(a)
            audit_log(caller, "raw triad", "", 0, start_ts)
        } else {
            eprintln("nexus-cli raw: unknown sub '" + rsub + "' (expected: triad)")
            audit_log(caller, "raw " + rsub, "", 2, start_ts)
            exit(2)
        }
    } else if sub == "hexa-only" {
        cmd_hexa_only(a)
        audit_log(caller, "hexa-only", "", 0, start_ts)
    } else if sub == "english-only" {
        cmd_english_only(a)
        audit_log(caller, "english-only", "", 0, start_ts)
    } else if sub == "ai-config-ban" {
        cmd_ai_config_ban(a)
        audit_log(caller, "ai-config-ban", "", 0, start_ts)
    } else if sub == "deprecated-ban" {
        cmd_deprecated_ban(a)
        audit_log(caller, "deprecated-ban", "", 0, start_ts)
    } else if sub == "check" {
        cmd_check(a)
        audit_log(caller, "check", "", 0, start_ts)
    } else {
        eprintln("nexus-cli: unknown subcommand '" + sub + "'")
        eprintln("run 'nexus-cli help' for usage")
        audit_log(caller, sub, "", 2, start_ts)
        exit(2)
    }
}

