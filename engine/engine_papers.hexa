// engine_papers.hexa — "Amplifier" (증폭기) 자율 엔진
// Papers: Academic paper pipeline
// 사용: hexa engine_papers.hexa status|tick|report
//
// 목표: 드래프트 0건 (100% 발행), DOI 100+ // 프로젝트: $home/Dev/papers

// ═══════════════════════════════════════════════════════════
// ─── CONSTANTS ───
// ═══════════════════════════════════════════════════════════

comptime const version = "1.0.0"
let home = exec("printenv HOME")
let dev = home + "/Dev"
let papers_dir = dev + "/papers"
let manifest_file = papers_dir + "/manifest.json"
let _atlas_home = exec("printenv HOME").trim()
let atlas_path = _atlas_home + "/Dev/nexus/shared/n6/atlas.n6"
let bus_file = atlas_path
let evolve_file = dev + "/nexus/shared/engine_papers_evolve.jsonl"
let discovery_log = atlas_path

comptime const goal_drafts = 0
comptime const goal_doi = 100
comptime const batch_threshold = 3

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

fn min_f(a: f64, b: f64) -> f64 {
    if a < b { return a }
    return b
}

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {}
    return v
}

fn safe_int(s: string) -> i64 {
    let mut v: i64 = 0
    try { v = to_int(s) } catch e {}
    return v
}

fn timestamp_now() -> string {
    let r = exec("date +%Y-%m-%dT%H:%M:%S")
    return r.trim()
}

// ═══════════════════════════════════════════════════════════
// ─── JSON HELPERS ───
// ═══════════════════════════════════════════════════════════

fn json_str(line: string, field: string) -> string {
    let marker = "\"" + field + "\":"
    let parts = line.split(marker)
    if parts.len() < 2 { return "" }
    let rest = parts[1].trim()
    if rest.len() == 0 { return "" }
    if rest[0] == "\"" {
        let inner = rest.split("\"")
        if inner.len() >= 2 { return inner[1] }
        return ""
    }
    let end = rest.split(",")[0].split("}")[0].split("]")[0].trim()
    return end
}

fn json_int(line: string, field: string) -> i64 {
    return safe_int(json_str(line, field))
}

// ═══════════════════════════════════════════════════════════
// ─── STATE: MANIFEST PARSER ───
// ═══════════════════════════════════════════════════════════

struct PaperStats {
    total: i64,
    published: i64,
    drafts: i64,
    doi_count: i64,
    draft_titles: string,
    no_doi_titles: string,
    fail_count: i64
}

fn parse_manifest() -> PaperStats {
    let mut stats = PaperStats {
        total: 0, published: 0, drafts: 0, doi_count: 0,
        draft_titles: "", no_doi_titles: "", fail_count: 0
    }
    if !file_exists(manifest_file) { return stats }
    let content = read_file(manifest_file)

    // split by paper entries — each entry has "status" field
    // approach: split on "},", count status values
    let entries = content.split("\"title\"")
    let mut i = 1  // skip before first title
    while i < entries.len() {
        let entry = entries[i]
        stats.total = stats.total + 1

        // extract title
        let title_raw = entry.split("\"")[0]
        let title_clean = if title_raw.contains(":") {
            let after = title_raw.split(":")[1]
            after.split("\"")[0].trim()
        } else {
            title_raw.trim()
        }
        // re-extract title properly: "title":"VALUE"
        let t_parts = entry.split("\"")
        let title = if t_parts.len() >= 2 { t_parts[1] } else { "unknown" }

        // check status
        let status = json_str(entry, "status")
        if status == "Published" {
            stats.published = stats.published + 1
        } else if status == "Draft" {
            stats.drafts = stats.drafts + 1
            if stats.draft_titles.len() > 0 { stats.draft_titles = stats.draft_titles + "|" }
            stats.draft_titles = stats.draft_titles + title
        }

        // check DOI
        let doi = json_str(entry, "doi")
        if doi.len() > 0 && doi != "null" && doi != "" {
            stats.doi_count = stats.doi_count + 1
        } else if status == "Published" {
            // published but no DOI = consistency issue
            if stats.no_doi_titles.len() > 0 { stats.no_doi_titles = stats.no_doi_titles + "|" }
            stats.no_doi_titles = stats.no_doi_titles + title
        }

        // check fail_count for evolve
        let fc = json_int(entry, "fail_count")
        if fc >= 2 {
            stats.fail_count = stats.fail_count + 1
        }

        i = i + 1
    }
    return stats
}

// ═══════════════════════════════════════════════════════════
// ─── STATUS FLAGS ───
// ═══════════════════════════════════════════════════════════

fn compute_status_flag(stats: PaperStats) -> string {
    if stats.drafts == 0 && stats.doi_count >= goal_doi {
        return "GOAL_NEAR"
    }
    if stats.drafts == 0 {
        return "BREAKTHROUGH"
    }
    if stats.drafts >= 5 || stats.fail_count >= 3 {
        return "STAGNANT"
    }
    return "HEALTHY"
}

fn compute_health_metric(stats: PaperStats) -> f64 {
    // composite: 40% draft-free ratio + 40% DOI progress + 20% fail penalty
    let draft_ratio = if stats.total > 0 {
        to_float(stats.published) / to_float(stats.total)
    } else { 0.0 }
    let doi_ratio = min_f(to_float(stats.doi_count) / to_float(goal_doi), 1.0)
    let fail_penalty = if stats.total > 0 {
        min_f(to_float(stats.fail_count) / to_float(stats.total), 1.0)
    } else { 0.0 }
    return draft_ratio * 0.4 + doi_ratio * 0.4 + (1.0 - fail_penalty) * 0.2
}

// ═══════════════════════════════════════════════════════════
// ─── GROWTH BUS ───
// ═══════════════════════════════════════════════════════════

fn bus_emit(event: string, detail: string) {
    let ts = timestamp_now()
    let entry = "{\"ts\":\"" + ts + "\",\"engine\":\"papers\",\"personality\":\"Amplifier\",\"event\":\"" + event + "\",\"detail\":\"" + detail + "\"}"
    append_file(bus_file, entry + "\n")
}

// ═══════════════════════════════════════════════════════════
// ─── EVOLVE: PUBLISH SUCCESS TRACKER ───
// ═══════════════════════════════════════════════════════════

fn evolve_record(action: string, drafts_before: i64, drafts_after: i64, doi_before: i64, doi_after: i64) {
    let ts = timestamp_now()
    let d_delta = drafts_before - drafts_after
    let doi_delta = doi_after - doi_before
    let entry = "{\"ts\":\"" + ts + "\",\"action\":\"" + action + "\",\"drafts_resolved\":" + to_string(d_delta) + ",\"doi_gained\":" + to_string(doi_delta) + "}"
    append_file(evolve_file, entry + "\n")
}

fn read_evolve_stats() -> string {
    if !file_exists(evolve_file) { return "no evolve history" }
    let content = read_file(evolve_file)
    let lines = content.split("\n")
    let mut total_resolved: i64 = 0
    let mut total_doi: i64 = 0
    let mut ticks: i64 = 0
    let mut i = 0
    while i < lines.len() {
        let line = lines[i].trim()
        if line.len() > 2 {
            total_resolved = total_resolved + json_int(line, "drafts_resolved")
            total_doi = total_doi + json_int(line, "doi_gained")
            ticks = ticks + 1
        }
        i = i + 1
    }
    if ticks == 0 { return "0 ticks" }
    let avg_r = to_float(total_resolved) / to_float(ticks)
    let avg_d = to_float(total_doi) / to_float(ticks)
    return to_string(ticks) + " ticks, avg resolved/tick: " + to_string(avg_r) + ", avg DOI/tick: " + to_string(avg_d)
}

// ═══════════════════════════════════════════════════════════
// ─── DISCOVERY CHECK (for paper generation) ───
// ═══════════════════════════════════════════════════════════

fn count_recent_discoveries() -> i64 {
    if !file_exists(discovery_log) { return 0 }
    let content = read_file(discovery_log)
    let lines = content.split("\n")
    let mut count: i64 = 0
    let mut i = 0
    while i < lines.len() {
        let line = lines[i].trim()
        if line.contains("\"EXACT\"") {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

// ═══════════════════════════════════════════════════════════
// ─── CMD: STATUS ───
// ═══════════════════════════════════════════════════════════

fn cmd_status() {
    let stats = parse_manifest()
    let flag = compute_status_flag(stats)
    let h = compute_health_metric(stats)

    print("=== engine_papers v" + version + " ===")
    print("project: papers (Academic paper pipeline)")
    print("personality: Amplifier (증폭기)")
    print("health:" + to_string(h))
    print("status: " + flag)
    print("")
    print("[total]     " + to_string(stats.total))
    print("[published] " + to_string(stats.published))
    print("[drafts]    " + to_string(stats.drafts) + "  (goal: " + to_string(goal_drafts) + ")")
    print("[doi_count] " + to_string(stats.doi_count) + "  (goal: " + to_string(goal_doi) + ")")
    print("[fail_flag] " + to_string(stats.fail_count) + " papers with fail_count >= 2")
    print("")

    if stats.draft_titles.len() > 0 {
        print("[drafts] " + stats.draft_titles)
    }
    if stats.no_doi_titles.len() > 0 {
        print("[no_doi] " + stats.no_doi_titles)
    }
    print("")
    print("[evolve] " + read_evolve_stats())
}

// ═══════════════════════════════════════════════════════════
// ─── CMD: TICK ───
// ═══════════════════════════════════════════════════════════

fn cmd_tick() {
    print("=== engine_papers tick ===")
    let ts = timestamp_now()
    print("[" + ts + "] starting tick...")

    // 1. read pre-state
    let stats_before = parse_manifest()
    let flag = compute_status_flag(stats_before)
    print("[state] drafts=" + to_string(stats_before.drafts) + " published=" + to_string(stats_before.published) + " doi=" + to_string(stats_before.doi_count) + " flag=" + flag)

    // 2. select action
    let mut action = "consistency"

    if stats_before.drafts >= batch_threshold {
        action = "batch_publish"
        print("[decision] drafts >= " + to_string(batch_threshold) + " → batch publish queue")

        // log recommendation (no actual upload without tokens)
        let draft_list = stats_before.draft_titles
        let items = draft_list.split("|")
        let mut j = 0
        print("[batch] papers queued for publish:")
        while j < items.len() {
            print("  - " + items[j])
            j = j + 1
        }
        print("[batch] NOTE: actual upload requires API tokens — logging recommendation only")
        bus_emit("batch_queue", "queued " + to_string(stats_before.drafts) + " drafts for publish")

    } else if stats_before.drafts == 0 {
        action = "generate"
        print("[decision] 0 drafts → GOAL_NEAR, checking for new discoveries to generate papers")

        let disc_count = count_recent_discoveries()
        print("[discoveries] " + to_string(disc_count) + " EXACT matches in discovery_log")

        if disc_count > 0 {
            print("[generate] new discoveries available — recommend paper generation pipeline")
            bus_emit("generate_recommend", "discoveries=" + to_string(disc_count))
        } else {
            print("[generate] no new discoveries — pipeline idle")
        }

    } else {
        action = "consistency"
        print("[decision] default → manifest consistency check")

        // check: all Published have DOI?
        let mut issues: i64 = 0
        if stats_before.no_doi_titles.len() > 0 {
            let missing = stats_before.no_doi_titles.split("|")
            let mut k = 0
            print("[consistency] Published papers missing DOI:")
            while k < missing.len() {
                print("  - " + missing[k])
                issues = issues + 1
                k = k + 1
            }
        }

        // check: fail-flagged papers
        if stats_before.fail_count > 0 {
            print("[consistency] " + to_string(stats_before.fail_count) + " papers with repeated failures")
            issues = issues + stats_before.fail_count
        }

        if issues == 0 {
            print("[consistency] all checks passed")
        } else {
            print("[consistency] " + to_string(issues) + " issues found")
            bus_emit("consistency_issues", "count=" + to_string(issues))
        }
    }

    // 3. re-read post-state
    let stats_after = parse_manifest()
    let flag_after = compute_status_flag(stats_after)
    print("[post] drafts=" + to_string(stats_after.drafts) + " published=" + to_string(stats_after.published) + " doi=" + to_string(stats_after.doi_count) + " flag=" + flag_after)

    // 4. evolve: track changes
    evolve_record(action, stats_before.drafts, stats_after.drafts, stats_before.doi_count, stats_after.doi_count)

    // 5. bus emit
    let detail = "action=" + action + " drafts=" + to_string(stats_after.drafts) + " doi=" + to_string(stats_after.doi_count)
    bus_emit("tick", detail)

    if flag_after == "GOAL_NEAR" && flag != "GOAL_NEAR" {
        bus_emit("goal_near", "0 drafts + doi=" + to_string(stats_after.doi_count))
    }

    // 6. summary
    let h = compute_health_metric(stats_after)
    print("")
    print("health:" + to_string(h))
    print("status: " + flag_after)
    print("[tick complete]")
}

// ═══════════════════════════════════════════════════════════
// ─── CMD: REPORT ───
// ═══════════════════════════════════════════════════════════

fn cmd_report() {
    let stats = parse_manifest()
    let flag = compute_status_flag(stats)
    let h = compute_health_metric(stats)
    let ts = timestamp_now()

    print("# Papers Engine Report (Amplifier / 증폭기)")
    print("")
    print("**Generated**: " + ts)
    print("**Version**: " + version)
    print("")
    print("## Status: " + flag)
    print("")
    print("| Metric | Value | Goal | Progress |")
    print("|--------|-------|------|----------|")

    let draft_pct = if stats.total > 0 {
        to_float(stats.published) / to_float(stats.total) * 100.0
    } else { 0.0 }
    let doi_pct = to_float(stats.doi_count) / to_float(goal_doi) * 100.0
    print("| Drafts | " + to_string(stats.drafts) + " | " + to_string(goal_drafts) + " | " + to_string(draft_pct) + "% published |")
    print("| DOI Count | " + to_string(stats.doi_count) + " | " + to_string(goal_doi) + " | " + to_string(doi_pct) + "% |")
    print("")

    print("## Pipeline Summary")
    print("")
    print("| Category | Count |")
    print("|----------|-------|")
    print("| Total | " + to_string(stats.total) + " |")
    print("| Published | " + to_string(stats.published) + " |")
    print("| Drafts | " + to_string(stats.drafts) + " |")
    print("| With DOI | " + to_string(stats.doi_count) + " |")
    print("| Fail-flagged | " + to_string(stats.fail_count) + " |")
    print("")

    if stats.draft_titles.len() > 0 {
        print("## Pending Drafts")
        print("")
        let items = stats.draft_titles.split("|")
        let mut i = 0
        while i < items.len() {
            print("- " + items[i])
            i = i + 1
        }
        print("")
    }

    if stats.no_doi_titles.len() > 0 {
        print("## Published Without DOI (consistency issue)")
        print("")
        let items = stats.no_doi_titles.split("|")
        let mut i = 0
        while i < items.len() {
            print("- " + items[i])
            i = i + 1
        }
        print("")
    }

    print("## Evolution History")
    print("")
    print(read_evolve_stats())
    print("")

    print("## Composite Health")
    print("")
    print("`health:" + to_string(h) + "`")
    print("")

    if flag == "STAGNANT" {
        print("## Recommendation")
        print("")
        print("- Too many drafts or repeated failures — clear backlog")
        print("- Check API tokens and submission endpoints")
        print("- Flag fail-count >= 3 papers for manual review")
    } else if flag == "GOAL_NEAR" {
        print("## Recommendation")
        print("")
        print("- All drafts published — monitor for new discovery-driven papers")
        print("- DOI target: " + to_string(goal_doi - stats.doi_count) + " remaining")
    }
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN ───
// ═══════════════════════════════════════════════════════════

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-stage1=[hexa, "run", script, user...]
    // 이전까지 Mac-only a[2] 가정 → Linux 에서 a[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut a: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        a = a + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && a.len() >= 3 {
        if a[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < a.len() {
                _a2 = _a2 + [a[_j2]]
                _j2 = _j2 + 1
            }
            a = _a2
        }
    }
    let mut cmd = "status"
    if a.len() >= 3 { cmd = a[2] }

    match cmd {
        "status" -> cmd_status(),
        "tick" -> cmd_tick(),
        "report" -> cmd_report(),
        _ -> {
            print("engine_papers.hexa — Amplifier (증폭기)")
            print("usage: hexa engine_papers.hexa status|tick|report")
        }
    }
}

main()
