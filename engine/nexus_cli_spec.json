        "--physics":       "물리 (dimensional, conservation, codata, planck, anchor, lorentz)",
        "--bio":           "바이오 (stub — 차후 wire)",
        "--sim":           "시뮬 (sim_bridge/anu_time/, stub)",
        "--qrng":          "양자난수 (ANU 분포 검증, stub)",
        "--brain":         "뇌 (~/core/hexa-brain 외부, stub)",
        "--consciousness": "의식 (AN11 11-axis, ANIMA 정적 자산 흡수 예정)",
        "--phi":           "Φ/IIT (phi_holo, phi_iit, ANIMA 흡수 예정)",
        "--learning":      "학습 정합성 (corpus_4gate, ANIMA 흡수 예정)",
        "--phenomenology": "현상학 (EEG cross-substrate, ANIMA 흡수 예정)",
        "--law":           "법칙/수렴 (consciousness_laws, ANIMA 흡수 예정)",
        "--integrity":     "무결성 (cert_gate / nexus_gate, ANIMA 흡수 예정)",
        "--meta":          "메타 (n6 honesty_triad, atlas_drift)",
        "--hexalint":      "hexa-lint (tree-sitter-hexa lints.scm AST 룰 검사 — relop/exec/catch/exit)",
        "--all":           "전체 (분야 미지정 시 기본)"
      },
      "sub_flags": {
        "--dimensional":   "물리 — 차원 분석 (SI 7-axis, E=mc²/F=ma/p=mv/¬E=mv 검증)",
        "--conservation":  "물리 — 보존 법칙 (energy/momentum/angular-L, 0.1% ppm 임계)",
        "--anchor":        "물리 — empirical_anchor χ² (n_s, m_π, M_chirp, α⁻¹)",
        "--codata":        "물리 — CODATA NIST live fetch (α⁻¹ vs hexa symbolic 137)",
        "--planck":        "물리 — Planck 2018 6-parameter (H₀, Ω_m, n_s, ...)",
        "--lorentz":       "물리/시뮬 — 64-site light-cone causality",
        "--invariants":    "수학/메타 — n6 10-atom invariants drift",
        "--honesty":       "메타 — honesty_triad C1~C5",
        "--drift":         "메타 — atlas_drift",
        "--all-physics":   "physics 분야 내 세부 모두 (단정적+네트워크)",
        "--ndjson":        "hexa-lint — 위반 1건당 NDJSON 한 줄 emit",
        "--selftest":      "hexa-lint — tooling/tree-sitter-hexa/test fixtures 대상 smoke"
      },
      "delegates_to": "tool/check_router.hexa (HEXA_ARGV env-pack)",
      "backends": [
