{
  "_meta": {
    "name": "nexus-cli SSOT spec",
    "description": "외부 프로젝트(hive 등) 전용 단일 CLI 진입점 — subcommand/flags/exit codes/json schema",
    "version": "0.4.0",
    "schema_version": "2",
    "updated": "2026-04-20",
    "entry": "~/.hx/bin/nexus (hx install nexus)",
    "engine": "shared/engine/nexus_cli.hexa",
    "runtime": "hexa",
    "related": [
      "run.hexa",
      "hive.json",
      "shared/roadmaps/drill_dod.json"
    ],
    "remote_routing": {
      "_note": "Heavy-compute subcommands force-route to remote via shared/scripts/bin/hexa (Mac stage0 SIGKILL avoidance). Override: HEXA_LOCAL=1.",
      "heavy_compute": [
        "drill",
        "smash",
        "free",
        "absolute",
        "meta-closure",
        "hyperarithmetic"
      ],
      "resolver": "shared/scripts/bin/hexa (remote_eligible())"
    },
    "recommended_invocation": "nexus <subcommand> [flags...]",
    "antipatterns": [
      "hexa run.hexa <subcommand>",
      "hexa run shared/engine/nexus_cli.hexa <subcommand>",
      "hexa run nexus.hexa <subcommand>",
      "hexa run /path/to/nexus/run.hexa <subcommand>"
    ],
    "antipattern_reason": "내부 구현 (run.hexa / nexus_cli.hexa) 직접 호출 금지 — 외부 인지 SSOT = nexus-cli",
    "legacy_aliases": {
      "nexus-cli": "DEPRECATED 2026-04-20 — shared/bin/nexus-cli bash wrapper, transition only"
    },
    "canonical_invocation": "nexus"
  },
  "projects": [
    "nexus",
    "anima",
    "n6-architecture",
    "papers",
    "hexa-lang",
    "void",
    "airgenome"
  ],
  "project_paths": {
    "_ssot": "shared/config/projects.json readme_order",
    "roadmap_dir": "shared/roadmaps",
    "convergence_dir": "shared/convergence",
    "state_dir": "shared/state",
    "resolution": {
      "roadmap": "$NEXUS/config/roadmaps/<project>.json",
      "convergence": "$NEXUS/convergence/<project>.json",
      "fallback": "project-local roadmap/convergence 가 nexus 에 없으면 404"
    }
  },
  "env": {
    "NEXUS": {
      "desc": "nexus 루트 디렉토리",
      "default": "$HOME/Dev/nexus"
    },
    "HEXA": {
      "desc": "hexa 바이너리 경로 (미지정 시 shared/bin/hexa resolver)",
      "default": ""
    }
  },
  "global_flags": {
    "--json": {
      "type": "bool",
      "default": false,
      "desc": "기계 파싱용 JSON stdout (default=pretty)"
    },
    "--quiet": {
      "type": "bool",
      "default": false,
      "desc": "(qmirror only, with --json) preamble/raw → stderr; only JSON tail → stdout. raw#10 no-op without --json."
    },
    "--caller": {
      "type": "string",
      "default": "",
      "desc": "외부 호출자 식별 (예: hive). audit log 기록"
    },
    "--catalog": {
      "type": "bool",
      "default": false,
      "desc": "spec sidecar (이 파일) stdout 덤프 — subcmd 전에 분기. hive 등 dynamic loader 용"
    },
    "--help": {
      "type": "bool",
      "desc": "서브커맨드 도움말"
    },
    "-h": {
      "alias": "--help"
    }
  },
  "exit_codes": {
    "0": "성공",
    "1": "실행 오류 (엔진 실패, 내부 오류)",
    "2": "인자 오류 (unknown subcommand, missing required flag)",
    "3": "gate 거부 (harness violation, cmd_gate REJECT)"
  },
  "audit": {
    "log_path": "shared/logs/nexus_cli.log",
    "format": "jsonl",
    "fields": [
      "ts",
      "caller",
      "subcmd",
      "args",
      "exit_code",
      "duration_ms"
    ]
  },
  "subcommands": {
    "thinking": {
      "desc": "anima 6-phase reflection",
      "usage": "nexus thinking --query \"...\" [--depth 6] [--json]",
      "flags": {
        "--query": {
          "type": "string",
          "required": true,
          "desc": "질의 텍스트"
        },
        "--depth": {
          "type": "int",
          "default": 6,
          "desc": "reflection 깊이 (1-12)"
        }
      },
      "delegates_to": "internal — nexus 런타임",
      "output_json": {
        "query": "string",
        "depth": "int",
        "phases": "[object]",
        "result": "string"
      }
    },
    "smash": {
      "desc": "blowup 9-phase 특이점 돌파",
      "usage": "nexus smash (--seed \"...\" | --batch \"s1|s2|...\") [--depth 3] [--seeds \"s1,s2,...|auto\"] [--json]",
      "flags": {
        "--seed": {
          "type": "string",
          "required": false,
          "desc": "돌파 시드 텍스트 (single 모드). --batch 와 상호배타"
        },
        "--batch": {
          "type": "string",
          "required": false,
          "desc": "`|` 구분 N seed 일괄 발사 (1 dispatch, bash 기동 1회). seed_engine 풀 amortize"
        },
        "--depth": {
          "type": "int",
          "default": 3,
          "desc": "돌파 깊이"
        },
        "--seeds": {
          "type": "string",
          "required": false,
          "desc": "blowup.hexa passthrough (seed_engine crossover 보강). 값 `auto` 시 seed_engine merge 자동 주입 — bash SSOT 완전 parity"
        }
      },
      "modes": {
        "single": "nexus-cli smash --seed \"target\" [--seeds \"s1,s2\"|auto]",
        "batch": "nexus-cli smash --batch \"t1|t2|t3\" [--seeds auto] — startup amortize"
      },
      "delegates_to": "internal — nexus 런타임",
      "gate": "cmd_gate.hexa",
      "remote_routing": true,
      "output_json": {
        "seed": "string",
        "depth": "int",
        "result": "string",
        "exit_code": "int"
      }
    },
    "free": {
      "desc": "compose 5-module DFS 탐색",
      "usage": "nexus free (--seed \"...\" | --batch \"s1|s2|...\") [--dfs 3] [--json]",
      "flags": {
        "--seed": {
          "type": "string",
          "required": false,
          "desc": "DFS 시드 (single). --batch 와 상호배타"
        },
        "--batch": {
          "type": "string",
          "required": false,
          "desc": "`|` 구분 N seed 일괄 DFS 발사 (1 dispatch)"
        },
        "--dfs": {
          "type": "int",
          "default": 3,
          "desc": "DFS 재귀 깊이"
        }
      },
      "delegates_to": "internal — nexus 런타임",
      "gate": "cmd_gate.hexa",
      "remote_routing": true,
      "output_json": {
        "seed": "string",
        "dfs": "int",
        "result": "string",
        "exit_code": "int"
      }
    },
    "absolute": {
      "desc": "Mk.VIII Δ₀-absolute Π₀¹ 검증 — arithmetical discovery 자동 [10*]→[11*] 승급",
      "usage": "nexus absolute [--seed \"...\"] [--json]",
      "flags": {
        "--seed": {
          "type": "string",
          "required": false,
          "desc": "검증 대상 seed (없으면 atlas 전체 스캔)"
        }
      },
      "delegates_to": "internal — nexus 런타임",
      "gate": "cmd_gate.hexa",
      "remote_routing": true,
      "output_json": {
        "seed": "string",
        "pi01_pass": "bool",
        "promoted": "[string]",
        "exit_code": "int"
      }
    },
    "drill": {
      "desc": "단일 명령어 사슬 — smash → free → absolute → meta-closure → hyperarithmetic → resonance (Mk.IX 6-stage), 고갈까지 자율 반복",
      "usage": "nexus drill --seed \"...\" [--max-rounds 10] [--json]",
      "flags": {
        "--seed": {
          "type": "string",
          "required": true,
          "desc": "사슬 진입 seed"
        },
        "--max-rounds": {
          "type": "int",
          "default": 10,
          "desc": "최대 라운드 수 (수렴 안 될 시 강제 종료)"
        }
      },
      "delegates_to": "internal — nexus 런타임",
      "gate": "cmd_gate.hexa",
      "saturation": "round_new == 0 → SATURATED — Δ₀-absolute 경험적 확증",
      "dod": "shared/roadmaps/drill_dod.json (yield ratio tier: scaffold/wired/serving)",
      "remote_routing": true,
      "output_json": {
        "seed": "string",
        "rounds": "int",
        "total_absorptions": "int",
        "saturated": "bool"
      }
    },
    "meta-closure": {
      "desc": "Phase 10 Meta-Closure 단일 실행 — 🛸16 self-ref 고정점 검증 + [10**] 승급",
      "usage": "nexus meta-closure [--seed \"...\"] [--json]",
      "flags": {
        "--seed": {
          "type": "string",
          "required": false,
          "desc": "역추적 대상 seed (없으면 최근 라운드)"
        }
      },
      "delegates_to": "internal — nexus 런타임",
      "gate": "cmd_gate.hexa",
      "remote_routing": true,
      "output_json": {
        "seed": "string",
        "meta_closed": "int",
        "promoted_10ss": "int",
        "rejected_h1": "int",
        "rejected_h2": "int",
        "rejected_h3": "int"
      }
    },
    "hyperarithmetic": {
      "desc": "Mk.IX Π₀² reverse-math 판정 — 5체계 (RCA₀/WKL₀/ACA₀/ATR₀/Π¹₁-CA₀) cross-check",
      "usage": "nexus hyperarithmetic --prop \"...\" [--json]",
      "flags": {
        "--prop": {
          "type": "string",
          "required": true,
          "desc": "판정 대상 Π₀² 명제 원문"
        }
      },
      "delegates_to": "internal — nexus 런타임",
      "gate": "cmd_gate.hexa",
      "remote_routing": true,
      "output_json": {
        "prop": "string",
        "pi02": "bool",
        "reduced_pi01": "bool",
        "reverse_math": "string",
        "n6_invariant": "bool"
      }
    },
    "promote": {
      "desc": "수동 등급 승급 — [12*] 는 자동 금지, 감사 로그 필수",
      "usage": "nexus promote --id <ID> --grade <10star|10starstar|11star|12star> --audit-log \"<reason>\"",
      "flags": {
        "--id": {
          "type": "string",
          "required": true,
          "desc": "atlas entry id"
        },
        "--grade": {
          "type": "string",
          "required": true,
          "enum": [
            "10star",
            "10starstar",
            "11star",
            "12star"
          ]
        },
        "--audit-log": {
          "type": "string",
          "required": true,
          "desc": "승급 사유 (shared/blowup/audit/ 저장)"
        }
      },
      "delegates_to": "internal — nexus 런타임",
      "gate": "cmd_gate.hexa",
      "output_json": {
        "id": "string",
        "from_grade": "string",
        "to_grade": "string",
        "audit_path": "string"
      }
    },
    "lens": {
      "desc": "렌즈 검색/조회",
      "usage": "nexus lens --query \"...\" [--top 5] [--json]",
      "flags": {
        "--query": {
          "type": "string",
          "required": true,
          "desc": "렌즈 검색 키워드"
        },
        "--top": {
          "type": "int",
          "default": 5,
          "desc": "상위 N개 반환"
        }
      },
      "delegates_to": "internal — nexus 런타임",
      "output_json": {
        "query": "string",
        "top": "int",
        "matches": "[{id,name,domain,score}]",
        "total": "int"
      }
    },
    "atlas": {
      "desc": "atlas.n6 검색/추가",
      "subcommands": {
        "search": {
          "usage": "nexus-cli atlas search \"...\" [--limit 10] [--json]",
          "flags": {
            "--limit": {
              "type": "int",
              "default": 10
            }
          },
          "delegates_to": "atlas_health.hexa search <query>"
        },
        "append": {
          "usage": "nexus-cli atlas append --node <json> | --edge <json> [--json]",
          "flags": {
            "--node": {
              "type": "string",
              "desc": "노드 JSON"
            },
            "--edge": {
              "type": "string",
              "desc": "엣지 JSON"
            }
          },
          "delegates_to": "atlas_health.hexa append"
        }
      },
      "output_json": {
        "action": "string",
        "results": "[object]",
        "count": "int"
      },
      "delegates_to": "internal — nexus 런타임"
    },
    "discovery": {
      "desc": "discovery_log SQLite 쿼리",
      "subcommands": {
        "query": {
          "usage": "nexus-cli discovery query \"...\" [--json]",
          "delegates_to": "discovery_query.hexa"
        }
      },
      "output_json": {
        "query": "string",
        "results": "[object]",
        "count": "int"
      },
      "delegates_to": "internal — nexus 런타임"
    },
    "roadmap": {
      "desc": "로드맵 조회",
      "subcommands": {
        "list": {
          "usage": "nexus-cli roadmap list [--project nexus] [--json]",
          "flags": {
            "--project": {
              "type": "string",
              "default": "nexus"
            }
          },
          "delegates_to": "entry.hexa roadmap list --project <project>"
        },
        "status": {
          "usage": "nexus-cli roadmap status [--project nexus] [--json]",
          "flags": {
            "--project": {
              "type": "string",
              "default": "nexus"
            }
          },
          "delegates_to": "entry.hexa roadmap status --project <project>"
        }
      },
      "output_json": {
        "project": "string",
        "phase": "string",
        "tasks": "[object]"
      },
      "delegates_to": "internal — nexus 런타임"
    },
    "bus": {
      "desc": "이벤트 버스 (향후 hive bus 연결)",
      "subcommands": {
        "publish": {
          "usage": "nexus-cli bus publish --topic <t> --payload <json> [--json]",
          "flags": {
            "--topic": {
              "type": "string",
              "required": true
            },
            "--payload": {
              "type": "string",
              "required": true
            }
          },
          "delegates_to": "entry.hexa broadcast append"
        },
        "tail": {
          "usage": "nexus-cli bus tail [--limit 20] [--json]",
          "flags": {
            "--limit": {
              "type": "int",
              "default": 20
            }
          },
          "delegates_to": "entry.hexa broadcast tail"
        },
        "history": {
          "usage": "nexus-cli bus history [--limit 50] [--json]",
          "flags": {
            "--limit": {
              "type": "int",
              "default": 50
            }
          },
          "delegates_to": "entry.hexa broadcast list"
        }
      },
      "output_json": {
        "action": "string",
        "events": "[object]",
        "count": "int"
      },
      "delegates_to": "internal — nexus 런타임"
    },
    "status": {
      "desc": "tool/loop/cl pool 전체 헬스 (인자 없음) — 프로젝트별은 status-proj",
      "usage": "nexus status [--json]",
      "delegates_to": "internal — nexus 런타임",
      "output_json": {
        "harness": "object",
        "health": "object",
        "version": "string"
      }
    },
    "version": {
      "desc": "버전 출력",
      "usage": "nexus version",
      "output": "nexus-cli 0.2.0",
      "delegates_to": "internal — nexus 런타임"
    },
    "gap": {
      "desc": "gap_monitor 1회 — 발견 누락/속도 저하 진단",
      "usage": "nexus gap",
      "delegates_to": "internal — nexus 런타임",
      "gate": "cmd_gate.hexa",
      "output_json": {}
    },
    "projects": {
      "desc": "프로젝트 리스트 출력",
      "usage": "nexus projects [table|json|names]",
      "flags": {
        "fmt": {
          "type": "string",
          "default": "table",
          "desc": "출력 포맷"
        }
      },
      "delegates_to": "internal — nexus 런타임",
      "gate": "cmd_gate.hexa",
      "output_json": {
        "projects": "[string]"
      }
    },
    "qmirror": {
      "desc": "quantum mirror — Phase 1+2 closure 8/8 cond verifier router",
      "usage": "nexus qmirror <subcmd> [flags...]",
      "delegates_to": "shared/cli/qmirror.hexa (router) → modules/qmirror/*.hexa",
      "subcommands": {
        "status": {
          "usage": "nexus qmirror status [--json]",
          "desc": "show 8/8 cond table + closure verdict",
          "cond_linkage": "ALL (cond.1..cond.8)",
          "cost": "$0 read-only"
        },
        "chsh": {
          "usage": "nexus qmirror chsh [--vendor=simulator|ionq|rigetti|ibm] [--json]",
          "desc": "CHSH Bell test, output S statistic (Tsirelson bound 2.828)",
          "flags": {
            "--vendor": {
              "type": "string",
              "default": "simulator",
              "enum": ["simulator", "ionq", "rigetti", "ibm"],
              "desc": "QPU vendor (real-QPU requires API key env)"
            }
          },
          "cond_linkage": "cond.1 (CHSH viol) + cond.3 (q-c separation)",
          "cost": "$0 simulator; live QPU per vendor pricing if key set"
        },
        "nist": {
          "usage": "nexus qmirror nist [--bits=1000000] [--json]",
          "desc": "NIST tier-1+ amplitude correlator on QRNG sample (selftest F2 proxy)",
          "flags": {
            "--bits": {
              "type": "int",
              "default": 1000000,
              "desc": "sample size in bits"
            }
          },
          "cond_linkage": "cond.2 (amplitude correlator agreement, max_err<1e-3)",
          "cost": "$0 mock LCG fixture"
        },
        "iit": {
          "usage": "nexus qmirror iit [--n-qubits=4] [--json]",
          "desc": "IIT 4.0 phi-star MIP measurement (Braket fixture reproduce)",
          "flags": {
            "--n-qubits": {
              "type": "int",
              "default": 4,
              "desc": "system size (cap=12 in iit_mip.hexa)"
            }
          },
          "cond_linkage": "cond.4 (4/4 phi-star verdicts byte-identical) + cond.6 (Braket reproduce)",
          "cost": "$0 mock; pyphi optional"
        },
        "qrng": {
          "usage": "nexus qmirror qrng [--bits=64] [--json] [--quiet]",
          "desc": "pull quantum random bits via 4-tier ANU fallback chain",
          "flags": {
            "--bits": {
              "type": "int",
              "default": 64,
              "desc": "bits to pull (rounded up to nearest byte; bytes_hex length = 2 * ceil(bits/8))"
            },
            "--quiet": {
              "type": "bool",
              "default": false,
              "desc": "with --json: route preamble/raw to stderr; pure JSON to stdout (orpheus/CI consumption)"
            }
          },
          "cond_linkage": "cond.7 (ANU paid→keyed→trial→direct→legacy fallback)",
          "cost": "$0 mock; live tiers per ANU pricing if NEXUS_QMIRROR_LIVE=1",
          "output_json_v0_2_0": {
            "qmirror": "string (CLI version)",
            "subcmd": "qrng",
            "bits": "int (requested)",
            "bytes": "int (ceil(bits/8); length of bytes_hex/2)",
            "pass": "bool",
            "bytes_hex": "string (lowercase hex; length = bytes*2)",
            "tier_used": "string ('mock-lcg-default' | 'mock-lcg-fallback' | 'anu-rest-direct' | 'unknown')",
            "mode": "string ('live' if NEXUS_QMIRROR_LIVE=1 else 'mock')"
          }
        },
        "selftest": {
          "usage": "nexus qmirror selftest [--json]",
          "desc": "full Phase 1 + Phase 2 falsifier sweep (F1+F2+F3+F4+F5)",
          "cond_linkage": "cond.8 (overall sweep PASS) + summary all 8 cond",
          "cost": "$0 CI mock; ~5-10s",
          "exit": "0 PASS, 1 any F* FAIL"
        }
      },
      "output_json": {
        "qmirror": "string (version)",
        "subcmd": "string",
        "verdict": "PASS|FAIL",
        "cond_met": "int|string"
      },
      "caveats_raw10_c3": [
        "CLI surface limited: 6 subcmds expose ~core ~10% of qmirror functionality",
        "Real-QPU subcommands need vendor API key env (IONQ_API_KEY, etc); else mock fallback",
        "selftest assumes infrastructure intact (_python_bridge, ANU fixtures, Braket dir)",
        "Future cond additions (cond.9+) need router updates — current 8/8 hardcoded"
      ]
    }
  },
  "subcmds_v2": {
    "_intro": "schema_version 2 — 7 프로젝트 일관 접근. projects[] 검증 + write 금지 + audit log.",
    "status-proj": {
      "desc": "프로젝트 건강지표 요약 (read-only)",
      "usage": "nexus-cli status-proj <project> [--json] [--caller X]",
      "positional": {
        "project": {
          "required": true,
          "enum_ref": "projects"
        }
      },
      "reads": [
        "shared/roadmaps/<project>.json (_meta + tracks keys)",
        "shared/convergence/<project>.json (optional)"
      ],
      "writes": [],
      "output_json": {
        "project": "string",
        "roadmap_exists": "bool",
        "convergence_exists": "bool",
        "roadmap_meta": "object",
        "track_count": "int",
        "total_tasks": "int|null",
        "updated": "string|null"
      },
      "exit": "0 on any project; 2 if project not in projects[]"
    },
    "roadmap-proj": {
      "desc": "프로젝트 로드맵 조회 (write 금지, next|list 전용)",
