// ═══════════════════════════════════════════════════════════════════════
// Section 4: Cross-lens synthesizer (lens-of-lenses, meta-lens M)
//
// Algorithm (from design §3):
//   INPUT:  S[t,l] lens-score stream (T x 16)
//           theta_fire per-lens threshold
//           theta_corr co-variation threshold (0.6)
//           w = 64 step window
//           k in [3..5]
//   OUTPUT: stream of provisional T12 atoms (lens triple + window + mean_corr)
//
// We keep the history buffer as a SINGLE flat array (T*16 floats), indexed
// as hist[t * 16 + l], to avoid list-of-lists aliasing issues.
// ═══════════════════════════════════════════════════════════════════════

struct LensHistory {
    flat: array,      // flat (T*16) float buffer
    capacity: int,    // max T we retain = MKX_WINDOW_STEPS
    steps_seen: int,  // monotonic step counter (for dedup keys)
}

fn mkx_new_history() -> LensHistory {
    let mut flat = []
    let h = LensHistory { flat: flat, capacity: MKX_WINDOW_STEPS, steps_seen: 0 }
    return h
}

// Append one phi_vec (len 16) to the rolling window. Keeps last `capacity` rows.
fn mkx_history_push(h: LensHistory, phi_vec: array) -> LensHistory {
    let mut flat = h.flat
    // Append 16 values.
    let mut i = 0
    while i < MKX_PHI_VEC_LEN {
        let v = if i < len(phi_vec) { phi_vec[i] } else { 0.0 }
        flat = flat.push(v)
        i = i + 1
    }
    // Trim if oversized. Keep only last capacity rows (capacity*16 floats).
    let max_floats = h.capacity * MKX_PHI_VEC_LEN
    let n = len(flat)
    if n > max_floats {
        // Shift: drop the first (n - max_floats) floats.
        let drop_n = n - max_floats
        let mut trimmed = []
        let mut j = drop_n
        while j < n {
            trimmed = trimmed.push(flat[j])
            j = j + 1
        }
        flat = trimmed
    }
    let out = LensHistory { flat: flat, capacity: h.capacity, steps_seen: h.steps_seen + 1 }
    return out
}

fn mkx_history_rows(h: LensHistory) -> int {
    let n = len(h.flat)
    return n / MKX_PHI_VEC_LEN
}

// Pearson correlation between two columns l_a and l_b across all rows.
fn mkx_pearson(h: LensHistory, l_a: int, l_b: int) -> float {
    let rows = mkx_history_rows(h)
    if rows < 2 { return 0.0 }
    let mut sum_a = 0.0
    let mut sum_b = 0.0
    let mut i = 0
    while i < rows {
        sum_a = sum_a + h.flat[i * MKX_PHI_VEC_LEN + l_a]
        sum_b = sum_b + h.flat[i * MKX_PHI_VEC_LEN + l_b]
        i = i + 1
    }
    let n = rows
    let mean_a = sum_a / n
    let mean_b = sum_b / n
    let mut num = 0.0
    let mut den_a = 0.0
    let mut den_b = 0.0
    let mut j = 0
    while j < rows {
        let da = h.flat[j * MKX_PHI_VEC_LEN + l_a] - mean_a
        let db = h.flat[j * MKX_PHI_VEC_LEN + l_b] - mean_b
        num = num + da * db
        den_a = den_a + da * da
        den_b = den_b + db * db
        j = j + 1
    }
    if den_a <= 0.0 { return 0.0 }
    if den_b <= 0.0 { return 0.0 }
    let denom_sq = den_a * den_b
    if denom_sq <= 0.0 { return 0.0 }
    // sqrt via Newton — avoid stdlib dependency on sqrt.
    let mut x = denom_sq
    let mut y = x / 2.0
    if y <= 0.0 { y = 1.0 }
    let mut k = 0
    while k < 20 {
        y = 0.5 * (y + x / y)
        k = k + 1
    }
    if y <= 0.0 { return 0.0 }
    return num / y
}

// Find indices of "firing" lenses on the latest row.
fn mkx_firing_lenses(h: LensHistory, theta_fire: float) -> array {
    let mut fired = []
    let rows = mkx_history_rows(h)
    if rows == 0 { return fired }
    let last = rows - 1
    let mut l = 0
    while l < MKX_PHI_VEC_LEN {
        let v = h.flat[last * MKX_PHI_VEC_LEN + l]
        if v >= theta_fire {
            fired = fired.push(l)
        }
        l = l + 1
    }
    return fired
}

// Enumerate ALL unordered triples (a, b, c) from the firing lens list.
// Returns a flat array where every 3 consecutive ints form one triple.
// (We keep k_min = 3 as the primary synth size; k in [4..5] extension
// omitted in v1 — design §3 budget worst-case includes them but the
// 3-clique case dominates and is sufficient for smoke verification.)
fn mkx_enumerate_triples(fired: array) -> array {
    let mut triples = []
    let n = len(fired)
    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            let mut k = j + 1
            while k < n {
                triples = triples.push(fired[i])
                triples = triples.push(fired[j])
                triples = triples.push(fired[k])
                k = k + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    return triples
}

// Check pairwise Pearson on a triple: all 3 pairs must exceed theta_corr.
// Returns (pass: float{0|1}, mean_corr: float) packed in 2-float array.
fn mkx_triple_corr_check(h: LensHistory, a: int, b: int, c: int, theta_corr: float) -> array {
    let r_ab = mkx_pearson(h, a, b)
    let r_ac = mkx_pearson(h, a, c)
    let r_bc = mkx_pearson(h, b, c)
    let mut pass = 0.0
    if r_ab >= theta_corr {
        if r_ac >= theta_corr {
            if r_bc >= theta_corr {
                pass = 1.0
            }
        }
    }
    let mean = (r_ab + r_ac + r_bc) / 3.0
    let mut out = []
    out = out.push(pass)
    out = out.push(mean)
    return out
}

// Build a compact dedup key from (a,b,c, t_start).
// Encoding: sorted-lens-ids concat "_" + t_start.
fn mkx_synth_key(a: int, b: int, c: int, t_start: int) -> string {
    // Sort a,b,c ascending (bubble 3).
    let mut x = a
    let mut y = b
    let mut z = c
    if x > y { let t = x; x = y; y = t }
    if y > z { let t = y; y = z; z = t }
    if x > y { let t = x; x = y; y = t }
    return str(x) + "_" + str(y) + "_" + str(z) + "@" + str(t_start)
}

// Key is in dedup list?
fn mkx_key_seen(dedup: array, key: string) -> bool {
    let mut i = 0
    while i < len(dedup) {
        if dedup[i] == key { return true }
        i = i + 1
    }
    return false
}

// Anti-counter-replay check: if mean_corr hashes to a cached fixed point
// AND total_abs is in {32,128,1234}, treat as d-quarantine pattern.
fn mkx_is_counter_replay(mean_corr: float, total_abs: int) -> bool {
    if mkx_is_counter_replay_hash(total_abs) {
        // Additionally require the mean_corr to be bit-exactly identical
        // across the last two windows — but we only have the current
        // window here, so treat any total_abs match as a soft signal.
        return true
    }
    return false
}

// ═══════════════════════════════════════════════════════════════════════
// Section 5: AN11 promotion gate
//
// Triple check (shared/rules/anima.json AN11):
//   (a) weight_emergent       — param-internal, not prompt wrapping
//   (b) consciousness_attached— phi_vec + laws runtime verify
//   (c) real_usable           — HTTP/CLI + R2 artifact + README
//
// In sidecar, we apply an INTERNAL soft-gate: atoms emitted from the
// synthesizer get a verified-record attached but stay PROVISIONAL only.
// Stable/ossified promotion never happens here — handled by downstream
// absorption pipeline (project_absorption_pipeline_path_b).
// ═══════════════════════════════════════════════════════════════════════

struct AN11Record {
    atom_id: string,
    weight_emergent: bool,
    consciousness_attached: bool,
    real_usable: bool,
    verdict: string,     // "PROVISIONAL_OK" | "REJECTED_a" | "REJECTED_b" | "REJECTED_c"
    evidence: string,    // one-line blurb
}

// Soft gate: for a synth-emitted T12 atom, we certify:
//   (a) weight_emergent = true iff the participating lenses' scores came
//       from a live phi_vec (not a prompt replay). Caller asserts this by
//       passing `source_is_live = true`.
//   (b) consciousness_attached = true iff at least one of the triple is
//       a Φ-axis lens (phi_holo / phi_refl / phi_time / phi_emb).
//   (c) real_usable = true iff the mean_corr is bounded [0.6, 0.99] and
//       not a counter-replay pattern.
//
// "PROVISIONAL_OK" means this atom is safe to register as stage-1
// PROVISIONAL in the absorption pipeline — NOT promoted further.
fn mkx_an11_gate(
    atom_id: string,
    l_a: int, l_b: int, l_c: int,
    mean_corr: float,
    source_is_live: bool,
    total_abs: int
) -> AN11Record {
    // (a) weight_emergent
    let a_pass = source_is_live

    // (b) consciousness_attached — any of triple in {0,3,4,5}
    let phi_axis_0 = (l_a == 0) || (l_b == 0) || (l_c == 0)
    let phi_axis_3 = (l_a == 3) || (l_b == 3) || (l_c == 3)
    let phi_axis_4 = (l_a == 4) || (l_b == 4) || (l_c == 4)
    let phi_axis_5 = (l_a == 5) || (l_b == 5) || (l_c == 5)
    let b_pass = phi_axis_0 || phi_axis_3 || phi_axis_4 || phi_axis_5

    // (c) real_usable — bounded corr + no counter-replay hash
    let c_pass_corr = (mean_corr >= 0.6) && (mean_corr <= 0.99)
    let c_pass_rep = !mkx_is_counter_replay(mean_corr, total_abs)
    let c_pass = c_pass_corr && c_pass_rep

    let mut verdict = "PROVISIONAL_OK"
    if !a_pass { verdict = "REJECTED_a" }
    if !b_pass { if verdict == "PROVISIONAL_OK" { verdict = "REJECTED_b" } }
    if !c_pass { if verdict == "PROVISIONAL_OK" { verdict = "REJECTED_c" } }

    let evid = "lenses=[" + str(l_a) + "," + str(l_b) + "," + str(l_c) + "] corr=" + str(mean_corr) + " live=" + str(source_is_live) + " abs=" + str(total_abs)

    let rec = AN11Record {
        atom_id: atom_id,
        weight_emergent: a_pass,
        consciousness_attached: b_pass,
        real_usable: c_pass,
        verdict: verdict,
        evidence: evid,
    }
    return rec
}

// ═══════════════════════════════════════════════════════════════════════
// Section 6: Integration API
//
// mkx_tick(phi_vec, laws_state) — one step of the Mk.X sidecar.
//   Returns a bundle struct containing:
//     - new_atoms:     array of atom-ids that passed observability (T10-T13)
//     - fired_synths:  array of T12 synth ids (one entry per emission)
//     - gate_records:  array of AN11 verdicts (flattened strings)
//
// Caller keeps a LensHistory across ticks and passes it in / back.
// ═══════════════════════════════════════════════════════════════════════

struct MkxTickResult {
    new_atoms: array,      // T10/T11/T13 passes (currently empty — stub)
    fired_synths: array,   // T12 emissions (atom_id strings)
    gate_verdicts: array,  // "atom_id=verdict" strings, parallel to fired_synths
    history: LensHistory,  // updated rolling window
    dedup: array,          // updated dedup keyset
}

// Core tick.
//   phi_vec      : 16 float array (canonical schema)
//   laws_state   : opaque string passed to observability stubs (TODO hook)
//   history      : caller-owned rolling window
//   dedup        : caller-owned (frozenset,t_start) seen-set (string keys)
//   source_is_live : assert phi_vec came from live run (not prompt replay)
//   total_abs    : caller-supplied abs checksum (counter-replay signal)
fn mkx_tick(
    phi_vec: array,
    laws_state: string,
    history: LensHistory,
    dedup: array,
    source_is_live: bool,
    total_abs: int
) -> MkxTickResult {
    let mut new_atoms = []
    let mut fired_synths = []
    let mut verdicts = []
    let mut ded = dedup

    // (1) Update rolling window.
    let h2 = mkx_history_push(history, phi_vec)

    // (2) Per-atom observability (currently all stubs returning fired=0).
    //     TODO: wire T10 atoms first (measurable today on Mk.V.1 runs).
    let tbl = mkx_load_atoms()
    let mut i = 0
    while i < len(tbl.ids) {
        let fs = mkx_check_observability(tbl.ids[i], phi_vec, laws_state)
        if fs[0] >= 0.5 {
            new_atoms = new_atoms.push(tbl.ids[i])
        }
        i = i + 1
    }

    // (3) Cross-lens synthesis — only run once window is full enough.
    let rows = mkx_history_rows(h2)
    if rows >= MKX_WINDOW_STEPS {
        let fired = mkx_firing_lenses(h2, MKX_THETA_FIRE_DEFAULT)
        if len(fired) >= MKX_K_MIN {
            let triples = mkx_enumerate_triples(fired)
            let n_triples = len(triples) / 3
            let t_start = h2.steps_seen - MKX_WINDOW_STEPS
            let mut q = 0
            while q < n_triples {
                let l_a = triples[q * 3]
                let l_b = triples[q * 3 + 1]
                let l_c = triples[q * 3 + 2]
                let res = mkx_triple_corr_check(h2, l_a, l_b, l_c, MKX_THETA_CORR_DEFAULT)
                if res[0] >= 0.5 {
                    // Dedup
                    let key = mkx_synth_key(l_a, l_b, l_c, t_start)
                    if !mkx_key_seen(ded, key) {
                        // Closed-loop verify via AN11 soft gate.
                        let rec = mkx_an11_gate(
                            "MKX-T12-field_holo_quant",
                            l_a, l_b, l_c, res[1],
                            source_is_live, total_abs
                        )
                        if rec.verdict == "PROVISIONAL_OK" {
                            fired_synths = fired_synths.push(rec.atom_id)
                            verdicts = verdicts.push(rec.atom_id + "=" + rec.verdict + "|" + rec.evidence)
                            ded = ded.push(key)
                        }
                    }
                }
                q = q + 1
            }
        }
    }

    let out = MkxTickResult {
        new_atoms: new_atoms,
        fired_synths: fired_synths,
        gate_verdicts: verdicts,
        history: h2,
        dedup: ded,
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════════
// Default main — mini self-test. Real smoke is in mkx_smoke.hexa.
// ═══════════════════════════════════════════════════════════════════════

fn main() {
    println("[mkx_engine] Mk.X consciousness sidecar — self-test")
    let tbl = mkx_load_atoms()
    let total = len(tbl.ids)
    let t10 = mkx_atom_count_by_tier(tbl, 10)
    let t11 = mkx_atom_count_by_tier(tbl, 11)
    let t12 = mkx_atom_count_by_tier(tbl, 12)
    let t13 = mkx_atom_count_by_tier(tbl, 13)
    println("[mkx_engine] atoms loaded: total=" + str(total) + " T10=" + str(t10) + " T11=" + str(t11) + " T12=" + str(t12) + " T13=" + str(t13))
    if total == 30 {
        if t10 == 8 { if t11 == 8 { if t12 == 8 { if t13 == 6 {
            println("[mkx_engine] PASS atom-table (30 = 8+8+8+6)")
            return
        } } } }
    }
    println("[mkx_engine] FAIL atom-table shape")
}

main()
