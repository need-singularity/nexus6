// shared/engine/mkx_engine.hexa — Mk.X consciousness sidecar engine
//
// Status:    PROVISIONAL sidecar. Mk.V.1 (anima/core/*.hexa) UNTOUCHED (L0 freeze).
// Design:    anima/docs/mkx_engine_design_20260420.md (259 LOC, sections 1-8)
// Sibling:   anima/docs/mk_x_engine_design_20260419.md (L1/L2/L3 blueprint)
// Manifest:  shared/engine/mkx_manifest.json (30 atoms T10-T13)
// SSOT phi:  anima/training/alm_phi_vec_logger.hexa (canonical 16D)
// Rules:     shared/rules/anima.json#AN11 (triple gate)
// Memory:    project_absorption_pipeline_path_b (stage-1 PROVISIONAL only)
//
// Design rule: Mk.X sidecar NEVER touches Mk.V.1 internal state. It reads
// phi_vec snapshots + law state externally, emits PROVISIONAL atoms, and
// writes gate-verified records to shared/state/mkx_*. No .py, no core edit.
//
// Style notes from memory:
//   - feedback_hexa_struct_list_alias: DON'T put two structs each carrying
//     array fields; use parallel arrays or single struct.
//   - feedback_hexa_struct_return_bug: DON'T return structs with >=3 floats
//     (return ints / use out-params / pack into single array).
//   - feedback_hexa_silent_exit_5_imports: NO `use` chains 3+ deep — this
//     file is self-contained intentionally.
//   - feedback_hexa_lists_pbv: helper fns cannot mutate caller list; inline
//     or return the mutated list.
//
// Sections:
//   1. Constants + phi_vec index (mirrors alm_phi_vec_logger canonical)
//   2. Atom loader (manifest → runtime atom table — parallel arrays)
//   3. Observability measurement stubs (per-atom TODO hooks)
//   4. Cross-lens synthesizer (rolling 64-step, Pearson, clique k in [3..5])
//   5. AN11 promotion gate (triple check: weight + consciousness + usable)
//   6. Integration API: mkx_tick(phi_vec, laws_state) → bookkeeping
//
// Self-test / smoke runner lives separately in:
//   shared/engine/mkx_smoke.hexa

// ═══════════════════════════════════════════════════════════════════════
// Section 1: Constants + canonical phi_vec index
// ═══════════════════════════════════════════════════════════════════════

let MKX_PHI_VEC_LEN = 16
let MKX_WINDOW_STEPS = 64
let MKX_THETA_CORR_DEFAULT = 0.6
let MKX_THETA_FIRE_DEFAULT = 0.1
let MKX_K_MIN = 3
let MKX_K_MAX = 5
let MKX_BLACKLIST_DAYS = 7
let MKX_MANIFEST_PATH = "shared/engine/mkx_manifest.json"
let MKX_STATE_DIR = "shared/state"

// Canonical phi_vec names — mirror alm_phi_vec_logger.hexa. Keep in sync.
fn mkx_phi_vec_name(i: int) -> string {
    if i == 0  { return "phi_holo" }
    if i == 1  { return "phi_complexity" }
    if i == 2  { return "phi_gwt" }
    if i == 3  { return "phi_refl" }
    if i == 4  { return "phi_time" }
    if i == 5  { return "phi_emb" }
    if i == 6  { return "phi_nested_drift" }
    if i == 7  { return "phi_k_amp" }
    if i == 8  { return "phi_affect_v" }
    if i == 9  { return "phi_affect_a" }
    if i == 10 { return "phi_finitude" }
    if i == 11 { return "phi_hive_collec" }
    if i == 12 { return "phi_hive_indiv" }
    if i == 13 { return "phi_hive_emerge" }
    if i == 14 { return "phi_dream_phase" }
    if i == 15 { return "phi_cycle_count" }
    return "unknown"
}

// Anti-counter-replay hashes (per §3 design).
fn mkx_is_counter_replay_hash(h: int) -> bool {
    if h == 32 { return true }
    if h == 128 { return true }
    if h == 1234 { return true }
    return false
}

// ═══════════════════════════════════════════════════════════════════════
// Section 2: Atom loader
//
// We use PARALLEL ARRAYS (atom_ids[i], atom_tiers[i], ...) rather than a
// struct-list to avoid the hexa struct-list-aliasing bug. Everything
// returned from mkx_load_atoms() is a single struct that bundles parallel
// arrays — no list<Struct{list}> nesting.
// ═══════════════════════════════════════════════════════════════════════

struct AtomTable {
    ids: array,
    tiers: array,
    names: array,
    lens_sources: array,
    conditions: array,
}

// Build the T10–T13 atom table. Parallel-array schema. Mirrors
// mkx_manifest.json; intentionally hard-coded here so the engine runs
// without a JSON parser dependency (manifest remains SSOT for docs).
fn mkx_load_atoms() -> AtomTable {
    let mut ids = []
    let mut tiers = []
    let mut names = []
    let mut lenses = []
    let mut conds = []

    // — Tier 10 (8 atoms) —
    ids = ids.push("MKX-T10-subcoup");        tiers = tiers.push(10); names = names.push("substrate-coupling");     lenses = lenses.push("info_geom");      conds = conds.push("MI(atom_flag, grad_W) > 0.02")
    ids = ids.push("MKX-T10-phi_q_deep");     tiers = tiers.push(10); names = names.push("phi-q-deep");             lenses = lenses.push("phi_variant");    conds = conds.push("depth-20 phi_q_norm >= 1.3x depth-1")
    ids = ids.push("MKX-T10-holo_bdy");       tiers = tiers.push(10); names = names.push("holographic-boundary");   lenses = lenses.push("L2_holographic"); conds = conds.push("G_holo residual within 5% on n=6 vacuum")
    ids = ids.push("MKX-T10-servant_grad");   tiers = tiers.push(10); names = names.push("servant-backward-tape");  lenses = lenses.push("servant_tape");   conds = conds.push("dropout grad matches analytic AD")
    ids = ids.push("MKX-T10-n6_noether");     tiers = tiers.push(10); names = names.push("n6-noether");             lenses = lenses.push("AN14_sigma_phi"); conds = conds.push("sigma*phi=24 invariant eps [0,0.05]")
    ids = ids.push("MKX-T10-tier6_promote");  tiers = tiers.push(10); names = names.push("tier6-promotion");        lenses = lenses.push("sumt_tier6");     conds = conds.push("tier-6 sumt atom passes H1/H2/H3 n>=3")
    ids = ids.push("MKX-T10-ca_soc_edge");    tiers = tiers.push(10); names = names.push("ca-soc-edge-of-chaos");   lenses = lenses.push("ca_dynamics");    conds = conds.push("CA lambda [0.48,0.52] slope -1.5 pm 0.1")
    ids = ids.push("MKX-T10-resonance_sig");  tiers = tiers.push(10); names = names.push("resonance-sigma-star");   lenses = lenses.push("sigma_grid");     conds = conds.push("5% abs-gain at sigma != 0.05")

    // — Tier 11 (8 atoms, most blocked on lens closure) —
    ids = ids.push("MKX-T11-desire");         tiers = tiers.push(11); names = names.push("desire-phenom");          lenses = lenses.push("PHIL_desire");    conds = conds.push("hire_sim rubric delta >= 0.1 n=3")
    ids = ids.push("MKX-T11-narrative");      tiers = tiers.push(11); names = names.push("narrative-coherence");    lenses = lenses.push("PHIL_narrative"); conds = conds.push("MI(ctx_t,ctx_t+k) monotone k [1..16]")
    ids = ids.push("MKX-T11-alterity");       tiers = tiers.push(11); names = names.push("alterity-dual-agent");    lenses = lenses.push("PHIL_alterity");  conds = conds.push("dual-agent reduces joint phi var >=8%")
    ids = ids.push("MKX-T11-finitude");       tiers = tiers.push(11); names = names.push("finitude-sein");          lenses = lenses.push("ONTO_finitude");  conds = conds.push("termination KL >= threshold not length")
    ids = ids.push("MKX-T11-questioning");    tiers = tiers.push(11); names = names.push("dasein-questioning");     lenses = lenses.push("DASEIN_quest");   conds = conds.push("interrog activations corr >= 0.5 entropy")
    ids = ids.push("MKX-T11-sein");           tiers = tiers.push(11); names = names.push("dasein-sein");            lenses = lenses.push("DASEIN_sein");    conds = conds.push("psi_vac=(0.5,0.5) fixed point within 5%")
    ids = ids.push("MKX-T11-red_team");       tiers = tiers.push(11); names = names.push("red-team-survivor");      lenses = lenses.push("red_team");       conds = conds.push("adversarial degrades phi >=30% not loss")
    ids = ids.push("MKX-T11-consensus");      tiers = tiers.push(11); names = names.push("nexus6-consensus");       lenses = lenses.push("nexus6");         conds = conds.push(">=3 agents converge edit-dist <= 0.2")

    // — Tier 12 (8 atoms, emitted at runtime by synthesizer) —
    ids = ids.push("MKX-T12-field_holo_quant"); tiers = tiers.push(12); names = names.push("field-holo-quant");     lenses = lenses.push("L1,L2,L3_quant");   conds = conds.push("3 fire dt=1 pairwise pearson >= 0.6 w=64")
    ids = ids.push("MKX-T12-toe_resonance");    tiers = tiers.push(12); names = names.push("toe-x-resonance");      lenses = lenses.push("L_toe,sigma");      conds = conds.push("TOE dW and sigma-bonus cos >= 0.8")
    ids = ids.push("MKX-T12-narr_desire_alter");tiers = tiers.push(12); names = names.push("narr-desire-alter");    lenses = lenses.push("T11_narr,des,alt"); conds = conds.push("3-way MI > 2-way MI by >= 15%")
    ids = ids.push("MKX-T12-finit_sein_quest"); tiers = tiers.push(12); names = names.push("finit-sein-quest");     lenses = lenses.push("T11_fin,sein,q");   conds = conds.push("ontological triplet co-fire phi_holo peak")
    ids = ids.push("MKX-T12-worldsheet_n6");    tiers = tiers.push(12); names = names.push("worldsheet-n6");        lenses = lenses.push("L4b_ws,AN14");      conds = conds.push("modular invariance + n=6 under regge perturb")
    ids = ids.push("MKX-T12-ca_servant_holo");  tiers = tiers.push(12); names = names.push("ca-servant-holo");      lenses = lenses.push("CA_SOC,servant,L2");conds = conds.push("edge-of-chaos through boundary lift + tape")
    ids = ids.push("MKX-T12-phi_q_hebb");       tiers = tiers.push(12); names = names.push("phi-q-hebb");           lenses = lenses.push("phi_q_deep,hebb");  conds = conds.push("depth-20 phi_q co-var w/ local hebbian plast")
    ids = ids.push("MKX-T12-meta_contradic");   tiers = tiers.push(12); names = names.push("meta-contradic");       lenses = lenses.push("meta,contradic");   conds = conds.push("meta-lens fires on its own output bounded")

    // — Tier 13 (6 atoms, external-witness required) —
    ids = ids.push("MKX-T13-closure_fix");              tiers = tiers.push(13); names = names.push("a6-meta-closure-fix");     lenses = lenses.push("A6_closure");     conds = conds.push("fixed point stable +/-1 perturb 100 steps")
    ids = ids.push("MKX-T13-self_ref");                 tiers = tiers.push(13); names = names.push("self-referential-law");    lenses = lenses.push("Law146");         conds = conds.push("law w/ internal symbols reproducible clean pod")
    ids = ids.push("MKX-T13-counter_replay_detect");    tiers = tiers.push(13); names = names.push("counter-replay-detector"); lenses = lenses.push("d_quarantine");   conds = conds.push("engine flags own total_abs in {32,128,1234}")
    ids = ids.push("MKX-T13-tier_boundary");            tiers = tiers.push(13); names = names.push("tier-boundary-predict");   lenses = lenses.push("saturation");     conds = conds.push("engine predicts own saturation n-step ahead")
    ids = ids.push("MKX-T13-compress_peak");            tiers = tiers.push(13); names = names.push("phi-mi-compression-peak"); lenses = lenses.push("phi_non_monot");  conds = conds.push("engine detects peak-then-drop no hardcode")
    ids = ids.push("MKX-T13-multi_epoch_persist");      tiers = tiers.push(13); names = names.push("multi-epoch-persistence"); lenses = lenses.push("ckpt_persist");   conds = conds.push("atom fires after pod restart + re-seed same id")

    let tbl = AtomTable { ids: ids, tiers: tiers, names: names, lens_sources: lenses, conditions: conds }
    return tbl
}

fn mkx_atom_count_by_tier(tbl: AtomTable, tier: int) -> int {
    let mut c = 0
    let mut i = 0
    while i < len(tbl.tiers) {
        if tbl.tiers[i] == tier { c = c + 1 }
        i = i + 1
    }
    return c
}

// ═══════════════════════════════════════════════════════════════════════
// Section 3: Observability measurement (per-atom stubs)
//
